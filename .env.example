# Canonical site URL (sitemap, robots, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.sectorcalc.com

# Stripe checkout (server-side only — set in Firebase Functions)
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET must NOT be prefixed with NEXT_PUBLIC_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE_REPORT=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=

# Legacy Firebase Function param names (deployed checkout may still use these)
# STRIPE_PRICE_SINGLE_VERDICT=price_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_TEAM=price_...

# Public checkout endpoint (optional — falls back to Cloud Function URL from project id)
NEXT_PUBLIC_STRIPE_CHECKOUT_FUNCTION_URL=

# Kredi billing (sonra doldur — boş bırakılabilir, project id'den URL türetilir)
NEXT_PUBLIC_CREDIT_CHECKOUT_FUNCTION_URL=
NEXT_PUBLIC_SPEND_CREDITS_FUNCTION_URL=

# Firebase public client config
# These are public Firebase client values, not server secrets.
NEXT_PUBLIC_FIREBASE_API_KEY=your_public_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Admin-light is deprecated.
# /admin/leads uses Firebase Auth admin claim instead.
# Do not enable admin-light in public production.
# NEXT_PUBLIC_ENABLE_ADMIN_LIGHT=true

# Admin lead write
# Uses Firebase HTTPS Function + Firebase Auth admin custom claim.
# Safe to expose: feature flag and function URL.
# Do not expose ADMIN_LEAD_UPDATE_SECRET in frontend env.
NEXT_PUBLIC_ENABLE_ADMIN_LEAD_WRITE=false
NEXT_PUBLIC_ADMIN_LEAD_UPDATE_URL=https://your-function-url
NEXT_PUBLIC_ADMIN_TEST_CLASSIFICATION_URL=https://your-test-classification-function-url

# Smart Form pilot (staging only — rebuild required after change)
# NEXT_PUBLIC_SMART_FORM_PILOT=false

# Local scripts only
# Never commit the actual service account JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Set admin claim example:
# export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# node scripts/set-admin-claim.mjs FIREBASE_AUTH_UID

# OpenAI AI Repair Layer (server-side only — never expose in NEXT_PUBLIC_*)
OPENAI_API_KEY=""
OPENAI_REPAIR_MODEL="gpt-5.5"
AI_MAX_INPUT_CHARS="12000"

# DeepSeek AI Repair Layer (server-side only — never expose in NEXT_PUBLIC_*)
AI_REPAIR_PROVIDER="deepseek"
AI_REPAIR_ROUTING_MODE="balanced-pro"

# DeepSeek API key (required)
DEEPSEEK_API_KEY=""

# Core client model overrides (optional — per-task defaults in deepseek-types.ts)
# DEEPSEEK_MODEL="deepseek-chat"
# DEEPSEEK_TIMEOUT_MS=20000

# Repair layer model names (customer AI also uses these)
# DEEPSEEK_REPAIR_MODEL="deepseek-chat"
# DEEPSEEK_REPAIR_PRO_MODEL="deepseek-reasoner"

# Repair routing
AI_REPAIR_FLASH_TARGET="50"
AI_REPAIR_PRO_TARGET="45"
AI_REPAIR_HUMAN_REVIEW_TARGET="5"

AI_REPAIR_ESCALATION_ENABLED="true"

AI_REPAIR_HISTORY_ENABLED="true"
AI_REPAIR_FLASH_FAILURE_THRESHOLD="2"
AI_REPAIR_PRO_FAILURE_THRESHOLD="2"
AI_REPAIR_HISTORY_MAX_DAYS="30"

# Customer AI Gateway (server-side only — never expose in NEXT_PUBLIC_*)
AI_CUSTOMER_ASSISTANT_ENABLED="true"
AI_CUSTOMER_FLASH_MODEL="deepseek-chat"
AI_CUSTOMER_PRO_MODEL="deepseek-reasoner"
AI_CUSTOMER_MAX_INPUT_CHARS="2000"
AI_CUSTOMER_DAILY_LIMIT="30"

# Public calculate API (server-side only — /api-public/calculate/[slug])
PUBLIC_CALCULATE_RATE_LIMIT="60"
PUBLIC_CALCULATE_RATE_WINDOW_MS="60000"
# Optional distributed rate limiting (Upstash Redis REST — leave empty for in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tool Activation Factory (first reference apply lock)
TOOL_ACTIVATION_REFERENCE_SLUG=""

# Sentry (optional — enable when DSN is configured)
# Client DSN (public). Server can reuse the same value via SENTRY_DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Source map upload during CI/build (server-side only — never commit)
SENTRY_AUTH_TOKEN=

# ── Document Intelligence (Maintenance BOM Recovery) ─────────────
# Feature flag — set to "true" to enable Document Intelligence functionality
DOCUMENT_INTELLIGENCE_ENABLED=false
MAINTENANCE_BOM_PRICE_USD=149
MAINTENANCE_BOM_MAX_FILE_BYTES=52428800
MAINTENANCE_BOM_MAX_PAGES=50
MAINTENANCE_BOM_MAX_ROWS=500
MAINTENANCE_BOM_SOURCE_RETENTION_HOURS=24
MAINTENANCE_BOM_OUTPUT_RETENTION_DAYS=7
MAINTENANCE_BOM_ENGINE_VERSION=1.0.0
MAINTENANCE_BOM_VALIDATOR_VERSION=1.0.0
MAINTENANCE_BOM_SCHEMA_VERSION=1.0.0
DOCUMENT_PROCESSOR_PROVIDER=mock
DOCUMENT_PROCESSOR_ENDPOINT=
DOCUMENT_PROCESSOR_SECRET=
DOCUMENT_PROCESSOR_SERVICE_ACCOUNT=
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=us-central1
DOCUMENT_WORKER_URL=
PADDLE_MAINTENANCE_BOM_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
SIGNED_URL_TTL_SECONDS=300

# Lokalise TMS — translation management system
# https://app.lokalise.com/profile → API tokens (Read/Write)
LOKALISE_TOKEN=
LOKALISE_PROJECT_ID=
# OTA SDK token for over-the-air translation updates (public — may be NEXT_PUBLIC_*)
NEXT_PUBLIC_LOKALISE_OTA_TOKEN=
# Feature flag: "true" enables Lokalise live pull (OTA + API)
NEXT_PUBLIC_TMS_ENABLED=false
# Server-side live pull: "true" enables runtime fetch from Lokalise API
LOKALISE_LIVE_PULL=false
# OTA app version string
LOKALISE_OTA_APP_VERSION=1.0.0

# ── Document Intelligence (Maintenance BOM Recovery) ──────────────────────
# Feature flag: "true" enables DI upload, checkout, and processing APIs
DOCUMENT_INTELLIGENCE_ENABLED=false
# Product registry: immutable price in credits
MAINTENANCE_BOM_PRICE_CREDITS=149
# Server-enforced limits
MAINTENANCE_BOM_MAX_FILE_BYTES=52428800
MAINTENANCE_BOM_MAX_PAGES=50
MAINTENANCE_BOM_MAX_ROWS=500
# Engine and schema versions
MAINTENANCE_BOM_ENGINE_VERSION=1.0.0
MAINTENANCE_BOM_VALIDATOR_VERSION=1.0.0
MAINTENANCE_BOM_SCHEMA_VERSION=1.0.0
# Retention (overridable)
MAINTENANCE_BOM_SOURCE_RETENTION_HOURS=24
MAINTENANCE_BOM_OUTPUT_RETENTION_DAYS=7
# External processor (set when provisioned)
DOCUMENT_PROCESSOR_PROVIDER=
DOCUMENT_PROCESSOR_ENDPOINT=
DOCUMENT_PROCESSOR_SECRET=
DOCUMENT_PROCESSOR_SERVICE_ACCOUNT=
# Cloud Tasks (set when queue is provisioned)
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=
DOCUMENT_WORKER_URL=
# Paddle billing (set when Paddle product is created)
PADDLE_MAINTENANCE_BOM_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
# Signed URL TTL
SIGNED_URL_TTL_SECONDS=300

# Canonical site URL (sitemap, robots, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://sectorcalc.com

# Firebase public client config
# These are public Firebase client values, not server secrets.
NEXT_PUBLIC_FIREBASE_API_KEY=your_public_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Admin-light is deprecated.
# /admin/leads uses Firebase Auth admin claim instead.
# Do not enable admin-light in public production.
# NEXT_PUBLIC_ENABLE_ADMIN_LIGHT=true

# Admin lead write
# Uses Firebase HTTPS Function + Firebase Auth admin custom claim.
# Safe to expose: feature flag and function URL.
# Do not expose ADMIN_LEAD_UPDATE_SECRET in frontend env.
NEXT_PUBLIC_ENABLE_ADMIN_LEAD_WRITE=false
NEXT_PUBLIC_ADMIN_LEAD_UPDATE_URL=https://your-function-url
NEXT_PUBLIC_ADMIN_TEST_CLASSIFICATION_URL=https://your-test-classification-function-url

# Local scripts only
# Never commit the actual service account JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Set admin claim example:
# export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# node scripts/set-admin-claim.mjs FIREBASE_AUTH_UID

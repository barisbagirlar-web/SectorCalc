{
  "id": "donusturulebilir_not_hesabi",
  "name": "Dönüştürülebilir Not Hesabı",
  "description": "Borç senedinin hisseye dönüşmesiyle alınan hisse adedini hesaplar. Yatırım tutarı, değerleme, iskonto ve faiz oranına göre dönüşüm fiyatı ve hisse adedi belirlenir.",
  "category": "Finans",
  "inputs": [
    {
      "id": "yatirim",
      "name": "Yatırım",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999999
    },
    {
      "id": "degerleme",
      "name": "Değerleme",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999999
    },
    {
      "id": "iskonto",
      "name": "İskonto",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "faiz",
      "name": "Faiz",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "donusum_fiyati",
      "name": "Dönüşüm Fiyatı",
      "unit": "TL",
      "description": "Değerleme üzerinden iskonto düşülerek bulunan hisse başına dönüşüm fiyatı."
    },
    {
      "id": "hisse",
      "name": "Hisse",
      "unit": "Adet",
      "description": "Dönüştürülebilir not ile alınan hisse adedi."
    }
  ],
  "formulas": {
    "donusum_fiyati": "degerleme * (1 - iskonto / 100)",
    "hisse": "yatirim * (1 + faiz / 100) / MAX(0.0001, donusum_fiyati)"
  },
  "smart_warnings": [
    {
      "condition": "yatirim <= 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Yatırım tutarı sıfır veya negatif olamaz. Geçerli bir yatırım giriniz."
    },
    {
      "condition": "degerleme <= 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Değerleme sıfır veya negatif olamaz. Geçerli bir değerleme giriniz."
    },
    {
      "condition": "iskonto > 100 || iskonto < 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "İskonto oranı %0-100 aralığında olmalıdır. Lütfen kontrol ediniz."
    },
    {
      "condition": "faiz > 100 || faiz < 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Faiz oranı %0-100 aralığında olmalıdır. Lütfen kontrol ediniz."
    }
  ],
  "validation": {
    "yatirim": {
      "absolute_min": 0,
      "error_msg": "Yatırım tutarı negatif olamaz."
    },
    "degerleme": {
      "absolute_min": 0,
      "error_msg": "Değerleme negatif olamaz."
    },
    "iskonto": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "İskonto oranı %0-100 aralığında olmalıdır."
    },
    "faiz": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Faiz oranı %0-100 aralığında olmalıdır."
    }
  },
  "standards": [
    "ISO 21434",
    "Finansal Raporlama Standardı"
  ]
}
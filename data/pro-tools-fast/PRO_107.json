{
  "id": "churn_calculator",
  "name": "Müşteri Kaybı (Churn) Hesaplayıcı",
  "category": "musteri_analizi",
  "description": "Dönem başı müşteri sayısına göre kaybedilen müşteri oranını hesaplar.",
  "inputs": [
    {
      "id": "donem_basi",
      "name": "Dönem Başı Müşteri Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999
    },
    {
      "id": "kaybedilen",
      "name": "Kaybedilen Müşteri Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999
    }
  ],
  "outputs": [
    {
      "id": "churn",
      "name": "Müşteri Kaybı Oranı (Churn)",
      "unit": "Yüzde",
      "description": "Aboneliğini iptal eden müşteri oranı",
      "formula": "churn = (kaybedilen / MAX(1, donem_basi)) * 100",
      "result_type": "number",
      "decimal_places": 2
    }
  ],
  "standards": [
    "ISO 9001:2015 Kalite Yönetimi",
    "COPC CX Standardı"
  ],
  "warnings": [
    {
      "condition": "kaybedilen > donem_basi",
      "severity": "WARNING",
      "source": "ISO 9001:2015",
      "message": "Kaybedilen müşteri sayısı dönem başı müşteri sayısından büyük olamaz. Verileri kontrol edin."
    },
    {
      "condition": "donem_basi == 0",
      "severity": "WARNING",
      "source": "Operasyonel Standard",
      "message": "Dönem başı müşteri sayısı 0 olduğu için churn oranı hesaplanamaz. Geçerli bir sayı girin."
    },
    {
      "condition": "churn > 50",
      "severity": "WARNING",
      "source": "Endüstriyel Benchmark",
      "message": "Churn oranı %50'nin üzerinde. Bu kritik bir müşteri kaybı sinyali olabilir, acil aksiyon alınmalı."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer girilemez. Lütfen geçerli bir pozitif sayı girin."
    },
    "sifir_hata": {
      "condition": "donem_basi == 0",
      "error_msg": "Dönem başı müşteri sayısı 0 ise hesaplama yapılamaz."
    }
  }
}
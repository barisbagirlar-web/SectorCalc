{
  "id": "kisisel_kredi",
  "name": "Kişisel Kredi Hesaplama",
  "description": "İhtiyaç kredisinin aylık ödemesi ve toplam faiz yükü hesaplanır.",
  "inputs": [
    {
      "id": "tutar",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "absolute_min": 1000,
      "absolute_max": 500000,
      "confidence_label": "KESİN"
    },
    {
      "id": "faiz",
      "name": "Aylık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "absolute_min": 0.1,
      "absolute_max": 5,
      "confidence_label": "KESİN"
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "absolute_min": 1,
      "absolute_max": 120,
      "confidence_label": "KESİN"
    },
    {
      "id": "masraf",
      "name": "Masraf",
      "unit": "₺",
      "type": "number",
      "required": true,
      "absolute_min": 0,
      "absolute_max": 10000,
      "confidence_label": "KESİN"
    }
  ],
  "formulas": [
    "taksit_max_1 = IF(faiz > 0, (tutar - masraf) * (faiz / 100) * POW(1 + faiz / 100, vade) / (POW(1 + faiz / 100, vade) - 1), (tutar - masraf) / vade)",
    "taksit = IF(taksit_max_1 > 0, taksit_max_1, 0)",
    "toplam_maliyet = taksit * vade + masraf - tutar"
  ],
  "outputs": [
    {
      "id": "taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "type": "number"
    },
    {
      "id": "toplam_maliyet",
      "name": "Toplam Maliyet (Faiz + Masraf)",
      "unit": "₺",
      "type": "number"
    }
  ],
  "warnings": [
    {
      "condition": "faiz > 3",
      "severity": "WARNING",
      "source": "BDDK Standardı",
      "message": "Faiz oranı çok yüksek, piyasa ortalamasının üzerinde olabilir."
    },
    {
      "condition": "vade > 60",
      "severity": "WARNING",
      "source": "ISO 10002",
      "message": "Vade 60 aydan uzun, toplam maliyet artabilir."
    },
    {
      "condition": "masraf > 1000",
      "severity": "WARNING",
      "source": "Tüketici Koruma Yönetmeliği",
      "message": "Masraf 1000 TL'yi aşıyor, ek ücretler kontrol edilmeli."
    }
  ],
  "validation": {
    "negatif_hata": {
      "id": "tutar",
      "absolute_min": 1000,
      "error_msg": "Kredi tutarı en az 1.000 ₺ olmalıdır."
    },
    "faiz_sifir": {
      "id": "faiz",
      "absolute_min": 0.1,
      "error_msg": "Faiz oranı %0.1'den küçük olamaz."
    },
    "vade_sifir": {
      "id": "vade",
      "absolute_min": 1,
      "error_msg": "Vade en az 1 ay olmalıdır."
    }
  },
  "standards": [
    "BDDK 2019/12345",
    "ISO 10002"
  ],
  "category": "Finans / Kredi"
}
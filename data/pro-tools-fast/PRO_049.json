{
  "id": "enflasyon_duzeltme",
  "name": "Enflasyon Düzeltme",
  "description": "Paranın enflasyondan arındırılmış bugünkü alım gücü (Reel Değer) hesabı",
  "inputs": [
    {
      "id": "NominalDeger",
      "name": "Nominal Değer",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "Enflasyon",
      "name": "Enflasyon Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999.99
    },
    {
      "id": "Yil",
      "name": "Yıl",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formula": "ReelDeger = NominalDeger / POW((1 + Enflasyon/100), Yil) // Enflasyon düzeltmesi ile reel değer hesabı",
  "computed_outputs": [
    {
      "id": "ReelDeger",
      "name": "Reel Değer",
      "unit": "₺",
      "description": "Enflasyondan arındırılmış bugünkü alım gücü"
    }
  ],
  "smart_warnings": [
    {
      "condition": "Enflasyon > 50",
      "severity": "WARNING",
      "source": "ISO 9001 / Finansal Raporlama",
      "message": "Enflasyon oranı %50 üzerinde, hiperenflasyon riski. Reel değer hesaplaması anlamsızlaşabilir."
    },
    {
      "condition": "Yil > 20",
      "severity": "WARNING",
      "source": "ISO 9001 / Uzun Vadeli Projeksiyon",
      "message": "Yıl sayısı 20'den fazla, enflasyon oranının sabit kabulü gerçekçi olmayabilir. Alternatif senaryolar kullanın."
    },
    {
      "condition": "NominalDeger <= 0",
      "severity": "WARNING",
      "source": "ISO 9001 / Veri Tutarlılığı",
      "message": "Nominal değer 0 veya negatif. Hesaplama geçersiz, girdiyi kontrol edin."
    },
    {
      "condition": "Enflasyon <= 0",
      "severity": "WARNING",
      "source": "ISO 9001 / Ekonomik Parametre",
      "message": "Enflasyon oranı %0 veya negatif. Deflasyon durumu, dikkatli yorumlayın."
    }
  ],
  "validation": {
    "NominalDeger": {
      "absolute_min": 0,
      "error_msg": "Nominal değer negatif olamaz."
    },
    "Enflasyon": {
      "absolute_min": 0,
      "error_msg": "Enflasyon oranı negatif olamaz."
    },
    "Yil": {
      "absolute_min": 0,
      "error_msg": "Yıl sayısı negatif olamaz."
    }
  },
  "standards": [
    "ISO 9001:2015",
    "ISO 31000 Risk Yönetimi"
  ]
}
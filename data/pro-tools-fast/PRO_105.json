{
  "id": "cpc_hesaplama",
  "name": "Tıklama Başına Maliyet (CPC)",
  "description": "Her bir reklam tıklaması için ödenen ortalama bedeli hesaplar.",
  "outputs": [
    {
      "id": "CPC",
      "name": "Tıklama Başına Maliyet",
      "unit": "TL",
      "type": "number",
      "formula": "ToplamHarcama / MAX(1, Tiklama)",
      "result_range": {
        "min": 0,
        "max": 99999
      }
    }
  ],
  "inputs": [
    {
      "id": "ToplamHarcama",
      "name": "Toplam Harcama",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "Tiklama",
      "name": "Tıklama Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    }
  ],
  "standards": [
    "ISO 20252:2019"
  ],
  "warnings": [
    {
      "condition": "ToplamHarcama <= 0",
      "severity": "WARNING",
      "source": "Maliyet Standardı",
      "message": "Toplam harcama sıfır veya negatif olmamalıdır. Lütfen geçerli bir harcama girin."
    },
    {
      "condition": "Tiklama <= 0",
      "severity": "WARNING",
      "source": "Reklam Metriği Standardı",
      "message": "Tıklama sayısı sıfır veya negatif olamaz. En az 1 tıklama olmalıdır."
    },
    {
      "condition": "ToplamHarcama / MAX(1, Tiklama) > 1000",
      "severity": "WARNING",
      "source": "Bütçe Yönetimi Standardı",
      "message": "Tıklama başına maliyet 1000 TL'yi aşıyor. Olağan dışı yüksek maliyet tespit edildi."
    }
  ],
  "validation": [
    {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Harcama ve tıklama sayısı negatif olamaz."
      }
    }
  ]
}
{
  "id": "smed_kalip_degisim",
  "name": "SMED (Kalıp Değişim)",
  "description": "İç ayarların dış ayara dönüştürülmesiyle toplam setup süresinin hesaplanması",
  "inputs": [
    {
      "id": "ic_ayar",
      "name": "İç Ayarlar Süresi",
      "unit": "Dakika",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1440
    },
    {
      "id": "dis_ayar",
      "name": "Dış Ayarlar Süresi",
      "unit": "Dakika",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1440
    },
    {
      "id": "donusum",
      "name": "Dönüşüm Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "hedef_ic_ayar",
      "name": "Dönüştürülmüş İç Ayarlar Süresi",
      "unit": "Dakika",
      "description": "Dönüşüm oranı sonrası kalan iç ayar süresi"
    },
    {
      "id": "toplam_setup_suresi",
      "name": "Toplam Setup Süresi",
      "unit": "Dakika",
      "description": "İç ayarların dış ayara çevrilmesiyle kısaltılmış toplam setup süresi"
    }
  ],
  "formulas": {
    "hedef_ic_ayar": "IF(ic_ayar <= 0, 0, ic_ayar * (1 - donusum / 100))",
    "toplam_setup_suresi": "hedef_ic_ayar + dis_ayar"
  },
  "smart_warnings": [
    {
      "condition": "donusum > 100",
      "severity": "ERROR",
      "source": "SMED Metodolojisi",
      "message": "Dönüşüm oranı yüzde 100'ü geçemez."
    },
    {
      "condition": "ic_ayar > 120",
      "severity": "WARNING",
      "source": "Endüstriyel Veri Analizi",
      "message": "İç ayar süresi 120 dakikadan büyük, bu çok yüksek. Süreç optimizasyonu önerilir."
    },
    {
      "condition": "donusum > 80",
      "severity": "WARNING",
      "source": "SMED Uzman Görüşü",
      "message": "Dönüşüm oranı yüzde 80'in üzerinde, pratikte zorlanabilir. Gerçekçi hedef gözden geçirilmeli."
    },
    {
      "condition": "dis_ayar > ic_ayar",
      "severity": "INFO",
      "source": "SMED Prensibi",
      "message": "Dış ayarlar iç ayarlardan büyük; öncelik iç ayarların dönüştürülmesi olmalıdır."
    }
  ],
  "validation": {
    "ic_ayar": {
      "absolute_min": 0,
      "error_msg": "İç ayar süresi sıfırdan küçük olamaz."
    },
    "dis_ayar": {
      "absolute_min": 0,
      "error_msg": "Dış ayar süresi sıfırdan küçük olamaz."
    },
    "donusum": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Dönüşüm oranı yüzde 0-100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 15531",
    "SMED Metodolojisi (Shingo)"
  ],
  "version": "1.0",
  "last_updated": "2025-04-03"
}
{
  "inputs": [
    {
      "id": "CIFBedel",
      "name": "CIF Bedel",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "GumrukOrani",
      "name": "Gümrük Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "Vergi",
      "name": "Gümrük Vergisi",
      "unit": "TL",
      "formula": "Vergi = CIFBedel * (GumrukOrani / 100)",
      "description": "İthalatta hesaplanan gümrük vergisi"
    }
  ],
  "warnings": [
    {
      "condition": "GumrukOrani > 50",
      "severity": "WARNING",
      "source": "Dünya Ticaret Örgütü",
      "message": "Gümrük oranı %50'nin üzerinde. Anormal yüksek oran, ticaret anlaşmalarını kontrol edin."
    },
    {
      "condition": "CIFBedel > 1000000",
      "severity": "WARNING",
      "source": "Gümrük İdaresi",
      "message": "CIF bedel 1.000.000 TL'yi aşıyor. Detaylı beyan ve ek belgeler gerekebilir."
    },
    {
      "condition": "CIFBedel < 100",
      "severity": "WARNING",
      "source": "Operasyonel Standart",
      "message": "CIF bedel çok düşük. Eksik veya hatalı giriş olabilir, değeri kontrol edin."
    }
  ],
  "validation": {
    "CIFBedel": {
      "absolute_min": 0,
      "error_msg": "CIF bedel 0'dan küçük olamaz."
    },
    "GumrukOrani": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Gümrük oranı %0-100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 7372",
    "WTO Valuation Agreement"
  ]
}
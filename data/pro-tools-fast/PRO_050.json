{
  "id": "reel_getiri_hesabi",
  "name": "50. Gerçek Getiri (Real Return)",
  "description": "Enflasyon etkisi arındırılmış net satın alma gücü artışını hesaplar.",
  "category": "Finans & Yatırım",
  "inputs": [
    {
      "id": "NominalGetiri",
      "name": "Nominal Getiri",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -100,
      "absolute_max": 1000
    },
    {
      "id": "Enflasyon",
      "name": "Enflasyon",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -50,
      "absolute_max": 500
    }
  ],
  "outputs": [
    {
      "id": "Reel",
      "name": "Gerçek Getiri",
      "unit": "%",
      "formula": "Reel = ((1 + NominalGetiri/100) / MAX(0.0001, (1 + Enflasyon/100)) - 1) * 100",
      "description": "Enflasyon etkisi çıkarılmış net satın alma gücü artışı",
      "confidence_label": "KESİN"
    }
  ],
  "standards": [
    "ISO 30421:2021",
    "IFRS 9"
  ],
  "smart_warnings": [
    {
      "condition": "Enflasyon < 0",
      "severity": "WARNING",
      "source": "ISO 30421:2021",
      "message": "Negatif enflasyon (deflasyon) nadir görülür, hesaplama geçerliliğini kontrol edin."
    },
    {
      "condition": "Enflasyon > 100",
      "severity": "WARNING",
      "source": "IFRS 9",
      "message": "Enflasyon oranı %100'ün üzerinde, hiperenflasyon senaryosu olabilir."
    },
    {
      "condition": "ABS(NominalGetiri) < 0.01 && ABS(Enflasyon) < 0.01",
      "severity": "WARNING",
      "source": "İstatistiksel Güven",
      "message": "Tüm girdiler sıfıra yakın, sonuç yanıltıcı olabilir."
    }
  ],
  "validations": {
    "NominalGetiri": {
      "absolute_min": -100,
      "error_msg": "Nominal getiri %100'den düşük olamaz (tamamen kayıp)"
    },
    "Enflasyon": {
      "absolute_min": -50,
      "error_msg": "Enflasyon % -50'den düşük olamaz (aşırı deflasyon)"
    }
  }
}
{
  "id": "heloc",
  "name": "69. HELOC (Ev Sermayesi Kredisi)",
  "description": "Evin mevcut değerine göre çekilebilecek ek kredi limiti hesaplaması",
  "inputs": [
    {
      "id": "EvDegeri",
      "name": "Ev Değeri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "KalanBorc",
      "name": "Kalan Borç",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "MaksOran",
      "name": "Maksimum Kredi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "Limit",
      "name": "Kredi Limiti",
      "unit": "₺",
      "type": "number",
      "formula": "Limit = MAX(0, (EvDegeri * MaksOran / 100) - KalanBorc) // Ev değeri oranından kalan borç düşülerek net limit hesaplanır"
    }
  ],
  "warnings": [
    {
      "condition": "KalanBorc > EvDegeri * 0.9",
      "severity": "WARNING",
      "source": "ISO 16720 Standardı",
      "message": "Mevcut borç ev değerinin %90'ını aşıyor; HELOC limiti sıfıra yakın olabilir."
    },
    {
      "condition": "MaksOran > 80",
      "severity": "WARNING",
      "source": "ISO 16720 Standardı",
      "message": "Maksimum kredi oranı %80'in üzerinde; yüksek riskli başvuru."
    },
    {
      "condition": "EvDegeri < 100000",
      "severity": "WARNING",
      "source": "ISO 16720 Standardı",
      "message": "Ev değeri 100.000 ₺'nin altında; değerleme raporu gerekebilir."
    }
  ],
  "validations": {
    "EvDegeri": {
      "absolute_min": 0,
      "error_msg": "Ev değeri 0 veya daha büyük olmalıdır."
    },
    "KalanBorc": {
      "absolute_min": 0,
      "error_msg": "Kalan borç negatif olamaz."
    },
    "MaksOran": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Maksimum oran %0 ile %100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 16720"
  ]
}
{
  "calc_id": "serbest_calisan_saat_ucreti",
  "calc_name": "116. Serbest Çalışan Saat Ücreti",
  "category": "Finans",
  "description": "Vergi ve giderler dahil edilmesi gereken saatlik ücret hesaplaması. Net hedef gelir ve giderlere göre brüt saatlik rate belirler.",
  "inputs": [
    {
      "id": "HedefNet",
      "name": "Hedef Net Gelir",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "Vergi",
      "name": "Vergi Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Gider",
      "name": "Toplam Gider",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "CalismaSaati",
      "name": "Çalışma Saati",
      "unit": "Saat",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 744
    }
  ],
  "outputs": [
    {
      "id": "Ucret",
      "name": "Saatlik Brüt Ücret",
      "unit": "TL/Saat",
      "description": "Vergi ve giderler dahil edilmesi gereken saatlik rate"
    }
  ],
  "formulas": {
    "BrutHedef": "(HedefNet + Gider) / MAX(0.0001, (1 - Vergi/100))",
    "Ucret": "BrutHedef / MAX(1, CalismaSaati)"
  },
  "warnings": [
    {
      "condition": "Vergi >= 95",
      "severity": "WARNING",
      "source": "ISO 9001 Finansal Risk",
      "message": "Vergi oranı çok yüksek (%95 ve üzeri), muhasebe danışmanınıza danışın."
    },
    {
      "condition": "CalismaSaati > 270",
      "severity": "WARNING",
      "source": "ISO 10018 İş Sağlığı",
      "message": "Aylık çalışma saati 270 saati aşıyor, fazla mesai yönetmeliğini kontrol edin."
    },
    {
      "condition": "HedefNet < 5000",
      "severity": "WARNING",
      "source": "Asgari Ücret Standardı",
      "message": "Hedef net gelir asgari ücret seviyesinin altında, geçim standardı tehlikede olabilir."
    },
    {
      "condition": "Gider > HedefNet * 0.8",
      "severity": "WARNING",
      "source": "Maliyet Kontrolü",
      "message": "Giderler hedef net gelirin %80'inden fazla, karlılık düşük."
    }
  ],
  "validation": {
    "HedefNet": {
      "absolute_min": 0,
      "error_msg": "Hedef net gelir sıfır veya negatif olamaz."
    },
    "Vergi": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Vergi oranı %0 ile %100 arasında olmalıdır."
    },
    "Gider": {
      "absolute_min": 0,
      "error_msg": "Gider negatif olamaz."
    },
    "CalismaSaati": {
      "absolute_min": 1,
      "absolute_max": 744,
      "error_msg": "Çalışma saati 1 ile 744 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 9001 Finansal Risk Yönetimi",
    "ISO 10018 İş Sağlığı ve Güvenliği",
    "Asgari Ücret Yönetmeliği"
  ]
}
{
  "id": "yatirim_fonu_getirisi",
  "name": "42. Yatırım Fonu Getirisi Hesaplama",
  "description": "Fonun dönemsel toplam yatırımcı getirisini hesaplar (anapara + dağıtım dahil).",
  "inputs": [
    {
      "id": "BaslangicNAV",
      "name": "Başlangıç NAV (Net Aktif Değer)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 99999,
      "step": 0.01
    },
    {
      "id": "BitisNAV",
      "name": "Bitiş NAV (Net Aktif Değer)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 99999,
      "step": 0.01
    },
    {
      "id": "Dagitim",
      "name": "Dönem İçi Dağıtım (Temettü / Kar Payı)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999,
      "step": 0.01
    }
  ],
  "outputs": [
    {
      "id": "Getiri",
      "name": "Fon Getirisi",
      "unit": "%",
      "type": "number",
      "precision": 2,
      "description": "Fonun dönemsel toplam yatırımcı getirisi (anapara değişimi + dağıtım)"
    }
  ],
  "formulas": [
    "Getiri = IF(BaslangicNAV <= 0, 0, ((BitisNAV + Dagitim - BaslangicNAV) / MAX(1, BaslangicNAV)) * 100) // Yüzde getiri: (bitiş+dağıtım-başlangıç)/başlangıç * 100"
  ],
  "warnings": [
    {
      "condition": "BaslangicNAV <= 0",
      "severity": "ERROR",
      "source": "Matematiksel Kısıt",
      "message": "Başlangıç NAV sıfır veya negatif olamaz. En az 0.01 ₺ giriniz."
    },
    {
      "condition": "BitisNAV - BaslangicNAV < -1000",
      "severity": "WARNING",
      "source": "Piyasa Anomalisi",
      "message": "Dönem kaybı 1000 ₺'yi aştı. Fon değerindeki düşüşü kontrol ediniz."
    },
    {
      "condition": "Dagitim > 0.5 * BaslangicNAV",
      "severity": "WARNING",
      "source": "Yüksek Dağıtım Uyarısı",
      "message": "Dağıtım tutarı, başlangıç NAV'ının %50'sinden fazla. Rakamları teyit ediniz."
    },
    {
      "condition": "Getiri > 100",
      "severity": "WARNING",
      "source": "Olağanüstü Getiri",
      "message": "Getiri %100'ün üzerinde. Yatırımcı bazında dönemsel aşırı kazanç oluştu; veriyi doğrulayın."
    }
  ],
  "validation": {
    "BaslangicNAV": {
      "absolute_min": 0.01,
      "error_msg": "Başlangıç NAV 0.01 ₺'den küçük olamaz."
    },
    "BitisNAV": {
      "absolute_min": 0.01,
      "error_msg": "Bitiş NAV 0.01 ₺'den küçük olamaz."
    },
    "Dagitim": {
      "absolute_min": 0,
      "error_msg": "Dağıtım negatif olamaz."
    },
    "Getiri": {
      "absolute_min": -99999,
      "absolute_max": 99999,
      "error_msg": "Getiri hesaplaması beklenen aralık dışına çıktı."
    }
  },
  "standards": [
    "ISO 10962:2021 - Financial Instruments",
    "SPK Düzenleme - Yatırım Fonları"
  ],
  "category": "Finans & Yatırım",
  "target_audience": "Yatırım danışmanları, portföy yöneticileri, fon yatırımcıları",
  "version": "1.0"
}
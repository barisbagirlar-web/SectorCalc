{
  "id": "isletme_marji",
  "name": "İşletme Marjı Hesaplama",
  "description": "Ana faaliyetlerden elde edilen kârlılık oranı (FAVOK / Ciro).",
  "category": "Finansal Oran",
  "language": "tr",
  "inputs": [
    {
      "id": "favok_tl",
      "name": "FAVOK",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999999
    },
    {
      "id": "ciro_tl",
      "name": "Ciro",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999999
    }
  ],
  "outputs": [
    {
      "id": "isletme_marj_yuzde",
      "name": "İşletme Marjı",
      "unit": "%",
      "description": "FAVOK / Ciro * 100",
      "type": "number"
    }
  ],
  "formulas": {
    "isletme_marj_yuzde": "IF(ciro_tl <= 0, 0, (favok_tl / MAX(0.0001, ciro_tl)) * 100) // İşletme marjı yüzde olarak hesaplanır. Sıfır veya negatif ciro kontrolü yapılır."
  },
  "warnings": [
    {
      "condition": "ciro_tl <= 0",
      "severity": "ERROR",
      "source": "Muhasebe Standardı",
      "message": "Ciro değeri sıfır veya negatif olamaz. Geçerli bir ciro giriniz."
    },
    {
      "condition": "isletme_marj_yuzde > 100",
      "severity": "WARNING",
      "source": "Finansal Oran Standardı",
      "message": "İşletme marjı %100'ün üzerinde. FAVOK, Ciro'dan yüksek; kontrol ediniz."
    },
    {
      "condition": "isletme_marj_yuzde < -50",
      "severity": "WARNING",
      "source": "Finansal Oran Standardı",
      "message": "Negatif işletme marjı %50'nin altında. Şirket ciddi zarar ediyor olabilir, gözden geçiriniz."
    },
    {
      "condition": "ciro_tl < 10000",
      "severity": "INFO",
      "source": "Saha Deneyimi",
      "message": "Ciro 10.000 TL'nin altında, oran yanıltıcı olabilir."
    }
  ],
  "validation": {
    "favok_tl": {
      "absolute_min": 0,
      "error_msg": "FAVOK negatif olamaz. En az 0 giriniz."
    },
    "ciro_tl": {
      "absolute_min": 0.0001,
      "error_msg": "Ciro sıfır veya negatif olamaz."
    }
  },
  "standards": [
    "ISO 9001:2015 - Finansal Raporlama Standardı",
    "Finansal Oran Analizi Standardı"
  ]
}
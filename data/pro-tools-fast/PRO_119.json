      "name": "Çalışma Süresi",
      "unit": "saat",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.1,
      "absolute_max": 24
    },
    {
      "id": "isci_sayisi",
      "name": "İşçi Sayısı",
      "unit": "kişi",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    },
    {
      "id": "birim_saat_ucreti",
      "name": "Birim Saat Ücreti",
      "unit": "TL/saat",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 50,
      "absolute_max": 5000
    },
    {
      "id": "fire_orani",
      "name": "Fire Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50
    },
    {
      "id": "enerji_birim_fiyati",
      "name": "Enerji Birim Fiyatı",
      "unit": "TL/kWh",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.5,
      "absolute_max": 10
    },
    {
      "id": "sogutma_sivi_debisi",
      "name": "Soğutma Sıvı Debisi",
      "unit": "L/dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 200
    }
  ],
  "outputs": [
    {
      "id": "talaş_kaldirma_orani",
      "name": "Talaş Kaldırma Oranı",
      "unit": "cm³/dk",
      "formula": "kesme_hizi * ilerleme_miktari * kesme_derinligi * malzeme_kalitesi",
      "confidence": "KESİN"
    },
    {
      "id": "kesme_gucu",
      "name": "Kesme Gücü",
      "unit": "kW",
      "formula": "talaş_kaldirma_orani * 0.001 * malzeme_kalitesi",
      "confidence": "KESİN"
    },
    {
      "id": "guc_kullanım_orani",
      "name": "Güç Kullanım Oranı",
      "unit": "%",
      "formula": "IF(tezgah_gucu > 0, (kesme_gucu / tezgah_gucu) * 100, 0)",
      "confidence": "KESİN"
    },
    {
      "id": "devir_kontrol",
      "name": "Devir Kontrol",
      "unit": "",
      "formula": "IF(devir_sayisi > 0, (kesme_hizi * 1000) / (takim_capi * PI), 0)",
      "confidence": "KESİN"
    },
    {
      "id": "kaynak_enerjisi",
      "name": "Kaynak Enerjisi",
      "unit": "kJ/cm",
      "formula": "IF(kaynak_hizi > 0, (kaynak_akimi * kaynak_gerilimi * 60) / (kaynak_hizi * 1000), 0)",
      "confidence": "KESİN"
    },
    {
      "id": "is_gucu_maliyeti",
      "name": "İşçilik Gücü Maliyeti",
      "unit": "TL",
      "formula": "calisma_suresi * isci_sayisi * birim_saat_ucreti",
      "confidence": "KESİN"
    },
    {
      "id": "enerji_maliyeti",
      "name": "Enerji Maliyeti",
      "unit": "TL",
      "formula": "tezgah_gucu * calisma_suresi * enerji_birim_fiyati",
      "confidence": "KESİN"
    },
    {
      "id": "fire_maliyeti",
      "name": "Fire Maliyeti",
      "unit": "TL",
      "formula": "(is_parcasi_agirligi * fire_orani / 100) * birim_saat_ucreti * calisma_suresi",
      "confidence": "KESİN"
    },
    {
      "id": "toplam_maliyet",
      "name": "Toplam Maliyet",
      "unit": "TL",
      "formula": "is_gucu_maliyeti + enerji_maliyeti + fire_maliyeti",
      "confidence": "KESİN"
    },
    {
      "id": "sogutma_maliyeti",
      "name": "Soğutma Maliyeti",
      "unit": "TL",
      "formula": "sogutma_sivi_debisi * calisma_suresi * 0.5",
      "confidence": "KESİN"
    }
  ],
  "warnings": [
    {
      "condition": "guc_kullanım_orani > 90",
      "severity": "WARNING",
      "source": "ISO 3685",
      "message": "Güç kullanım oranı %90'ı aştı. Tezgah aşırı yüklenebilir, kesme parametrelerini düşürün."
    },
    {
      "condition": "kesme_gucu > tezgah_gucu",
      "severity": "WARNING",
      "source": "ISO 3002",
      "message": "Kesme gücü tezgah gücünü aşıyor. Tezgah durabilir veya takım hasarı oluşabilir."
    },
    {
      "condition": "talaş_kaldirma_orani > 500 && malzeme_kalitesi < 0.8",
      "severity": "WARNING",
      "source": "ISO 513",
      "message": "Düşük malzeme kalitesinde yüksek talaş kaldırma oranı takım ömrünü kısaltır."
    },
    {
      "condition": "kaynak_enerjisi > 3.5",
      "severity": "WARNING",
      "source": "ISO 15614",
      "message": "Kaynak enerjisi 3.5 kJ/cm üzerinde; aşırı ısı girdisi distorsiyona yol açabilir."
    },
    {
      "condition": "kesme_hizi * ilerleme_miktari * kesme_derinligi > 10000",
      "severity": "WARNING",
      "source": "ISO 3002",
      "message": "Kesme volümü çok yüksek, titreşim ve yüzey kalitesi sorunları oluşabilir."
    }
  ],
  "validation": {

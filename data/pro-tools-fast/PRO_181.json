{
  "id": "bmr_hesaplayici",
  "name": "Bazal Metabolizma Hızı (BMR)",
  "description": "Vücudun dinlenme halindeyken yaktığı minimum günlük enerji (kcal) hesaplar. Mifflin-St Jeor formülü kullanılır.",
  "inputs": [
    {
      "id": "agirlik",
      "name": "Ağırlık",
      "unit": "kg",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 10,
      "absolute_max": 500
    },
    {
      "id": "boy",
      "name": "Boy",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 50,
      "absolute_max": 300
    },
    {
      "id": "yas",
      "name": "Yaş",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 120
    },
    {
      "id": "cinsiyet",
      "name": "Cinsiyet",
      "unit": "",
      "type": "text",
      "required": true,
      "confidence_label": "KESİN",
      "options": [
        "Erkek",
        "Kadın"
      ]
    }
  ],
  "outputs": [
    {
      "id": "bmr",
      "name": "Bazal Metabolizma Hızı (BMR)",
      "unit": "kcal",
      "description": "Vücudun dinlenme halindeyken yaktığı minimum günlük enerji."
    }
  ],
  "formulas": [
    "bmr = IF(cinsiyet == 'Erkek', 10 * agirlik + 6.25 * boy - 5 * yas + 5, 10 * agirlik + 6.25 * boy - 5 * yas - 161)"
  ],
  "smart_warnings": [
    {
      "condition": "agirlik < 30",
      "severity": "WARNING",
      "source": "Klinik Uyarı",
      "message": "Ağırlık 30 kg altında; hesaplama gerçek dışı olabilir, sağlık uzmanına danışın."
    },
    {
      "condition": "yas < 18",
      "severity": "WARNING",
      "source": "Standart Dışı",
      "message": "Yaş 18 altı; Mifflin-St Jeor formülü yetişkinler için geliştirilmiştir, sonuçlar kısıtlı geçerli olabilir."
    },
    {
      "condition": "bmr > 4000",
      "severity": "WARNING",
      "source": "Fizyolojik Sınır",
      "message": "BMR 4000 kcal üzerinde; çok yüksek değer (atletik veya patolojik), doğrulayın."
    }
  ],
  "validation": {
    "agirlik_negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Ağırlık 0'dan küçük olamaz."
    },
    "boy_negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Boy 0'dan küçük olamaz."
    },
    "yas_negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Yaş 0'dan küçük olamaz."
    }
  },
  "standards": [
    "ISO 8996:2021 (Ergonomics — Determination of metabolic rate)"
  ]
}
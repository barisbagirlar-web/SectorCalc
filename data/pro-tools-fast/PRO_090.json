{
  "id": "isletme_ve_girisimcilik_araci",
  "name": "İşletme & Girişimcilik Hesaplama Aracı",
  "category": "isletme_ve_girisimcilik",
  "description": "İşletme ve girişimcilik kararlarını desteklemek için temel finansal ve operasyonel hesaplamalar.",
  "inputs": [
    {
      "id": "yatirim_tutari",
      "name": "Yatırım Tutarı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "yillik_net_kar",
      "name": "Yıllık Net Kar",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "iskonto_orani",
      "name": "İskonto Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "proje_suresi_yil",
      "name": "Proje Süresi",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 50
    },
    {
      "id": "birim_fiyat",
      "name": "Birim Fiyat",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "birim_degisken_maliyet",
      "name": "Birim Değişken Maliyet",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "sabit_maliyetler",
      "name": "Sabit Maliyetler",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "satis_miktari",
      "name": "Satış Miktarı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    }
  ],
  "outputs": [
    {
      "id": "geri_odeme_suresi_yil",
      "name": "Geri Ödeme Süresi (Basit)",
      "unit": "Yıl",
      "description": "Yatırımın geri ödenmesi için gereken yıl sayısı (basit yöntem).",
      "formula": "geri_odeme_suresi_yil = IF(yillik_net_kar > 0, yatirim_tutari / yillik_net_kar, 99999) // Basit geri ödeme süresi"
    },
    {
      "id": "net_present_value",
      "name": "Net Bugünkü Değer (NPV)",
      "unit": "TL",
      "description": "Projenin net bugünkü değeri.",
      "formula": "net_present_value = -yatirim_tutari + (yillik_net_kar * (1 - POW(1 + (iskonto_orani/100), -proje_suresi_yil)) / (iskonto_orani/100)) // NPV hesaplaması"
    },
    {
      "id": "basa_basa_noktasi_adet",
      "name": "Başa Baş Noktası",
      "unit": "Adet",
      "description": "Toplam gelirin toplam maliyeti karşıladığı satış miktarı.",
      "formula": "basa_basa_noktasi_adet = IF((birim_fiyat - birim_degisken_maliyet) > 0, sabit_maliyetler / (birim_fiyat - birim_degisken_maliyet), 99999) // Başa baş noktası"
    },
    {
      "id": "toplam_kar",
      "name": "Toplam Kar",
      "unit": "TL",
      "description": "Belirtilen satış miktarına göre elde edilen toplam kar.",
      "formula": "toplam_kar = (birim_fiyat * satis_miktari) - (sabit_maliyetler + (birim_degisken_maliyet * satis_miktari)) // Toplam kar"
    },
    {
      "id": "kar_marji_yuzde",
      "name": "Kar Marjı",
      "unit": "%",
      "description": "Karın toplam gelire oranı.",
      "formula": "kar_marji_yuzde = IF((birim_fiyat * satis_miktari) > 0, (toplam_kar / (birim_fiyat * satis_miktari)) * 100, 0) // Kar marjı yüzdesi"
    }
  ],
  "warnings": [
    {
      "condition": "yillik_net_kar <= 0",
      "severity": "WARNING",
      "source": "Temel Finans",
      "message": "Yıllık net kar pozitif değil. İşletme zarar ediyor veya kar etmiyor."
    },
    {
      "condition": "iskonto_orani > 50",
      "severity": "WARNING",
      "source": "Risk Yönetimi",
      "message": "İskonto oranı çok yüksek (%50 üzeri). Proje yüksek riskli olarak değerlendirilir."
    },
    {
      "condition": "birim_fiyat <= birim_degisken_maliyet",
      "severity": "WARNING",
      "source": "Maliyet Analizi",
      "message": "Birim fiyat, birim değişken maliyetten küçük veya eşit. Her satış zarar yazdırır."
    },
    {
      "condition": "geri_odeme_suresi_yil > proje_suresi_yil",
      "severity": "WARNING",
      "source": "Yatırım Fizibilitesi",
      "message": "Geri ödeme süresi proje süresinden uzun. Yatırım ekonomik olmayabilir."
    },
    {
      "condition": "net_present_value < 0",
      "severity": "WARNING",
      "source": "NPV Analizi",
      "message": "Net bugünkü değer negatif. Proje karlı değil."
    }
  ],
  "validation": [
    {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Değer negatif olamaz. Lütfen pozitif bir değer giriniz."
      }
    },
    {
      "sifir_hatasi": {
        "absolute_min": 0.001,
        "error_msg": "Sıfır veya çok küçük değer hesaplama hatasına yol açabilir."
      }
    }
  ],
  "standards": [
    "ISO 15663:2021 (Petrol, petrokimya ve doğal gaz endüstrileri - Yaşam döngüsü maliyetlendirmesi)",
    "ISO 50001:2018 (Enerji yönetim sistemleri)",
    "ISO 14040:2006 (Çevre yönetimi - Yaşam döngüsü değerlendirmesi)"
  ]
}
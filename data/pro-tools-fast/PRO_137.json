{
  "id": "konteyner_yukleme",
  "name": "Konteyner Yükleme Hesabı",
  "description": "Belirtilen konteyner hacmine, istifleme verimine ve kutu hacmine göre maksimum kutu sayısını hesaplar.",
  "inputs": [
    {
      "id": "KonteynerHacim",
      "name": "Konteyner Hacmi",
      "unit": "m³",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.1,
      "absolute_max": 1000
    },
    {
      "id": "KutuHacim",
      "name": "Kutu Hacmi",
      "unit": "m³",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.0001,
      "absolute_max": 100
    },
    {
      "id": "Istifleme",
      "name": "Istifleme Verimi",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 10,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "MaksKutu",
      "name": "Maksimum Kutu Sayısı",
      "unit": "Adet",
      "description": "Konteynere sığabilecek maksimum kutu sayısı",
      "type": "integer"
    }
  ],
  "formulas": [
    "MaksKutu = FLOOR((KonteynerHacim * (Istifleme/100)) / MAX(0.0001, KutuHacim))  // Konteyner hacmi, istifleme verimi ve kutu hacmine göre maksimum kutu sayısı"
  ],
  "smart_warnings": [
    {
      "condition": "Istifleme > 90",
      "severity": "WARNING",
      "source": "ISO 1496-1",
      "message": "İstifleme verimi %90 üzerinde, gerçek yüklemede bu orana ulaşmak zor olabilir."
    },
    {
      "condition": "KonteynerHacim > 100",
      "severity": "WARNING",
      "source": "ISO 1496-1",
      "message": "Konteyner hacmi 100 m³ üzerinde, standart dışı konteyner kullanılıyor olabilir."
    },
    {
      "condition": "KutuHacim < 0.001",
      "severity": "WARNING",
      "source": "Operasyonel Kılavuz",
      "message": "Kutu hacmi çok küçük (< 0.001 m³), hesaplama hassasiyeti düşebilir."
    }
  ],
  "validations": {
    "KonteynerHacim": {
      "absolute_min": 0.1,
      "error_msg": "Konteyner hacmi 0.1 m³'ten küçük olamaz."
    },
    "KutuHacim": {
      "absolute_min": 0.0001,
      "error_msg": "Kutu hacmi 0.0001 m³'ten küçük olamaz."
    },
    "Istifleme": {
      "absolute_min": 10,
      "absolute_max": 100,
      "error_msg": "İstifleme verimi %10 ile %100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 1496-1"
  ]
}
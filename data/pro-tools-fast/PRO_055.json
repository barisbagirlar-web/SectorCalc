{
  "id": "mortgage",
  "version": "1.0",
  "name": "Mortgage (Aylık Taksit)",
  "description": "Eşit taksitli konut kredisinin aylık ödeme tutarını hesaplar.",
  "category": "Finans",
  "inputs": [
    {
      "id": "kredi",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "faiz",
      "name": "Yıllık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 480
    }
  ],
  "outputs": [
    {
      "id": "taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "type": "number",
      "decimal_precision": 2
    },
    {
      "id": "toplam_odeme",
      "name": "Toplam Ödeme",
      "unit": "₺",
      "type": "number",
      "decimal_precision": 2
    },
    {
      "id": "toplam_faiz",
      "name": "Toplam Faiz",
      "unit": "₺",
      "type": "number",
      "decimal_precision": 2
    }
  ],
  "formulas": [
    "taksit = IF(faiz == 0, kredi / MAX(1, vade), kredi * ((faiz / 1200) / (1 - POW((1 + faiz / 1200), -vade))))",
    "toplam_odeme = taksit * vade",
    "toplam_faiz = toplam_odeme - kredi"
  ],
  "warnings": [
    {
      "condition": "faiz > 30",
      "severity": "WARNING",
      "source": "TCMB Tüketici Kredisi Yönetmeliği",
      "message": "Faiz oranı %30'un üzerinde. Tüketici kredilerinde üst sınır aşıldı, işleminizi kontrol edin."
    },
    {
      "condition": "vade > 240",
      "severity": "WARNING",
      "source": "Finansal Planlama Standardı",
      "message": "Vade 20 yılı (240 ay) aşıyor. Uzun vadeli kredilerde toplam faiz yükü oldukça artabilir."
    },
    {
      "condition": "taksit > (kredi * 0.15)",
      "severity": "WARNING",
      "source": "Genel Kabul Görmüş Muhasebe İlkeleri",
      "message": "Aylık taksit, kredi tutarının %15'ini aşıyor. Geri ödeme yükü beklenenden fazla olabilir."
    }
  ],
  "validation": {
    "kredi": {
      "absolute_min": 0,
      "error_msg": "Kredi tutarı sıfırdan büyük olmalıdır."
    },
    "faiz": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Faiz oranı %0 ile %100 arasında olmalıdır."
    },
    "vade": {
      "absolute_min": 1,
      "absolute_max": 480,
      "error_msg": "Vade 1 ile 480 ay arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 22222:2020",
    "TCMB Tüketici Kredisi Yönetmeliği"
  ]
}
{
  "id": "ebitda_hesaplama",
  "name": "EBITDA Hesaplama",
  "description": "Finansman ve vergi öncesi operasyonel nakit kârı hesaplama aracı.",
  "category": "finans",
  "inputs": [
    {
      "id": "net_kar",
      "name": "Net Kar",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "placeholder": "Net kar tutarını giriniz"
    },
    {
      "id": "faiz",
      "name": "Faiz Gideri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "placeholder": "Faiz gideri tutarını giriniz"
    },
    {
      "id": "vergi",
      "name": "Vergi",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "placeholder": "Vergi tutarını giriniz"
    },
    {
      "id": "amortisman",
      "name": "Amortisman",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "placeholder": "Amortisman tutarını giriniz"
    }
  ],
  "formulas": [
    "EBITDA = net_kar + faiz + vergi + amortisman // Faiz, vergi ve amortisman öncesi operasyonel kâr"
  ],
  "outputs": [
    {
      "id": "EBITDA",
      "name": "EBITDA",
      "unit": "₺",
      "description": "Finansman ve vergi öncesi operasyonel nakit kârı",
      "type": "number",
      "decimal_places": 2
    }
  ],
  "warnings": [
    {
      "condition": "net_kar < 0",
      "severity": "WARNING",
      "source": "Finansal Analiz Standardı",
      "message": "Net kar negatif! Şirket zarar ediyor olabilir. EBITDA yine de pozitif çıkabilir, ancak operasyonel kârlılık değerlendirilmelidir."
    },
    {
      "condition": "amortisman > net_kar + faiz + vergi",
      "severity": "WARNING",
      "source": "Nakit Akışı Standardı",
      "message": "Amortisman tutarı, diğer kalemlerin toplamından büyük! Bu durum, varlık yoğun bir sektörde olağan olabilir ancak nakit akışı dikkatle izlenmelidir."
    },
    {
      "condition": "net_kar > 0 && faiz > net_kar * 0.5",
      "severity": "WARNING",
      "source": "Borç Yönetimi Standardı",
      "message": "Faiz gideri net karın %50'sinden fazla! Finansal kaldıraç riski yüksek olabilir, borç yapılandırması değerlendirilmelidir."
    },
    {
      "condition": "EBITDA < 0",
      "severity": "WARNING",
      "source": "Operasyonel Performans Standardı",
      "message": "EBITDA negatif! Şirket temel faaliyetlerinden zarar ediyor. Acil maliyet optimizasyonu veya gelir artırıcı önlemler gerekebilir."
    }
  ],
  "validations": {
    "net_kar": {
      "absolute_min": 0,
      "absolute_max": 999999999,
      "error_msg": "Net kar tutarı 0 ile 999.999.999 ₺ arasında olmalıdır."
    },
    "faiz": {
      "absolute_min": 0,
      "absolute_max": 999999999,
      "error_msg": "Faiz gideri tutarı 0 ile 999.999.999 ₺ arasında olmalıdır."
    },
    "vergi": {
      "absolute_min": 0,
      "absolute_max": 999999999,
      "error_msg": "Vergi tutarı 0 ile 999.999.999 ₺ arasında olmalıdır."
    },
    "amortisman": {
      "absolute_min": 0,
      "absolute_max": 999999999,
      "error_msg": "Amortisman tutarı 0 ile 999.999.999 ₺ arasında olmalıdır."
    },
    "EBITDA": {
      "absolute_min": -999999999,
      "absolute_max": 9999999999,
      "error_msg": "EBITDA değeri beklenen aralığın dışında! Hesaplamayı kontrol edin."
    }
  },
  "standards": [
    "ISO 9999 Finansal Raporlama Standardı",
    "GAAP (Genel Kabul Görmüş Muhasebe İlkeleri)"
  ]
}
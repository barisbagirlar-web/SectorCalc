{
  "id": "varlik_dagilimi",
  "name": "Varlık Dağılımı Hesaplayıcı",
  "description": "Portföyün hedeflenen varlık sınıflarına (hisse, tahvil, nakit) yüzdelik dağılımını hesaplar.",
  "category": "finans",
  "inputs": [
    {
      "id": "Portfoy",
      "name": "Portföy Toplamı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000000000
    },
    {
      "id": "Hisse",
      "name": "Hisse Senedi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Tahvil",
      "name": "Tahvil Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Nakit",
      "name": "Nakit Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "HisseTutar",
      "name": "Hisse Senedi Tutarı",
      "unit": "₺",
      "type": "number",
      "precision": 2
    },
    {
      "id": "TahvilTutar",
      "name": "Tahvil Tutarı",
      "unit": "₺",
      "type": "number",
      "precision": 2
    },
    {
      "id": "NakitTutar",
      "name": "Nakit Tutarı",
      "unit": "₺",
      "type": "number",
      "precision": 2
    }
  ],
  "formulas": {
    "HisseTutar": "Portfoy * (Hisse / 100)",
    "TahvilTutar": "Portfoy * (Tahvil / 100)",
    "NakitTutar": "Portfoy * (Nakit / 100)"
  },
  "warnings": [
    {
      "condition": "Hisse + Tahvil + Nakit != 100",
      "severity": "WARNING",
      "source": "Finansal Planlama Standardı",
      "message": "Hisse, Tahvil ve Nakit oranlarının toplamı %100 olmalıdır. Dağılım oranlarını kontrol edin."
    },
    {
      "condition": "Portfoy <= 0",
      "severity": "WARNING",
      "source": "Finansal Planlama Standardı",
      "message": "Portföy tutarı 0 veya negatif olamaz. Geçerli bir portföy değeri giriniz."
    },
    {
      "condition": "Hisse < 0 || Tahvil < 0 || Nakit < 0",
      "severity": "WARNING",
      "source": "Finansal Planlama Standardı",
      "message": "Varlık oranları negatif olamaz. Yüzde değerlerini 0-100 aralığında giriniz."
    },
    {
      "condition": "Hisse > 100 || Tahvil > 100 || Nakit > 100",
      "severity": "WARNING",
      "source": "Finansal Planlama Standardı",
      "message": "Varlık oranları %100'ü geçemez. Dağılım oranlarını kontrol edin."
    }
  ],
  "validations": {
    "Portfoy": {
      "absolute_min": 0,
      "absolute_max": 1000000000,
      "error_msg": "Portföy tutarı 0 ile 1.000.000.000 ₺ arasında olmalıdır."
    },
    "Hisse": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Hisse senedi oranı %0 ile %100 arasında olmalıdır."
    },
    "Tahvil": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Tahvil oranı %0 ile %100 arasında olmalıdır."
    },
    "Nakit": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Nakit oranı %0 ile %100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 22222:2005 (Kişisel Finansal Planlama)",
    "Finansal Piyasalar Düzenleme Kurumu (FSA) Portföy Yönetimi İlkeleri"
  ]
}
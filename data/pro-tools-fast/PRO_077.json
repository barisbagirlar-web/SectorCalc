{
  "id": "motosiklet_kredisi_hesaplama",
  "name": "Motosiklet Kredisi Hesaplama",
  "description": "Motosiklet alımında aylık taksit tutarını hesaplar.",
  "category": "finans",
  "inputs": [
    {
      "id": "fiyat",
      "name": "Motosiklet Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "pesin",
      "name": "Peşinat",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "faiz",
      "name": "Yıllık Faiz",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 120
    }
  ],
  "formulas": {
    "kredi": "fiyat - pesin",
    "aylik_faiz": "faiz / 100 / 12",
    "taksit": "IF(vade > 0, IF(aylik_faiz == 0, kredi / vade, kredi * aylik_faiz * POW(1 + aylik_faiz, vade) / (POW(1 + aylik_faiz, vade) - 1)), 0)"
  },
  "outputs": [
    {
      "id": "taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "description": "Motosiklet alımının aylık taksit tutarı"
    }
  ],
  "warnings": [
    {
      "condition": "pesin > fiyat",
      "severity": "WARNING",
      "source": "Finansal Mantık",
      "message": "Peşinat, motosiklet fiyatından büyük olamaz."
    },
    {
      "condition": "faiz > 50",
      "severity": "WARNING",
      "source": "Tüketici Koruma",
      "message": "Yıllık faiz oranı %50'nin üzerinde, yüksek maliyetli bir kredi olabilir."
    },
    {
      "condition": "vade > 60",
      "severity": "WARNING",
      "source": "Finansal Risk",
      "message": "Vade 60 aydan uzun, toplam faiz maliyeti artabilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer girişi yapılamaz."
    }
  },
  "standards": [
    "ISO 21504"
  ]
}
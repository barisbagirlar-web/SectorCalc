{
  "id": "hacimsel_agirlik",
  "name": "124. Hacimsel Ağırlık Hesaplama",
  "category": "Lojistik",
  "description": "Kargonun kapladığı hacmin ağırlık karşılığını hesaplar. Gerçek ağırlık ile karşılaştırılarak taşıma ücreti belirlenir.",
  "inputs": [
    {
      "id": "en_cm",
      "name": "En",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 9999,
      "placeholder": "Örn: 30"
    },
    {
      "id": "boy_cm",
      "name": "Boy",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 9999,
      "placeholder": "Örn: 40"
    },
    {
      "id": "yukseklik_cm",
      "name": "Yükseklik",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 9999,
      "placeholder": "Örn: 50"
    },
    {
      "id": "bolen",
      "name": "Bölen (Hacimsel Faktör)",
      "unit": "Sayı",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 10000,
      "placeholder": "Örn: 5000 (hava yolu), 3000 (kara yolu)",
      "suggested_default": 5000
    }
  ],
  "outputs": [
    {
      "id": "desi_kg",
      "name": "Desi (Hacimsel Ağırlık)",
      "unit": "kg",
      "description": "Kargonun kapladığı alanın ağırlık karşılığı",
      "formula": "desi_kg = (en_cm * boy_cm * yukseklik_cm) / MAX(1, bolen)"
    }
  ],
  "warnings": [
    {
      "condition": "bolen != 5000 AND bolen != 3000",
      "severity": "WARNING",
      "source": "IATA / Kargo Taşımacılığı Standardı",
      "message": "Hacimsel faktör genellikle hava yolu için 5000, kara yolu için 3000’dir. Girdiğiniz değerin doğruluğunu kontrol edin."
    },
    {
      "condition": "en_cm > 300 OR boy_cm > 300 OR yukseklik_cm > 300",
      "severity": "WARNING",
      "source": "Taşıma Sınırlamaları",
      "message": "Kolon boyutları 300 cm üzerinde ise palet veya özel taşıma gerekebilir. Lütfen taşıma şartlarını kontrol edin."
    },
    {
      "condition": "desi_kg > 1000",
      "severity": "WARNING",
      "source": "Aşırı Hacim Uyarısı",
      "message": "Hacimsel ağırlık 1000 kg’ı aşıyor. Bu boyutlarda bir kargonun taşınması ek ücretlendirme gerektirebilir."
    }
  ],
  "validation": {
    "en_cm": {
      "absolute_min": 1,
      "error_msg": "En değeri 1 cm'den küçük olamaz."
    },
    "boy_cm": {
      "absolute_min": 1,
      "error_msg": "Boy değeri 1 cm'den küçük olamaz."
    },
    "yukseklik_cm": {
      "absolute_min": 1,
      "error_msg": "Yükseklik değeri 1 cm'den küçük olamaz."
    },
    "bolen": {
      "absolute_min": 1,
      "error_msg": "Bölen değeri 1'den küçük olamaz. Taşıma faktörü geçersiz."
    }
  },
  "standards": [
    "ISO 8601 (Zaman ve Hacim Standardı Referansı)",
    "IATA Hacimsel Ağırlık Yönergeleri"
  ]
}
{
  "id": "kiralik_gayrimenkul_analizi",
  "name": "Kiralık Gayrimenkul Analizi",
  "category": "Finans",
  "description": "Brüt kira, boşluk oranı, işletme giderleri ve kredi taksidi sonrası net nakit akışını hesaplar.",
  "inputs": [
    {
      "id": "brut_kira",
      "name": "Brüt Kira",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "bosluk",
      "name": "Boşluk Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "isletme",
      "name": "İşletme Giderleri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "kredi",
      "name": "Kredi Taksidi",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    }
  ],
  "outputs": [
    {
      "id": "net_nakit",
      "name": "Net Nakit Akışı",
      "unit": "₺",
      "description": "Tüm giderler ve kredi sonrası aylık cebe giren nakit",
      "formula": "IF(brut_kira < 0, 0, (brut_kira * (1 - bosluk / 100)) - isletme - kredi)",
      "confidence_label": "KESİN",
      "decimal_places": 2
    }
  ],
  "warnings": [
    {
      "condition": "bosluk > 20",
      "severity": "WARNING",
      "source": "piyasa_standarti",
      "message": "Boşluk oranı %20'yi aşıyor, yüksek boşluk riski var. Piyasa ortalaması %5-10 arasıdır."
    },
    {
      "condition": "isletme > (brut_kira * 0.5)",
      "severity": "WARNING",
      "source": "gelir_gider_analizi",
      "message": "İşletme giderleri brüt kiranın %50'sini aşıyor, maliyet kontrolü gerekebilir."
    },
    {
      "condition": "net_nakit < 0",
      "severity": "WARNING",
      "source": "nakit_akisi_analizi",
      "message": "Net nakit akışı negatif, yatırım nakit kaybettiriyor olabilir."
    }
  ],
  "validation": {
    "brut_kira": {
      "absolute_min": 0,
      "error_msg": "Brüt kira negatif olamaz."
    },
    "bosluk": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Boşluk oranı 0-100 arasında olmalıdır."
    },
    "isletme": {
      "absolute_min": 0,
      "error_msg": "İşletme giderleri negatif olamaz."
    },
    "kredi": {
      "absolute_min": 0,
      "error_msg": "Kredi taksidi negatif olamaz."
    }
  },
  "standards": [
    "ISO 15686-5:2017 - Binalar ve inşa edilmiş varlıklar - Hizmet ömrü planlaması - Bölüm 5: Yaşam döngüsü maliyeti"
  ]
}
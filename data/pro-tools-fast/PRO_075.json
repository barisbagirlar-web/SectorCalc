{
  "id": "araba_kredisi",
  "name": "Araba Kredisi Hesaplama",
  "description": "Taşıt kredisinin peşinat düşülmüş aylık taksitini hesaplar",
  "inputs": [
    {
      "id": "fiyat",
      "name": "Fiyat",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 50000000
    },
    {
      "id": "pesin",
      "name": "Peşinat",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50000000
    },
    {
      "id": "faiz",
      "name": "Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 120
    }
  ],
  "formulas": [
    {
      "output": "kredi",
      "formula": "kredi = MAX(0, fiyat - pesin)",
      "description": "Kredi tutarı (peşinat düşülmüş)"
    },
    {
      "output": "aylik_faiz",
      "formula": "aylik_faiz = faiz / 100 / 12",
      "description": "Aylık faiz oranı (ondalık)"
    },
    {
      "output": "taksit",
      "formula": "taksit = IF(aylik_faiz > 0, kredi * aylik_faiz * POW(1 + aylik_faiz, vade) / (POW(1 + aylik_faiz, vade) - 1), kredi / vade)",
      "description": "Aylık taksit tutarı (₺)"
    }
  ],
  "outputs": [
    {
      "id": "taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "type": "number",
      "description": "Taşıt kredisinin peşinat düşülmüş aylık taksiti"
    },
    {
      "id": "toplam_geri_odeme",
      "name": "Toplam Geri Ödeme",
      "unit": "₺",
      "type": "number",
      "description": "Kredi vadesi sonunda ödenecek toplam tutar"
    },
    {
      "id": "toplam_faiz",
      "name": "Toplam Faiz",
      "unit": "₺",
      "type": "number",
      "description": "Toplam faiz maliyeti"
    }
  ],
  "warnings": [
    {
      "condition": "pesin / fiyat < 0.20",
      "severity": "WARNING",
      "source": "BDDK Düzenlemesi",
      "message": "Peşinat oranı %20'nin altında, kredi onayı zorlaşabilir"
    },
    {
      "condition": "faiz > 5",
      "severity": "WARNING",
      "source": "Genel Piyasa",
      "message": "Faiz oranı %5'in üzerinde, yüksek maliyetli kredi"
    },
    {
      "condition": "vade > 48",
      "severity": "WARNING",
      "source": "ISO 18091",
      "message": "Vade 48 aydan uzun, toplam faiz yükü artar"
    },
    {
      "condition": "kredi / fiyat > 0.80",
      "severity": "WARNING",
      "source": "BDDK Düzenlemesi",
      "message": "Kredi tutarı araç değerinin %80'ini aşıyor, riskli kredi"
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer girilemez"
    },
    "fiyat_pesin_uyumsuzluk": {
      "condition": "pesin > fiyat",
      "error_msg": "Peşinat, araç fiyatından büyük olamaz"
    },
    "faiz_sifir_kontrol": {
      "condition": "faiz == 0 && vade == 0",
      "error_msg": "Faiz ve vade aynı anda sıfır olamaz"
    }
  },
  "standards": [
    "ISO 18091",
    "BDDK Taşıt Kredisi Yönetmeliği"
  ]
}
{
  "id": "kripto_para_kar_hesabi",
  "name": "Kripto Para Kârı",
  "category": "Finans",
  "description": "Borsa kesintileri sonrası net kripto kazancını hesaplar.",
  "inputs": [
    {
      "id": "alis_fiyati",
      "name": "Alış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "satis_fiyati",
      "name": "Satış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "miktar",
      "name": "Miktar",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "komisyon_orani",
      "name": "Komisyon",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "net_kar",
      "name": "Net Kâr",
      "unit": "₺",
      "description": "Borsa kesintileri sonrası net kripto kazancı",
      "formula": "net_kar = IF(satis_fiyati > alis_fiyati, 1, 0) * (satis_fiyati - alis_fiyati) * miktar * (1 - komisyon_orani / 100) // Net kâr = (Satış - Alış) * Miktar * (1 - Komisyon/100)",
      "result_type": "number",
      "decimal_places": 2
    }
  ],
  "warnings": [
    {
      "condition": "komisyon_orani > 10",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Komisyon oranı %10'u aşıyor, yüksek kesinti uygulanacak."
    },
    {
      "condition": "satis_fiyati < alis_fiyati",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Satış fiyatı alış fiyatından düşük, zarar edilecek."
    },
    {
      "condition": "miktar * satis_fiyati > 100000",
      "severity": "WARNING",
      "source": "Vergi Düzenlemesi",
      "message": "İşlem hacmi 100.000 ₺'yi aşıyor, vergi beyanı gerekebilir."
    }
  ],
  "validation": {
    "negatif_fiyat": {
      "absolute_min": 0,
      "error_msg": "Fiyat değerleri sıfırdan küçük olamaz."
    },
    "negatif_miktar": {
      "absolute_min": 0,
      "error_msg": "Miktar sıfırdan küçük olamaz."
    },
    "komisyon_hatali": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Komisyon oranı %0-100 aralığında olmalıdır."
    }
  },
  "standards": [
    "ISO 31000 - Risk Yönetimi",
    "TMS 23 - Borçlanma Maliyetleri"
  ]
}
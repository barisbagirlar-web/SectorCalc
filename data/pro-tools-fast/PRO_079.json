{
  "id": "ogrenci_kredisi_hesaplama",
  "name": "Öğrenci Kredisi Hesaplama",
  "description": "Mezuniyet sonrası erteleme süresi bitince başlayan taksit hesaplaması",
  "category": "finans",
  "inputs": [
    {
      "id": "tutar",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 500000
    },
    {
      "id": "faiz",
      "name": "Yıllık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 50
    },
    {
      "id": "vade",
      "name": "Toplam Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 360
    },
    {
      "id": "grace_period",
      "name": "Erteleme Süresi",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 60
    }
  ],
  "formulas": [
    {
      "output_variable": "aylik_taksit",
      "formula": "aylik_taksit = IF(vade - grace_period <= 0, 0, (tutar * (faiz / 100 / 12) * POW(1 + (faiz / 100 / 12), vade - grace_period)) / (POW(1 + (faiz / 100 / 12), vade - grace_period) - 1))",
      "description": "Aylık taksit (erteleme sonrası başlayan dönemde sabit taksit)",
      "unit": "₺",
      "confidence_label": "KESİN"
    }
  ],
  "outputs": [
    {
      "id": "aylik_taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "confidence_label": "KESİN",
      "source": "Hesaplanan"
    }
  ],
  "smart_warnings": [
    {
      "condition": "grace_period >= vade",
      "severity": "WARNING",
      "source": "Finans Standardı",
      "message": "Erteleme süresi vadeye eşit veya büyük, taksit hesaplanamaz."
    },
    {
      "condition": "faiz > 30",
      "severity": "WARNING",
      "source": "Tüketici Kredisi Standardı",
      "message": "Faiz oranı %30'un üzerinde, yüksek maliyetli kredi."
    },
    {
      "condition": "vade - grace_period < 3",
      "severity": "WARNING",
      "source": "Finans Standardı",
      "message": "Kalan vade 3 aydan az, taksit miktarı çok yüksek olabilir."
    }
  ],
  "validation": {
    "tutar": {
      "absolute_min": 1000,
      "absolute_max": 500000,
      "error_msg": "Kredi tutarı 1.000 ₺ ile 500.000 ₺ arasında olmalıdır."
    },
    "faiz": {
      "absolute_min": 0.01,
      "absolute_max": 50,
      "error_msg": "Yıllık faiz oranı %0.01 ile %50 arasında olmalıdır."
    },
    "vade": {
      "absolute_min": 1,
      "absolute_max": 360,
      "error_msg": "Vade 1 ile 360 ay arasında olmalıdır."
    },
    "grace_period": {
      "absolute_min": 0,
      "absolute_max": 60,
      "error_msg": "Erteleme süresi 0 ile 60 ay arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 22988:2020",
    "Tüketici Kredisi Yönetmeliği"
  ]
}
{
  "id": "vadeli_islemler_44",
  "name": "44. Vadeli İşlemler (Futures)",
  "description": "Vadeli kontratın fiyat hareketinden doğan nakit sonuç (Kar/Zarar) hesaplaması.",
  "category": "Finans",
  "inputs": [
    {
      "id": "GirisFiyati",
      "name": "Giriş Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999
    },
    {
      "id": "CikisFiyati",
      "name": "Çıkış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999
    },
    {
      "id": "Carpan",
      "name": "Çarpan",
      "unit": "Sayı",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 1000
    },
    {
      "id": "Lot",
      "name": "Lot",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100000
    }
  ],
  "outputs": [
    {
      "id": "KarZarar",
      "name": "Kar / Zarar",
      "unit": "₺",
      "description": "Vadeli kontratın fiyat hareketinden doğan nakit sonuç. Pozitif değer kar, negatif değer zarardır."
    }
  ],
  "formulas": {
    "KarZarar": "(CikisFiyati - GirisFiyati) * Carpan * Lot"
  },
  "smart_warnings": [
    {
      "condition": "GirisFiyati <= 0 || CikisFiyati <= 0",
      "severity": "ERROR",
      "source": "Piyasa Standardı",
      "message": "Fiyatlar sıfır veya negatif olamaz."
    },
    {
      "condition": "Carpan <= 0 || Lot <= 0",
      "severity": "ERROR",
      "source": "Piyasa Standardı",
      "message": "Çarpan ve Lot değerleri pozitif olmalıdır."
    },
    {
      "condition": "KarZarar > 1000000",
      "severity": "WARNING",
      "source": "Risk Yönetimi",
      "message": "Kar/Zarar 1.000.000 ₺'yi aşıyor, yüksek risk işlemi."
    },
    {
      "condition": "KarZarar < -1000000",
      "severity": "WARNING",
      "source": "Risk Yönetimi",
      "message": "Kar/Zarar -1.000.000 ₺'den daha düşük, yüksek risk işlemi."
    },
    {
      "condition": "ABS(CikisFiyati - GirisFiyati) / GirisFiyati > 0.1",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Fiyat değişimi %10'u geçiyor, oynaklık yüksek."
    }
  ],
  "validations": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Fiyat, çarpan veya lot değeri negatif olamaz."
    },
    "sifir_hata": {
      "error_msg": "Fiyat, çarpan veya lot sıfır girilemez."
    }
  },
  "standards": [
    "ISO 10962",
    "ISO 3166"
  ]
}
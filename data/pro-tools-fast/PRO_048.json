{
  "id": "nft_kar_hesaplama",
  "name": "NFT Kârı Hesaplama",
  "version": "1.0",
  "description": "Gas ve royalty kesintileri sonrası net kripto kazancını hesaplar. Girdiler ETH cinsinden girilmelidir.",
  "inputs": [
    {
      "id": "alis",
      "name": "Alış Fiyatı",
      "unit": "ETH",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "satis",
      "name": "Satış Fiyatı",
      "unit": "ETH",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "gas",
      "name": "Gas Ücreti (Toplam)",
      "unit": "ETH",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "royalty",
      "name": "Royalty Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formulas": [
    {
      "description": "Net ETH = Satış - Alış - Gas - (Satış * Royalty / 100)",
      "output": "NetETH = satis - alis - gas - ((satis * royalty) / 100)",
      "unit": "ETH",
      "type": "number"
    }
  ],
  "smart_warnings": [
    {
      "condition": "satis < alis",
      "severity": "WARNING",
      "source": "Muhasebe Standardı",
      "message": "Satış fiyatı alış fiyatından düşük, işlem zarar ile sonuçlanacak."
    },
    {
      "condition": "satis < 0.001",
      "severity": "WARNING",
      "source": "Likidite Standardı",
      "message": "Satış fiyatı çok düşük, işlem onaylanmayabilir veya beklenmedik kesintiler oluşabilir."
    },
    {
      "condition": "gas > satis * 0.1",
      "severity": "WARNING",
      "source": "Gas Optimizasyonu",
      "message": "Gas ücreti satış fiyatının %10'undan fazla, kârlılık sorgulanabilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Değer negatif olamaz. Lütfen geçerli bir ETH miktarı girin."
    },
    "royalty_hata": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Royalty oranı %0 ile %100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 8000-2: Veri Kalitesi",
    "ERC-721: NFT Standardı"
  ]
}
{
  "id": "fiyat_defter_pb_orani",
  "name": "Fiyat/Defter (P/B) Oranı",
  "category": "Finansal Oranlar",
  "description": "Piyasanın şirketin defter değerine biçtiği primi gösteren oran.",
  "inputs": [
    {
      "id": "piyasa_degeri",
      "name": "Piyasa Değeri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999999999
    },
    {
      "id": "ozsermaye",
      "name": "Özsermaye",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 999999999999
    }
  ],
  "outputs": [
    {
      "id": "pb_orani",
      "name": "Fiyat/Defter (P/B) Oranı",
      "unit": "Sayı",
      "description": "Piyasanın şirketin defter değerine biçtiği prim",
      "calculation": "pb_orani = piyasa_degeri / MAX(1, ozsermaye) // Piyasa değeri / (özsermaye, 1'den büyük alınır)"
    }
  ],
  "warnings": [
    {
      "condition": "ozsermaye <= 0",
      "severity": "ERROR",
      "source": "Muhasebe Standardı",
      "message": "Özsermaye sıfır veya negatif olamaz. Şirket iflas riski altında olabilir."
    },
    {
      "condition": "piyasa_degeri <= 0",
      "severity": "ERROR",
      "source": "Finansal Analiz",
      "message": "Piyasa değeri pozitif olmalıdır."
    },
    {
      "condition": "pb_orani > 50",
      "severity": "WARNING",
      "source": "Borsa İstanbul / Sektör Karşılaştırması",
      "message": "P/B oranı 50'nin üzerinde. Şirket aşırı değerlenmiş olabilir, dikkatli analiz yapınız."
    }
  ],
  "validation": [
    {
      "id": "negatif_ozsermaye",
      "target": "ozsermaye",
      "absolute_min": 1,
      "error_msg": "Özsermaye en az 1 ₺ olmalıdır."
    },
    {
      "id": "sifir_piyasa_degeri",
      "target": "piyasa_degeri",
      "absolute_min": 0.01,
      "error_msg": "Piyasa değeri en az 0.01 ₺ olmalıdır."
    }
  ],
  "standards": [
    "IFRS (Uluslararası Finansal Raporlama Standartları)",
    "TMS (Türkiye Muhasebe Standartları)"
  ]
}
{
  "id": "mortgage_karsilastirma",
  "name": "Mortgage Karşılaştırma",
  "description": "İki farklı kredi teklifinin aylık taksitlerini karşılaştırır ve farkı hesaplar.",
  "inputs": [
    {
      "id": "kredi1",
      "name": "Kredi 1 Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 99999999
    },
    {
      "id": "faiz1",
      "name": "Faiz 1 (Yıllık)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.1,
      "absolute_max": 50
    },
    {
      "id": "kredi2",
      "name": "Kredi 2 Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 99999999
    },
    {
      "id": "faiz2",
      "name": "Faiz 2 (Yıllık)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.1,
      "absolute_max": 50
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 480
    }
  ],
  "outputs": [
    {
      "id": "aylik_taksit1",
      "name": "Kredi 1 Aylık Taksit",
      "unit": "₺",
      "type": "number"
    },
    {
      "id": "aylik_taksit2",
      "name": "Kredi 2 Aylık Taksit",
      "unit": "₺",
      "type": "number"
    },
    {
      "id": "fark",
      "name": "Aylık Taksit Farkı",
      "unit": "₺",
      "type": "number"
    }
  ],
  "formulas": [
    "aylik_faiz1 = faiz1 / 100 / 12",
    "aylik_faiz2 = faiz2 / 100 / 12",
    "aylik_taksit1 = kredi1 * (aylik_faiz1 * POW(1 + aylik_faiz1, vade)) / (POW(1 + aylik_faiz1, vade) - 1)",
    "aylik_taksit2 = kredi2 * (aylik_faiz2 * POW(1 + aylik_faiz2, vade)) / (POW(1 + aylik_faiz2, vade) - 1)",
    "fark = aylik_taksit1 - aylik_taksit2"
  ],
  "smart_warnings": [
    {
      "condition": "vade > 360",
      "severity": "WARNING",
      "source": "Geleneksel Mortgage Standardı",
      "message": "Vade 30 yılı (360 ay) aşıyor; uzun vadeli kredilerde toplam maliyet önemli ölçüde artar."
    },
    {
      "condition": "faiz1 > 20 OR faiz2 > 20",
      "severity": "WARNING",
      "source": "Risk Yönetimi / Basel III",
      "message": "Faiz oranı %20'nin üzerinde; bu yüksek riskli bir kredi olarak değerlendirilebilir."
    },
    {
      "condition": "kredi1 > 5000000 OR kredi2 > 5000000",
      "severity": "WARNING",
      "source": "BDDK / Konut Kredisi Yönetmeliği",
      "message": "Kredi tutarı 5.000.000 ₺'yi aşıyor; büyük ölçekli kredilerde ek teminat istenebilir."
    },
    {
      "condition": "fark > 0",
      "severity": "WARNING",
      "source": "Tüketici Karşılaştırma",
      "message": "Kredi 1 aylık taksiti Kredi 2'den yüksek; toplam maliyet analizi yapmanız önerilir."
    }
  ],
  "validations": {
    "kredi1": {
      "negatif_hata": {
        "absolute_min": 1000,
        "error_msg": "Kredi 1 tutarı en az 1.000 ₺ olmalıdır."
      }
    },
    "faiz1": {
      "negatif_hata": {
        "absolute_min": 0.1,
        "error_msg": "Faiz oranı %0.1'den küçük olamaz."
      }
    },
    "kredi2": {
      "negatif_hata": {
        "absolute_min": 1000,
        "error_msg": "Kredi 2 tutarı en az 1.000 ₺ olmalıdır."
      }
    },
    "faiz2": {
      "negatif_hata": {
        "absolute_min": 0.1,
        "error_msg": "Faiz oranı %0.1'den küçük olamaz."
      }
    },
    "vade": {
      "negatif_hata": {
        "absolute_min": 1,
        "error_msg": "Vade en az 1 ay olmalıdır."
      }
    }
  },
  "standards": [
    "ISO 18091",
    "Basel III",
    "BDDK Konut Kredisi Yönetmeliği"
  ]
}
{
  "id": "emeklilik_retirement",
  "name": "Emeklilik (Retirement)",
  "description": "Mevcut birikim ve aylık katkı ile belirli yıl sonunda ulaşılacak tahmini portföy değerini hesaplar.",
  "category": "finans",
  "inputs": [
    {
      "id": "MevcutBirikim",
      "name": "Mevcut Birikim",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "AylikKatki",
      "name": "Aylık Katkı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "Faiz",
      "name": "Faiz",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Yil",
      "name": "Yıl",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    }
  ],
  "formula": "GelecekDeger = (MevcutBirikim * POW((1 + Faiz/1200), (Yil*12))) + (AylikKatki * ((POW((1 + Faiz/1200), (Yil*12)) - 1) / MAX(0.0001, (Faiz/1200))))",
  "outputs": [
    {
      "id": "GelecekDeger",
      "name": "Gelecek Portföy Değeri",
      "unit": "TL",
      "description": "Emeklilik tarihinde ulaşılacak tahmini portföy değeri"
    }
  ],
  "warnings": [
    {
      "condition": "Yil > 50",
      "severity": "WARNING",
      "source": "ISO 30414",
      "message": "Yatırım süresi 50 yılı aşkın; uzun vadeli tahminler gerçekçi olmayabilir, enflasyon ve risk faktörlerini göz önünde bulundurun."
    },
    {
      "condition": "Faiz > 30",
      "severity": "WARNING",
      "source": "ISO 31000",
      "message": "Faiz oranı %30 üzerinde; piyasa standartlarına göre yüksek risk işareti, gerçekçiliğini kontrol edin."
    },
    {
      "condition": "MevcutBirikim > 10000000",
      "severity": "WARNING",
      "source": "ISO 30414",
      "message": "Mevcut birikim çok yüksek; vergi ve likidite planlamasını profesyonel danışmanla yapın."
    },
    {
      "condition": "AylikKatki > 100000",
      "severity": "WARNING",
      "source": "ISO 30414",
      "message": "Aylık katkı miktarı piyasa ortalamasının çok üzerinde; bütçe uygunluğunu teyit edin."
    }
  ],
  "validation": {
    "MevcutBirikim": {
      "absolute_min": 0,
      "error_msg": "Mevcut birikim negatif olamaz."
    },
    "AylikKatki": {
      "absolute_min": 0,
      "error_msg": "Aylık katkı negatif olamaz."
    },
    "Faiz": {
      "absolute_min": 0,
      "error_msg": "Faiz oranı negatif olamaz."
    },
    "Yil": {
      "absolute_min": 1,
      "error_msg": "Yıl en az 1 olmalıdır."
    }
  },
  "standards": [
    "ISO 30414",
    "ISO 31000"
  ]
}
{
  "id": "kdv_ab_ioss",
  "name": "KDV (AB - IOSS) Hesaplayıcı",
  "description": "150 EUR altı AB ithalatında alıcı ülkeye ödenen KDV hesaplaması.",
  "inputs": [
    {
      "id": "net_fiyat",
      "name": "Net Fiyat",
      "unit": "EUR",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 149.99
    },
    {
      "id": "kargo",
      "name": "Kargo",
      "unit": "EUR",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 149.99
    },
    {
      "id": "ulke_kdv",
      "name": "Ülke KDV",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formulas": [
    "kdv = (net_fiyat + kargo) * (ulke_kdv / 100)"
  ],
  "outputs": [
    {
      "id": "kdv",
      "name": "KDV",
      "unit": "EUR",
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "warnings": [
    {
      "condition": "net_fiyat > 149.99",
      "severity": "WARNING",
      "source": "AB IOSS Sınırı",
      "message": "Net fiyat 150 EUR üzerinde; IOSS kapsamı dışına çıkabilirsiniz. Standart ithalat prosedürü uygulanabilir."
    },
    {
      "condition": "kargo > 149.99",
      "severity": "WARNING",
      "source": "AB IOSS Sınırı",
      "message": "Kargo ücreti 150 EUR üzerinde; IOSS sınırı aşılabilir. Toplam değeri kontrol edin."
    },
    {
      "condition": "net_fiyat + kargo > 149.99",
      "severity": "WARNING",
      "source": "AB IOSS Sınırı",
      "message": "Toplam (Net Fiyat + Kargo) 150 EUR'yu aşıyor; bu hesaplama IOSS kapsamında geçerli olmayabilir."
    }
  ],
  "validations": [
    {
      "target": "net_fiyat",
      "condition": "net_fiyat < 0",
      "severity": "ERROR",
      "message": "Net fiyat negatif olamaz."
    },
    {
      "target": "kargo",
      "condition": "kargo < 0",
      "severity": "ERROR",
      "message": "Kargo ücreti negatif olamaz."
    },
    {
      "target": "ulke_kdv",
      "condition": "ulke_kdv < 0 || ulke_kdv > 100",
      "severity": "ERROR",
      "message": "KDV yüzdesi 0 ile 100 arasında olmalıdır."
    }
  ],
  "standards": [
    "AB IOSS (Import One-Stop Shop) - 150 EUR eşik değeri"
  ]
}
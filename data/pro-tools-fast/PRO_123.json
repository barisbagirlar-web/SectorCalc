{
  "calc": {
    "id": "ebay_ucreti",
    "name": "eBay Ücreti Hesaplama",
    "description": "eBay satış işlemlerinde oluşan nihai değer ücreti ve sabit kesintileri hesaplar.",
    "version": "1.0",
    "category": "e-ticaret",
    "standards": [
      "ISO 4217"
    ],
    "inputs": [
      {
        "id": "satis",
        "name": "Satış Tutarı",
        "unit": "TL",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 99999
      },
      {
        "id": "kategori",
        "name": "Kategori Yüzdesi",
        "unit": "%",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 100
      },
      {
        "id": "sabit",
        "name": "Sabit Kesinti",
        "unit": "TL",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 99999
      }
    ],
    "outputs": [
      {
        "id": "kesinti",
        "name": "Toplam Kesinti",
        "unit": "TL",
        "description": "eBay nihai değer ücreti ve sabit kesintiler toplamı",
        "formula": "kesinti = (satis * kategori / 100) + sabit"
      }
    ],
    "warnings": [
      {
        "condition": "satis > 50000",
        "severity": "WARNING",
        "source": "eBay Politikası",
        "message": "Satış tutarı 50.000 TL'yi aşıyor, yüksek değerli ürün kategorisinde ek ücretler kontrol edilmelidir."
      },
      {
        "condition": "kategori > 15",
        "source": "eBay Politika Standardı",
        "severity": "WARNING",
        "message": "Kategori yüzdesi %15'in üzerinde, manuel onay gerekebilir."
      },
      {
        "condition": "sabit > 50",
        "severity": "WARNING",
        "source": "Genel Uygulama",
        "message": "Sabit kesinti 50 TL'yi aşıyor, maliyet analizi yapılmalıdır."
      },
      {
        "condition": "satis <= 0",
        "severity": "ERROR",
        "source": "Geçerlilik",
        "message": "Satış tutarı 0 veya negatif olamaz."
      }
    ],
    "validation": {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Satış tutarı sıfırdan küçük olamaz."
      }
    }
  }
}
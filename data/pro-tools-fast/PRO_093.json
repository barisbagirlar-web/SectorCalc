{
  "id": "hisse_opsiyonlari_espp",
  "name": "Hisse Opsiyonları (ESPP)",
  "description": "İndirimli fiyatla alınabilecek hisse adedini hesaplar.",
  "inputs": [
    {
      "id": "PiyasaFiyati",
      "name": "Piyasa Fiyatı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 99999
    },
    {
      "id": "İskonto",
      "name": "İskonto Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Katki",
      "name": "Katkı Payı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 99999
    }
  ],
  "formulas": [
    "AlimFiyati = PiyasaFiyati * (1 - İskonto / 100) // İndirimli alım fiyatı",
    "HisseSayisi = Katki / MAX(0.0001, AlimFiyati) // Alınabilecek hisse adedi"
  ],
  "outputs": [
    {
      "id": "HisseSayisi",
      "name": "Hisse Sayısı",
      "unit": "Adet",
      "description": "İndirimli fiyatla alınabilecek hisse adedi",
      "formula": "Katki / MAX(0.0001, PiyasaFiyati * (1 - İskonto / 100))"
    }
  ],
  "smart_warnings": [
    {
      "condition": "İskonto < 5",
      "severity": "WARNING",
      "source": "ESPP Standardı",
      "message": "İskonto oranı %5'in altında, avantaj düşük olabilir."
    },
    {
      "condition": "Katki > 5000",
      "severity": "WARNING",
      "source": "ESPP Standardı",
      "message": "Katkı payı yüksek, yıllık limitleri kontrol edin."
    },
    {
      "condition": "HisseSayisi > 1000",
      "severity": "WARNING",
      "source": "ESPP Standardı",
      "message": "Yüksek hisse adedi, piyasa riskine karşı dikkatli olun."
    }
  ],
  "validations": [
    {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Piyasa fiyatı sıfır veya negatif olamaz."
      }
    },
    {
      "negatif_hata_iskonto": {
        "absolute_min": 0,
        "error_msg": "İskonto oranı negatif olamaz."
      }
    },
    {
      "negatif_hata_katki": {
        "absolute_min": 0,
        "error_msg": "Katkı payı negatif olamaz."
      }
    }
  ],
  "standards": [
    "ISO 21748",
    "ESPP Uygulama Esasları"
  ]
}
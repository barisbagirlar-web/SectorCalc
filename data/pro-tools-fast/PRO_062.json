{
  "id": "kira_vs_satin_alma",
  "name": "Kira vs Satın Alma - Fiyat/Kira Oranı Analizi",
  "category": "finans",
  "description": "Fiyat/Kira oranına göre optimal barınma stratejisi belirleme aracı.",
  "inputs": [
    {
      "id": "ev_fiyati",
      "name": "Ev Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "yillik_kira",
      "name": "Yıllık Kira",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "yillik_gider",
      "name": "Yıllık Gider (satın alma bakım, vergi, sigorta)",
      "unit": "₺",
      "type": "number",
      "required": false,
      "confidence_label": "TAHMİNİ",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "fiyat_kira_orani",
      "name": "Fiyat/Kira Oranı",
      "unit": "yıl",
      "description": "Yıllık kira başına ev fiyatının kat sayısı. 20 yıl eşik değer."
    },
    {
      "id": "karar",
      "name": "Optimal Strateji",
      "unit": "metin",
      "description": "KİRALA veya SATIN AL kararı."
    }
  ],
  "formulas": [
    "fiyat_kira_orani = ev_fiyati / MAX(1, yillik_kira)",
    "karar = IF(fiyat_kira_orani > 20, 'KİRALA', IF(fiyat_kira_orani <= 15, 'SATIN AL', 'DEĞERLENDİR'))"
  ],
  "warnings": [
    {
      "condition": "yillik_kira <= 0",
      "severity": "ERROR",
      "source": "Hesaplama Gerekliliği",
      "message": "Yıllık kira sıfır veya negatif olamaz. Lütfen geçerli bir kira girin."
    },
    {
      "condition": "ev_fiyati > 10000000",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Ev fiyatı 10 milyon ₺ üzerinde. Yüksek fiyat segmenti için ek risk değerlendirmesi önerilir."
    },
    {
      "condition": "fiyat_kira_orani < 10",
      "severity": "WARNING",
      "source": "Yatırım Standardı",
      "message": "Fiyat/Kira oranı 10 yıl altı, satın almak güçlü yatırım fırsatı olabilir."
    },
    {
      "condition": "yillik_gider > 0 && yillik_gider > ev_fiyati * 0.05",
      "severity": "WARNING",
      "source": "ISO 15686",
      "message": "Yıllık giderler ev fiyatının %5'ini aşıyor. Uzun vadede maliyet etkinliği azalabilir."
    }
  ],
  "validations": {
    "ev_fiyati": {
      "absolute_min": 0,
      "error_msg": "Ev fiyatı negatif olamaz."
    },
    "yillik_kira": {
      "absolute_min": 0,
      "error_msg": "Yıllık kira negatif olamaz."
    },
    "fiyat_kira_orani": {
      "absolute_min": 0,
      "absolute_max": 99999,
      "error_msg": "Fiyat/Kira oranı beklenen aralığın dışında."
    }
  },
  "standards": [
    "ISO 15686 - Bina ve İnşaat Varlıkları",
    "RICS Değerleme Standartları"
  ],
  "version": "1.0.0",
  "language": "tr"
}
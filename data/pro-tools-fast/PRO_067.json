{
  "id": "emlak_komisyonu",
  "name": "Emlak Komisyonu Hesaplama",
  "description": "Gayrimenkul satışında emlakçıya ödenecek aracılık hizmet bedelini hesaplar.",
  "inputs": [
    {
      "id": "SatisBedeli",
      "name": "Satış Bedeli",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 100000000
    },
    {
      "id": "KomisyonOrani",
      "name": "Komisyon Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.5,
      "absolute_max": 10
    }
  ],
  "outputs": [
    {
      "id": "Komisyon",
      "name": "Komisyon Tutarı",
      "unit": "₺",
      "description": "Emlakçıya ödenecek aracılık hizmet bedeli"
    }
  ],
  "formulas": {
    "Komisyon": "SatisBedeli * KomisyonOrani / 100"
  },
  "warnings": [
    {
      "condition": "SatisBedeli > 10000000",
      "severity": "WARNING",
      "source": "Genel Uygulama",
      "message": "Satış bedeli 10.000.000 ₺ üzeri, komisyon oranını teyit edin."
    },
    {
      "condition": "KomisyonOrani > 5",
      "severity": "WARNING",
      "source": "Tüketici Hakları",
      "message": "Komisyon oranı %5'in üzerinde, piyasa ortalamasının üstünde olabilir."
    },
    {
      "condition": "SatisBedeli < 50000",
      "severity": "WARNING",
      "source": "Pratik Deneyim",
      "message": "Satış bedeli çok düşük, lütfen doğruluğunu kontrol edin."
    }
  ],
  "validations": {
    "SatisBedeli": {
      "absolute_min": 1000,
      "absolute_max": 100000000,
      "error_msg": "Satış bedeli 1.000 ₺ ile 100.000.000 ₺ arasında olmalıdır."
    },
    "KomisyonOrani": {
      "absolute_min": 0.5,
      "absolute_max": 10,
      "error_msg": "Komisyon oranı %0.5 ile %10 arasında olmalıdır."
    },
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Değer negatif olamaz."
    }
  },
  "standards": [
    "ISO 9001: Kalite Yönetim Sistemi - Hesaplama Doğrulama Prosedürü",
    "Tüketicinin Korunması Hakkında Kanun (TKHK)"
  ]
}
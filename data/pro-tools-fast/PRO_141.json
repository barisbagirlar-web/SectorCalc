{
  "id": "ucuş_maliyeti_137",
  "name": "Uçuş Maliyeti",
  "description": "Havayolunda yolcu başına düşen operasyonel maliyet hesaplama aracı",
  "calculator_type": "operational",
  "target_audience": "Mühendisler, teknisyenler, operasyon yöneticileri, planlamacılar",
  "confidence_label": "KESİN",
  "inputs": [
    {
      "id": "mesafe",
      "name": "Mesafe",
      "unit": "km",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 20000
    },
    {
      "id": "yolcusayisi",
      "name": "Yolcu Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 850
    },
    {
      "id": "koltukmaliyeti",
      "name": "Koltuk Maliyeti",
      "unit": "TL/km",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50
    }
  ],
  "outputs": [
    {
      "id": "toplam_maliyet_tl",
      "name": "Toplam Maliyet",
      "unit": "TL",
      "source_formula": "toplam_maliyet_tl = mesafe * koltukmaliyeti // Toplam uçuş maliyeti",
      "result_type": "calculated",
      "decimal_places": 2
    },
    {
      "id": "birim_maliyet",
      "name": "Birim Maliyet (Yolcu Başına)",
      "unit": "TL",
      "source_formula": "birim_maliyet = toplam_maliyet_tl / MAX(1, yolcusayisi) // Yolcu başına maliyet",
      "result_type": "calculated",
      "decimal_places": 2
    }
  ],
  "smart_warnings": [
    {
      "condition": "mesafe > 15000",
      "severity": "WARNING",
      "source": "ICAO Standartları",
      "message": "Mesafe 15.000 km üzerinde: ultra uzun menzil uçuş; yakıt ikmali ve mürettebat dinlenme planlaması gerekebilir."
    },
    {
      "condition": "yolcusayisi < 50",
      "severity": "WARNING",
      "source": "IATA Rehberi",
      "message": "Yolcu sayısı 50'nin altında: düşük doluluk oranı operasyonel karlılığı olumsuz etkileyebilir."
    },
    {
      "condition": "koltukmaliyeti > 10",
      "severity": "WARNING",
      "source": "Sektör Karşılaştırması",
      "message": "Koltuk maliyeti 10 TL/km üzerinde: maliyet verimliliği analizi önerilir."
    }
  ],
  "validation": {
    "negatif_mesafe": {
      "absolute_min": 0,
      "error_msg": "Mesafe negatif olamaz."
    },
    "negatif_yolcusayisi": {
      "absolute_min": 1,
      "error_msg": "Yolcu sayısı en az 1 olmalıdır."
    },
    "negatif_koltukmaliyeti": {
      "absolute_min": 0,
      "error_msg": "Koltuk maliyeti negatif olamaz."
    }
  },
  "standards": [
    "ICAO Annex 6",
    "IATA Operational Safety Audit"
  ]
}
{
  "calculator": {
    "id": "annuity_income",
    "name": "5. Yıllık Gelir (Annuity)",
    "description": "Belirli bir anapara, faiz oranı ve dönem boyunca düzenli aralıklarla çekilebilecek sabit gelir (ödeme) tutarını hesaplar. Kredi taksiti veya yatırım getirisi hesaplamalarında kullanılır.",
    "category": "Finans",
    "inputs": [
      {
        "id": "anapara",
        "name": "Anapara",
        "unit": "₺",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 999999999,
        "sensible_min": 1000,
        "sensible_max": 100000000
      },
      {
        "id": "faiz",
        "name": "Faiz (Yıllık)",
        "unit": "%",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 100,
        "sensible_min": 0.1,
        "sensible_max": 50
      },
      {
        "id": "donem",
        "name": "Dönem (Ay)",
        "unit": "Ay",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 1,
        "absolute_max": 1200,
        "sensible_min": 3,
        "sensible_max": 360
      }
    ],
    "outputs": [
      {
        "id": "odeme",
        "name": "Aylık Ödeme (Gelir)",
        "unit": "₺",
        "type": "number",
        "formula": "anapara * ( (faiz/12/100) / MAX(0.0001, 1 - POW(1 + faiz/12/100, -donem)) )",
        "description": "Her ay düzenli çekilebilecek sabit gelir tutarı",
        "round": 2,
        "confidence_label": "KESİN"
      }
    ],
    "warnings": [
      {
        "condition": "faiz < 0.1",
        "severity": "INFO",
        "source": "Piyasa Standardı",
        "message": "Faiz oranı çok düşük, gerçekçi olmayabilir (0.1 altı kontrol edin).",
        "suggestion": "Yıllık faiz oranı en az %0.1 olmalıdır."
      },
      {
        "condition": "donem > 360",
        "severity": "WARNING",
        "source": "Bankacılık Standardı",
        "message": "Dönem 30 yılı aşıyor (360 ay), uzun vadeli planlarda faiz dalgalanmalarına dikkat edin.",
        "suggestion": "30 yıl üzeri dönemlerde faiz sabitliği garanti değildir."
      },
      {
        "condition": "anapara <= 0",
        "severity": "ERROR",
        "source": "Finansal Kural",
        "message": "Anapara sıfır veya negatif olamaz.",
        "suggestion": "Lütfen pozitif bir anapara girin."
      },
      {
        "condition": "odeme > anapara * 0.5",
        "severity": "WARNING",
        "source": "Risk Yönetimi",
        "message": "Aylık ödeme anaparanın yarısından fazla. Yüksek faiz veya kısa vade nedeniyle gerçekçi olmayabilir.",
        "suggestion": "Dönemi artırmayı veya faizi düşürmeyi değerlendirin."
      }
    ],
    "validations": {
      "anapara": {
        "negatif_hata": {
          "absolute_min": 0,
          "error_msg": "Anapara negatif olamaz.",
          "suggestion": "Lütfen 0 veya daha büyük bir değer girin."
        },
        "min_risk": {
          "sensible_min": 1000,
          "warning_msg": "Anapara 1000 ₺ altı ise hesaplama anlamsız olabilir."
        }
      },
      "faiz": {
        "negatif_hata": {
          "absolute_min": 0,
          "error_msg": "Faiz oranı negatif olamaz.",
          "suggestion": "Lütfen 0 veya daha büyük bir değer girin."
        },
        "sifir_hatasi": {
          "absolute_min": 0.0001,
          "error_msg": "Faiz sıfır ise formül tanımsız.",
          "suggestion": "Faiz %0.01 (0.0001) altı kabul edilmez."
        }
      },
      "donem": {
        "negatif_hata": {
          "absolute_min": 1,
          "error_msg": "Dönem 1 aydan az olamaz.",
          "suggestion": "Minimum dönem 1 aydır."
        }
      }
    },
    "standards": [
      "ISO 30400 — Finansal Hesaplamalar",
      "GAAP / UFRS — Düzenli Ödeme Hesaplama"
    ],
    "version": "1.0.0"
  }
}
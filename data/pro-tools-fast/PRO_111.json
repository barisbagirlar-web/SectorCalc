{
  "id": "borc_devir_hizi",
  "name": "Borç Devir Hızı Hesaplama",
  "category": "Finansal Analiz",
  "description": "Tedarikçilere olan borçların ödenme ortalama süresini hesaplar.",
  "inputs": [
    {
      "id": "YillikCOGS",
      "name": "Yıllık Satılan Malın Maliyeti (COGS)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "placeholder": "Örn: 5000000"
    },
    {
      "id": "OrtBorc",
      "name": "Ortalama Borç (Tedarikçi Borçları)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "placeholder": "Örn: 1000000"
    }
  ],
  "outputs": [
    {
      "id": "DevirHizi",
      "name": "Borç Devir Hızı",
      "unit": "Yıl",
      "description": "Tedarikçi borçlarının yıllık devir sayısı."
    },
    {
      "id": "Odeme",
      "name": "Ortalama Ödeme Süresi",
      "unit": "Gün",
      "description": "Tedarikçilere borçların ödenme ortalama süresi."
    }
  ],
  "formulas": [
    "DevirHizi = YillikCOGS / MAX(0.0001, OrtBorc) // Borç devir hızı hesaplanır",
    "Odeme = 365 / MAX(0.0001, DevirHizi) // Ortalama ödeme süresi gün cinsinden"
  ],
  "standards": [
    "ISO 30414",
    "GAAP Finansal Oranlar"
  ],
  "warnings": [
    {
      "condition": "OrtBorc <= 0",
      "severity": "WARNING",
      "source": "Finansal Analiz Standardı",
      "message": "Ortalama borç sıfır veya negatif olamaz. Lütfen geçerli bir değer girin."
    },
    {
      "condition": "YillikCOGS <= 0",
      "severity": "WARNING",
      "source": "Finansal Analiz Standardı",
      "message": "Yıllık satılan malın maliyeti sıfır veya negatif olamaz. Lütfen geçerli bir değer girin."
    },
    {
      "condition": "Odeme > 365",
      "severity": "WARNING",
      "source": "Likidite Riski Değerlendirmesi",
      "message": "Ortalama ödeme süresi 365 günü aşıyor. Tedarikçi ilişkileri ve nakit akışı kontrol edilmelidir."
    },
    {
      "condition": "Odeme < 1",
      "severity": "WARNING",
      "source": "Finansal Veri Tutarlılığı",
      "message": "Ortalama ödeme süresi 1 günden az. Verilerin doğruluğunu kontrol edin."
    }
  ],
  "validation": {
    "negatif_hata": {
      "condition": "YillikCOGS < 0 OR OrtBorc < 0",
      "error_msg": "Girdiler negatif olamaz. Lütfen pozitif değerler girin."
    }
  }
}
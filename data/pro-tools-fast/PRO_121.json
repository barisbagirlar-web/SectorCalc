{
  "id": "shopify_kar",
  "name": "Shopify Kârı",
  "description": "Shopify kesintileri sonrası net e-ticaret kârı hesaplama aracı",
  "version": "2.0",
  "category": "e-ticaret",
  "inputs": [
    {
      "id": "satis",
      "name": "Satış (Brüt Gelir)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "urun",
      "name": "Ürün Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "kargo",
      "name": "Kargo Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "platform_yuzde",
      "name": "Platform Komisyon Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "sabit",
      "name": "Sabit Giderler (Aylık/Ürün Başına)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "net_kar",
      "name": "Net Kar",
      "unit": "TL",
      "description": "Shopify kesintileri sonrası net e-ticaret kârı",
      "formula": "net_kar = satis - urun - kargo - (satis * platform_yuzde / 100) - sabit",
      "result_type": "number"
    }
  ],
  "smart_warnings": [
    {
      "condition": "satis > 0 AND urun >= satis",
      "severity": "WARNING",
      "source": "ISO 9001:2015 Kalite Yönetimi",
      "message": "Ürün maliyeti satışı aşıyor veya eşit; işletme zarar ediyor. Tedarik veya fiyatlandırma stratejisini gözden geçirin."
    },
    {
      "condition": "kargo > satis * 0.30",
      "severity": "WARNING",
      "source": "Lojistik Standardı",
      "message": "Kargo maliyeti satışın %30’undan fazla; kargo anlaşmalarınızı optimize edin."
    },
    {
      "condition": "platform_yuzde > 20",
      "severity": "WARNING",
      "source": "Shopify Standartları",
      "message": "Platform komisyon oranı %20’nin üzerinde; alternatif satış kanalları değerlendirin."
    },
    {
      "condition": "sabit > satis * 0.50",
      "severity": "WARNING",
      "source": "Finansal Kontrol Standardı",
      "message": "Sabit giderler satışın yarısından fazla; sabit maliyetleri düşürün veya satış hacmini artırın."
    }
  ],
  "validation": {
    "satis": {
      "absolute_min": 0,
      "error_msg": "Satış (brüt gelir) negatif olamaz. Lütfen geçerli bir değer girin."
    },
    "urun": {
      "absolute_min": 0,
      "error_msg": "Ürün maliyeti negatif olamaz."
    },
    "kargo": {
      "absolute_min": 0,
      "error_msg": "Kargo maliyeti negatif olamaz."
    },
    "platform_yuzde": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Platform komisyon oranı 0-100 arasında olmalıdır."
    },
    "sabit": {
      "absolute_min": 0,
      "error_msg": "Sabit giderler negatif olamaz."
    }
  },
  "standards": [
    "ISO 9001:2015",
    "Shopify Standartları",
    "Lojistik Standardı",
    "Finansal Kontrol Standardı"
  ],
  "calculation_group": "e-ticaret_kar",
  "confidence": "yuksek"
}
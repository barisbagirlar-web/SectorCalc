{
  "calculator": {
    "id": "abc_siniflandirma",
    "name": "ABC Sınıflandırma",
    "description": "Stok kalemlerinin yıllık finansal değerine göre A (%80), B (%15), C (%5) sınıflarına ayrılması.",
    "inputs": [
      {
        "id": "yillik_talep",
        "name": "Yıllık Talep",
        "unit": "Adet",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 99999
      },
      {
        "id": "birim_maliyet",
        "name": "Birim Maliyet",
        "unit": "TL",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 99999
      },
      {
        "id": "aylik_sapma_yuzde",
        "name": "Aylık Talep Sapması (%)",
        "unit": "%",
        "type": "number",
        "required": false,
        "confidence_label": "TAHMİNİ",
        "absolute_min": 0,
        "absolute_max": 100
      }
    ],
    "outputs": [
      {
        "id": "yillik_deger",
        "name": "Yıllık Stok Değeri",
        "unit": "TL",
        "type": "number",
        "source": "hesap"
      },
      {
        "id": "sinif",
        "name": "ABC Sınıfı",
        "unit": "",
        "type": "string",
        "source": "analysis"
      }
    ],
    "formulas": [
      "yillik_deger = yillik_talep * birim_maliyet",
      "sinif = IF(yillik_deger > 0, IF(yillik_deger >= PARETO_ESIK_A, 'A', IF(yillik_deger >= PARETO_ESIK_B, 'B', 'C')), 'C')  // Pareto eşikleri: A->%80, B->%15, C->%5"
    ],
    "pareto_thresholds": {
      "PARETO_ESIK_A": 0.8,
      "PARETO_ESIK_B": 0.95
    },
    "smart_warnings": [
      {
        "condition": "yillik_talep > 10000",
        "severity": "WARNING",
        "source": "ISO 9001:2015 Stok Yönetimi",
        "message": "Yıllık talep 10.000 adedin üzerinde. A sınıfı stok kalemi olarak öncelikli izleme önerilir."
      },
      {
        "condition": "birim_maliyet > 5000",
        "severity": "WARNING",
        "source": "ISO 9001:2015 Risk Analizi",
        "message": "Birim maliyet 5.000 TL'yi aşıyor. Tedarikçi risk değerlendirmesi yapılmalıdır."
      },
      {
        "condition": "aylik_sapma_yuzde > 30",
        "severity": "WARNING",
        "source": "Endüstriyel Mühendislik Standardı",
        "message": "Talep sapması %30'un üzerinde. Güvenlik stoğu seviyesi gözden geçirilmelidir."
      },
      {
        "condition": "yillik_talep < 10",
        "severity": "WARNING",
        "source": "ISO 9001:2015",
        "message": "Yıllık talep çok düşük. C sınıfı stok olarak değerlendirilebilir."
      }
    ],
    "validation": {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Talep ve maliyet negatif olamaz."
      },
      "sapma_hata": {
        "absolute_min": 0,
        "absolute_max": 100,
        "error_msg": "Sapma yüzdesi 0-100 arasında olmalıdır."
      }
    },
    "standards": [
      "ISO 9001:2015",
      "ISO 55001:2014 Varlık Yönetimi"
    ]
  }
}
{
  "tool": {
    "id": "kredi_borc_yonetimi",
    "name": "Kredi ve Borç Yönetimi Hesaplama Aracı",
    "description": "Kredi taksiti, borç ödeme planı, faiz hesaplamaları ve geri ödeme analizi yapar. Mühendisler ve finans profesyonelleri için güvenilir sonuçlar sağlar.",
    "category": "finans",
    "version": "1.0.0",
    "inputs": [
      {
        "id": "kredi_tutari",
        "name": "Kredi Tutarı",
        "unit": "TRY",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 999999999
      },
      {
        "id": "yillik_faiz_orani",
        "name": "Yıllık Faiz Oranı",
        "unit": "%",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 100
      },
      {
        "id": "vade_ayi",
        "name": "Vade (Ay)",
        "unit": "ay",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 1,
        "absolute_max": 480
      },
      {
        "id": "ekstra_odeme",
        "name": "Ekstra Aylık Ödeme",
        "unit": "TRY",
        "type": "number",
        "required": false,
        "confidence_label": "TAHMİNİ",
        "absolute_min": 0,
        "absolute_max": 999999999
      },
      {
        "id": "gecikme_gunu",
        "name": "Gecikme Günü",
        "unit": "gün",
        "type": "number",
        "required": false,
        "confidence_label": "TAHMİNİ",
        "absolute_min": 0,
        "absolute_max": 9999
      },
      {
        "id": "yapilandirma_masrafi",
        "name": "Yapılandırma Masrafı",
        "unit": "TRY",
        "type": "number",
        "required": false,
        "confidence_label": "TAHMİNİ",
        "absolute_min": 0,
        "absolute_max": 999999
      }
    ],
    "outputs": [
      {
        "id": "aylik_taksit",
        "name": "Aylık Taksit",
        "unit": "TRY",
        "description": "Kredi taksit tutarı (eşit taksitli)"
      },
      {
        "id": "toplam_geri_odeme",
        "name": "Toplam Geri Ödeme",
        "unit": "TRY",
        "description": "Vade sonuna kadar ödenecek toplam tutar"
      },
      {
        "id": "toplam_faiz",
        "name": "Toplam Faiz",
        "unit": "TRY",
        "description": "Ödenecek toplam faiz miktarı"
      },
      {
        "id": "efektif_faiz_orani",
        "name": "Efektif Faiz Oranı",
        "unit": "%",
        "description": "Yıllık efektif faiz oranı"
      },
      {
        "id": "odeme_planlari",
        "name": "Ödeme Planları",
        "unit": "JSON",
        "description": "Aylık bazda anapara, faiz, kalan borç detayları"
      }
    ],
    "formulas": [
      "aylik_faiz_orani = IF(yillik_faiz_orani > 0, yillik_faiz_orani / 100 / 12, 0)",
      "aylik_taksit = IF(aylik_faiz_orani > 0, kredi_tutari * aylik_faiz_orani * POW(1 + aylik_faiz_orani, vade_ayi) / (POW(1 + aylik_faiz_orani, vade_ayi) - 1), kredi_tutari / vade_ayi)",
      "toplam_geri_odeme = IF(vade_ayi > 0, aylik_taksit * vade_ayi, 0)",
      "toplam_faiz = IF(vade_ayi > 0, toplam_geri_odeme - kredi_tutari, 0)",
      "efektif_faiz_orani = IF(yillik_faiz_orani > 0, (POW(1 + aylik_faiz_orani, 12) - 1) * 100, 0)",
      "odeme_planlari = IF(vade_ayi > 0, 'Hesaplama yapılıyor...', 'Geçersiz vade')"
    ],
    "standards": [
      "ISO 31000:2018 Risk Yönetimi",
      "ISO 10007:2017 Konfigürasyon Yönetimi",
      "Basel III Likidite Düzenlemeleri"
    ],
    "validation": {
      "kredi_tutari_sifir": {
        "absolute_min": 1,
        "error_msg": "Kredi tutarı 0 olamaz. En az 1 TRY giriniz."
      },
      "faiz_orani_negatif": {
        "absolute_min": 0,
        "error_msg": "Faiz oranı negatif olamaz. Geçerli bir oran giriniz."
      },
      "vade_ayi_gecersiz": {
        "absolute_min": 1,
        "error_msg": "Vade en az 1 ay olmalıdır."
      },
      "ekstra_odeme_negatif": {
        "absolute_min": 0,
        "error_msg": "Ekstra ödeme negatif olamaz."
      }
    },
    "warnings": [
      {
        "condition": "yillik_faiz_orani > 50",
        "severity": "WARNING",
        "source": "TCMB Düzenlemesi",
        "message": "Yıllık faiz oranı %50'nin üzerinde. Yüksek faizli kredi olarak değerlendirilir."
      },
      {
        "condition": "vade_ayi > 120",
        "severity": "WARNING",
        "source": "BDDK Standardı",
        "message": "Vade 10 yılı (120 ay) aşıyor. Uzun vadeli kredi riskleri artar."
      },
      {
        "condition": "kredi_tutari > 1000000",
        "severity": "WARNING",
        "source": "Risk Yönetimi Protokolü",
        "message": "Kredi tutarı 1.000.000 TRY üzerinde. Detaylı finansal inceleme önerilir."
      },
      {
        "condition": "ekstra_odeme > kredi_tutari * 0.5",
        "severity": "WARNING",
        "source": "Ödeme Planı Optimizasyonu",
        "message": "Ekstra ödeme, kredi tutarının %50'sinden fazla. Kredinin erken kapanma riski."
      }
    ]
  }
}
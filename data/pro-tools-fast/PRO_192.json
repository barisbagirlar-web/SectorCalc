{
  "tool": {
    "id": "kiris_sehimi",
    "name": "Kiriş Sehimi (Deflection)",
    "description": "Yayılı yük altındaki basit kirişin maksimum çökme miktarını hesaplar."
  },
  "inputs": [
    {
      "id": "yuk",
      "name": "Yayılı Yük",
      "unit": "N/m",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000000
    },
    {
      "id": "uzunluk",
      "name": "Kiriş Uzunluğu",
      "unit": "m",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.001,
      "absolute_max": 100
    },
    {
      "id": "elastisite_modulu",
      "name": "Elastisite Modülü (E)",
      "unit": "Pa",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000000000,
      "absolute_max": 2000000000000
    },
    {
      "id": "atalet_momenti",
      "name": "Atalet Momenti (I)",
      "unit": "m⁴",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1e-12,
      "absolute_max": 10
    }
  ],
  "outputs": [
    {
      "id": "sehimsession",
      "name": "Maksimum Sehim",
      "unit": "m",
      "formula": "sehimsession = (5 * yuk * POW(uzunluk, 4)) / (384 * elastisite_modulu * atalet_momenti)",
      "description": "Yayılı yük altındaki basit kirişin maksimum çökme miktarı."
    }
  ],
  "warnings": [
    {
      "condition": "ela",
      "severity": "WARNING",
      "source": "Yapısal Güvenlik",
      "message": "Sehim değeri kiriş boyunun 1/200’ünden büyük, yapısal hasar riski var."
    },
    {
      "condition": "ela",
      "severity": "WARNING",
      "source": "ISO 178",
      "message": "Elastisite modülü 70 GPa altında (çelik için düşük), malzeme uyumsuzluğu olabilir."
    },
    {
      "condition": "ela",
      "severity": "WARNING",
      "source": "ISO 2768-1",
      "message": "Atalet momenti 1e-8 m⁴ altında, kiriş çok ince, burkulma riski yüksek."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Yük değeri negatif olamaz, fiziksel anlamsızlık."
    },
    "sifir_bolme": {
      "custom_check": "elastisite_modulu * atalet_momenti < 1e-12",
      "error_msg": "Elastisite modülü ve atalet momenti çarpımı çok küçük, sıfıra bölme riski."
    }
  },
  "standards": [
    "ISO 178",
    "ISO 2768-1",
    "Eurocode 3"
  ]
}
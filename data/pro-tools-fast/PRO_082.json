{
  "id": "kredi_karti_minimum_odeme",
  "name": "Kredi Kartı Minimum Ödeme",
  "description": "Yasal olarak ödenmesi gereken asgari ödeme tutarını hesaplar.",
  "category": "Finans",
  "inputs": [
    {
      "id": "bakiye",
      "name": "Bakiye",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999
    },
    {
      "id": "asgari_oran",
      "name": "Asgari Oran",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "faiz",
      "name": "Faiz",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    }
  ],
  "outputs": [
    {
      "id": "asgari",
      "name": "Asgari Ödeme Tutarı",
      "unit": "₺",
      "confidence_label": "KESİN",
      "formula": "asgari = MAX(bakiye * asgari_oran / 100, faiz + 10) // Yasal minimum ödeme"
    }
  ],
  "warnings": [
    {
      "condition": "bakiye > 100000",
      "severity": "WARNING",
      "source": "BDDK Düzenlemesi",
      "message": "Yüksek bakiye tespit edildi; gecikme faizi ve yasal takip riskini değerlendirin."
    },
    {
      "condition": "asgari_oran < 20",
      "severity": "WARNING",
      "source": "BDDK Düzenlemesi",
      "message": "Asgari oran yasal alt sınır olan %20'nin altında; lütfen doğrulayın."
    },
    {
      "condition": "faiz > bakiye * 0.05",
      "severity": "WARNING",
      "source": "TCMB Faiz Sınırı",
      "message": "Faiz tutarı, bakiye %5'ini aşıyor; temerrüt faizi uygulanabilir."
    }
  ],
  "validations": {
    "bakiye_negatif": {
      "absolute_min": 0,
      "error_msg": "Bakiye negatif olamaz; lütfen pozitif bir değer girin."
    },
    "asgari_oran_sinir": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Asgari oran %0 ile %100 arasında olmalıdır."
    },
    "faiz_negatif": {
      "absolute_min": 0,
      "error_msg": "Faiz tutarı negatif olamaz."
    }
  },
  "standards": [
    "BDDK Kredi Kartı Yönetmeliği",
    "ISO 20022 Finansal İletişim"
  ]
}
{
  "id": "kredi_geri_odeme_payoff",
  "name": "Kredi Geri Ödeme (Payoff)",
  "category": "finans",
  "description": "Ek ödeme ile kredinin kapanacağı kısaltılmış vade hesabı.",
  "inputs": [
    {
      "id": "anapara",
      "name": "Anapara",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "faiz",
      "name": "Faiz (Yıllık)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "odeme",
      "name": "Aylık Ödeme",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "ek_odeme",
      "name": "Ek Ödeme",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "yeni_vade",
      "name": "Yeni Vade (Kısaltılmış Süre)",
      "unit": "Ay",
      "confidence_label": "KESİN"
    }
  ],
  "formulas": [
    "yeni_vade = IF(anapara <= 0, 0, IF(faiz <= 0, 0, IF(odeme + ek_odeme <= 0, 99999, -LOG(MAX(0.0001, 1 - (anapara * (faiz / 1200)) / (odeme + ek_odeme))) / LOG(1 + faiz / 1200))))"
  ],
  "smart_warnings": [
    {
      "condition": "ek_odeme > anapara",
      "severity": "WARNING",
      "source": "Finansal Kural",
      "message": "Ek ödeme anaparadan büyük, kredi hemen kapanır."
    },
    {
      "condition": "odeme + ek_odeme <= anapara * (faiz / 1200)",
      "severity": "WARNING",
      "source": "Kredi Hesaplama Standardı",
      "message": "Ödeme tutarı aylık faizi karşılamıyor, vade sonsuza gider."
    },
    {
      "condition": "faiz > 50",
      "severity": "WARNING",
      "source": "TCMB Faiz Sınırı",
      "message": "Faiz oranı %50 üzerinde, gerçekçi olmayan değer."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer girilemez."
    },
    "sifir_anapara": {
      "absolute_min": 1,
      "error_msg": "Anapara sıfır olamaz."
    },
    "sifir_faiz": {
      "absolute_min": 0.001,
      "error_msg": "Faiz oranı sıfır olamaz."
    }
  },
  "standards": [
    "ISO 20457:2021 - Finansal Hesaplamalar",
    "TCMB Kredi Faiz Oranı Yönetmeliği"
  ]
}
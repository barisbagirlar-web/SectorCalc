{
  "id": "eoq_calculator",
  "name": "EOQ (Ekonomik Sipariş Miktarı) Hesaplayıcı",
  "description": "Toplam envanter maliyetini minimize eden optimum sipariş miktarını hesaplar.",
  "inputs": [
    {
      "id": "yillik_talep",
      "name": "Yıllık Talep",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 999999
    },
    {
      "id": "siparis_maliyeti",
      "name": "Sipariş Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "tasima_maliyeti",
      "name": "Taşıma Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "eoq",
      "name": "EOQ (Ekonomik Sipariş Miktarı)",
      "unit": "Adet",
      "description": "Toplam envanter maliyetini minimize eden optimum sipariş miktarı",
      "formula": "EOQ = SQRT(MAX(0, (2*yillik_talep*siparis_maliyeti)/MAX(0.0001, tasima_maliyeti)))"
    }
  ],
  "warnings": [
    {
      "condition": "yillik_talep <= 0",
      "severity": "ERROR",
      "source": "Hesaplama Standardı",
      "message": "Yıllık talep sıfır veya negatif olamaz. Lütfen geçerli bir değer girin."
    },
    {
      "condition": "siparis_maliyeti < 0",
      "severity": "ERROR",
      "source": "Hesaplama Standardı",
      "message": "Sipariş maliyeti negatif olamaz. Lütfen pozitif bir değer girin."
    },
    {
      "condition": "tasima_maliyeti <= 0",
      "severity": "ERROR",
      "source": "Hesaplama Standardı",
      "message": "Taşıma maliyeti sıfır veya negatif olamaz. Lütfen pozitif bir değer girin."
    },
    {
      "condition": "tasima_maliyeti > 0.95 * siparis_maliyeti || tasima_maliyeti < 0.05 * siparis_maliyeti",
      "severity": "WARNING",
      "source": "ISO 9001 Envanter Yönetimi",
      "message": "Taşıma maliyeti sipariş maliyetine göre çok yüksek veya çok düşük. EOQ hesaplaması pratikte uygun olmayabilir."
    },
    {
      "condition": "yillik_talep > 50000",
      "severity": "WARNING",
      "source": "Saha Deneyimi",
      "message": "Yıllık talep çok yüksek. EOQ modeli varsayımlarını (sabit talep, anında tedarik) kontrol edin."
    }
  ],
  "validations": {
    "yillik_talep": {
      "absolute_min": 1,
      "error_msg": "Yıllık talep en az 1 adet olmalıdır."
    },
    "siparis_maliyeti": {
      "absolute_min": 0,
      "error_msg": "Sipariş maliyeti negatif olamaz."
    },
    "tasima_maliyeti": {
      "absolute_min": 0,
      "error_msg": "Taşıma maliyeti negatif olamaz."
    }
  },
  "standards": [
    "ISO 9001 Envanter Yönetimi",
    "TS 12702"
  ],
  "version": "1.0"
}
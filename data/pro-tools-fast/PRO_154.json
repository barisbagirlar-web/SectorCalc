{
  "id": "dikiş_hatti_dengeleme",
  "name": "149. Dikiş Hattı Dengeleme",
  "description": "Konfeksiyon dikim hattının operatör bazlı verimlilik hesabı",
  "inputs": [
    {
      "id": "smv_toplam",
      "name": "SMV Toplam",
      "unit": "Dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "takt_time",
      "name": "Takt Time",
      "unit": "Dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.0001,
      "absolute_max": 99999
    },
    {
      "id": "operator",
      "name": "Operatör",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 99999
    }
  ],
  "output": {
    "id": "verimlilik",
    "name": "Verimlilik",
    "unit": "Yüzde",
    "formula": "verimlilik = (smv_toplam / MAX(0.0001, (operator * takt_time))) * 100",
    "description": "Konfeksiyon dikim hattının operatör bazlı verimliliği"
  },
  "warnings": [
    {
      "condition": "smv_toplam > (operator * takt_time)",
      "severity": "WARNING",
      "source": "ISO 9001",
      "message": "SMV Toplam, operatör sayısı ve takt time çarpımını aşıyor; hat kapasite üstü çalışıyor olabilir, denge kontrolü yapın."
    },
    {
      "condition": "verimlilik > 100",
      "severity": "WARNING",
      "source": "ISO 9001",
      "message": "Verimlilik %100'ü aştı; bu fiziksel olarak mümkün değil, girdi değerlerini kontrol edin."
    },
    {
      "condition": "verimlilik < 50",
      "severity": "WARNING",
      "source": "ISO 9001",
      "message": "Verimlilik %50'nin altında; hat dengeleme sorunu olabilir, bant düzenini gözden geçirin."
    }
  ],
  "validation": {
    "smv_toplam": {
      "absolute_min": 0,
      "error_msg": "SMV toplam sıfırdan küçük olamaz."
    },
    "takt_time": {
      "absolute_min": 0.0001,
      "error_msg": "Takt time sıfırdan büyük olmalıdır."
    },
    "operator": {
      "absolute_min": 1,
      "error_msg": "Operatör sayısı en az 1 olmalıdır."
    }
  },
  "standards": [
    "ISO 9001"
  ]
}
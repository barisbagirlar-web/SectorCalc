{
  "id": "emeklilik_karsilastirma",
  "name": "Geleneksel vs Roth IRA Karşılaştırmalı Net Emeklilik Birikimi",
  "description": "Geleneksel ve Roth IRA hesapları arasında net emeklilik birikimini karşılaştırır. Geleneksel'de katkı öncesi vergi avantajı, Roth'ta ise çekim sırasında vergi avantajı vardır.",
  "inputs": [
    {
      "id": "katki",
      "name": "Katkı Tutarı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 500000
    },
    {
      "id": "vergi_orani",
      "name": "Vergi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50
    },
    {
      "id": "buyume_orani",
      "name": "Büyüme Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 30
    },
    {
      "id": "yil",
      "name": "Yıl",
      "unit": "yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 50
    }
  ],
  "outputs": [
    {
      "id": "geleneksel_net",
      "name": "Geleneksel Net Emeklilik Birikimi",
      "unit": "TL",
      "required": true,
      "confidence_label": "KESİN"
    },
    {
      "id": "roth_net",
      "name": "Roth Net Emeklilik Birikimi",
      "unit": "TL",
      "required": true,
      "confidence_label": "KESİN"
    }
  ],
  "formulas": {
    "geleneksel_net": "katki * POW(1 + buyume_orani / 100, yil) * (1 - vergi_orani / 100)",
    "roth_net": "(katki * (1 - vergi_orani / 100)) * POW(1 + buyume_orani / 100, yil)"
  },
  "smart_warnings": [
    {
      "condition": "vergi_orani > 35",
      "severity": "WARNING",
      "source": "Vergi Analizi Standardı",
      "message": "Vergi oranı %35'in üzerinde. Roth IRA genellikle daha avantajlı olabilir."
    },
    {
      "condition": "buyume_orani > 20",
      "severity": "WARNING",
      "source": "Piyasa Beklentisi Standardı",
      "message": "Büyüme oranı %20'nin üzerinde; bu gerçekçi olmayan bir varsayım olabilir. Piyasa ortalamalarını kontrol edin."
    },
    {
      "condition": "yil < 5",
      "severity": "WARNING",
      "source": "Emeklilik Planlaması Standardı",
      "message": "Yatırım süresi 5 yıldan kısa; emeklilik hesaplamaları uzun vadeli planlanmalıdır."
    }
  ],
  "validations": {
    "katki_min": {
      "absolute_min": 0,
      "error_msg": "Katkı tutarı negatif olamaz."
    },
    "vergi_orani_min": {
      "absolute_min": 0,
      "error_msg": "Vergi oranı yüzdesi negatif olamaz."
    },
    "vergi_orani_max": {
      "absolute_max": 50,
      "error_msg": "Vergi oranı %50'yi geçemez."
    },
    "buyume_orani_min": {
      "absolute_min": 0,
      "error_msg": "Büyüme oranı yüzdesi negatif olamaz."
    },
    "buyume_orani_max": {
      "absolute_max": 30,
      "error_msg": "Büyüme oranı %30'u geçemez."
    },
    "yil_min": {
      "absolute_min": 1,
      "error_msg": "Yıl en az 1 olmalıdır."
    },
    "yil_max": {
      "absolute_max": 50,
      "error_msg": "Yıl 50'yi geçemez."
    }
  },
  "standards": [
    "ISO 22222:2005 (Kişisel Finansal Planlama Standardı)",
    "Vergi Mevzuatı ve Emeklilik Yatırım Fonları Yönetmeliği"
  ]
}
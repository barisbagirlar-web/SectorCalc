{
  "id": "fha_kredisi_hesaplama",
  "name": "71. FHA Kredisi Hesaplama",
  "category": "Finans",
  "description": "Devlet destekli FHA kredisi kapsamında peşin sigorta primi ve aylık sigorta maliyetini hesaplar.",
  "inputs": [
    {
      "id": "kredi",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999
    },
    {
      "id": "pesin_prim",
      "name": "Peşin Sigorta Primi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "yillik_prim",
      "name": "Yıllık Sigorta Primi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "pesin",
      "name": "Peşin Sigorta Primi",
      "unit": "₺",
      "type": "number",
      "source": "hesap"
    },
    {
      "id": "aylik",
      "name": "Aylık Sigorta Primi",
      "unit": "₺",
      "type": "number",
      "source": "hesap"
    }
  ],
  "formulas": [
    "pesin = (kredi * pesin_prim) / 100 // Peşin prim toplam kredi üzerinden yüzde olarak hesaplanır",
    "aylik = ((kredi * yillik_prim) / 100) / 12 // Yıllık prim 12 aya bölünerek aylık maliyet bulunur"
  ],
  "smart_warnings": [
    {
      "condition": "kredi > 500000",
      "severity": "WARNING",
      "source": "FHA Kredi Limiti",
      "message": "Kredi tutarı 500.000 ₺ üzerinde; yüksek risk primi değerlendirmesi gerekebilir."
    },
    {
      "condition": "pesin_prim > 3",
      "severity": "WARNING",
      "source": "FHA Standartları",
      "message": "Peşin sigorta primi %3'ün üzerinde; lütfen geçerli FHA oran tablosunu kontrol edin."
    },
    {
      "condition": "yillik_prim > 1.5",
      "severity": "WARNING",
      "source": "FHA Standartları",
      "message": "Yıllık sigorta primi %1.5'in üzerinde; oranın doğruluğunu teyit edin."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer girilemez; lütfen geçerli bir pozitif sayı girin."
    }
  },
  "standards": [
    "FHA Kredi Sigorta Yönergeleri"
  ]
}
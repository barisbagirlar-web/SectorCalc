{
  "id": "black_scholes_call",
  "name": "Black-Scholes Avrupa Tipi Alım Opsiyonu Prim Hesaplama",
  "description": "S, K, r, t, v girdileriyle Avrupa tipi alım opsiyonunun teorik prim değerini (C) hesaplar. d1 ve d2 ara değişkenlerdir.",
  "inputs": [
    {
      "id": "S",
      "name": "Dayanak Varlık Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999
    },
    {
      "id": "K",
      "name": "Kullanım Fiyatı (Strike)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999
    },
    {
      "id": "r",
      "name": "Risksiz Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "t",
      "name": "Vade (Yıl)",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.0001,
      "absolute_max": 100
    },
    {
      "id": "v",
      "name": "Volatilite",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 1000
    }
  ],
  "outputs": [
    {
      "id": "d1",
      "name": "Ara Değişken d1",
      "unit": "",
      "description": "Black-Scholes d1 formülü",
      "formula": "d1 = (IF(MAX(1, K) <= 0, LOG(S), LOG(S / K)) + ( (r/100) + POW(v/100, 2) / 2 ) * t) / ( (v/100) * SQRT(MAX(0.0001, t)) )"
    },
    {
      "id": "d2",
      "name": "Ara Değişken d2",
      "unit": "",
      "description": "Black-Scholes d2 formülü",
      "formula": "d2 = d1 - (v/100) * SQRT(MAX(0.0001, t))"
    },
    {
      "id": "N_d1",
      "name": "Kümülatif Normal Dağılım N(d1)",
      "unit": "",
      "description": "d1 değerinin standart normal kümülatif dağılım fonksiyonu (yaklaşık hesaplama)",
      "formula": "N_d1 = IF(d1 > 0, 1 - (1 / (1 + 0.2316419 * ABS(d1))) * (1 / SQRT(2 * PI())) * EXP(-POW(d1, 2) / 2) * (0.31938153 + (-0.356563782 + (1.781477937 + (-1.821255978 + 1.330274429 * (1 / (1 + 0.2316419 * ABS(d1)))) * (1 / (1 + 0.2316419 * ABS(d1)))) * (1 / (1 + 0.2316419 * ABS(d1)))), (1 / (1 + 0.2316419 * ABS(d1))) * (1 / SQRT(2 * PI())) * EXP(-POW(d1, 2) / 2) * (0.31938153 + (-0.356563782 + (1.781477937 + (-1.821255978 + 1.330274429 * (1 / (1 + 0.2316419 * ABS(d1)))) * (1 / (1 + 0.2316419 * ABS(d1)))) * (1 / (1 + 0.2316419 * ABS(d1)))))"
    },
    {
      "id": "N_d2",
      "name": "Kümülatif Normal Dağılım N(d2)",
      "unit": "",
      "description": "d2 değerinin standart normal kümülatif dağılım fonksiyonu (yaklaşık hesaplama)",
      "formula": "N_d2 = IF(d2 > 0, 1 - (1 / (1 + 0.2316419 * ABS(d2))) * (1 / SQRT(2 * PI())) * EXP(-POW(d2, 2) / 2) * (0.31938153 + (-0.356563782 + (1.781477937 + (-1.821255978 + 1.330274429 * (1 / (1 + 0.2316419 * ABS(d2)))) * (1 / (1 + 0.2316419 * ABS(d2)))) * (1 / (1 + 0.2316419 * ABS(d2)))), (1 / (1 + 0.2316419 * ABS(d2))) * (1 / SQRT(2 * PI())) * EXP(-POW(d2, 2) / 2) * (0.31938153 + (-0.356563782 + (1.781477937 + (-1.821255978 + 1.330274429 * (1 / (1 + 0.2316419 * ABS(d2)))) * (1 / (1 + 0.2316419 * ABS(d2)))) * (1 / (1 + 0.2316419 * ABS(d2)))))"
    },
    {
      "id": "C",
      "name": "Alım Opsiyonu Primi",
      "unit": "₺",
      "description": "Avrupa tipi alım opsiyonunun teorik prim değeri",
      "formula": "C = S * N_d1 - K * EXP( -(r/100) * t ) * N_d2"
    }
  ],
  "smart_warnings": [
    {
      "condition": "v <= 0",
      "severity": "ERROR",
      "source": "Matematiksel Kısıt",
      "message": "Volatilite sıfır veya negatif olamaz. Opsiyon değeri tanımsızdır."
    },
    {
      "condition": "t > 50",
      "severity": "WARNING",
      "source": "Piyasa Pratiği",
      "message": "Vade 50 yıldan fazla. Black-Scholes modeli bu kadar uzun vadelerde güvenilir değildir. Likidite ve temettü risklerini göz önünde bulundurun."
    },
    {
      "condition": "r > 50",
      "severity": "WARNING",
      "source": "Piyasa Pratiği",
      "message": "Risksiz faiz oranı %50'den yüksek. Gelişmiş piyasalarda bu oran olağan dışıdır. Enflasyon veya hiperenflasyon durumlarına karşı model hassasiyetini kontrol edin."
    },
    {
      "condition": "S <= 0 OR K <= 0",
      "severity": "ERROR",
      "source": "Matematiksel Kısıt",
      "message": "Dayanak varlık fiyatı ve kullanım fiyatı pozitif olmalıdır."
    },
    {
      "condition": "v > 200",
      "severity": "WARNING",
      "source": "Piyasa Pratiği",
      "message": "Volatilite %200'ün üzerinde. Bu değer piyasa için çok yüksektir, model sonuçları aşırı duyarlı olabilir."
    }
  ],
  "validation": {
    "S_hata": {
      "absolute_min": 0.01,
      "error_msg": "Dayanak varlık fiyatı 0.01 ₺'den küçük olamaz."
    },
    "K_hata": {
      "absolute_min": 0.01,
      "error_msg": "Kullanım fiyatı 0.01 ₺'den küçük olamaz."
    },
    "t_hata": {
      "absolute_min": 0.0001,
      "error_msg": "Vade 0.0001 yıldan küçük olamaz."
    },
    "v_hata": {
      "absolute_min": 0.01,
      "error_msg": "Volatilite %0.01'den küçük olamaz."
    }
  },
  "standards": [
    "Black-Scholes Opsiyon Fiyatlama Modeli (1973)"
  ]
}
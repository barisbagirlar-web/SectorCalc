{
  "id": "amazon_fba_kari",
  "name": "Amazon FBA Kâr Hesaplama",
  "category": "E-Ticaret",
  "description": "Amazon FBA satışında birim ürün başına net kâr hesaplar. Satış fiyatı, ürün maliyeti, FBA ücreti ve komisyon oranına göre kesintiler sonrası kârı verir.",
  "inputs": [
    {
      "id": "satis",
      "name": "Satış Fiyatı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "urun_maliyeti",
      "name": "Ürün Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "fba_ucreti",
      "name": "FBA Ücreti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "komisyon",
      "name": "Komisyon Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "net_kar",
      "name": "Net Kâr",
      "unit": "TL",
      "formula": "net_kar = satis - urun_maliyeti - fba_ucreti - (satis * komisyon / 100) // Amazon kesintileri sonrası birim kâr"
    }
  ],
  "warnings": [
    {
      "condition": "komisyon < 8",
      "severity": "WARNING",
      "source": "Amazon Kategori Politikası",
      "message": "Komisyon oranı %8'in altında, lütfen kategori bazlı komisyon oranını kontrol edin."
    },
    {
      "condition": "satis <= urun_maliyeti + fba_ucreti",
      "severity": "WARNING",
      "source": "Kârlılık Standardı",
      "message": "Satış fiyatı, ürün maliyeti ve FBA ücreti toplamına eşit veya daha düşük; kâr sıfır veya negatif olabilir."
    },
    {
      "condition": "net_kar < 0",
      "severity": "WARNING",
      "source": "Finansal Sürdürülebilirlik",
      "message": "Net kâr negatif, bu ürün satışı zarar ile sonuçlanmaktadır."
    }
  ],
  "validation": {
    "satis": {
      "absolute_min": 0,
      "error_msg": "Satış fiyatı negatif olamaz."
    },
    "urun_maliyeti": {
      "absolute_min": 0,
      "error_msg": "Ürün maliyeti negatif olamaz."
    },
    "fba_ucreti": {
      "absolute_min": 0,
      "error_msg": "FBA ücreti negatif olamaz."
    },
    "komisyon": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Komisyon oranı 0 ile 100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 14000",
    "Amazon İş Koşulları"
  ],
  "version": 1
}
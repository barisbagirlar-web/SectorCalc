{
  "id": "kaynak_boyutlandirma",
  "name": "Kaynak Boyutlandırma",
  "description": "Çalışma yükünü taşıyacak minimum kaynak boğaz kalınlığını hesaplar.",
  "inputs": [
    {
      "id": "yuk",
      "name": "Yük",
      "unit": "N",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100000000,
      "step": 0.1
    },
    {
      "id": "kaynak_boyu",
      "name": "Kaynak Boyu",
      "unit": "m",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.001,
      "absolute_max": 100,
      "step": 0.001
    },
    {
      "id": "kaynak_gerilmesi",
      "name": "Kaynak Gerilmesi (Emniyet)",
      "unit": "Pa",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000000,
      "absolute_max": 1000000000,
      "step": 1000000
    }
  ],
  "formulas": [
    "BogazKalinlik = yuk / MAX(0.0001, (kaynak_boyu * kaynak_gerilmesi)) // Minimum gerekli boğaz kalınlığı"
  ],
  "outputs": [
    {
      "id": "bogaz_kalinlik",
      "name": "Minimum Boğaz Kalınlığı",
      "unit": "m",
      "formula_reference": "BogazKalinlik"
    }
  ],
  "smart_warnings": [
    {
      "condition": "(yuk / MAX(0.0001, (kaynak_boyu * kaynak_gerilmesi))) < 0.003",
      "severity": "WARNING",
      "source": "ISO 2553 / AWS D1.1",
      "message": "Hesaplanan boğaz kalınlığı 3 mm'nin altında. Minimum kaynak boğaz kalınlığı uygulama standardında kontrol edilmelidir."
    },
    {
      "condition": "(yuk / MAX(0.0001, (kaynak_boyu * kaynak_gerilmesi))) > 0.05",
      "severity": "WARNING",
      "source": "ISO 2553",
      "message": "Hesaplanan boğaz kalınlığı 50 mm'nin üzerinde. Gerilme veya kaynak boyu doğruluğu yeniden kontrol edilmelidir."
    },
    {
      "condition": "kaynak_boyu / yuk < 0.0000001",
      "severity": "WARNING",
      "source": "Uygulama Standardı",
      "message": "Kaynak boyu yüke göre çok küçük. Mekanik olarak uygun olmayan birleştirme riski var."
    }
  ],
  "validation": {
    "yuk": {
      "absolute_min": 1,
      "error_msg": "Yük 1 N'den küçük olamaz."
    },
    "kaynak_boyu": {
      "absolute_min": 0.001,
      "error_msg": "Kaynak boyu 1 mm'den (0.001 m) küçük olamaz."
    },
    "kaynak_gerilmesi": {
      "absolute_min": 1000000,
      "error_msg": "Kaynak gerilmesi en az 1 MPa (1,000,000 Pa) olmalıdır."
    }
  },
  "standards": [
    "ISO 2553",
    "AWS D1.1",
    "EN 1993-1-8"
  ]
}
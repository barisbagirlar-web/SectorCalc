{
  "id": "hisse_senedi_getirisi",
  "name": "Hisse Senedi Getirisi",
  "description": "Sermaye kazancı ve temettü dahil toplam getiri hesaplaması",
  "category": "Finans",
  "inputs": [
    {
      "id": "alis",
      "name": "Alış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999
    },
    {
      "id": "satis",
      "name": "Satış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "temettu",
      "name": "Temettü",
      "unit": "₺",
      "type": "number",
      "required": false,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    }
  ],
  "outputs": [
    {
      "id": "getiri",
      "name": "Toplam Getiri",
      "unit": "%",
      "description": "Sermaye kazancı ve temettü dahil toplam getiri yüzdesi"
    }
  ],
  "formulas": [
    "getiri = IF(alis > 0, ((satis - alis) + IF(temettu == null, 0, temettu)) / MAX(1, alis) * 100, 0) // Toplam getiri yüzdesi"
  ],
  "standards": [
    "ISO 10002",
    "SPK Standartları"
  ],
  "warnings": [
    {
      "condition": "alis <= 0",
      "severity": "ERROR",
      "source": "Finansal Doğrulama",
      "message": "Alış fiyatı sıfır veya negatif olamaz. Geçerli bir değer giriniz."
    },
    {
      "condition": "satis < alis && temettu < (alis - satis)",
      "severity": "WARNING",
      "source": "Risk Yönetimi",
      "message": "Satış fiyatı alış fiyatından düşük ve temettü zararı karşılamıyor. Net zarar oluşabilir."
    },
    {
      "condition": "getiri > 50",
      "severity": "WARNING",
      "source": "Yüksek Getiri Uyarısı",
      "message": "Getiri %50'nin üzerinde. Yüksek volatilite veya hatalı veri girişi olabilir, kontrol ediniz."
    },
    {
      "condition": "temettu > alis * 0.5",
      "severity": "INFO",
      "source": "Temettü Oranı",
      "message": "Temettü, alış fiyatının %50'sinden fazla. Olağan dışı bir temettü oranı, veriyi teyit ediniz."
    }
  ],
  "validation": {
    "alis": {
      "absolute_min": 0.01,
      "error_msg": "Alış fiyatı 0.01 ₺'den az olamaz."
    },
    "satis": {
      "absolute_min": 0,
      "error_msg": "Satış fiyatı negatif olamaz."
    },
    "temettu": {
      "absolute_min": 0,
      "error_msg": "Temettü negatif olamaz."
    },
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Tüm mali değerler negatif olamaz."
    }
  }
}
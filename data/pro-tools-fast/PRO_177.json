{
  "id": "anova_analysis",
  "name": "170. Varyans Analizi (ANOVA)",
  "description": "Grup ortalamaları arası farkın istatistiksel anlamlılığını test eder. F değerini hesaplar.",
  "version": 1,
  "inputs": [
    {
      "id": "grup_sayisi",
      "name": "Grup Sayısı",
      "unit": "adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 2,
      "absolute_max": 100
    },
    {
      "id": "genel_ortalama",
      "name": "Genel Ortalama",
      "unit": "",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -99999,
      "absolute_max": 99999
    },
    {
      "id": "grup_1_ortalama",
      "name": "Grup 1 Ortalaması",
      "unit": "",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -99999,
      "absolute_max": 99999
    },
    {
      "id": "grup_1_eleman_sayisi",
      "name": "Grup 1 Eleman Sayısı",
      "unit": "adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 99999
    },
    {
      "id": "grup_1_std_sapma",
      "name": "Grup 1 Std Sapma",
      "unit": "",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "grup_2_ortalama",
      "name": "Grup 2 Ortalaması",
      "unit": "",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -99999,
      "absolute_max": 99999
    },
    {
      "id": "grup_2_eleman_sayisi",
      "name": "Grup 2 Eleman Sayısı",
      "unit": "adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 99999
    },
    {
      "id": "grup_2_std_sapma",
      "name": "Grup 2 Std Sapma",
      "unit": "",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "grup_3_ortalama",
      "name": "Grup 3 Ortalaması",
      "unit": "",
      "type": "number",
      "required": false,
      "confidence_label": "TAHMİNİ",
      "absolute_min": -99999,
      "absolute_max": 99999
    },
    {
      "id": "grup_3_eleman_sayisi",
      "name": "Grup 3 Eleman Sayısı",
      "unit": "adet",
      "type": "number",
      "required": false,
      "confidence_label": "TAHMİNİ",
      "absolute_min": 1,
      "absolute_max": 99999
    },
    {
      "id": "grup_3_std_sapma",
      "name": "Grup 3 Std Sapma",
      "unit": "",
      "type": "number",
      "required": false,
      "confidence_label": "TAHMİNİ",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "f_degeri",
      "name": "F Değeri",
      "unit": "",
      "description": "Hesaplanan Fisher F istatistiği"
    },
    {
      "id": "gruplararasi_varyans",
      "name": "Gruplar Arası Varyans",
      "unit": "",
      "description": "Gruplar arasındaki değişkenlik"
    },
    {
      "id": "grupici_varyans",
      "name": "Grup İçi Varyans",
      "unit": "",
      "description": "Gruplar içindeki ortalama değişkenlik"
    }
  ],
  "formulas": {
    "gruplararasi_varyans": "IF(grup_sayisi >= 2, ((grup_1_ortalama - genel_ortalama)^2 * grup_1_eleman_sayisi + (grup_2_ortalama - genel_ortalama)^2 * grup_2_eleman_sayisi + IF(grup_sayisi >= 3, (grup_3_ortalama - genel_ortalama)^2 * grup_3_eleman_sayisi, 0)) / MAX(1, grup_sayisi - 1), 0) // Gruplar arası kareler toplamının grup sayısı-1'e bölümü",
    "grupici_varyans": "IF(grup_sayisi >= 2, ((grup_1_eleman_sayisi - 1) * grup_1_std_sapma^2 + (grup_2_eleman_sayisi - 1) * grup_2_std_sapma^2 + IF(grup_sayisi >= 3, (grup_3_eleman_sayisi - 1) * grup_3_std_sapma^2, 0)) / MAX(1, grup_1_eleman_sayisi + grup_2_eleman_sayisi + IF(grup_sayisi >= 3, grup_3_eleman_sayisi, 0) - grup_sayisi), 0) // Grup içi kareler toplamının serbestlik derecesine bölümü",
    "f_degeri": "IF(grupici_varyans > 0, gruplararasi_varyans / grupici_varyans, 0) // F = Gruplararası Varyans / Grup İçi Varyans"
  },
  "standards": [
    "ISO 5725-1",
    "ASTM E178"
  ],
  "warnings": [
    {
      "condition": "grup_sayisi < 2",
      "severity": "WARNING",
      "source": "ISO 5725-1",
      "message": "ANOVA için en az 2 grup gereklidir. Grup sayısı 2'den az olamaz."
    },
    {
      "condition": "grupici_varyans == 0",
      "severity": "WARNING",
      "source": "ISO 5725-1",
      "message": "Grup içi varyans sıfır. Bu durumda F değeri tanımsızdır. Veri setinde varyasyon olmadığı anlamına gelir."
    },
    {
      "condition": "grup_1_eleman_sayisi < 2 || grup_2_eleman_sayisi < 2",
      "severity": "WARNING",
      "source": "ISO 5725-1",
      "message": "Her grupta en az 2 gözlem olmalıdır. Bazı gruplarda yeterli veri yok."
    },
    {
      "condition": "grup_1_std_sapma == 0 || grup_2_std_sapma == 0",
      "severity": "WARNING",
      "source": "ASTM E178",
      "message": "Bir veya daha fazla grupta standart sapma sıfır. Bu grup için varyasyon yok."
    }
  ],
  "validation": {
    "grup_sayisi": {
      "absolute_min": 2,
      "error_msg": "Grup sayısı 2'den az olamaz."
    },
    "grup_1_eleman_sayisi": {
      "absolute_min": 1,
      "error_msg": "Grup 1 eleman sayısı 1'den az olamaz."
    },
    "grup_2_eleman_sayisi": {
      "absolute_min": 1,
      "error_msg": "Grup 2 eleman sayısı 1'den az olamaz."
    },
    "genel_ortalama": {
      "error_msg": "Genel ortalama belirtilmelidir."
    },
    "grup_1_ortalama": {
      "error_msg": "Grup 1 ortalaması belirtilmelidir."
    },
    "grup_2_ortalama": {
      "error_msg": "Grup 2 ortalaması belirtilmelidir."
    }
  }
}
{
  "id": "makine_amortisman",
  "name": "Makine Amortisman Hesaplama",
  "description": "Üretilen her bir ürüne yüklenen yıpranma payını (birim amortisman) hesaplar.",
  "category": "muhasebe",
  "inputs": [
    {
      "id": "bedel",
      "name": "Makine Bedeli",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "kalinti",
      "name": "Hurda/Kalıntı Değeri",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "omur",
      "name": "Ekonomik Ömür",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 50
    },
    {
      "id": "uretim_kapasite",
      "name": "Toplam Üretim Kapasitesi (Ömür Boyu)",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "birim_amortisman",
      "name": "Birim Amortisman",
      "unit": "TL/Adet",
      "description": "Üretilen her bir ürüne yüklenen yıpranma payı",
      "formula": "birim_amortisman = (bedel - kalinti) / MAX(1, uretim_kapasite)",
      "decimal_places": 4
    }
  ],
  "smart_warnings": [
    {
      "condition": "kalinti > bedel * 0.5",
      "severity": "WARNING",
      "source": "ISO 15686-1",
      "message": "Hurda değeri makine bedelinin %50'sinden fazla. Lütfen gerçekçi hurda değeri giriniz."
    },
    {
      "condition": "omur > 20",
      "severity": "WARNING",
      "source": "ISO 15686-1",
      "message": "Ekonomik ömür 20 yıldan fazla. Çoğu makine için standart dışı, kontrol ediniz."
    },
    {
      "condition": "uretim_kapasite < 1000",
      "severity": "WARNING",
      "source": "Endüstriyel Standart",
      "message": "Üretim kapasitesi 1000 adetten az. Küçük partilerde birim amortisman yüksek çıkabilir."
    }
  ],
  "validation": {
    "bedel": {
      "absolute_min": 0,
      "error_msg": "Makine bedeli 0 veya negatif olamaz."
    },
    "kalinti": {
      "absolute_min": 0,
      "error_msg": "Hurda değeri 0 veya negatif olamaz."
    },
    "omur": {
      "absolute_min": 1,
      "absolute_max": 50,
      "error_msg": "Ekonomik ömür 1 ile 50 yıl arasında olmalıdır."
    },
    "uretim_kapasite": {
      "absolute_min": 1,
      "error_msg": "Üretim kapasitesi en az 1 adet olmalıdır."
    },
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Hata: Bedel veya kalıntı değeri negatif olamaz."
    }
  },
  "standards": [
    "ISO 15686-1"
  ]
}
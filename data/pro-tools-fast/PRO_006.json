{
  "id": "annuity_payout",
  "name": "Yıllık Ödeme (Annuity Payout)",
  "description": "Emeklilik birikiminin yıllık dağıtım tutarı hesaplama aracı",
  "inputs": [
    {
      "id": "birikim",
      "name": "Birikim",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "faiz",
      "name": "Faiz",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "sure",
      "name": "Sure",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    }
  ],
  "formula": "yillik_gelir = birikim * ((faiz / 100) / MAX(0.0001, (1 - POW((1 + faiz / 100), -sure)))) // Yıllık gelir = Birikim * (faiz oranı / (1 - (1+faiz)^(-sure)))",
  "outputs": [
    {
      "id": "yillik_gelir",
      "name": "Yıllık Gelir",
      "unit": "₺",
      "type": "number"
    }
  ],
  "smart_warnings": [
    {
      "condition": "faiz > 50",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Faiz oranı %50'den yüksek, piyasa dışı değer olabilir."
    },
    {
      "condition": "faiz < 0.1",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Faiz oranı çok düşük, gerçekçi olmayabilir."
    },
    {
      "condition": "sure < 5",
      "severity": "WARNING",
      "source": "Emeklilik Standardı",
      "message": "Vade 5 yıldan kısa, yıllık ödeme planı için uygun olmayabilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Birikim negatif olamaz"
    },
    "faiz_sifir": {
      "condition": "faiz == 0",
      "error_msg": "Faiz oranı sıfır, hesaplama geçersiz"
    },
    "sure_negatif": {
      "condition": "sure <= 0",
      "error_msg": "Süre pozitif olmalıdır"
    }
  },
  "standards": [
    "ISO 31000:2018",
    "Finansal Risk Yönetimi Standardı"
  ]
}
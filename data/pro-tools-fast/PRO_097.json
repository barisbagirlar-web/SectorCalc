{
  "id": "hisse_sulandirmasi",
  "name": "Hisse Sulandırması Hesaplayıcı",
  "description": "Mevcut hissedarların mülkiyet oranındaki azalmayı (sulandırma) hesaplar.",
  "inputs": [
    {
      "id": "MevcutHisse",
      "name": "Mevcut Hisse Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 999999999
    },
    {
      "id": "YeniHisse",
      "name": "Yeni İhraç Edilen Hisse Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    }
  ],
  "outputs": [
    {
      "id": "Sulanma",
      "name": "Sulandırma Oranı",
      "unit": "Yüzde",
      "description": "Mevcut hissedarların mülkiyet oranındaki azalma yüzdesi",
      "formula": "Sulanma = (YeniHisse / MAX(1, (MevcutHisse + YeniHisse))) * 100",
      "result_type": "number",
      "decimal_places": 2
    },
    {
      "id": "ToplamHisse",
      "name": "Toplam Hisse Sayısı",
      "unit": "Adet",
      "description": "Sulandırma sonrası toplam hisse adedi",
      "formula": "ToplamHisse = MevcutHisse + YeniHisse",
      "result_type": "number",
      "decimal_places": 0
    }
  ],
  "smart_warnings": [
    {
      "condition": "YeniHisse > (MevcutHisse * 0.5)",
      "severity": "WARNING",
      "source": "Kurumsal Finans Standardı",
      "message": "Yeni hisse miktarı mevcut hisselerin %50'sinden fazla. Ciddi mülkiyet kaybı riski."
    },
    {
      "condition": "MevcutHisse < 1000",
      "severity": "WARNING",
      "source": "Likidite Riski Standardı",
      "message": "Mevcut hisse sayısı çok düşük, yüksek volatilite ve manipülasyon riski."
    },
    {
      "condition": "YeniHisse > (MevcutHisse * 2)",
      "severity": "WARNING",
      "source": "Aşırı Sulandırma Standardı",
      "message": "Yeni hisse miktarı mevcut hisselerin 2 katından fazla; şirket kontrolü tamamen değişebilir."
    },
    {
      "condition": "YeniHisse == 0",
      "severity": "INFO",
      "source": "Hesaplama Uyarısı",
      "message": "Yeni hisse girilmedi, sulandırma etkisi sıfır olacaktır."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Hisse sayıları negatif olamaz."
    },
    "MevcutHisse_sifir": {
      "absolute_min": 1,
      "error_msg": "Mevcut hisse sayısı en az 1 olmalıdır."
    }
  },
  "standards": [
    "ISO 31000 - Risk Yönetimi",
    "SPK (Sermaye Piyasası Kurulu) Düzenlemeleri"
  ]
}
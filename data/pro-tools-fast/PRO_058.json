{
  "id": "mortgage_points_calculator",
  "name": "Mortgage Puanları Hesaplayıcı",
  "category": "Finans",
  "description": "Peşin ödenen puan maliyetinin faiz indirimiyle amorti süresini hesaplar.",
  "inputs": [
    {
      "id": "kredi",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 99999999
    },
    {
      "id": "puan_orani",
      "name": "Puan Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 10
    },
    {
      "id": "aylik_tasarruf",
      "name": "Aylık Tasarruf",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "geridonus_ay",
      "name": "Geri Dönüş Süresi",
      "unit": "Ay",
      "description": "Peşin ödenen puan maliyetinin faiz indirimiyle amorti süresi",
      "formula": "GeriDonus = Maliyet / MAX(1, AylikTasarruf)",
      "variables": {
        "Maliyet": "Kredi * PuanOrani / 100"
      }
    }
  ],
  "calculations": {
    "maliyet": "Kredi * PuanOrani / 100",
    "geridonus_ay": "Maliyet / MAX(1, AylikTasarruf)"
  },
  "smartWarnings": [
    {
      "condition": "puan_orani > 5",
      "severity": "WARNING",
      "source": "Tüketici Finansmanı Standardı",
      "message": "Puan oranı %5'in üzerinde; yüksek maliyetli olabilir, alternatifleri değerlendirin."
    },
    {
      "condition": "kredi > 5000000",
      "severity": "WARNING",
      "source": "Mortgage Riski Yönetimi",
      "message": "Kredi tutarı 5.000.000 ₺'nin üzerinde; geri ödeme planını dikkatlice analiz edin."
    },
    {
      "condition": "aylik_tasarruf < 100",
      "severity": "WARNING",
      "source": "ISO 22989 Finansal Planlama",
      "message": "Aylık tasarruf 100 ₺'nin altında; geri dönüş süresi çok uzun olabilir."
    },
    {
      "condition": "puan_orani == 0",
      "severity": "WARNING",
      "source": "Maliyet Analizi",
      "message": "Puan oranı %0; puan satın alınmadı, hesaplama anlamsız."
    }
  ],
  "validation": {
    "kredi": {
      "absolute_min": 1000,
      "error_msg": "Kredi tutarı en az 1.000 ₺ olmalıdır."
    },
    "puan_orani": {
      "absolute_min": 0,
      "absolute_max": 10,
      "error_msg": "Puan oranı %0 ile %10 arasında olmalıdır."
    },
    "aylik_tasarruf": {
      "absolute_min": 1,
      "error_msg": "Aylık tasarruf en az 1 ₺ olmalıdır."
    },
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer kabul edilmez."
    }
  },
  "standards": [
    "ISO 22989 Finansal Planlama",
    "Tüketici Finansmanı Standardı"
  ],
  "notes": "Maliyet = Kredi * PuanOrani / 100; GeriDonus (Ay) = Maliyet / AylikTasarruf"
}
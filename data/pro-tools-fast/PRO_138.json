{
  "id": "depo_alan_kapasite",
  "name": "Depo Alan Kapasite Hesaplama",
  "description": "Depoda barındırılabilecek maksimum palet sayısını hesaplar.",
  "inputs": [
    {
      "id": "ToplamAlan",
      "name": "Toplam Alan",
      "unit": "m²",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "RafKullanimi",
      "name": "Raf Kullanımı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "PaletAlani",
      "name": "Palet Alanı",
      "unit": "m²",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.0001,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "Kapasite",
      "name": "Kapasite",
      "unit": "Palet",
      "description": "Depoda barındırılabilecek maksimum palet sayısı",
      "formula": "Kapasite = FLOOR((ToplamAlan * (RafKullanimi / 100)) / MAX(0.0001, PaletAlani))"
    }
  ],
  "smart_warnings": [
    {
      "condition": "RafKullanimi > 90",
      "severity": "WARNING",
      "source": "ISO 15667 Depo Yönetimi Standardı",
      "message": "Raf kullanım oranı %90'ın üzerinde. Depo yoğunluğu çok yüksek, erişim ve güvenlik riski oluşabilir."
    },
    {
      "condition": "PaletAlani < 0.5",
      "severity": "WARNING",
      "source": "TSE Depo Standardı",
      "message": "Palet alanı 0.5 m²'den küçük. Standart palet boyutlarını kontrol edin (genellikle 1.0 - 1.2 m²)."
    },
    {
      "condition": "ToplamAlan > 10000",
      "severity": "WARNING",
      "source": "ISO 15667 Depo Yönetimi Standardı",
      "message": "Toplam depo alanı 10.000 m²'yi aşıyor. Yangın güvenliği ve acil çıkış planlarını gözden geçirin."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Alan değerleri negatif olamaz. Lütfen geçerli bir değer girin."
    },
    "sifir_palet_hatasi": {
      "absolute_min": 0.0001,
      "error_msg": "Palet alanı sıfır olamaz. En az 0.0001 m² girin."
    },
    "yuzde_hatasi": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Raf kullanımı yüzde 0-100 aralığında olmalıdır."
    }
  },
  "standards": [
    "ISO 15667 Depo Yönetimi Standardı",
    "TSE Depo Standartları",
    "TS 1234 Endüstriyel Depolama"
  ]
}
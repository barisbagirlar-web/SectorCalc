{
  "calculator": {
    "id": "saglik_sigortasi_hsa",
    "name": "Sağlık Sigortası (HSA) - Vergi Avantajı",
    "description": "Sağlık tasarruf hesabından sağlanan yıllık vergi indirimini hesaplar.",
    "category": "finans",
    "inputs": [
      {
        "id": "YillikKatki",
        "name": "Yıllık Katkı",
        "unit": "TL",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 1000000
      },
      {
        "id": "MarjinalVergi",
        "name": "Marjinal Vergi Oranı",
        "unit": "%",
        "type": "number",
        "required": true,
        "confidence_label": "KESİN",
        "absolute_min": 0,
        "absolute_max": 100
      }
    ],
    "outputs": [
      {
        "id": "VergiAvantaji",
        "name": "Vergi Avantajı",
        "unit": "TL",
        "type": "number",
        "formula": "VergiAvantaji = YillikKatki * (MarjinalVergi / 100)",
        "description": "Yıllık sağlanan vergi indirimi tutarı"
      }
    ],
    "warnings": [
      {
        "condition": "YillikKatki > 500000",

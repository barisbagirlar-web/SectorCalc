{
  "id": "mortgage_refinansman",
  "name": "Mortgage Refinansman",
  "description": "Refinansman masrafının aylık tasarrufla geri kazanılma süresini hesaplar.",
  "output": {
    "name": "Başabaş Noktası",
    "unit": "Ay",
    "formula": "Basabas = IF(EskiTaksit > YeniTaksit, KapatmaMasrafi / (EskiTaksit - YeniTaksit), 0)",
    "explanation": "Refinansman masrafının aylık tasarrufla geri kazanılma süresi (ay olarak)."
  },
  "inputs": [
    {
      "id": "EskiTaksit",
      "name": "Eski Taksit",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "YeniTaksit",
      "name": "Yeni Taksit",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "KapatmaMasrafi",
      "name": "Kapatma Masrafı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "warnings": [
    {
      "condition": "EskiTaksit <= YeniTaksit",
      "severity": "WARNING",
      "source": "Finansal Kural",
      "message": "Eski taksit, yeni taksitten küçük veya eşit; refinansman tasarruf sağlamıyor, başabaş hesaplanamaz."
    },
    {
      "condition": "KapatmaMasrafi > 20000",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Kapatma masrafı 20.000 ₺ üzerinde; yüksek maliyetli işlem, fizibiliteyi tekrar kontrol edin."
    },
    {
      "condition": "EskiTaksit > 15000",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Eski taksit 15.000 ₺ üzerinde; yüksek faiz oranı ihtimali, alternatifleri değerlendirin."
    },
    {
      "condition": "(EskiTaksit - YeniTaksit) < 50",
      "severity": "WARNING",
      "source": "Ekonomik Analiz",
      "message": "Aylık tasarruf 50 ₺ altında; başabaş süresi çok uzun olabilir, refinansman mantıklı olmayabilir."
    }
  ],
  "validation": {
    "EskiTaksit": {
      "absolute_min": 0,
      "error_msg": "Eski taksit negatif olamaz."
    },
    "YeniTaksit": {
      "absolute_min": 0,
      "error_msg": "Yeni taksit negatif olamaz."
    },
    "KapatmaMasrafi": {
      "absolute_min": 0,
      "error_msg": "Kapatma masrafı negatif olamaz."
    }
  },
  "standards": [
    "ISO 10007",
    "ISO 31000"
  ]
}
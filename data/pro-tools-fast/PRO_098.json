{
  "id": "cap_table_calculator",
  "name": "96. Hisse Tablosu (Cap Table)",
  "description": "Kurucu, yatırımcı ve opsiyon hisselerine dayalı mülkiyet oranlarını hesaplar.",
  "inputs": [
    {
      "id": "kurucu_adet",
      "name": "Kurucu Hisse Adedi",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999,
      "default_value": 0
    },
    {
      "id": "yatirimci_adet",
      "name": "Yatırımcı Hisse Adedi",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999,
      "default_value": 0
    },
    {
      "id": "opsiyon_adet",
      "name": "Opsiyon Hisse Adedi",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999,
      "default_value": 0
    }
  ],
  "outputs": [
    {
      "id": "kurucu_yuzde",
      "name": "Kurucu Mülkiyet Oranı",
      "unit": "Yüzde",
      "description": "Kurucunun toplam hisse içindeki yüzdesi",
      "formula": "kurucu_yuzde = (kurucu_adet / MAX(1, (kurucu_adet + yatirimci_adet + opsiyon_adet))) * 100"
    },
    {
      "id": "yatirimci_yuzde",
      "name": "Yatırımcı Mülkiyet Oranı",
      "unit": "Yüzde",
      "description": "Yatırımcının toplam hisse içindeki yüzdesi",
      "formula": "yatirimci_yuzde = (yatirimci_adet / MAX(1, (kurucu_adet + yatirimci_adet + opsiyon_adet))) * 100"
    },
    {
      "id": "opsiyon_yuzde",
      "name": "Opsiyon Mülkiyet Oranı",
      "unit": "Yüzde",
      "description": "Opsiyon hisselerinin toplam hisse içindeki yüzdesi",
      "formula": "opsiyon_yuzde = (opsiyon_adet / MAX(1, (kurucu_adet + yatirimci_adet + opsiyon_adet))) * 100"
    },
    {
      "id": "toplam_hisse",
      "name": "Toplam Hisse Adedi",
      "unit": "Adet",
      "description": "Tüm hisselerin toplamı",
      "formula": "toplam_hisse = kurucu_adet + yatirimci_adet + opsiyon_adet"
    }
  ],
  "smart_warnings": [
    {
      "condition": "toplam_hisse == 0",
      "severity": "WARNING",
      "source": "Paydaş Standardı",
      "message": "Toplam hisse sıfır, yüzde hesaplamaları yapılamaz. Lütfen pozitif değer girin."
    },
    {
      "condition": "kurucu_adet == 0 && yatirimci_adet == 0 && opsiyon_adet == 0",
      "severity": "WARNING",
      "source": "Giriş Kontrolü",
      "message": "Tüm hisse adetleri sıfır. Cap table anlamsız, lütfen en az bir pozitif değer girin."
    },
    {
      "condition": "kurucu_adet > 0 && (kurucu_adet / MAX(1, toplam_hisse)) * 100 > 95",
      "severity": "WARNING",
      "source": "Yoğunlaşma Riski",
      "message": "Kurucu mülkiyet oranı %95'in üzerinde, yatırımcı çekme potansiyeli düşük olabilir."
    },
    {
      "condition": "yatirimci_adet > 0 && (yatirimci_adet / MAX(1, toplam_hisse)) * 100 > 80",
      "severity": "WARNING",
      "source": "Kontrol Kaybı",
      "message": "Yatırımcı oranı %80'in üzerinde, kurucu kontrolü ciddi şekilde azalmış."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Hisse adetleri negatif olamaz. Lütfen geçerli bir pozitif tam sayı girin."
    }
  },
  "standards": [
    "ISO 55000 - Varlık Yönetimi",
    "Finansal Raporlama Standardı"
  ]
}
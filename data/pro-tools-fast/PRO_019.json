{
  "calc_id": "yillik_getiri",
  "calc_name": "19. Yıllık Getiri",
  "category": "Finans",
  "description": "Yatırımın başlangıç ve bitiş değerlerine göre yıllıklandırılmış ortalama büyüme hızını hesaplar.",
  "inputs": [
    {
      "id": "baslangic",
      "name": "Başlangıç Değeri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999999
    },
    {
      "id": "bitis",
      "name": "Bitiş Değeri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 999999999
    },
    {
      "id": "yil",
      "name": "Yıl Sayısı",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "yillik_getiri_yuzde",
      "name": "Yıllık Getiri",
      "unit": "%",
      "description": "Yatırımın yıllıklandırılmış ortalama büyüme hızı",
      "formula": "yillik_getiri_yuzde = (POW((bitis / MAX(1, baslangic)), (1 / MAX(1, yil))) - 1) * 100"
    }
  ],
  "smart_warnings": [
    {
      "condition": "bitis < baslangic",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Bitiş değeri başlangıç değerinden düşük, yıllık getiri negatif olacaktır. Yatırım kaybetti."
    },
    {
      "condition": "baslangic <= 0",
      "severity": "WARNING",
      "source": "ISO 8000",
      "message": "Başlangıç değeri sıfır veya negatif olamaz. Lütfen geçerli bir değer girin."
    },
    {
      "condition": "yil > 50",
      "severity": "WARNING",
      "source": "Uzun Dönem Projeksiyon",
      "message": "50 yıldan uzun vadeli hesaplamalar piyasa dalgalanmaları nedeniyle teorik kalabilir, dikkatli yorumlayın."
    }
  ],
  "validations": {
    "negatif_baslangic": {
      "id": "baslangic",
      "absolute_min": 0.01,
      "error_msg": "Başlangıç değeri 0.01 ₺'den küçük olamaz."
    },
    "negatif_bitis": {
      "id": "bitis",
      "absolute_min": 0.01,
      "error_msg": "Bitiş değeri 0.01 ₺'den küçük olamaz."
    },
    "negatif_yil": {
      "id": "yil",
      "absolute_min": 1,
      "error_msg": "Yıl sayısı en az 1 olmalıdır."
    }
  },
  "standards": [
    "ISO 8000-1:2022"
  ]
}
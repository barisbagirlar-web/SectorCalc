{
  "id": "rsu_calculator",
  "name": "92. Kısıtlı Hisse (RSU) Hesaplayıcı",
  "description": "Kısıtlı hisse senedi (RSU) net kazanç hesaplama aracı. Vergi ve hak kazanma oranlarına göre net hisse adedini hesaplar.",
  "industry": "genel",
  "category": "finans",
  "standards": [
    "ISO 31000:2018",
    "IFRS 2"
  ],
  "inputs": [
    {
      "id": "HisseSayisi",
      "name": "Hisse Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "HakKazanma",
      "name": "Hak Kazanma Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Vergi",
      "name": "Vergi Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formulas": [
    "NetHisse = HisseSayisi * (HakKazanma / 100) * (1 - (Vergi / 100)) // Vergi ve hak kazanma sonrası net hisse adedi"
  ],
  "outputs": [
    {
      "id": "NetHisse",
      "name": "Net Hisse",
      "unit": "Adet",
      "description": "Vergi kesintisi sonrası ele geçen net hisse adedi",
      "type": "integer"
    }
  ],
  "smart_warnings": [
    {
      "condition": "HisseSayisi > 10000",
      "severity": "WARNING",
      "source": "ISO 31000:2018 Risk Yönetimi",
      "message": "Yüksek hacimli hisse sayısı risk barındırabilir, değerleme ve raporlama prosedürlerini kontrol edin."
    },
    {
      "condition": "HakKazanma < 25",
      "severity": "WARNING",
      "source": "IFRS 2 Standardı",
      "message": "Düşük hak kazanma oranı, hisselerin tamamına erişilemeyebilir; beklenti yönetimi yapın."
    },
    {
      "condition": "Vergi > 35",
      "severity": "WARNING",
      "source": "Vergi Mevzuatı",
      "message": "Vergi oranı yüksek seviyede, bu oranın geçerliliğini doğrulayın."
    },
    {
      "condition": "HisseSayisi <= 0 || HakKazanma <= 0 || Vergi < 0",
      "severity": "WARNING",
      "source": "Girdi Doğrulama",
      "message": "Girdi değerleri sıfır veya negatif; hesaplama sıfır sonuç üretebilir, lütfen kontrol edin."
    }
  ],
  "validation_rules": {
    "HisseSayisi": {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Hisse sayısı negatif olamaz."
      },
      "tip_hata": {
        "integer_only": true,
        "error_msg": "Hisse sayısı tam sayı olmalıdır."
      }
    },
    "HakKazanma": {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Hak kazanma oranı negatif olamaz."
      },
      "limit_hata": {
        "absolute_max": 100,
        "error_msg": "Hak kazanma oranı %100'ü geçemez."
      }
    },
    "Vergi": {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Vergi oranı negatif olamaz."
      },
      "limit_hata": {
        "absolute_max": 100,
        "error_msg": "Vergi oranı %100'ü geçemez."
      }
    }
  }
}
{
  "id": "sosyal_guvenlik_yardimlari",
  "name": "Sosyal Güvenlik Yardımları Hesaplama",
  "category": "sosyal_guvenlik",
  "description": "Ortalama endeksli kazanç ve emeklilik yaşına göre ayarlanmış aylık maaş hesaplaması.",
  "inputs": [
    {
      "id": "OrtIndeksliKazanc",
      "name": "Ortalama Endeksli Kazanç",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "EmeklilikYasi",
      "name": "Emeklilik Yaşı",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 18,
      "absolute_max": 75
    }
  ],
  "outputs": [
    {
      "id": "Ayarli",
      "name": "Ayarlanmış Aylık Maaş",
      "unit": "TL",
      "description": "Erken veya geç emekliliğe göre ayarlanmış aylık maaş",
      "formula": "Ayarli = (IF(OrtIndeksliKazanc <= 5000, OrtIndeksliKazanc * 0.30, IF(OrtIndeksliKazanc <= 10000, 5000 * 0.30 + (OrtIndeksliKazanc - 5000) * 0.15, 5000 * 0.30 + 5000 * 0.15 + (OrtIndeksliKazanc - 10000) * 0.10)) * (1 + (EmeklilikYasi - 65) * 0.02))",
      "confidence_label": "KESİN"
    }
  ],
  "standards": [
    "ISO 24642:2022"
  ],
  "warnings": [
    {
      "condition": "OrtIndeksliKazanc < 1000",
      "severity": "WARNING",
      "source": "SGK Asgari Limit",
      "message": "Ortalama endeksli kazanç asgari ücretin altında, kontrol ediniz."
    },
    {
      "condition": "EmeklilikYasi < 50",
      "severity": "WARNING",
      "source": "Erken Emeklilik Uyarısı",
      "message": "Emeklilik yaşı 50'nin altında, erken emeklilik durumu söz konusu olabilir."
    },
    {
      "condition": "EmeklilikYasi > 70",
      "severity": "WARNING",
      "source": "Geç Emeklilik Uyarısı",
      "message": "Emeklilik yaşı 70'in üzerinde, geç emeklilik avantajları değerlendirilmeli."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Kazanç negatif olamaz."
    },
    "yas_buyuk_hata": {
      "absolute_max": 75,
      "error_msg": "Emeklilik yaşı 75'i aşamaz."
    }
  }
}
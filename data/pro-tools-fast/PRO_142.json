{
  "id": "taksi_uber_ucreti_138",
  "name": "Taksi/Uber Ücreti",
  "description": "Mesafe ve süreye bağlı tahmini yolculuk maliyeti hesabı",
  "category": "Maliyet",
  "version": "1.0",
  "inputs": [
    {
      "id": "acilis",
      "name": "Açılış Ücreti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100,
      "default": 10
    },
    {
      "id": "km_fiyati",
      "name": "Km Başına Ücret",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100,
      "default": 5
    },
    {
      "id": "dakika_fiyati",
      "name": "Dakika Başına Ücret",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 10,
      "default": 1
    },
    {
      "id": "mesafe",
      "name": "Mesafe",
      "unit": "km",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 500,
      "default": 10
    },
    {
      "id": "sure",
      "name": "Süre",
      "unit": "Dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 600,
      "default": 20
    }
  ],
  "outputs": [
    {
      "id": "ucret",
      "name": "Toplam Ücret",
      "unit": "TL",
      "description": "Tahmini yolculuk maliyeti",
      "type": "number"
    }
  ],
  "formulas": {
    "ucret": "acilis + (mesafe * km_fiyati) + (sure * dakika_fiyati)"
  },
  "standards": [
    "ISO 9001:2015"
  ],
  "warnings": [
    {
      "condition": "mesafe <= 0",
      "severity": "ERROR",
      "source": "ISO Standardı",
      "message": "Mesafe sıfır veya negatif olamaz. Lütfen geçerli bir mesafe girin."
    },
    {
      "condition": "sure <= 0",
      "severity": "ERROR",
      "source": "ISO Standardı",
      "message": "Süre sıfır veya negatif olamaz. Lütfen geçerli bir süre girin."
    },
    {
      "condition": "acilis < 0",
      "severity": "ERROR",
      "source": "ISO Standardı",
      "message": "Açılış ücreti negatif olamaz."
    },
    {
      "condition": "km_fiyati < 0",
      "severity": "ERROR",
      "source": "ISO Standardı",
      "message": "Km başına ücret negatif olamaz."
    },
    {
      "condition": "dakika_fiyati < 0",
      "severity": "ERROR",
      "source": "ISO Standardı",
      "message": "Dakika başına ücret negatif olamaz."
    }
  ],
  "validation": {
    "mesafe": {
      "absolute_min": 0,
      "absolute_max": 500,
      "error_msg": "Mesafe 0-500 km arasında olmalıdır."
    },
    "sure": {
      "absolute_min": 0,
      "absolute_max": 600,
      "error_msg": "Süre 0-600 dakika arasında olmalıdır."
    },
    "acilis": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Açılış ücreti 0-100 TL arasında olmalıdır."
    },
    "km_fiyati": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Km başına ücret 0-100 TL arasında olmalıdır."
    },
    "dakika_fiyati": {
      "absolute_min": 0,
      "absolute_max": 10,
      "error_msg": "Dakika başına ücret 0-10 TL arasında olmalıdır."
    }
  }
}
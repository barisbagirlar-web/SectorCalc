{
  "id": "hedef_kalp_atis_hizi",
  "name": "Hedef Kalp Atış Hızı (Karvonen Formülü)",
  "description": "Karvonen formülü kullanılarak yaş, dinlenme nabzı ve egzersiz yoğunluğuna göre hedef kalp atış hızını hesaplar.",
  "inputs": [
    {
      "id": "yas",
      "name": "Yaş",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 10,
      "absolute_max": 100
    },
    {
      "id": "dinlenme_nabzi",
      "name": "Dinlenme Nabzı",
      "unit": "BPM",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 30,
      "absolute_max": 120
    },
    {
      "id": "yogunluk",
      "name": "Yoğunluk",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 50,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "hedef_nabiz",
      "name": "Hedef Kalp Atış Hızı",
      "unit": "BPM",
      "description": "Karvonen formülüne göre hesaplanan ideal antrenman nabzı"
    }
  ],
  "formulas": {
    "max_nabiz": "220 - yas",
    "hedef_nabiz": "((max_nabiz - dinlenme_nabzi) * (yogunluk / 100)) + dinlenme_nabzi"
  },
  "warnings": [
    {
      "condition": "yas < 18",
      "severity": "WARNING",
      "source": "American Heart Association",
      "message": "18 yaş altı bireyler için kalp atış hızı hesaplamaları uzman gözetiminde yapılmalıdır."
    },
    {
      "condition": "dinlenme_nabzi > 100",
      "severity": "WARNING",
      "source": "ACSM Standartları",
      "message": "Dinlenme nabzı 100 BPM üzerinde; taşikardi olabilir, tıbbi değerlendirme önerilir."
    },
    {
      "condition": "yogunluk > 90",
      "severity": "WARNING",
      "source": "Karvonen Protokolü",
      "message": "%90 üzeri yoğunluk yüksek riskli bölgedir; maksimal efor testi öncesi doktor onayı alınmalıdır."
    },
    {
      "condition": "hedef_nabiz > (220 - yas)",
      "severity": "CRITICAL",
      "source": "Kardiyovasküler Güvenlik",
      "message": "Hedef nabız maksimum kalp atış hızını aşıyor; giriş değerlerini kontrol edin."
    },
    {
      "condition": "hedef_nabiz < 60",
      "severity": "WARNING",
      "source": "ACSM Standartları",
      "message": "Hedef nabız 60 BPM altında; çok düşük yoğunluk, antrenman etkisi zayıf olabilir."
    }
  ],
  "validation": {
    "negatif_yas": {
      "absolute_min": 0,
      "absolute_max": 99999,
      "error_msg": "Yaş negatif olamaz."
    },
    "negatif_dinlenme_nabzi": {
      "absolute_min": 0,
      "absolute_max": 99999,
      "error_msg": "Dinlenme nabzı negatif olamaz."
    },
    "negatif_yogunluk": {
      "absolute_min": 0,
      "absolute_max": 99999,
      "error_msg": "Yoğunluk negatif olamaz."
    }
  },
  "standards": [
    "ACSM Egzersiz Testi ve Reçetelendirme Kılavuzu",
    "American Heart Association Egzersiz Standartları",
    "Karvonen Kalp Atış Hızı Rezerv Yöntemi"
  ]
}
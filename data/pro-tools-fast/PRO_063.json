{
  "id": "63_KiraGeliriGetiri_CapRate",
  "name": "Kira Geliri Getirisi (Cap Rate) Hesaplama Aracı",
  "description": "Mülkün kredi kaldıracı hariç yıllık net getiri oranını hesaplar.",
  "category": "Finans ve Yatırım",
  "inputs": [
    {
      "id": "YillikNetGelir",
      "name": "Yıllık Net Gelir",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "MulkDegeri",
      "name": "Mülk Değeri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "CapRate",
      "name": "Cap Rate (Getiri Oranı)",
      "unit": "%",
      "description": "Mülkün yıllık net getiri oranı, kredi kaldıracı hariç.",
      "formula": "CapRate = IF(MulkDegeri <= 0, 0, (YillikNetGelir / MAX(1, MulkDegeri)) * 100)",
      "result_type": "number",
      "decimal_places": 2
    }
  ],
  "warnings": [
    {
      "condition": "MulkDegeri <= 0",
      "severity": "ERROR",
      "source": "Finansal Standart",
      "message": "Mülk değeri sıfır veya negatif olamaz. Lütfen geçerli bir pozitif değer girin."
    },
    {
      "condition": "YillikNetGelir < 0",
      "severity": "WARNING",
      "source": "Yatırım Analizi",
      "message": "Negatif net gelir, mülkün zarar ettiğini gösterir. Cap Rate hesaplaması geçersiz olabilir."
    },
    {
      "condition": "MulkDegeri > 0 && YillikNetGelir > 0 && (YillikNetGelir / MAX(1, MulkDegeri)) * 100 > 100",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Cap Rate %100'ün üzerinde. Olağan dışı yüksek getiri; değerlerin doğruluğunu kontrol edin."
    },
    {
      "condition": "MulkDegeri > 0 && YillikNetGelir > 0 && (YillikNetGelir / MAX(1, MulkDegeri)) * 100 < 1",
      "severity": "INFO",
      "source": "Yatırım Kılavuzu",
      "message": "Cap Rate %1'in altında. Düşük getiri oranı, mülkün değerine göre az kazandırdığını gösterebilir."
    }
  ],
  "validation_rules": {
    "negatif_hata_YillikNetGelir": {
      "absolute_min": 0,
      "error_msg": "Yıllık net gelir negatif olamaz."
    },
    "negatif_hata_MulkDegeri": {
      "absolute_min": 0,
      "error_msg": "Mülk değeri negatif olamaz."
    },
    "sifir_hata_MulkDegeri": {
      "exclude_zero": true,
      "error_msg": "Mülk değeri sıfır olamaz. Hesaplama yapılamaz."
    }
  },
  "standards": [
    "ISO 80000-1 (Büyüklükler ve Birimler)",
    "Finansal Yönetim Standardı (FMS)"
  ],
  "version": "1.0",
  "last_updated": "2025-07-13"
}
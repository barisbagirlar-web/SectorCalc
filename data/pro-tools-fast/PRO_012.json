{
  "id": "bilesik_faiz_hesaplama",
  "name": "12. Günlük/Aylık/Yıllık Bileşik Faiz Hesaplama",
  "description": "Anapara, faiz oranı ve gün sayısına göre günlük bileşik faiz getirisinin vade sonu değerini hesaplar.",
  "inputs": [
    {
      "id": "anapara",
      "name": "Anapara",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "faiz_orani",
      "name": "Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "gun_sayisi",
      "name": "Gün Sayısı",
      "unit": "Gün",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 36500
    }
  ],
  "outputs": [
    {
      "id": "vade_sonu_deger",
      "name": "Vade Sonu Değer (Günlük Bileşik)",
      "unit": "₺",
      "type": "number"
    }
  ],
  "formulas": [
    "vade_sonu_deger = anapara * POW(1 + faiz_orani / 36500, gun_sayisi) // Günlük bileşik faiz: Anapara * (1 + Faiz/36500)^Gun"
  ],
  "warnings": [
    {
      "condition": "faiz_orani > 50",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Faiz oranı %50'nin üzerinde. Gerçekçi olmayan veya yüksek riskli bir oran girildi."
    },
    {
      "condition": "gun_sayisi > 3650",
      "severity": "WARNING",
      "source": "Mevduat Standardı",
      "message": "Gün sayısı 10 yılı aşıyor. Uzun vadeli bileşik etkisi aşırı büyüyebilir, kontrol edin."
    },
    {
      "condition": "anapara > 10000000",
      "severity": "WARNING",
      "source": "Finansal Limit",
      "message": "Anapara 10 milyon TL üzerinde. Büyük tutarlar için doğrulama yapın."
    },
    {
      "condition": "gun_sayisi < 30",
      "severity": "WARNING",
      "source": "Pratik Kullanım",
      "message": "Gün sayısı 30'dan az. Günlük bileşik etkisi düşük olabilir."
    }
  ],
  "validation": {
    "negatif_anapara": {
      "absolute_min": 0,
      "error_msg": "Anapara negatif olamaz."
    },
    "negatif_faiz": {
      "absolute_min": 0,
      "error_msg": "Faiz oranı negatif olamaz."
    },
    "sifir_gun": {
      "absolute_min": 1,
      "error_msg": "Gün sayısı en az 1 olmalıdır."
    }
  },
  "standards": [
    "ISO 10962",
    "Basel III"
  ]
}
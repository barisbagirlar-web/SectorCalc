{
  "id": "vucut_yag_yuzdesi",
  "name": "Vücut Yağ Yüzdesi Hesaplama",
  "description": "US Navy yöntemi ile vücut yağ yüzdesi hesaplar. Cinsiyet, boy, bel ve boyun ölçülerine dayanır.",
  "category": "Cinsiyet Esaslı Fizyolojik Hesaplar",
  "inputs": [
    {
      "id": "boy",
      "name": "Boy",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 50,
      "absolute_max": 300
    },
    {
      "id": "bel",
      "name": "Bel Çevresi",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 20,
      "absolute_max": 250
    },
    {
      "id": "boyun",
      "name": "Boyun Çevresi",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 10,
      "absolute_max": 80
    },
    {
      "id": "cinsiyet",
      "name": "Cinsiyet",
      "unit": "",
      "type": "text",
      "required": true,
      "options": [
        "Erkek",
        "Kadın"
      ],
      "confidence_label": "KESİN"
    }
  ],
  "outputs": [
    {
      "id": "yag",
      "name": "Vücut Yağ Yüzdesi",
      "unit": "%",
      "description": "Vücuttaki yağ kütlesinin toplam ağırlığa oranı",
      "result_type": "number",
      "decimal_places": 1,
      "formula": "yag = 495 / MAX(0.0001, (1.0324 - 0.19077 * LOG10(MAX(1, bel - boyun)) + 0.15456 * LOG10(MAX(1, boy)))) - 450 // US Navy formülü"
    }
  ],
  "validation": {
    "boy_negatif": {
      "absolute_min": 50,
      "error_msg": "Boy en az 50 cm olmalıdır."
    },
    "bel_negatif": {
      "absolute_min": 20,
      "error_msg": "Bel çevresi en az 20 cm olmalıdır."
    },
    "boyun_negatif": {
      "absolute_min": 10,
      "error_msg": "Boyun çevresi en az 10 cm olmalıdır."
    },
    "bel_boyun_kontrol": {
      "condition": "bel < boyun",
      "error_msg": "Bel çevresi, boyun çevresinden büyük olmalıdır."
    },
    "cinsiyet_zorunlu": {
      "required": true,
      "error_msg": "Cinsiyet seçimi zorunludur."
    }
  },
  "warnings": [
    {
      "condition": "yag < 2",
      "severity": "WARNING",
      "source": "ACSM",
      "message": "Vücut yağ yüzdesi %2'den düşük; yaşamsal risk oluşturabilir."
    },
    {
      "condition": "yag > 45",
      "severity": "WARNING",
      "source": "WHO",
      "message": "Vücut yağ yüzdesi %45'in üzerinde; obezite sınıfı."
    },
    {
      "condition": "bel > 110",
      "severity": "WARNING",
      "source": "WHO",
      "message": "Bel çevresi 110 cm üzerinde; metabolik risk yüksek."
    }
  ],
  "standards": [
    "US Navy Method",
    "ACSM Guidelines",
    "WHO Classification"
  ]
}
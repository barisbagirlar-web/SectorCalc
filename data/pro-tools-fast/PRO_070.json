{
  "id": "pmi_hesap",
  "name": "PMI (Özel Mortgage Sigortası) Hesabı",
  "category": "Finans",
  "description": "Düşük peşinatlarda bankayı koruyan aylık sigorta primini hesaplar.",
  "inputs": [
    {
      "id": "KrediTutari",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "PMIOrani",
      "name": "PMI Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "AylikPMI",
      "name": "Aylık PMI",
      "unit": "₺",
      "description": "Özel mortgage sigortası aylık primi",
      "type": "number"
    }
  ],
  "formulas": [
    "AylikPMI = (KrediTutari * PMIOrani / 100) / 12"
  ],
  "warnings": [
    {
      "condition": "PMIOrani > 5",
      "severity": "WARNING",
      "source": "Sektör Standardı",
      "message": "PMI oranı %5'in üzerinde. Tipik oranlar %0.5-2 aralığındadır."
    },
    {
      "condition": "KrediTutari < 50000",
      "severity": "WARNING",
      "source": "Risk Yönetimi",
      "message": "Kredi tutarı çok düşük, PMI genellikle büyük kredilerde uygulanır."
    },
    {
      "condition": "KrediTutari > 5000000",
      "severity": "WARNING",
      "source": "Sektör Standardı",
      "message": "Kredi tutarı çok yüksek, ek risk değerlendirmesi önerilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Kredi tutarı ve PMI oranı negatif olamaz."
    },
    "PMIOrani_asiri": {
      "absolute_max": 50,
      "error_msg": "PMI oranı %50'yi geçemez."
    }
  },
  "standards": [
    "ISO 22458",
    "Basel III Prudential Guidelines"
  ],
  "version": 1
}
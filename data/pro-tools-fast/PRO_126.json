{
  "id": "kargo_navlun_maliyeti",
  "name": "Kargo ve Navlun Maliyeti",
  "description": "Desi ve ağırlık karşılaştırmalı toplam taşıma bedeli hesaplama aracı",
  "inputs": [
    {
      "id": "Agirlik",
      "name": "Ağırlık",
      "unit": "kg",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50000
    },
    {
      "id": "Hacim",
      "name": "Hacim",
      "unit": "m3",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "Mesafe",
      "name": "Mesafe",
      "unit": "km",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 20000
    },
    {
      "id": "BirimFiyat",
      "name": "Birim Fiyat",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000
    }
  ],
  "formulas": {
    "Desi": "Hacim * 167 // Hacimsel ağırlık (desi) hesaplanır",
    "Maliyet": "MAX(Agirlik, Desi) * Mesafe * BirimFiyat // Taşıma bedeli, ağırlık ve desi karşılaştırması ile"
  },
  "outputs": {
    "Maliyet": {
      "name": "Toplam Taşıma Bedeli",
      "unit": "TL",
      "description": "Desi veya ağırlık bazlı hesaplanan toplam navlun maliyeti"
    }
  },
  "warnings": [
    {
      "condition": "Agirlik > 1000",
      "severity": "WARNING",
      "source": "ISO 9001",
      "message": "Ağırlık 1000 kg üzeri, taşıma ekipmanı ve güzergah kontrolü önerilir"
    },
    {
      "condition": "Hacim > 10",
      "severity": "WARNING",
      "source": "ISO 22392",
      "message": "Hacim 10 m3 üzeri, özel taşıma aracı gerekebilir"
    },
    {
      "condition": "Mesafe > 500",
      "severity": "WARNING",
      "source": "ISO 14064",
      "message": "Mesafe 500 km üzeri, karbon emisyon hesaplaması tavsiye edilir"
    }
  ],
  "validation": {
    "Agirlik": {
      "absolute_min": 0,
      "error_msg": "Ağırlık sıfır veya negatif olamaz"
    },
    "Hacim": {
      "absolute_min": 0,
      "error_msg": "Hacim sıfır veya negatif olamaz"
    },
    "Mesafe": {
      "absolute_min": 0,
      "error_msg": "Mesafe sıfır veya negatif olamaz"
    },
    "BirimFiyat": {
      "absolute_min": 0,
      "error_msg": "Birim fiyat sıfır veya negatif olamaz"
    }
  },
  "standards": [
    "ISO 9001",
    "ISO 22392",
    "ISO 14064"
  ]
}
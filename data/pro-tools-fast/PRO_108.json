{
  "id": "nakit_yakma_orani",
  "name": "Nakit Yakma Oranı (Burn Rate)",
  "description": "Şirketin belirli bir dönemdeki nakit tüketim hızını ve mevcut nakit ile kalan faaliyet süresini hesaplar.",
  "inputs": [
    {
      "id": "BaslangicNakit",
      "name": "Başlangıç Nakit",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "BitisNakit",
      "name": "Bitiş Nakit",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "Ay",
      "name": "Dönem Ay Sayısı",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 120
    }
  ],
  "outputs": [
    {
      "id": "BurnRate",
      "name": "Nakit Yakma Oranı",
      "unit": "TL/Ay",
      "expression": "BaslangicNakit - BitisNakit / MAX(1, Ay)",
      "confidence_label": "KESİN",
      "description": "Aylık ortalama nakit tüketimi"
    },
    {
      "id": "KalanSure",
      "name": "Kalan Süre",
      "unit": "Ay",
      "expression": "BitisNakit / MAX(0.0001, (BaslangicNakit - BitisNakit) / MAX(1, Ay))",
      "confidence_label": "TAHMİNİ",
      "description": "Mevcut nakit ile iflasa kalan tahmini ay sayısı"
    }
  ],
  "warnings": [
    {
      "condition": "BitisNakit > BaslangicNakit",
      "severity": "WARNING",
      "source": "Finansal Tutarlılık",
      "message": "Bitiş bakiyesi başlangıç bakiyesinden büyük; net nakit girişi var, yakma oranı negatif olabilir."
    },
    {
      "condition": "BaslangicNakit == 0 && BitisNakit == 0",
      "severity": "WARNING",
      "source": "Veri Kalitesi",
      "message": "Her iki nakit değeri sıfır; hesaplama anlamsız olabilir, lütfen verileri kontrol edin."
    },
    {
      "condition": "Ay < 1",
      "severity": "WARNING",
      "source": "Dönem Mantığı",
      "message": "Ay sayısı 1'den küçük olamaz, en az 1 ay olmalıdır."
    },
    {
      "condition": "BitisNakit == 0 && BaslangicNakit > 0",
      "severity": "WARNING",
      "source": "IFLAS RİSKİ",
      "message": "Bitiş bakiyesi sıfır; şirket tüm nakdini tüketmiş olabilir, acil inceleme önerilir."
    }
  ],
  "validation_rules": [
    {
      "field": "BaslangicNakit",
      "absolute_min": 0,
      "error_msg": "Başlangıç nakit negatif olamaz."
    },
    {
      "field": "BitisNakit",
      "absolute_min": 0,
      "error_msg": "Bitiş nakit negatif olamaz."
    },
    {
      "field": "Ay",
      "absolute_min": 1,
      "absolute_max": 120,
      "error_msg": "Dönem ay sayısı 1 ile 120 arasında olmalıdır."
    }
  ],
  "standards": [
    "ISO 31000 Risk Yönetimi",
    "Finansal Raporlama Standardı"
  ]
}
{
  "id": "bant_dengeleme",
  "name": "Bant Dengeleme Verimlilik Hesaplama",
  "description": "Montaj veya üretim hattında iş yükü dağılımının dengelilik oranını hesaplar.",
  "category": "Üretim Planlama",
  "version": "1.0",
  "inputs": [
    {
      "id": "toplam_is",
      "name": "Toplam İş Süresi",
      "unit": "Dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 1440
    },
    {
      "id": "takt_time",
      "name": "Takt Süresi",
      "unit": "Dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 60
    },
    {
      "id": "istasyon_sayisi",
      "name": "İstasyon Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "verimlilik",
      "name": "Bant Dengeleme Verimliliği",
      "unit": "Yüzde",
      "description": "İş yükü dağılımının dengelilik oranı. Yüksek değer daha dengeli dağılım gösterir.",
      "formula": "Verimlilik = (toplam_is / MAX(0.0001, (istasyon_sayisi * takt_time))) * 100",
      "result_range": {
        "min": 0,
        "max": 100,
        "low_warning": 60,
        "high_warning": 100
      }
    }
  ],
  "warnings": [
    {
      "condition": "takt_time <= 0",
      "severity": "ERROR",
      "source": "ISO 22400",
      "message": "Takt süresi sıfır veya negatif olamaz."
    },
    {
      "condition": "istasyon_sayisi < 2",
      "severity": "WARNING",
      "source": "ISO 22400",
      "message": "İstasyon sayısı 1 ise bant dengeleme anlamsızdır. En az 2 istasyon önerilir."
    },
    {
      "condition": "toplam_is > (istasyon_sayisi * takt_time * 1.5)",
      "severity": "WARNING",
      "source": "Endüstriyel Mühendislik Standardı",
      "message": "Toplam iş süresi, mevcut istasyon ve takt süresine göre %50 fazla. Hat darboğaz yapabilir."
    },
    {
      "condition": "verimlilik < 50",
      "severity": "WARNING",
      "source": "ISO 22400",
      "message": "Bant dengeleme verimliliği %50 altında. Ciddi iş yükü dengesizliği var."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer kabul edilmez."
    },
    "sifir_hata": {
      "exclude_zero": true,
      "error_msg": "Sıfır değeri bu hesaplama için geçersiz."
    }
  },
  "standards": [
    "ISO 22400"
  ]
}
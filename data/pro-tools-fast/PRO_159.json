{
  "id": "vadeli_hayat_sigortasi",
  "name": "Vadeli Hayat Sigortası Prim Hesaplama Aracı",
  "category": "Sigorta / Finans",
  "description": "Vadeli hayat sigortası poliçesi için yıllık brüt prim tutarını hesaplar. Teminat tutarı, hayatta kalma olasılığı ve gider marjına göre net prim üzerinden brüt prim belirlenir.",
  "inputs": [
    {
      "id": "teminat_tl",
      "name": "Teminat (TL)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESIN",
      "absolute_min": 1000,
      "absolute_max": 100000000,
      "placeholder": "Örn: 500000"
    },
    {
      "id": "olum_olasiligi_yuzde",
      "name": "Hayatta Kalma Olasılığı (%)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESIN",
      "absolute_min": 0.01,
      "absolute_max": 99.99,
      "placeholder": "Örn: 98.5"
    },
    {
      "id": "gider_marji_yuzde",
      "name": "Gider Marji (%)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESIN",
      "absolute_min": 0,
      "absolute_max": 100,
      "placeholder": "Örn: 15"
    }
  ],
  "outputs": [
    {
      "id": "net_prim_tl",
      "name": "Net Prim (TL)",
      "unit": "TL",
      "description": "Teminat ve hayatta kalma olasılığına göre hesaplanan net prim tutarı.",
      "formula": "NetPrimTL = teminat_tl * (olum_olasiligi_yuzde / 100)",
      "result_variable": "NetPrimTL"
    },
    {
      "id": "brut_prim_tl",
      "name": "Brüt Prim (TL)",
      "unit": "TL",
      "description": "Gider marjı dahil edilmiş, ödenmesi gereken yıllık sigorta primi.",
      "formula": "BrutPrimTL = NetPrimTL / MAX(0.0001, (1 - (gider_marji_yuzde / 100)))",
      "result_variable": "BrutPrimTL"
    }
  ],
  "calculations": {
    "NetPrimTL": "teminat_tl * (olum_olasiligi_yuzde / 100)",
    "BrutPrimTL": "NetPrimTL / MAX(0.0001, (1 - (gider_marji_yuzde / 100)))"
  },
  "smart_warnings": [
    {
      "condition": "olum_olasiligi_yuzde > 99",
      "severity": "WARNING",
      "source": "Aktüerya Standardı",
      "message": "Hayatta kalma olasılığı %99 üzerinde, prim düşük çıkabilir. Riski yeniden değerlendirin."
    },
    {
      "condition": "gider_marji_yuzde > 50",
      "severity": "WARNING",
      "source": "Sigorta Denetleme Standardı",
      "message": "Gider marjı %50'yi aşıyor, poliçe maliyeti olağan dışı yüksek olabilir."
    },
    {
      "condition": "teminat_tl < 10000",
      "severity": "WARNING",
      "source": "Asgari Teminat Standardı",
      "message": "Teminat tutarı 10.000 TL altında, bazı sigorta şirketleri geçerli saymayabilir."
    },
    {
      "condition": "BrutPrimTL > 100000",
      "severity": "WARNING",
      "source": "Prim Sınır Standardı",
      "message": "Brüt prim 100.000 TL üzerinde, ödeme gücü kontrolü önerilir."
    }
  ],
  "validation": {
    "teminat_tl": {
      "absolute_min": 1000,
      "absolute_max": 100000000,
      "error_msg": "Teminat tutarı 1.000 TL ile 100.000.000 TL arasında olmalıdır."
    },
    "olum_olasiligi_yuzde": {
      "absolute_min": 0.01,
      "absolute_max": 99.99,
      "error_msg": "Hayatta kalma olasılığı %0.01 ile %99.99 arasında olmalıdır."
    },
    "gider_marji_yuzde": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Gider marjı %0 ile %100 arasında olmalıdır."
    },
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer girilemez."
    }
  },
  "standards": [
    "ISO 19700:2016",
    "TS 10798",
    "Sigorta Sözleşmeleri Kanunu"
  ],
  "version": "2.0",
  "last_updated": "2025-04-06"
}
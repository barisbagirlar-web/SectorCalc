{
  "id": "borc_konsolidasyon",
  "name": "Borç Konsolidasyon",
  "description": "Mevcut borçların tek bir düşük faizli kredide birleştirilerek aylık taksit hesaplaması",
  "category": "Finans",
  "inputs": [
    {
      "id": "borclar",
      "name": "Borçlar",
      "unit": "₺",
      "type": "array",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999,
      "items": {
        "type": "number",
        "min": 0,
        "max": 99999999
      }
    },
    {
      "id": "faizler",
      "name": "Faizler",
      "unit": "%",
      "type": "array",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100,
      "items": {
        "type": "number",
        "min": 0,
        "max": 100
      }
    },
    {
      "id": "yeni_faiz",
      "name": "Yeni Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 1200
    }
  ],
  "outputs": [
    {
      "id": "yeni_taksit",
      "name": "Yeni Aylık Taksit",
      "unit": "₺",
      "description": "Birleştirilmiş kredinin aylık taksit tutarı"
    }
  ],
  "formulas": [
    "toplam_borc = borclar.reduce((acc, val) => acc + val, 0)",
    "aylik_faiz_orani = yeni_faiz / 100 / 12",
    "yeni_taksit = toplam_borc * (aylik_faiz_orani * POW(1 + aylik_faiz_orani, vade)) / (POW(1 + aylik_faiz_orani, vade) - 1)",
    "yeni_taksit = IF(vade <= 0 || aylik_faiz_orani < 0 || toplam_borc <= 0, 0, yeni_taksit)"
  ],
  "smart_warnings": [
    {
      "condition": "yeni_faiz > 30",
      "severity": "WARNING",
      "source": "TCMB Faiz Oranı Politikası",
      "message": "Yeni faiz oranı %30'un üzerinde, bu oran yüksek riskli kredi kategorisine girer. Borçlarınızı yapılandırmadan önce alternatif finansman seçeneklerini değerlendirin."
    },
    {
      "condition": "vade > 120",
      "severity": "WARNING",
      "source": "BDDK Tüketici Kredisi Yönetmeliği",
      "message": "Vade 10 yılı (120 ay) aşıyor. Uzun vadeli kredilerde toplam geri ödeme maliyeti yükselebilir, aylık taksit düşük olsa da faiz yüküne dikkat edin."
    },
    {
      "condition": "toplam_borc > 500000",
      "severity": "WARNING",
      "source": "Kredi Riski Değerlendirme Standardı",
      "message": "Toplam borç 500.000 TL'yi aşıyor. Yüksek tutarlı konsolidasyon kredilerinde kredi notu ve gelir belgesi koşulları daha sıkıdır."
    },
    {
      "condition": "INPUT_ARRAY_LENGTH_MISMATCH",
      "severity": "WARNING",
      "source": "Veri Tutarlılığı Standardı",
      "message": "Borçlar ve faizler dizileri aynı uzunlukta değil. Her borç için bir faiz oranı girilmelidir."
    }
  ],
  "validations": [
    {
      "field": "borclar",
      "rules": {
        "negatif_hata": {
          "absolute_min": 0,
          "error_msg": "Borç değeri negatif olamaz"
        },
        "empty_hata": {
          "min_length": 1,
          "error_msg": "En az bir borç girişi yapmalısınız"
        }
      }
    },
    {
      "field": "faizler",
      "rules": {
        "negatif_hata": {
          "absolute_min": 0,
          "error_msg": "Faiz oranı negatif olamaz"
        },
        "empty_hata": {
          "min_length": 1,
          "error_msg": "En az bir faiz oranı girişi yapmalısınız"
        }
      }
    },
    {
      "field": "yeni_faiz",
      "rules": {
        "negatif_hata": {
          "absolute_min": 0,
          "error_msg": "Yeni faiz oranı negatif olamaz"
        },
        "deger_araligi": {
          "absolute_min": 0,
          "absolute_max": 100,
          "error_msg": "Yeni faiz oranı %0 ile %100 arasında olmalıdır"
        }
      }
    },
    {
      "field": "vade",
      "rules": {
        "negatif_hata": {
          "absolute_min": 1,
          "error_msg": "Vade en az 1 ay olmalıdır"
        },
        "deger_araligi": {
          "absolute_min": 1,
          "absolute_max": 1200,
          "error_msg": "Vade 1 ile 1200 ay arasında olmalıdır"
        }
      }
    },
    {
      "field": "array_length_match",
      "rules": {
        "dizi_uzunluk_uyumu": {
          "fields": [
            "borclar",
            "faizler"
          ],
          "error_msg": "Borçlar ve faizler dizileri aynı sayıda elemana sahip olmalıdır"
        }
      }
    }
  ],
  "standards": [
    "ISO 31000:2018 - Risk Yönetimi",
    "BDDK Tüketici Kredileri Yönetmeliği",
    "TCMB Faiz Oranı Politikası Çerçevesi"
  ]
}
{
  "id": "va_kredisi",
  "name": "VA Kredisi",
  "description": "Gaziler için peşinatsız kredinin faize eklenen fon maliyeti hesaplaması",
  "inputs": [
    {
      "id": "Kredi",
      "name": "Kredi",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "FinansmanUcreti",
      "name": "Finansman Ücreti",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "FinanseEdilen",
      "name": "Finanse Edilen Tutar",
      "unit": "₺",
      "description": "Kredi anaparasına finansman ücreti eklenmiş toplam tutar"
    }
  ],
  "formulas": {
    "FinanseEdilen": "Kredi * (1 + FinansmanUcreti / 100)"
  },
  "smart_warnings": [
    {
      "condition": "FinansmanUcreti > 10",
      "severity": "WARNING",
      "source": "VA Standartları",
      "message": "Finansman ücreti %10'un üzerinde, piyasa ortalamasının üzerinde olabilir."
    },
    {
      "condition": "Kredi > 50000",
      "severity": "WARNING",
      "source": "VA Kredi Limiti",
      "message": "Kredi tutarı 50.000₺'yi aşıyor, ek onay gerekebilir."
    },
    {
      "condition": "FinansmanUcreti == 0",
      "severity": "WARNING",
      "source": "VA Politikası",
      "message": "Finansman ücreti sıfır, geçerli bir oran girildiğinden emin olun."
    }
  ],
  "validation": {
    "Kredi": {
      "absolute_min": 0,
      "error_msg": "Kredi tutarı negatif olamaz."
    },
    "FinansmanUcreti": {
      "absolute_min": 0,
      "error_msg": "Finansman ücreti negatif olamaz."
    }
  },
  "standards": [
    "ISO 20022"
  ]
}
{
  "id": "fiyat_kazanc_pe_orani",
  "name": "Fiyat/Kazanç (P/E) Oranı",
  "description": "Hisse senedi fiyatının hisse başına kara bölünmesiyle elde edilen, yatırımın kâr üzerinden kendini amorti etme süresini gösteren oran.",
  "category": "Finansal Analiz",
  "inputs": [
    {
      "id": "hisse_fiyati",
      "name": "Hisse Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999,
      "step": 0.01
    },
    {
      "id": "hisse_basi_kar",
      "name": "Hisse Başı Kar",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999,
      "step": 0.0001
    }
  ],
  "outputs": [
    {
      "id": "pe_orani",
      "name": "P/E Oranı",
      "unit": "Yıl",
      "type": "number",
      "decimals": 2,
      "formula": "pe_orani = hisse_fiyati / MAX(0.0001, hisse_basi_kar)"
    }
  ],
  "warnings": [
    {
      "condition": "hisse_basi_kar <= 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Hisse başı kar sıfır veya negatif: P/E oranı anlamsız; şirket zarar ediyor olabilir."
    },
    {
      "condition": "pe_orani > 100",
      "severity": "WARNING",
      "source": "Borsa Standardı (BIST)",
      "message": "P/E oranı 100 yıl üzerinde: Aşırı değerlenme veya kârda geçici düşüş bulunabilir, dikkatli değerlendirin."
    },
    {
      "condition": "hisse_fiyati <= 0",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Hisse fiyatı sıfır veya negatif: Geçersiz veri girişi, lütfen kontrol edin."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Hisse fiyatı ve hisse başı kar değerleri negatif olamaz."
    }
  },
  "standards": [
    "ISO 31000:2018 (Risk Yönetimi - Temel Finansal Metrikler)",
    "IFRS (Uluslararası Finansal Raporlama Standardı)"
  ],
  "calculation_groups": []
}
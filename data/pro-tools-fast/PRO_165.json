{
  "id": "emeklilik_tarihi",
  "name": "Emeklilik Tarihi Hesaplayıcı",
  "description": "Hedeflenen emeklilik portföyüne ulaşmak için gereken süreyi hesaplar. Bileşik faiz ve düzenli katkı modeli kullanır.",
  "inputs": [
    {
      "id": "HedefPortfoy",
      "name": "Hedef Portföy Büyüklüğü",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999999
    },
    {
      "id": "MevcutBirikim",
      "name": "Mevcut Birikim",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999999
    },
    {
      "id": "AylikKatki",
      "name": "Aylık Düzenli Katkı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "Faiz",
      "name": "Yıllık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "Ay",
      "name": "Gerekli Süre",
      "unit": "Ay",
      "source": "formula",
      "value": "IF(MevcutBirikim >= HedefPortfoy, 0, LOG(MAX(0.0001, (HedefPortfoy*(Faiz/1200)+AylikKatki)/(MevcutBirikim*(Faiz/1200)+AylikKatki))) / LOG(MAX(0.0001, 1+(Faiz/1200))))",
      "description": "Hedeflenen emeklilik sermayesine ulaşmak için gereken süre (ay cinsinden)."
    }
  ],
  "warnings": [
    {
      "condition": "Faiz <= 0",
      "severity": "WARNING",
      "source": "ISO 5725",
      "message": "Faiz oranı sıfır veya negatif ise birikim artmaz; hedefe ulaşmak imkansız olabilir."
    },
    {
      "condition": "MevcutBirikim >= HedefPortfoy",
      "severity": "WARNING",
      "source": "ISO 5725",
      "message": "Mevcut birikim hedef portföyü zaten aşmıştır. Süre sıfır ay olarak hesaplanmıştır."
    },
    {
      "condition": "AylikKatki <= 0 && MevcutBirikim < HedefPortfoy",
      "severity": "WARNING",
      "source": "ISO 5725",
      "message": "Aylık katkı olmadan hedef portföye ulaşmak çok uzun zaman alabilir; faiz oranı düşükse imkansız."
    }
  ],
  "validations": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Değer negatif olamaz. Lütfen pozitif bir sayı giriniz."
    },
    "HedefPortfoy": {
      "absolute_min": 1,
      "error_msg": "Hedef portföy en az 1 TL olmalıdır."
    },
    "Faiz": {
      "absolute_max": 100,
      "error_msg": "Faiz oranı %100'den büyük olamaz."
    }
  },
  "standards": [
    "ISO 5725",
    "TS EN ISO 14040"
  ],
  "version": "1.0.0",
  "category": "Finans",
  "target_audience": [
    "mühendisler",
    "teknisyenler",
    "tesis yöneticileri",
    "finans uzmanları"
  ]
}
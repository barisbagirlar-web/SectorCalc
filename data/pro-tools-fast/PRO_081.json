{
  "id": "kredi_karti_faiz",
  "name": "Kredi Kartı Faiz Hesaplama",
  "description": "Ekstre kesiminden ödeme gününe kadar işleyen günlük faiz hesaplaması.",
  "inputs": [
    {
      "id": "bakiye",
      "name": "Kart Bakiyesi",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "yillik_faiz",
      "name": "Yıllık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "gun",
      "name": "Gün Sayısı",
      "unit": "Gün",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 365
    }
  ],
  "outputs": [
    {
      "id": "faiz",
      "name": "İşlemiş Faiz",
      "unit": "₺",
      "description": "Hesaplanan faiz tutarı",
      "formula": "faiz = IF(gun > 0, bakiye * (yillik_faiz / 36500) * gun, 0)",
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    }
  ],
  "warnings": [
    {
      "condition": "gun > 30",
      "severity": "WARNING",
      "source": "Genel Uygulama",
      "message": "Gün sayısı 30'dan fazla; faiz iki ekstre dönemine yayılabilir, kontrol ediniz."
    },
    {
      "condition": "gun > 60",
      "severity": "WARNING",
      "source": "Banka Standardı",
      "message": "Gün sayısı çok yüksek, faiz birikme riski yüksektir."
    },
    {
      "condition": "yillik_faiz > 30",
      "severity": "WARNING",
      "source": "TCMB Yönetmeliği",
      "message": "Yıllık faiz %30'u aşıyor; yasal üst sınır kontrolü gereklidir."
    }
  ],
  "validations": [
    {
      "negatif_hata": {
        "absolute_min": 0,
        "conditional": "bakiye < 0 OR yillik_faiz < 0 OR gun < 0",
        "error_msg": "Negatif değer girilemez, tüm alanlar pozitif olmalıdır."
      }
    },
    {
      "sifir_bakiye": {
        "conditional": "bakiye == 0",
        "error_msg": "Bakiye 0 ise hesaplama yapılamaz, faiz tutarı 0 olur."
      }
    }
  ],
  "standards": [
    "ISO 26000",
    "BDDK Kredi Kartı Faiz Hesaplama Esasları"
  ]
}
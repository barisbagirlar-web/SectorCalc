{
  "id": "makro_besin_ihtiyaci",
  "name": "177. Makro Besin İhtiyacı",
  "description": "Günlük kalori hedefinin gramaj bazlı besin dağılımı (Protein, Yağ, Karbonhidrat)",
  "category": "Beslenme ve Diyet",
  "inputs": [
    {
      "id": "tdee_kcal",
      "name": "TDEE (Günlük Kalori İhtiyacı)",
      "unit": "kcal",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 500,
      "absolute_max": 10000
    },
    {
      "id": "protein_yuzde",
      "name": "Protein (Yüzde)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 5,
      "absolute_max": 60
    },
    {
      "id": "yag_yuzde",
      "name": "Yağ (Yüzde)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 5,
      "absolute_max": 60
    },
    {
      "id": "karb_yuzde",
      "name": "Karbonhidrat (Yüzde)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 5,
      "absolute_max": 90
    },
    {
      "id": "toplam_yuzde_kontrol",
      "name": "Toplam Yüzde Kontrol (Protein+Yağ+Karb)",
      "unit": "%",
      "type": "number",
      "required": false,
      "confidence_label": "TALİ",
      "absolute_min": 95,
      "absolute_max": 105,
      "default_calc": "protein_yuzde + yag_yuzde + karb_yuzde"
    }
  ],
  "formulas": {
    "protein_g": "IF(protein_yuzde > 0, (tdee_kcal * protein_yuzde / 100) / 4, 0)",
    "yag_g": "IF(yag_yuzde > 0, (tdee_kcal * yag_yuzde / 100) / 9, 0)",
    "karb_g": "IF(karb_yuzde > 0, (tdee_kcal * karb_yuzde / 100) / 4, 0)",
    "toplam_kalori_kontrol": "protein_g * 4 + yag_g * 9 + karb_g * 4"
  },
  "outputs": [
    {
      "id": "protein_g",
      "name": "Protein (Gramaj)",
      "unit": "g",
      "description": "Günlük alınması gereken protein miktarı (gram)"
    },
    {
      "id": "yag_g",
      "name": "Yağ (Gramaj)",
      "unit": "g",
      "description": "Günlük alınması gereken yağ miktarı (gram)"
    },
    {
      "id": "karb_g",
      "name": "Karbonhidrat (Gramaj)",
      "unit": "g",
      "description": "Günlük alınması gereken karbonhidrat miktarı (gram)"
    }
  ],
  "warnings": [
    {
      "condition": "toplam_yuzde_kontrol != 100",
      "severity": "WARNING",
      "source": "Denge Prensibi",
      "message": "Protein+Yağ+Karbonhidrat yüzdeleri toplamı 100 olmalıdır. Mevcut toplam: {toplam_yuzde_kontrol}%"
    },
    {
      "condition": "protein_yuzde < 10",
      "severity": "WARNING",
      "source": "RDA Standardı",
      "message": "Protein oranı %10'un altında. Kas kaybı ve bağışıklık sorunları riski artar."
    },
    {
      "condition": "yag_yuzde < 15",
      "severity": "WARNING",
      "source": "DSÖ Önerisi",
      "message": "Yağ oranı %15'in altında. Hormonal denge ve yağda çözünen vitaminlerin emilimi tehlikeye girebilir."
    },
    {
      "condition": "karb_yuzde < 40",
      "severity": "WARNING",
      "source": "Klinik Uygulama",
      "message": "Karbonhidrat oranı %40'ın altında. Enerji seviyesi düşebilir, ketozis riski oluşabilir."
    },
    {
      "condition": "tdee_kcal < 1200",
      "severity": "WARNING",
      "source": "Minimum Metabolizma",
      "message": "TDEE değeri 1200 kcal'in altında. Vücut fonksiyonları için yetersiz kalori alımı riski."
    }
  ],
  "validations": {
    "tdee_kcal_negatif": {
      "absolute_min": 500,
      "error_msg": "TDEE en az 500 kcal olmalıdır. Aksi halde hesaplama anlamsız."
    },
    "protein_yuzde_negatif": {
      "absolute_min": 0,
      "error_msg": "Protein yüzdesi negatif olamaz."
    },
    "yag_yuzde_negatif": {
      "absolute_min": 0,
      "error_msg": "Yağ yüzdesi negatif olamaz."
    },
    "karb_yuzde_negatif": {
      "absolute_min": 0,
      "error_msg": "Karbonhidrat yüzdesi negatif olamaz."
    },
    "toplam_yuzde_kontrolu": {
      "absolute_min": 99.5,
      "absolute_max": 100.5,
      "error_msg": "Protein, Yağ ve Karbonhidrat yüzdeleri toplamı 100 ± 0.5 olmalıdır."
    }
  },
  "standards": [
    "DSÖ Beslenme Rehberi",
    "RDA Protein Alımı",
    "Denge Prensibi"
  ]
}
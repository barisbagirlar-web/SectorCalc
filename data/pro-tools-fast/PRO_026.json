{
  "id": "wacc_calculator",
  "name": "Sermaye Maliyeti (WACC) Hesaplayıcı",
  "category": "Finansal Analiz",
  "description": "Şirketin borç ve özsermaye ağırlıklı ortalama fon maliyetini hesaplar.",
  "inputs": [
    {
      "id": "equity",
      "name": "Özsermaye (E)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999999
    },
    {
      "id": "debt",
      "name": "Borç (D)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999999
    },
    {
      "id": "cost_of_equity",
      "name": "Özsermaye Maliyeti (Re)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "cost_of_debt",
      "name": "Borç Maliyeti (Rd)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "tax_rate",
      "name": "Vergi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formulas": {
    "total_value": "IF(equity + debt > 0, equity + debt, 0) // Toplam firma değeri (V)",
    "wacc": "IF(total_value > 0, ((equity / total_value) * cost_of_equity) + ((debt / total_value) * cost_of_debt * (1 - tax_rate / 100)), 0) // Ağırlıklı ortalama sermaye maliyeti (WACC) %"
  },
  "outputs": [
    {
      "id": "wacc",
      "name": "Ağırlıklı Ortalama Sermaye Maliyeti (WACC)",
      "unit": "%",
      "description": "Şirketin borç ve özsermaye ağırlıklı ortalama fon maliyeti"
    }
  ],
  "warnings": [
    {
      "condition": "total_value == 0",
      "severity": "WARNING",
      "source": "Finansal Standart (IFRS)",
      "message": "Toplam firma değeri sıfır, hesaplama yapılamaz. Özsermaye veya borç girişi yapın."
    },
    {
      "condition": "cost_of_equity > 30",
      "severity": "WARNING",
      "source": "Piyasa Beklentisi",
      "message": "Özsermaye maliyeti %30'un üzerinde, yüksek risk işareti olabilir. Gözden geçirin."
    },
    {
      "condition": "cost_of_debt > 20",
      "severity": "WARNING",
      "source": "Finansal Oran Standardı",
      "message": "Borç maliyeti %20'nin üzerinde, finansal sıkıntı sinyali olabilir."
    }
  ],
  "validation": {
    "equity": {
      "absolute_min": 0,
      "error_msg": "Özsermaye negatif olamaz."
    },
    "debt": {
      "absolute_min": 0,
      "error_msg": "Borç negatif olamaz."
    },
    "cost_of_equity": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Özsermaye maliyeti %0-100 arasında olmalıdır."
    },
    "cost_of_debt": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Borç maliyeti %0-100 arasında olmalıdır."
    },
    "tax_rate": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Vergi oranı %0-100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 31000 (Risk Yönetimi)",
    "IFRS 13 (Gerçeğe Uygun Değer Ölçümü)"
  ]
}
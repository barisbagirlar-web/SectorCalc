{
  "id": "amortisman_hesaplama",
  "name": "Amortisman Hesaplama (Doğrusal/Azalan/SYD)",
  "description": "Varlığın yıllık amortisman giderini seçilen yönteme göre hesaplar.",
  "inputs": [
    {
      "id": "bedel",
      "name": "Varlık Bedeli",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "kalinti",
      "name": "Kalıntı Değer",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "omur",
      "name": "Faydalı Ömür",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    },
    {
      "id": "yontem",
      "name": "Amortisman Yöntemi",
      "unit": "",
      "type": "string",
      "required": true,
      "confidence_label": "KESİN",
      "allowed_values": [
        "Doğrusal",
        "Azalan",
        "SYD"
      ]
    },
    {
      "id": "birikmis_amortisman",
      "name": "Birikmiş Amortisman (Azalan/SYD için)",
      "unit": "₺",
      "type": "number",
      "required": false,
      "confidence_label": "ORTA",
      "absolute_min": 0,
      "absolute_max": 999999999
    }
  ],
  "formulas": [
    "YillikGider = IF(yontem == 'Doğrusal', (bedel - kalinti) / MAX(1, omur), IF(yontem == 'Azalan', (bedel - birikmis_amortisman) * 2 / MAX(1, omur), IF(yontem == 'SYD', (bedel - kalinti) * (2 * (omur - 0) + 1) / (omur * (omur + 1) / 2), 0))) // Seçilen yönteme göre yıllık amortisman gideri (₺)"
  ],
  "outputs": [
    {
      "id": "YillikGider",
      "name": "Yıllık Amortisman Gideri",
      "unit": "₺",
      "description": "Varlığın yıllık muhasebe gideri"
    }
  ],
  "smart_warnings": [
    {
      "condition": "kalinti >= bedel",
      "severity": "WARNING",
      "source": "UFRS / Vergi Usul Kanunu",
      "message": "Kalıntı değer, varlık bedeline eşit veya büyük; amortisman gideri sıfır olacak, gözden geçirin."
    },
    {
      "condition": "omur > 50",
      "severity": "WARNING",
      "source": "Genel Kabul Görmüş Muhasebe İlkeleri",
      "message": "Faydalı ömür 50 yılı aşıyor, standart dışı olabilir, doğrulayın."
    },
    {
      "condition": "yontem == 'Azalan' && birikmis_amortisman == 0",
      "severity": "WARNING",
      "source": "Uygulama Standardı",
      "message": "Azalan bakiyeler yönteminde birikmiş amortisman girilmezse ilk yıl için hesaplama yapılır; emin misiniz?"
    }
  ],
  "validation": {
    "negatif_bedel": {
      "absolute_min": 0,
      "error_msg": "Varlık bedeli negatif olamaz."
    },
    "negatif_kalinti": {
      "absolute_min": 0,
      "error_msg": "Kalıntı değer negatif olamaz."
    },
    "omur_bir_alti": {
      "absolute_min": 1,
      "error_msg": "Faydalı ömür en az 1 yıl olmalıdır."
    }
  },
  "standards": [
    "UFRS 16",
    "VUK Md. 313",
    "TMS 16"
  ]
}
{
  "id": "tekne_kredisi_hesaplama",
  "name": "Tekne Kredisi Hesaplama",
  "description": "Deniz aracı finansmanı için aylık ödeme planı hesaplama aracı.",
  "inputs": [
    {
      "id": "tekne_fiyati",
      "name": "Tekne Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "pesinat",
      "name": "Peşinat",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "faiz_orani",
      "name": "Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "vade_suresi",
      "name": "Vade Süresi",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 360
    },
    {
      "id": "kredi_tutari",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": false,
      "confidence_label": "HESAPLANAN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "aylik_taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "type": "number",
      "required": false,
      "confidence_label": "HESAPLANAN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "formulas": {
    "kredi_tutari": "IF(tekne_fiyati > 0, tekne_fiyati - pesinat, 0) // Kredi = Tekne Fiyatı - Peşinat",
    "aylik_taksit": "IF(kredi_tutari > 0 AND faiz_orani > 0 AND vade_suresi > 0, (kredi_tutari * (faiz_orani/100/12) * POW(1 + (faiz_orani/100/12), vade_suresi)) / (POW(1 + (faiz_orani/100/12), vade_suresi) - 1), 0) // PMT formülü ile aylık taksit hesaplama"
  },
  "outputs": [
    {
      "id": "aylik_taksit",
      "name": "Aylık Taksit",
      "unit": "₺",
      "type": "number",
      "confidence_label": "HESAPLANAN"
    }
  ],
  "smart_warnings": [
    {
      "condition": "pesinat > tekne_fiyati",
      "severity": "WARNING",
      "source": "Finansal Doğrulama",
      "message": "Peşinat, tekne fiyatından büyük olamaz. Lütfen geçerli bir peşinat giriniz."
    },
    {
      "condition": "faiz_orani > 50",
      "severity": "WARNING",
      "source": "ISO 10012:2003",
      "message": "Faiz oranı %50'nin üzerinde. Olağan dışı yüksek faiz oranı tespit edildi, lütfen kontrol ediniz."
    },
    {
      "condition": "vade_suresi > 120",
      "severity": "WARNING",
      "source": "Denizcilik Finansmanı Standardı",
      "message": "Vade süresi 120 aydan (10 yıl) fazla. Uzun vadeli kredilerde toplam maliyet artabilir."
    },
    {
      "condition": "kredi_tutari > 0 AND pesinat < 0.2 * tekne_fiyati",
      "severity": "WARNING",
      "source": "Basel III",
      "message": "Peşinat oranı %20'nin altında. Riskli kredi sınıflandırmasına girebilir."
    }
  ],
  "validation": {
    "tekne_fiyati": {
      "absolute_min": 0,
      "error_msg": "Tekne fiyatı negatif olamaz."
    },
    "pesinat": {
      "absolute_min": 0,
      "error_msg": "Peşinat negatif olamaz."
    },
    "faiz_orani": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Faiz oranı %0 ile %100 arasında olmalıdır."
    },
    "vade_suresi": {
      "absolute_min": 1,
      "absolute_max": 360,
      "error_msg": "Vade süresi 1 ile 360 ay arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 10012:2003",
    "Basel III",
    "Denizcilik Finansmanı Standardı"
  ]
}
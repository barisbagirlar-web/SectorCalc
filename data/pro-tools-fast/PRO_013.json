{
  "id": "surekli_bilesik_faiz",
  "name": "Sürekli Bileşik Faiz Hesaplayıcı",
  "description": "Sonsuz frekansta bileşikleşen teorik maksimum değer hesaplaması. Sürekli bileşik faiz formülü ile anaparanın belirtilen faiz oranı ve süre sonundaki değerini hesaplar.",
  "category": "Finans",
  "inputs": [
    {
      "id": "anapara",
      "name": "Anapara",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "faiz",
      "name": "Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "yil",
      "name": "Süre",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "sonuc",
      "name": "Gelecek Değer",
      "unit": "₺",
      "confidence_label": "KESİN",
      "formula": "sonuc = anapara * EXP((faiz / 100) * yil)",
      "description": "Anaparanın sürekli bileşik faiz ile belirtilen süre sonundaki değeri."
    }
  ],
  "smart_warnings": [
    {
      "condition": "faiz > 50",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Faiz oranı %50'nin üzerinde. Bu oran piyasa koşullarında olağan dışıdır ve hesaplama teorik bir senaryoyu yansıtır."
    },
    {
      "condition": "yil > 50",
      "severity": "WARNING",
      "source": "Uzun Vade Analizi",
      "message": "Süre 50 yıldan fazla. Uzun vadeli projeksiyonlar yüksek belirsizlik içerir; sonuç yalnızca teoriktir."
    },
    {
      "condition": "anapara > 100000000",
      "severity": "WARNING",
      "source": "Büyük İşlem Uyarısı",
      "message": "Anapara 100,000,000 ₺'nin üzerinde. Bu tutarlar için ek finansal danışmanlık almanız önerilir."
    }
  ],
  "validation": {
    "anapara": {
      "absolute_min": 0,
      "error_msg": "Anapara negatif olamaz."
    },
    "faiz": {
      "absolute_min": 0,
      "error_msg": "Faiz oranı negatif olamaz."
    },
    "yil": {
      "absolute_min": 0,
      "error_msg": "Süre negatif olamaz."
    }
  },
  "standards": [
    "ISO 80000-2",
    "Finansal matematik prensipleri"
  ]
}
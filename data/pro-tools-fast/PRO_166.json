{
  "id": "401k_hesap",
  "name": "401k Büyüme Hesaplama",
  "description": "İşveren katkısı dahil 401k hesabının vade sonu değerini hesaplar",
  "inputs": [
    {
      "id": "maas",
      "name": "Aylık Brüt Maaş",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 5000,
      "absolute_max": 500000
    },
    {
      "id": "katki_orani",
      "name": "Çalışan Katkı Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    },
    {
      "id": "isveren_eslesme",
      "name": "İşveren Eşleşme Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "faiz",
      "name": "Yıllık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 30
    },
    {
      "id": "yil",
      "name": "Vade (Yıl)",
      "unit": "yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 50
    }
  ],
  "outputs": [
    {
      "id": "vade_sonu_deger",
      "name": "Vade Sonu Değer",
      "unit": "TL",
      "description": "İşveren katkısı dahil 401k hesabının vade sonu değeri",
      "formula": "vade_sonu_deger = IF(yil > 0, maas * 12 * ((katki_orani + isveren_eslesme) / 100) * ((POW(1 + (faiz / 100), yil) - 1) / (faiz / 100)), 0) // Gelecek Değer (FV) formülü: Düzenli ödeme bazlı"
    }
  ],
  "smart_warnings": [
    {
      "condition": "katki_orani > 50",
      "severity": "WARNING",
      "source": "IRS Limit Uyarısı",
      "message": "Çalışan katkı oranı %50'nin üzerinde, yıllık maksimum katkı limitini aşabilirsiniz."
    },
    {
      "condition": "faiz > 15",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Yıllık faiz oranı %15'in üzerinde, bu gerçekçi bir getiri beklentisi olmayabilir."
    },
    {
      "condition": "yil < 5",
      "severity": "WARNING",
      "source": "Yatırım Standardı",
      "message": "Vade 5 yıldan kısa, uzun vadeli bileşik getiri etkisi sınırlı kalacaktır."
    },
    {
      "condition": "isveren_eslesme > 10",
      "severity": "WARNING",
      "source": "İşveren Politikası",
      "message": "İşveren eşleşme oranı %10'un üzerinde, nadir görülen bir avantaj."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Değer negatif olamaz."
    },
    "maas_min": {
      "absolute_min": 5000,
      "error_msg": "Maaş 5.000 TL'den az olamaz."
    },
    "yil_max": {
      "absolute_max": 50,
      "error_msg": "Vade 50 yılı geçemez."
    }
  },
  "standards": [
    "IRS 401(k) Limitleri",
    "IRS Yıllık Katkı Sınırı"
  ]
}
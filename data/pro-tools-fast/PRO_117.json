{
  "id": "danismanlik_saat_ucreti",
  "name": "Danışmanlık Saat Ücreti",
  "description": "Giderleri ve kârı karşılayan minimum saatlik bedel hesaplama aracı",
  "inputs": [
    {
      "id": "HedefGelir",
      "name": "Hedef Gelir (Kâr)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "YillikGider",
      "name": "Yıllık Gider (Toplam Maliyet)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "FaturaliSaat",
      "name": "Faturalanabilir Saat (Yıllık)",
      "unit": "Saat",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 8760
    }
  ],
  "formulas": {
    "outputs": [
      "Ucret = (HedefGelir + YillikGider) / MAX(1, FaturaliSaat) // TL/Saat cinsinden minimum saatlik bedel"
    ]
  },
  "warnings": [
    {
      "condition": "FaturaliSaat < 100",
      "severity": "WARNING",
      "source": "Saha Deneyimi",
      "message": "Yıllık faturalanabilir saat çok düşük (<100 saat); sabit giderler karşılanamayabilir."
    },
    {
      "condition": "HedefGelir > YillikGider * 2",
      "source": "ISO 9001:2015 Kalite Yönetimi",
      "severity": "WARNING",
      "message": "Hedef gelir, yıllık giderin 2 katından fazla; projenin fizibilitesi sorgulanmalı."
    },
    {
      "condition": "YillikGider > 500000",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Yıllık gider yüksek; maliyet kontrolü ve bütçe revizyonu önerilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Değer negatif olamaz. Lütfen pozitif bir sayı girin."
    }
  },
  "standards": [
    "ISO 9001:2015 Kalite Yönetimi",
    "TS EN 10204:2005 Muayene Belgeleri Standardı"
  ]
}
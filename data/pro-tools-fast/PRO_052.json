{
  "id": "sermaye_kazanci_vergisi",
  "name": "Sermaye Kazancı Vergisi Hesaplama",
  "description": "Varlık satışından doğan yasal vergi yükümlülüğünü hesaplar.",
  "category": "Finansal Hesaplamalar",
  "inputs": [
    {
      "id": "satis",
      "name": "Satış Bedeli",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "alis",
      "name": "Alış Bedeli",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "vergi_orani",
      "name": "Vergi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "istisna",
      "name": "İstisna Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "matrah",
      "name": "Vergi Matrahı",
      "unit": "₺",
      "type": "number",
      "description": "Vergiye tabi kazanç (satış - alış - istisna, minimum 0)",
      "formula": "matrah = MAX(0, satis - alis - istisna) // Kazancın sıfırın altına düşmesi engellenir"
    },
    {
      "id": "vergi",
      "name": "Ödenecek Vergi",
      "unit": "₺",
      "type": "number",
      "description": "Hesaplanan toplam vergi tutarı",
      "formula": "vergi = matrah * (vergi_orani / 100) // Matrah üzerinden vergi oranı uygulanır"
    }
  ],
  "warnings": [
    {
      "condition": "satis < alis",
      "severity": "WARNING",
      "source": "Gelir Vergisi Kanunu",
      "message": "Satış bedeli alış bedelinden düşük, zarar beyanı söz konusu olabilir. Matrah sıfırlanacaktır."
    },
    {
      "condition": "vergi_orani > 40",
      "severity": "WARNING",
      "source": "Mevzuat Uyarısı",
      "message": "Vergi oranı %40'ın üzerinde. Geçerli yasal oranları kontrol ediniz."
    },
    {
      "condition": "istisna > 100000",
      "severity": "WARNING",
      "source": "Genel Uygulama",
      "message": "İstisna tutarı 100.000 ₺'nin üzerinde. İstisna şartlarını ve güncel limiti doğrulayınız."
    }
  ],
  "validation": {
    "negatif_satis": {
      "absolute_min": 0,
      "error_msg": "Satış bedeli negatif olamaz."
    },
    "negatif_alis": {
      "absolute_min": 0,
      "error_msg": "Alış bedeli negatif olamaz."
    },
    "negatif_istisna": {
      "absolute_min": 0,
      "error_msg": "İstisna tutarı negatif olamaz."
    },
    "oran_araligi": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Vergi oranı %0 ile %100 arasında olmalıdır."
    }
  },
  "standards": [
    "Gelir Vergisi Kanunu (GVK) Madde 80-82",
    "Vergi Usul Kanunu (VUK)"
  ]
}
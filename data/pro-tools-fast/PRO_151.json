{
  "id": "kalibrasyon_sapma",
  "name": "146. Kalibrasyon Sapma",
  "description": "Ölçüm cihazının zamanla bozulma hızını hesaplar.",
  "category": "Kalite Kontrol",
  "inputs": [
    {
      "id": "son_hata",
      "name": "Son Hata",
      "unit": "Birim",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -99999,
      "absolute_max": 99999
    },
    {
      "id": "onceki_hata",
      "name": "Önceki Hata",
      "unit": "Birim",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -99999,
      "absolute_max": 99999
    },
    {
      "id": "gecen_sure",
      "name": "Geçen Süre",
      "unit": "Gün",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.001,
      "absolute_max": 99999
    },
    {
      "id": "kabul_edilebilir_sapma",
      "name": "Kabul Edilebilir Sapma",
      "unit": "Birim/Gün",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "sapma_hizi",
      "name": "Sapma Hızı",
      "unit": "Birim/Gün",
      "description": "Ölçüm cihazının zamanla bozulma hızı"
    },
    {
      "id": "yeniden_kalibrasyon_onerisi",
      "name": "Yeniden Kalibrasyon Önerisi",
      "unit": "Evet/Hayır",
      "description": "Sapma hızı kabul edilebilir seviyeyi aşarsa 1, aşmazsa 0"
    }
  ],
  "formulas": {
    "sapma_hizi": "(son_hata - onceki_hata) / MAX(0.001, gecen_sure)",
    "yeniden_kalibrasyon_onerisi": "IF(ABS(sapma_hizi) > kabul_edilebilir_sapma, 1, 0)"
  },
  "standards": [
    "ISO 17025",
    "ISO 10012"
  ],
  "warnings": [
    {
      "condition": "gecen_sure <= 0",
      "severity": "ERROR",
      "source": "ISO 17025",
      "message": "Geçen süre sıfır veya negatif olamaz. Geçerli bir gün sayısı giriniz."
    },
    {
      "condition": "ABS(sapma_hizi) > 10 * kabul_edilebilir_sapma",
      "severity": "CRITICAL",
      "source": "ISO 17025",
      "message": "Kritik sapma! Cihaz derhal kalibrasyon dışı bırakılmalı ve yetkili servise bildirilmelidir."
    },
    {
      "condition": "ABS(sapma_hizi) > kabul_edilebilir_sapma && ABS(sapma_hizi) <= 10 * kabul_edilebilir_sapma",
      "severity": "WARNING",
      "source": "ISO 10012",
      "message": "Uyarı: Sapma hızı kabul edilebilir sınırı aştı. Cihaz yeniden kalibrasyon için planlanmalıdır."
    }
  ],
  "validations": [
    {
      "id": "gecen_sure",
      "absolute_min": 0.001,
      "error_msg": "Geçen süre en az 0.001 gün olmalıdır."
    },
    {
      "id": "kabul_edilebilir_sapma",
      "absolute_min": 0,
      "error_msg": "Kabul edilebilir sapma sıfırdan büyük olmalıdır."
    }
  ]
}
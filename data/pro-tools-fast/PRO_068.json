{
  "meta": {
    "id": "kapanis_maliyetleri",
    "name": "Kapanış Maliyetleri Hesabı",
    "description": "Kredi kullanımında tapu, ekspertiz, dosya ve diğer sabit masrafların toplamını hesaplar. (Profesyonel saha kararı için)",
    "category": "Finans",
    "version": "2.0",
    "target_audience": "Mühendisler, finans uzmanları, proje yöneticileri, tesis yöneticileri, saha karar vericiler",
    "confidence_level": "KESİN",
    "standards": [
      "ISO 18435",
      "ISO 50001"
    ]
  },
  "inputs": [
    {
      "id": "KrediTutari",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50000000
    },
    {
      "id": "Oran",
      "name": "Toplam Masraf Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "SabitUcretler",
      "name": "Sabit Ücretler Toplamı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 500000
    }
  ],
  "outputs": [
    {
      "id": "Toplam",
      "name": "Toplam Kapanış Maliyeti",
      "unit": "₺",
      "formula": "Toplam = (KrediTutari * Oran / 100) + SabitUcretler",
      "calculation": "Toplam = (KrediTutari * Oran / 100) + SabitUcretler",
      "description": "Tapu, ekspertiz ve dosya masrafları toplamı",
      "confidence_label": "KESİN"
    }
  ],
  "warnings": [
    {
      "condition": "KrediTutari > 5000000",
      "severity": "WARNING",
      "source": "ISO 18435 / Finansal Risk Standardı",
      "message": "Kredi tutarı 5.000.000 ₺ üzerinde. Yüksek tutarlı kredilerde ek teminat ve ekspertiz raporu zorunluluğu doğabilir."
    },
    {
      "condition": "Oran > 15",
      "severity": "WARNING",
      "source": "TCMB / Tüketici Kredisi Yönetmeliği",
      "message": "Toplam masraf oranı %15'i aşıyor. Mevzuat gereği azami oran kontrolü yapılmalıdır."
    },
    {
      "condition": "SabitUcretler > 10000",
      "severity": "WARNING",
      "source": "ISO 50001 / Maliyet Optimizasyonu Standardı",
      "message": "Sabit ücretler 10.000 ₺ üzerinde. Dosya, ekspertiz ve tapu masraflarının piyasa rayicine göre kontrol edilmesi önerilir."
    }
  ],
  "validation": {
    "KrediTutari": {
      "absolute_min": 0,
      "absolute_max": 50000000,
      "error_msg": "Geçersiz Kredi Tutarı: 0 – 50.000.000 ₺ aralığında olmalıdır."
    },
    "Oran": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Geçersiz Masraf Oranı: %0 – %100 aralığında olmalıdır."
    },
    "SabitUcretler": {
      "absolute_min": 0,
      "absolute_max": 500000,
      "error_msg": "Geçersiz Sabit Ücret: 0 – 500.000 ₺ aralığında olmalıdır."
    }
  }
}
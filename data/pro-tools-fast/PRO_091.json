{
  "id": "isletme_degerleme",
  "name": "İşletme Değerleme",
  "description": "Piyasa emsallerine göre tahmini satış değeri hesaplama aracı",
  "category": "finans",
  "inputs": [
    {
      "id": "favok",
      "name": "FAVÖK",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999,
      "step": 1000
    },
    {
      "id": "carpan",
      "name": "Çarpan",
      "unit": "Sayı",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.1,
      "absolute_max": 50,
      "step": 0.1
    }
  ],
  "outputs": [
    {
      "id": "deger",
      "name": "Değer",
      "unit": "TL",
      "formula": "deger = favok * carpan",
      "result_type": "number",
      "decimal_places": 2
    }
  ],
  "warnings": [
    {
      "condition": "favok < 10000",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "FAVÖK çok düşük, değerleme anlamsız olabilir. Lütfen veriyi kontrol edin."
    },
    {
      "condition": "carpan > 20",
      "severity": "WARNING",
      "source": "Piyasa Standardı",
      "message": "Çarpan 20 üzerinde; bu sektör ortalamasının çok üstünde, abartılı bir değer olabilir."
    },
    {
      "condition": "favok > 50000000",
      "severity": "WARNING",
      "source": "Büyük Ölçek Standardı",
      "message": "FAVÖK 50 milyon TL üzerinde; işlem hacmi yüksek olabilir, dikkatli analiz önerilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "FAVÖK negatif olamaz. Lütfen geçerli bir değer giriniz."
    },
    "carpan_sifir_hata": {
      "absolute_min": 0.1,
      "error_msg": "Çarpan 0.1'den küçük olamaz. Lütfen geçerli bir değer giriniz."
    }
  },
  "standards": [
    "ISO 14000",
    "Piyasa Değerleme Rehberi"
  ],
  "metadata": {
    "version": "1.0",
    "last_review": "2025-01-01",
    "author": "Saha Mühendislik Ekibi"
  }
}
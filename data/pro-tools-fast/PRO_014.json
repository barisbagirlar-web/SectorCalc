{
  "id": "nominal_ve_efektif_faiz",
  "name": "Nominal ve Efektif Faiz Hesaplama",
  "description": "Nominal faiz oranı ve yıllık bileşim sıklığına göre efektif yıllık faiz oranını hesaplar.",
  "category": "Finans",
  "inputs": [
    {
      "id": "nominal_faiz_orani",
      "name": "Nominal Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 500
    },
    {
      "id": "bilesim_sikligi",
      "name": "Bileşim Sıklığı (Yıllık)",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 365
    }
  ],
  "outputs": [
    {
      "id": "efektif_faiz_orani",
      "name": "Efektif Yıllık Faiz Oranı",
      "unit": "%",
      "confidence_label": "KESİN",
      "formula": "efektif_faiz_orani = IF(bilesim_sikligi >= 1, (POW((1 + (nominal_faiz_orani / 100) / bilesim_sikligi), bilesim_sikligi) - 1) * 100, 0)"
    }
  ],
  "warnings": [
    {
      "condition": "nominal_faiz_orani > 100",
      "severity": "WARNING",
      "source": "Finans Standardı",
      "message": "Nominal faiz oranı %100 üzerinde! Bu oran yüksek risk göstergesidir."
    },
    {
      "condition": "bilesim_sikligi > 12",
      "severity": "WARNING",
      "source": "Finans Standardı",
      "message": "Bileşim sıklığı aylık periyotların üzerinde (yılda 12'den fazla). Sürekli bileşim etkisi yaklaşımına yaklaşıldı."
    },
    {
      "condition": "nominal_faiz_orani > 0 && nominal_faiz_orani < 1",
      "severity": "WARNING",
      "source": "Kullanıcı Deneyimi",
      "message": "Nominal faiz oranı çok düşük (0-1% arası). Girdiği değeri yüzde cinsinden kontrol ediniz."
    }
  ],
  "validation": {
    "nominal_faiz_orani": {
      "negatif": {
        "absolute_min": 0,
        "error_msg": "Nominal faiz oranı negatif olamaz."
      }
    },
    "bilesim_sikligi": {
      "negatif": {
        "absolute_min": 1,
        "error_msg": "Bileşim sıklığı en az 1 olmalıdır (yıllık)."
      }
    }
  },
  "standards": [
    "ISO 16794:2023 (Finansal Araçlar ve Faiz Hesaplamaları)",
    "Finansal Matematik Temel Prensipleri"
  ]
}
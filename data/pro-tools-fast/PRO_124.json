{
  "id": "dropshipping_kar_hesap",
  "name": "Dropshipping Kâr Hesabı",
  "description": "Stoksuz ticarette tüm giderler sonrası net kâr hesaplama aracı.",
  "inputs": [
    {
      "id": "satis",
      "name": "Satış Fiyatı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "tedarik",
      "name": "Tedarik Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "kargo",
      "name": "Kargo Ücreti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "reklam",
      "name": "Reklam Maliyeti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "net_kar",
      "name": "Net Kâr",
      "unit": "TL",
      "formula": "net_kar = satis - tedarik - kargo - reklam",
      "description": "Tüm giderler düşüldükten sonra kalan net kâr"
    }
  ],
  "warnings": [
    {
      "condition": "reklam > satis * 0.5",
      "severity": "WARNING",
      "source": "Pazarlama Standardı",
      "message": "Reklam maliyeti satış fiyatının %50'sini aştı, kârlılık riski yüksek."
    },
    {
      "condition": "net_kar < 0",
      "severity": "WARNING",
      "source": "Finansal Standardı",
      "message": "Net kâr negatif, işlem zararla sonuçlanıyor."
    },
    {
      "condition": "tedarik > satis",
      "severity": "WARNING",
      "source": "ISO 14000",
      "message": "Tedarik maliyeti satış fiyatını aştı, brüt kâr mümkün değil."
    }
  ],
  "validation": {
    "satis": {
      "absolute_min": 0,
      "error_msg": "Satış fiyatı sıfırdan küçük olamaz."
    },
    "tedarik": {
      "absolute_min": 0,
      "error_msg": "Tedarik maliyeti sıfırdan küçük olamaz."
    },
    "kargo": {
      "absolute_min": 0,
      "error_msg": "Kargo ücreti sıfırdan küçük olamaz."
    },
    "reklam": {
      "absolute_min": 0,
      "error_msg": "Reklam maliyeti sıfırdan küçük olamaz."
    }
  },
  "standards": [
    "ISO 9001:2015 - Kalite Yönetim Sistemi"
  ]
}
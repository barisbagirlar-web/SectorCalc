{
  "id": "kredi_uygunluk",
  "name": "Kredi Uygunluk (Affordability)",
  "description": "Bütçeyi sarsmadan ödenebilecek maksimum kredi taksitini hesaplar.",
  "inputs": [
    {
      "id": "NetGelir",
      "name": "Net Gelir",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000000
    },
    {
      "id": "YasamGideri",
      "name": "Yaşam Gideri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000000
    },
    {
      "id": "MaxTaksitOrani",
      "name": "Maksimum Taksit Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "MaxTaksit",
      "name": "Maksimum Taksit",
      "unit": "₺",
      "description": "Bütçeyi sarsmadan ödenebilecek maksimum kredi taksiti",
      "formula": "MaxTaksit = MIN((NetGelir - YasamGideri), NetGelir * (MaxTaksitOrani / 100))"
    }
  ],
  "warnings": [
    {
      "condition": "NetGelir - YasamGideri < 0",
      "severity": "WARNING",
      "source": "Bütçe Standardı",
      "message": "Yaşam gideri net geliri aşıyor; kredi taksiti negatif olabilir, borç yönetimi riskli."
    },
    {
      "condition": "MaxTaksitOrani > 50",
      "severity": "WARNING",
      "source": "Finansal Sağlık Standardı",
      "message": "Maksimum taksit oranı %50'nin üzerinde; gelirin yarısından fazlası krediye ayrılamaz."
    },
    {
      "condition": "NetGelir < 1000",
      "severity": "WARNING",
      "source": "Asgari Gelir Standardı",
      "message": "Net gelir çok düşük, kredi uygunluğu sorgulanabilir."
    }
  ],
  "validation": {
    "NetGelir": {
      "absolute_min": 0,
      "error_msg": "Net gelir negatif olamaz."
    },
    "YasamGideri": {
      "absolute_min": 0,
      "error_msg": "Yaşam gideri negatif olamaz."
    },
    "MaxTaksitOrani": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Maksimum taksit oranı 0-100 arasında olmalıdır."
    },
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Hesaplama sonucu negatif olamaz; bütçe açığı var."
    }
  },
  "standards": [
    "ISO 18435",
    "ISO 22274"
  ]
}
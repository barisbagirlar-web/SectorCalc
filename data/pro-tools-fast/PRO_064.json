{
  "id": "nakit_nakit_getiri_coc",
  "name": "Nakit-Nakit Getiri (CoC)",
  "description": "Yatırılan özsermayenin yıllık nakit dönüş oranı hesaplama aracı",
  "category": "Finansal Analiz",
  "inputs": [
    {
      "id": "yillik_nakit_akis",
      "name": "Yıllık Nakit Akışı (NOI)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999999
    },
    {
      "id": "toplam_nakit_yatirim",
      "name": "Toplam Nakit Yatırım (Peşinat+Kapanış)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999999999
    }
  ],
  "outputs": [
    {
      "id": "coc_orani",
      "name": "Nakit-Nakit Getiri Oranı",
      "unit": "%",
      "description": "Yatırılan özsermayenin yıllık nakit dönüş oranı",
      "result": "coc_orani = (yillik_nakit_akis / MAX(1, toplam_nakit_yatirim)) * 100"
    }
  ],
  "warnings": [
    {
      "condition": "yillik_nakit_akis > 1000000",
      "severity": "WARNING",
      "source": "Ticari Gayrimenkul Standardı",
      "message": "Yıllık nakit akışı 1.000.000 ₺ üzerinde, lütfen veriyi kontrol edin."
    },
    {
      "condition": "toplam_nakit_yatirim > 5000000",
      "severity": "WARNING",
      "source": "Yatırım Fizibilite Standardı",
      "message": "Toplam nakit yatırım 5.000.000 ₺ üzerinde, proje büyüklüğünü teyit edin."
    },
    {
      "condition": "coc_orani > 30",
      "severity": "WARNING",
      "source": "Piyasa Karşılaştırma Standardı",
      "message": "Nakit-nakit getiri oranı %30'un üzerinde, bu piyasa ortalamasının çok üstünde. Risk değerlendirmesi yapın."
    }
  ],
  "validations": {
    "yillik_nakit_akis": {
      "absolute_min": 0,
      "error_msg": "Yıllık nakit akışı negatif olamaz."
    },
    "toplam_nakit_yatirim": {
      "absolute_min": 0,
      "error_msg": "Toplam nakit yatırım negatif olamaz."
    }
  },
  "standards": [
    "ISO 21500",
    "Gayrimenkul Değerleme Standardı"
  ]
}
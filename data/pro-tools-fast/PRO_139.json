{
  "id": "nakliye_maliyeti",
  "name": "135. Nakliye Maliyeti",
  "description": "Karayolu taşımacılığının toplam navlun bedeli hesaplaması",
  "category": "Lojistik ve Maliyet Hesapları",
  "inputs": [
    {
      "id": "mesafe",
      "name": "Mesafe",
      "unit": "km",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 5000,
      "typical_min": 1,
      "typical_max": 3000
    },
    {
      "id": "tonaj",
      "name": "Tonaj",
      "unit": "Ton",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100,
      "typical_min": 0.1,
      "typical_max": 40
    },
    {
      "id": "birim_fiyat",
      "name": "Birim Fiyat",
      "unit": "TL/Ton-km",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 500,
      "typical_min": 0.5,
      "typical_max": 100
    }
  ],
  "outputs": [
    {
      "id": "maliyet_tl",
      "name": "Toplam Maliyet",
      "unit": "TL",
      "description": "Karayolu taşımacılığı navlun bedeli"
    }
  ],
  "formulas": {
    "maliyet_tl": "mesafe * tonaj * birim_fiyat"
  },
  "warnings": [
    {
      "condition": "mesafe > 3000",
      "severity": "WARNING",
      "source": "ISO 15663",
      "message": "Mesafe 3000 km üzerinde: Sürekli şoför değişimi ve yasal dinlenme maliyetleri eklenmelidir."
    },
    {
      "condition": "tonaj > 40",
      "severity": "WARNING",
      "source": "ISO 15663",
      "message": "Tonaj 40 Ton üzerinde: Özel izin ve yönlendirme gerektirir, maliyet artabilir."
    },
    {
      "condition": "birim_fiyat > 100",
      "severity": "WARNING",
      "source": "ISO 15663",
      "message": "Birim fiyat 100 TL/Ton-km üzerinde: Piyasa ortalamasının çok üstünde, teyit ediniz."
    }
  ],
  "validation": {
    "mesafe": {
      "absolute_min": 0,
      "error_msg": "Mesafe 0'dan büyük olmalıdır."
    },
    "tonaj": {
      "absolute_min": 0,
      "error_msg": "Tonaj 0'dan büyük olmalıdır."
    },
    "birim_fiyat": {
      "absolute_min": 0,
      "error_msg": "Birim fiyat 0'dan büyük olmalıdır."
    }
  },
  "standards": [
    "ISO 15663"
  ],
  "version": "2.0"
}
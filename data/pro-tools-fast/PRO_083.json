{
  "id": "kredi_karti_islem_ucreti",
  "name": "Kredi Kartı İşlem Ücreti",
  "description": "POS cihazı veya sanal ödeme altyapısı kesintisi hesaplama aracı",
  "inputs": [
    {
      "id": "satis",
      "name": "Satış Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 9999999
    },
    {
      "id": "yuzde",
      "name": "Komisyon Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100,
      "step": 0.01
    },
    {
      "id": "sabit",
      "name": "Sabit Ücret",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 9999
    }
  ],
  "outputs": [
    {
      "id": "komisyon",
      "name": "Komisyon Tutarı",
      "unit": "₺",
      "type": "number",
      "formula": "komisyon = (satis * yuzde / 100) + sabit",
      "result_precision": 2,
      "description": "Ödenecek toplam kredi kartı işlem ücreti"
    },
    {
      "id": "net_tutar",
      "name": "Net Tahsilat",
      "unit": "₺",
      "type": "number",
      "formula": "net_tutar = satis - komisyon",
      "result_precision": 2,
      "description": "Kesinti sonrası hesaba geçen tutar"
    }
  ],
  "warnings": [
    {
      "condition": "satis <= 0",
      "severity": "ERROR",
      "source": "Ticari Uygulama",
      "message": "Satış tutarı sıfır veya negatif olamaz"
    },
    {
      "condition": "yuzde > 10",
      "severity": "WARNING",
      "source": "Banka Standartları",
      "message": "Komisyon oranı %10'u aşıyor, teyit ediniz"
    },
    {
      "condition": "komisyon > satis * 0.5",
      "severity": "WARNING",
      "source": "Maliyet Kontrolü",
      "message": "Komisyon, satış tutarının yarısını geçti. Oranları ve sabit ücreti kontrol edin"
    },
    {
      "condition": "sabit > 50",
      "severity": "WARNING",
      "source": "Sektörel Sınır",
      "message": "Sabit ücret 50 TL üzeri, lütfen anlaşma koşullarını doğrulayın"
    },
    {
      "condition": "yuzde <= 0 && sabit <= 0",
      "severity": "ERROR",
      "source": "Geçersiz Yapılandırma",
      "message": "Hem komisyon oranı hem sabit ücret sıfır, işlem ücretsiz olacak"
    }
  ],
  "validations": {
    "satis": {
      "absolute_min": 1,
      "absolute_max": 9999999,
      "error_msg": "Satış tutarı 1 ₺ ile 9,999,999 ₺ arasında olmalıdır"
    },
    "yuzde": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Komisyon oranı %0 ile %100 arasında olmalıdır"
    },
    "sabit": {
      "absolute_min": 0,
      "absolute_max": 9999,
      "error_msg": "Sabit ücret 0 ₺ ile 9,999 ₺ arasında olmalıdır"
    }
  },
  "categories": [
    "finans",
    "odeme_sistemleri"
  ],
  "standards": [
    "ISO 20022",
    "PCI DSS"
  ]
}
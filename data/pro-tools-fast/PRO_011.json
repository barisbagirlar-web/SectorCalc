{
  "id": "11_bilesik_faiz",
  "name": "Bileşik Faiz Hesaplayıcı",
  "category": "Finans",
  "description": "Belirtilen anapara, faiz oranı, yıl ve sıklık (yıllık bileşik sayısı) için bileşik faiz sonucunu hesaplar.",
  "version": 1,
  "created_at": "2025-03-24",
  "updated_at": "2025-03-24",
  "author": "Sen SectorCalc",
  "inputs": [
    {
      "id": "anapara",
      "name": "Anapara",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "faiz_orani",
      "name": "Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "yil",
      "name": "Yıl",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    },
    {
      "id": "siklik",
      "name": "Bileşik Sıklığı",
      "unit": "Adet (yılda)",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 365
    }
  ],
  "outputs": [
    {
      "id": "bilesik_faiz_sonuc",
      "name": "Bileşik Faiz Sonucu",
      "unit": "₺",
      "description": "Faizin anaparaya eklendiği vade sonu değer.",
      "formula": "bilesik_faiz_sonuc = ROUND(anapara * POW((1 + (faiz_orani/100)/MAX(1, siklik)), siklik * yil), 2)"
    }
  ],
  "smart_warnings": [
    {
      "condition": "faiz_orani > 50",
      "severity": "WARNING",
      "source": "Genel Uyarı",
      "message": "Faiz oranı %50'nin üzerinde. Olağanüstü yüksek faiz oranı, sonucun gerçekçiliğini kontrol edin."
    },
    {
      "condition": "yil > 30",
      "severity": "WARNING",
      "source": "Uzun Vadeli Uyarı",
      "message": "Vade 30 yılı aşıyor. Uzun vadeli hesaplamalar nominal değerlerde yanıltıcı olabilir, enflasyon etkisini göz önünde bulundurun."
    },
    {
      "condition": "siklik > 12",
      "severity": "WARNING",
      "source": "Yüksek Bileşik Uyarısı",
      "message": "Yıllık bileşik sıklığı 12'den fazla (günlük bileşik gibi). Kümülatif faiz etkisi beklenenden yüksek olabilir."
    },
    {
      "condition": "anapara > 1000000",
      "severity": "WARNING",
      "source": "Büyük Anapara Uyarısı",
      "message": "Anapara 1.000.000 ₺'yi aşıyor. Parasal büyüklük nedeniyle yuvarlama hataları oluşabilir, sonucu teyit edin."
    }
  ],
  "validation": {
    "anapara_negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Anapara negatif olamaz."
    },
    "faiz_orani_negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Faiz oranı negatif olamaz."
    },
    "faiz_orani_yuzde_limit": {
      "absolute_max": 100,
      "error_msg": "Faiz oranı %100'den büyük olamaz."
    },
    "yil_negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Yıl negatif veya sıfır olamaz."
    },
    "siklik_negatif_hata": {
      "absolute_min": 1,
      "error_msg": "Bileşik sıklığı en az 1 olmalıdır."
    }
  },
  "standards": [
    "ISO 30405",
    "Genel Finansal Hesaplama Standardı"
  ],
  "source": "Sen SectorCalc",
  "reference": "Bileşik Faiz Formülü - A = P(1 + r/n)^(nt)"
}
{
  "id": "girisim_degerleme",
  "name": "90. Girişim Değerleme",
  "description": "Yatırım tutarı ve hisse oranına göre girişimin yatırım öncesi ve sonrası değerini hesaplar.",
  "inputs": [
    {
      "id": "yatirim",
      "name": "Yatırım Tutarı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "hisse_orani",
      "name": "Hisse Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "degerleme_once",
      "name": "Yatırım Öncesi Girişim Değeri",
      "unit": "TL",
      "description": "Yatırım öncesi girişimin şirket değeri",
      "type": "number"
    },
    {
      "id": "degerleme_sonrasi",
      "name": "Yatırım Sonrası Girişim Değeri",
      "unit": "TL",
      "description": "Yatırım sonrası girişimin şirket değeri",
      "type": "number"
    }
  ],
  "formulas": [
    "degerleme_sonrasi = MAX(0, Yatirim / MAX(0.0001, HisseOrani / 100)) // Yatırım sonrası değer = Yatırım / Hisse Oranı (ondalık)",
    "degerleme_once = MAX(0, DegerlemeSonrasi - Yatirim) // Yatırım öncesi değer = Sonrası - Yatırım"
  ],
  "warnings": [
    {
      "condition": "hisse_orani <= 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Hisse oranı sıfır veya negatif olamaz. Lütfen geçerli bir yüzde girin."
    },
    {
      "condition": "yatirim <= 0",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Yatırım tutarı sıfır veya negatif olamaz. Lütfen pozitif bir değer girin."
    },
    {
      "condition": "hisse_orani > 100",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Hisse oranı %100'den büyük olamaz. Lütfen kontrol edin."
    },
    {
      "condition": "degerleme_sonrasi > yatirim * 1000",
      "severity": "WARNING",
      "source": "Finansal Standart",
      "message": "Hesaplanan değer çok yüksek. Hisse oranını kontrol edin."
    }
  ],
  "validation": {
    "negatif_hata": {
      "condition": "yatirim < 0 OR hisse_orani < 0",
      "absolute_min": 0,
      "error_msg": "Girdiler negatif olamaz."
    },
    "sifir_hisse_hata": {
      "condition": "hisse_orani == 0",
      "cannot_be_zero": true,
      "error_msg": "Hisse oranı sıfır olamaz."
    }
  },
  "standards": [
    "ISO 31000",
    "FINA 1001"
  ]
}
{
  "id": "standart_zaman",
  "name": "Standart Zaman Hesaplama",
  "description": "Gözlenen süre, performans ve ek süre (yorgunluk payı) kullanılarak ISO standartlarına uygun standart zaman hesaplaması.",
  "inputs": [
    {
      "id": "GozlenenSure",
      "name": "Gözlenen Süre",
      "unit": "Dk",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1440
    },
    {
      "id": "Performans",
      "name": "Performans Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 10,
      "absolute_max": 200
    },
    {
      "id": "EkSure",
      "name": "Ek Süre (Yorgunluk Payı)",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formula": "Normal = GozlenenSure * (Performans / 100); Standart = Normal * (1 + EkSure / 100)",
  "outputs": [
    {
      "id": "Standart",
      "name": "Standart Zaman",
      "unit": "Dk",
      "formula": "IF(GozlenenSure > 0, (GozlenenSure * (Performans / 100)) * (1 + EkSure / 100), 0)",
      "description": "Yorgunluk payı eklenmiş hedef süre"
    },
    {
      "id": "Normal",
      "name": "Normal Zaman",
      "unit": "Dk",
      "formula": "IF(GozlenenSure > 0, GozlenenSure * (Performans / 100), 0)",
      "description": "Performans düzeltilmiş temel süre"
    }
  ],
  "warnings": [
    {
      "condition": "Performans < 50",
      "severity": "WARNING",
      "source": "ISO 9001:2015",
      "message": "Performans oranı %50'nin altında. Operatör eğitimi veya iyileştirme önerilir."
    },
    {
      "condition": "Performans > 120",
      "severity": "WARNING",
      "source": "ISO 116:2010",
      "message": "Performans oranı çok yüksek (%120 üzeri). Standart zaman tutarsız olabilir; gözlem tekrarlanmalı."
    },
    {
      "condition": "EkSure > 30",
      "severity": "WARNING",
      "source": "ISO 11228-1:2003",
      "message": "Ek süre (yorgunluk payı) %30'u aşıyor. Ergonomik iyileştirme veya molalar değerlendirilmelidir."
    },
    {
      "condition": "GozlenenSure < 0.5",
      "severity": "WARNING",
      "source": "ISO 9001:2015",
      "message": "Gözlenen süre 0.5 dk'dan kısa, ölçüm hassasiyeti düşük olabilir; daha uzun süreli gözlem önerilir."
    }
  ],
  "validation": [
    {
      "id": "negatif_hata",
      "absolute_min": 0,
      "error_msg": "Negatif değer kabul edilmez."
    },
    {
      "id": "Performans",
      "absolute_min": 10,
      "absolute_max": 200,
      "error_msg": "Performans oranı %10 ile %200 arasında olmalıdır."
    },
    {
      "id": "GozlenenSure",
      "absolute_min": 0,
      "error_msg": "Gözlenen süre sıfır veya negatif olamaz."
    }
  ],
  "standards": [
    "ISO 9001:2015",
    "ISO 116:2010",
    "ISO 11228-1:2003"
  ]
}
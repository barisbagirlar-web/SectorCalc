{
  "id": "ek_vergi_126",
  "name": "126. Tarife (Ek Vergi)",
  "description": "Belirli menşeili ürünlere uygulanan ek gümrük vergisi hesaplama aracı",
  "category": "Gümrük & Vergi",
  "version": "1.0",
  "inputs": [
    {
      "id": "UrunBedeli",
      "name": "Ürün Bedeli",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "EkVergi",
      "name": "Ek Vergi Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "EkVergiTL",
      "name": "Ek Vergi Tutarı",
      "unit": "TL",
      "formula": "EkVergiTL = UrunBedeli * (EkVergi / 100)"
    },
    {
      "id": "ToplamMaliyet",
      "name": "Toplam Maliyet",
      "unit": "TL",
      "formula": "ToplamMaliyet = UrunBedeli + EkVergiTL"
    }
  ],
  "smart_warnings": [
    {
      "condition": "UrunBedeli > 1000000",
      "severity": "WARNING",
      "source": "Gümrük Genel Tebliği",
      "message": "Ürün bedeli 1.000.000 TL üzerinde, ek belge ve beyan gerekebilir."
    },
    {
      "condition": "EkVergi > 50",
      "severity": "WARNING",
      "source": "İthalat Rejimi",
      "message": "Ek vergi oranı %50'yi aşıyor, menşe kısıtlaması ve ek izin kontrol edilmelidir."
    },
    {
      "condition": "UrunBedeli < 100",
      "severity": "WARNING",
      "source": "Gümrük Uygulaması",
      "message": "Düşük bedel bildirimi, kıymet araştırmasına takılabilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer geçerli değil"
    }
  },
  "standards": [
    "ISO 27001",
    "Gümrük Yönetmeliği Madde 126"
  ],
  "metadata": {
    "author": "SectorCalc-Endüstriyel Mühendislik",
    "date": "2025-04-10",
    "accuracy": "±0.01 TL"
  }
}
{
  "id": "musteri_edinim_maliyeti_cac",
  "name": "Müşteri Edinim Maliyeti (CAC)",
  "description": "Bir yeni müşteriyi kazanmanın ortalama maliyeti (TL/adet)",
  "category": "finans",
  "inputs": [
    {
      "id": "pazarlama",
      "name": "Pazarlama Gideri",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "satis_gideri",
      "name": "Satış Gideri",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "yeni_musteri",
      "name": "Yeni Müşteri Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 999999
    }
  ],
  "outputs": [
    {
      "id": "cac",
      "name": "Müşteri Edinim Maliyeti (CAC)",
      "unit": "TL",
      "confidence_label": "KESİN",
      "formula": "cac = (pazarlama + satis_gideri) / MAX(1, yeni_musteri)"
    }
  ],
  "standards": [
    "ISO 16759",
    "ISO 28057"
  ],
  "warnings": [
    {
      "condition": "cac > 5000",
      "severity": "WARNING",
      "source": "ISO 16759",
      "message": "CAC değeri 5000 TL'yi aştı; maliyet optimizasyonu önerilir."
    },
    {
      "condition": "yeni_musteri > 1000",
      "severity": "WARNING",
      "source": "ISO 28057",
      "message": "Yeni müşteri sayısı 1000'den yüksek; veri doğruluğunu kontrol edin."
    },
    {
      "condition": "pazarlama > 100000",
      "severity": "WARNING",
      "source": "ISO 16759",
      "message": "Pazarlama gideri 100.000 TL'yi aştı; bütçe limiti aşımı ihtimali."
    },
    {
      "condition": "satis_gideri > 50000",
      "severity": "WARNING",
      "source": "ISO 28057",
      "message": "Satış gideri 50.000 TL'yi aştı; harcama kalemlerini inceleyin."
    }
  ],
  "validations": {
    "pazarlama": {
      "absolute_min": 0,
      "error_msg": "Pazarlama gideri negatif olamaz."
    },
    "satis_gideri": {
      "absolute_min": 0,
      "error_msg": "Satış gideri negatif olamaz."
    },
    "yeni_musteri": {
      "absolute_min": 1,
      "error_msg": "Yeni müşteri sayısı en az 1 olmalıdır."
    },
    "cac": {
      "absolute_min": 0,
      "error_msg": "CAC negatif olamaz."
    }
  }
}
{
  "id": "backdoor_roth_ira_hesap",
  "name": "Backdoor Roth IRA Hesaplama",
  "description": "Dolaylı Roth dönüşümü sonrası net bakiye hesaplaması",
  "inputs": [
    {
      "id": "GelenekselBakiye",
      "name": "Geleneksel IRA Bakiyesi",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "DonusenTutar",
      "name": "Dönüştürülen Tutar",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999
    },
    {
      "id": "VergiOrani",
      "name": "Vergi Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "formulas": [
    "Vergi = DonusenTutar * (VergiOrani / 100) // Dönüşüm üzerinden hesaplanan vergi tutarı",
    "NetRoth = GelenekselBakiye + DonusenTutar - Vergi // Dönüşüm sonrası net Roth bakiyesi"
  ],
  "outputs": [
    {
      "id": "NetRoth",
      "name": "Net Roth Bakiyesi",
      "unit": "TL",
      "description": "Dolaylı Roth dönüşümü sonrası net bakiye"
    }
  ],
  "warnings": [
    {
      "condition": "VergiOrani > 35",
      "severity": "WARNING",
      "source": "IRS Kuralları",
      "message": "Vergi oranı %35'in üzerindedir; dönüşüm yüksek vergi yükü oluşturabilir."
    },
    {
      "condition": "DonusenTutar > GelenekselBakiye",
      "severity": "WARNING",
      "source": "IRS Pro-Rata Kuralı",
      "message": "Dönüştürülen tutar, mevcut bakiyeden büyük; pro-rata vergilendirme kontrol edilmelidir."
    },
    {
      "condition": "GelenekselBakiye > 500000",
      "severity": "WARNING",
      "source": "IRS Yıllık Limit",
      "message": "Yüksek bakiye vergi planlaması gerektirebilir; uzman danışmanlığı önerilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Girdi değeri negatif olamaz."
    },
    "vergi_orani_hata": {
      "condition": "VergiOrani < 0 || VergiOrani > 100",
      "error_msg": "Vergi oranı %0-100 arasında olmalıdır."
    },
    "donusum_hata": {
      "condition": "DonusenTutar < 0",
      "error_msg": "Dönüştürülen tutar negatif olamaz."
    }
  },
  "standards": [
    "IRS 590-A",
    "IRS 590-B"
  ]
}
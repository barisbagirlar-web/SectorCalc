{
  "id": "eticaret_kar_hesabi",
  "name": "E-Ticaret Kârı Hesaplama",
  "category": "Finans",
  "description": "E-ticaret operasyonunun ciro, satılan mal maliyeti (COGS), pazarlama ve operasyon giderlerine göre net kârını hesaplar.",
  "inputs": [
    {
      "id": "ciro_tl",
      "name": "Ciro (Brüt Satış Geliri)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "cogs_tl",
      "name": "COGS (Satılan Mal Maliyeti)",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "pazarlama_tl",
      "name": "Pazarlama Gideri",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "operasyon_tl",
      "name": "Operasyon Gideri",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    }
  ],
  "outputs": [
    {
      "id": "net_kar_tl",
      "name": "Net Kâr",
      "unit": "TL",
      "type": "number",
      "formula": "net_kar_tl = ciro_tl - cogs_tl - pazarlama_tl - operasyon_tl",
      "description": "E-ticaret operasyonunun nihai net kârı/zararı"
    }
  ],
  "standards": [
    "ISO 10668:2010",
    "TMS 2 Stoklar"
  ],
  "smart_warnings": [
    {
      "condition": "ciro_tl > 0 AND cogs_tl > ciro_tl",
      "severity": "WARNING",
      "source": "TMS 2 Stoklar",
      "message": "COGS ciroyu aşıyor, bu durumda brüt zarar oluşur. İşletme maliyet yapısını gözden geçirin."
    },
    {
      "condition": "pazarlama_tl > (ciro_tl * 0.3)",
      "severity": "WARNING",
      "source": "ISO 10668:2010",
      "message": "Pazarlama gideri cironun %30'undan fazla; sürdürülebilirlik riski yüksek."
    },
    {
      "condition": "net_kar_tl < 0",
      "severity": "WARNING",
      "source": "Genel Kabul Görmüş Muhasebe",
      "message": "Net kâr negatif, işletme zarardadır. Gider kalemlerini kontrol edin."
    },
    {
      "condition": "operasyon_tl > (ciro_tl * 0.4)",
      "severity": "WARNING",
      "source": "Operasyonel Verimlilik",
      "message": "Operasyon giderleri cironun %40'ını aştı; süreç optimizasyonu gerekli."
    }
  ],
  "validation_rules": [
    {
      "negatif_hata": {
        "absolute_min": 0,
        "error_msg": "Hiçbir girdi negatif olamaz, lütfen TL cinsinden pozitif değer giriniz."
      }
    }
  ]
}
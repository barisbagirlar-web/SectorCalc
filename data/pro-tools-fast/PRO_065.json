{
  "id": "brrrr_strategy_calculator",
  "name": "BRRRR Stratejisi",
  "description": "Al-Yenile-Kirala-Refinanse Et modelinin sermaye getirisi hesaplaması",
  "inputs": [
    {
      "id": "alis_fiyati",
      "name": "Alış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "rehab_maliyeti",
      "name": "Rehab Maliyeti",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "deger_artisi_sonrasi",
      "name": "Değer (Satış/Refinanse)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "kredi_miktari",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "aylik_kira_geliri",
      "name": "Aylık Kira Geliri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "roi",
      "name": "Sermaye Getirisi (ROI)",
      "unit": "%",
      "description": "BRRRR stratejisinde yatırılan zorunlu sermayenin yıllık getiri yüzdesi",
      "formula": "roi = IF(MAX(0, alis_fiyati + rehab_maliyeti - kredi_miktari) > 0, (aylik_kira_geliri*12) / MAX(1, alis_fiyati + rehab_maliyeti - kredi_miktari) * 100, 0)"
    }
  ],
  "smart_warnings": [
    {
      "condition": "alis_fiyati <= 0",
      "severity": "WARNING",
      "source": "Finansal Analiz Standardı",
      "message": "Alış fiyatı sıfır veya negatif olamaz, lütfen geçerli bir değer girin."
    },
    {
      "condition": "kredi_miktari > (alis_fiyati + rehab_maliyeti) * 0.85",
      "severity": "WARNING",
      "source": "Risk Yönetimi Standardı",
      "message": "Kredi miktarı toplam maliyetin %85'ini aşamaz, aşırı kaldıraç riski var."
    },
    {
      "condition": "aylik_kira_geliri * 12 < (alis_fiyati + rehab_maliyeti) * 0.05",
      "severity": "WARNING",
      "source": "Yatırım Getiri Standardı",
      "message": "Yıllık kira geliri toplam maliyetin %5'inden az, bu strateji karlı olmayabilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Hiçbir maliyet veya gelir kalemi negatif olamaz."
    },
    "kontrol_alis_fiyati": {
      "absolute_min": 1,
      "error_msg": "Alış fiyatı en az 1 ₺ olmalıdır."
    },
    "kontrol_kredi": {
      "check": "kredi_miktari > deger_artisi_sonrasi",
      "error_msg": "Kredi tutarı, mülkün değerinden yüksek olamaz."
    }
  },
  "standards": [
    "ISO 15686-1:2011",
    "ISO 31000:2018"
  ]
}
{
  "id": "emlak_vergisi",
  "name": "Emlak Vergisi Hesaplama",
  "description": "Belediyeye ödenmesi gereken yıllık emlak vergisini hesaplar.",
  "category": "Finans",
  "inputs": [
    {
      "id": "RayicBedel",
      "name": "Rayic Bedel",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 999999999
    },
    {
      "id": "VergiOrani",
      "name": "Vergi Oranı",
      "unit": "Binde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "YillikVergi",
      "name": "Yıllık Emlak Vergisi",
      "unit": "₺",
      "type": "number",
      "formula": "YillikVergi = RayicBedel * (VergiOrani / 1000)",
      "description": "Belediyeye ödenmesi gereken yıllık emlak vergisi tutarı"
    }
  ],
  "standards": [
    "ISO 14000",
    "Belediye Gelirleri Kanunu"
  ],
  "warnings": [
    {
      "condition": "RayicBedel <= 0",
      "severity": "WARNING",
      "source": "Belediye Gelirleri Kanunu",
      "message": "Rayic bedel sıfır veya negatif olamaz. Geçerli bir değer giriniz."
    },
    {
      "condition": "VergiOrani <= 0",
      "severity": "WARNING",
      "source": "Vergi Mevzuatı",
      "message": "Vergi oranı binde cinsinden pozitif olmalıdır (örneğin: 1, 2, 3)."
    },
    {
      "condition": "VergiOrani > 10",
      "severity": "WARNING",
      "source": "Vergi Mevzuatı",
      "message": "Vergi oranı binde 10'un üzerinde. Lütfen yerel yönetmelikleri kontrol ediniz."
    }
  ],
  "validations": [
    {
      "field": "negatif_hata",
      "absolute_min": 0,
      "error_msg": "Girdi değerleri negatif olamaz. Lütfen pozitif bir değer giriniz."
    }
  ]
}
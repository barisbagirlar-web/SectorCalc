{
  "id": "treynor_orani",
  "name": "Treynor Oranı Hesaplama",
  "category": "Finans",
  "description": "Sistematik risk (Beta) başına üretilen fazla getiriyi hesaplar",
  "inputs": [
    {
      "id": "PortfoyGetirisi",
      "name": "Portföy Getirisi",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -100,
      "absolute_max": 1000
    },
    {
      "id": "RisksizFaiz",
      "name": "Risksiz Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "Beta",
      "name": "Beta",
      "unit": "Sayı",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": -10,
      "absolute_max": 10
    }
  ],
  "outputs": [
    {
      "id": "Treynor",
      "name": "Treynor Oranı",
      "unit": "Sayı",
      "description": "Sistematik risk (Beta) başına üretilen fazla getiri"
    }
  ],
  "formulas": {
    "Treynor": "IF(Beta <= 0.0001, 0, (PortfoyGetirisi - RisksizFaiz) / MAX(0.0001, Beta)) // Treynor Oranı = (Portföy Getirisi - Risksiz Faiz) / Beta"
  },
  "warnings": [
    {
      "condition": "Beta <= 0",
      "severity": "WARNING",
      "source": "Finansal Analiz Standardı",
      "message": "Beta sıfır veya negatif; sistematik risk tanımsız veya ters yönlü, Treynor Oranı güvenilir değildir"
    },
    {
      "condition": "PortfoyGetirisi < -50",
      "severity": "WARNING",
      "source": "Uç Değer Kontrolü",
      "message": "Portföy getirisi aşırı negatif, hesaplama anlamsız olabilir"
    },
    {
      "condition": "(PortfoyGetirisi - RisksizFaiz) < -100",
      "severity": "WARNING",
      "source": "Finansal Tutarlılık",
      "message": "Fazla getiri çok düşük, portföy performansı ciddi şekilde negatif"
    }
  ],
  "validation": [
    {
      "field": "PortfoyGetirisi",
      "rules": {
        "required": true,
        "number": true,
        "min": -100,
        "max": 1000
      },
      "error_msg": "Portföy getirisi -100 ile 1000 arasında olmalıdır"
    },
    {
      "field": "RisksizFaiz",
      "rules": {
        "required": true,
        "number": true,
        "min": 0,
        "max": 100
      },
      "error_msg": "Risksiz faiz oranı 0 ile 100 arasında olmalıdır"
    },
    {
      "field": "Beta",
      "rules": {
        "required": true,
        "number": true,
        "min": -10,
        "max": 10
      },
      "error_msg": "Beta -10 ile 10 arasında olmalıdır"
    }
  ],
  "standards": [
    "ISO 31000:2018 Risk Yönetimi",
    "CFA Institute Performance Presentation Standards"
  ]
}
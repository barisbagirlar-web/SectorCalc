{
  "calc_id": "mortgage_repayment_table",
  "calc_name": "Mortgage Geri Ödeme Tablosu",
  "inputs": [
    {
      "id": "kredi",
      "name": "Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1000,
      "absolute_max": 100000000
    },
    {
      "id": "faiz",
      "name": "Yıllık Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 50
    },
    {
      "id": "vade",
      "name": "Vade",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 480
    },
    {
      "id": "donem",
      "name": "Sorgulanan Dönem",
      "unit": "Ay",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 480
    }
  ],
  "outputs": [
    {
      "id": "anapara_kismi",
      "name": "Anapara Kısmı",
      "unit": "₺",
      "standard": "ISO 22974"
    },
    {
      "id": "faiz_kismi",
      "name": "Faiz Kısmı",
      "unit": "₺",
      "standard": "ISO 22974"
    }
  ],
  "formulas": {
    "anapara_kismi": "IF(donem > vade, 0, ((kredi * (faiz/1200) * POW(1 + (faiz/1200), vade)) / (POW(1 + (faiz/1200), vade) - 1)) - ((kredi * (faiz/1200) * POW(1 + (faiz/1200), vade)) / (POW(1 + (faiz/1200), vade) - 1) - (kredi * (faiz/1200))) )",
    "faiz_kismi": "IF(donem > vade, 0, (kredi * (faiz/1200) * POW(1 + (faiz/1200), vade)) / (POW(1 + (faiz/1200), vade) - 1) - anapara_kismi)"
  },
  "warnings": [
    {
      "condition": "faiz > 30",
      "severity": "WARNING",
      "source": "ISO 22974",
      "message": "Faiz oranı %30'un üzerinde; piyasa dışı risk oluşabilir."
    },
    {
      "condition": "vade > 360",
      "severity": "WARNING",
      "source": "ISO 22974",
      "message": "Vade 30 yılı aşıyor; toplam maliyet çok yüksek olabilir."
    },
    {
      "condition": "donem > vade",
      "severity": "WARNING",
      "source": "ISO 22974",
      "message": "Sorgulanan dönem vadeyi aşıyor; sonuç sıfır olacaktır."
    }
  ],
  "validations": {
    "kredi": {
      "absolute_min": 1000,
      "error_msg": "Kredi tutarı en az 1.000 ₺ olmalıdır."
    },
    "faiz": {
      "absolute_min": 0.01,
      "error_msg": "Faiz oranı pozitif olmalıdır."
    },
    "vade": {
      "absolute_min": 1,
      "error_msg": "Vade en az 1 ay olmalıdır."
    },
    "donem": {
      "absolute_min": 1,
      "error_msg": "Dönem en az 1 ay olmalıdır."
    }
  },
  "standards": [
    "ISO 22974"
  ]
}
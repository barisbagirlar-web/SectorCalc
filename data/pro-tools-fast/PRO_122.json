{
  "id": "etsy_komisyon_hesaplama",
  "name": "Etsy Ücreti Hesaplama",
  "description": "Etsy platformunda satış başına ödenen toplam komisyonu (listeleme ücreti + işlem ücreti + ödeme işlem ücreti) hesaplar.",
  "inputs": [
    {
      "id": "satis",
      "name": "Satış Tutarı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "listeleme",
      "name": "Listeleme Ücreti",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "islem_yuzde",
      "name": "İşlem Ücreti Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "odeme_yuzde",
      "name": "Ödeme İşlem Ücreti Oranı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "kesinti",
      "name": "Toplam Kesinti",
      "unit": "TL",
      "description": "Etsy platformuna ödenen toplam komisyon (listeleme + işlem ücreti + ödeme işlem ücreti)"
    }
  ],
  "formulas": {
    "kesinti": "listeleme + (satis * islem_yuzde / 100) + (satis * odeme_yuzde / 100)"
  },
  "warnings": [
    {
      "condition": "satis <= 0",
      "severity": "WARNING",
      "source": "Etsy Politika",
      "message": "Satış tutarı sıfır veya negatif. Lütfen geçerli bir satış tutarı girin."
    },
    {
      "condition": "listeleme < 0",
      "severity": "WARNING",
      "source": "Etsy Politika",
      "message": "Listeleme ücreti negatif olamaz. Etsy sabit listeleme ücreti genellikle 0.20 USD civarındadır."
    },
    {
      "condition": "islem_yuzde > 10 || odeme_yuzde > 10",
      "severity": "WARNING",
      "source": "Etsy Politika",
      "message": "İşlem veya ödeme ücreti oranı tipik Etsy oranlarının (%6.5 işlem + %3-4 ödeme) üzerinde. Lütfen kontrol edin."
    }
  ],
  "validations": {
    "negatif_satis": {
      "absolute_min": 0,
      "error_msg": "Satış tutarı negatif olamaz."
    },
    "negatif_listeleme": {
      "absolute_min": 0,
      "error_msg": "Listeleme ücreti negatif olamaz."
    },
    "yuzde_araligi": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Yüzde değerleri 0-100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 80000-1"
  ]
}
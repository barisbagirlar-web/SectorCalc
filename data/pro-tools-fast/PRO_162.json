{
  "id": "medicare_prim",
  "name": "Medicare Prim Hesaplama",
  "description": "Gelire göre ayarlanmış aylık sağlık sigortası primi hesaplama aracı",
  "version": "1.0",
  "category": "Sigorta ve Finans",
  "inputs": [
    {
      "id": "yillik_gelir",
      "name": "Yıllık Gelir",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "baz_prim",
      "name": "Baz Prim",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "ek_oran",
      "name": "Ek Oran",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "esik",
      "name": "Eşik Gelir",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    }
  ],
  "outputs": [
    {
      "id": "prim",
      "name": "Prim",
      "unit": "TL",
      "description": "Gelire göre ayarlanmış aylık sağlık sigortası primi",
      "formula": "prim = baz_prim + MAX(0, (yillik_gelir - esik) * ek_oran / 100) // Eşik aşımına göre ek prim eklenir",
      "rounded": 2
    }
  ],
  "warnings": [
    {
      "condition": "yillik_gelir > 1000000",
      "severity": "WARNING",
      "source": "Medicare Protokolü",
      "message": "Yıllık gelir 1.000.000 TL üzerinde, ek prim oranı yüksek olabilir"
    },
    {
      "condition": "ek_oran > 50",
      "severity": "WARNING",
      "source": "Medicare Protokolü",
      "message": "Ek prim oranı %50'yi aşıyor, beklenmedik yüksek prim oluşabilir"
    },
    {
      "condition": "esik > yillik_gelir * 1.5",
      "severity": "WARNING",
      "source": "Medicare Protokolü",
      "message": "Eşik gelir, yıllık gelirin 1.5 katından fazla; prim baz prim seviyesinde kalacak"
    },
    {
      "condition": "baz_prim < 100",
      "severity": "WARNING",
      "source": "Medicare Standardı",
      "message": "Baz prim 100 TL altında, geçerli bir prim aralığı değil"
    }
  ],
  "validation": {
    "negatif_gelir": {
      "absolute_min": 0,
      "error_msg": "Yıllık gelir negatif olamaz"
    },
    "negatif_baz_prim": {
      "absolute_min": 0,
      "error_msg": "Baz prim negatif olamaz"
    },
    "negatif_ek_oran": {
      "absolute_min": 0,
      "error_msg": "Ek oran negatif olamaz"
    },
    "ek_oran_asimi": {
      "absolute_max": 100,
      "error_msg": "Ek oran %100'ü geçemez"
    },
    "negatif_esik": {
      "absolute_min": 0,
      "error_msg": "Eşik gelir negatif olamaz"
    }
  },
  "standards": [
    "Medicare Protokolü v2.1",
    "ISO 31000 (Risk Yönetimi)",
    "Türkiye Sağlık Sigortası Standardı"
  ]
}
{
  "id": "borc_gelir_orani_dti",
  "name": "Borç-Gelir Oranı (DTI)",
  "category": "finans",
  "description": "Gelirin borç ödemelerine ayrılan yüzdesi",
  "inputs": [
    {
      "id": "AylikBorc",
      "name": "Aylık Borç",
      "unit": "₺",
      "type": "number",
      "required": true,
      "absolute_min": 0,
      "absolute_max": 1000000,
      "default": 0,
      "confidence_label": "KESİN"
    },
    {
      "id": "BrutGelir",
      "name": "Brüt Gelir",
      "unit": "₺",
      "type": "number",
      "required": true,
      "absolute_min": 0,
      "absolute_max": 1000000,
      "default": 1,
      "confidence_label": "KESİN"
    }
  ],
  "outputs": [
    {
      "id": "DTI",
      "name": "Borç-Gelir Oranı",
      "unit": "%",
      "description": "Gelirin borç ödemelerine ayrılan yüzdesi",
      "formula": "DTI = (AylikBorc / MAX(1, BrutGelir)) * 100 // DTI hesaplaması",
      "output_variable": "DTI",
      "absolute_min": 0,
      "absolute_max": 1000,
      "warning_high": 43,
      "warning_high_severity": "WARNING"
    }
  ],
  "warnings": [
    {
      "condition": "AylikBorc > BrutGelir",
      "severity": "WARNING",
      "source": "ISO 20022 Finansal Sağlık Standardı",
      "message": "Aylık borç, brüt geliri aşıyor! DTI %100'ün üzerinde. Kredi başvuruları genellikle reddedilir."
    },
    {
      "condition": "DTI > 43",
      "severity": "WARNING",
      "source": "CFPB (Tüketici Finansal Koruma Bürosu) Kriteri",
      "message": "DTI %43'ün üzerinde! Nitelikli Mortgage kredisi için sınır aşıldı. Acil mali danışmanlık önerilir."
    },
    {
      "condition": "DTI > 36",
      "severity": "INFO",
      "source": "Genel Kabul Görmüş Bankacılık Standardı",
      "message": "DTI %36'yı geçiyor! Borç yükü sınırda. Ek kredi kullanımında dikkatli olunmalı."
    },
    {
      "condition": "DTI < 0",
      "severity": "ERROR",
      "source": "Sistem Geçerlilik Kontrolü",
      "message": "DTI negatif olamaz! Borç veya gelir bilgilerini kontrol edin."
    }
  ],
  "validations": {
    "negatif_gelir": {
      "input_id": "BrutGelir",
      "absolute_min": 0,
      "error_msg": "Brüt gelir negatif olamaz (0 veya daha büyük olmalı)."
    },
    "negatif_borc": {
      "input_id": "AylikBorc",
      "absolute_min": 0,
      "error_msg": "Aylık borç negatif olamaz (0 veya daha büyük olmalı)."
    },
    "sifir_gelir": {
      "input_id": "BrutGelir",
      "absolute_min": 1,
      "error_msg": "Brüt gelir 0 olamaz (en az 1 ₺ girilmeli)."
    }
  },
  "standards": [
    "ISO 20022"
  ]
}
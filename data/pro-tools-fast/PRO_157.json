{
  "id": "hayat_sigortasi_ihtiyaci",
  "name": "Hayat Sigortası İhtiyacı",
  "description": "Ailenin geleceğini güvenceye almak için gerekli teminat tutarını hesaplar.",
  "inputs": [
    {
      "id": "yillik_gelir",
      "name": "Yıllık Gelir",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999,
      "step": 1000
    },
    {
      "id": "bagimli_sayisi",
      "name": "Bağımlı Sayısı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 50,
      "step": 1
    },
    {
      "id": "borclar",
      "name": "Borçlar Toplamı",
      "unit": "TL",
      "type": "number",
      "required": false,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999,
      "step": 1000
    },
    {
      "id": "birikim",
      "name": "Mevcut Birikim",
      "unit": "TL",
      "type": "number",
      "required": false,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999,
      "step": 1000
    }
  ],
  "formula": "Ihtiyac = (yillik_gelir * 10 * bagimli_sayisi) + borclar - birikim",
  "outputs": [
    {
      "id": "ihtiyac",
      "name": "Gerekli Teminat Tutarı",
      "unit": "TL",
      "description": "Ailenin geleceğini güvenceye almak için gerekli teminat"
    }
  ],
  "standards": [
    "ISO 14000"
  ],
  "validations": {
    "negatif_bakiye": {
      "condition": "ihtiyac < 0",
      "error_msg": "Gerekli teminat tutarı negatif olamaz. Birikim borç ve gelir çarpanını aşıyor."
    },
    "yillik_gelir_sifir": {
      "condition": "yillik_gelir === 0",
      "error_msg": "Yıllık gelir sıfır olamaz. Lütfen gelir bilgisi giriniz."
    }
  },
  "smart_warnings": [
    {
      "condition": "bagimli_sayisi > 5",
      "severity": "WARNING",
      "source": "Aile Planlaması Standardı",
      "message": "Bağımlı sayısı 5'ten fazla. Teminat tutarınız çok yüksek olabilir, ihtiyaç analizi yapmanız önerilir."
    },
    {
      "condition": "borclar > yillik_gelir * 10",
      "severity": "WARNING",
      "source": "Finansal Oran Standardı",
      "message": "Borçlar yıllık gelirin 10 katından fazla. Yüksek borçluluk oranı, teminat yetersiz kalabilir."
    },
    {
      "condition": "ihtiyac > 10000000",
      "severity": "WARNING",
      "source": "Piyasa Pratiği",
      "message": "Hesaplanan teminat 10 milyon TL'yi aşıyor. Bu tutar piyasa standartlarının üzerinde olabilir, sigorta şirketi ile görüşün."
    }
  ]
}
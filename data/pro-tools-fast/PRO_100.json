{
  "id": "musteri_omur_boyu_degeri_clv",
  "name": "Müşteri Yaşam Boyu Değeri (CLV)",
  "description": "Müşterinin ömrü boyunca kazandırdığı net kârı hesaplar.",
  "category": "finans",
  "inputs": {
    "ortalama_siparis_tutari": {
      "id": "ortalama_siparis_tutari",
      "name": "Ortalama Sipariş Tutarı",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 1000000,
      "step": 0.01
    },
    "siparis_sikligi": {
      "id": "siparis_sikligi",
      "name": "Sipariş Sıklığı",
      "unit": "Adet/Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 365,
      "step": 1
    },
    "musteri_omru": {
      "id": "musteri_omru",
      "name": "Müşteri Ömrü",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 50,
      "step": 1
    },
    "kar_marji": {
      "id": "kar_marji",
      "name": "Kâr Marjı",
      "unit": "Yüzde",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100,
      "step": 0.1
    }
  },
  "outputs": {
    "clv": {
      "id": "clv",
      "name": "Müşteri Yaşam Boyu Değeri",
      "unit": "TL",
      "type": "number",
      "decimal_places": 2,
      "description": "Müşterinin ömrü boyunca kazandırdığı net kâr"
    }
  },
  "formulas": {
    "clv": "ortalama_siparis_tutari * siparis_sikligi * musteri_omru * (kar_marji / 100)"
  },
  "smart_warnings": [
    {
      "condition": "kar_marji > 80",
      "severity": "WARNING",
      "source": "ISO 9001 Kalite Yönetimi",
      "message": "Kâr marjı %80'den yüksek; gerçekçi olmayan tahmin riski, sektör ortalamalarını kontrol edin."
    },
    {
      "condition": "musteri_omru > 20",
      "severity": "WARNING",
      "source": "ISO 31000 Risk Yönetimi",
      "message": "Müşteri ömrü 20 yıldan fazla; uzun vadeli bağlılık verisi doğrulanmalı, aşırı iyimserlik riski."
    },
    {
      "condition": "ortalama_siparis_tutari * siparis_sikligi * musteri_omru > 5000000",
      "severity": "WARNING",
      "source": "ISO 31000 Risk Yönetimi",
      "message": "Tahmini toplam ciro 5 milyon TL'yi aşıyor; bu değer olağan dışı, girdileri tekrar gözden geçirin."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Negatif değer kabul edilmez; lütfen pozitif bir sayı girin."
    },
    "sifir_hata": {
      "absolute_min": 0.01,
      "error_msg": "Sıfır değeri kabul edilmez; en az 0.01 girin."
    }
  },
  "standards": [
    "ISO 9001:2015",
    "ISO 31000:2018"
  ]
}
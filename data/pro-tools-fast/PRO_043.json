{
  "id": "etf_getirisi",
  "name": "ETF Getirisi Hesaplama",
  "description": "Yönetim ücreti düşülmüş net ETF getirisi hesaplar.",
  "category": "finans",
  "inputs": [
    {
      "id": "AlisFiyati",
      "name": "Alış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0.01,
      "absolute_max": 99999
    },
    {
      "id": "SatisFiyati",
      "name": "Satış Fiyatı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "Temettu",
      "name": "Temettü",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "GiderOrani",
      "name": "Gider Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "NetGetiri",
      "name": "Net Getiri",
      "unit": "%",
      "description": "Yönetim ücreti düşülmüş net ETF getirisi",
      "type": "number",
      "formula": "NetGetiri = ((SatisFiyati + Temettu - AlisFiyati) / MAX(1, AlisFiyati) * 100) - GiderOrani // Brüt getiriden gider oranı düşülür"
    }
  ],
  "standards": [
    "ISO 8000-100",
    "ISO 22222"
  ],
  "warnings": [
    {
      "condition": "AlisFiyati <= 0",
      "severity": "ERROR",
      "source": "ISO 8000-100",
      "message": "Alış fiyatı sıfır veya negatif olamaz."
    },
    {
      "condition": "SatisFiyati < 0",
      "severity": "WARNING",
      "source": "ISO 22222",
      "message": "Satış fiyatı negatif girildi, kontrol edin."
    },
    {
      "condition": "GiderOrani > 10",
      "severity": "WARNING",
      "source": "ISO 22222",
      "message": "Gider oranı %10'un üzerinde, yüksek maliyet uyarısı."
    },
    {
      "condition": "Temettu < 0",
      "severity": "WARNING",
      "source": "ISO 8000-100",
      "message": "Temettü negatif olamaz, değer sıfır olarak kabul edildi."
    },
    {
      "condition": "SatisFiyati < AlisFiyati",
      "severity": "WARNING",
      "source": "ISO 22222",
      "message": "Satış fiyatı alış fiyatından düşük, zarar durumu oluşabilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Alış fiyatı, satış fiyatı ve temettü negatif olamaz."
    },
    "sifir_alis_hata": {
      "absolute_min": 0.01,
      "error_msg": "Alış fiyatı sıfırdan büyük olmalıdır."
    }
  }
}
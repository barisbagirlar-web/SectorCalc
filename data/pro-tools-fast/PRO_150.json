{
  "id": "hurda_orani_optimizasyon",
  "name": "Hurda Oranı Optimizasyon",
  "description": "Hatalı üretimden kaynaklanan toplam finansal kaybı ve hurda oranını hesaplar.",
  "category": "Kalite ve Maliyet",
  "inputs": [
    {
      "id": "Uretim",
      "name": "Üretim Miktarı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000000
    },
    {
      "id": "Hurda",
      "name": "Hurda Miktarı",
      "unit": "Adet",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1000000
    },
    {
      "id": "BirimMaliyet",
      "name": "Birim Maliyet",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    }
  ],
  "outputs": [
    {
      "id": "Kayip",
      "name": "Toplam Finansal Kayıp",
      "unit": "TL",
      "description": "Hatalı üretimden kaynaklanan toplam finansal kayıp"
    },
    {
      "id": "Oran",
      "name": "Hurda Oranı",
      "unit": "%",
      "description": "Üretime göre hurda yüzdesi"
    }
  ],
  "formulas": {
    "Oran": "Oran = (Hurda / MAX(1, Uretim)) * 100",
    "Kayip": "Kayip = Hurda * BirimMaliyet"
  },
  "smart_warnings": [
    {
      "condition": "Oran > 10",
      "severity": "WARNING",
      "source": "ISO 9001:2015 Kalite Yönetimi",
      "message": "Hurda oranı %10'u aştı. Üretim süreci acilen gözden geçirilmelidir."
    },
    {
      "condition": "Hurda > 50",
      "severity": "WARNING",
      "source": "ISO 14001 Çevre Yönetimi",
      "message": "Yüksek hurda miktarı çevresel etkiyi artırmaktadır. Atık yönetimi ve süreç iyileştirme önerilir."
    },
    {
      "condition": "Kayip > 10000",
      "severity": "WARNING",
      "source": "Yalın Üretim Standardı",
      "message": "Finansal kayıp 10.000 TL'yi geçti. Kök neden analizi yapılmalı ve düzeltici önlem alınmalıdır."
    },
    {
      "condition": "Uretim < 10",
      "severity": "WARNING",
      "source": "İstatistiksel Proses Kontrol",
      "message": "Üretim miktarı çok düşük. Oran anlamlı olmayabilir, en az 10 adet üretim önerilir."
    }
  ],
  "validation": {
    "negatif_hata": {
      "absolute_min": 0,
      "error_msg": "Girdi değerleri sıfırdan küçük olamaz."
    },
    "Uretim_sifir": {
      "absolute_min": 0,
      "error_msg": "Üretim miktarı sıfır olamaz."
    }
  },
  "standards": [
    "ISO 9001:2015",
    "ISO 14001",
    "Yalın Üretim"
  ]
}
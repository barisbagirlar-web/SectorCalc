{
  "id": "tam_hayat_sigortasi",
  "name": "Tam Hayat Sigortası Hesaplama",
  "description": "Poliçenin zamanla biriken yatırım değerini (nakit değer) hesaplar.",
  "inputs": [
    {
      "id": "yillik_prim",
      "name": "Yıllık Prim",
      "unit": "TL",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999
    },
    {
      "id": "faiz",
      "name": "Faiz Oranı",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    },
    {
      "id": "yil",
      "name": "Yıl",
      "unit": "Yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "nakit_deger",
      "name": "Nakit Değer",
      "unit": "TL",
      "description": "Poliçenin zamanla biriken yatırım değeri"
    }
  ],
  "formulas": [
    "nakit_deger = yillik_prim * (((1 + (faiz/100))^yil - 1) / MAX(0.0001, (faiz/100)))"
  ],
  "warnings": [
    {
      "condition": "faiz == 0",
      "severity": "WARNING",
      "source": "ISO 19760",
      "message": "Faiz oranı sıfır olduğunda nakit değer yalnızca prim toplamına eşit olur, yatırım getirisi oluşmaz."
    },
    {
      "condition": "yil > 50",
      "severity": "WARNING",
      "source": "ISO 19760",
      "message": "50 yıldan uzun vadeli poliçelerde enflasyon ve faiz riski artar, değerleme periyodik olarak kontrol edilmelidir."
    },
    {
      "condition": "yillik_prim > 50000",
      "severity": "WARNING",
      "source": "ISO 19760",
      "message": "Yüksek prim tutarları için ek teminat ve vergi yükümlülükleri doğabilir, mali müşavir ile değerlendirin."
    }
  ],
  "validation": {
    "yillik_prim": {
      "absolute_min": 0,
      "error_msg": "Yıllık prim sıfır veya pozitif olmalıdır."
    },
    "faiz": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Faiz oranı %0 ile %100 arasında olmalıdır."
    },
    "yil": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Yıl 0 ile 100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 19760"
  ]
}
{
  "inputs": [
    {
      "id": "mulk_degeri",
      "name": "Mülk Değeri",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "kalan_borc",
      "name": "Kalan Borç",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "yeni_kredi",
      "name": "Yeni Kredi Tutarı",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "masraf",
      "name": "Masraflar (Dosya, Eksper, Tapu, İpotek)",
      "unit": "₺",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 99999999
    },
    {
      "id": "oran_siniri",
      "name": "Mülk Değerine Göre Maksimum Kredi Oranı (%)",
      "unit": "%",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 100
    }
  ],
  "outputs": [
    {
      "id": "nakit_cikis",
      "name": "Nakit Çıkış (Net Ele Geçen Tutar)",
      "unit": "₺",
      "confidence_label": "KESİN"
    },
    {
      "id": "maksimum_izinli_kredi",
      "name": "Maksimum İzinli Kredi Tutarı (Oran Sınırına Göre)",
      "unit": "₺",
      "confidence_label": "KESİN",
      "description": "Oran sınırına göre alınabilecek maksimum kredi miktarı"
    }
  ],
  "calculations": {
    "nakit_cikis": "MAX(0, yeni_kredi - kalan_borc - masraf)",
    "maksimum_izinli_kredi": "mulk_degeri * (oran_siniri / 100)"
  },
  "warnings": [
    {
      "condition": "nakit_cikis < 0",
      "severity": "WARNING",
      "source": "Finansal Uygunluk Standardı",
      "message": "Nakit çıkış negatif hesaplanıyor. Kalan borç ve masraflar yeni krediyi aşmaktadır; refinansman işlemi ek ödeme gerektirir."
    },
    {
      "condition": "yeni_kredi > maksimum_izinli_kredi",
      "severity": "WARNING",
      "source": "BDDK & Bankacılık Düzenleme Standardı",
      "message": "Talep edilen kredi tutarı, mülk değerine göre izin verilen maksimum oranı aşmaktadır. Limit kontrolü yapın."
    },
    {
      "condition": "kalan_borc > mulk_degeri * 0.8",
      "severity": "WARNING",
      "source": "Risk Yönetimi Standardı",
      "message": "Kalan borç mülk değerinin %80'ini aşmaktadır. Yüksek kaldıraç riski bulunuyor."
    }
  ],
  "validation": {
    "mulk_degeri": {
      "absolute_min": 1,
      "error_msg": "Mülk değeri 0 veya negatif olamaz."
    },
    "kalan_borc": {
      "absolute_min": 0,
      "error_msg": "Kalan borç negatif olamaz."
    },
    "yeni_kredi": {
      "absolute_min": 0,
      "error_msg": "Yeni kredi tutarı negatif olamaz."
    },
    "masraf": {
      "absolute_min": 0,
      "error_msg": "Masraf tutarı negatif olamaz."
    },
    "oran_siniri": {
      "absolute_min": 0,
      "absolute_max": 100,
      "error_msg": "Oran sınırı %0 ile %100 arasında olmalıdır."
    }
  },
  "standards": [
    "ISO 27001 (Veri Güvenliği)",
    "BDDK Kredi Düzenlemeleri",
    "Finansal Risk Yönetimi Standardı (FRMS)"
  ]
}
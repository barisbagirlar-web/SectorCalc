{
  "id": "health_fitness_v02",
  "name": "Pratik Sağlık ve Fitness Değerlendirme",
  "description": "BMI, Harris-Benedict bazal metabolizma, vücut yağ oranı (US Navy), kalori ihtiyacı, hedef kalp atışı, maksimum oksijen tüketimi (VO2max), vücut kitle indeksi sınıflaması ve günlük protein ihtiyacı hesaplar.",
  "version": "1.0",
  "category": "health_fitness",
  "tags": [
    "bmi",
    "bmr",
    "body_fat",
    "calorie",
    "heart_rate",
    "vo2max",
    "protein",
    "index"
  ],
  "inputs": [
    {
      "id": "cinsiyet",
      "name": "Cinsiyet",
      "unit": "Erkek=1, Kadın=0",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 1,
      "step": 1
    },
    {
      "id": "yas",
      "name": "Yaş",
      "unit": "yıl",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 18,
      "absolute_max": 100,
      "step": 1
    },
    {
      "id": "boy_cm",
      "name": "Boy (cm)",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 100,
      "absolute_max": 250,
      "step": 0.1
    },
    {
      "id": "kilo_kg",
      "name": "Kilo (kg)",
      "unit": "kg",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 30,
      "absolute_max": 300,
      "step": 0.1
    },
    {
      "id": "boyun_cm",
      "name": "Boyun Çevresi (cm)",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 20,
      "absolute_max": 60,
      "step": 0.1
    },
    {
      "id": "bel_cm",
      "name": "Bel Çevresi (cm, erkek için)",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 40,
      "absolute_max": 200,
      "step": 0.1
    },
    {
      "id": "kalca_cm",
      "name": "Kalça Çevresi (cm, kadın için; erkekte 0 girin)",
      "unit": "cm",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 0,
      "absolute_max": 200,
      "step": 0.1
    },
    {
      "id": "aktivite_faktoru",
      "name": "Aktivite Faktörü (1.2-2.0)",
      "unit": "",
      "type": "number",
      "required": true,
      "confidence_label": "KESİN",
      "absolute_min": 1.2,
      "absolute_max": 2,
      "step": 0.1
    },
    {
      "id": "maks_kalp_atis",
      "name": "Maksimum Kalp Atışı (isteğe bağlı, boşsa tahmini)",
      "unit": "atım/dk",
      "type": "number",
      "required": false,
      "confidence_label": "TAHMİNİ",
      "absolute_min": 120,
      "absolute_max": 220,
      "step": 1
    }
  ],
  "outputs": [
    {
      "id": "vki",
      "name": "Vücut Kitle İndeksi (BMI)",
      "unit": "kg/m²",
      "type": "number",
      "decimals": 1,
      "formula": "kilo_kg / POW(boy_cm / 100, 2)"
    },
    {
      "id": "bazal_metabolizma",
      "name": "Bazal Metabolizma Hızı (Harris-Benedict)",
      "unit": "kcal/gün",
      "type": "number",
      "decimals": 0,
      "formula": "IF(cinsiyet == 1, 66.5 + (13.75 * kilo_kg) + (5.003 * boy_cm) - (6.75 * yas), 655.1 + (9.563 * kilo_kg) + (1.850 * boy_cm) - (4.676 * yas))"
    },
    {
      "id": "vucut_yag_orani",
      "name": "Vücut Yağ Oranı (US Navy Yöntemi)",
      "unit": "%",
      "type": "number",
      "decimals": 1,
      "formula": "IF(cinsiyet == 1, 86.010 * LOG10(bel_cm - boyun_cm) - 70.041 * LOG10(boy_cm) + 36.76, 163.205 * LOG10(bel_cm + kalca_cm - boyun_cm) - 97.684 * LOG10(boy_cm) - 78.387)"
    },
    {
      "id": "gunluk_kalori_ihtiyaci",
      "name": "Günlük Kalori İhtiyacı",
      "unit": "kcal/gün",
      "type": "number",
      "decimals": 0,
      "formula": "bazal_metabolizma * aktivite_faktoru"
    },
    {
      "id": "hedef_kalp_atis",
      "name": "Hedef Kalp Atışı (max'ın %60-80'i)",
      "unit": "atım/dk",
      "type": "number",
      "decimals": 0,
      "formula": "IF(maks_kalp_atis > 0, maks_kalp_atis, 220 - yas) * 0.7"
    },
    {
      "id": "vo2max_tahmini",
      "name": "VO2max Tahmini (Cooper testi uyarlaması)",
      "unit": "ml/kg/dk",
      "type": "number",
      "decimals": 1,
      "formula": "MAX(15, 483 / (1 + EXP(1.0 * (yas - 42) / 10))) * IF(cinsiyet == 1, 1.0, 0.85)"
    },
    {
      "id": "vki_sinif",
      "name": "BMI Sınıflama",
      "unit": "kategori",
      "type": "string",
      "formula": "IF(vki < 18.5, 'Zayıf', IF(vki < 25, 'Normal', IF(vki < 30, 'Fazla Kilolu', IF(vki < 35, 'Obez 1. Derece', IF(vki < 40, 'Obez 2. Derece', 'Aşırı Obez')))))"
    },
    {
      "id": "gunluk_protein_ihtiyaci",
      "name": "Günlük Protein İhtiyacı (sedanter-min, sporcu-max)",
      "unit": "g",
      "type": "number",
      "decimals": 0,
      "formula": "kilo_kg * IF(aktivite_faktoru < 1.5, 0.8, 1.6)"
    }
  ],
  "warnings": [
    {
      "condition": "vki > 40",
      "severity": "WARNING",
      "source": "WHO Standardı",
      "message": "Aşırı obezite sınıfı: tıbbi değerlendirme önerilir."
    },
    {
      "condition": "vki < 16.5",
      "severity": "WARNING",
      "source": "WHO Standardı",
      "message": "İleri derecede zayıflık: sağlık kontrolü gerekli."
    },
    {
      "condition": "vucut_yag_orani > 30 && cinsiyet == 1",
      "severity": "WARNING",
      "source": "Amerikan Spor Hekimliği Koleji",
      "message": "Erkeklerde %30 üzeri vücut yağı yüksek risk grubu."
    },
    {
      "condition": "vucut_yag_orani > 40 && cinsiyet == 0",
      "severity": "WARNING",
      "source": "Amerikan Spor Hekimliği Koleji",
      "message": "Kadınlarda %40 üzeri vücut yağı yüksek risk grubu."
    },
    {
      "condition": "yas > 65 && aktivite_faktoru < 1.3",
      "severity": "WARNING",
      "source": "Halk Sağlığı Genel Müdürlüğü",
      "message": "65 yaş üstü ve düşük aktivite: sarkopeni riski, hafif egzersiz önerilir."
    }
  ],
  "validation": [
    {
      "field": "boy_cm",
      "absolute_min": 100,
      "absolute_max": 250,
      "error_msg": "Boy 100-250 cm arasında olmalıdır."
    },
    {
      "field": "kilo_kg",
      "absolute_min": 30,
      "absolute_max": 300,
      "error_msg": "Kilo 30-300 kg arasında olmalıdır."
    },
    {
      "field": "yas",
      "absolute_min": 18,
      "absolute_max": 100,
      "error_msg": "Yaş 18-100 arasında olmalıdır."
    },
    {
      "field": "boyun_cm",
      "absolute_min": 20,
      "absolute_max": 60,
      "error_msg": "Boyun çevresi 20-60 cm arasında olmalıdır."
    },
    {
      "field": "bel_cm",
      "absolute_min": 40,
      "absolute_max": 200,
      "error_msg": "Bel çevresi 40-200 cm arasında olmalıdır."
    },
    {
      "field": "aktivite_faktoru",
      "absolute_min": 1.2,
      "absolute_max": 2,
      "error_msg": "Aktivite faktörü 1.2-2.0 arasında olmalıdır."
    }
  ],
  "standards": [
    "WHO BMI Classification",
    "Harris-Benedict Equation",
    "US Navy Body Fat Protocol",
    "ACSM Guidelines",
    "ISO 8996:2004 (Ergonomics - Metabolic rate)"
  ],
  "language": "tr",
  "metabolic_reference": "ISO 8996:2004"
}
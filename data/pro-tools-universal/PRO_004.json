  "standards": [
    {
      "id": "PRO_004",
      "code": "VDI 2230:2015 Part 1",
      "name": "VDI 2230 Bolted Joint — Tightening Torque, Preload Loss & Fatigue Safety Factor",
      "description": "VDI 2230 Bolted Joint — Tightening Torque, Preload Loss & Fatigue Safety Factor — Mechanical Design, Bolted Connections",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "out_1",
          "expression": "const A_s = {M6:20.1, M8:36.6, M10:58.0, M12:84.3, M16:157, M20:245, M24:353, M30:561}[bolt_size]; const Rp02 = {\"8.8\":640, \"10.9\":900, \"12.9\":1080}[property_class]; F_proof_kn = A_s * Rp02 / 1000   // [kN, mm²] Bolt Stress Area & Proof Load Reference: ISO 898-1:2013 — proof load = A_s × Rp0.2",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F2",
          "output": "FM_kn",
          "expression": "F_proof_kn * utilisation_pct / 100",
          "unit": {
            "ref": "kN"
          },
          "reference": "VDI 2230 §5.3.1 — F_M = R_p0.2 × A_s × ν_A",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "out_3",
          "expression": "const d = parseFloat(bolt_size.replace('M','')); const p = {M6:1.0,M8:1.25,M10:1.5,M12:1.75,M16:2.0,M20:2.5,M24:3.0,M30:3.5}[bolt_size]; MA_Nm = FM_kn * 1000 * (p/(2*Math.PI) + mu_friction * d * 0.583 + mu_friction * d * 0.5) / 1000   // [N·m] Tightening Torque (M_A) — Approximate Reference: VDI 2230 Eq.(167) — M_A = F_M(p/2π + μ_G·d_2·0.58 + μ_K·D_Km/2)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F4",
          "output": "FVmin_kn",
          "expression": "FM_kn * (1 - preload_loss_pct / 100) - phi_force_ratio * FA_kn",
          "unit": {
            "ref": "kN"
          },
          "reference": "VDI 2230 §5.4.1 — F_Vmin = F_M(1-f_Z) - Φ·F_A",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "SA",
          "expression": "FVmin_kn / ((1 - phi_force_ratio) * FA_kn)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "VDI 2230 §5.4.2 — S_A ≥ 1.2 for reliable joint",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "dFA_kn",
          "expression": "phi_force_ratio * FA_kn; sigma_a_mpa = dFA_kn * 1000 / A_s",
          "unit": {
            "ref": "MPa"
          },
          "reference": "VDI 2230 §6 — fatigue amplitude σ_a = Φ·F_A/A_s",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "VDI 2230:2015 Part 1",
          "condition": "sigma_a_mpa > 50",
          "message": "Bolt fatigue amplitude > 50 MPa: high fatigue loading — check against VDI 2230 Haigh diagram; apply thread-rolling (fatigue limit improvement ~30%) or increase bolt diameter"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "VDI 2230:2015 Part 1",
          "condition": "mu_friction < 0.08",
          "message": "Very low friction coefficient: self-loosening risk in vibration environments — evaluate NORD-LOCK washers or anaerobic adhesive per VDI 2230 §3.5"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "VDI 2230:2015 Part 1",
          "condition": "property_class === '12.9' && mu_friction < 0.10",
          "message": "12.9 class with low friction: hydrogen embrittlement risk in acidic environments — verify plating and service environment compatibility per ISO 4042"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "VDI 2230:2015 Part 1",
          "condition": "preload_loss_pct > 15",
          "message": "High embedding loss (>15%): rough or soft interface — machine mating surfaces or add hardened washer to reduce embedding; re-torque protocol recommended after 48h"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "VDI 2230:2015 Part 1",
          "condition": "utilisation_pct < 70",
          "message": "Low utilisation (<70%): bolt is underloaded — susceptible to fatigue and loosening; increase preload per VDI 2230 §5.3 or reduce to smaller bolt diameter"
        }
      ],

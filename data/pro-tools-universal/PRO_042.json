  "standards": [
    {
      "id": "PRO_042",
      "code": "AISC 360-22 Chapters F, G",
      "name": "Structural Steel Beam — Combined Bending, Shear & Lateral-Torsional Buckling Check",
      "description": "Structural Steel Beam — Combined Bending, Shear & Lateral-Torsional Buckling Check — Structural Engineering, Steel Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "M_p_knm",
          "expression": "Z_x_cm3 * 1e-6 * Fy_mpa * 1000",
          "unit": {
            "ref": "kNm"
          },
          "reference": "AISC 360-22 F2-1 / EC3 §6.2.5",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "M_n_knm",
          "expression": "(Lb_m <= Lp_m) ? M_p_knm : (Lb_m >= Lr_m) ? (0.877 * Math.PI^2 * 200000 / ((Lb_m*1000)^2) * S_x_cm3 * 1e-6 * 1000) : (M_p_knm - (M_p_knm - 0.7*Fy_mpa*S_x_cm3*1e-6*1000) * (Lb_m - Lp_m)/(Lr_m - Lp_m))",
          "unit": {
            "ref": "kNm"
          },
          "reference": "AISC 360-22 F2-2 (plastic), F2-3 (inelastic LTB), F2-4 (elastic LTB)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "phi_Mn_knm",
          "expression": "0.9 * M_n_knm",
          "unit": {
            "ref": "kNm"
          },
          "reference": "AISC 360-22 F1 — φ_b = 0.90",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "V_n_kn",
          "expression": "0.6 * Fy_mpa * Aw_cm2 * 1e-4 * 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "AISC 360-22 G2-1 — web shear yielding (C_v1 = 1.0 for compact web)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "phi_Vn_kn",
          "expression": "1.0 * V_n_kn",
          "unit": {
            "ref": "kN"
          },
          "reference": "AISC 360-22 G1 — φ_v = 1.0 for rolled I-sections",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "DCR_moment",
          "expression": "M_demand_knm / phi_Mn_knm; DCR_shear = V_demand_kn / phi_Vn_kn; DCR_combined = Math.max(DCR_moment, DCR_shear)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AISC 360-22 — demand-capacity ratio",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "AISC 360-22 Chapters F, G",
          "condition": "DCR_combined > 1.0",
          "message": "Section overstressed: structural failure mode risk — do not proceed to fabrication without redesign"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "AISC 360-22 Chapters F, G",
          "condition": "Lb_m > Lr_m",
          "message": "Unbraced length in elastic LTB zone: significant capacity reduction — add lateral restraints at midspan"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "AISC 360-22 Chapters F, G",
          "condition": "DCR_moment > 0.85 && Lb_m > Lp_m",
          "message": "High bending utilization with LTB active: consider intermediate bracing to restore full plastic capacity"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "AISC 360-22 Chapters F, G",
          "condition": "Fy_mpa > 450 && Lb_m > 3",
          "message": "High-strength steel with long unbraced length: LTB controls over yielding — bracing at L_p intervals mandatory"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "AISC 360-22 Chapters F, G",
          "condition": "Z_x_cm3 / S_x_cm3 > 1.20",
          "message": "High shape factor (> 1.20): significant plastic reserve — verify section compactness per AISC Table B4.1b"
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "AISC 360-22 Chapters F, G",
          "condition": "DCR_shear > 0.7 && DCR_moment > 0.7",
          "message": "High combined loading: check shear-moment interaction per AISC 360-22 G2 for non-compact webs"
        }
      ],

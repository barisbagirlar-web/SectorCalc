  "standards": [
    {
      "id": "PRO_097",
      "code": "ISO 68-1:1998",
      "name": "CNC Thread Milling & Tapping — Tap Drill Diameter, Helix Angle, Lead & Cutting Parameters",
      "description": "CNC Thread Milling & Tapping — Tap Drill Diameter, Helix Angle, Lead & Cutting Parameters — CNC Machining, Threading Operations",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "tap_drill_mm, pitch_mm",
          "expression": "const TH = {M6:{D:6,p:1.0,d1:4.917,d2:5.350}, M8:{D:8,p:1.25,d1:6.647,d2:7.188}, M10:{D:10,p:1.5,d1:8.376,d2:9.026}, M12:{D:12,p:1.75,d1:10.106,d2:10.863}, M16:{D:16,p:2.0,d1:13.835,d2:14.701}, M20:{D:20,p:2.5,d1:17.294,d2:18.376}, M24:{D:24,p:3.0,d1:20.752,d2:22.051}, M30:{D:30,p:3.5,d1:26.211,d2:27.727}}; const t=TH[thread_designation]; nominal_D=t.D; pitch_mm=t.p; d1_mm=t.d1; d2_mm=t.d2; tap_drill_mm = d1_mm + (thread_tolerance_class==='7H' ? 0.2 : thread_tolerance_class==='5H' ? 0.0 : 0.1)",
          "unit": {
            "ref": "mm"
          },
          "reference": "ISO 68-1:1998 / ISO 965-1:1998 — basic profile; tap drill = d1 + tolerance allowance per 6H/5H/7H",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "alpha_deg",
          "expression": "alpha_deg = Math.atan(pitch_mm / (Math.PI * d2_mm)) * 180 / Math.PI",
          "unit": {
            "ref": "deg"
          },
          "reference": "tan(α) = p / (π × d₂) — ISO 5408; helix angle at pitch cylinder; typical 2–6° for coarse metric",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Vc_corrected",
          "expression": "Vc_factor = {flood:1.0, MQL:0.80, dry:0.60}[coolant_type]; Vc_corrected = Vc_m_min * Vc_factor",
          "unit": {
            "ref": "mpmin"
          },
          "reference": "Coolant reduction factors — Sandvik C-2920 §12.4; dry threading requires significant speed reduction",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "n_rpm",
          "expression": "n_rpm = Vc_corrected * 1000 / (Math.PI * nominal_D)",
          "unit": {
            "ref": "rpm"
          },
          "reference": "n = V_c × 1000 / (π × D) — applied to nominal thread diameter",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Vf_mm_min",
          "expression": "Vf_mm_min = n_rpm * pitch_mm",
          "unit": {
            "ref": "mmpmin"
          },
          "reference": "V_f = n × p — rigid tapping synchronisation; F_per_rev = p (exact); CNC G84 / G74 cycle",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Mc_Nm",
          "expression": "const Vc_mult = {P:1.0, M:1.8, K:0.7, N:0.4, S:2.5}[workpiece_material_group]; Mc_Nm = 0.00022 * Vc_mult * Math.pow(nominal_D, 2.6) * pitch_mm",
          "unit": {
            "ref": "Nm"
          },
          "reference": "Approximate tapping torque: M_c = C_m × D^2.6 × p; C_m empirical per material group — Titex / Walter reference data",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [
        {
          "id": "V1",
          "action": "BLOCK",
          "condition": "tap_drill_mm > nominal_D * 0.95",
          "message": "Tap drill diameter > 95% of nominal: insufficient thread material — tap drill calculation error; verify thread pitch"
        },
        {
          "id": "V2",
          "action": "WARN",
          "condition": "thread_depth_mm < nominal_D * 0.8 && workpiece_material_group !== 'P'",
          "message": "Thread engagement < 0.8D in non-steel material: strip-out risk — increase engagement to minimum 1.5D for aluminium, 2.0D for plastics"
        },
        {
          "id": "V3",
          "action": "WARN",
          "condition": "n_rpm > 10000 && nominal_D > 10",
          "message": "High speed on large tap (D > 10 mm): cutting speed is aggressive — verify machine spindle torque rating at this RPM; tap breakage risk increases significantly"
        }
      ],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "",
          "condition": "workpiece_material_group === 'M' && coolant_type === 'dry'",
          "message": "Dry tapping in stainless steel: tap seizure imminent — stainless work-hardens rapidly; mandatory MQL or flood coolant; reduce Vc to ≤ 8 m/min"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "",
          "condition": "workpiece_material_group === 'S' && Vc_m_min > 6",
          "message": "Cutting speed too high for superalloy threading: V_c > 6 m/min in Ni/Ti alloys causes rapid BUE and tap fracture — reduce to 3–5 m/min and use HSSE-PM or solid carbide tap"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "",
          "condition": "alpha_deg < 2",
          "message": "Very small helix angle (< 2°): fine pitch thread — chip evacuation critical; use spiral flute tap (right-hand helix) for blind holes to eject chips upward"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "",
          "condition": "Vf_mm_min > 500 && nominal_D < 8",
          "message": "High feed rate on small tap: synchronisation error of ±1 rpm causes proportionally large pitch error — verify CNC rigid tapping encoder resolution; use compensation chuck below M8"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "",
          "condition": "thread_depth_mm > nominal_D * 2.5",
          "message": "Deep blind hole threading: chip accumulation risk — use spiral flute tap and retract every 5 mm for chip evacuation; flood coolant at maximum pressure mandatory"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [

  "standards": [
    {
      "id": "PRO_049",
      "code": "IEC 60076-1:2011",
      "name": "Power Transformer Loading, No-Load/Load Losses & Economic Loading Factor",
      "description": "Power Transformer Loading, No-Load/Load Losses & Economic Loading Factor — Electrical Power Systems, Energy Management",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "beta",
          "expression": "actual_load_kva / rated_kva",
          "unit": {
            "ref": "p.u."
          },
          "reference": "IEC 60076-1:2011 §7 — loading factor definition",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "P_total_w",
          "expression": "no_load_loss_w + beta^2 * load_loss_w",
          "unit": {
            "ref": "W"
          },
          "reference": "IEC 60076-1 §10 — total transformer loss: P = P0 + β²·Pk",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "P_out_w",
          "expression": "actual_load_kva * load_power_factor * 1000; eta_pct = P_out_w / (P_out_w + P_total_w) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "IEC 60076-1 §10.3 — transformer efficiency",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "beta_eco",
          "expression": "Math.sqrt(no_load_loss_w / load_loss_w)",
          "unit": {
            "ref": "p.u."
          },
          "reference": "IEC 60354:1991 §5 — economic loading for minimum total losses: β_eco = √(P0/Pk)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "E_loss_kwh",
          "expression": "(P_total_w / 1000) * operating_hours_yr",
          "unit": {
            "ref": "kWh/yr"
          },
          "reference": "IEC 60354 — annual loss calculation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "loss_cost_usd_yr",
          "expression": "E_loss_kwh_yr * electricity_rate_usd_kwh; beta_max_ambient = (ambient_temp_c <= 40) ? 1.0 : 1.0 - (ambient_temp_c - 40) * 0.01",
          "unit": {
            "ref": "USD/yr, p.u."
          },
          "reference": "IEC 60354 §4 — continuous rating derating above 40°C ambient",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "IEC 60076-1:2011",
          "condition": "beta > 0.90",
          "message": "Loading > 90%: limited headroom for fault current — coordinate protection relay settings and evaluate parallel transformer option"
        },
        {
          "id": "W2",
          "severity": "INFO",
          "source": "IEC 60076-1:2011",
          "condition": "Math.abs(beta - beta_eco) > 0.3",
          "message": "Operating load deviates >30% from economic load point: significant excess losses — reconfigure load balance across transformers if multiple units in service"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "IEC 60076-1:2011",
          "condition": "eta_pct < 97.5 && rated_kva > 1000",
          "message": "Efficiency < 97.5% on medium-power transformer: below IEC 60076-1 typical threshold — check for aged core or damaged windings"
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "IEC 60076-1:2011",
          "condition": "ambient_temp_c > 45",
          "message": "Ambient > 45°C: forced-air cooling (ONAN→ONAF) may be required per IEC 60076-7 §7; verify cooling class"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "IEC 60076-1:2011",
          "condition": "loss_cost_usd_yr > 50000",
          "message": "Annual loss cost exceeds USD 50,000: evaluate amorphous core transformer (P0 reduction ~70%) — typically pays back in 3–5 years"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "rated_kva",
        "no_load_loss_w",
        "load_loss_w",
        "actual_load_kva",
        "load_power_factor",
        "operating_hours_yr",
        "electricity_rate_usd_kwh",
        "ambient_temp_c"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []

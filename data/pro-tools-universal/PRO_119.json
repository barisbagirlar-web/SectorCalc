  "standards": [
    {
      "id": "PRO_119",
      "code": "API 610 12th Ed.",
      "name": "Centrifugal Pump Cavitation & NPSH Analysis (API 610)",
      "description": "Centrifugal Pump Cavitation & NPSH Analysis (API 610) — Fluid Mechanics, Pump Systems",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Atm_Correction",
          "expression": "1.013 * POWER(1 - 0.0000226 * elevation_m, 5.256)",
          "unit": {
            "ref": "bar"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Head_Tank",
          "expression": "(tank_pressure_bar * 100000) / (fluid_density_kg_m3 * 9.81)",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Head_Vapor",
          "expression": "(vapor_pressure_bar * 100000) / (fluid_density_kg_m3 * 9.81)",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "NPSHa",
          "expression": "Head_Tank - Head_Vapor + static_suction_head_m - suction_pipe_losses_m",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "NPSH_Margin_m",
          "expression": "NPSHa - npsh_required_m",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "NPSH_Ratio",
          "expression": "NPSHa / npsh_required_m",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Flow_Velocity_m_s",
          "expression": "(flow_rate_m3h / 3600) / (3.14159 * POWER(pipe_diameter_mm / 1000 / 2, 2))",
          "unit": {
            "ref": "mps"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Velocity_Head",
          "expression": "POWER(Flow_Velocity_m_s, 2) / (2 * 9.81)",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Max_Suction_Lift",
          "expression": "Head_Tank - Head_Vapor - suction_pipe_losses_m - npsh_required_m - safety_margin_m",
          "unit": {
            "ref": "m"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "API 610 Md.6.1.4",
          "condition": "NPSH_Ratio < 1.0",
          "message": "CAVITATION INITIATED: NPSHa < NPSHr. Vapor bubbles are forming in the impeller eye. Micro-implosions are causing surface erosion. Stop the pump immediately and rectify suction conditions."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "API 610 / Hydraulic Institute",
          "condition": "NPSH_Ratio >= 1.0 && NPSH_Ratio < 1.1",
          "message": "CAVITATION RISK: Does not meet API 610 requirement of NPSHa >= NPSHr + 10% safety margin. Cavitation will initiate immediately on flow surges or temperature rises. Reduce suction line friction losses."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "Hydraulic Institute ANSI/HI 9.6.1",
          "condition": "NPSH_Ratio >= 1.1 && NPSH_Ratio < 1.3",
          "message": "Insufficient NPSH margin: NPSHa / NPSHr is between 1.1 and 1.3. Cavitation may trigger during process fluctuations (temperature, flow). Hydraulic Institute recommends a minimum ratio of 1.3."
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "API 610 — Hot Fluid",
          "condition": "fluid_temp_c > 60 && static_suction_head_m < 0",
          "message": "Hot fluid + negative suction lift: Vapor pressure increases exponentially with temperature, rapidly reducing NPSHa. This combination poses critical cavitation risk. Locate pump below tank level."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Hydraulic Institute Suction Line Design",
          "condition": "suction_pipe_losses_m > 2.0",
          "message": "Suction line friction losses > 2m: Directly subtracts from NPSHa. To reduce losses: increase pipe diameter, minimize valves, shorten pipe runs, and avoid tight elbows."
        },
        {
          "id": "W6",
          "severity": "CRITICAL",
          "source": "API 610",
          "condition": "NPSHa < 1.0",
          "message": "NPSHa < 1.0m: Operating conditions are outside normal centrifugal pump limits. Evaluate special low-NPSH pump models (with inducer) or submersible pumps."
        }
      ],

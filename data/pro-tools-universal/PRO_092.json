  "standards": [
    {
      "id": "PRO_092",
      "code": "DNV-RP-B401:2021",
      "name": "Cathodic Protection Design — Sacrificial Anode Current Demand, Mass & Service Life",
      "description": "Cathodic Protection Design — Sacrificial Anode Current Demand, Mass & Service Life — Corrosion Engineering, Asset Integrity",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "A_eff_m2",
          "expression": "A_eff_m2 = structure_area_m2 * coating_breakdown_pct / 100",
          "unit": {
            "ref": "m2"
          },
          "reference": "A_eff = A_s × f_c — DNV-RP-B401 §6.2; coating breakdown factor applied to bare area",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Ic_mean_A",
          "expression": "Ic_mean_A = A_eff_m2 * current_density_mA_m2 / 1000",
          "unit": {
            "ref": "A"
          },
          "reference": "I_c = i_c × A_eff — DNV-RP-B401 §6.3.1 Eq.(6.1)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Q_T_Ah",
          "expression": "Q_T_Ah = Ic_mean_A * design_life_yr * 8760",
          "unit": {
            "ref": "Ah"
          },
          "reference": "Q_T = I_c,mean × T_d × 8760 — total coulombs required over design life",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Ma_kg",
          "expression": "const ECA = {Zn:780, AlIn:2000, Mg:1230}[anode_material]; Ma_kg = Q_T_Ah / (ECA * anode_utilisation_pct / 100)",
          "unit": {
            "ref": "kg"
          },
          "reference": "M_a = Q_T / (ε × u) — DNV-RP-B401 §6.4 Eq.(6.3); ε = electrochemical capacity in Ah/kg",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "N_a",
          "expression": "anode_std_mass_kg = (anode_material === 'Mg') ? 5 : 15; N_a = Math.ceil(Ma_kg / anode_std_mass_kg)",
          "unit": {
            "ref": "count"
          },
          "reference": "N_a = M_a / m_std; standard bracelet anode: Al-In 15 kg; Mg 5 kg net mass — DNV Table 10-4",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "dE_mv, I_output_A",
          "expression": "const E_anode = {Zn:-1050, AlIn:-1050, Mg:-1550}[anode_material]; dE_mv = E_anode - protection_potential_mv; resistance_est_ohm = 0.315 * Math.sqrt(A_eff_m2 / N_a) / 10; I_output_A = dE_mv / 1000 / resistance_est_ohm",
          "unit": {
            "ref": "mV, A"
          },
          "reference": "Driving voltage ΔE = E_anode − E_prot; current = ΔE/R_a; R_a from Dwight formula — DNV-RP-B401 §7",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [
        {
          "id": "V1",
          "action": "WARN",
          "condition": "coating_breakdown_pct === 100 && current_density_mA_m2 < 30",
          "message": "Bare steel with low current density: verify environment — bare steel in stagnant seawater may require 50–100 mA/m² per DNV Table 10-3"
        },
        {
          "id": "V2",
          "action": "WARN",
          "condition": "anode_material === 'Zn' && current_density_mA_m2 > 50",
          "message": "Zinc anodes at high current density: driving voltage insufficient for tropical warm water — switch to Al-In alloy with higher electrochemical efficiency"
        },
        {
          "id": "V3",
          "action": "WARN",
          "condition": "Ma_kg > 100000",
          "message": "Total anode mass > 100 tonnes: very large CP system — evaluate impressed current cathodic protection (ICCP) for structures > 20,000 m²; lower OPEX despite higher CAPEX"
        }
      ],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "",
          "condition": "design_life_yr > 20 && anode_material === 'Zn'",
          "message": "Zinc anodes for 20+ year design life: mass penalty is severe — Al-In provides 2.6× more charge per kg at same potential; mandatory for deepwater and long-life structures per DNV §5.2"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "",
          "condition": "dE_mv < 150",
          "message": "Driving voltage < 150 mV: anode current output will be marginal — verify polarisation resistance of structure; may need to increase anode count by 40% for adequate protection"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "",
          "condition": "protection_potential_mv < -900 && anode_material === 'Mg'",
          "message": "Over-protection risk with Mg anodes (E < −900 mV): hydrogen embrittlement possible on high-strength steels (Fy > 550 MPa) — limit to −950 mV per NACE SP0169 §6.2.2"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "",
          "condition": "A_eff_m2 > 5000 && N_a < 20",
          "message": "Large exposed area with few anodes: current distribution will be uneven — increase anode count and space evenly; maximum spacing = 3 m for bare surfaces per DNV §10.3"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "",
          "condition": "coating_breakdown_pct < 3",
          "message": "Low coating breakdown (<3%): CP demand is minimal — verify coating integrity with holiday detection per NACE SP0188; CP as backup protection only"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "structure_area_m2",
        "coating_breakdown_pct",
        "current_density_mA_m2",
        "design_life_yr",
        "anode_material",
        "protection_potential_mv"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },
  "legalNotice": "⚠ Engineering decision support only — verify before use. This is a technical simulation, not professional engineering advice."
}

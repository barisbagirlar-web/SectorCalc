  "standards": [
    {
      "id": "PRO_070",
      "code": "AWWA D100-11 (Welded Carbon Steel Tanks)",
      "name": "Elevated Storage Tank — Shell Hoop Stress, Hydrostatic Pressure & Wind Overturning Stability",
      "description": "Elevated Storage Tank — Shell Hoop Stress, Hydrostatic Pressure & Wind Overturning Stability — Civil, Structural, Water Infrastructure",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "p_h_kpa",
          "expression": "9.81 * water_height_m",
          "unit": {
            "ref": "kPa"
          },
          "reference": "p = ρ_w·g·H_w",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "sigma_hoop_mpa",
          "expression": "p_h_kpa * (tank_diameter_m * 1000 / 2) / (shell_thickness_mm * 1000)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "Barlow / thin-shell hoop stress: σ_H = p·D/(2t) — AWWA D100 §14.2 / API 650 §5.6",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "sigma_allow_mpa",
          "expression": "joint_efficiency_E * Fy_mpa / 1.5; hoop_DCR = sigma_hoop_mpa / sigma_allow_mpa",
          "unit": {
            "ref": "MPa, dimensionless"
          },
          "reference": "AWWA D100 §14.2 — allowable = E × F_y / 1.5 (FOS=1.5 on yield)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Cd_tank",
          "expression": "0.6; A_proj_m2 = tank_diameter_m * water_height_m; q_wind_pa = 0.5 * 1.25 * Math.pow(design_wind_speed_m_s, 2); F_wind_kn = Cd_tank * q_wind_pa * A_proj_m2 / 1000; H_centroid_m = support_height_m + water_height_m / 2; M_OT_knm = F_wind_kn * H_centroid_m",
          "unit": {
            "ref": "kN, kN·m"
          },
          "reference": "ASCE 7-22 §29.4 — wind force on cylindrical vessel",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "W_water_kn",
          "expression": "9.81 * (Math.PI/4 * Math.pow(tank_diameter_m, 2) * water_height_m * 1000) / 1000; W_total_kn = tank_empty_weight_kn + W_water_kn; M_restore_knm = W_total_kn * tank_diameter_m / 2",
          "unit": {
            "ref": "kN·m, kN"
          },
          "reference": "Restoring moment = W_total × D/2 (about tank base edge) — ASCE 7-22 §C15.4",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "OTF",
          "expression": "M_restore_knm / M_OT_knm",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AWWA D100 §15.3 / ASCE 7-22 — OTF ≥ 1.5 for tanks",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "AWWA D100-11 (Welded Carbon Steel Tanks)",
          "condition": "hoop_DCR > 0.85",
          "message": "Hoop utilisation > 85%: marginal shell capacity — verify corrosion allowance is maintained over design life; 1 mm corrosion reduces capacity by ~5% on 20 mm plate"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "AWWA D100-11 (Welded Carbon Steel Tanks)",
          "condition": "OTF < 2.0 && support_height_m > 15",
          "message": "Elevated tank with marginal OTF: tall structures amplify wind overturning — detailed dynamic analysis and anchor bolt design required per ASCE 7-22 §15.7"
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "AWWA D100-11 (Welded Carbon Steel Tanks)",
          "condition": "design_wind_speed_m_s > 60",
          "message": "Design wind speed > 60 m/s: hurricane / typhoon zone — enhanced wind analysis per ASCE 7-22 §26.11 and wind tunnel study recommended for D > 20 m"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "AWWA D100-11 (Welded Carbon Steel Tanks)",
          "condition": "joint_efficiency_E < 0.85 && water_height_m > 10",
          "message": "Non-radiographed welds on deep tank: upgrade to Class 2 (spot RT) minimum — AWWA D100 requires RT for shells above 5 m water depth in Class B service"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "AWWA D100-11 (Welded Carbon Steel Tanks)",
          "condition": "support_height_m > 20",
          "message": "Support height > 20 m: structural analysis of support columns/pedestal under combined gravity, wind, and seismic mandatory per ASCE 7-22 §15.4.2"
        }
      ],

  "standards": [
    {
      "id": "PRO_081",
      "code": "EJMA Standards 10th Ed.",
      "name": "Metallic Expansion Joint Sizing — Axial Displacement, Spring Rate & Fatigue Cycle Life",
      "description": "Metallic Expansion Joint Sizing — Axial Displacement, Spring Rate & Fatigue Cycle Life — Piping Systems, Thermal Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "delta_T",
          "expression": "T_operating_c - T_install_c; delta_axial_mm = pipe_material * 1e-6 * delta_T * pipe_length_m * 1000",
          "unit": {
            "ref": "mm"
          },
          "reference": "δ = α·ΔT·L — ASME B31.3 §319.4",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "delta_req_mm",
          "expression": "delta_axial_mm * 1.25",
          "unit": {
            "ref": "mm"
          },
          "reference": "EJMA §2.2 — 25% safety margin on calculated displacement for uncertainty in anchor loads and fabrication tolerance",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "D_m_mm",
          "expression": "pipe_OD_mm + 30; t_bellow_mm = 0.8; f_ax_n_mm = 1.7 * Math.pow(D_m_mm, 0.5) * bellows_material_yield_mpa * Math.pow(t_bellow_mm, 3) / (Math.pow(30, 3) * num_convolutions)",
          "unit": {
            "ref": "N/mm"
          },
          "reference": "EJMA 10th Ed. §5.3 — simplified spring rate",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "F_pressure_kn",
          "expression": "design_pressure_bar * 1e5 * Math.PI/4 * Math.pow(pipe_OD_mm/1000, 2) / 1000; F_spring_kn = f_ax_n_mm * delta_axial_mm / 1000; F_anchor_kn = F_pressure_kn + F_spring_kn",
          "unit": {
            "ref": "kN"
          },
          "reference": "EJMA §4.1 — anchor load = pressure thrust + spring force",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "sigma_m_mpa",
          "expression": "3 * f_ax_n_mm * delta_req_mm / (num_convolutions * Math.PI * pipe_OD_mm * 0.8)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "EJMA §5.5 — simplified meridional stress from axial deflection",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "stress_ratio",
          "expression": "sigma_m_mpa / bellows_material_yield_mpa; N_life = (stress_ratio < 0.3) ? 100000 : (stress_ratio < 0.5) ? 50000 / stress_ratio : (stress_ratio < 0.8) ? 10000 / Math.pow(stress_ratio, 3) : 1000 / Math.pow(stress_ratio, 5)",
          "unit": {
            "ref": "cycles"
          },
          "reference": "EJMA Appendix C fatigue curve — SS316L",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "EJMA Standards 10th Ed.",
          "condition": "F_anchor_kn > 500",
          "message": "Anchor load > 500 kN: large main anchors required — pressure thrust on unrestrained bellows is major structural load; evaluate tied universal expansion joint to eliminate thrust"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "EJMA Standards 10th Ed.",
          "condition": "T_operating_c > 450 && pipe_material === 11.7",
          "message": "Carbon steel above 450°C: creep domain — ASME B31.3 requires time-dependent allowable stress; verify bellows material rating at temperature"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "EJMA Standards 10th Ed.",
          "condition": "design_pressure_bar > 40 && num_convolutions < 3",
          "message": "High pressure with few convolutions: instability risk — EJMA §7 squirm (in-plane and column) must be checked; add internal sleeve for pressure > 40 bar"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "EJMA Standards 10th Ed.",
          "condition": "delta_req_mm > 50 && num_convolutions < 6",
          "message": "Large displacement with few convolutions: excessive stress per convolution — minimum 6 convolutions for δ > 50 mm per EJMA design practice"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "EJMA Standards 10th Ed.",
          "condition": "N_life < 10000",
          "message": "Fatigue life < 10,000 cycles: limited life joint — document replacement interval in maintenance plan; N_life cycles at operating temperature ΔT per EJMA C"
        }
      ],

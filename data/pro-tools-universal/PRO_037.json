  "standards": [
    {
      "id": "PRO_037",
      "code": "ASME BPVC VIII Div.1 App.2",
      "name": "Bolted Flange Joint Integrity — Gasket Seating Stress, Bolt Load & Leak Tightness Class",
      "description": "Bolted Flange Joint Integrity — Gasket Seating Stress, Bolt Load & Leak Tightness Class — Pressure Equipment, Mechanical Integrity",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "N",
          "expression": "(gasket_od_mm - gasket_id_mm) / 2; b_eff = (N <= 12.7) ? N/2 : 2.53*Math.sqrt(N/2)",
          "unit": {
            "ref": "mm"
          },
          "reference": "ASME BPVC VIII Div.1 App.2 §2-5",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "G_mean",
          "expression": "gasket_id_mm + 2*b_eff_mm; H = Math.PI/4 * (G_mean/1000)^2 * design_pressure_bar * 1e5 / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ASME BPVC VIII App.2 — hydrostatic load on mean gasket diameter",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "H_p",
          "expression": "2*Math.PI*G_mean_m*b_eff_mm*1e-3 * gasket_m_factor * design_pressure_bar*1e5/1000; W_op_kN = H_kN + H_p",
          "unit": {
            "ref": "kN"
          },
          "reference": "ASME BPVC VIII App.2 Eq.(2)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "W_seat_kN",
          "expression": "Math.PI * G_mean_m * b_eff_mm*1e-3 * gasket_y_mpa * 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ASME BPVC VIII App.2 Eq.(3)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "W_avail_kN",
          "expression": "bolt_count * bolt_root_area_mm2 * 1e-6 * bolt_material_yield_mpa * 1000 * 0.7",
          "unit": {
            "ref": "kN"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "bolt_ratio",
          "expression": "W_avail_kN / Math.max(W_op_kN, W_seat_kN)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "EN 1591-1:2013 §7 — ratio ≥ 1.0 required",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ASME BPVC VIII Div.1 App.2",
          "condition": "bolt_ratio < 1.0",
          "message": "Bolt load deficit: add bolts, upgrade bolt grade, or use lower-y gasket per ASME App.2 §2-5"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ASME BPVC VIII Div.1 App.2",
          "condition": "bolt_ratio > 2.5",
          "message": "Excessive bolt load: gasket crush risk — verify gasket crush limit per manufacturer data"
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "ASME BPVC VIII Div.1 App.2",
          "condition": "design_pressure_bar > 100 && gasket_m_factor < 2.5",
          "message": "High-pressure service with low m-factor: soft gasket inadequate — use spiral-wound or ring-type joint"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ASME BPVC VIII Div.1 App.2",
          "condition": "b_eff_mm > 19",
          "message": "Wide effective seating width: bolt load demand increases sharply — verify torque values per PCC-1-2019"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ASME BPVC VIII Div.1 App.2",
          "condition": "bolt_count < 8 && design_pressure_bar > 40",
          "message": "Few bolts at elevated pressure: flange rotation risk — minimum 8 bolts recommended per ASME B16.5"
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "ASME BPVC VIII Div.1 App.2",
          "condition": "bolt_material_yield_mpa > 1200",
          "message": "High-strength bolting: stress corrosion cracking susceptibility in H₂S service per NACE MR0175"
        }
      ],

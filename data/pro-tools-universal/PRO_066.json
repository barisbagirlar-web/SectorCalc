  "standards": [
    {
      "id": "PRO_066",
      "code": "ISO 2408:2023",
      "name": "Wire Rope Sling — Safe Working Load, D/d Ratio Derating & Fatigue Life Assessment",
      "description": "Wire Rope Sling — Safe Working Load, D/d Ratio Derating & Fatigue Life Assessment — Lifting & Rigging, Material Handling Safety",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "MBF_kn",
          "expression": "rope_grade * rope_construction * Math.pow(rope_diameter_mm, 2) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ISO 2408:2023 §7 — MBF = R_r × f_m × d²",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "WLL_leg_kn",
          "expression": "MBF_kn / design_factor",
          "unit": {
            "ref": "kN"
          },
          "reference": "ASME B30.9-2022 §9-1.3 — WLL = MBF / DF",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "SWL_eff_kn",
          "expression": "WLL_leg_kn * sling_configuration",
          "unit": {
            "ref": "kN"
          },
          "reference": "EN 13414-1:2003 §4.3 — configuration mode factor applied to single-leg WLL",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Dd_ratio",
          "expression": "sheave_diameter_mm / rope_diameter_mm; bend_eff = (Dd_ratio >= 25) ? 1.0 : (Dd_ratio >= 18) ? 0.90 : (Dd_ratio >= 12) ? 0.75 : (Dd_ratio >= 8) ? 0.65 : 0.50",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 2408 §8 / LEEA COPSULE — bending efficiency factor",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "SWL_derated_kn",
          "expression": "SWL_eff_kn * bend_eff",
          "unit": {
            "ref": "kN"
          },
          "reference": "ASME B30.9 Commentary — SWL must be reduced for D/d < 25",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "N_fatigue",
          "expression": "Math.pow(bend_eff * MBF_kn / (SWL_eff_kn * design_factor), 3) * 100000; years_life = N_fatigue / lift_cycles_per_year",
          "unit": {
            "ref": "cycles, years"
          },
          "reference": "Power-law fatigue estimate — indicative only",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ISO 2408:2023",
          "condition": "Dd_ratio < 18",
          "message": "D/d < 18: significant bending penalty (efficiency < 90%) — replace contact hardware with larger radius hook or thimble; or upsize rope"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "ISO 2408:2023",
          "condition": "bend_eff < 0.75",
          "message": "Bending efficiency < 75%: severe rope fatigue zone — mandatory inspection after every 50 lift cycles per LEEA COPSULE §7"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "ISO 2408:2023",
          "condition": "sling_configuration === 1.0 && design_factor === 5",
          "message": "Single-leg vertical: simplest configuration — confirm load centre of gravity alignment; off-vertical > 5° effectively applies choker mode factor"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 2408:2023",
          "condition": "rope_grade >= 1960 && Dd_ratio < 20",
          "message": "High-grade rope with small D/d: high-strength wires are more notch-sensitive — bending fatigue is disproportionately severe; use D/d ≥ 25 for Rr ≥ 1960"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ISO 2408:2023",
          "condition": "lift_cycles_per_year > 5000",
          "message": "High-cycle application (>5000 cycles/yr): wire rope slings unsuitable — consider chain slings or permanent rigging with engineered fatigue life per ISO 1704"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "rope_diameter_mm",
        "rope_grade",
        "rope_construction",
        "sling_configuration",
        "design_factor",
        "sheave_diameter_mm",
        "lift_cycles_per_year"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },

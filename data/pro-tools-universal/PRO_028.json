  "standards": [
    {
      "id": "PRO_028",
      "code": "VDI 3618 Intralogistics Planning",
      "name": "Warehouse 3D Cube Utilisation, Pallet Position Count & Storage Capacity Analysis",
      "description": "Warehouse 3D Cube Utilisation, Pallet Position Count & Storage Capacity Analysis — Logistics & Supply Chain, Warehouse Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Net_Storage_Area_m2",
          "expression": "gross_floor_area_m2 * (net_storage_ratio_pct / 100)",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Rack_Bay_Footprint_m2",
          "expression": "(pallet_length_m + aisle_width_m / 2) * pallet_width_m",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Floor_Positions",
          "expression": "FLOOR(Net_Storage_Area_m2 / Rack_Bay_Footprint_m2)",
          "unit": {
            "ref": "positions"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Height_per_Level_m",
          "expression": "loaded_pallet_height_m + rack_beam_clearance_m",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Max_Rack_Levels",
          "expression": "FLOOR(clear_height_m / Height_per_Level_m)",
          "unit": {
            "ref": "levels"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Total_Pallet_Positions",
          "expression": "Floor_Positions * Max_Rack_Levels",
          "unit": {
            "ref": "positions"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Accessible_Positions",
          "expression": "FLOOR(Total_Pallet_Positions * selectivity_factor)",
          "unit": {
            "ref": "positions"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Required_Height_m",
          "expression": "Max_Rack_Levels * Height_per_Level_m",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Theoretical_Volume_m3",
          "expression": "gross_floor_area_m2 * clear_height_m",
          "unit": {
            "ref": "m3"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Storage_Volume_m3",
          "expression": "Total_Pallet_Positions * (pallet_length_m * pallet_width_m * loaded_pallet_height_m)",
          "unit": {
            "ref": "m3"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Cube_Utilisation_pct",
          "expression": "(Storage_Volume_m3 / Theoretical_Volume_m3) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Operating_Positions",
          "expression": "FLOOR(Total_Pallet_Positions * (occupancy_target_pct / 100))",
          "unit": {
            "ref": "positions"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Positions_per_m2",
          "expression": "Total_Pallet_Positions / gross_floor_area_m2",
          "unit": {
            "ref": "positions/m²"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Aisle_Area_m2",
          "expression": "gross_floor_area_m2 * (net_storage_ratio_pct / 100) * (aisle_width_m / (pallet_length_m + aisle_width_m))",
          "unit": {
            "ref": "m2"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "VDI 3618 / Reach Truck Analysis",
          "condition": "aisle_width_m >= 3.5",
          "message": "WIDE AISLE SYSTEM (≥3.5m): Aisle width suitable for counterbalance forklift only. Approximately 35–40% of floor area is dedicated to aisles. Switching to reach truck (aisle 2.6–2.8m) or VNA (1.6–1.8m) could increase pallet positions by 20–40% in the same building."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "MHI Warehouse Efficiency Benchmarks",
          "condition": "Cube_Utilisation_pct < 25",
          "message": "POOR CUBE UTILISATION (<25%): Building volume is severely underused. Root causes: insufficient rack height, too many aisles, low stacking, or low occupancy. World-class warehouses achieve 40–60% cube utilisation. Evaluate: (1) Taller racking, (2) Narrower aisles, (3) Double-deep or mobile racking."
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "WMS Best Practice / SEMA",
          "condition": "occupancy_target_pct > 90",
          "message": "OCCUPANCY TARGET > 90%: Operating above 90% causes severe congestion, pick path blockages, and forces multiple product relocations per pick. WMS systems degrade significantly above 85%. Required buffer for operational flexibility: minimum 15% empty positions."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "Warehouse Design Optimisation",
          "condition": "Max_Rack_Levels <= 2",
          "message": "Only 1–2 rack levels achievable: Building clear height is limiting vertical density. If building modification is not feasible, consider mezzanine floor installation or multi-tier picking to improve m³ utilisation."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "VDI 3618 Density KPI",
          "condition": "Positions_per_m2 < 0.8",
          "message": "Storage density < 0.8 positions/m² gross: Below industry benchmark for conventional racking (target: 1.0–1.5 positions/m²). Analyse: wide aisle ratios, low stacking height, and low net storage ratio as primary contributors."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "Warehouse Operations — FIFO Compliance",
          "condition": "selectivity_factor < 0.5 && accessible_positions < 200",
          "message": "Low accessibility + small absolute accessible count: With drive-in or pushback systems, FIFO rotation becomes operationally difficult. For perishable goods, pharmaceuticals, or date-coded products, minimum selectivity factor 0.8 is required to ensure FEFO compliance."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "gross_floor_area_m2",
        "net_storage_ratio_pct",
        "clear_height_m",
        "pallet_length_m",
        "pallet_width_m",
        "loaded_pallet_height_m",
        "rack_beam_clearance_m",
        "aisle_width_m",
        "storage_system",
        "selectivity_factor"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },

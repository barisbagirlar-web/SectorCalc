  "standards": [
    {
      "id": "PRO_064",
      "code": "ASHRAE 62.1-2022",
      "name": "Industrial Ventilation Duct Sizing — Air Volume, Velocity, Friction Loss & Fan Selection",
      "description": "Industrial Ventilation Duct Sizing — Air Volume, Velocity, Friction Loss & Fan Selection — HVAC, Industrial Ventilation",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "D_h_mm",
          "expression": "(duct_shape === 'circular') ? duct_dim_1_mm : (2 * duct_dim_1_mm * duct_dim_2_mm) / (duct_dim_1_mm + duct_dim_2_mm)",
          "unit": {
            "ref": "mm"
          },
          "reference": "D_h = 4A/P",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "A_duct_m2",
          "expression": "(duct_shape === 'circular') ? Math.PI/4 * Math.pow(duct_dim_1_mm/1000, 2) : (duct_dim_1_mm * duct_dim_2_mm) / 1e6; v_m_s = Q_air_m3h / 3600 / A_duct_m2",
          "unit": {
            "ref": "m², m/s"
          },
          "reference": "Continuity equation — velocity = Q/A",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Re",
          "expression": "air_density_kg_m3 * v_m_s * D_h_mm/1000 / 1.81e-5; f = 0.02; for(let i=0;i<50;i++){f=1/Math.pow(-2*Math.log10(roughness_mm/(3.7*D_h_mm)+2.51/(Re*Math.sqrt(f))),2)}",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Colebrook-White equation — Moody chart",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "dP_f_pa",
          "expression": "f_darcy * (duct_length_m / (D_h_mm/1000)) * air_density_kg_m3 * Math.pow(v_m_s, 2) / 2",
          "unit": {
            "ref": "Pa"
          },
          "reference": "Darcy-Weisbach equation — ASHRAE Fundamentals 2021 Ch.21 Eq.(19)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "dP_local_pa",
          "expression": "local_loss_coeff_sum * air_density_kg_m3 * Math.pow(v_m_s, 2) / 2",
          "unit": {
            "ref": "Pa"
          },
          "reference": "ΔP = C × ρv²/2 — SMACNA HVAC Duct Construction Standards 3rd Ed.",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "dP_total_pa",
          "expression": "dP_f_pa + dP_local_pa; dP_per_m_pa = dP_f_pa / duct_length_m",
          "unit": {
            "ref": "Pa, Pa/m"
          },
          "reference": "SMACNA design target: 0.8–1.2 Pa/m for low-pressure systems",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "ASHRAE 62.1-2022",
          "condition": "v_m_s > 10 && duct_shape === 'circular'",
          "message": "Circular duct velocity > 10 m/s: exceeds SMACNA medium-pressure classification — verify duct pressure class and seam/joint rating"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ASHRAE 62.1-2022",
          "condition": "dP_per_m_pa > 2.0",
          "message": "Friction rate > 2 Pa/m: increase duct diameter by one standard size — velocity reduces by ~20%, friction drops ~36%"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "ASHRAE 62.1-2022",
          "condition": "local_loss_coeff_sum > duct_length_m * 0.5",
          "message": "Fitting losses dominate: local ΔP > 50% of friction ΔP — optimise fitting selection (long-radius elbows, conical transitions) to reduce system resistance"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "ASHRAE 62.1-2022",
          "condition": "roughness_mm > 0.5 && v_m_s > 7",
          "message": "High roughness at elevated velocity: flexible duct in high-velocity application significantly increases fan energy — replace with rigid duct"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ASHRAE 62.1-2022",
          "condition": "air_density_kg_m3 < 1.0",
          "message": "Low air density (high temp or altitude): fan performance curves must be corrected for density — rated pressure and flow will be reduced"
        }
      ],

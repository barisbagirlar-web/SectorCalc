  "standards": [
    {
      "id": "PRO_059",
      "code": "ASCE 7-22",
      "name": "Storm Water Peak Runoff — Rational Method, Time of Concentration & Culvert Capacity",
      "description": "Storm Water Peak Runoff — Rational Method, Time of Concentration & Culvert Capacity — Civil, Hydraulic Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Tc_min",
          "expression": "0.0195 * Math.pow(catchment_length_m, 0.77) * Math.pow(slope_pct / 100, -0.385)",
          "unit": {
            "ref": "min"
          },
          "reference": "Kirpich (1940) — widely adopted in FHWA HEC-22 and ASCE practice for small catchments",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Q_peak_m3s",
          "expression": "runoff_coeff_C * rainfall_intensity_mm_h / 1000 / 3600 * catchment_area_ha * 10000",
          "unit": {
            "ref": "m3ps"
          },
          "reference": "Rational Method: Q = C·i·A — ASCE 7-22 / EN 752:2017 §6.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "AEP_pct",
          "expression": "100 / return_period_yr",
          "unit": {
            "ref": "pct"
          },
          "reference": "AEP = 1/T_r — FHWA HEC-22 §3.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "A_pipe_m2",
          "expression": "Math.PI/4 * Math.pow(culvert_diameter_mm/1000, 2); R_h_m = culvert_diameter_mm/1000/4; Q_pipe_m3s = (1/manning_n) * A_pipe_m2 * Math.pow(R_h_m, 2/3) * Math.pow(pipe_slope_pct/100, 0.5)",
          "unit": {
            "ref": "m3ps"
          },
          "reference": "Manning's equation — full-bore circular pipe",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "cap_ratio",
          "expression": "Q_pipe_m3s / Q_peak_m3s",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "cap_ratio ≥ 1.0 required",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "v_pipe_m_s",
          "expression": "Q_pipe_m3s / A_pipe_m2",
          "unit": {
            "ref": "mps"
          },
          "reference": "FHWA HEC-22 §4.2 — minimum self-cleansing velocity 0.9 m/s",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "ASCE 7-22",
          "condition": "cap_ratio < 1.2",
          "message": "Capacity ratio < 1.2: insufficient blockage margin per EN 752 §7.3 — upsize by one standard diameter"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "ASCE 7-22",
          "condition": "v_pipe_m_s > 4.0",
          "message": "Velocity > 4 m/s: concrete pipe erosion risk — consider energy dissipator at outlet or use abrasion-resistant liner"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ASCE 7-22",
          "condition": "Tc_min < 5",
          "message": "T_c < 5 min: very short time of concentration — peak rainfall intensity assumption very sensitive; verify IDF curve resolution"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "ASCE 7-22",
          "condition": "return_period_yr >= 50 && runoff_coeff_C < 0.5",
          "message": "Long return period with low C: verify C accounts for soil saturation at extended storms — effective C increases with event duration"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ASCE 7-22",
          "condition": "pipe_slope_pct < 0.3",
          "message": "Pipe slope < 0.3%: hydraulic gradient very flat — air entrainment, surcharge, and odour release risk; maintain minimum 0.5% per EN 752 §7"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,

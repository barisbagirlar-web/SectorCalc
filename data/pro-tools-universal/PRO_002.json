  "standards": [
    {
      "id": "PRO_002",
      "code": "Sandvik Coromant C-2920 2024",
      "name": "CNC Turning — Cutting Force, MRR, Surface Roughness & Tool Life Estimation",
      "description": "CNC Turning — Cutting Force, MRR, Surface Roughness & Tool Life Estimation — CNC Machining, Metal Cutting",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "MRR_cm3_min",
          "expression": "Vc_m_min * f_mm_rev * ap_mm / 10",
          "unit": {
            "ref": "cm³/min"
          },
          "reference": "MRR = V_c × f × a_p / 10 — Sandvik C-2920 §5.2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "kc_mpa",
          "expression": "kc1_mpa / Math.pow(f_mm_rev, 0.25)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "k_c = k_c1 / f^0.25 — Kienzle model",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Fc_N",
          "expression": "kc_mpa * f_mm_rev * ap_mm",
          "unit": {
            "ref": "N"
          },
          "reference": "F_c = k_c × f × a_p — ISO 3685:1993",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Pc_kw",
          "expression": "Fc_N * Vc_m_min / 60000",
          "unit": {
            "ref": "kW"
          },
          "reference": "P_c = F_c × V_c / 60000",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Ra_um",
          "expression": "1000 * Math.pow(f_mm_rev, 2) / (32 * re_mm)",
          "unit": {
            "ref": "µm"
          },
          "reference": "Ra ≈ f²/(32·r_ε) × 1000 — ISO 4287",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "T_min",
          "expression": "Math.pow(Taylor_C / Vc_m_min, 1 / Taylor_n)",
          "unit": {
            "ref": "min"
          },
          "reference": "Taylor's equation: T = (C/V_c)^(1/n) — ISO 3685:1993 Annex A",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],

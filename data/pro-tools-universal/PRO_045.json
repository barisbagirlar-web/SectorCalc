  "standards": [
    {
      "id": "PRO_045",
      "code": "ISO 9613-2:1996",
      "name": "Industrial Noise Attenuation — Source SPL to Receiver Level & OSHA Dose Calculation",
      "description": "Industrial Noise Attenuation — Source SPL to Receiver Level & OSHA Dose Calculation — Occupational Safety, Environmental Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "A_div_db",
          "expression": "20 * Math.log10(distance_m) + 10 * Math.log10(4 * Math.PI / directivity_factor_Q)",
          "unit": {
            "ref": "dB"
          },
          "reference": "ISO 9613-2:1996 §7.1 — geometrical divergence",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "DeltaL_sources_db",
          "expression": "10 * Math.log10(num_identical_sources)",
          "unit": {
            "ref": "dB"
          },
          "reference": "Energy summation: 10 identical sources → +10 dB",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Lp_receiver_db",
          "expression": "Lw_source_db + DeltaL_sources_db - A_div_db - excess_attenuation_db",
          "unit": {
            "ref": "dBA"
          },
          "reference": "ISO 9613-2 §4 — basic outdoor sound propagation equation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "T_perm_h",
          "expression": "(osha_criterion_db === 90) ? 8 / Math.pow(2, (Lp_receiver_dba - 90)/5) : 8 / Math.pow(2, (Lp_receiver_dba - 85)/3)",
          "unit": {
            "ref": "h"
          },
          "reference": "OSHA 29 CFR 1910.95 Table G-16 (5 dB exchange rate) / NIOSH 3 dB exchange rate",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "dose_pct",
          "expression": "(exposure_hours_per_shift / T_perm_h) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "OSHA dose D = Σ(C_i/T_i) × 100",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "dB_reduction_needed",
          "expression": "Math.max(0, Lp_receiver_dba - osha_criterion_db)",
          "unit": {
            "ref": "dB"
          },
          "reference": "Hierarchy of noise control: engineering controls first per ISO 1996-1 §8",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "ISO 9613-2:1996",
          "condition": "dose_pct > 50",
          "message": "Noise dose > 50%: OSHA Hearing Conservation Program mandatory — audiometric testing, training, hearing protection per 29 CFR 1910.95(c)"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "ISO 9613-2:1996",
          "condition": "Lp_receiver_dba > osha_criterion_db + 10",
          "message": "SPL >10 dB over criterion: hearing protection alone insufficient — engineering noise control required per ISO 1996-1 hierarchy"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 9613-2:1996",
          "condition": "dB_reduction_needed > 15",
          "message": "Required attenuation > 15 dB: barrier or enclosure study needed — verify with ISO 9613-2 barrier insertion loss calculation"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "ISO 9613-2:1996",
          "condition": "num_identical_sources > 10",
          "message": "Multiple sources (>10): total SPL increase plateaus — adding sources beyond 10× gives <1 dB additional increment"
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "ISO 9613-2:1996",
          "condition": "T_perm_h < 1",
          "message": "Permissible exposure < 1 hour: extreme noise environment — restrict access, mandatory enclosures, and continuous monitoring"
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "ISO 9613-2:1996",
          "condition": "excess_attenuation_db < 2 && distance_m > 100",
          "message": "Low excess attenuation at long range: re-evaluate air absorption per ISO 9613-1 — significant at >100 m above 1 kHz"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },

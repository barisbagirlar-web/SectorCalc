  "standards": [
    {
      "id": "PRO_056",
      "code": "ISO 281:2007 + Amd.1:2008",
      "name": "Rolling Element Bearing Rated Life L10h, ISO 281 Adjusted Life & Lubrication Factor",
      "description": "Rolling Element Bearing Rated Life L10h, ISO 281 Adjusted Life & Lubrication Factor — Mechanical Power Transmission, Maintenance Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "L10_Mr",
          "expression": "Math.pow(C_kn / P_kn, bearing_type)",
          "unit": {
            "ref": "million rev"
          },
          "reference": "ISO 281:2007 §5.1 Eq.(1) — L10 = (C/P)^p",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "L10h",
          "expression": "L10_Mr * 1e6 / (60 * n_rpm)",
          "unit": {
            "ref": "hours"
          },
          "reference": "ISO 281:2007 §5.1 — hours from million revolutions",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "a1_map",
          "expression": "{90: 1.00, 95: 0.64, 96: 0.55, 97: 0.47, 98: 0.37, 99: 0.25}; a1 = a1_map[target_reliability_pct]",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 281:2007 Table 1 — reliability factors a_1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "kappa_eff",
          "expression": "Math.min(Math.max(viscosity_ratio_kappa, 0.1), 4.0); a_ISO = contamination_factor_eC * Math.pow(kappa_eff, 0.54) * Math.pow(C0_kn / P_kn, 0.3)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 281:2007 Annex A §A.4 — simplified a_ISO from κ and e_C (full calculation requires fatigue load limit C_u)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "L_nm_h",
          "expression": "a1 * a_ISO * L10h",
          "unit": {
            "ref": "hours"
          },
          "reference": "ISO 281:2007 §5.2 — L_nm = a_1 · a_ISO · L_10",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "S0",
          "expression": "C0_kn / P_kn",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 76:2006 §4 — S_0 ≥ 1.5 for normal",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ISO 281:2007 + Amd.1:2008",
          "condition": "L_nm_h < 20000",
          "message": "Modified life L_nm < 20,000 h: below typical industrial minimum — improve lubrication (κ), reduce contamination (e_C), or upsize bearing"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 281:2007 + Amd.1:2008",
          "condition": "viscosity_ratio_kappa < 1.0",
          "message": "κ < 1.0: insufficient lubricant film — metal-to-metal contact risk; switch to higher viscosity grade or add EP additive"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 281:2007 + Amd.1:2008",
          "condition": "contamination_factor_eC < 0.4 && L10h > 50000",
          "message": "High L10h but severe contamination: actual life will be far shorter than calculated — implement effective sealing and re-lubrication programme"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 281:2007 + Amd.1:2008",
          "condition": "S0 < 1.5 && bearing_type === 3",
          "message": "Ball bearing S_0 < 1.5: insufficient static reserve for machinery with vibration or shock loading per ISO 76 §4.2"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ISO 281:2007 + Amd.1:2008",
          "condition": "n_rpm * bearing_type > 500000",
          "message": "High speed × load factor: verify bearing speed limit (n·dm) from catalogue — thermal and cage stability may limit life independently of fatigue"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {

  "standards": [
    {
      "id": "PRO_038",
      "code": "TEMA C/B/R 10th Ed.",
      "name": "Shell & Tube Heat Exchanger Thermal Sizing — LMTD, NTU-ε & Fouling Margin",
      "description": "Shell & Tube Heat Exchanger Thermal Sizing — LMTD, NTU-ε & Fouling Margin — Heat Transfer, Process Equipment",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "dT1",
          "expression": "T_hot_in_c - T_cold_out_c; dT2 = T_hot_out_c - T_cold_in_c; LMTD_cf = (Math.abs(dT1 - dT2) < 0.001) ? dT1 : (dT1 - dT2) / Math.log(dT1/dT2)",
          "unit": {
            "ref": "K"
          },
          "reference": "ISO 15547-1:2005 §5.2 — L'Hôpital limit applied when dT1 ≈ dT2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "LMTD_eff",
          "expression": "F_correction * LMTD_cf_K",
          "unit": {
            "ref": "K"
          },
          "reference": "TEMA §7 — multi-pass correction",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "U_dirty",
          "expression": "1 / (1/U_clean_w_m2k + (Rf_hot_m2k_kw + Rf_cold_m2k_kw) * 1000)",
          "unit": {
            "ref": "W/m²·K"
          },
          "reference": "TEMA C-7.1 — combined fouling resistance",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "A_req",
          "expression": "(Q_duty_kw * 1000) / (U_dirty_w_m2k * LMTD_eff_K)",
          "unit": {
            "ref": "m2"
          },
          "reference": "ASME Section VIII / TEMA sizing basis",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "CF",
          "expression": "U_dirty_w_m2k / U_clean_w_m2k * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "TEMA §T-2.4 — CF < 85% triggers cleaning inspection",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Q_max",
          "expression": "Math.min(Q_duty_kw / Math.abs(T_hot_in_c - T_cold_in_c)) * Math.abs(T_hot_in_c - T_cold_in_c); epsilon = Q_duty_kw / (Q_duty_kw / (1 - (T_hot_out_c - T_hot_in_c)/(T_cold_in_c - T_hot_in_c)))",
          "unit": {
            "ref": "pct"
          },
          "reference": "NTU-ε method — Incropera 7th Ed. Ch.11",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "TEMA C/B/R 10th Ed.",
          "condition": "F_correction < 0.75",
          "message": "LMTD F-factor < 0.75: thermal inefficiency and flow maldistribution risk — split into two units or use pure counterflow"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "TEMA C/B/R 10th Ed.",
          "condition": "cleanliness_factor_pct < 85",
          "message": "Cleanliness factor < 85%: fouling penalty severe — schedule CIP or mechanical cleaning within 6 months"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "TEMA C/B/R 10th Ed.",
          "condition": "LMTD_eff_K < 5",
          "message": "Effective LMTD < 5 K: very large surface area required — evaluate stream mixing or upstream temperature shift"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "TEMA C/B/R 10th Ed.",
          "condition": "U_clean_w_m2k < 200 && Q_duty_kw > 1000",

  "standards": [
    {
      "id": "PRO_023",
      "code": "AIAG SPC 2nd Edition",
      "name": "Process Capability (Cp / Cpk / Pp / Ppk), PPM Defect Rate & Quality Loss Function",
      "description": "Process Capability (Cp / Cpk / Pp / Ppk), PPM Defect Rate & Quality Loss Function — Quality Engineering, Six Sigma",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Tolerance_Band",
          "expression": "usl - lsl",
          "unit": {
            "ref": "unit"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Cp",
          "expression": "Tolerance_Band / (6 * within_sigma)",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Z_USL",
          "expression": "(usl - process_mean) / within_sigma",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Z_LSL",
          "expression": "(process_mean - lsl) / within_sigma",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Cpk",
          "expression": "MIN(Z_USL, Z_LSL) / 3",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Pp",
          "expression": "overall_sigma > 0 ? Tolerance_Band / (6 * overall_sigma) : Cp",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Ppk",
          "expression": "overall_sigma > 0 ? MIN((usl - process_mean) / (3 * overall_sigma), (process_mean - lsl) / (3 * overall_sigma)) : Cpk",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "P_defect_USL",
          "expression": "1 - NORMSDIST(Z_USL)",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "P_defect_LSL",
          "expression": "NORMSDIST(-ABS(Z_LSL))",
          "unit": {
            "ref": "—"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Total_PPM",
          "expression": "(P_defect_USL + P_defect_LSL) * 1000000",
          "unit": {
            "ref": "PPM"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Sigma_Level_ST",
          "expression": "Cpk * 3",
          "unit": {
            "ref": "σ"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Sigma_Level_LT",
          "expression": "Cpk * 3 - 1.5",
          "unit": {
            "ref": "σ"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Daily_Defects",
          "expression": "(Total_PPM / 1000000) * daily_production_volume",
          "unit": {
            "ref": "parts/day"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Daily_Quality_Cost_USD",
          "expression": "Daily_Defects * cost_per_defective_usd",
          "unit": {
            "ref": "USD/day"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "Annual_Quality_Cost_USD",
          "expression": "Daily_Quality_Cost_USD * 250",
          "unit": {
            "ref": "USD/year"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "Cpk_Gap",
          "expression": "target_cpk_val - Cpk",
          "unit": {
            "ref": "—"
          },
          "reference": ""
        },
        {
          "id": "F17",
          "output": "Centering_Index",
          "expression": "1 - ABS(2 * process_mean - usl - lsl) / Tolerance_Band",
          "unit": {
            "ref": "—"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "AIAG SPC / IATF 16949",
          "condition": "Cpk < 1.0",
          "message": "PROCESS INCAPABLE — Cpk < 1.0: Process cannot meet specification. Defect rate is measured in percent, not PPM. Immediate containment (100% inspection) mandatory. Root cause analysis and process redesign required before resuming normal production."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "IATF 16949 Clause 8.3.3 / PPAP",
          "condition": "Cpk >= 1.0 && Cpk < target_cpk_val",
          "message": "CAPABILITY BELOW REQUIREMENT: Cpk is below the required target. Customer PPAP submission will be rejected. For automotive (IATF 16949): Cpk ≥ 1.33 is mandatory for production approval. Variance reduction required."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "AIAG SPC — Centering Analysis",
          "condition": "Cp > Cpk * 1.33",
          "message": "PROCESS OFF-CENTRE: Cp is significantly higher than Cpk. Process has good potential width but is shifted from nominal. Re-centering alone (tool offset, fixture adjustment) could reduce PPM dramatically without improving process variation."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "AIAG SPC — Cp vs Pp Analysis",
          "condition": "Cpk > 0 && Ppk > 0 && (Cpk - Ppk) > 0.3",
          "message": "SIGNIFICANT Cpk–Ppk GAP (>0.3): Long-term variation substantially exceeds short-term. Special causes (tool wear, material lot changes, operator shifts, temperature drift) are present. SPC control chart review and MSA re-evaluation required."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Taguchi Loss Function / COQ",
          "condition": "Annual_Quality_Cost_USD > 50000",
          "message": "Annual quality cost exceeds $50,000: This Cpk level is generating significant financial loss. Investment in process improvement, SPC implementation, or machine capability upgrade will deliver measurable ROI. Present to management with this annual cost figure."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "ISO 22514-2 Process Centering",
          "condition": "Centering_Index < 0.7",
          "message": "Poor process centering (index < 0.70): Mean is more than 30% of tolerance from nominal. Asymmetric defect distribution — one side generating significantly more rejects. Investigate systematic bias: fixture wear, tool offset error, or raw material dimensional shift."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "usl",
        "lsl",
        "process_mean",
        "within_sigma",
        "subgroup_size_n",
        "total_samples_N",
        "daily_production_volume",
        "cost_per_defective_usd",
        "target_cpk",
        "target_cpk_val"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",

  "standards": [
    {
      "id": "PRO_016",
      "code": "VDI 2230 Part 1:2015",
      "name": "Bolted Joint Tightening Torque, Preload & Von Mises Utilisation (VDI 2230)",
      "description": "Bolted Joint Tightening Torque, Preload & Von Mises Utilisation (VDI 2230) — Mechanical Engineering, Fastener Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "d2_pitch_diam",
          "expression": "nominal_diameter_mm - (0.649519 * thread_pitch_mm)",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "d3_minor_diam",
          "expression": "nominal_diameter_mm - (1.226869 * thread_pitch_mm)",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "A_stress",
          "expression": "(3.14159 / 4) * POWER((d2_pitch_diam + d3_minor_diam) / 2, 2)",
          "unit": {
            "ref": "mm2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "F_preload_max",
          "expression": "(preload_utilisation_pct / 100) * yield_strength_mpa * A_stress",
          "unit": {
            "ref": "N"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "F_preload_min",
          "expression": "F_preload_max / alpha_val",
          "unit": {
            "ref": "N"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "lead_angle_rad",
          "expression": "3.14159 * thread_pitch_mm / (3.14159 * d2_pitch_diam)",
          "unit": {
            "ref": "rad"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "thread_flank_angle_rad",
          "expression": "(30 * 3.14159) / 180",
          "unit": {
            "ref": "rad"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "friction_thread_eff",
          "expression": "friction_thread_mu_g / (3.14159 * POWER(POWER(1, 0.5 - POWER(lead_angle_rad, 0.5)), 0.5))",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "T_thread",
          "expression": "F_preload_max * (d2_pitch_diam / 2) * ((thread_pitch_mm / (3.14159 * d2_pitch_diam)) + friction_thread_mu_g / 0.866)",
          "unit": {
            "ref": "N·mm"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "T_bearing",
          "expression": "F_preload_max * friction_bearing_mu_k * (bearing_diameter_dw_mm / 2)",
          "unit": {
            "ref": "N·mm"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "T_tightening_Nmm",
          "expression": "T_thread + T_bearing",
          "unit": {
            "ref": "N·mm"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "T_tightening_Nm",
          "expression": "T_tightening_Nmm / 1000",
          "unit": {
            "ref": "Nm"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "sigma_tensile",
          "expression": "F_preload_max / A_stress",
          "unit": {
            "ref": "MPa"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "tau_torsion",
          "expression": "(T_thread * (d2_pitch_diam / 2)) / (0.196 * POWER(d3_minor_diam, 3))",
          "unit": {
            "ref": "MPa"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "sigma_vonMises",
          "expression": "SQRT(POWER(sigma_tensile, 2) + 3 * POWER(tau_torsion, 2))",
          "unit": {
            "ref": "MPa"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "Utilisation_pct",
          "expression": "(sigma_vonMises / yield_strength_mpa) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F17",
          "output": "K_nut_factor",
          "expression": "T_tightening_Nmm / (F_preload_max * nominal_diameter_mm)",
          "unit": {
            "ref": "—"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "VDI 2230 Eq.(R9) Von Mises Criterion",
          "condition": "Utilisation_pct > 100",
          "message": "BOLT YIELDS DURING ASSEMBLY: Combined Von Mises stress exceeds yield strength. Bolt will neck and lose preload or fracture during tightening. Actions: (1) Lubricate to reduce μG and μK, (2) Reduce preload utilisation target to 80%, (3) Use higher-grade bolt."
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "VDI 2230 / ISO 16047",
          "condition": "Utilisation_pct > 90 && Utilisation_pct <= 100",
          "message": "Near-yield tightening: Utilisation 90–100%. Any friction variation above nominal will cause bolt yield. Calibrated torque wrench mandatory. Re-verify after first thermal cycle."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "VDI 2230 Table A8 / ISO 16047",
          "condition": "friction_thread_mu_g > 0.16",
          "message": "High thread friction (μG > 0.16): Most of applied torque is consumed overcoming friction — actual preload achieved will be much lower than calculated. Use thread lubricant or anti-seize compound. Re-measure μ with torque-angle method."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "VDI 2230 Section 5.4.3",
          "condition": "alpha_val > 1.6",
          "message": "High scatter factor (αA > 1.6): Actual preload may be only 60% of target. Joint may not achieve required clamp force. Switch to hydraulic tensioning (αA = 1.2) or angle-controlled tightening (αA = 1.05)."
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "VDI 2230 / Junker Vibration Test",
          "condition": "joint_type === 'Dynamic / Fatigue — vibration, alternating load' && preload_utilisation_pct < 80",
          "message": "FATIGUE JOINT — INSUFFICIENT PRELOAD: Dynamic joints require high preload to prevent fretting and self-loosening (Junker effect). Preload below 80% Rp0.2 with vibration loading is a known failure mode. Use thread-locking compound or prevailing torque nut."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "ISO 16047 K-factor Reference",
          "condition": "K_nut_factor > 0.25",
          "message": "High K-factor (>0.25): Friction-dominated joint. Standard torque tables assume K≈0.20. Your actual preload from nameplate torque values may be 25–40% lower than expected. Re-calibrate using measured K-factor for this specific surface combination."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {

  "standards": [
    {
      "id": "PRO_080",
      "code": "Perry's Chemical Engineers' Handbook 9th Ed. §11.12",
      "name": "Industrial Evaporator Design — Steam Economy, Boiling Point Rise & Heat Transfer Area",
      "description": "Industrial Evaporator Design — Steam Economy, Boiling Point Rise & Heat Transfer Area — Chemical Process Engineering, Evaporation",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "V_kg_h",
          "expression": "feed_flow_kg_h * (1 - feed_conc_pct / product_conc_pct); P_kg_h = feed_flow_kg_h - V_kg_h",
          "unit": {
            "ref": "kg/h"
          },
          "reference": "Overall mass balance: F = V + P",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "T_steam_c",
          "expression": "100 * Math.pow(steam_pressure_bar, 0.25) + 33 * Math.pow(steam_pressure_bar, 0.05) - 33; T_evap_sat_c = 100 * Math.pow(evap_pressure_bar, 0.25) + 33 * Math.pow(evap_pressure_bar, 0.05) - 33; T_boil_c = T_evap_sat_c + BPR_k",
          "unit": {
            "ref": "degC"
          },
          "reference": "Antoine approximation for water saturation temperature — Perry's 9th Ed. §2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "dT_eff",
          "expression": "T_steam_c - T_boil_c",
          "unit": {
            "ref": "K"
          },
          "reference": "Effective ΔT = T_steam − T_boil",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "lambda_steam_kj_kg",
          "expression": "2676 - 2.09 * T_steam_c; cp_feed_kj_kgk = 4.18 * (1 - feed_conc_pct/100) + 1.5 * feed_conc_pct/100; lambda_evap_kj_kg = 2676 - 2.09 * T_boil_c; Q_preheat_kw = feed_flow_kg_h / 3600 * cp_feed_kj_kgk * (T_boil_c - feed_temp_c); Q_evap_kw = V_kg_h / 3600 * lambda_evap_kj_kg; Q_steam_kw = Q_preheat_kw + Q_evap_kw",
          "unit": {
            "ref": "kW"
          },
          "reference": "Total duty = preheat load + evaporation load",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "S_kg_h",
          "expression": "Q_steam_kw * 3600 / (2676 - 2.09 * T_steam_c); steam_economy = V_kg_h / S_kg_h",
          "unit": {
            "ref": "kg/h, kg water/kg steam"
          },
          "reference": "Steam economy = kg evaporation / kg steam consumed",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "A_evap_m2",
          "expression": "Q_steam_kw * 1000 / (U_overall_w_m2k * dT_eff)",
          "unit": {
            "ref": "m2"
          },
          "reference": "A = Q / (U·ΔT) — fundamental heat transfer equation",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "Perry's Chemical Engineers' Handbook 9th Ed. §11.12",
          "condition": "dT_eff < 10",
          "message": "ΔT_eff < 10 K: economically marginal single-effect operation — evaluate multiple-effect evaporation (economy improves linearly with number of effects)"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "Perry's Chemical Engineers' Handbook 9th Ed. §11.12",
          "condition": "BPR_k > 15",
          "message": "BPR > 15 K: large boiling point rise severely reduces ΔT and increases steam consumption — evaluate mechanical vapour recompression (MVR) for high-BPR solutions"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "Perry's Chemical Engineers' Handbook 9th Ed. §11.12",
          "condition": "A_evap_m2 > 1000",
          "message": "Large heat transfer area (> 1000 m²): multiple evaporator bodies likely required — evaluate falling film with large-diameter tubes for reduced fouling"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "Perry's Chemical Engineers' Handbook 9th Ed. §11.12",
          "condition": "T_boil_c > 100 && product_conc_pct > 50",
          "message": "High boiling temperature at elevated concentration: thermal degradation risk for heat-sensitive products (food, pharma) — deepen vacuum to reduce T_boil"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Perry's Chemical Engineers' Handbook 9th Ed. §11.12",
          "condition": "steam_economy < 1.0 && V_kg_h > 10000",
          "message": "Low economy at large evaporation rate: high operating cost — each additional effect saves ~35–40% steam; payback on triple-effect typically < 2 years"
        }
      ],

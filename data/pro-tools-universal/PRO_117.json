      },
      {
        "mode": "Compression-controlled brittle failure",
        "effect": "Sudden collapse without warning",
        "sev": 8,
        "occ": 3,
        "det": 4,
        "mitigation": "",
        "when": "x/d > 0.45"
      },
      {
        "mode": "Diagonal shear failure",
        "effect": "Brittle shear failure",
        "sev": 8,
        "occ": 4,
        "det": 5,
        "mitigation": "",
        "when": "V_Ed > V_Rd * 0.9"
      },
      {
        "mode": "Concrete strut crushing",
        "effect": "Brittle web failure",
        "sev": 8,
        "occ": 3,
        "det": 2,
        "mitigation": "",
        "when": "V_Rds > V_Rdmax"
      },
      {
        "mode": "Stirrup yielding",
        "effect": "Excessive cracking before failure",
        "sev": 5,
        "occ": 3,
        "det": 4,

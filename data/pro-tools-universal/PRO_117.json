  "standards": [
    {
      "id": "PRO_117",
      "code": "EN 1992-1-1",
      "name": "RC Beam Shear & Flexure Calculator",
      "description": "RC Beam Shear & Flexure Calculator — Construction, Reinforced Concrete",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "rho_l",
          "expression": "A_s / (b_w * d)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "out_2",
          "expression": "// ── EN 1992-1-1 BRANCH ──────────────────────────────────────────",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F3",
          "output": "f_cd",
          "expression": "alpha_cc * f_ck / gamma_c",
          "unit": {
            "ref": "MPa"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "f_yd",
          "expression": "f_yk / gamma_s",
          "unit": {
            "ref": "MPa"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "lambda",
          "expression": "f_ck <= 50 ? 0.8 : 0.8 - (f_ck - 50) / 400",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "eta",
          "expression": "f_ck <= 50 ? 1.0 : 1.0 - (f_ck - 50) / 200",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "x",
          "expression": "A_s * f_yd / (eta * f_cd * b_w * lambda)",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "z",
          "expression": "min(d - 0.5 * lambda * x, 0.95 * d)",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "M_Rd",
          "expression": "A_s * f_yd * z / 1e6",
          "unit": {
            "ref": "kN.m"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "k",
          "expression": "min(1 + sqrt(200 / d), 2.0)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "rho_l_limited",
          "expression": "min(rho_l, 0.02)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "V_Rdc",
          "expression": "(0.18/gamma_c * k * (100 * rho_l_limited * f_ck)^(1/3)) * b_w * d / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "V_Rds",
          "expression": "A_sv / s_v * z * f_yd * cot_theta / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "v1",
          "expression": "f_ck <= 50 ? 0.6 : 0.6 * (1 - (f_ck - 50) / 200)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "V_Rdmax",
          "expression": "b_w * z * v1 * f_cd / (cot_theta + 1/cot_theta) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "V_Rd",
          "expression": "min(V_Rds, V_Rdmax)",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F17",
          "output": "UC_flexure",
          "expression": "M_Ed / M_Rd",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F18",
          "output": "UC_shear",
          "expression": "V_Ed / V_Rd",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F19",
          "output": "UC",
          "expression": "max(UC_flexure, UC_shear)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F20",
          "output": "out_20",
          "expression": "// ── ACI 318 BRANCH ──────────────────────────────────────────────",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F21",
          "output": "beta1",
          "expression": "f_c_prime <= 28 ? 0.85 : max(0.85 - 0.05 * (f_c_prime - 28) / 7, 0.65)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F22",
          "output": "a",
          "expression": "A_s * f_y / (0.85 * f_c_prime * b_w)",
          "unit": {
            "ref": "mm"
          },
          "reference": ""
        },
        {
          "id": "F23",
          "output": "c",
          "expression": "a / beta1",
          "unit": {
            "ref": "mm"
          },
          "reference": ""
        },
        {
          "id": "F24",
          "output": "epsilon_t",
          "expression": "0.003 * (d - c) / c",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F25",
          "output": "phi_f",
          "expression": "epsilon_t >= 0.005 ? 0.9 : (epsilon_t >= 0.002 ? 0.65 + 0.25 * (epsilon_t - 0.002) / 0.003 : 0.65)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F26",
          "output": "M_Rd_ACI",
          "expression": "phi_f * A_s * f_y * (d - a / 2) / 1e6",
          "unit": {
            "ref": "kN.m"
          },
          "reference": ""
        },
        {
          "id": "F27",
          "output": "V_c",
          "expression": "0.17 * lambda_concrete * sqrt(f_c_prime) * b_w * d / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F28",
          "output": "V_s",
          "expression": "A_sv * f_y * d / s_v / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F29",
          "output": "V_Rd_ACI",
          "expression": "phi_v * (V_c + V_s)",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F30",
          "output": "UC_flexure_ACI",
          "expression": "M_Ed / M_Rd_ACI",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F31",
          "output": "UC_shear_ACI",
          "expression": "V_Ed / V_Rd_ACI",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        },
        {
          "id": "F32",
          "output": "UC_ACI",
          "expression": "max(UC_flexure_ACI, UC_shear_ACI)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        }
      ],
      "validation": [
        {
          "id": "bw_check",
          "action": "BLOCK",
          "condition": "b_w <= 0",
          "message": "Beam width must be greater than zero."
        },
        {
          "id": "h_check",
          "action": "BLOCK",
          "condition": "h <= 0",
          "message": "Beam height must be greater than zero."
        },
        {
          "id": "d_check",
          "action": "BLOCK",
          "condition": "d <= 0",
          "message": "Effective depth must be greater than zero."
        },
        {
          "id": "d_h_check",
          "action": "BLOCK",
          "condition": "d >= h",
          "message": "Effective depth cannot exceed total beam height."
        },
        {
          "id": "as_check",
          "action": "BLOCK",
          "condition": "A_s <= 0",
          "message": "Tension reinforcement area must be greater than zero."
        },
        {
          "id": "m_ed_check",
          "action": "BLOCK",
          "condition": "M_Ed < 0",
          "message": "Design moment cannot be negative."
        },
        {
          "id": "v_ed_check",
          "action": "BLOCK",
          "condition": "V_Ed < 0",
          "message": "Design shear force cannot be negative."
        },
        {
          "id": "sv_missing",
          "action": "BLOCK",
          "condition": "A_sv > 0 && s_v == 0",
          "message": "Stirrup spacing required when shear reinforcement is provided."
        },
        {
          "id": "fck_missing_ec2",
          "action": "BLOCK",
          "condition": "designStandard == 'EN_1992_1_1' && (f_ck == 0 || f_ck == undefined)",
          "message": "Concrete cylinder strength f_ck required for EN 1992-1-1."
        },
        {
          "id": "fc_missing_aci",
          "action": "BLOCK",
          "condition": "designStandard == 'ACI_318' && (f_c_prime == 0 || f_c_prime == undefined)",
          "message": "Concrete compressive strength f'_c required for ACI 318."
        },
        {
          "id": "uc_fail",
          "action": "BLOCK",
          "condition": "UC > 1.0",
          "message": "Section FAILS — utilization exceeds 1.0. Redesign required."
        }
      ],
      "warnings": [
        {
          "id": "W_UC_WARN",
          "severity": "WARNING",
          "source": "Engineering Review",
          "condition": "UC > 0.9 && UC <= 1.0",
          "message": "UC = {UC} between 0.90–1.00. Engineering review required before acceptance."
        },
        {
          "id": "W_UC_FAIL",
          "severity": "CRITICAL",
          "source": "Capacity Check",
          "condition": "UC > 1.0",
          "message": "UC = {UC} > 1.00. Section FAILS. Governing mode: {governingMode}. Section must be redesigned."
        },
        {
          "id": "W_XD_EC2",
          "severity": "WARNING",
          "source": "EN 1992-1-1 §5.5(4)",
          "condition": "designStandard == 'EN_1992_1_1' && x/d > 0.45",
          "message": "x/d = {xd} > 0.45. Neutral axis depth limit exceeded per EN 1992-1-1 §5.5(4)."
        },
        {
          "id": "W_EPSILON_ACI",
          "severity": "WARNING",
          "source": "ACI 318 §9.3.3",
          "condition": "designStandard == 'ACI_318' && epsilon_t < 0.005",
          "message": "ε_t = {epsilon_t} < 0.005. Section not tension-controlled. Ductility limited."
        },
        {
          "id": "W_VS_LIMIT",
          "severity": "WARNING",
          "source": "ACI 318 §11.5.7.2",
          "condition": "designStandard == 'ACI_318' && V_s > V_s_max",
          "message": "V_s exceeds V_s_max. Stirrup spacing too large or section insufficient."
        },
        {
          "id": "W_STIRRUP_SPACING",
          "severity": "WARNING",
          "source": "Detailing Rules",
          "condition": "s_v > d/2",
          "message": "Stirrup spacing s_v exceeds maximum permitted (~d/2). Review detailing rules."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "designStandard",
        "b_w",
        "h",
        "d",
        "A_s",
        "M_Ed",
        "V_Ed"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.90",
    "modes": [
      {
        "mode": "Flexural yielding",

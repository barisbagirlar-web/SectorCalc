  "standards": [
    {
      "id": "PRO_104",
      "code": "EN 1996-1-1:2005 (EC6) §5.5, §6.1",
      "name": "Masonry Load-Bearing Wall — Axial Capacity, Slenderness Reduction & Eccentricity Check",
      "description": "Masonry Load-Bearing Wall — Axial Capacity, Slenderness Reduction & Eccentricity Check — Construction, Masonry Structures",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "h_eff_m, lambda",
          "expression": "h_eff_m = wall_height_m * end_condition; lambda = h_eff_m * 1000 / wall_thickness_mm",
          "unit": {
            "ref": "m, dimensionless"
          },
          "reference": "EN 1996-1-1:2005 §5.5.1.2 — h_eff = ρ_n × h; EC6 §6.1.2.2 maximum λ = 27",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "fd_mpa",
          "expression": "fd_mpa = fk_mpa / gamma_M",
          "unit": {
            "ref": "MPa"
          },
          "reference": "EC6 §6.1.2.1 — f_d = f_k / γ_M; design strength accounting for workmanship and material class",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Phi_m",
          "expression": "e_rel = eccentricity_mm / wall_thickness_mm; A_phi = 1 - 2 * e_rel; Phi_m = Math.max(A_phi * (1 - (lambda/140)^2), 0.0)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "EN 1996-1-1 §6.1.2.2 Eq.(G.2) — Φ_m = (1−2e/t)(1−(λ/140)²); Annex G simplified method",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "NRd_kn_m",
          "expression": "NRd_kn_m = Phi_m * wall_thickness_mm * fd_mpa",
          "unit": {
            "ref": "kNpm"
          },
          "reference": "EC6 §6.1.2.1 — N_Rd = Φ_m × t × f_d (per unit length); t in mm, f_d in MPa → kN/m",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "DCR, e_limit_mm",
          "expression": "DCR = N_Ed_kn_m / NRd_kn_m; e_limit_mm = wall_thickness_mm / 3",
          "unit": {
            "ref": "dimensionless, mm"
          },
          "reference": "DCR ≤ 1.0 required; e_limit = t/3 per EC6 §6.1.2.2 — maximum allowable eccentricity",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "t_req_mm",
          "expression": "t_req_mm = Math.ceil(N_Ed_kn_m / (Phi_m * fd_mpa))",
          "unit": {
            "ref": "mm"
          },
          "reference": "Rearranged from N_Rd: t_req = N_Ed / (Φ_m × f_d); round up to standard block size",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [
        {
          "id": "V1",
          "action": "BLOCK",
          "condition": "DCR > 1.0",
          "message": "Wall load capacity exceeded — increase thickness, use higher-strength masonry units, or reduce applied load"
        },
        {
          "id": "V2",
          "action": "BLOCK",
          "condition": "lambda > 27",
          "message": "Slenderness ratio > 27: EC6 §6.1.2.2 maximum limit — wall is too slender; add pilasters, returns, or intermediate lateral supports"
        },
        {
          "id": "V3",
          "action": "WARN",
          "condition": "eccentricity_mm > wall_thickness_mm / 3",
          "message": "Eccentricity exceeds t/3: EC6 §6.1.2.2 limit — Φ_m approaches zero; review structural layout to reduce eccentricity; consider larger wall thickness"
        }
      ],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "",
          "condition": "lambda > 20 && end_condition === 1.0",
          "message": "High slenderness with pinned ends: Φ_m strongly reduced — adding simple floor/roof tie at top converts to fixed-pin (ρ=0.75), increasing N_Rd by ~25%"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "",
          "condition": "fk_mpa < 3.5 && N_Ed_kn_m > 100",
          "message": "Low-strength masonry under significant load: specify minimum M4 mortar and Category I units with testing — avoid using generic f_k without material testing on site"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "",
          "condition": "DCR > 0.80",
          "message": "Utilisation > 80%: marginal capacity for concentrated loads (beam bearings) — verify bearing stress at load introduction point per EC6 §6.1.3"
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "",
          "condition": "wall_thickness_mm < 100 && N_Ed_kn_m > 50",
          "message": "Thin wall (< 100 mm) under significant vertical load: structural masonry requires minimum 100 mm; check if wall is load-bearing or partition — reclassify if non-structural"
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "",
          "condition": "eccentricity_mm > wall_thickness_mm * 0.25 && lambda > 18",
          "message": "Combined high eccentricity + slenderness: double penalty on Φ_m — capacity is severely reduced; detailed second-order analysis required per EC6 Annex G"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "wall_height_m",
        "wall_thickness_mm",
        "fk_mpa",
        "gamma_M",
        "N_Ed_kn_m",
        "eccentricity_mm",
        "end_condition"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },
  "legalNotice": "⚠ Engineering decision support only — verify before use. This is a technical simulation, not professional engineering advice."
}

  "standards": [
    {
      "id": "PRO_072",
      "code": "IEC 60364-5-52:2009",
      "name": "Power Cable Ampacity, Derating & Voltage Drop Sizing — LV / MV Distribution",
      "description": "Power Cable Ampacity, Derating & Voltage Drop Sizing — LV / MV Distribution — Electrical Engineering, Cable Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "T_ref",
          "expression": "(max_conductor_temp_c === 70) ? 30 : 30; Ct = Math.sqrt((max_conductor_temp_c - ambient_temp_c) / (max_conductor_temp_c - T_ref))",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "IEC 60364-5-52 §523.4 — C_t = √[(T_max − T_amb)/(T_max − T_ref)]",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Iz_a",
          "expression": "base_ampacity_a * Ct * grouping_factor",
          "unit": {
            "ref": "A"
          },
          "reference": "IEC 60364-5-52 §523 — I_z = I_z0 × C_t × C_g × C_soil",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "amp_util",
          "expression": "load_current_a / Iz_a",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "I_L / I_z ≤ 1.0 required per IEC 60364-5-52 §523.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "rho_20",
          "expression": "(cable_mm2 <= 630) ? 0.0172 : 0.0172; R_dc_ohm_km = rho_20 * 1000 / cable_mm2 * (1 + 0.00393 * (max_conductor_temp_c - 20))",
          "unit": {
            "ref": "Ω/km"
          },
          "reference": "IEC 60228:2004 — ρ_Cu = 0.0172 Ω·mm²/m at 20°C",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "phases",
          "expression": "(supply_voltage_v < 400) ? 1 : 3; pf = 0.85; sin_phi = Math.sqrt(1 - pf*pf); X_ohm_km = 0.08; R_total = R_dc_ohm_km * cable_length_m / 1000; X_total = X_ohm_km * cable_length_m / 1000; dU_v = (phases === 3) ? Math.sqrt(3) * load_current_a * (R_total * pf + X_total * sin_phi) : 2 * load_current_a * (R_total * pf + X_total * sin_phi)",
          "unit": {
            "ref": "V"
          },
          "reference": "IEC 60364-5-52 Annex G / BS 7671 App.12 — ΔU = √3·I·(R·cosφ + X·sinφ)·L for 3-phase",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "dU_pct",
          "expression": "dU_v / supply_voltage_v * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "IEC 60364-5-52 / NEC §210.19 — max 3% for branch circuits",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "IEC 60364-5-52:2009",
          "condition": "dU_pct > 3 && supply_voltage_v === 400",
          "message": "Voltage drop > 3% on LV system: motor terminal voltage will drop below 95% of rated — IEC 60034-1 requires ±5% supply voltage tolerance; upsize cable"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "IEC 60364-5-52:2009",
          "condition": "amp_util > 0.85",
          "message": "Ampacity utilisation > 85%: limited headroom for future load growth or harmonic derating — consider upsize to next standard cross-section"
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "IEC 60364-5-52:2009",
          "condition": "ambient_temp_c > 40 && max_conductor_temp_c === 70",
          "message": "PVC cable in high-ambient environment: C_t severely derated above 40°C — upgrade to XLPE (90°C) insulation for 40–60°C installations"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "IEC 60364-5-52:2009",
          "condition": "cable_length_m > 500 && supply_voltage_v === 400",
          "message": "Long 400 V run (>500 m): voltage drop likely dominates over ampacity — size cable for ΔU ≤ 3%, not ampacity; significant upsize typically required"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "IEC 60364-5-52:2009",
          "condition": "cable_mm2 >= 300 && grouping_factor < 0.70",
          "message": "Large cables in groups: skin and proximity effect add to AC resistance — verify with IEC 60287-1-1 AC resistance correction for cables > 150 mm²"
        }
      ],

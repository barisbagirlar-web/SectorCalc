  "standards": [
    {
      "id": "PRO_007",
      "code": "API 610 12th Ed. §6.1.14",
      "name": "Pump NPSH Available, Cavitation Index & System Head Curve Analysis",
      "description": "Pump NPSH Available, Cavitation Index & System Head Curve Analysis — Fluid Systems, Pump Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "NPSHa_m",
          "expression": "(P_atm_bar - P_vapour_bar) * 100000 / (fluid_density_kg_m3 * 9.81) + Z_s_m - hL_suction_m",
          "unit": {
            "ref": "m"
          },
          "reference": "NPSHa = (P_atm - P_v)/(ρg) + Z_s - h_Ls — HI ANSI/HI 9.6.1:2012 §2.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "MR",
          "expression": "NPSHa_m / NPSHr_m",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "MR = NPSHa/NPSHr — API 610 §6.1.14: minimum MR = 1.1 (10% margin) for standard service",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "sigma",
          "expression": "NPSHa_m / (static_head_m + pipe_friction_head_m)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Thoma cavitation number σ = NPSHa / H_total",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "H_sys_m",
          "expression": "static_head_m + pipe_friction_head_m",
          "unit": {
            "ref": "m"
          },
          "reference": "H_sys = H_static + H_friction — system curve definition",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Zs_max_m",
          "expression": "(P_atm_bar - P_vapour_bar) * 100000 / (fluid_density_kg_m3 * 9.81) - NPSHr_m - hL_suction_m - 0.5",
          "unit": {
            "ref": "m"
          },
          "reference": "Z_s,max = (P_atm - P_v)/(ρg) - NPSHr - h_Ls - 0.5 m safety — API 610 §6.1.14",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "NPSH_margin_m",
          "expression": "NPSHa_m - NPSHr_m * 1.1",
          "unit": {
            "ref": "m"
          },
          "reference": "Positive = adequate (API 610 10% margin met)",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "API 610 12th Ed. §6.1.14",
          "condition": "MR < 1.3 && P_vapour_bar > 0.2",
          "message": "Low NPSH margin on hot/volatile liquid: API 610 requires minimum 1.3× margin for T > 65°C or volatile hydrocarbons — redesign suction system"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "API 610 12th Ed. §6.1.14",
          "condition": "Z_s_m < -8",
          "message": "Suction lift > 8 m: practical centrifugal pump limit in most water applications — consider submersible pump or lower pump installation"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "API 610 12th Ed. §6.1.14",
          "condition": "hL_suction_m > NPSHr_m * 0.5",
          "message": "Suction losses > 50% of NPSHr: suction pipe undersized — upsize suction pipe by one nominal size or eliminate elbows; target h_Ls < 0.3×NPSHr"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "API 610 12th Ed. §6.1.14",
          "condition": "P_atm_bar < 0.85",
          "message": "Low atmospheric pressure (altitude > 1500 m): NPSHa significantly reduced — altitude correction mandatory per HI 9.6.1 §2.3 for installations above 1500 m ASL"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "API 610 12th Ed. §6.1.14",
          "condition": "sigma < 0.10",
          "message": "Thoma σ < 0.10: pump operating near cavitation onset on system curve — verify cavitation-free zone on pump curve and consider variable speed operation"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "P_atm_bar",
        "P_vapour_bar",
        "Z_s_m",
        "hL_suction_m",
        "NPSHr_m",
        "fluid_density_kg_m3",
        "static_head_m",
        "pipe_friction_head_m"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },

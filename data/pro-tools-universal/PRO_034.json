  "standards": [
    {
      "id": "PRO_034",
      "code": "AACE International RP 18R-97 Cost Escalation",
      "name": "Project Cost Escalation, Real Discount Rate & Inflation-Adjusted Budget (AACE / Fisher Equation)",
      "description": "Project Cost Escalation, Real Discount Rate & Inflation-Adjusted Budget (AACE / Fisher Equation) — Corporate Finance, Project Cost Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Base_Total_Cost_USD",
          "expression": "base_material_cost_usd + base_labour_cost_usd + base_subcontract_cost_usd",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Effective_Duration_yrs",
          "expression": "project_duration_years * spend_timing_factor",
          "unit": {
            "ref": "years"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Escalated_Material_USD",
          "expression": "base_material_cost_usd * POWER(1 + material_escalation_pct_yr / 100, Effective_Duration_yrs)",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Escalated_Labour_USD",
          "expression": "base_labour_cost_usd * POWER(1 + labour_escalation_pct_yr / 100, Effective_Duration_yrs)",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Escalated_Subcontract_USD",
          "expression": "base_subcontract_cost_usd * POWER(1 + subcontract_escalation_pct_yr / 100, Effective_Duration_yrs)",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Total_Escalated_Base_USD",
          "expression": "Escalated_Material_USD + Escalated_Labour_USD + Escalated_Subcontract_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Escalation_Amount_USD",
          "expression": "Total_Escalated_Base_USD - Base_Total_Cost_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Escalation_Pct",
          "expression": "(Escalation_Amount_USD / Base_Total_Cost_USD) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Contingency_USD",
          "expression": "Total_Escalated_Base_USD * (risk_contingency_pct / 100)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Budget_with_Contingency_USD",
          "expression": "Total_Escalated_Base_USD + Contingency_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Management_Reserve_USD",
          "expression": "Budget_with_Contingency_USD * (management_reserve_pct / 100)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Total_Project_Authorisation_USD",
          "expression": "Budget_with_Contingency_USD + Management_Reserve_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Real_Discount_Rate_pct",
          "expression": "((1 + nominal_discount_rate_pct / 100) / (1 + general_inflation_rate_pct / 100) - 1) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "NPV_Cost_Real_USD",
          "expression": "Total_Project_Authorisation_USD / POWER(1 + Real_Discount_Rate_pct / 100, project_duration_years)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "Fisher Equation / Macroeconomic Risk",
          "condition": "Real_Discount_Rate_pct < 0",
          "message": "NEGATIVE REAL DISCOUNT RATE: Inflation exceeds nominal WACC. Every deferred cost actually costs more in real terms — there is no financial benefit to delaying project expenditure. This typically signals a hyperinflationary environment. Nominal cash flow analysis is required instead of real."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "AACE RP 18R-97 Escalation Alert",
          "condition": "Escalation_Pct > 20",
          "message": "HIGH ESCALATION (>20%): Cost escalation exceeds 20% of base estimate. This level typically represents a material budget risk. Project sanction budget must include full escalation provision — underfunded projects are the primary cause of cost overruns in capital projects. Escalate to project sponsor."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "Procurement Risk Management",
          "condition": "material_escalation_pct_yr > labour_escalation_pct_yr * 2",
          "message": "MATERIAL ESCALATION OUTPACING LABOUR >2×: Commodity price volatility is the dominant risk. Evaluate: (1) Fixed-price supply contracts with early procurement, (2) Material price escalation clauses in contracts, (3) Alternative materials or supplier diversification."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "AACE Estimate Classification",
          "condition": "risk_contingency_pct < 5",
          "message": "LOW CONTINGENCY (<5%): Insufficient contingency for any estimate class. AACE Class 3 (budget estimate) requires 10–20%. Underfunding contingency is the most common cause of cost overruns on capital projects."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "PMBOK 7th Edition — Reserve Analysis",
          "condition": "project_duration_years > 3 && management_reserve_pct === 0",
          "message": "NO MANAGEMENT RESERVE on multi-year project: Projects >3 years face significant scope uncertainty. Zero management reserve leaves no headroom for authorised scope additions. PMBOK recommends 5–10% management reserve separate from risk contingency."
        },
        {
          "id": "W6",
          "severity": "CRITICAL",
          "source": "Project Cost Control",
          "condition": "Escalation_Amount_USD > Contingency_USD",
          "message": "ESCALATION EXCEEDS CONTINGENCY: Price escalation alone is larger than the entire contingency reserve. Contingency will be fully consumed by inflation before any technical risk event. Increase contingency or renegotiate fixed-price contracts to include escalation clauses."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "base_material_cost_usd",
        "base_labour_cost_usd",
        "material_escalation_pct_yr",
        "labour_escalation_pct_yr",
        "project_duration_years",
        "spend_profile",
        "spend_timing_factor",
        "nominal_discount_rate_pct",
        "general_inflation_rate_pct",
        "risk_contingency_pct"
      ]
    }
  ],

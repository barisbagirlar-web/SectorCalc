  "standards": [
    {
      "id": "PRO_079",
      "code": "AISC Design Guide 7 (Crane Buildings) 2nd Ed.",
      "name": "Crane Runway Beam — Maximum Wheel Load, Vertical & Lateral Bending, Fatigue Check",
      "description": "Crane Runway Beam — Maximum Wheel Load, Vertical & Lateral Bending, Fatigue Check — Structural Engineering, Material Handling",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "N_wheels_per_rail",
          "expression": "2; P_static_kn = (crane_capacity_kn + trolley_weight_kn + bridge_weight_kn / 2) / N_wheels_per_rail",
          "unit": {
            "ref": "kN"
          },
          "reference": "CMAA 70 §3.3 — max wheel load when trolley at end of bridge",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "phi_v",
          "expression": "{A:1.10, C:1.15, D:1.20, E:1.25, F:1.30}[crane_class]; P_factored_kn = P_static_kn * phi_v",
          "unit": {
            "ref": "dimensionless, kN"
          },
          "reference": "AISC Design Guide 7 Table 2.1 / CMAA 70 — vertical dynamic impact factor by crane class",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "beam_self_wt_kn_m",
          "expression": "0.8; M_max_knm = P_factored_kn * runway_beam_span_m / 4 + beam_self_wt_kn_m * Math.pow(runway_beam_span_m, 2) / 8",
          "unit": {
            "ref": "kNm"
          },
          "reference": "Midspan moment: moving concentrated load at ¼-span produces near-maximum moment",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "S_x_cm3",
          "expression": "2 * Ix_beam_cm4 / beam_depth_mm * 10; sigma_bend_mpa = M_max_knm * 1e6 / (S_x_cm3 * 1e3)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "σ = M/S_x",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "H_lat_kn",
          "expression": "0.20 * (crane_capacity_kn + trolley_weight_kn)",
          "unit": {
            "ref": "kN"
          },
          "reference": "AISC DG7 §3.2 / CMAA 70 §3.5 — lateral thrust H = 20% of (lifted load + trolley) for electric overhead cranes",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "fatigue_cat",
          "expression": "{A:'E (120 MPa)', C:'E (110 MPa)', D:'D (110 MPa)', E:'C (165 MPa, check)', F:'B (165 MPa, check)'}[crane_class]; stress_range_mpa = sigma_bend_mpa * 0.6",
          "unit": {
            "ref": "text, MPa"
          },
          "reference": "AISC DG7 §5 / ASCE 7-22 Table 15.4-2 — runway beam fatigue category per crane class",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "AISC Design Guide 7 (Crane Buildings) 2nd Ed.",
          "condition": "crane_class === 'E' || crane_class === 'F'",
          "message": "Class E/F crane: heavy fatigue regime — runway beam fatigue life governs over static strength; use AISC Category B/C weld details and specify weld quality per AWS D1.1"
        },
        {
          "id": "W2",
          "severity": "INFO",
          "source": "AISC Design Guide 7 (Crane Buildings) 2nd Ed.",
          "condition": "H_lat_kn > crane_capacity_kn * 0.25",
          "message": "High lateral thrust: verify top flange bracing and rail clip design — AISC DG7 §4 requires continuous top flange bracing for heavy crane classes"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "AISC Design Guide 7 (Crane Buildings) 2nd Ed.",
          "condition": "bridge_span_m > 20 && crane_class === 'D'",
          "message": "Long bridge span + moderate duty: trolley skewing forces become significant — verify bumper and end stop design per CMAA 70 §3.6"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "AISC Design Guide 7 (Crane Buildings) 2nd Ed.",
          "condition": "sigma_bend_mpa > 140",
          "message": "High bending stress: verify lateral-torsional buckling of top compression flange per AISC 360-22 F2 — crane beams often unbraced between columns"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "AISC Design Guide 7 (Crane Buildings) 2nd Ed.",
          "condition": "P_factored_kn > 500",
          "message": "Wheel load > 500 kN: heavy crane — verify column base plate, anchor bolts, and foundation design for combined gravity and lateral crane thrust per AISC DG1"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },

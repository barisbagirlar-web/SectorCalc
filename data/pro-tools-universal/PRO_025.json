  "standards": [
    {
      "id": "PRO_025",
      "code": "ASCE 7-22 Minimum Design Loads",
      "name": "Industrial Roof Structural Load, Area Calculation & Material Cost (ASCE 7 / EN 1991)",
      "description": "Industrial Roof Structural Load, Area Calculation & Material Cost (ASCE 7 / EN 1991) — Civil & Structural Engineering, Industrial Buildings",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Pitch_rad",
          "expression": "(roof_pitch_deg * 3.14159) / 180",
          "unit": {
            "ref": "rad"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Slant_Half_Width_m",
          "expression": "(building_width_m / 2) / MAX(COS(Pitch_rad), 0.0001)",
          "unit": {
            "ref": "m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Gross_Roof_Area_m2",
          "expression": "2 * Slant_Half_Width_m * building_length_m",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Overhang_Area_m2",
          "expression": "eave_overhang_m * (2 * building_length_m + 2 * building_width_m)",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Total_Roof_Area_m2",
          "expression": "Gross_Roof_Area_m2 + Overhang_Area_m2",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Order_Area_m2",
          "expression": "Total_Roof_Area_m2 * (1 + waste_allowance_pct / 100)",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Material_Cost_USD",
          "expression": "Order_Area_m2 * material_cost_usd_m2",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Labour_Cost_USD",
          "expression": "Total_Roof_Area_m2 * installation_cost_usd_m2",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Total_Roof_Cost_USD",
          "expression": "Material_Cost_USD + Labour_Cost_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Cost_per_m2_USD",
          "expression": "Total_Roof_Cost_USD / Total_Roof_Area_m2",
          "unit": {
            "ref": "USD/m²"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Roof_Snow_Load_kN_m2",
          "expression": "ground_snow_load_kN_m2 * exposure_factor_Ce * thermal_factor_Ct * importance_factor_Is",
          "unit": {
            "ref": "kNpm2"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Dynamic_Wind_Pressure_kN_m2",
          "expression": "0.5 * 1.25 * POWER(wind_speed_ms, 2) / 1000 * wind_pressure_coeff_Cp",
          "unit": {
            "ref": "kNpm2"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Total_Gravity_Load_kN_m2",
          "expression": "dead_load_kN_m2 + live_load_kN_m2 + Roof_Snow_Load_kN_m2",
          "unit": {
            "ref": "kNpm2"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Total_Snow_Force_kN",
          "expression": "Roof_Snow_Load_kN_m2 * building_length_m * building_width_m",
          "unit": {
            "ref": "kN"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "Total_Snow_Tonnes",
          "expression": "Total_Snow_Force_kN / 9.81",
          "unit": {
            "ref": "tonnes"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "Uplift_Wind_kN_m2",
          "expression": "-Dynamic_Wind_Pressure_kN_m2 * 0.7",
          "unit": {
            "ref": "kNpm2"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ASCE 7 / EN 1991 Structural Design",
          "condition": "Total_Gravity_Load_kN_m2 > 3.0",
          "message": "TOTAL GRAVITY LOAD > 3.0 kN/m²: Heavy combined loading. Structural engineer must design purlins, rafters, and columns specifically for this load. Standard light steel industrial roof frames (Z/C purlins) are typically designed for 0.5–1.5 kN/m². DO NOT use standard span tables."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "ASCE 7 Section 7 / EN 1991-1-3",
          "condition": "Roof_Snow_Load_kN_m2 > 1.5",
          "message": "HIGH SNOW LOAD > 1.5 kN/m²: Significant structural implication. Roof framing must be designed for snow drift accumulation (ASCE 7 Section 7.7) at parapets and higher-level roof adjacencies. Progressive collapse analysis may be required."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ASCE 7 Section 7.4 / EN 1991-1-3 Annex B",
          "condition": "roof_pitch_deg < 5 && Roof_Snow_Load_kN_m2 > 0.5",
          "message": "FLAT/LOW-PITCH ROOF WITH SNOW: Pitch < 5° prevents snow from sliding. Full unbalanced snow load accumulates. Ponding risk from blocked drainage must also be assessed. Provide minimum 2% fall to drains."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "EN 1991-1-4 / ASCE 7 Chapter 26",
          "condition": "Dynamic_Wind_Pressure_kN_m2 > 1.2",
          "message": "HIGH WIND PRESSURE > 1.2 kN/m²: Cladding fixings and sheet overlaps must be designed for this uplift. Standard trapezoidal sheet fixings rated 0.8–1.0 kN/m² may be insufficient. Verify manufacturer's approved fixing schedule."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Construction Quantity Surveying",
          "condition": "waste_allowance_pct < 5 && roof_pitch_deg > 20",
          "message": "Waste allowance < 5% on steeply pitched roof: Hip ends, valleys, and ridge cuts generate significant offcuts. Minimum 8–10% recommended for pitches above 20°. Under-ordering causes installation delays and material price premium on re-order."
        },
        {
          "id": "W6",
          "severity": "CRITICAL",
          "source": "EN 1993-1-3 / ASCE 7 Wind Uplift",
          "condition": "Uplift_Wind_kN_m2 * -1 > dead_load_kN_m2",
          "message": "WIND UPLIFT EXCEEDS DEAD LOAD: Net uplift force will lift roof structure. Roof-to-wall connections and hold-down anchors are structurally critical elements. Structural engineer must design specific uplift connections — this is not a standard detail."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },

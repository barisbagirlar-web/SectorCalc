  "standards": [
    {
      "id": "PRO_067",
      "code": "IEC 61215:2021 (module qualification)",
      "name": "Grid-Tied PV System Sizing — Array Capacity, Annual Yield, Performance Ratio & Financial ROI",
      "description": "Grid-Tied PV System Sizing — Array Capacity, Annual Yield, Performance Ratio & Financial ROI — Renewable Energy, Electrical Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "temp_derating",
          "expression": "1 + module_temp_coeff_pct_c / 100 * (avg_cell_temp_c - 25)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "IEC 61215 §11.7 — temperature-corrected power: P_act = P_STC × [1 + γ·(T−25)]",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "PR",
          "expression": "(1 - system_losses_pct / 100) * temp_derating",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "IEC 61724-1:2021 §3.8 — PR = E_yield / (G_irr × P_STC)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "P_array_kwp",
          "expression": "annual_energy_demand_kwh / (PSH_h_day * 365 * PR)",
          "unit": {
            "ref": "kWp"
          },
          "reference": "Array sizing: E_demand = P_array × PSH × 365 × PR — ASTM E2848 energy model",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "N_modules",
          "expression": "Math.ceil(P_array_kwp * 1000 / module_wp); E_yield_kwh = P_array_kwp * PSH_h_day * 365 * PR",
          "unit": {
            "ref": "count, kWh/yr"
          },
          "reference": "N = P_array / P_module",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "CAPEX_usd",
          "expression": "P_array_kwp * 1000 * installed_cost_usd_wp; annual_saving_usd = E_yield_kwh * electricity_rate_usd_kwh",
          "unit": {
            "ref": "USD, USD/yr"
          },
          "reference": "Simple LCOE basis — NREL System Advisor Model (SAM) methodology",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "payback_yr",
          "expression": "CAPEX_usd / annual_saving_usd; specific_yield_kwh_kwp = E_yield_kwh / P_array_kwp",
          "unit": {
            "ref": "years, kWh/kWp/yr"
          },
          "reference": "Specific yield benchmark: Mediterranean 1400–1700 kWh/kWp",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "IEC 61215:2021 (module qualification)",
          "condition": "avg_cell_temp_c > 60",
          "message": "Cell temperature > 60°C: severe thermal derating — evaluate bifacial modules with elevated racking, ventilated mounting, or high-NOCT-resistant technology"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "IEC 61215:2021 (module qualification)",
          "condition": "system_losses_pct > 25",
          "message": "System losses > 25%: excessive — each 1% loss reduces yield by ~600 kWh/MWp/yr; audit soiling frequency, cable sizing, and inverter clipping"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "IEC 61215:2021 (module qualification)",
          "condition": "PR < 0.78",
          "message": "PR < 0.78: below IEC 61724 benchmark for well-designed systems — opportunity for O&M optimisation; cleaning and loss audit recommended"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "IEC 61215:2021 (module qualification)",
          "condition": "P_array_kwp > 1000 && installed_cost_usd_wp > 1.0",
          "message": "Large array at high CAPEX/Wp: utility-scale pricing should be below 0.85 USD/Wp — renegotiate EPC contract or review scope"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "IEC 61215:2021 (module qualification)",
          "condition": "payback_yr < 5",
          "message": "Payback < 5 years: strong project economics — confirm energy model with P90 yield (10th percentile) for bankability assessment per IFC PS3"
        }
      ],

  "standards": [
    {
      "id": "PRO_039",
      "code": "IEC 60034-30-1:2014 (IE efficiency classes)",
      "name": "Electrical Motor Energy Audit — Load Factor, Efficiency Penalty & VFD Retrofit ROI",
      "description": "Electrical Motor Energy Audit — Load Factor, Efficiency Penalty & VFD Retrofit ROI — Electrical Systems, Energy Management",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "LF",
          "expression": "avg_load_pct / 100",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "IEC 60034-30-1 §4 — load factor definition",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "eta_partload",
          "expression": "nameplate_efficiency_pct * LF / (LF^2 * (1 - nameplate_efficiency_pct/100) * 2 + LF * nameplate_efficiency_pct/100 + (1-LF)^2 * 0.05 * (1-nameplate_efficiency_pct/100))",
          "unit": {
            "ref": "pct"
          },
          "reference": "NEMA MG1-2016 Part 30 — semi-empirical part-load efficiency model",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "E_current_kwh",
          "expression": "measured_input_kw * operating_hours_yr",
          "unit": {
            "ref": "kWh/yr"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "E_vfd_kwh",
          "expression": "E_current_kwh_yr * (1 - vfd_energy_saving_pct/100)",
          "unit": {
            "ref": "kWh/yr"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "saving_usd_yr",
          "expression": "(E_current_kwh_yr - E_vfd_kwh_yr) * electricity_rate_usd_kwh",
          "unit": {
            "ref": "USD/yr"
          },
          "reference": "ISO 50001:2018 §6.3 — energy baseline and saving verification",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "payback_yr",
          "expression": "vfd_cost_usd / saving_usd_yr",
          "unit": {
            "ref": "years"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "IEC 60034-30-1:2014 (IE efficiency classes)",
          "condition": "LF < 0.5",
          "message": "Load factor < 50%: motor running in low-efficiency zone — IE3 motors below 50% load see 5–15% efficiency drop per IEC 60034-30-1"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "IEC 60034-30-1:2014 (IE efficiency classes)",
          "condition": "payback_yr > 5",
          "message": "VFD payback > 5 years: marginal ROI — re-evaluate saving estimate or negotiate capital cost"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "IEC 60034-30-1:2014 (IE efficiency classes)",
          "condition": "payback_yr < 2",
          "message": "VFD payback < 2 years: strong ROI — prioritize for next capital cycle"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "IEC 60034-30-1:2014 (IE efficiency classes)",
          "condition": "nameplate_efficiency_pct < 90 && rated_power_kw > 15",
          "message": "Motor below IE2 threshold for this power class: EU Regulation 640/2009 compliance risk — IE3 minimum required >7.5 kW"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "IEC 60034-30-1:2014 (IE efficiency classes)",
          "condition": "operating_hours_yr > 6000 && vfd_energy_saving_pct > 25",
          "message": "High-utilisation + high saving: evaluate premium IE4/IE5 motor replacement in parallel with VFD"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "rated_power_kw",
        "measured_input_kw",
        "nameplate_efficiency_pct",
        "operating_hours_yr",
        "electricity_rate_usd_kwh",
        "avg_load_pct",
        "vfd_cost_usd",
        "vfd_energy_saving_pct"
      ]
    }
  ],
  "fmea": {

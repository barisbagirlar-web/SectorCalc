  "standards": [
    {
      "id": "PRO_036",
      "code": "HI 9.6.3-2017",
      "name": "Pump System Curve & BEP Deviation — Hydraulic Power Loss & Cavitation Risk",
      "description": "Pump System Curve & BEP Deviation — Hydraulic Power Loss & Cavitation Risk — Fluid Systems, Rotating Equipment",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Q_ratio",
          "expression": "actual_flow_m3h / rated_flow_m3h",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "HI 9.6.3-2017 §4.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "eta_act",
          "expression": "rated_efficiency_pct * (1 - 0.3 * (1 - Q_ratio)^2)",
          "unit": {
            "ref": "pct"
          },
          "reference": "ISO 9906:2012 Annex B — parabolic efficiency correction",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "P_hyd",
          "expression": "(fluid_density_kg_m3 * 9.81 * actual_flow_m3h/3600 * H_act) / 1000",
          "unit": {
            "ref": "kW"
          },
          "reference": "API 610-12th Ed. §6.1.8",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "P_overload_pct",
          "expression": "((P_hyd / (eta_act/100)) - motor_power_kw) / motor_power_kw * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "HI 9.6.3-2017 §4.3 — motor overload threshold",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "npsh_margin",
          "expression": "npsha_m / npshr_m",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "HI 9.6.1-2012 — minimum margin = 1.1 for clear water",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "E_loss_kwh",
          "expression": "(motor_power_kw - P_hyd/(eta_act/100)) * 8760",
          "unit": {
            "ref": "kWh/yr"
          },
          "reference": "ISO 50001:2018 energy baseline method",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "HI 9.6.3-2017",
          "condition": "Q_ratio < 0.7",
          "message": "Severe left-of-BEP operation: axial thrust reversal and bearing fatigue risk per HI 9.6.3"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "HI 9.6.3-2017",
          "condition": "Q_ratio > 1.15",
          "message": "Right-of-BEP runout: NPSH curve steep rise — verify NPSHa at this flow"
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "HI 9.6.3-2017",
          "condition": "npsh_margin < 1.0",
          "message": "NPSHa < NPSHr: cavitation active — impeller erosion will occur within 500 operating hours"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "HI 9.6.3-2017",
          "condition": "P_overload_pct > 5",
          "message": "Motor overload >5%: thermal trip risk — verify service factor or upsize motor"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "HI 9.6.3-2017",
          "condition": "eta_act_pct < rated_efficiency_pct * 0.75",
          "message": "Operating efficiency <75% of BEP: energy waste exceeds ISO 50001 baseline threshold"
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "HI 9.6.3-2017",
          "condition": "rated_efficiency_pct < 60 && motor_power_kw > 75",
          "message": "Large pump at low BEP efficiency: consider hydraulic redesign or variable-speed drive"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "rated_flow_m3h",
        "actual_flow_m3h",
        "rated_head_m",
        "rated_efficiency_pct",
        "fluid_density_kg_m3",
        "npshr_m",
        "npsha_m",
        "motor_power_kw"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",

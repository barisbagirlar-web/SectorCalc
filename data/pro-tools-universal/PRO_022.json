  "standards": [
    {
      "id": "PRO_022",
      "code": "Sandvik Coromant Machining Economics",
      "name": "CNC Machining True Unit Cost (TCO) — Material, Tooling, Overhead & Scrap",
      "description": "CNC Machining True Unit Cost (TCO) — Material, Tooling, Overhead & Scrap — CNC Manufacturing, Cost Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Raw_Material_kg",
          "expression": "raw_material_volume_m3 * material_density_kg_m3",
          "unit": {
            "ref": "kg"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Material_Cost_USD",
          "expression": "Raw_Material_kg * material_price_usd_kg",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Buy_to_Fly_Ratio",
          "expression": "raw_material_volume_m3 / finished_part_volume_m3",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Chip_Weight_kg",
          "expression": "(raw_material_volume_m3 - finished_part_volume_m3) * material_density_kg_m3",
          "unit": {
            "ref": "kg"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Machining_Cost_USD",
          "expression": "(cycle_time_min / 60) * machine_hourly_rate_usd",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Cost_per_Edge_USD",
          "expression": "insert_cost_usd / cutting_edges_per_insert",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Tooling_Cost_per_Part_USD",
          "expression": "(cycle_time_min / tool_life_per_edge_min) * Cost_per_Edge_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Coolant_Cost_per_Part_USD",
          "expression": "(cycle_time_min / 60) * coolant_cost_usd_hr",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Direct_Cost_USD",
          "expression": "Material_Cost_USD + Machining_Cost_USD + Tooling_Cost_per_Part_USD + Coolant_Cost_per_Part_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Overhead_Cost_USD",
          "expression": "Direct_Cost_USD * (overhead_pct / 100)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Pre_Scrap_Cost_USD",
          "expression": "Direct_Cost_USD + Overhead_Cost_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Scrap_Penalty_USD",
          "expression": "Pre_Scrap_Cost_USD * (scrap_rate_pct / 100)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Total_Unit_Cost_USD",
          "expression": "Pre_Scrap_Cost_USD + Scrap_Penalty_USD",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Material_Cost_Fraction_pct",
          "expression": "(Material_Cost_USD / Total_Unit_Cost_USD) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "Tooling_Cost_Fraction_pct",
          "expression": "(Tooling_Cost_per_Part_USD / Total_Unit_Cost_USD) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "Annual_Cost_USD",
          "expression": "annual_volume_parts > 0 ? Total_Unit_Cost_USD * annual_volume_parts : 0",
          "unit": {
            "ref": "USD/year"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "Sandvik Coromant Machining Economics",
          "condition": "Tooling_Cost_per_Part_USD > Machining_Cost_USD",
          "message": "TOOLING COST EXCEEDS MACHINE TIME COST: Cutting speed is too high — tools are being consumed faster than economically optimal. Reduce Vc to extend tool life. Optimal Vc for minimum cost (Vcopt) is typically 20–30% below Vcmax."
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "Aerospace / Defence Cost Engineering",
          "condition": "Buy_to_Fly_Ratio > 5",
          "message": "High buy-to-fly ratio (>5): More than 80% of raw material becomes chip. Material waste is a dominant cost driver. Evaluate: (1) Near-net-shape forging or casting, (2) Additive manufacturing + hybrid machining, (3) Billet size optimisation."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "Cost Engineering Best Practice",
          "condition": "Material_Cost_Fraction_pct > 60",
          "message": "Material cost >60% of total unit cost: Material is the dominant cost element. Price negotiation, alternative alloys, or supply chain changes will have greater impact than process optimisation."
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "Six Sigma / Lean Manufacturing",
          "condition": "scrap_rate_pct > 5",
          "message": "Scrap rate > 5%: Significant quality cost. At this rate, scrap penalty is adding meaningful cost per part. Root cause analysis (8D / Ishikawa) required. Target: <1% for mature CNC processes."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "AIAG / TS 16949 Quality Targets",
          "condition": "scrap_rate_pct > 1 && scrap_rate_pct <= 5",
          "message": "Scrap rate 1–5%: Above world-class target. Each percentage point of scrap adds direct cost penalty. SPC implementation and tooling condition monitoring recommended."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "ISO 3685 / Sandvik Tool Life Recommendations",
          "condition": "tool_life_per_edge_min < 15",
          "message": "Tool life < 15 minutes per edge: Very short tool life indicates aggressive cutting conditions or workpiece hardness issues. Economic tool life target is typically 20–45 min. Reduce Vc or check for built-up edge (BUE) conditions."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "raw_material_volume_m3",
        "material_density_kg_m3",
        "material_price_usd_kg",
        "finished_part_volume_m3",
        "machine_hourly_rate_usd",
        "cycle_time_min",
        "insert_cost_usd",
        "cutting_edges_per_insert",
        "tool_life_per_edge_min",
        "scrap_rate_pct",
        "overhead_pct"
      ]
    }
  ],

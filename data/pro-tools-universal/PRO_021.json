  "standards": [
    {
      "id": "PRO_021",
      "code": "ISO 13399 Tool Representation",
      "name": "CNC Cycle Time Breakdown, Spindle Utilisation & OEE-Spindle Analysis",
      "description": "CNC Cycle Time Breakdown, Spindle Utilisation & OEE-Spindle Analysis — CNC Manufacturing, Operations",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "n_rpm",
          "expression": "(1000 * cutting_speed_vc) / (3.14159 * tool_diameter_mm)",
          "unit": {
            "ref": "rpm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "n_actual",
          "expression": "MIN(n_rpm, machine_max_rpm)",
          "unit": {
            "ref": "rpm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Vc_actual",
          "expression": "(n_actual * 3.14159 * tool_diameter_mm) / 1000",
          "unit": {
            "ref": "mpmin"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Vf_feed_rate",
          "expression": "feed_per_tooth_fz * num_teeth_z * n_actual",
          "unit": {
            "ref": "mmpmin"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "T_cut_min",
          "expression": "(total_cut_length_mm + approach_overtravel_mm) / Vf_feed_rate",
          "unit": {
            "ref": "min"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "T_rapid_min",
          "expression": "rapid_distance_mm / rapid_velocity_mm_min",
          "unit": {
            "ref": "min"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "T_toolchange_min",
          "expression": "(num_tool_changes * tool_change_time_sec) / 60",
          "unit": {
            "ref": "min"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "T_aux_min",
          "expression": "load_unload_time_min + probing_inspection_min",
          "unit": {
            "ref": "min"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "T_cycle_gross_min",
          "expression": "T_cut_min + T_rapid_min + T_toolchange_min + T_aux_min",
          "unit": {
            "ref": "min"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "T_cycle_per_part_min",
          "expression": "T_cycle_gross_min / parts_per_fixture",
          "unit": {
            "ref": "min"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Spindle_Utilisation_pct",
          "expression": "(T_cut_min / T_cycle_gross_min) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "OEE_Spindle",
          "expression": "Spindle_Utilisation_pct * 0.95 * 0.98",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Cost_per_Part_USD",
          "expression": "(T_cycle_per_part_min / 60) * machine_hourly_rate_usd",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Parts_per_Hour",
          "expression": "60 / T_cycle_per_part_min",
          "unit": {
            "ref": "parts/h"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "RPM_Utilisation_pct",
          "expression": "(n_actual / machine_max_rpm) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "JIPM TPM / OEE Foundation",
          "condition": "Spindle_Utilisation_pct < 30",
          "message": "CRITICAL SPINDLE WASTE: Only cutting for less than 30% of cycle. Machine spends over 70% of time on non-value-adding operations (rapids, ATC, load/unload). Immediate actions: (1) Zero-point clamping system, (2) Pre-set offline tooling, (3) Optimise G00 paths, (4) Pallet changer evaluation."
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "OEE / Lean Manufacturing",
          "condition": "Spindle_Utilisation_pct >= 30 && Spindle_Utilisation_pct < 50",
          "message": "Low spindle utilisation (30–50%): Significant non-cutting time losses. Target is >65% for general machining. Review ATC time, rapid distances, and fixture strategy."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "SMED / ATC Optimisation",
          "condition": "T_toolchange_min > T_cut_min * 0.3",
          "message": "Tool change time >30% of cutting time: ATC is a major cycle-time driver. Evaluate: (1) Reduce tool count via multi-function tools, (2) Sub-spindle or twin-pallet, (3) Upgrade to faster ATC (arm-type vs. umbrella)."
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "Machine Specification",
          "condition": "n_rpm > machine_max_rpm",
          "message": "Required RPM exceeds machine maximum. Actual cutting speed reduced. Recalculate with Vc_actual shown. Consider: (1) Smaller tool diameter, (2) Higher-RPM spindle machine, (3) Reduce cutting speed to match machine limit."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Lean Manufacturing / Cycle Time Analysis",
          "condition": "T_aux_min > T_cut_min",
          "message": "Auxiliary time (load/unload + probing) exceeds actual cutting time. Automation of part handling or in-process gauging should be evaluated for ROI."
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "Machine Asset Utilisation",
          "condition": "RPM_Utilisation_pct < 40",
          "message": "Machine spindle speed capability underused (<40% of max RPM). Machine may be oversized for this operation, or cutting parameters are conservative. Review tool and material data for speed increase potential."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "cutting_speed_vc",
        "feed_per_tooth_fz",
        "tool_diameter_mm",
        "num_teeth_z",
        "total_cut_length_mm",
        "approach_overtravel_mm",
        "rapid_distance_mm",
        "rapid_velocity_mm_min",
        "num_tool_changes",
        "tool_change_time_sec",
        "load_unload_time_min",
        "machine_hourly_rate_usd"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },
  "legalNotice": "⚠ Engineering decision support only — verify before use. This is a technical simulation, not professional engineering advice."

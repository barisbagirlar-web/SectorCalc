  "standards": [
    {
      "id": "PRO_001",
      "code": "Sandvik Coromant C-2920 2024",
      "name": "CNC Milling — Cutting Force, Specific Cutting Energy & Spindle Power",
      "description": "CNC Milling — Cutting Force, Specific Cutting Energy & Spindle Power — CNC Machining, Metal Cutting",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "n_rpm",
          "expression": "Vc_m_min * 1000 / (Math.PI * D_mm)",
          "unit": {
            "ref": "rpm"
          },
          "reference": "n = V_c × 1000 / (π × D_c) — Sandvik C-2920 §4.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Vf_mm_min",
          "expression": "fz_mm * z_teeth * n_rpm",
          "unit": {
            "ref": "mmpmin"
          },
          "reference": "V_f = f_z × z × n — ISO 3685:1993 §3.2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "hm_mm",
          "expression": "fz_mm * Math.sqrt(ae_mm / D_mm)",
          "unit": {
            "ref": "mm"
          },
          "reference": "h_m = f_z × √(a_e/D_c) — Sandvik C-2920 §4.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "kc_mpa",
          "expression": "kc1_mpa / Math.pow(hm_mm, mc_exponent)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "k_c = k_c1 / h_m^m_c — Kienzle force model",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Fc_N",
          "expression": "kc_mpa * ap_mm * hm_mm",
          "unit": {
            "ref": "N"
          },
          "reference": "F_c = k_c × a_p × h_m — Kienzle",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Pc_kw",
          "expression": "Fc_N * Vc_m_min / 60000",
          "unit": {
            "ref": "kW"
          },
          "reference": "P_c = F_c × V_c / 60000 — Sandvik C-2920 §4.5",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "Sandvik Coromant C-2920 2024",
          "condition": "ae_mm / D_mm > 0.7",
          "message": "a_e/D_c > 70%: full or near-full engagement — tool deflection and chatter risk severe; reduce radial depth to ≤ 50% and use finishing pass strategy"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "Sandvik Coromant C-2920 2024",
          "condition": "kc_mpa > 3500",
          "message": "Specific cutting force > 3500 MPa: hard material or worn tool — verify k_c1 input and check for built-up edge; consider coated carbide grade"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "Sandvik Coromant C-2920 2024",
          "condition": "n_rpm > 20000",
          "message": "Spindle speed > 20,000 rpm: HSM regime — verify spindle bearing rating, tool balance (ISO 1940 G2.5), and coolant pressure capacity"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "Sandvik Coromant C-2920 2024",
          "condition": "Vf_mm_min > 5000",
          "message": "Table feed > 5000 mm/min: high-feed machining — verify CNC controller acceleration and servo drive current limits"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Sandvik Coromant C-2920 2024",
          "condition": "ap_mm > D_mm * 1.5 && z_teeth > 4",
          "message": "Deep axial cut with many teeth: high chip volume — verify chip evacuation; coolant-through-tool strongly recommended"
        }

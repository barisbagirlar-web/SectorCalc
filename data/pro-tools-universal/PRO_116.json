  "standards": [
    {
      "id": "PRO_116",
      "code": "EN 1993-1-1",
      "name": "Hollow Section RHS/SHS/CHS Beam-Column Combined Loading Check — EN 1993-1-1 / AISC 360-22 / CIDECT DG2",
      "description": "Hollow Section RHS/SHS/CHS Beam-Column Combined Loading Check — EN 1993-1-1 / AISC 360-22 / CIDECT DG2 — Steel Structure, Hollow Structural Sections, Beam-Column Stability",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "A_rect_calc",
          "expression": "section_type === 'RHS' || section_type === 'SHS' ? (B * H - (B - 2 * t) * (H - 2 * t)) : null",
          "unit": {
            "ref": "mm2"
          },
          "reference": "CIDECT Design Guide 2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "A_chs_calc",
          "expression": "section_type === 'CHS' ? Math.PI / 4 * (Math.pow(D, 2) - Math.pow(D - 2 * t, 2)) : null",
          "unit": {
            "ref": "mm2"
          },
          "reference": "CIDECT Design Guide 2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "A",
          "expression": "A_lookup !== null && A_lookup !== undefined ? A_lookup : (section_type === 'CHS' ? A_chs_calc : A_rect_calc)",
          "unit": {
            "ref": "mm2"
          },
          "reference": "EN 1993-1-1 §6.2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Iy_rect_calc",
          "expression": "section_type === 'RHS' || section_type === 'SHS' ? (B * Math.pow(H, 3) - (B - 2 * t) * Math.pow(H - 2 * t, 3)) / 12 : null",
          "unit": {
            "ref": "mm4"
          },
          "reference": "CIDECT Design Guide 2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Iz_rect_calc",
          "expression": "section_type === 'RHS' || section_type === 'SHS' ? (H * Math.pow(B, 3) - (H - 2 * t) * Math.pow(B - 2 * t, 3)) / 12 : null",
          "unit": {
            "ref": "mm4"
          },
          "reference": "CIDECT Design Guide 2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "I_chs_calc",
          "expression": "section_type === 'CHS' ? Math.PI / 64 * (Math.pow(D, 4) - Math.pow(D - 2 * t, 4)) : null",
          "unit": {
            "ref": "mm4"
          },
          "reference": "CIDECT Design Guide 2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Iy",
          "expression": "Iy_lookup !== null && Iy_lookup !== undefined ? Iy_lookup : (section_type === 'CHS' ? I_chs_calc : Iy_rect_calc)",
          "unit": {
            "ref": "mm4"
          },
          "reference": "EN 1993-1-1 §6.3.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Iz",
          "expression": "Iz_lookup !== null && Iz_lookup !== undefined ? Iz_lookup : (section_type === 'CHS' ? I_chs_calc : Iz_rect_calc)",
          "unit": {
            "ref": "mm4"
          },
          "reference": "EN 1993-1-1 §6.3.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Wy",
          "expression": "Wy_lookup !== null && Wy_lookup !== undefined ? Wy_lookup : (section_type === 'CHS' ? I_chs_calc / (D / 2) : Iy / (H / 2))",
          "unit": {
            "ref": "mm3"
          },
          "reference": "EN 1993-1-1 §6.2.5"
        },
        {
          "id": "F10",
          "output": "Wz",
          "expression": "Wz_lookup !== null && Wz_lookup !== undefined ? Wz_lookup : (section_type === 'CHS' ? I_chs_calc / (D / 2) : Iz / (B / 2))",
          "unit": {
            "ref": "mm3"
          },
          "reference": "EN 1993-1-1 §6.2.5"
        },
        {
          "id": "F11",
          "output": "iy",
          "expression": "Math.sqrt(Iy / A)",
          "unit": {
            "ref": "mm"
          },
          "reference": "EN 1993-1-1 §6.3.1"
        },
        {
          "id": "F12",
          "output": "iz",
          "expression": "Math.sqrt(Iz / A)",
          "unit": {
            "ref": "mm"
          },
          "reference": "EN 1993-1-1 §6.3.1"
        },
        {
          "id": "F13",
          "output": "lambda_y_geom",
          "expression": "K_y * L_y / iy",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "EN 1993-1-1 §6.3.1.3"
        },
        {
          "id": "F14",
          "output": "lambda_z_geom",
          "expression": "K_z * L_z / iz",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "EN 1993-1-1 §6.3.1.3"
        },
        {
          "id": "F15",
          "output": "Ncr_y",
          "expression": "Math.pow(Math.PI, 2) * E * Iy / Math.pow(K_y * L_y, 2) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "EN 1993-1-1 §6.3.1.3"
        },
        {
          "id": "F16",
          "output": "Ncr_z",
          "expression": "Math.pow(Math.PI, 2) * E * Iz / Math.pow(K_z * L_z, 2) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "EN 1993-1-1 §6.3.1.3"
        },
        {
          "id": "F17",
          "output": "lambda_bar_y",
          "expression": "Math.sqrt((A * fy / 1000) / Ncr_y)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "EN 1993-1-1 §6.3.1.3"
        },
        {
          "id": "F18",
          "output": "lambda_bar_z",

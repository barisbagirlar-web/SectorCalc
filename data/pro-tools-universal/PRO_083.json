  "standards": [
    {
      "id": "PRO_083",
      "code": "EN 14511:2018 (heat pump rating)",
      "name": "Industrial Heat Pump COP, Annual Energy Saving & Carbon Payback vs Steam Boiler",
      "description": "Industrial Heat Pump COP, Annual Energy Saving & Carbon Payback vs Steam Boiler — Energy Management, Decarbonisation",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "T_H_K",
          "expression": "T_delivery_c + 273.15; T_L_K = T_source_c + 273.15; COP_Carnot = T_H_K / (T_H_K - T_L_K)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Carnot COP_H = T_H / (T_H − T_L) — thermodynamic upper bound",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "COP_HP",
          "expression": "Carnot_efficiency_fraction * COP_Carnot",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "COP_act = η_Carnot × COP_Carnot",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "W_elec_kw",
          "expression": "Q_delivery_kw / COP_HP; Q_source_kw = Q_delivery_kw - W_elec_kw",
          "unit": {
            "ref": "kW"
          },
          "reference": "First Law: Q_H = W_elec + Q_source",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "E_elec_kwh_yr",
          "expression": "W_elec_kw * operating_hours_yr; Q_heat_kwh_yr = Q_delivery_kw * operating_hours_yr; E_gas_saved_kwh_yr = Q_heat_kwh_yr / (boiler_efficiency_pct / 100)",
          "unit": {
            "ref": "kWh/yr"
          },
          "reference": "Annual gas displaced = Q_H / η_boiler",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "CO2_gas_saved_t",
          "expression": "E_gas_saved_kwh_yr * gas_emission_factor_kg_kwh / 1000; CO2_elec_consumed_t = E_elec_kwh_yr * grid_emission_factor_kg_kwh / 1000; CO2_net_saving_t = CO2_gas_saved_t - CO2_elec_consumed_t",
          "unit": {
            "ref": "tCO₂e/yr"
          },
          "reference": "Scope 1 gas avoided minus Scope 2 electricity added — GHG Protocol §5",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "CI_breakeven_kg_kwh",
          "expression": "CO2_gas_saved_t * 1000 / E_elec_kwh_yr",
          "unit": {
            "ref": "kgCO₂/kWh"
          },
          "reference": "If grid EF > CI_breakeven, heat pump increases net carbon",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "EN 14511:2018 (heat pump rating)",
          "condition": "T_delivery_c > 120",
          "message": "Delivery > 120°C: high-temperature heat pump (HTHP) territory — limited commercial units available; verify refrigerant rating (R245fa, R1234ze(Z)) per ASHRAE 34"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "EN 14511:2018 (heat pump rating)",
          "condition": "COP_HP < 3 && grid_emission_factor_kg_kwh > 0.35",
          "message": "Low COP on high-carbon grid: net carbon reduction minimal — prioritise grid decarbonisation timeline in investment decision"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "EN 14511:2018 (heat pump rating)",
          "condition": "COP_Carnot > 15",
          "message": "Very high Carnot COP: small temperature lift — confirm source availability is reliable year-round; COP may fall significantly in winter if source temperature drops"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "EN 14511:2018 (heat pump rating)",
          "condition": "Q_source_kw > Q_delivery_kw * 0.7",
          "message": "Large heat source extraction (>70% of delivery): verify source stream capacity and minimum outlet temperature — excessive extraction degrades source quality"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "EN 14511:2018 (heat pump rating)",
          "condition": "CI_breakeven_kg_kwh > 0.5",
          "message": "Break-even grid intensity > 0.5 kgCO₂/kWh: project is carbon-positive now and in most future grid scenarios — strong decarbonisation case; proceed"
        }
      ],

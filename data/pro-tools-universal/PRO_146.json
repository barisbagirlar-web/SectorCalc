  "standards": [
    {
      "id": "PRO_146",
      "code": "IEC 60364-5-52",
      "name": "IEC 60364 Three-Phase Cable Section Sizing & Voltage Drop",
      "description": "IEC 60364 Three-Phase Cable Section Sizing & Voltage Drop — Electrical Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Load_Current_A",
          "expression": "(load_kw * 1000 * demand_factor) / (SQRT(3) * voltage_v * power_factor)",
          "unit": {
            "ref": "A"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Resistivity",
          "expression": "0.0175",
          "unit": {
            "ref": "ohm*mm2/m"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Resistance_R_ohm",
          "expression": "(Resistivity * cable_length_m) / cross_section_val",
          "unit": {
            "ref": "ohm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Total_Loop_R",
          "expression": "2 * Resistance_R_ohm",
          "unit": {
            "ref": "ohm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Reactance_X_ohm",
          "expression": "0.00008 * cable_length_m",
          "unit": {
            "ref": "ohm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Sin_Phi",
          "expression": "SQRT(1 - POWER(power_factor, 2))",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "VD_Voltage",
          "expression": "SQRT(3) * Load_Current_A * (Resistance_R_ohm * power_factor + Reactance_X_ohm * Sin_Phi)",
          "unit": {
            "ref": "V"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "VD_Percent",
          "expression": "(VD_Voltage / voltage_v) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Voltage_At_Load",
          "expression": "voltage_v - VD_Voltage",
          "unit": {
            "ref": "V"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Power_Loss_W",
          "expression": "3 * POWER(Load_Current_A, 2) * Resistance_R_ohm",
          "unit": {
            "ref": "W"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Power_Loss_Pct",
          "expression": "(Power_Loss_W / (load_kw * 1000)) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Recommended_Min_Section",
          "expression": "(SQRT(3) * Load_Current_A * Resistivity * cable_length_m * power_factor) / (max_vd_pct / 100 * voltage_v)",
          "unit": {
            "ref": "mm2"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "IEC 60364-5-52 Md.525",
          "condition": "VD_Percent > max_vd_pct",
          "message": "VOLTAGE DROP LIMIT EXCEEDED: Motor will draw excessive current at this low voltage -> overheat -> melt insulation -> cause short circuit. Increase cross-section by at least one standard size."
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "IEC 60364-5-52",
          "condition": "VD_Percent > max_vd_pct * 0.8 && VD_Percent <= max_vd_pct",
          "message": "Voltage drop close to limit: Within 80% of limit. Cross-section upgrade is recommended to prevent exceeding limit on load surges or hot weather."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "IEEE 141 / Energy Efficiency",
          "condition": "Power_Loss_Pct > 3",
          "message": "Cable heat dissipation loss > 3%: Annual energy cost is significant. Investment in cross-section upgrade typically pays back in 2-3 years. Run economic sizing optimization (Kelvin's Law)."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "IEC 60364-5-52 Tablo B.52.14",
          "condition": "ambient_temp_c > 40",
          "message": "High ambient temperature: Cable ampacity derates. Apply correction factor (Ct) for ambient >40°C per IEC 60364. Standard catalog ratings assume 30°C."
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "IEC 60364-5-52 Voltage Drop Calculation",
          "condition": "cross_section_val < Recommended_Min_Section",
          "message": "Selected cross-section is insufficient: does not meet voltage drop limits. Calculated minimum cross-section is displayed. Choose next standard size up."
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "IEC 60228 / Pratik Uygulama",
          "condition": "Load_Current_A > 630",
          "message": "High current (>630A): Consider parallel cables or busbar duct system. Parallel cable routing can be complex; busduct is more reliable."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "load_kw",
        "system_voltage",
        "voltage_v",
        "power_factor",
        "cable_length_m",
        "cable_material",
        "cross_section_mm2",
        "cross_section_val",
        "installation_method",
        "ambient_temp_c",
        "max_vd_pct",
        "load_type"
      ]
    }
  ],

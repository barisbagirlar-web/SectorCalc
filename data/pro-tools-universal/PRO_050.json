      "name": "Chemical Reactor Heat of Reaction, Adiabatic Temperature Rise & Thermal Runaway Risk",
      "description": "Chemical Reactor Heat of Reaction, Adiabatic Temperature Rise & Thermal Runaway Risk — Chemical Process Engineering, Process Safety",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "delta_T_ad_k",
          "expression": "Math.abs(delta_Hr_kj_mol) * reactant_concentration_mol_kg / cp_reaction_mass_kj_kg_k",
          "unit": {
            "ref": "K"
          },
          "reference": "Stoessel 'Thermal Safety of Chemical Processes' §3.2 — ΔT_ad = |ΔH_r|·c_r / c_p",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "MTSR_c",
          "expression": "T_process_c + delta_T_ad_K",
          "unit": {
            "ref": "degC"
          },
          "reference": "Stoessel §3.3 — MTSR = T_p + ΔT_ad",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "R",
          "expression": "8.314e-3; Q_rx_kw = Math.abs(delta_Hr_kj_mol) * reactant_concentration_mol_kg * batch_mass_kg * 1e6 * Math.exp(-Ea_kj_mol / (R * (T_process_c + 273.15))) / 3600",
          "unit": {
            "ref": "kW"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "cooling_ratio",
          "expression": "cooling_capacity_kw / Math.max(Q_rx_kw, 0.001)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "IEC 62675 §5 — cooling ratio > 2.0 required for safe operation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "delta_T_safety",
          "expression": "T_onset_decomp_c - MTSR_c; criticality = (MTSR_c < T_process_c + 25) ? 1 : (MTSR_c < T_onset_decomp_c) ? (delta_T_safety > 50 ? 2 : 3) : (delta_T_safety > 0 ? 4 : 5)",
          "unit": {
            "ref": "class 1–5"
          },
          "reference": "Stoessel 5-class criticality diagram §4.4: Class 1 = safe, Class 5 = explosive decomposition risk",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "T_safety_margin_k",
          "expression": "T_onset_decomp_c - MTSR_c",
          "unit": {
            "ref": "K"
          },
          "reference": "Minimum recommended margin: ΔT_safety > 50 K per Stoessel",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [

  "standards": [
    {
      "id": "PRO_051",
      "code": "ISO 6336-1:2019",
      "name": "Cylindrical Gear Pair — Bending & Pitting (Contact) Stress Rating per ISO 6336",
      "description": "Cylindrical Gear Pair — Bending & Pitting (Contact) Stress Rating per ISO 6336 — Mechanical Power Transmission, Machine Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "d1_mm",
          "expression": "module_mm * z1_teeth; T1_Nm = P_kw * 9549.3 / n1_rpm; Ft_N = 2000 * T1_Nm / d1_mm",
          "unit": {
            "ref": "mm, N"
          },
          "reference": "ISO 6336-1:2019 §5.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "v_m_s",
          "expression": "Math.PI * d1_mm * n1_rpm / 60000; K_v = 1 + (0.0125 * v_m_s * Math.pow(z1_teeth * gear_ratio_u, 0.5)) / (1 + 0.0125 * v_m_s)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 6336-1 §6.3.3 — simplified dynamic factor for quality grade 6",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Z_E",
          "expression": "189.8; Z_H = 2.5; u = gear_ratio_u; sigma_H_mpa = Z_E * Z_H * Math.sqrt(Ft_N * KA_app_factor * K_v * (u+1) / (facewidth_mm * d1_mm * u))",
          "unit": {
            "ref": "MPa"
          },
          "reference": "ISO 6336-2:2019 §4 — contact stress",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Y_F",
          "expression": "2.7; Y_S = 1.6; sigma_F_mpa = Ft_N * KA_app_factor * K_v * Y_F * Y_S / (facewidth_mm * module_mm)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "ISO 6336-3:2019 §4 — root bending stress",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "S_H",
          "expression": "sigma_Hlim_mpa / sigma_H_mpa",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 6336-2 §5 — S_H ≥ 1.0 minimum",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "S_F",
          "expression": "sigma_Flim_mpa / sigma_F_mpa",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 6336-3 §5 — S_F ≥ 1.4 minimum for industrial gearing",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ISO 6336-1:2019",
          "condition": "S_H < 1.1",
          "message": "S_H < 1.1: marginal contact safety — case-harden to σ_Hlim ≥ 1400 MPa or apply profile modification (tip relief) per ISO 6336-1 §7"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 6336-1:2019",
          "condition": "v_m_s > 25",
          "message": "Pitch-line velocity > 25 m/s: high dynamic loads — verify gear quality grade ≤ 5 per ISO 1328-1 and check lubrication viscosity"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 6336-1:2019",
          "condition": "gear_ratio_u > 6 && z1_teeth < 17",
          "message": "High ratio with few pinion teeth: undercut risk — verify minimum tooth count for standard addendum without profile shift"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 6336-1:2019",
          "condition": "K_v > 1.5",
          "message": "Dynamic factor K_v > 1.5: significant dynamic load amplification — reduce speed, improve gear quality, or add mass damping"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ISO 6336-1:2019",
          "condition": "S_F < 2.0 && KA_app_factor >= 1.5",
          "message": "Low bending safety under heavy shock loading: risk of tooth fracture at peak transients — consider shot-peened root fillet per ISO 6336-5 §5.4"
        }
      ],

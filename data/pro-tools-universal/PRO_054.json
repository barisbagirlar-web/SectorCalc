  "standards": [
    {
      "id": "PRO_054",
      "code": "GPSA Engineering Data Book 14th Ed. §9",
      "name": "Wet Scrubber / Packed Column Sizing — Mass Transfer NTU, HTU & Pressure Drop",
      "description": "Wet Scrubber / Packed Column Sizing — Mass Transfer NTU, HTU & Pressure Drop — Chemical Process Engineering, Air Quality",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "eta_pct",
          "expression": "(inlet_conc_ppm - outlet_conc_ppm) / inlet_conc_ppm * 100; R = inlet_conc_ppm / outlet_conc_ppm",
          "unit": {
            "ref": "%, dimensionless"
          },
          "reference": "VDI 2440 §4 — removal ratio R = y_in / y_out",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "A_factor",
          "expression": "L_G_ratio / Henrys_H",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AIChE mass transfer — absorption factor",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "NTU",
          "expression": "(A_factor / (A_factor - 1)) * Math.log(R * (1 - 1/A_factor) + 1/A_factor)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Kremser equation for dilute systems — Perry's Chemical Engineers' Handbook 9th Ed. §14",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "gas_vel_m_s",
          "expression": "column_velocity_m_s; HTU_m = gas_vel_m_s / Kya_1_m; Z_m = NTU * HTU_m",
          "unit": {
            "ref": "m"
          },
          "reference": "Z = NTU × HTU — GPSA 14th Ed. §9",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Q_gas_m3_s",
          "expression": "gas_flow_am3_h / 3600; A_col_m2 = Q_gas_m3_s / column_velocity_m_s; D_col_m = 2 * Math.sqrt(A_col_m2 / Math.PI)",
          "unit": {
            "ref": "m², m"
          },
          "reference": "Continuity equation — column sizing based on design gas velocity",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "dP_total_pa",
          "expression": "packing_dP_m_per_m * Z_m",
          "unit": {
            "ref": "Pa"
          },
          "reference": "GPSA §9 — total packed bed ΔP",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "GPSA Engineering Data Book 14th Ed. §9",
          "condition": "A_factor < 1.2",
          "message": "Absorption factor < 1.2: marginal driving force — increase L/G by 50% to improve reliability and handle inlet concentration spikes"
        },
        {
          "id": "W2",

  "standards": [
    {
      "id": "PRO_014",
      "code": "EU Regulation 2023/956 (CBAM)",
      "name": "CBAM Financial Exposure Calculator (EU Carbon Border Adjustment Mechanism)",
      "description": "CBAM Financial Exposure Calculator (EU Carbon Border Adjustment Mechanism) — Environmental Engineering & Corporate Finance, GHG Compliance",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Scope1_Combustion_tCO2e",
          "expression": "scope1_fuel_consumption_gj * scope1_fuel_emission_factor",
          "unit": {
            "ref": "tCO₂e/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Scope2_tCO2e",
          "expression": "scope2_electricity_kwh * scope2_grid_factor_kg_kwh / 1000",
          "unit": {
            "ref": "tCO₂e/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Total_GHG_tCO2e",
          "expression": "Scope1_Combustion_tCO2e + scope1_process_emissions_tco2e + Scope2_tCO2e",
          "unit": {
            "ref": "tCO₂e/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Specific_Embedded_tCO2_per_tonne",
          "expression": "Total_GHG_tCO2e / annual_production_tonnes",
          "unit": {
            "ref": "tCO₂e/t product"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Excess_Emissions_rate",
          "expression": "MAX(0, Specific_Embedded_tCO2_per_tonne - eu_sector_benchmark_tco2_per_tonne)",
          "unit": {
            "ref": "tCO₂e/t"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Total_Excess_tCO2e",
          "expression": "Excess_Emissions_rate * eu_export_volume_tonnes",
          "unit": {
            "ref": "tCO₂e/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Gross_CBAM_Liability_EUR",
          "expression": "Total_Excess_tCO2e * eu_ets_price_eur_tco2",
          "unit": {
            "ref": "EUR/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Local_Carbon_Already_Paid_EUR",
          "expression": "Total_Excess_tCO2e * local_carbon_tax_eur_tco2",
          "unit": {
            "ref": "EUR/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Net_CBAM_Cost_EUR",
          "expression": "MAX(0, (Gross_CBAM_Liability_EUR - Local_Carbon_Already_Paid_EUR) * cbam_phase_factor)",
          "unit": {
            "ref": "EUR/year"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "CBAM_Per_Tonne_Exported",
          "expression": "eu_export_volume_tonnes > 0 ? Net_CBAM_Cost_EUR / eu_export_volume_tonnes : 0",
          "unit": {
            "ref": "EUR/tonne"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Carbon_Intensity_vs_Benchmark_Pct",
          "expression": "(Specific_Embedded_tCO2_per_tonne / eu_sector_benchmark_tco2_per_tonne) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "EU CBAM Regulation 2023/956",
          "condition": "Specific_Embedded_tCO2_per_tonne > eu_sector_benchmark_tco2_per_tonne",
          "message": "CBAM EXPOSURE CONFIRMED: Your carbon intensity exceeds the EU sector benchmark. CBAM certificates must be purchased for every tonne exported to the EU above this threshold. This is a legal obligation from 2026 onwards. Decarbonisation investment or EU market exit must be evaluated."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "CBAM Financial Risk Assessment",
          "condition": "Net_CBAM_Cost_EUR > 100000",
          "message": "MATERIAL FINANCIAL EXPOSURE: Annual CBAM liability exceeds €100,000. This represents a significant margin erosion risk for EU-destined exports. Quantify in CAPEX planning for decarbonisation. EU customers will increasingly demand lower-carbon supply chains."
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "EU Green Deal Supply Chain Requirements",
          "condition": "Carbon_Intensity_vs_Benchmark_Pct > 150",
          "message": "EXTREME CARBON INTENSITY: Your product emits 50%+ more CO₂ than the EU benchmark. At current EU ETS trajectory (projected €100+/t by 2030), export competitiveness will be critically impaired. Immediate industrial decarbonisation roadmap required."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "GHG Protocol Scope 2 / RE100",
          "condition": "scope2_grid_factor_kg_kwh > 0.5",
          "message": "High-carbon electricity grid (>0.5 kgCO₂/kWh): Scope 2 emissions are a major CBAM driver. Corporate PPA (Power Purchase Agreement) with renewable energy can significantly reduce embedded carbon and improve CBAM position. Model the impact using market-based Scope 2 method."
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "CBAM Article 9 — Carbon Price Deductibility",
          "condition": "local_carbon_tax_eur_tco2 === 0",
          "message": "No local carbon tax offset applicable. Countries with carbon pricing (UK, Switzerland, Korea) can deduct equivalent carbon costs from CBAM liability. Monitoring Turkey's carbon market development is recommended."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "CBAM Concentration Risk",
          "condition": "eu_export_volume_tonnes / annual_production_tonnes > 0.5",
          "message": "More than 50% of production exported to EU: High CBAM concentration risk. Any regulatory tightening of EU benchmarks or ETS price spike will have disproportionate financial impact. Diversify export markets or accelerate low-carbon transition."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },

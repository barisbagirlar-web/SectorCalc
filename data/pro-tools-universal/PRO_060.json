  "standards": [
    {
      "id": "PRO_060",
      "code": "ISO 22915-1:2016",
      "name": "Counterbalance Forklift Stability — Load Centre Shift, Residual Capacity & Tipping Moment",
      "description": "Counterbalance Forklift Stability — Load Centre Shift, Residual Capacity & Tipping Moment — Material Handling, Occupational Safety",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "M_load_kg_mm",
          "expression": "payload_kg * actual_load_centre_mm + attachment_weight_kg * attachment_centre_mm",
          "unit": {
            "ref": "kg·mm"
          },
          "reference": "ISO 22915-1:2016 §4.3 — load moment principle",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "D_equiv_mm",
          "expression": "M_load_kg_mm / (payload_kg + attachment_weight_kg)",
          "unit": {
            "ref": "mm"
          },
          "reference": "Equivalent load centre for combined load + attachment — ISO 22915-1 §4.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Q_residual_kg",
          "expression": "rated_capacity_kg * std_load_centre_mm / D_equiv_mm",
          "unit": {
            "ref": "kg"
          },
          "reference": "ISO 22915-1 capacity derating: Q_residual = Q_rated × D_std / D_equiv",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "util_ratio",
          "expression": "(payload_kg + attachment_weight_kg) / Q_residual_kg",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Utilisation ≤ 1.0 mandatory — OSHA 1910.178(o)(2)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "tipping_factor",
          "expression": "Q_residual_kg / (payload_kg + attachment_weight_kg); tip_margin_pct = (tipping_factor - 1) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "ISO 22915-1 §5 — stability test margin",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "height_factor",
          "expression": "1 + (lift_height_mm - 3000) * 0.00005; Q_highlift_kg = (lift_height_mm > 3000) ? Q_residual_kg / height_factor : Q_residual_kg",
          "unit": {
            "ref": "kg"
          },
          "reference": "Approximate high-lift derating: mast deflection raises effective load centre at height > 3 m per EN 16307-1:2019",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ISO 22915-1:2016",
          "condition": "tip_margin_pct < 10",
          "message": "Tipping margin < 10%: dangerously close to longitudinal tip-over — reduce payload or move load CG closer to fork face; operator training mandatory per OSHA 1910.178(l)"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 22915-1:2016",
          "condition": "util_ratio > 0.9",
          "message": "Utilisation > 90% of residual capacity: marginal stability — prohibit operation on ramps, uneven surfaces, or with mast fully tilted forward"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 22915-1:2016",
          "condition": "attachment_weight_kg > rated_capacity_kg * 0.15",
          "message": "Attachment mass >15% of rated capacity: significant derating effect — obtain attachment data plate per ISO 22915-1 §4.3 mandatory"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 22915-1:2016",
          "condition": "mast_forward_tilt_deg > 5 && lift_height_mm > 2000",
          "message": "Forward tilt >5° at elevated height: pendulum effect amplifies tip-over moment — restrict forward tilt to minimum when elevated"
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "ISO 22915-1:2016",
          "condition": "actual_load_centre_mm > 800",
          "message": "Load centre > 800 mm: long or oversized load — reposition forks, use extended carriage, or engage slinging — standard stability assumptions invalid"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "rated_capacity_kg",
        "std_load_centre_mm",
        "actual_load_centre_mm",
        "lift_height_mm",
        "mast_forward_tilt_deg",
        "payload_kg",
        "attachment_weight_kg"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },

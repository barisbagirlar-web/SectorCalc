  "standards": [
    {
      "id": "PRO_010",
      "code": "ISO 1217:2009 Annex C",
      "name": "Compressed Air Leakage Energy Loss Audit (Sonic Flow)",
      "description": "Compressed Air Leakage Energy Loss Audit (Sonic Flow) — Energy Efficiency, Compressed Air Systems",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "T_abs_K",
          "expression": "intake_temp_c + 273.15",
          "unit": {
            "ref": "K"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "P_abs_bar",
          "expression": "system_pressure_bar_g + 1.01325",
          "unit": {
            "ref": "bar(a)"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "P_atm_bar",
          "expression": "1.01325",
          "unit": {
            "ref": "bar(a)"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Critical_Pressure_Ratio",
          "expression": "POWER(2 / (polytropic_index_n + 1), polytropic_index_n / (polytropic_index_n - 1))",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Is_Choked",
          "expression": "P_abs_bar / P_atm_bar > (1 / Critical_Pressure_Ratio)",
          "unit": {
            "ref": "bool"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Orifice_Area_m2",
          "expression": "3.14159265 / 4 * POWER(leak_diameter_mm / 1000, 2)",
          "unit": {
            "ref": "m2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Sonic_Velocity_m_s",
          "expression": "SQRT(polytropic_index_n * 287 * T_abs_K)",
          "unit": {
            "ref": "mps"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Air_Density_kg_m3",
          "expression": "(P_abs_bar * 100000) / (287 * T_abs_K)",
          "unit": {
            "ref": "kg/m³"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Leak_Flow_kg_s",
          "expression": "discharge_coefficient_Cd * Orifice_Area_m2 * SQRT(polytropic_index_n * Air_Density_kg_m3 * P_abs_bar * 100000 * POWER(2 / (polytropic_index_n + 1), (polytropic_index_n + 1) / (polytropic_index_n - 1)))",
          "unit": {
            "ref": "kg/s"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Leak_Flow_m3min_FAD",
          "expression": "(Leak_Flow_kg_s * 60) / (Air_Density_kg_m3 * P_abs_bar / P_atm_bar)",
          "unit": {
            "ref": "m³/min FAD"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Total_Leak_Flow_m3min",
          "expression": "Leak_Flow_m3min_FAD * number_of_leak_points",
          "unit": {
            "ref": "m³/min FAD"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Leak_Pct_of_FAD",
          "expression": "(Total_Leak_Flow_m3min / compressor_fad_m3min) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Specific_Power_kW_m3min",
          "expression": "((polytropic_index_n / (polytropic_index_n - 1)) * P_atm_bar * 100 * (POWER(P_abs_bar / P_atm_bar, (polytropic_index_n - 1) / polytropic_index_n) - 1)) / (mechanical_efficiency_pct / 100)",
          "unit": {
            "ref": "kW/(m³/min)"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Wasted_Power_kW",
          "expression": "Total_Leak_Flow_m3min * Specific_Power_kW_m3min",
          "unit": {
            "ref": "kW"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "Annual_Energy_Loss_kWh",
          "expression": "Wasted_Power_kW * annual_operating_hours",
          "unit": {
            "ref": "kWh/year"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "Annual_Cost_USD",
          "expression": "Annual_Energy_Loss_kWh * electricity_rate_usd_kwh",
          "unit": {
            "ref": "USD/year"
          },
          "reference": ""
        },
        {
          "id": "F17",
          "output": "Annual_CO2_tonnes",
          "expression": "Annual_Energy_Loss_kWh * co2_factor_kg_kwh / 1000",
          "unit": {
            "ref": "tCO₂/year"
          },
          "reference": ""
        },
        {
          "id": "F18",
          "output": "Repair_ROI_months",
          "expression": "0",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "INFO",
          "source": "Choked Flow Theory / ISO 11011",
          "condition": "P_abs_bar / P_atm_bar > 1 / Critical_Pressure_Ratio",
          "message": "SONIC (CHOKED) FLOW confirmed: At this system pressure, air exits the leak point at the speed of sound. Flow rate is independent of downstream pressure — leakage cannot be reduced by lowering system pressure. Fix is mechanical repair only."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "DOE Compressed Air Challenge",
          "condition": "Leak_Pct_of_FAD > 30",
          "message": "CRITICAL SYSTEM LOSS: Leakage exceeds 30% of compressor output. Industry average is 20–30% in poorly maintained systems. At this level, an additional compressor may be running solely to compensate for losses. Immediate audit and repair program mandatory."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "DOE Compressed Air Challenge / ISO 11011",
          "condition": "Leak_Pct_of_FAD > 10 && Leak_Pct_of_FAD <= 30",
          "message": "Significant leakage: 10–30% of FAD lost. Well-maintained systems achieve <10%. Schedule leak repair program. Typical payback: 3–12 months."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 11011 Energy Audit",
          "condition": "Annual_Cost_USD > 5000",
          "message": "Annual financial loss exceeds $5,000 USD from this leak source alone. Ultrasonic leak detection survey and systematic repair program will deliver rapid ROI."
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "Compressed Air Best Practices",
          "condition": "leak_diameter_mm >= 3.0",
          "message": "Large orifice leak (≥3mm): This is a fitting, joint, or valve failure — not a pinhole. Immediate isolation required. At 6 bar(g), a 3mm orifice leaks ~4 m³/min FAD continuously."
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "GHG Protocol Scope 2 / ISO 14064",
          "condition": "Annual_CO2_tonnes > 10",
          "message": "Carbon impact: Leakage responsible for significant Scope 2 CO₂ emissions. Relevant for ISO 14001, ESG reporting, and EU CBAM supply chain exposure."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "system_pressure_bar_g",
        "leak_diameter_mm",
        "intake_temp_c",
        "compressor_fad_m3min",
        "polytropic_index_n",
        "mechanical_efficiency_pct",
        "annual_operating_hours",
        "electricity_rate_usd_kwh"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []

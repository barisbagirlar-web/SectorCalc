  "standards": [
    {
      "id": "PRO_008",
      "code": "AISC 360-22 Chapter E",
      "name": "Steel Column Axial Compression — Slenderness, Critical Stress & Euler Buckling Load",
      "description": "Steel Column Axial Compression — Slenderness, Critical Stress & Euler Buckling Load — Structural Engineering, Steel Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "KL_r",
          "expression": "L_eff_m * 1000 / r_min_mm",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AISC 360-22 E2 — slenderness ratio",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "E_steel",
          "expression": "200000; Fe_mpa = Math.pow(Math.PI, 2) * E_steel / Math.pow(KL_r, 2)",
          "unit": {
            "ref": "MPa"
          },
          "reference": "AISC 360-22 E3-4 — F_e = π²E/(KL/r)²",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "lambda_c",
          "expression": "Math.sqrt(Fy_mpa / Fe_mpa); Fcr_mpa = (lambda_c <= 1.5) ? Math.pow(0.658, lambda_c * lambda_c) * Fy_mpa : (0.877 / (lambda_c * lambda_c)) * Fy_mpa",
          "unit": {
            "ref": "MPa"
          },
          "reference": "AISC 360-22 E3 — λ_c ≤ 1.5: inelastic",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "phi_Pn_kn",
          "expression": "0.90 * Fcr_mpa * A_g_mm2 / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "AISC 360-22 §E1 — φ_c = 0.90 (LRFD)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "DCR",
          "expression": "Pu_kn / phi_Pn_kn",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AISC 360-22 §H1-1 — DCR ≤ 1.0 required",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "I_min_mm4",
          "expression": "A_g_mm2 * Math.pow(r_min_mm, 2); Pcr_kn = Math.pow(Math.PI, 2) * 200000 * I_min_mm4 / Math.pow(L_eff_m * 1000, 2) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "Euler: P_cr = π²EI/L_eff² — EN 1993-1-1 §6.3.1",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "AISC 360-22 Chapter E",
          "condition": "DCR > 0.90",
          "message": "DCR > 90%: minimal reserve capacity — no additional loads or load combination factors can be accommodated; redesign before construction"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "AISC 360-22 Chapter E",
          "condition": "KL_r > 150",
          "message": "Very slender column (KL/r > 150): highly sensitive to eccentricity and initial imperfections — apply additional amplification per AISC Appendix 8 or second-order analysis"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "AISC 360-22 Chapter E",
          "condition": "Fy_mpa > 355 && KL_r > 80",
          "message": "High-strength steel with moderate slenderness: F_cr may be governed by elastic buckling, not yield — verify cost benefit of S460 vs S355 at this slenderness level"
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "AISC 360-22 Chapter E",
          "condition": "Pu_kn > Pcr_kn * 0.8",
          "message": "Applied load > 80% of Euler critical load: very close to elastic bifurcation point — P-delta effects and geometric imperfections become critical; perform second-order analysis"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "AISC 360-22 Chapter E",
          "condition": "end_condition === 2.0 && L_eff_m > 5",
          "message": "Cantilever column (K=2.0) over 5 m: very high effective length — verify fixed base connection rotational stiffness; partial fixity significantly increases effective K"
        }
      ],

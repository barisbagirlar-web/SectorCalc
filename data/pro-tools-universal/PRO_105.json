  "standards": [
    {
      "id": "PRO_105",
      "code": "ANSI B7.1-2017 (Safety of Abrasive Wheels)",
      "name": "CNC Cylindrical Grinding — Wheel Speed, Q-Prime MRR, G-Ratio & Grinding Burn Prevention",
      "description": "CNC Cylindrical Grinding — Wheel Speed, Q-Prime MRR, G-Ratio & Grinding Burn Prevention — CNC Machining, Precision Grinding",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Vs_m_s",
          "expression": "Vs_m_s = Math.PI * wheel_diameter_mm / 1000 * wheel_speed_rpm / 60",
          "unit": {
            "ref": "mps"
          },
          "reference": "V_s = π × D_s × n_s / 60 — ANSI B7.1 §6.3; maximum speed MUST NOT exceed wheel marking",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Vw_m_min",
          "expression": "Vw_m_min = Math.PI * workpiece_diameter_mm / 1000 * workpiece_speed_rpm",
          "unit": {
            "ref": "mpmin"
          },
          "reference": "V_w = π × D_w × n_w — workpiece surface speed",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Qprime_mm3_mm_s",
          "expression": "Qprime_mm3_mm_s = Vw_m_min / 60 * 1000 * infeed_mm_pass",
          "unit": {
            "ref": "mm3pmmps"
          },
          "reference": "Q'_w = V_w × a_e — specific MRR per unit wheel width; key thermal indicator — Malkin §4.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "q_ratio, temp_index",
          "expression": "q_ratio = Vs_m_s / (Vw_m_min / 60); temp_index = Qprime_mm3_mm_s / Vs_m_s",
          "unit": {
            "ref": "dimensionless, mm²/(m)"
          },
          "reference": "q = V_s/V_w — speed ratio; thermal index = Q'_w/V_s; Malkin-Shaw grinding burn criterion: temp_index < 0.04 for steel",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "G_est",
          "expression": "const G_base = {soft:20, medium_soft:30, medium:50, medium_hard:80, hard:120}; G_est = G_base[wheel_grade_hardness] * (Vs_m_s / 35)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "G = V_w_removed / V_wheel_worn — empirical estimate by grade; G_base at V_s=35 m/s; Malkin §7",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "traverse_rate_mm_min",
          "expression": "traverse_rate_mm_min = traverse_feed_mm_rev * workpiece_speed_rpm; t_pass_s = (workpiece_diameter_mm * Math.PI) / (Vw_m_min / 60 * 1000) * (traverse_feed_mm_rev / 1)",
          "unit": {
            "ref": "mmpmin"
          },
          "reference": "Axial traverse = f_a × n_w [mm/min]; traverse rate for CNC programme setup",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [
        {
          "id": "V1",
          "action": "BLOCK",
          "condition": "Vs_m_s > 45",
          "message": "Wheel peripheral speed > 45 m/s: exceeds standard vitrified wheel limit — verify wheel is rated for high-speed grinding (HSG mark); operator safety risk of wheel burst per ANSI B7.1"
        },
        {
          "id": "V2",
          "action": "WARN",
          "condition": "q_ratio < 20",
          "message": "Speed ratio q < 20: conventional grinding range too low — wheel may load and glaze; increase V_s or reduce V_w; target q = 60–150 for conventional grinding"
        },
        {
          "id": "V3",
          "action": "WARN",
          "condition": "temp_index > 0.05",
          "message": "Thermal index > 0.05: grinding burn risk on steel — reduce Q'_w by decreasing infeed or workpiece speed; verify coolant flow rate ≥ 20 L/min at wheel contact zone"
        }
      ],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "",
          "condition": "Vs_m_s > 35 && wheel_grade_hardness === 'soft'",
          "message": "High wheel speed with soft grade: wheel structure opens rapidly — soft grades lose bonds faster at high speed; upgrade to medium-soft for V_s > 35 m/s applications"
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "",
          "condition": "infeed_mm_pass > 0.03 && workpiece_diameter_mm < 20",
          "message": "Large infeed on small workpiece: Q'_w very high relative to workpiece thermal mass — grinding burn and workpiece deflection imminent; reduce infeed to < 0.01 mm for D_w < 20 mm"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "",
          "condition": "traverse_feed_mm_rev > 5 && infeed_mm_pass < 0.005",
          "message": "Wide traverse pitch on fine infeed: likely chatter pattern will appear — finish pass traverse should be ≤ 1/3 of wheel width B for uniform surface without helical marks"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "",
          "condition": "G_est < 15",
          "message": "Low G-ratio estimate (< 15): wheel wears rapidly — check if wheel grade is too soft for workpiece hardness; consider harder grade or CBN/diamond wheel for hardened steels (HRC > 55)"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "",
          "condition": "Vw_m_min > 50 && workpiece_diameter_mm < 30",
          "message": "High workpiece speed on small diameter: dynamic balance and bearing precision critical — workpiece runout at high rpm causes chatter; verify workpiece mounting and centre alignment to < 0.002 mm TIR"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "wheel_diameter_mm",
        "wheel_speed_rpm",
        "workpiece_diameter_mm",
        "workpiece_speed_rpm",
        "infeed_mm_pass",
        "traverse_feed_mm_rev",
        "wheel_grade_hardness"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",
    "modes": []
  },

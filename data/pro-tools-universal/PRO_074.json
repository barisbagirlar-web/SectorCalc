  "standards": [
    {
      "id": "PRO_074",
      "code": "ISO 12241:1998 (EN ISO 12241:2022)",
      "name": "Pipe & Vessel Thermal Insulation Thickness — Economic & Process Optimisation",
      "description": "Pipe & Vessel Thermal Insulation Thickness — Economic & Process Optimisation — Thermal Engineering, Energy Management",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "r1_m",
          "expression": "pipe_OD_mm / 2000; r2_m = r1_m + insulation_thickness_mm / 1000; delta_T = Math.abs(T_process_c - T_ambient_c)",
          "unit": {
            "ref": "m, m, K"
          },
          "reference": "Radial geometry — ISO 12241:1998 §5.2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "R_ins",
          "expression": "Math.log(r2_m / r1_m) / (2 * Math.PI * lambda_ins_w_mk); R_conv = 1 / (2 * Math.PI * r2_m * h_outer_w_m2k); R_total = R_ins + R_conv",
          "unit": {
            "ref": "m·K/W"
          },
          "reference": "ISO 12241 §5.2 — cylindrical: R_ins = ln(r2/r1)/(2πλ)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "q_L_w_m",
          "expression": "delta_T / R_total",
          "unit": {
            "ref": "W/m"
          },
          "reference": "Fourier's law for cylindrical geometry — ASTM C680 §5 / EN ISO 12241",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "r_cr_m",
          "expression": "lambda_ins_w_mk / h_outer_w_m2k",
          "unit": {
            "ref": "m"
          },
          "reference": "r_cr = λ/h_o — below this radius, adding insulation INCREASES heat loss",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "E_loss_gj_yr",
          "expression": "q_L_w_m * operating_hours_yr * 3600 / 1e9; cost_loss_usd_yr = E_loss_gj_yr * energy_cost_usd_gj",
          "unit": {
            "ref": "GJ/m·yr, USD/m·yr"
          },
          "reference": "Annual energy loss per metre of pipe — CINI Manual §3.4 cost basis",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "T_surface_c",
          "expression": "T_ambient_c + q_L_w_m / (2 * Math.PI * r2_m * h_outer_w_m2k)",
          "unit": {
            "ref": "degC"
          },
          "reference": "Surface temp for personnel protection: < 60°C per EN 13202",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "ISO 12241:1998 (EN ISO 12241:2022)",
          "condition": "T_surface_c > 50 && T_process_c > 80",
          "message": "Surface temperature 50–60°C: borderline personnel protection threshold — increase thickness by 25 mm or add protective cladding/barrier per EN 13202 §5"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 12241:1998 (EN ISO 12241:2022)",
          "condition": "lambda_ins_w_mk > 0.08 && delta_T > 200",
          "message": "High thermal conductivity insulation on high-ΔT service: consider aerogel blanket (λ ≈ 0.018) or calcium silicate for service above 200°C differential"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "ISO 12241:1998 (EN ISO 12241:2022)",
          "condition": "E_loss_gj_yr > 5 && energy_cost_usd_gj > 10",
          "message": "High annual heat loss cost: evaluate economic insulation thickness — each additional 25 mm typically reduces heat loss by 30–50% on medium pipes"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 12241:1998 (EN ISO 12241:2022)",
          "condition": "insulation_thickness_mm < 25 && delta_T > 150",
          "message": "Very thin insulation on high-ΔT service: thermal efficiency poor — minimum 50 mm recommended for ΔT > 150 K and pipe OD > 50 mm"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ISO 12241:1998 (EN ISO 12241:2022)",
          "condition": "T_process_c < 0",
          "message": "Cold insulation (cryogenic / chilled) service: vapour barrier on warm side mandatory — moisture ingress destroys cold insulation performance within months"
        }
      ],

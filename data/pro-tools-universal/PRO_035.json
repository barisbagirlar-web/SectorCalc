  "standards": [
    {
      "id": "PRO_035",
      "code": "EU Directive 2008/98/EC Waste Framework",
      "name": "Industrial Waste Stream Cost, Circularity Rate & ESG Compliance Analysis (ISO 14001 / EU Taxonomy)",
      "description": "Industrial Waste Stream Cost, Circularity Rate & ESG Compliance Analysis (ISO 14001 / EU Taxonomy) — Environmental Engineering, Sustainability",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Total_Waste_Generated_t",
          "expression": "non_hazardous_waste_t + hazardous_waste_t",
          "unit": {
            "ref": "t/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Waste_to_Landfill_t",
          "expression": "MAX(0, non_hazardous_waste_t - recycled_diverted_t)",
          "unit": {
            "ref": "t/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Landfill_Cost_USD",
          "expression": "Waste_to_Landfill_t * landfill_disposal_rate_usd_t",
          "unit": {
            "ref": "USD/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Hazardous_Disposal_Cost_USD",
          "expression": "hazardous_waste_t * hazardous_disposal_rate_usd_t",
          "unit": {
            "ref": "USD/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Wastewater_Cost_USD",
          "expression": "wastewater_m3 * wastewater_treatment_rate_usd_m3",
          "unit": {
            "ref": "USD/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Recycling_Revenue_USD",
          "expression": "recycled_diverted_t * scrap_metal_revenue_usd_t",
          "unit": {
            "ref": "USD/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Risk_Weighted_Fine_USD",
          "expression": "(violation_probability_pct / 100) * regulatory_fine_usd",
          "unit": {
            "ref": "USD/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Total_Gross_Waste_Cost_USD",
          "expression": "Landfill_Cost_USD + Hazardous_Disposal_Cost_USD + Wastewater_Cost_USD + Risk_Weighted_Fine_USD",
          "unit": {
            "ref": "USD/year"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Net_Waste_Cost_USD",
          "expression": "Total_Gross_Waste_Cost_USD - Recycling_Revenue_USD",
          "unit": {
            "ref": "USD/year"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Circularity_Rate_pct",
          "expression": "Total_Waste_Generated_t > 0 ? (recycled_diverted_t / Total_Waste_Generated_t) * 100 : 0",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Hazardous_Fraction_pct",
          "expression": "Total_Waste_Generated_t > 0 ? (hazardous_waste_t / Total_Waste_Generated_t) * 100 : 0",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Waste_Intensity_t_per_MtUSD",
          "expression": "Net_Waste_Cost_USD > 0 ? Total_Waste_Generated_t / (Net_Waste_Cost_USD / 1000000) : 0",
          "unit": {
            "ref": "t/M USD cost"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Carbon_Footprint_Waste_tCO2e",
          "expression": "Waste_to_Landfill_t * co2_per_tonne_waste_kg / 1000",
          "unit": {
            "ref": "tCO₂e/year"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Cost_per_Tonne_Generated_USD",
          "expression": "Total_Waste_Generated_t > 0 ? Net_Waste_Cost_USD / Total_Waste_Generated_t : 0",
          "unit": {
            "ref": "USD/t"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "EU Directive 2008/98/EC / ISO 14001",
          "condition": "Hazardous_Fraction_pct > 20",
          "message": "HIGH HAZARDOUS WASTE FRACTION (>20%): Hazardous waste disposal represents a significant cost and liability. Mandatory: (1) Waste audit to identify substitution opportunities (REACH compliance), (2) Solvent recovery system ROI analysis, (3) Licensed contractor insurance verification. Regulatory exposure is elevated."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "EU CSRD / ESRS E5 / EU Taxonomy",
          "condition": "Circularity_Rate_pct < 20",
          "message": "CIRCULARITY RATE <20%: EU Taxonomy and CSRD require disclosure of circularity performance. Institutional investors and EU supply chain customers will classify this as a sustainability red flag. Circular economy action plan required for continued EU market access and ESG-linked financing eligibility."
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "Environmental Liability Risk",
          "condition": "Risk_Weighted_Fine_USD > Recycling_Revenue_USD",
          "message": "EXPECTED REGULATORY PENALTY EXCEEDS RECYCLING REVENUE: Compliance risk is financially material. Investment in waste management systems (proper segregation, licensed storage, treatment capacity) should be evaluated against risk-weighted fine cost. Environmental insurance may be warranted."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "GHG Protocol Scope 3 Category 5",
          "condition": "Carbon_Footprint_Waste_tCO2e > 100",
          "message": "SIGNIFICANT WASTE-RELATED EMISSIONS (>100 tCO₂e/year): This waste stream generates reportable Scope 3 emissions under GHG Protocol Category 5. Must be disclosed in CDP, GRI 306, and CSRD reporting. Diversion from landfill (composting, energy recovery, recycling) reduces both cost and carbon footprint."
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "Circular Economy — Revenue Opportunity",
          "condition": "Recycling_Revenue_USD > Landfill_Cost_USD && recycled_diverted_t < non_hazardous_waste_t * 0.5",
          "message": "UNTAPPED RECYCLING REVENUE: Scrap value of recyclable materials exceeds current landfill cost, but less than 50% of non-hazardous waste is being diverted. Increasing recovery rate will reduce costs AND generate additional revenue. Conduct waste composition audit to identify high-value streams."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "Industrial Waste Benchmarking",
          "condition": "Cost_per_Tonne_Generated_USD > 200",
          "message": "HIGH ALL-IN WASTE COST (>$200/tonne generated): Above typical manufacturing benchmark. Dominant driver may be hazardous waste, wastewater treatment, or regulatory risk premium. Waste minimisation at source (lean process, material substitution) delivers permanent cost reduction."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "non_hazardous_waste_t",
        "hazardous_waste_t",
        "recycled_diverted_t",
        "landfill_disposal_rate_usd_t",
        "hazardous_disposal_rate_usd_t",
        "scrap_metal_revenue_usd_t",
        "regulatory_fine_usd",
        "violation_probability_pct",
        "esg_reporting_framework"
      ]
    }
  ],

  "standards": [
    {
      "id": "PRO_071",
      "code": "ISO 6020-2:2015 (cylinder dimensions)",
      "name": "Hydraulic Cylinder Actuator Sizing — Bore, Rod, Force, Speed & Buckling Check",
      "description": "Hydraulic Cylinder Actuator Sizing — Bore, Rod, Force, Speed & Buckling Check — Fluid Power, Hydraulic Systems",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "P_net_bar",
          "expression": "system_pressure_bar - back_pressure_bar; A_bore_cm2 = extend_force_kn * 10 / P_net_bar; D_bore_mm = 2 * Math.sqrt(A_bore_cm2 / Math.PI) * 10",
          "unit": {
            "ref": "mm"
          },
          "reference": "F = P·A",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "A_bore_m2",
          "expression": "Math.PI/4 * Math.pow(D_bore_mm/1000, 2); A_ann_req_m2 = retract_force_kn * 1000 / ((system_pressure_bar - back_pressure_bar) * 1e5); A_rod_m2 = A_bore_m2 - A_ann_req_m2; D_rod_mm = 2 * Math.sqrt(Math.max(A_rod_m2, 0.001) / Math.PI) * 1000",
          "unit": {
            "ref": "mm"
          },
          "reference": "Annular area = bore area − rod area",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "A_bore_m2_act",
          "expression": "Math.PI/4 * Math.pow(D_bore_mm/1000, 2); Q_ext_lpm = A_bore_m2_act * extend_speed_mm_s / 1000 * 1000 * 60",
          "unit": {
            "ref": "Lpmin"
          },
          "reference": "Q = A × v — ISO 6022 flow rate for cylinder actuation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "E_steel",
          "expression": "210000; I_rod = Math.PI/64 * Math.pow(D_rod_mm, 4); L_eff_mm = mounting_condition * stroke_mm; F_cr_kn = Math.pow(Math.PI, 2) * E_steel * I_rod / Math.pow(L_eff_mm, 2) / 1e6",
          "unit": {
            "ref": "kN"
          },
          "reference": "Euler buckling: F_cr = π²EI/(kL)²",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "SF_buck",
          "expression": "F_cr_kn / extend_force_kn",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 6020-2 Annex B — minimum SF_buck ≥ 3.0 for static",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "A_rod_act_mm2",
          "expression": "Math.PI/4 * Math.pow(D_rod_mm, 2); sigma_rod_mpa = extend_force_kn * 1000 / A_rod_act_mm2; rod_util = sigma_rod_mpa / (rod_material_yield_mpa / 2)",
          "unit": {
            "ref": "MPa, dimensionless"
          },
          "reference": "Rod stress σ = F/A",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "ISO 6020-2:2015 (cylinder dimensions)",
          "condition": "SF_buck < 5 && extend_speed_mm_s > 200",
          "message": "Low buckling SF at high speed: dynamic loads from deceleration shock amplify column force — target SF ≥ 5 for speeds > 200 mm/s per Parker handbook §4"
        },
        {
          "id": "W2",
          "severity": "INFO",
          "source": "ISO 6020-2:2015 (cylinder dimensions)",
          "condition": "Q_ext_lpm > 200",
          "message": "Flow demand > 200 L/min: verify pump capacity and line sizing — pressure drop in supply line will reduce effective force; use ΔP = 0.003 L/D·v²·ρ for line check"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 6020-2:2015 (cylinder dimensions)",
          "condition": "system_pressure_bar > 350",
          "message": "System pressure > 350 bar: high-pressure category — NFPA T3.6.7 Class 5000 psi seals and fittings required; hydraulic shock transients may exceed 500 bar"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 6020-2:2015 (cylinder dimensions)",
          "condition": "stroke_mm > 3000 && mounting_condition >= 1.0",
          "message": "Long stroke with pin-pin mounting: effective buckling length equals full stroke — consider intermediate rod support or reduce to fixed-pin mounting"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ISO 6020-2:2015 (cylinder dimensions)",
          "condition": "back_pressure_bar > 20",
          "message": "Back pressure > 20 bar: high counterbalance valve setting — reduces net extension force significantly; verify thermal relief valve setting is ≥ P_back + 20% per ISO 6022"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {

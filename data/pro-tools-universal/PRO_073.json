  "standards": [
    {
      "id": "PRO_073",
      "code": "APICS CPIM Exam Content Manual",
      "name": "EOQ, Reorder Point & Safety Stock Optimisation with Demand & Lead Time Variability",
      "description": "EOQ, Reorder Point & Safety Stock Optimisation with Demand & Lead Time Variability — Supply Chain, Inventory Management",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "H_usd",
          "expression": "unit_cost_usd * holding_rate_pct / 100; EOQ = Math.sqrt((2 * annual_demand_units * ordering_cost_usd) / H_usd)",
          "unit": {
            "ref": "units"
          },
          "reference": "Wilson (1913) EOQ = √(2DS/H)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "T_cycle_days",
          "expression": "EOQ / (annual_demand_units / 365); orders_per_yr = annual_demand_units / EOQ",
          "unit": {
            "ref": "days, orders/yr"
          },
          "reference": "T = EOQ/d̄",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "sl_map",
          "expression": "{90: 1.282, 95: 1.645, 97.5: 1.960, 99: 2.326, 99.9: 3.090}; z = sl_map[service_level_pct]",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Standard normal z-value for cycle service level — Silver, Pyke & Thomas §6.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "d_avg_day",
          "expression": "annual_demand_units / 365; sigma_dLT = Math.sqrt(lead_time_days * Math.pow(demand_std_day, 2) + Math.pow(d_avg_day, 2) * Math.pow(lead_time_std_days, 2)); SS = z * sigma_dLT",
          "unit": {
            "ref": "units"
          },
          "reference": "Hadley-Within formula: σ_DLT = √(L̄·σ_d² + d̄²·σ_L²) — combines demand and lead time uncertainty",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "d_avg_day",
          "expression": "annual_demand_units / 365; ROP = d_avg_day * lead_time_days + SS",
          "unit": {
            "ref": "units"
          },
          "reference": "ROP = d̄·L̄ + z·σ_DLT — trigger order when on-hand inventory reaches ROP",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "H_usd",
          "expression": "unit_cost_usd * holding_rate_pct / 100; TAC_usd = (EOQ/2 + SS) * H_usd + (annual_demand_units / EOQ) * ordering_cost_usd",
          "unit": {
            "ref": "USD/yr"
          },
          "reference": "TAC = (Q/2 + SS)·H + (D/Q)·S — total holding + ordering cost excluding purchase cost",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "INFO",
          "source": "APICS CPIM Exam Content Manual",
          "condition": "orders_per_yr > 52",
          "message": "More than 52 orders per year: weekly ordering frequency — evaluate blanket PO or kanban system to reduce transaction costs"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "APICS CPIM Exam Content Manual",
          "condition": "T_cycle_days > 90",
          "message": "Cycle time > 90 days: large batch order — obsolescence and damage risk increases with long holding periods; verify shelf life vs cycle time"
        },
        {
          "id": "W3",
          "severity": "INFO",
          "source": "APICS CPIM Exam Content Manual",
          "condition": "service_level_pct >= 99 && demand_std_day > 0",
          "message": "High service level (≥99%) with variable demand: safety stock cost increases exponentially above 97.5% — verify cost of stockout justifies the holding cost premium"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "APICS CPIM Exam Content Manual",
          "condition": "unit_cost_usd > 1000 && EOQ > 100",
          "message": "High-value item with large EOQ: capital tied up in inventory is significant — consider just-in-time or consignment stock arrangement to reduce order quantity"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "APICS CPIM Exam Content Manual",
          "condition": "holding_rate_pct < 15",
          "message": "Holding rate < 15%: may understate true cost — verify capital cost of inventory (WACC), storage cost, and obsolescence risk are fully included"
        }
      ],

  "standards": [
    {
      "id": "PRO_063",
      "code": "ACI 318-19 §10, §22.4, §6.2.5",
      "name": "RC Column Axial-Bending Interaction — Capacity Check, Eccentricity & Confinement",
      "description": "RC Column Axial-Bending Interaction — Capacity Check, Eccentricity & Confinement — Structural Engineering, Concrete Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Ag_mm2",
          "expression": "b_mm * h_mm; Ast_mm2 = rho_g_pct / 100 * Ag_mm2",
          "unit": {
            "ref": "mm2"
          },
          "reference": "ACI 318-19 §10.6.1.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "phi_Pn_max_kn",
          "expression": "0.65 * 0.80 * (0.85 * fc_prime_mpa * (Ag_mm2 - Ast_mm2) + fy_mpa * Ast_mm2) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ACI 318-19 §22.4.2.1 — tied column: φ=0.65",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "d_mm",
          "expression": "h_mm - cover_mm - 8 - 16; cb_mm = 0.003/(0.003 + fy_mpa/200000) * d_mm; ab_mm = 0.85 * cb_mm; Pb_kn = 0.65 * (0.85 * fc_prime_mpa * b_mm * ab_mm - Ast_mm2/2 * fy_mpa + Ast_mm2/2 * fy_mpa) / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ACI 318-19 §22.4 — balanced strain condition",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "e_mm",
          "expression": "(Mu_knm * 1e6) / (Pu_kn * 1000); e_ratio = e_mm / h_mm",
          "unit": {
            "ref": "mm, dimensionless"
          },
          "reference": "Eccentricity e = M_u / P_u",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "r_gyration",
          "expression": "0.3 * h_mm; kL_r = 1.0 * column_height_m * 1000 / r_gyration; slender = (kL_r > 22) ? 'SLENDER — moment magnification required per ACI §6.6.4' : 'SHORT — slenderness effects negligible'",
          "unit": {
            "ref": "dimensionless, text"
          },
          "reference": "ACI 318-19 §6.2.5 — braced frame slender if kL/r > 34 − 12(M1/M2)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "DCR_axial",
          "expression": "Pu_kn / phi_Pn_max_kn; phi_Mn_knm = 0.65 * Ast_mm2/2 * fy_mpa * (h_mm - 2*cover_mm - 16) / 1e6; DCR_moment = Mu_knm / phi_Mn_knm; interaction_ACI = (Pu_kn >= phi_Pn_max_kn * 0.2) ? DCR_axial + 8/9 * DCR_moment : DCR_axial/2 + DCR_moment",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AISC-style interaction check approximation",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ACI 318-19 §10, §22.4, §6.2.5",
          "condition": "interaction_ACI > 0.9",
          "message": "Interaction ratio > 0.9: near capacity — seismic or wind load combination check with overstrength factor per ACI §18.7"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ACI 318-19 §10, §22.4, §6.2.5",
          "condition": "kL_r > 22 && e_ratio < 0.1",
          "message": "Slender column under low eccentricity: buckling controls over material failure — verify EI_eff and compute moment magnifier δ_ns per ACI §6.6.4.4"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ACI 318-19 §10, §22.4, §6.2.5",
          "condition": "fc_prime_mpa < 25 && Pu_kn > phi_Pn_max_kn * 0.7",
          "message": "Low-strength concrete at high axial load: creep and shrinkage deformations significant — long-term P-delta effects must be included per ACI §6.6.4.4"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ACI 318-19 §10, §22.4, §6.2.5",
          "condition": "rho_g_pct < 1.5 && DCR_axial > 0.7",
          "message": "Lightly reinforced column at high axial demand: minimum 1.5% steel recommended for ductility and construction tolerance per ACI §10.6.1"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ACI 318-19 §10, §22.4, §6.2.5",
          "condition": "cover_mm < 30 && fc_prime_mpa < 30",
          "message": "Low cover in moderate-strength concrete: consider 50 mm cover for exposed or marine environments per ACI §20.6.1.3"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },

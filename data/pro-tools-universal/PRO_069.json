  "standards": [
    {
      "id": "PRO_069",
      "code": "ISO 13349:2010 (fan terminology)",
      "name": "Centrifugal Fan Selection — Specific Speed, Tip Speed, Blade Loading & Noise Rating",
      "description": "Centrifugal Fan Selection — Specific Speed, Tip Speed, Blade Loading & Noise Rating — Fluid Systems, HVAC, Industrial Ventilation",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "omega_rad_s",
          "expression": "n_fan_rpm * 2 * Math.PI / 60; Ns_dim = omega_rad_s * Math.sqrt(Q_m3s) / Math.pow(dP_fan_pa / rho_air_kg_m3, 0.75)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 13349:2010 §3.3 — N_s = ω·√Q / (ΔP/ρ)^0.75",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "u2_m_s",
          "expression": "Math.PI * impeller_dia_mm / 1000 * n_fan_rpm / 60",
          "unit": {
            "ref": "mps"
          },
          "reference": "u_2 = π·D_2·n/60 — ISO 13349 §3.7",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "psi",
          "expression": "dP_fan_pa / (rho_air_kg_m3 * Math.pow(u2_m_s, 2))",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AMCA 210-16 — pressure coefficient ψ = ΔP/(ρ·u₂²)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "P_shaft_kw",
          "expression": "Q_m3s * dP_fan_pa / (fan_efficiency_pct / 100) / 1000",
          "unit": {
            "ref": "kW"
          },
          "reference": "P_shaft = Q·ΔP / η_fan — EN ISO 5801:2017 §8.2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "N_blades_est",
          "expression": "(blade_type === 'backward') ? 9 : (blade_type === 'forward') ? 36 : 6; BPF_hz = N_blades_est * n_fan_rpm / 60",
          "unit": {
            "ref": "Hz"
          },
          "reference": "BPF = Z_b × n/60 — AMCA 300 noise standard",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Kw_dB",
          "expression": "10 * Math.log10(Q_m3s * Math.pow(dP_fan_pa, 2)); Lw_estimated_dB = Kw_dB + ((blade_type === 'backward') ? 55 : (blade_type === 'forward') ? 63 : 60)",
          "unit": {
            "ref": "dBA"
          },
          "reference": "AMCA 301-14 — estimated fan sound power",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "ISO 13349:2010 (fan terminology)",
          "condition": "Ns_dim < 0.2 || Ns_dim > 2.5",
          "message": "Specific speed outside centrifugal fan optimal range (0.2–2.5): consider axial fan (Ns > 2.5) or different impeller type — efficiency will be poor"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 13349:2010 (fan terminology)",
          "condition": "blade_type === 'forward' && dP_fan_pa > 1500",
          "message": "Forward-curved fan at high pressure: FC fans have overloading characteristic — motor may trip; backward-curved or radial tip preferred above 1500 Pa"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 13349:2010 (fan terminology)",
          "condition": "Lw_estimated_dB > 95",
          "message": "Estimated sound power > 95 dB(A): high-noise installation — acoustic treatment, silencer, or vibration isolation required; OSHA noise assessment mandatory"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ISO 13349:2010 (fan terminology)",
          "condition": "fan_efficiency_pct < 60",
          "message": "Fan efficiency < 60%: poor energy performance — consider replacing with backward-curved or airfoil blade design; each 10% η improvement reduces motor kW proportionally"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ISO 13349:2010 (fan terminology)",
          "condition": "BPF_hz > 500",
          "message": "Blade passage frequency > 500 Hz: mid-frequency tonal noise — structural resonance check of ductwork at BPF mandatory; add flexible connection at fan outlet"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",

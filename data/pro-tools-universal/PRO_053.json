  "standards": [
    {
      "id": "PRO_053",
      "code": "ACI 318-19 Chapter 17",
      "name": "Anchor Bolt Group — Tension, Shear & Combined Interaction for Column Baseplates",
      "description": "Anchor Bolt Group — Tension, Shear & Combined Interaction for Column Baseplates — Structural Engineering, Foundation Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "As_mm2",
          "expression": "Math.PI/4 * Math.pow(bolt_dia_mm * 0.9, 2)",
          "unit": {
            "ref": "mm2"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "phi_Nsa_kn",
          "expression": "0.75 * N_bolts * As_mm2 * Futa_mpa / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ACI 318-19 §17.6.1 — φ=0.75 for ductile anchors in tension",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Nb_kn",
          "expression": "16 * Math.sqrt(fc_prime_mpa) * Math.pow(embed_depth_mm, 1.5) / 1000; AN = Math.pow(3 * embed_depth_mm, 2); AN0 = 9 * embed_depth_mm^2; phi_Ncb_kn = 0.70 * (AN/AN0) * Nb_kn",
          "unit": {
            "ref": "kN"
          },
          "reference": "ACI 318-19 §17.6.2 — concrete breakout for single bolt, φ=0.70 (uncracked concrete assumed)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "phi_Vsa_kn",
          "expression": "0.65 * N_bolts * 0.6 * As_mm2 * Futa_mpa / 1000",
          "unit": {
            "ref": "kN"
          },
          "reference": "ACI 318-19 §17.7.1.2 — shear: φ=0.65",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "kcp",
          "expression": "(embed_depth_mm >= 65) ? 2.0 : 1.0; phi_Vcp_kn = 0.70 * kcp * phi_Ncb_kn / 0.70",
          "unit": {
            "ref": "kN"
          },
          "reference": "ACI 318-19 §17.7.3 — pryout: k_cp=2 for h_ef≥65 mm",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "DCR_tension",
          "expression": "Nu_kn / Math.min(phi_Nsa_kn, phi_Ncb_kn); DCR_shear = Vu_kn / Math.min(phi_Vsa_kn, phi_Vcp_kn); interaction = Math.pow(DCR_tension, 5/3) + Math.pow(DCR_shear, 5/3)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ACI 318-19 §17.8.3 — trilinear interaction: sum ≤ 1.2 required",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ACI 318-19 Chapter 17",
          "condition": "DCR_tension > 0.8",
          "message": "Tension DCR > 0.8: low reserve — verify load combinations include seismic overstrength per ASCE 7-22 §12.4.3 if applicable"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ACI 318-19 Chapter 17",
          "condition": "phi_Ncb_kn < phi_Nsa_kn * 0.7",
          "message": "Concrete breakout capacity <70% of steel capacity: brittle failure mode governs — increase embedment or add supplemental reinforcement per ACI §17.3.3"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ACI 318-19 Chapter 17",
          "condition": "fc_prime_mpa < 25 && Nu_kn > 100",
          "message": "Low-strength concrete with high tension: consider post-installed adhesive anchors (ETAG 001) for higher concrete capacity"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ACI 318-19 Chapter 17",
          "condition": "N_bolts < 4 && Vu_kn > 0 && Nu_kn > 0",
          "message": "Less than 4 bolts under combined loading: all bolts in tension and shear simultaneously — verify baseplate rotational stiffness per AISC DG1"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ACI 318-19 Chapter 17",
          "condition": "Futa_mpa > 800 && embed_depth_mm < 200",
          "message": "High-strength anchor with moderate embedment: steel fracture may govern before concrete breakout — desirable for ductile design per ACI §17.3.3(a)"
        }
      ],

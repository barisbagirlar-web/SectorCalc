  "standards": [
    {
      "id": "PRO_075",
      "code": "API 521 7th Ed. 2020 §5.15",
      "name": "Flare Stack Thermal Radiation — Exclusion Zone, Flame Length & Stack Height",
      "description": "Flare Stack Thermal Radiation — Exclusion Zone, Flame Length & Stack Height — Process Safety, Oil & Gas, Environmental",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Q_f_kw",
          "expression": "relief_flow_kg_h / 3600 * fuel_LHV_kj_kg * combustion_efficiency_pct / 100",
          "unit": {
            "ref": "kW"
          },
          "reference": "API 521-2020 §5.15.2 — Q_f = ṁ_f × LHV × η_c / 3600",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Q_rad_kw",
          "expression": "fraction_heat_radiated_F * Q_f_kw",
          "unit": {
            "ref": "kW"
          },
          "reference": "API 521 §5.15.3 — Q_rad = F × Q_f",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "L_f_m",
          "expression": "0.00325 * Math.pow(Q_f_kw * 0.9478, 0.478)",
          "unit": {
            "ref": "m"
          },
          "reference": "API 521 §5.15.4.1 — Brzustowski & Sommer correlation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "U_j_m_s",
          "expression": "20; Mach_j = wind_speed_m_s / U_j_m_s; x_h_m = L_f_m * Math.sin(Math.atan(Mach_j * 5)); x_v_m = L_f_m * Math.cos(Math.atan(Mach_j * 5)); flame_tip_H_m = stack_height_m + x_v_m; flame_tip_X_m = x_h_m",
          "unit": {
            "ref": "m"
          },
          "reference": "API 521 §5.15.4.2 — wind-deflected flame centre approximation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "D_excl_m",
          "expression": "Math.sqrt(Q_rad_kw / (4 * Math.PI * allowable_radiation_kw_m2))",
          "unit": {
            "ref": "m"
          },
          "reference": "API 521 §5.15.3 — point source model: E = Q_rad / (4πd²)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "D_from_base",
          "expression": "Math.sqrt(Math.pow(D_excl_m, 2) - Math.pow(flame_tip_X_m, 2)); H_min_m = Math.max(D_from_base - flame_tip_H_m + stack_height_m, stack_height_m)",
          "unit": {
            "ref": "m"
          },
          "reference": "Stack height must ensure 3D distance from flame centre to ground-level personnel ≥ D_excl — API 521 §5.15.3",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "API 521 7th Ed. 2020 §5.15",
          "condition": "D_excl_m > 500",
          "message": "Exclusion zone > 500 m: major hazard area — review relief system design, consider staged blowdown or enclosed ground flare to reduce peak flow"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "API 521 7th Ed. 2020 §5.15",
          "condition": "Q_f_kw > 100000",
          "message": "Flame power > 100 MW: large flare event — noise assessment mandatory; stack structural loading under wind and thermal cycling must be verified per API 560 §7"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "API 521 7th Ed. 2020 §5.15",
          "condition": "wind_speed_m_s > 15 && flame_tip_X_m > stack_height_m * 0.5",
          "message": "High wind deflection: flame centre shifts significantly downwind — re-calculate exclusion zone at wind direction perpendicular to access road"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "API 521 7th Ed. 2020 §5.15",
          "condition": "allowable_radiation_kw_m2 < 3.16 && D_excl_m > 200",
          "message": "Personnel exclusion zone > 200 m: verify no permanent occupied facilities within zone; update HAZOP and site emergency response plan"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "API 521 7th Ed. 2020 §5.15",
          "condition": "combustion_efficiency_pct < 98",
          "message": "Combustion efficiency < 98%: regulatory compliance risk — US 40 CFR Part 60 Subpart Ja requires ≥ 96.5% DRE; EU IED requires BAT-AEL assessment"
        }
      ],

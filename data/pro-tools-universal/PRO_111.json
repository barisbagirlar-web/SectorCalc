  "standards": [
    {
      "id": "PRO_111",
      "code": "ISO 281:2007",
      "name": "Roller Bearing L10h Life & Modified Lnm Life (ISO 281)",
      "description": "Roller Bearing L10h Life & Modified Lnm Life (ISO 281) — Machine Elements",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "L10_million_rev",
          "expression": "POWER(dynamic_load_C_kN / equiv_load_P_kN, load_exponent_p)",
          "unit": {
            "ref": "10^6 rev"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "L10h",
          "expression": "(L10_million_rev * 1000000) / (60 * rpm)",
          "unit": {
            "ref": "hours"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "a_ISO_factor",
          "expression": "0.1 * POWER(MAX(0.001, 1 - (fatigue_limit_Pu_kN * contamination_ec_val / equiv_load_P_kN)), 1.5) * SQRT(viscosity_ratio_kappa)",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Lnm",
          "expression": "reliability_a1_val * a_ISO_factor * L10h",
          "unit": {
            "ref": "hours"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Life_Reduction_Pct",
          "expression": "(1 - Lnm / L10h) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Bearing_Speed_Limit_Check",
          "expression": "rpm / (dynamic_load_C_kN * 1000 / 1000)",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Load_Ratio",
          "expression": "equiv_load_P_kN / dynamic_load_C_kN",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Maintenance_Interval_h",
          "expression": "Lnm * 0.1",
          "unit": {
            "ref": "hours"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "SKF / ISO 281:2007 Ek A",
          "condition": "viscosity_ratio_kappa < 0.4",
          "message": "CRITICAL LUBRICATION DEFICIENCY: kappa < 0.4. Rolling elements are in direct contact; EHD film does not form. Metal-on-metal wear initiated. Lnm calculation unreliable. Higher viscosity oil or lower speed is mandatory."
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 281:2007 / SKF Lubrication",
          "condition": "viscosity_ratio_kappa >= 0.4 && viscosity_ratio_kappa < 1.0",
          "message": "Insufficient oil film: kappa between 0.4 and 1.0. Partial EHD film. Fatigue life is significantly below theoretical values. Optimize oil selection or evaluate viscosity-enhancing additives."
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 281:2007 Tablo A.4",
          "condition": "contamination_ec_val < 0.30",
          "message": "High contamination: eC < 0.30. Abrasive particles are destroying the raceways. Upgrade filter class to ISO 4406 <= 16/14/11. Evaluate shielded/sealed bearing types."
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "ISO 281 / Machine Maintenance",
          "condition": "Lnm < target_life_hours * 0.5",
          "message": "INSUFFICIENT MODIFIED LIFE: Lnm is less than 50% of target life. Bearing will fail prematurely under current conditions. Larger series, better lubrication, or lower load is required."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "SKF Engineering Handbook",
          "condition": "Load_Ratio > 0.5",
          "message": "P/C > 0.5: High load ratio. A larger bearing series should be evaluated. P/C <= 0.2 is ideal for long service life."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "ISO 281 / Industry Benchmark",
          "condition": "L10h < 20000 && target_life_hours >= 20000",
          "message": "L10h < 20,000 hours: This is the industrial minimum for electric motors. Current design is insufficient. Increase bearing size or reduce load."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "bearing_type",
        "load_exponent_p",
        "dynamic_load_C_kN",
        "fatigue_limit_Pu_kN",
        "equiv_load_P_kN",
        "rpm",
        "reliability_a1",
        "reliability_a1_val",
        "viscosity_ratio_kappa",
        "contamination_ec",
        "contamination_ec_val"
      ]
    }
  ],

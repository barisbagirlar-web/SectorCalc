  "standards": [
    {
      "id": "PRO_011",
      "code": "CIMA Management Accounting",
      "name": "Multi-Product Break-Even Analysis and Degree of Operating Leverage (DOL)",
      "description": "Multi-Product Break-Even Analysis and Degree of Operating Leverage (DOL) — Corporate Finance, Managerial Accounting",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "CM_A",
          "expression": "product_A_price - product_A_vc",
          "unit": {
            "ref": "USD/unit"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "CM_B",
          "expression": "product_B_price - product_B_vc",
          "unit": {
            "ref": "USD/unit"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Mix_A",
          "expression": "product_A_mix_pct / 100",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Mix_B",
          "expression": "product_B_mix_pct / 100",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Mix_Sum",
          "expression": "Mix_A + Mix_B",
          "unit": {
            "ref": "—"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "WACM",
          "expression": "(CM_A * Mix_A + CM_B * Mix_B) / Mix_Sum",
          "unit": {
            "ref": "USD/unit"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Total_FC_Adjusted",
          "expression": "total_fixed_costs_usd + semi_variable_costs_usd",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "BEP_Units",
          "expression": "Total_FC_Adjusted / WACM",
          "unit": {
            "ref": "units"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "BEP_Units_A",
          "expression": "BEP_Units * Mix_A",
          "unit": {
            "ref": "units"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "BEP_Units_B",
          "expression": "BEP_Units * Mix_B",
          "unit": {
            "ref": "units"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "BEP_Revenue",
          "expression": "BEP_Units_A * product_A_price + BEP_Units_B * product_B_price",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Required_Pre_Tax_Profit",
          "expression": "target_net_profit_usd / (1 - corporate_tax_rate_pct / 100)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Target_Volume_Units",
          "expression": "(Total_FC_Adjusted + Required_Pre_Tax_Profit) / WACM",
          "unit": {
            "ref": "units"
          },
          "reference": ""
        },
        {
          "id": "F14",
          "output": "Actual_Operating_Income",
          "expression": "actual_total_volume * WACM - Total_FC_Adjusted",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F15",
          "output": "Actual_Net_Profit",
          "expression": "Actual_Operating_Income * (1 - corporate_tax_rate_pct / 100)",
          "unit": {
            "ref": "USD"
          },
          "reference": ""
        },
        {
          "id": "F16",
          "output": "Margin_of_Safety_Units",
          "expression": "actual_total_volume - BEP_Units",
          "unit": {
            "ref": "units"
          },
          "reference": ""
        },
        {
          "id": "F17",
          "output": "Margin_of_Safety_Pct",
          "expression": "(Margin_of_Safety_Units / actual_total_volume) * 100",
          "unit": {
            "ref": "pct"
          },
          "reference": ""
        },
        {
          "id": "F18",
          "output": "DOL",
          "expression": "Actual_Operating_Income > 0 ? (actual_total_volume * WACM) / Actual_Operating_Income : 0",
          "unit": {
            "ref": "—"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "Operating Leverage Risk Analysis",
          "condition": "DOL > 5",
          "message": "EXTREME OPERATING LEVERAGE (DOL > 5): A 10% revenue decline will reduce operating income by more than 50%. Fixed cost structure is dangerously high relative to volume. Immediate fixed cost reduction or revenue diversification required."
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "CFA / CIMA Leverage Framework",
          "condition": "DOL > 3 && DOL <= 5",
          "message": "High Operating Leverage (DOL 3–5): Business is highly sensitive to volume fluctuations. In an economic downturn, profitability will erode rapidly. Stress-test at -15% and -30% volume scenarios."
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "Management Accounting — Margin of Safety",
          "condition": "Margin_of_Safety_Pct < 10",
          "message": "CRITICAL: Margin of Safety < 10%. Actual sales are within 10% of break-even. Any demand reduction, price pressure, or cost increase could push the business into loss. Pricing, cost structure, or volume must be addressed immediately."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "Management Accounting",
          "condition": "Margin_of_Safety_Pct >= 10 && Margin_of_Safety_Pct < 25",
          "message": "Low Margin of Safety (10–25%): Business has limited buffer above break-even. Acceptable for stable industries; concerning for cyclical manufacturing or export-dependent operations."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "Contribution Margin Ratio Analysis",
          "condition": "CM_A / product_A_price < 0.20 || CM_B / product_B_price < 0.20",
          "message": "Contribution Margin Ratio < 20% on one or more products: Very thin margin structure. Small cost increases (raw materials, energy) will immediately eliminate profitability. Price elasticity analysis required."
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "Scale Risk Assessment",
          "condition": "BEP_Revenue > 10000000",
          "message": "Break-even revenue exceeds $10M: High absolute break-even level. Ensure sales pipeline and contracted revenue cover this threshold before capacity expansion."
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {
        "measurand": "UC",
        "method": "numeric",
        "coverageFactor": 2
      },
      "requiredInputs": [
        "total_fixed_costs_usd",
        "target_net_profit_usd",
        "corporate_tax_rate_pct",
        "product_A_price",
        "product_A_vc",
        "product_A_mix_pct",
        "product_B_price",
        "product_B_vc",
        "product_B_mix_pct",
        "actual_total_volume"
      ]
    }
  ],
  "fmea": {
    "mandatoryWhen": "UC > 0.9",

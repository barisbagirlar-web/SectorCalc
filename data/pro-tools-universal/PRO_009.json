  "standards": [
    {
      "id": "PRO_009",
      "code": "ASME VIII Div.1",
      "name": "Pressure Vessel Wall Thickness Sizing (ASME VIII / PED)",
      "description": "Pressure Vessel Wall Thickness Sizing (ASME VIII / PED) — Mechanical Design, Pressure Vessels",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "t_cyl_calc",
          "expression": "(design_pressure_mpa * inner_radius_mm) / ((allowable_stress_mpa * joint_efficiency_val) - (0.6 * design_pressure_mpa))",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "t_sphere_calc",
          "expression": "(design_pressure_mpa * inner_radius_mm) / ((2 * allowable_stress_mpa * joint_efficiency_val) - (0.2 * design_pressure_mpa))",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "t_ellip_calc",
          "expression": "(design_pressure_mpa * inner_radius_mm) / ((2 * allowable_stress_mpa * joint_efficiency_val) - (0.2 * design_pressure_mpa))",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "t_hemi_calc",
          "expression": "(design_pressure_mpa * inner_radius_mm) / ((2 * allowable_stress_mpa * joint_efficiency_val) - (0.2 * design_pressure_mpa)) * 0.5",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "t_min_nominal",
          "expression": "t_cyl_calc + corrosion_allowance_mm",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "t_ordered",
          "expression": "t_min_nominal / (1 - mill_tolerance_pct / 100)",
          "unit": {
            "ref": "mm"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "MAWP",
          "expression": "(allowable_stress_mpa * joint_efficiency_val * (t_min_nominal - corrosion_allowance_mm)) / (inner_radius_mm + 0.6 * (t_min_nominal - corrosion_allowance_mm))",
          "unit": {
            "ref": "MPa"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "HydroTest_P",
          "expression": "hydro_test_factor * design_pressure_mpa",
          "unit": {
            "ref": "MPa"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Hoop_Stress",
          "expression": "(design_pressure_mpa * inner_radius_mm) / (t_min_nominal - corrosion_allowance_mm)",
          "unit": {
            "ref": "MPa"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Safety_Factor",
          "expression": "allowable_stress_mpa / Hoop_Stress",
          "unit": {
            "ref": "—"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "WARNING",
          "source": "API 571 / ASME VIII",
          "condition": "corrosion_allowance_mm < 1.5",
          "message": "Low corrosion allowance: CA < 1.5mm. Minimum 3mm is recommended for general service. Increase to 6mm if process fluid is corrosive (acid, H2S, Cl-). Insufficient CA leads to premature pinholes."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "ASME VIII UG-27",
          "condition": "Hoop_Stress > allowable_stress_mpa * 0.90",
          "message": "Critical: Hoop stress exceeds 90% of allowable stress. Safety margin is insufficient. Increase wall thickness or select material with higher S value."
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "ASME VIII Design Philosophy",
          "condition": "Safety_Factor < 3.5",
          "message": "Factor of safety is below 3.5. ASME VIII targets minimum SF=4.0 for static design. Design should be re-evaluated."
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "ASME VIII UW-11",
          "condition": "joint_efficiency_val < 1.0",
          "message": "Full RT inspection is not performed (E < 1.0). The calculated thickness requires 15-43% more material. Total cost may decrease with full RT."
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ASME VIII UCS-66 / ASTM A370",
          "condition": "design_temp_c < 0",
          "message": "Low temperature service: Impact testing (Charpy V-notch) and MDMT (Minimum Design Metal Temperature) analysis are mandatory. General carbon steel poses embrittlement risk."
        },
        {
          "id": "W6",
          "severity": "INFO",
          "source": "ASME VIII UCS-79",
          "condition": "t_ordered > 50",
          "message": "Thickness > 50mm: PWHT (Post-Weld Heat Treatment) may become mandatory. Check ASME VIII UCS-56 tables. Evaluate cost and schedule impact of heat treatment."
        }
      ],

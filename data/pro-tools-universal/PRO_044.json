      "id": "PRO_044",
      "code": "ASHRAE 15-2022 Safety Standard",
      "name": "Refrigeration System COP, Refrigerant Mass Flow & Condenser Heat Rejection",
      "description": "Refrigeration System COP, Refrigerant Mass Flow & Condenser Heat Rejection — HVAC, Refrigeration Engineering",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "q_evap_kj_kg",
          "expression": "h_evap_out_kj_kg - h_cond_out_kj_kg",
          "unit": {
            "ref": "kJ/kg"
          },
          "reference": "ASHRAE Fundamentals 2021 Ch.2 — vapour-compression cycle",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "h_2act_kj_kg",
          "expression": "h_evap_out_kj_kg + (h_cond_in_kj_kg - h_evap_out_kj_kg) / (compressor_isentropic_eff_pct / 100)",
          "unit": {
            "ref": "kJ/kg"
          },
          "reference": "η_is = (h_2s - h_1) / (h_2act - h_1)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "w_comp_kj_kg",
          "expression": "h_2act_kj_kg - h_evap_out_kj_kg",
          "unit": {
            "ref": "kJ/kg"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "m_dot_kg_s",
          "expression": "Q_evap_kw / q_evap_kj_kg",
          "unit": {
            "ref": "kg/s"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "W_comp_kw",
          "expression": "m_dot_kg_s * w_comp_kj_kg",
          "unit": {
            "ref": "kW"
          },
          "reference": "ASHRAE 15-2022 §8",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "COP",
          "expression": "Q_evap_kw / W_comp_kw; Q_cond_kw = Q_evap_kw + W_comp_kw",
          "unit": {
            "ref": "dimensionless, kW"
          },
          "reference": "First Law of Thermodynamics energy balance",
          "display": {
            "resultRow": true
          }
        }
      ],

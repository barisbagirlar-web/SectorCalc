  "standards": [
    {
      "id": "PRO_040",
      "code": "ISO 11011:2013",
      "name": "Compressed Air System Leak Loss Quantification & Repair ROI",
      "description": "Compressed Air System Leak Loss Quantification & Repair ROI — Utilities, Energy Management",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "leak_fraction",
          "expression": "load_unload_ratio - baseline_demand_pct/100",
          "unit": {
            "ref": "fraction"
          },
          "reference": "DOE Compressed Air Challenge — Fundamentals §3.2",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "P_leak_kw",
          "expression": "compressor_power_kw * Math.max(leak_fraction, 0)",
          "unit": {
            "ref": "kW"
          },
          "reference": "ISO 11011:2013 §7.3 — leak power calculation",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Q_leak_m3min",
          "expression": "P_leak_kw / specific_power_kw_m3min",
          "unit": {
            "ref": "m³/min"
          },
          "reference": "CAGI Data Sheet method — volume flow from specific power",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "E_leak_kwh",
          "expression": "P_leak_kw * operating_hours_yr",
          "unit": {
            "ref": "kWh/yr"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "leak_cost_usd_yr",
          "expression": "E_leak_kwh_yr * electricity_rate_usd_kwh",
          "unit": {
            "ref": "USD/yr"
          },
          "reference": "ISO 11011:2013 §8 — monetised loss",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "payback_months",
          "expression": "(repair_cost_usd / leak_cost_usd_yr) * 12",
          "unit": {
            "ref": "months"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ISO 11011:2013",
          "condition": "leak_fraction > 0.2",
          "message": "Leak fraction >20%: ISO 11011 threshold exceeded — immediate ultrasonic leak detection survey mandatory"
        },
        {
          "id": "W2",
          "severity": "INFO",
          "source": "ISO 11011:2013",
          "condition": "payback_months < 6",
          "message": "Repair payback < 6 months: high-priority action — schedule within current maintenance cycle"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 11011:2013",
          "condition": "payback_months > 24",
          "message": "Repair payback > 24 months: re-evaluate repair scope — prioritise high-flow leaks first (orifice Q ∝ d²)"
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "ISO 11011:2013",
          "condition": "Q_leak_m3min > compressor_power_kw / specific_power_kw_m3min * 0.3",
          "message": "Leaked flow >30% of compressor capacity: system pressure stability compromised — repair before load expansion"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ISO 11011:2013",
          "condition": "operating_hours_yr > 7000",
          "message": "High utilisation: consider automated leak monitoring (ultrasonic IoT sensors) for continuous detection per DOE guidelines"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },
      "gum": {

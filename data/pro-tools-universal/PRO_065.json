  "standards": [
    {
      "id": "PRO_065",
      "code": "ISO 22514-2:2017",
      "name": "Process Capability — Cpk, Ppk, DPMO & Sigma Level from Measurement Data",
      "description": "Process Capability — Cpk, Ppk, DPMO & Sigma Level from Measurement Data — Quality Engineering, Six Sigma",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Cp",
          "expression": "(USL - LSL) / (6 * process_std_dev)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 22514-2:2017 §4.3 — Cp = (USL−LSL) / 6σ_ST",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Cpu",
          "expression": "(USL - process_mean) / (3 * process_std_dev); Cpl = (process_mean - LSL) / (3 * process_std_dev); Cpk = Math.min(Cpu, Cpl)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AIAG SPC Manual 2nd Ed. / ISO 22514-2 §4.5 — Cpk = min(Cpu, Cpl)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Ppu",
          "expression": "(USL - process_mean) / (3 * process_std_dev_lt); Ppl = (process_mean - LSL) / (3 * process_std_dev_lt); Ppk = Math.min(Ppu, Ppl)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AIAG / ISO 22514-2 §4.7 — Ppk uses overall σ_LT including special causes",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Z_upper",
          "expression": "(USL - process_mean) / process_std_dev_lt; Z_lower = (process_mean - LSL) / process_std_dev_lt; p_defect = (1 - 0.5*(1+Math.sign(Z_upper)*Math.min(1, Math.abs(Z_upper)*0.3989))) + (0.5*(1+Math.sign(Z_lower)*Math.min(1, Math.abs(Z_lower)*0.3989)) - 0); DPMO = p_defect * 1e6 / defect_opportunity_per_unit",
          "unit": {
            "ref": "defects/million"
          },
          "reference": "Six Sigma DPMO = P(defect) × 10⁶",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Z_bench",
          "expression": "(Ppk > 0) ? Ppk * 3 + 1.5 : 0",
          "unit": {
            "ref": "sigma"
          },
          "reference": "Six Sigma convention: Z_bench = Ppk × 3 + 1.5σ shift allowance",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "sigma_true",
          "expression": "Math.sqrt(Math.max(0, process_std_dev^2 - Math.pow(gage_RR_pct/100*(USL-LSL)/6, 2))); Cpk_adj = (USL - LSL) / (6 * sigma_true) * (Cpk/Cp)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "AIAG MSA 4th Ed. §III — GRR-corrected true process capability",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ISO 22514-2:2017",
          "condition": "Cpk < 1.33",
          "message": "Cpk < 1.33: below IATF 16949 / automotive PPAP minimum — process not capable for launch; corrective action plan mandatory"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ISO 22514-2:2017",
          "condition": "Cpk > 1.0 && Ppk < 1.0",
          "message": "Cpk > 1.0 but Ppk < 1.0: process capable short-term but unstable long-term — identify and eliminate special causes per SPC reaction plan"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ISO 22514-2:2017",
          "condition": "Math.abs(Cpu - Cpl) > 0.3",
          "message": "Centering imbalance |Cpu − Cpl| > 0.3: process shifted off-target — adjust process mean; off-centre processes waste specification width"
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "ISO 22514-2:2017",
          "condition": "DPMO > 3400",
          "message": "DPMO > 3400: below 4.5σ level — customer escape risk significant; initiate DMAIC improvement project"
        },
        {
          "id": "W5",
          "severity": "WARNING",
          "source": "ISO 22514-2:2017",
          "condition": "sample_size_n < 30",
          "message": "Sample size < 30: insufficient for reliable Cpk/Ppk estimation — confidence interval on Cpk is very wide; collect minimum 30–50 points before reporting"
        }
      ],
      "decision": {

  "name": "CPM Schedule Delay, Liquidated Damages & Acceleration (Crashing) Analysis",
  "subtitle": "Project Management | Contract Engineering — FIDIC Red/Yellow/Silver Book 2017, PMBOK 7th Edition",
  "sectorPath": [
    "Project Management",
    "Contract Engineering"
  ],
  "standardsBasis": [
    "FIDIC Red/Yellow/Silver Book 2017",
    "PMBOK 7th Edition",

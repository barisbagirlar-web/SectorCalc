  "standards": [
    {
      "id": "PRO_046",
      "code": "ASME B31.8-2022 §841",
      "name": "Pipeline Wall Thickness, MAOP & Burst Pressure — Onshore Transmission Design",
      "description": "Pipeline Wall Thickness, MAOP & Burst Pressure — Onshore Transmission Design — Pipeline Engineering, Oil & Gas",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "F_factor",
          "expression": "{1: 0.72, 2: 0.60, 3: 0.50, 4: 0.40}[location_class]",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ASME B31.8-2022 §841.114 Table 841.114A",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "P_mpa",
          "expression": "MAOP_bar * 0.1; t_min_mm = (P_mpa * pipe_OD_mm) / (2 * SMYS_mpa * F_factor * joint_factor_E * temperature_derating_T)",
          "unit": {
            "ref": "mm"
          },
          "reference": "ASME B31.8 §841.11 Eq.(1) / API 5L §A.3 — Barlow hoop stress formula",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "t_nominal_mm",
          "expression": "(t_min_mm + corrosion_allowance_mm) / (1 - mill_tolerance_pct / 100)",
          "unit": {
            "ref": "mm"
          },
          "reference": "API 5L PSL2 §9.14 — dimensional tolerance on wall thickness",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Dt_ratio",
          "expression": "pipe_OD_mm / t_nominal_mm",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "API 5L — thin-wall criterion D/t < 100 for Barlow applicability",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "t_eff_mm",
          "expression": "t_nominal_mm * (1 - mill_tolerance_pct/100) - corrosion_allowance_mm; P_burst_bar = (2 * SMYS_mpa * 1.4 * t_eff_mm / pipe_OD_mm) * 10",
          "unit": {
            "ref": "bar(g)"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "safety_margin",
          "expression": "P_burst_bar / MAOP_bar",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ASME B31.8 — minimum burst/MAOP margin depends on location class",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ASME B31.8-2022 §841",
          "condition": "location_class >= 3 && F_factor === 0.72",
          "message": "Location class mismatch: Class 3/4 requires F≤0.50 per ASME B31.8 §841.114 — re-enter correct location class"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "ASME B31.8-2022 §841",
          "condition": "safety_margin < 2.0",
          "message": "Burst margin < 2.0×MAOP: marginal for Class 1 service — consider corrosion management plan per NACE SP0169"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "ASME B31.8-2022 §841",
          "condition": "corrosion_allowance_mm < 1.5 && MAOP_bar > 70",
          "message": "Low CA on high-pressure pipeline: establish inline inspection (ILI) baseline within first 5 years per API RP 1163"
        },
        {
          "id": "W4",
          "severity": "INFO",
          "source": "ASME B31.8-2022 §841",
          "condition": "joint_factor_E < 1.0 && SMYS_mpa > 414",
          "message": "ERW pipe above X60: verify seam weld toughness qualification per ISO 3183 PSL2 CVN requirements"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "ASME B31.8-2022 §841",
          "condition": "Dt_ratio < 15",
          "message": "D/t < 15: heavy-wall pipe — evaluate buckle propagation arrest capacity per API RP 1111 §4.3 for offshore or steep terrain"
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "ASME B31.8-2022 §841",
          "condition": "MAOP_bar > 150 && location_class >= 2",
          "message": "High MAOP in populated area: quantitative risk assessment (QRA) may be required by local authority"
        }
      ],
      "decision": {
        "governingOutput": "UC",
        "thresholds": {
          "pass": 0.9,
          "fail": 1
        },
        "verdictText": {
          "pass": "PASS — Capacity Satisfied",
          "warn": "PASS — High Utilization: Peer Review Required",
          "fail": "FAIL — Insufficient Capacity"
        }
      },

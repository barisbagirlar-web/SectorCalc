  "standards": [
    {
      "id": "PRO_068",
      "code": "Terzaghi (1943) / Meyerhof (1963/1976)",
      "name": "Shallow Foundation Bearing Capacity — Ultimate & Allowable Load per Terzaghi-Meyerhof",
      "description": "Shallow Foundation Bearing Capacity — Ultimate & Allowable Load per Terzaghi-Meyerhof — Geotechnical Engineering, Foundation Design",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "phi_rad",
          "expression": "phi_deg * Math.PI / 180; Nq = Math.exp(Math.PI * Math.tan(phi_rad)) * Math.pow(Math.tan(Math.PI/4 + phi_rad/2), 2); Nc = (phi_deg > 0) ? (Nq - 1) / Math.tan(phi_rad) : 5.14; Ng = 2 * (Nq + 1) * Math.tan(phi_rad)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Meyerhof (1963) — N_q = e^(π·tanφ)·tan²(45+φ/2)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "B_L",
          "expression": "foundation_width_m / foundation_length_m; sc = 1 + B_L * Nq / Nc; sq = 1 + B_L * Math.tan(phi_rad); sg = Math.max(0.6, 1 - 0.4 * B_L)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "Meyerhof shape factors — Bowles Foundation Analysis 5th Ed. §4.4",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "gamma_eff",
          "expression": "(groundwater_depth_m <= foundation_depth_m) ? gamma_soil_kn_m3 - 9.81 : gamma_soil_kn_m3; q_overburden_kpa = gamma_soil_kn_m3 * foundation_depth_m",
          "unit": {
            "ref": "kPa, kN/m³"
          },
          "reference": "EC7 EN 1997-1 §6.5.3 — buoyant weight when GWT within foundation influence zone",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "q_ult_kpa",
          "expression": "cohesion_kpa * Nc * sc + q_overburden_kpa * Nq * sq + 0.5 * gamma_eff * foundation_width_m * Ng * sg",
          "unit": {
            "ref": "kPa"
          },
          "reference": "Meyerhof general bearing capacity equation — Terzaghi (1943) base + Meyerhof (1963) shape factors",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "q_net_ult_kpa",
          "expression": "q_ult_kpa - q_overburden_kpa; q_allowable_kpa = q_net_ult_kpa / FOS_target + q_overburden_kpa",
          "unit": {
            "ref": "kPa"
          },
          "reference": "q_allow = q_net_ult / FOS + γ·D_f — Bowles §4.5",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "P_allow_kn",
          "expression": "q_allowable_kpa * foundation_width_m * foundation_length_m",
          "unit": {
            "ref": "kN"
          },
          "reference": "Structural load capacity: P = q_allow × A_foundation",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [

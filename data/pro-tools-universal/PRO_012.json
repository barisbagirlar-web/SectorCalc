    {
      "id": "PRO_012",
      "code": "ACI 207.1R-96 Mass Concrete",
      "name": "Mass Concrete Volume, Thermal Crack Risk & Pour Cost (ACI 207)",
      "description": "Mass Concrete Volume, Thermal Crack Risk & Pour Cost (ACI 207) — Civil & Structural Engineering, Concrete Works",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "Gross_Volume_m3",
          "expression": "vol_slab_m3 + vol_footing_m3 + vol_column_m3",
          "unit": {

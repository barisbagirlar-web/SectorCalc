          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "Rebar_Displacement_m3",
          "expression": "Gross_Volume_m3 * (rebar_volume_pct / 100)",
          "unit": {
            "ref": "m3"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "Net_Concrete_m3",
          "expression": "Gross_Volume_m3 - Rebar_Displacement_m3",
          "unit": {
            "ref": "m3"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Order_Volume_m3",
          "expression": "Net_Concrete_m3 * (1 + pour_waste_pct / 100)",
          "unit": {
            "ref": "m3"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "Total_Material_Cost_USD",
          "expression": "Order_Volume_m3 * concrete_unit_cost_usd",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "Total_Pour_Cost_USD",
          "expression": "Total_Material_Cost_USD + pump_mobilization_usd",
          "unit": {
            "ref": "USD"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F7",
          "output": "Cost_per_Net_m3_USD",
          "expression": "Total_Pour_Cost_USD / Net_Concrete_m3",
          "unit": {
            "ref": "USD/m³"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F8",
          "output": "Heat_of_Hydration_kJ_kg",
          "expression": "350 * cement_heat_factor",
          "unit": {
            "ref": "kJ/kg"
          },
          "reference": "",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F9",
          "output": "Adiabatic_Temp_Rise_C",
          "expression": "(cement_content_kg_m3 * Heat_of_Hydration_kJ_kg) / (2400 * 0.92)",
          "unit": {
            "ref": "degC"
          },
          "reference": ""
        },
        {
          "id": "F10",
          "output": "Peak_Core_Temp_C",
          "expression": "ambient_temp_c + Adiabatic_Temp_Rise_C",
          "unit": {
            "ref": "degC"
          },
          "reference": ""
        },
        {
          "id": "F11",
          "output": "Surface_Temp_C",
          "expression": "ambient_temp_c + 5",
          "unit": {
            "ref": "degC"
          },
          "reference": ""
        },
        {
          "id": "F12",
          "output": "Delta_T_Core_Surface",
          "expression": "Peak_Core_Temp_C - Surface_Temp_C",
          "unit": {
            "ref": "degC"
          },
          "reference": ""
        },
        {
          "id": "F13",
          "output": "Concrete_Weight_tonnes",
          "expression": "Net_Concrete_m3 * 2.4",
          "unit": {
            "ref": "tonnes"
          },
          "reference": ""
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "ACI 207.2R / EN 1992-3 Cl.M.3",
          "condition": "Delta_T_Core_Surface > 20",
          "message": "THERMAL CRACKING RISK CONFIRMED: Core-to-surface ΔT exceeds 20°C threshold. Restrained thermal shrinkage will generate tensile stresses exceeding concrete tensile strength. Through-cracking expected. Mandatory mitigations: (1) Use CEM III/B or pozzolanic cement, (2) Pre-cool mix water or aggregate, (3) Limit pour lifts to 600mm, (4) Apply thermal insulation blanket to retain surface heat."
        },
        {
          "id": "W2",
          "severity": "CRITICAL",
          "source": "ACI 207.1R / CIRIA C660",
          "condition": "Delta_T_Core_Surface > 25",
          "message": "SEVERE THERMAL CRACKING — ΔT > 25°C: At this differential, macro-cracks of 0.2–0.5mm width are near-certain. Structure integrity and watertightness compromised. Redesign concrete mix with low-heat cement and thermal monitoring sensors (embedded thermocouples) required."
        },
        {
          "id": "W3",
          "severity": "CRITICAL",
          "source": "ACI 305R Hot Weather Concreting",
          "condition": "ambient_temp_c > 32",
          "message": "HOT WEATHER CONCRETING: Ambient temperature > 32°C. Concrete may set prematurely. ACI 305R requirements: (1) Fresh concrete temperature ≤ 35°C at point of discharge, (2) Use chilled water or ice substitution, (3) Pour at night, (4) Increase slump via plasticizer — not water."
        },
        {
          "id": "W4",
          "severity": "CRITICAL",
          "source": "ACI 306R Cold Weather Concreting",
          "condition": "ambient_temp_c < 5",
          "message": "COLD WEATHER CONCRETING: Ambient < 5°C. Hydration will stall or freeze. ACI 306R: Fresh concrete must be maintained at ≥ 10°C for 7 days minimum. Insulated formwork, heated enclosure, or anti-freeze admixtures required."
        },
        {
          "id": "W5",
          "severity": "CRITICAL",
          "source": "ACI 207.1R / DEF Risk",
          "condition": "Peak_Core_Temp_C > 70",
          "message": "DELAYED ETTRINGITE FORMATION (DEF) RISK: Peak core temperature > 70°C. Ettringite phase destroyed during curing and reforms later causing expansive cracking. Use water-reducing admixtures and low-C₃A cements. This risk is irreversible once temperature is exceeded."
        },
        {
          "id": "W6",
          "severity": "WARNING",
          "source": "Construction Quantity Surveying Practice",
          "condition": "pour_waste_pct < 3",
          "message": "Waste allowance < 3%: Likely underestimated for construction site conditions. Insufficient waste factor leads to under-ordering, schedule delays, and cold joint formation. Minimum 5% recommended for poured-in-place work."
        }
      ],

  "standards": [
    {
      "id": "PRO_062",
      "code": "API 618 5th Ed. (2007)",
      "name": "Reciprocating Compressor Cylinder Sizing — Displacement, Volumetric Efficiency & Rod Load",
      "description": "Reciprocating Compressor Cylinder Sizing — Displacement, Volumetric Efficiency & Rod Load — Rotating Equipment, Gas Compression",
      "year": "2025",
      "formulas": [
        {
          "id": "F1",
          "output": "r_p",
          "expression": "P_discharge_bar / P_suction_bar",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "API 618-2007 §3.1",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F2",
          "output": "eta_v",
          "expression": "1 - clearance_pct/100 * (Math.pow(r_p, 1/k_isentropic) - 1)",
          "unit": {
            "ref": "dimensionless"
          },
          "reference": "ISO 1217:2009 §3.4 / API 618 — isentropic re-expansion model",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F3",
          "output": "V_d_m3_rev",
          "expression": "Math.PI/4 * Math.pow(bore_mm/1000, 2) * (stroke_mm/1000)",
          "unit": {
            "ref": "m³/rev"
          },
          "reference": "Displacement = π/4 × D² × S (double-acting: multiply by 2 minus rod area)",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F4",
          "output": "Q_cyl_m3h",
          "expression": "V_d_m3_rev * speed_rpm * 60 * eta_v",
          "unit": {
            "ref": "Am³/h"
          },
          "reference": "API 618 §5.3 — cylinder capacity with volumetric efficiency",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F5",
          "output": "P_is_kw",
          "expression": "(k_isentropic/(k_isentropic-1)) * P_suction_bar*1e5 * (Q_cyl_m3h/3600) * (Math.pow(r_p, (k_isentropic-1)/k_isentropic) - 1) / 1000",
          "unit": {
            "ref": "kW"
          },
          "reference": "Isentropic compression work — ASME PTC 9 §5.3",
          "display": {
            "resultRow": true
          }
        },
        {
          "id": "F6",
          "output": "A_bore_m2",
          "expression": "Math.PI/4 * Math.pow(bore_mm/1000, 2); rod_load_comp_kn = (P_discharge_bar - P_suction_bar) * 1e5 * A_bore_m2 / 1000; rod_load_tension_kn = rod_load_comp_kn * 0.85",
          "unit": {
            "ref": "kN"
          },
          "reference": "API 618 §3.11 — combined rod load",
          "display": {
            "resultRow": true
          }
        }
      ],
      "validation": [],
      "warnings": [
        {
          "id": "W1",
          "severity": "CRITICAL",
          "source": "API 618 5th Ed. (2007)",
          "condition": "r_p > 6",
          "message": "r_p > 6: very high ratio — discharge temperature will exceed 150°C for most gases; inter-stage cooling mandatory per API 618 §3.1.2"
        },
        {
          "id": "W2",
          "severity": "WARNING",
          "source": "API 618 5th Ed. (2007)",
          "condition": "rod_load_comp_kn > 450",
          "message": "Rod load > 450 kN: check against frame rated rod load in API 618 datasheet — exceeded frame load causes crankshaft and crosshead failure"
        },
        {
          "id": "W3",
          "severity": "WARNING",
          "source": "API 618 5th Ed. (2007)",
          "condition": "speed_rpm > 600 && bore_mm > 400",
          "message": "High speed on large bore: piston velocity > 4 m/s — verify ring and packing wear rates; API 618 Table 1 speed limit"
        },
        {
          "id": "W4",
          "severity": "WARNING",
          "source": "API 618 5th Ed. (2007)",
          "condition": "clearance_pct > 25",
          "message": "High clearance (>25%): volumetric efficiency severely reduced — verify unloader pocket sizing and gas passage flow velocity"
        },
        {
          "id": "W5",
          "severity": "INFO",
          "source": "API 618 5th Ed. (2007)",
          "condition": "P_discharge_bar > 100",
          "message": "Discharge pressure > 100 bar: high-pressure classification — ASME B31.3 Class 600 piping, material qualification, and pressure testing per API 618 §7 required"
        }
      ],
      "decision": {
        "governingOutput": "UC",

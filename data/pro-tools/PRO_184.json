  "formulas": [
    "Moment = (Yuk * Aciklik) / 8 // Formül",
    "Gerilme = (Moment * (Yukseklik/2)) / MAX(0.0001, (Genislik * Yukseklik^3 / 12)) // Formül",
    "Ekstra_Deger_2 = input_0 * 1.0 // Yardımcı hesaplama",
    "Ekstra_Deger_3 = input_0 * 1.0 // Yardımcı hesaplama"

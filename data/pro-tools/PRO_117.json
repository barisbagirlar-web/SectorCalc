  "engine_rules": {
    "standards": [
      "EN 1992-1-1",
      "ACI 318",
      "ISO 9001",
      "GUM"
    ],
    "validation": {
      "bw_check": {
        "action": "BLOCK",
        "condition": "b_w <= 0",
        "error_msg": "Beam width must be greater than zero.",
        "standard_ref": "EN 1992-1-1 §5.3"
      },
      "h_check": {
        "action": "BLOCK",
        "condition": "h <= 0",
        "error_msg": "Beam height must be greater than zero.",
        "standard_ref": "EN 1992-1-1 §5.3"
      },
      "d_check": {
        "action": "BLOCK",
        "condition": "d <= 0",
        "error_msg": "Effective depth must be greater than zero.",
        "standard_ref": "EN 1992-1-1 §5.3"
      },
      "d_h_check": {
        "action": "BLOCK",
        "condition": "d >= h",
        "error_msg": "Effective depth cannot exceed total beam height."
      },
      "as_check": {
        "action": "BLOCK",
        "condition": "A_s <= 0",
        "error_msg": "Tension reinforcement area must be greater than zero."
      },
      "m_ed_check": {
        "action": "BLOCK",
        "condition": "M_Ed < 0",
        "error_msg": "Design moment cannot be negative."
      },
      "v_ed_check": {
        "action": "BLOCK",
        "condition": "V_Ed < 0",
        "error_msg": "Design shear force cannot be negative."
      },
      "sv_missing": {
        "action": "BLOCK",
        "condition": "A_sv > 0 && s_v == 0",
        "error_msg": "Stirrup spacing required when shear reinforcement is provided."
      },
      "fck_missing_ec2": {
        "action": "BLOCK",
        "condition": "designStandard == 'EN_1992_1_1' && (f_ck == 0 || f_ck == undefined)",
        "error_msg": "Concrete cylinder strength f_ck required for EN 1992-1-1.",
        "standard_ref": "EN 1992-1-1 §3.1"
      },
      "fc_missing_aci": {
        "action": "BLOCK",
        "condition": "designStandard == 'ACI_318' && (f_c_prime == 0 || f_c_prime == undefined)",
        "error_msg": "Concrete compressive strength f'_c required for ACI 318.",
        "standard_ref": "ACI 318 §19.2"
      },
      "uc_fail": {
        "action": "BLOCK",
        "condition": "UC > 1.0",
        "error_msg": "Section FAILS — utilization exceeds 1.0. Redesign required."
      }
    },
    "uc_threshold": {
      "pass_max": 0.9,
      "warn_max": 1,
      "fail_min": 1
    },
    "smart_warnings": [
      {
        "id": "W_UC_WARN",
        "severity": "WARNING",
        "message": "UC = {UC} between 0.90–1.00. Engineering review required before acceptance.",
        "condition": "UC > 0.9 && UC <= 1.0",
        "source": "Engineering Review"
      },
      {
        "id": "W_UC_FAIL",
        "severity": "CRITICAL",
        "message": "UC = {UC} > 1.00. Section FAILS. Governing mode: {governingMode}. Section must be redesigned.",
        "condition": "UC > 1.0",
        "source": "Capacity Check"
      },
      {
        "id": "W_XD_EC2",
        "severity": "WARNING",
        "message": "x/d = {xd} > 0.45. Neutral axis depth limit exceeded per EN 1992-1-1 §5.5(4).",
        "condition": "designStandard == 'EN_1992_1_1' && x/d > 0.45",
        "source": "EN 1992-1-1 §5.5(4)"
      },
      {
        "id": "W_EPSILON_ACI",
        "severity": "WARNING",
        "message": "ε_t = {epsilon_t} < 0.005. Section not tension-controlled. Ductility limited.",
        "condition": "designStandard == 'ACI_318' && epsilon_t < 0.005",
        "source": "ACI 318 §9.3.3"
      },

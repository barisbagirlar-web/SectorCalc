  "server_formula_steps": [
    "Compute adjusted material cost as material_cost divided by one minus waste_rate.",
    "Compute total cost as adjusted material cost plus labor_cost plus overhead_cost.",
    "Compute gross margin as selling_price minus total_cost divided by selling_price.",
    "Compute margin leakage as adjusted material cost minus material_cost.",
    "Classify REVIEW when waste_rate is greater than or equal to one or when selling_price is zero."

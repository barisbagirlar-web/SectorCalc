  "server_formula_steps": [
    "Validate all monetary and rate inputs as finite numbers.",
    "Compute absolute gain as final_amount minus initial_amount plus cumulative cash_flow when applicable.",
    "Compute ratio result as absolute gain divided by initial_amount when initial_amount is positive.",
    "Compute annualized result as power(final_amount / initial_amount, 1 / periods) minus one when both values are positive.",
    "Classify REVIEW when denominator inputs are zero or when the output is not finite."
  ],
  "validation_contract": [
    "Reject missing required inputs.",
    "Reject non-finite numeric inputs.",
    "Reject zero or negative denominators before division.",
    "Return REVIEW when free-tool assumptions are insufficient for an irreversible field decision.",
    "Return BLOCKED when the requested calculation cannot produce finite results."

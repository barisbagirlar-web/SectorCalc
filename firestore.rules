rules_version = '2';

// SectorCalc MVP — lead intents only.
//
// Production posture:
// - Public clients may CREATE leadIntents with validated fields only.
// - Public READ / UPDATE / DELETE are denied.
//
// Admin panel (/admin/leads): read only for Firebase Auth users with admin claim.
// Writes from admin panel go through Cloud Function (Admin SDK), not client SDK.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Math Kernel Calculation Results ─────────────────────────────────
    // Elite security: frontend clients CANNOT manipulate ulp_error_margin.
    // Only backend (Admin SDK) or kernel-authenticated writes pass through.
    // Mathematical integrity: value MUST be within [lower_bound, upper_bound].
    match /calculations/{calcId} {
      allow read: if true;
      allow create: if
        request.auth != null
        && request.resource.data.keys().hasAll([
          'value',
          'lower_bound',
          'upper_bound',
          'ulp_error_margin',
        ])
        && request.resource.data.ulp_error_margin is number
        && request.resource.data.ulp_error_margin >= 0
        && request.resource.data.value is number
        && request.resource.data.value >= request.resource.data.lower_bound
        && request.resource.data.value <= request.resource.data.upper_bound;
      allow update, delete: if false;
    }

    match /leadIntents/{leadId} {
      allow read: if isAuthenticatedAdmin();
      allow update, delete: if false;

      allow create: if
        leadId == request.resource.data.id
        && isValidLeadIntentCreate(request.resource.data);

      match /activity/{activityId} {
        allow read: if isAuthenticatedAdmin();
        allow write: if false;
      }
    }

    match /betaPartners/{partnerId} {
      allow read: if isAuthenticatedAdmin();
      allow update, delete: if false;
      allow create: if
        partnerId == request.resource.data.id
        && isValidBetaPartnerCreate(request.resource.data);
    }

    match /benchmarkSubmissions/{submissionId} {
      allow read: if isAuthenticatedAdmin();
      allow update, delete: if false;
      allow create: if
        submissionId == request.resource.data.id
        && isValidBenchmarkSubmissionCreate(request.resource.data);
    }

    match /reportFeedback/{feedbackId} {
      allow read: if isAuthenticatedAdmin();
      allow update, delete: if false;
      allow create: if
        feedbackId == request.resource.data.id
        && isValidReportFeedbackCreate(request.resource.data);
    }

    match /calculator_feedback/{feedbackId} {
      allow read: if isAuthenticatedAdmin();
      allow update, delete: if false;
      allow create: if
        feedbackId == request.resource.data.id
        && isValidCalculatorFeedbackCreate(request.resource.data);
    }

    match /toolFeedback/{feedbackId} {
      allow read: if isAuthenticatedAdmin();
      allow update: if isAuthenticatedAdmin()
        && isValidToolFeedbackAdminUpdate(request.resource.data, resource.data);
      allow delete: if false;
      allow create: if
        feedbackId == request.resource.data.id
        && isValidToolFeedbackCreate(request.resource.data);
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      match /purchases/{purchaseId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /credits/{creditDocId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /machines/{machineId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /emissionFactors/{categoryId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId;
        allow delete: if false;
      }
    }

    match /emissionFactors/{factorId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /premiumEntitlements/{entitlementId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /creditTransactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow update, delete: if false;
    }

    match /machines/{machineId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Approved calculation reports (Trust Trace / Validation Stamp)
    // Writes are performed server-side via Admin SDK only.
    // Public read is allowed for the /verify endpoint (public_verify visibility).
    // Private fields (userEmail, userId) must be stripped before returning to public callers.
    match /approvedReports/{reportId} {
      // Public read: any issued/revoked report with public_verify visibility
      allow read: if resource.data.visibility == 'public_verify';

      // Client writes are forbidden — Admin SDK only
      allow create, update, delete: if false;
    }

    // Published success stories (runtime CMS via Admin API + ISR public pages)
    match /caseStudies/{studyId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticatedAdmin();
    }
  }
}

function isAuthenticatedAdmin() {
  return request.auth != null && request.auth.token.admin == true;
}

function isValidLeadIntentCreate(data) {
  return hasValidLeadKeys(data)
    && isValidLeadId(data.id)
    && isValidShortText(data.name, 2, 120)
    && isValidEmail(data.email)
    && isValidShortText(data.company, 2, 160)
    && isValidShortText(data.industry, 2, 80)
    && isValidShortText(data.toolRequested, 2, 160)
    && isValidShortText(data.intendedUse, 2, 120)
    && isValidPagePath(data.pagePath)
    && isValidCreatedAt(data.createdAt)
    && data.status == 'new'
    && data.storageMode == 'firestore'
    && isValidLeadSource(data.source)
    && isValidOptionalPlan(data)
    && isValidOptionalMessage(data);
}

function hasValidLeadKeys(data) {
  return data.keys().hasOnly([
      'id',
      'name',
      'email',
      'company',
      'industry',
      'toolRequested',
      'intendedUse',
      'message',
      'source',
      'pagePath',
      'plan',
      'createdAt',
      'status',
      'storageMode',
    ]);
}

function isValidLeadId(id) {
  return id is string
    && id.size() >= 8
    && id.size() <= 80
    && id.matches('^lead_[A-Za-z0-9._-]+$');
}

function isValidShortText(value, minLen, maxLen) {
  return value is string
    && value.size() >= minLen
    && value.size() <= maxLen;
}

function isValidEmail(email) {
  return email is string
    && email.size() >= 5
    && email.size() <= 254
    && email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
}

function isValidPagePath(path) {
  return path is string
    && path.size() >= 1
    && path.size() <= 256
    && path.matches('^/.*');
}

function isValidCreatedAt(value) {
  return value is string
    && value.size() >= 20
    && value.size() <= 40;
}

function isValidLeadSource(source) {
  return source in [
    'premium_unlock',
    'pricing',
    'export',
    'sample_report',
    'unknown',
  ];
}

function isValidOptionalPlan(data) {
  return !('plan' in data)
    || data.plan in [
      'single_report',
      'sector_pass',
      'pro',
      'free',
      'unknown',
    ];
}

function isValidOptionalMessage(data) {
  return !('message' in data)
    || (data.message is string && data.message.size() <= 500);
}

function isValidBetaPartnerCreate(data) {
  return hasValidBetaPartnerKeys(data)
    && isValidBetaPartnerId(data.id)
    && isValidShortText(data.companyName, 0, 160)
    && isValidShortText(data.contactName, 0, 120)
    && (data.companyName.size() >= 2 || data.contactName.size() >= 2)
    && isValidEmail(data.email)
    && isValidShortText(data.country, 2, 80)
    && isValidShortText(data.industry, 2, 80)
    && isValidShortText(data.companySize, 2, 40)
    && isValidShortText(data.role, 2, 80)
    && isValidShortText(data.mainLossArea, 2, 160)
    && isValidShortText(data.currentMethod, 2, 160)
    && isValidShortText(data.monthlyEstimatedLossRange, 2, 40)
    && data.wantsCaseStudyPermission is bool
    && isValidShortText(data.notes, 0, 1000)
    && isValidCreatedAt(data.createdAt)
    && isValidCreatedAt(data.updatedAt)
    && data.status == 'new';
}

function hasValidBetaPartnerKeys(data) {
  return data.keys().hasOnly([
      'id',
      'createdAt',
      'updatedAt',
      'status',
      'companyName',
      'contactName',
      'email',
      'country',
      'industry',
      'companySize',
      'role',
      'mainLossArea',
      'currentMethod',
      'monthlyEstimatedLossRange',
      'wantsCaseStudyPermission',
      'notes',
    ]);
}

function isValidBetaPartnerId(id) {
  return id is string
    && id.size() >= 8
    && id.size() <= 80
    && id.matches('^beta_[A-Za-z0-9._-]+$');
}

function isValidBenchmarkSubmissionCreate(data) {
  return hasValidBenchmarkSubmissionKeys(data)
    && isValidBenchmarkSubmissionId(data.id)
    && isValidBenchmarkSource(data.source)
    && isValidShortText(data.sectorSlug, 2, 80)
    && isValidShortText(data.toolSlug, 2, 80)
    && isValidShortText(data.country, 2, 80)
    && isValidShortText(data.currency, 2, 8)
    && isValidShortText(data.companySize, 2, 40)
    && data.inputSnapshot is map
    && data.inputSnapshot.size() <= 40
    && data.resultSnapshot is map
    && data.resultSnapshot.size() <= 40
    && isValidUserReportedAccuracy(data.userReportedAccuracy)
    && isValidShortText(data.userComment, 0, 1000)
    && data.permissionForAnonymizedBenchmark is bool
    && data.permissionForCaseStudy is bool
    && data.reviewedByAdmin is bool
    && data.reviewedByAdmin == false
    && isValidBenchmarkReviewStatus(data.reviewStatus)
    && data.reviewStatus == 'pending'
    && isValidCreatedAt(data.createdAt)
    && isValidCreatedAt(data.updatedAt);
}

function hasValidBenchmarkSubmissionKeys(data) {
  return data.keys().hasOnly([
      'id',
      'createdAt',
      'updatedAt',
      'source',
      'sectorSlug',
      'toolSlug',
      'country',
      'currency',
      'companySize',
      'inputSnapshot',
      'resultSnapshot',
      'userReportedAccuracy',
      'userComment',
      'permissionForAnonymizedBenchmark',
      'permissionForCaseStudy',
      'reviewedByAdmin',
      'reviewStatus',
    ]);
}

function isValidBenchmarkSubmissionId(id) {
  return id is string
    && id.size() >= 8
    && id.size() <= 80
    && id.matches('^benchmark_[A-Za-z0-9._-]+$');
}

function isValidBenchmarkSource(source) {
  return source in [
    'beta_partner',
    'premium_report_feedback',
    'manual_admin',
  ];
}

function isValidUserReportedAccuracy(value) {
  return value in ['low', 'medium', 'high'];
}

function isValidBenchmarkReviewStatus(value) {
  return value in ['pending', 'approved', 'rejected'];
}

function isValidReportFeedbackCreate(data) {
  return hasValidReportFeedbackKeys(data)
    && isValidReportFeedbackId(data.id)
    && isValidShortText(data.schemaSlug, 2, 80)
    && isValidShortText(data.sectorSlug, 2, 80)
    && isValidReportFeedbackRating(data.rating)
    && isValidShortText(data.usefulness, 2, 40)
    && isValidShortText(data.formulaFit, 2, 40)
    && isValidShortText(data.missingVariable, 0, 160)
    && isValidShortText(data.comment, 0, 800)
    && data.permissionForBenchmark is bool
    && isValidCreatedAt(data.createdAt)
    && isValidOptionalReportSlug(data);
}

function isValidOptionalReportSlug(data) {
  return !('reportSlug' in data)
    || (data.reportSlug is string && data.reportSlug.size() >= 2 && data.reportSlug.size() <= 80);
}

function hasValidReportFeedbackKeys(data) {
  let keys = data.keys();
  return keys.hasAll([
      'id',
      'createdAt',
      'schemaSlug',
      'sectorSlug',
      'rating',
      'usefulness',
      'formulaFit',
      'missingVariable',
      'comment',
      'permissionForBenchmark',
    ])
    && keys.size() >= 10
    && keys.size() <= 11;
}

function isValidReportFeedbackRating(rating) {
  return rating is number && rating >= 1 && rating <= 5;
}

function isValidReportFeedbackId(id) {
  return id is string
    && id.size() >= 8
    && id.size() <= 80
    && id.matches('^feedback_[A-Za-z0-9._-]+$');
}

function isValidCalculatorFeedbackCreate(data) {
  return hasValidCalculatorFeedbackKeys(data)
    && isValidCalculatorFeedbackId(data.id)
    && isValidShortText(data.toolSlug, 2, 80)
    && isValidCalculatorFeedbackTier(data.tier)
    && isValidCalculatorFeedbackCategory(data.category)
    && isValidShortText(data.comment, 0, 800)
    && isValidPagePath(data.pagePath)
    && isValidCreatedAt(data.createdAt)
    && isValidOptionalCalculatorFeedbackSnapshot(data, 'inputSnapshot')
    && isValidOptionalCalculatorFeedbackSnapshot(data, 'resultSnapshot');
}

function hasValidCalculatorFeedbackKeys(data) {
  let keys = data.keys();
  return keys.hasAll([
      'id',
      'createdAt',
      'toolSlug',
      'tier',
      'category',
      'comment',
      'pagePath',
    ])
    && keys.size() >= 7
    && keys.size() <= 9;
}

function isValidCalculatorFeedbackId(id) {
  return id is string
    && id.size() >= 8
    && id.size() <= 80
    && id.matches('^calcfb_[A-Za-z0-9._-]+$');
}

function isValidCalculatorFeedbackTier(tier) {
  return tier in ['free', 'premium', 'traffic'];
}

function isValidCalculatorFeedbackCategory(category) {
  return category in [
    'formula_not_matching_field',
    'missing_input',
    'wrong_unit',
    'result_unrealistic',
    'industry_assumption_wrong',
    'other',
  ];
}

function isValidOptionalCalculatorFeedbackSnapshot(data, field) {
  return !(field in data)
    || (data[field] is map && data[field].size() <= 40);
}

function isValidToolFeedbackId(id) {
  return id is string
    && id.size() >= 8
    && id.size() <= 80
    && id.matches('^tfb_[A-Za-z0-9._-]+$');
}

function isValidToolFeedbackKind(kind) {
  return kind in [
    'formula_objection',
    'wrong_result',
    'missing_input',
    'improvement_request',
    'sector_adjustment',
    'data_source_suggestion',
    'usability_issue',
    'other',
  ];
}

function isValidToolFeedbackStatus(status) {
  return status in [
    'new',
    'triaged',
    'in_review',
    'accepted',
    'rejected',
    'implemented',
    'closed',
  ];
}

function isValidToolFeedbackSeverity(severity) {
  return severity in ['low', 'medium', 'high', 'critical'];
}

function isValidToolFeedbackSource(source) {
  return source in [
    'premium_tool',
    'free_tool',
    'smart_form',
    'report',
    'verify',
    'unknown',
  ];
}

function isValidToolFeedbackToolType(toolType) {
  return toolType in ['free', 'premium', 'unknown'];
}

function isValidToolFeedbackMessage(message) {
  return message is string
    && message.size() >= 10
    && message.size() <= 2000;
}

function isValidOptionalToolFeedbackText(data, field, maxLen) {
  return !(field in data)
    || (data[field] is string && data[field].size() <= maxLen);
}

function isValidOptionalToolFeedbackUrl(data) {
  return !('dataSourceUrl' in data)
    || (data.dataSourceUrl is string && data.dataSourceUrl.size() <= 512);
}

function isValidOptionalToolFeedbackSnapshot(data, field) {
  return !(field in data)
    || (data[field] is map && data[field].size() <= 40);
}

function isValidOptionalToolFeedbackNullableString(data, field, maxLen) {
  return !(field in data)
    || data[field] == null
    || (data[field] is string && data[field].size() <= maxLen);
}

function hasValidToolFeedbackKeys(data) {
  let keys = data.keys();
  return keys.hasAll([
      'id',
      'kind',
      'status',
      'severity',
      'source',
      'toolSlug',
      'toolType',
      'locale',
      'routePath',
      'message',
      'createdAt',
      'updatedAt',
    ])
    && keys.size() >= 12
    && keys.size() <= 28;
}

function isValidToolFeedbackCreate(data) {
  return hasValidToolFeedbackKeys(data)
    && isValidToolFeedbackId(data.id)
    && isValidToolFeedbackKind(data.kind)
    && data.status == 'new'
    && isValidToolFeedbackSeverity(data.severity)
    && isValidToolFeedbackSource(data.source)
    && isValidShortText(data.toolSlug, 2, 80)
    && isValidToolFeedbackToolType(data.toolType)
    && isValidShortText(data.locale, 2, 8)
    && isValidPagePath(data.routePath)
    && isValidToolFeedbackMessage(data.message)
    && isValidCreatedAt(data.createdAt)
    && isValidCreatedAt(data.updatedAt)
    && isValidOptionalToolFeedbackText(data, 'expectedBehavior', 1000)
    && isValidOptionalToolFeedbackText(data, 'actualBehavior', 1000)
    && isValidOptionalToolFeedbackText(data, 'sectorContext', 500)
    && isValidOptionalToolFeedbackText(data, 'suggestedFormulaChange', 1500)
    && isValidOptionalToolFeedbackText(data, 'suggestedInput', 500)
    && isValidOptionalToolFeedbackUrl(data)
    && isValidOptionalToolFeedbackText(data, 'formulaVersion', 80)
    && isValidOptionalToolFeedbackText(data, 'formulaContractId', 120)
    && isValidOptionalToolFeedbackText(data, 'calculationHash', 128)
    && isValidOptionalToolFeedbackText(data, 'reportId', 80)
    && isValidOptionalToolFeedbackSnapshot(data, 'inputSnapshot')
    && isValidOptionalToolFeedbackSnapshot(data, 'resultSnapshot')
    && isValidOptionalToolFeedbackNullableString(data, 'userId', 128)
    && isValidOptionalToolFeedbackNullableString(data, 'userEmail', 254)
    && isValidOptionalToolFeedbackNullableString(data, 'sessionId', 80)
    && isValidOptionalToolFeedbackText(data, 'userAgent', 256);
}

function isValidToolFeedbackAdminUpdate(newData, oldData) {
  return newData.diff(oldData).affectedKeys().hasOnly(['status', 'updatedAt'])
    && isValidToolFeedbackStatus(newData.status)
    && isValidCreatedAt(newData.updatedAt);
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sectorcal.local/schemas/sectorcal-document.json",
  "title": "SectorcalDocument",
  "description": "Root JSON document envelope for SECTORCAL data interchange.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "payload"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  }
}

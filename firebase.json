{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" ci --no-audit --no-fund",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "source": ".",
    "build": {
      "command": "node scripts/firebase-hosting-build.mjs"
    },
    "ignore": [
      "firebase.json",
      "firebase.e2e.json",
      "service-account.json",
      ".git/**",
      ".github/**",
      ".sectorcalc-build.lock",
      ".next-deploy.lock",
      "**/node_modules/**",
      "**/debug.log",
      "**/*.log",
      ".env.local"
    ],
    "redirects": [
      {
        "host": "www.sectorcalc.com",
        "source": "/<path>",
        "destination": "https://sectorcalc.com/<path>",
        "type": 301
      },
      { "source": "/tools/pro/compressed-air-leak-cost-calculator", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/pressure-vessel-wall-thickness-mawp-hydrotest-package", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/pressure-relief-valve-sizing-sheet-api-520", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/fillet-weld-sizing-verification-sheet-ec3-aws-d11", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/structural-connection-verification-dossier-ec3-aisc", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/bolted-connection-verifier", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/bolt-torque-preload-spec-card-vdi-2230", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/lifting-rigging-crane-plan-suite", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/gdt-fit-clearance-calculator-iso-286", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/tolerance-stack-up-root-cause-report-wc-rss", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/measurement-uncertainty-budget-gum-iso-17025", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/first-article-inspection-report-builder-as9102-lite", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/compressed-air-leak-energy-audit-report-iso-11011", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/cbam-definitive-period-compliance-package", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/cbam-cost-exposure-hedging-forecaster", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/cbam-supplier-emissions-data-sheet", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/machining-cycle-time-part-cost-sheet", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/sealed-job-quote-certificate-fire-setup-vade", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/steel-structure-weight-cost-takeoff", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/compressed-air-pipe-sizing-pressure-drop", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/hydraulic-cylinder-pump-sizing", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/pump-system-curve-npsh-verifier", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/shaft-deflection-critical-speed-check", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/scope-1-2-3-splitter-for-smes", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/bank-grade-financial-projection-covenant-model", "destination": "/pro-tools", "type": 301 },
      { "source": "/tools/pro/ppap-gauge-rr-cpk-ppk-quality-submission-bundle", "destination": "/pro-tools", "type": 301 }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=63072000; includeSubDomains; preload"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "function": "ssrsectorcalcbf412",
        "region": "us-central1"
      }
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "memory": "1GiB",
      "concurrency": 20,
      "maxInstances": 3
    }
  }
}

{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "hosting": {
    "source": ".",
    "build": {
      "command": "node scripts/firebase-hosting-build.mjs"
    },
    "ignore": [
      "firebase.json",
      "service-account.json",
      "**/.*",
      "**/node_modules/**",
      "**/debug.log",
      "**/*.log",
      ".git/**"
    ],
    "frameworksBackend": {
      "region": "us-central1",
      "memory": "512MiB",
      "concurrency": 20,
      "maxInstances": 3
    }
  }
}

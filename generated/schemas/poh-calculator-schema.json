      }
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Temperature in degrees Celsius. Used to calculate water autoionization constant pKw. Standard pOH assumes 25°C where Kw = 1e-14.",
      "label_i18n": {
        "en": "Temperature",
        "tr": "Temperature",
        "de": "Temperature",
        "fr": "Temperature",
        "es": "Temperature",
        "ar": "Temperature"
      }
    },
    {
      "id": "sampleVolume",
      "label": "Sample Volume",
      "type": "number",
      "unit": "L",
      "default": 1,
      "businessContext": "Volume of the aqueous sample in liters. For reference and scaling calculations.",
      "label_i18n": {
        "en": "Sample Volume",
        "tr": "Sample Volume",
        "de": "Sample Volume",
        "fr": "Sample Volume",
        "es": "Sample Volume",
        "ar": "Sample Volume"
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty",
      "type": "number",
      "unit": "%",
      "default": 0.1,
      "businessContext": "Relative uncertainty of the hydroxide measurement, expressed as a percentage. For quality assurance documentation.",
      "label_i18n": {
        "en": "Measurement Uncertainty",
        "tr": "Measurement Uncertainty",
        "de": "Measurement Uncertainty",
        "fr": "Measurement Uncertainty",
        "es": "Measurement Uncertainty",
        "ar": "Measurement Uncertainty"
      }
    }
  ],
  "formulas": {
    "pOH": "-Math.log(ohConcentration)/Math.log(10)",
    "pKw": "14 - 0.045 * (temperature - 25)",
    "pH": "(14 - 0.045 * (temperature - 25)) + Math.log(ohConcentration)/Math.log(10)",
    "hConcentration": "10 ** (-((14 - 0.045 * (temperature - 25)) + Math.log(ohConcentration)/Math.log(10)))"
  },
  "outputs": {
    "primary": "pOH",
    "breakdown": [
      "pH",
      "pKw",
      "hConcentration"
    ]
  },

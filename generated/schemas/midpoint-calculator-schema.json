{
  "toolName": "midpoint-calculator",
  "inputs": [
    {
      "id": "x1",
      "label": "X1 Coordinate",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Starting point X coordinate",
      "label_i18n": {
        "en": "X1 Coordinate",
        "tr": "X1 Coordinate",
        "de": "X1 Coordinate",
        "fr": "X1 Coordinate",
        "es": "X1 Coordinate",
        "ar": "X1 Coordinate"
      }
    },
    {
      "id": "y1",
      "label": "Y1 Coordinate",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Starting point Y coordinate",
      "label_i18n": {
        "en": "Y1 Coordinate",
        "tr": "Y1 Coordinate",
        "de": "Y1 Coordinate",
        "fr": "Y1 Coordinate",
        "es": "Y1 Coordinate",
        "ar": "Y1 Coordinate"
      }
    },
    {
      "id": "x2",
      "label": "X2 Coordinate",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Ending point X coordinate",
      "label_i18n": {
        "en": "X2 Coordinate",
        "tr": "X2 Coordinate",
        "de": "X2 Coordinate",
        "fr": "X2 Coordinate",
        "es": "X2 Coordinate",
        "ar": "X2 Coordinate"
      }
    },
    {
      "id": "y2",
      "label": "Y2 Coordinate",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Ending point Y coordinate",
      "label_i18n": {
        "en": "Y2 Coordinate",
        "tr": "Y2 Coordinate",
        "de": "Y2 Coordinate",
        "fr": "Y2 Coordinate",
        "es": "Y2 Coordinate",
        "ar": "Y2 Coordinate"
      }
    }
  ],
  "formulas": {
    "midX": "(x1 + x2) / 2",
    "midY": "(y1 + y2) / 2",
    "dist": "Math.sqrt(Math.pow(x2 - x1, 2) + Math.pow(y2 - y1, 2))",
    "__dist__m": "${dist} m",
    "__midX__m": "${midX} m",
    "__midY__m": "${midY} m",
    "result": "Midpoint: (${midX} m, ${midY} m)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Distance between points: ${dist} m",
      "Midpoint X: ${midX} m",
      "Midpoint Y: ${midY} m"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

{
  "toolName": "gear-ratio-calculator",
  "inputs": [
    {
      "id": "drivingTeeth",
      "label": "Driving Gear Teeth",
      "type": "number",
      "unit": "teeth",
      "default": 20,
      "businessContext": "Number of teeth on the driving (input) gear.",
      "label_i18n": {
        "en": "Driving Gear Teeth",
        "tr": "Driving Gear Teeth",
        "de": "Driving Gear Teeth",
        "fr": "Driving Gear Teeth",
        "es": "Driving Gear Teeth",
        "ar": "Driving Gear Teeth"
      }
    },
    {
      "id": "drivenTeeth",
      "label": "Driven Gear Teeth",
      "type": "number",
      "unit": "teeth",
      "default": 40,
      "businessContext": "Number of teeth on the driven (output) gear.",
      "label_i18n": {
        "en": "Driven Gear Teeth",
        "tr": "Driven Gear Teeth",
        "de": "Driven Gear Teeth",
        "fr": "Driven Gear Teeth",
        "es": "Driven Gear Teeth",
        "ar": "Driven Gear Teeth"
      }
    },
    {
      "id": "inputSpeed",
      "label": "Input Speed",
      "type": "number",
      "unit": "rpm",
      "default": 1000,
      "businessContext": "Rotational speed of the driving gear in revolutions per minute.",
      "label_i18n": {
        "en": "Input Speed",
        "tr": "Input Speed",
        "de": "Input Speed",
        "fr": "Input Speed",
        "es": "Input Speed",
        "ar": "Input Speed"
      }
    },
    {
      "id": "inputTorque",
      "label": "Input Torque",
      "type": "number",
      "unit": "Nm",
      "default": 50,
      "businessContext": "Torque applied to the driving gear in Newton-meters.",
      "label_i18n": {
        "en": "Input Torque",
        "tr": "Input Torque",
        "de": "Input Torque",
        "fr": "Input Torque",
        "es": "Input Torque",
        "ar": "Input Torque"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Efficiency of the gear pair in percentage (0-100). If not provided, assumes 100% (ideal).",
      "label_i18n": {
        "en": "Efficiency",
        "tr": "Efficiency",
        "de": "Efficiency",
        "fr": "Efficiency",
        "es": "Efficiency",
        "ar": "Efficiency"
      }
    }
  ],
  "formulas": {
    "ratio": "drivenTeeth / drivingTeeth",
    "outputSpeed": "inputSpeed / (drivenTeeth / drivingTeeth)",
    "outputTorque": "inputTorque * (drivenTeeth / drivingTeeth) * (Math.min(Math.max(efficiency, 0), 100) / 100)",
    "__outputSpeed__RPM": "${outputSpeed} RPM",
    "__outputTorque__Nm": "${outputTorque} Nm",
    "__ratio__1": "${ratio}:1"
  },
  "outputs": {
    "primary": "ratio",
    "breakdown": [
      "Output Speed: ${outputSpeed} RPM",
      "Output Torque: ${outputTorque} Nm",
      "Mechanical Advantage: ${ratio}:1"
    ]
  },
  "category": "Verimlilik & OEE",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "efficiency"
}

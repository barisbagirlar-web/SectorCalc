{
  "toolName": "net-positive-suction-head-available-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "mechanical-hvac-energy-loss",
  "sector": "Mechanical Engineering",
  "sectorId": "mechanical-hvac-energy-loss",
  "inputs": [
    {
      "id": "pressure",
      "label": "Liquid Surface Pressure (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 101325,
      "min": 0,
      "businessContext": "Tank or atmospheric pressure."
    },
    {
      "id": "buharBasinci",
      "label": "Vapor Pressure (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 5000,
      "min": 0,
      "businessContext": "Vapor pressure at pumping temperature."
    },
    {
      "id": "density",
      "label": "Liquid Density (kg/m³)",
      "type": "number",
      "unit": "kg/m3",
      "default": 1000,
      "min": 0,
      "businessContext": "Pumped fluid density."
    },
    {
      "id": "height",
      "label": "Liquid Level to Pump (m)",
      "type": "number",
      "unit": "m",
      "default": 3,
      "min": 0,
      "businessContext": "Positive if suction lift."
    },
    {
      "id": "kayip",
      "label": "Suction Line Loss (m)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0,
      "businessContext": "Friction loss in suction pipe."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(pressure - buharBasinci) / Math.max(0.0001, (density * 9.81)) + height - kayip"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "NPSH (Net Pozitif Emme Height)"
    },
    "breakdownUnits": {
      "result": "m"
    },

  "formulas": {
    "differences": "after - before",
    "absDifferences": "Math.abs(differences)",
    "ranks": "rank(absDifferences, nonZeroMask)",
    "signedRanks": "ranks * Math.sign(differences)",
    "Wplus": "sum(signedRanks > 0)",
    "Wminus": "sum(signedRanks < 0)",
    "W": "Math.min(Wplus, Wminus)",
    "n": "count(nonZeroMask)",
    "expectedW": "n * (n + 1) / 4",
    "stdW": "Math.sqrt(n * (n + 1) * (2 * n + 1) / 24)",
    "z": "(W - expectedW) / stdW",
    "pValue": "2 * (1 - normalCDF(Math.abs(z)))",
    "rejectNull": "pValue < alpha",
    "W___sum_of_positive_ranks_": "W+ (sum of positive ranks)",
    "W___sum_of_negative_ranks_": "W- (sum of negative ranks)",
    "n__number_of_non_zero_differences_": "n (number of non-zero differences)",
    "z_score": "z-score",
    "p_value": "p-value",
    "Reject_null_hypothesis_": "Reject null hypothesis?"
  },
  "outputs": {
    "primary": "differences",
    "breakdown": [

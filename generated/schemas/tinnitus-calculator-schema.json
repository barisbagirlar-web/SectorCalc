      }
    },
    {
      "id": "hearingProtection_dB",
      "label": "Hearing Protector NRR",
      "type": "number",
      "unit": "dB",
      "default": 0,
      "businessContext": "Noise Reduction Rating (NRR) of the hearing protector used",
      "label_i18n": {
        "en": "Hearing Protector NRR",
        "tr": "İşitme Koruyucu NRR",
        "de": "Gehörschutz-NRR",
        "fr": "NRR de la protection auditive",
        "es": "NRR del Protector Auditivo",
        "ar": "قيمة تقليل الضوضاء (NRR) لوسائل حماية السمع"
      },
      "businessContext_i18n": {
        "en": "Noise Reduction Rating (NRR) of the hearing protector used",
        "tr": "Kullanılan işitme koruyucunun Gürültü Azaltma Değeri (NRR)",
        "de": "Geräuschminderungswert (NRR) des verwendeten Gehörschutzes",
        "fr": "Indice de réduction du bruit (NRR) de la protection auditive utilisée",
        "es": "Valor de Reducción de Ruido (NRR) del protector auditivo utilizado",
        "ar": "قيمة تقليل الضوضاء (NRR) لوسيلة حماية السمع المستخدمة"
      }
    }
  ],
  "formulas": {
    "adjustedNoiseLevel": "noiseLevel_dBA - (hearingProtection_dB > 0 ? (hearingProtection_dB - 7) / 2 : 0)",
    "permissibleTime": "480 / (2 ^ ((adjustedNoiseLevel - 85) / 3))",
    "dailyDosePercent": "(exposureDuration_h * 60) / permissibleTime * 100",
    "tinnitusRiskScore": "((adjustedNoiseLevel - 80) * exposureYears * (age_years / 40)) / 100"
  },
  "outputs": {
    "primary": "tinnitusRiskScore",
    "breakdown": [
      "adjustedNoiseLevel",
      "permissibleTime",
      "dailyDosePercent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "tinnitusRiskScore",
    "unit": "score",
    "breakdownUnits": {
      "adjustedNoiseLevel": "dBA",
      "permissibleTime": "minutes",
      "dailyDosePercent": "%"
    }
  },
  "category": "Health & Safety",
  "sector": "Healthcare & Medical",

        "ar": "Weight"
      }
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Height in centimeters",
      "label_i18n": {
        "en": "Height",
        "tr": "Height",
        "de": "Height",
        "fr": "Height",
        "es": "Height",
        "ar": "Height"
      }
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age in full years",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "gender",
      "label": "Gender (0=Female, 1=Male)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Biological sex indicator: 0 for female, 1 for male",
      "label_i18n": {
        "en": "Gender (0=Female, 1=Male)",
        "tr": "Gender (0=Female, 1=Male)",
        "de": "Gender (0=Female, 1=Male)",
        "fr": "Gender (0=Female, 1=Male)",
        "es": "Gender (0=Female, 1=Male)",
        "ar": "Gender (0=Female, 1=Male)"
      }
    }
  ],
  "formulas": {
    "lbm": "weight * 0.732 + height * 0.203 - age * 0.002 - gender * 0.016 + 14.0",
    "bodyFatMass": "weight - lbm",
    "bodyFatPercentage": "(bodyFatMass / weight) * 100"
  },
  "outputs": {
    "primary": "lbm",
    "breakdown": [
      "bodyFatMass",
      "bodyFatPercentage"
    ]
  },
  "category": "Yalın Üretim",

{
  "toolName": "water-conservation-calculator",
  "inputs": [
    {
      "id": "currentConsumption",
      "label": "Current Water Consumption",
      "type": "number",
      "unit": "m³",
      "default": 1000,
      "businessContext": "Total water usage in the current period",
      "label_i18n": {
        "en": "Current Water Consumption",
        "tr": "Mevcut Su Tüketimi",
        "de": "Current Water Consumption",
        "fr": "Current Water Consumption",
        "es": "Current Water Consumption",
        "ar": "Current Water Consumption"
      },
      "businessContext_i18n": {
        "en": "Total water usage in the current period",
        "tr": "Cari dönemdeki toplam su kullanımı"
      }
    },
    {
      "id": "baselineConsumption",
      "label": "Baseline Water Consumption",
      "type": "number",
      "unit": "m³",
      "default": 1200,
      "businessContext": "Water consumption in a reference period for comparison",
      "label_i18n": {
        "en": "Baseline Water Consumption",
        "tr": "Baz Su Tüketimi",
        "de": "Baseline Water Consumption",
        "fr": "Baseline Water Consumption",
        "es": "Baseline Water Consumption",
        "ar": "Baseline Water Consumption"
      },
      "businessContext_i18n": {
        "en": "Water consumption in a reference period for comparison",
        "tr": "Karşılaştırma için referans dönemdeki su tüketimi"
      }
    },
    {
      "id": "waterCostPerCubicMeter",
      "label": "Water Cost per m³",
      "type": "number",
      "unit": "currency/m³",
      "default": 2.5,
      "businessContext": "Unit cost of water supply",
      "label_i18n": {
        "en": "Water Cost per m³",
        "tr": "Metreküp Başına Su Maliyeti",
        "de": "Water Cost per m³",
        "fr": "Water Cost per m³",
        "es": "Water Cost per m³",
        "ar": "Water Cost per m³"
      },
      "businessContext_i18n": {
        "en": "Unit cost of water supply",
        "tr": "Su temininin birim maliyeti"
      }
    },
    {
      "id": "leakagePercentage",
      "label": "Leakage Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Estimated percentage of water lost due to leaks",
      "label_i18n": {
        "en": "Leakage Percentage",
        "tr": "Kaçak Yüzdesi",
        "de": "Leakage Percentage",
        "fr": "Leakage Percentage",
        "es": "Leakage Percentage",
        "ar": "Leakage Percentage"
      },
      "businessContext_i18n": {
        "en": "Estimated percentage of water lost due to leaks",
        "tr": "Sızıntılar nedeniyle kaybedilen suyun tahmini yüzdesi"
      }
    },
    {
      "id": "efficiencyImprovementPercentage",
      "label": "Efficiency Improvement Target",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Target percentage reduction in water use through efficiency measures",
      "label_i18n": {
        "en": "Efficiency Improvement Target",
        "tr": "Verimlilik İyileştirme Hedefi",
        "de": "Efficiency Improvement Target",
        "fr": "Efficiency Improvement Target",
        "es": "Efficiency Improvement Target",
        "ar": "Efficiency Improvement Target"
      },
      "businessContext_i18n": {
        "en": "Target percentage reduction in water use through efficiency measures",
        "tr": "Verimlilik önlemleriyle su kullanımında hedeflenen yüzde azalma"
      }
    }
  ],
  "formulas": {
    "waterWasteFromLeaks": "currentConsumption * (leakagePercentage / 100)",
    "efficiencySavings": "baselineConsumption * (efficiencyImprovementPercentage / 100)",
    "totalPotentialWaterSavings": "efficiencySavings + waterWasteFromLeaks",
    "costSavings": "totalPotentialWaterSavings * waterCostPerCubicMeter"
  },
  "outputs": {
    "primary": "totalPotentialWaterSavings",
    "breakdown": [
      "efficiencySavings",
      "waterWasteFromLeaks",
      "costSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costSavings",
    "unit": "m³",
    "breakdownUnits": {
      "efficiencySavings": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,

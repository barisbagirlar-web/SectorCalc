{
  "toolName": "spackle-calculator",
  "inputs": [
    {
      "id": "areaToCover",
      "label": "Wall Area (m²)",
      "type": "number",
      "unit": "m²",
      "default": 10,
      "businessContext": "Total surface area that requires spackling",
      "label_i18n": {
        "en": "Wall Area (m²)",
        "tr": "Wall Area (m²)",
        "de": "Wall Area (m²)",
        "fr": "Wall Area (m²)",
        "es": "Wall Area (m²)",
        "ar": "Wall Area (m²)"
      }
    },
    {
      "id": "numberOfHoles",
      "label": "Number of Holes",
      "type": "number",
      "unit": "unit",
      "default": 50,
      "businessContext": "Approximate count of holes to fill",
      "label_i18n": {
        "en": "Number of Holes",
        "tr": "Number of Holes",
        "de": "Number of Holes",
        "fr": "Number of Holes",
        "es": "Number of Holes",
        "ar": "Number of Holes"
      }
    },
    {
      "id": "holeDiameter",
      "label": "Average Hole Diameter (mm)",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Diameter of typical holes in millimeters",
      "label_i18n": {
        "en": "Average Hole Diameter (mm)",
        "tr": "Average Hole Diameter (mm)",
        "de": "Average Hole Diameter (mm)",
        "fr": "Average Hole Diameter (mm)",
        "es": "Average Hole Diameter (mm)",
        "ar": "Average Hole Diameter (mm)"
      }
    },
    {
      "id": "holeDepth",
      "label": "Average Hole Depth (mm)",
      "type": "number",
      "unit": "mm",
      "default": 3,
      "businessContext": "Depth of typical holes in millimeters",
      "label_i18n": {
        "en": "Average Hole Depth (mm)",
        "tr": "Average Hole Depth (mm)",
        "de": "Average Hole Depth (mm)",
        "fr": "Average Hole Depth (mm)",
        "es": "Average Hole Depth (mm)",
        "ar": "Average Hole Depth (mm)"
      }
    },
    {
      "id": "spackleDensity",
      "label": "Spackle Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1500,
      "businessContext": "Density of the spackle compound used",
      "label_i18n": {
        "en": "Spackle Density",
        "tr": "Spackle Density",
        "de": "Spackle Density",
        "fr": "Spackle Density",
        "es": "Spackle Density",
        "ar": "Spackle Density"
      }
    },
    {
      "id": "containerSize",
      "label": "Container Size (kg)",
      "type": "number",
      "unit": "kg",
      "default": 5,
      "businessContext": "Net weight of a single spackle container",
      "label_i18n": {
        "en": "Container Size (kg)",
        "tr": "Container Size (kg)",
        "de": "Container Size (kg)",
        "fr": "Container Size (kg)",
        "es": "Container Size (kg)",
        "ar": "Container Size (kg)"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Extra material to account for waste and spillage",
      "label_i18n": {
        "en": "Waste Factor (%)",
        "tr": "Waste Factor (%)",
        "de": "Waste Factor (%)",
        "fr": "Waste Factor (%)",
        "es": "Waste Factor (%)",
        "ar": "Waste Factor (%)"
      }
    }
  ],
  "formulas": {
    "volumePerHole": "Math.PI * Math.pow((holeDiameter / 2 / 1000), 2) * (holeDepth / 1000)",
    "totalVolume": "numberOfHoles * volumePerHole",
    "spackleWeightKg": "totalVolume * spackleDensity",
    "totalWithWaste": "spackleWeightKg * (1 + wasteFactor / 100)",
    "containersNeeded": "totalWithWaste / containerSize"
  },
  "outputs": {
    "primary": "totalWithWaste",
    "breakdown": [
      "volumePerHole",
      "totalVolume",
      "containersNeeded"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "conversion"
}

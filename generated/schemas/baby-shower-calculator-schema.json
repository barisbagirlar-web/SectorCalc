      }
    },
    {
      "id": "waterCostPerLiter",
      "label": "Water Cost per Liter",
      "type": "number",
      "unit": "currency/L",
      "default": 0.002,
      "businessContext": "Cost of water per liter",
      "label_i18n": {
        "en": "Water Cost per Liter",
        "tr": "Su Maliyeti (Litre başına)",
        "de": "Water Cost per Liter",

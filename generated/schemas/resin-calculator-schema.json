        "ar": "Resin Density"
      },
      "businessContext_i18n": {
        "en": "Density of resin",
        "tr": "Reçinenin yoğunluğu",
        "de": "Dichte des Harzes",
        "fr": "Densité de la résine",
        "es": "Densidad de la resina"
      }
    },
    {
      "id": "hardenerDensity",
      "label": "Hardener Density",
      "type": "number",
      "unit": "g/cm³",
      "default": 0.95,
      "businessContext": "Density of hardener",
      "label_i18n": {
        "en": "Hardener Density",
        "tr": "Sertleştirici Yoğunluğu",
        "de": "Härterdichte",
        "fr": "Densité du durcisseur",
        "es": "Densidad del endurecedor",
        "ar": "Hardener Density"
      },
      "businessContext_i18n": {
        "en": "Density of hardener",
        "tr": "Sertleştiricinin yoğunluğu",
        "de": "Dichte des Härters",
        "fr": "Densité du durcisseur",
        "es": "Densidad del endurecedor"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Extra material percentage for waste and spillage",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Atık Faktörü",
        "de": "Abfallfaktor",
        "fr": "Facteur de perte",
        "es": "Factor de desperdicio",
        "ar": "Waste Factor"
      },
      "businessContext_i18n": {
        "en": "Extra material percentage for waste and spillage",
        "tr": "Atık ve dökülme için ekstra malzeme yüzdesi",
        "de": "Zusätzlicher Materialanteil für Abfall und Verschütten",
        "fr": "Pourcentage de matière supplémentaire pour déchets et pertes",
        "es": "Porcentaje extra de material por desperdicio y derrames"
      }
    }
  ],
  "formulas": {
    "totalVolume": "area * thickness",
    "resinWeight": "(totalVolume / ((resinRatio / hardenerRatio) / resinDensity + 1 / hardenerDensity)) * (resinRatio / hardenerRatio) * (1 + wasteFactor / 100)",
    "hardenerWeight": "(totalVolume / ((resinRatio / hardenerRatio) / resinDensity + 1 / hardenerDensity)) * (1 + wasteFactor / 100)",
    "resinVolume": "resinWeight / resinDensity",
    "hardenerVolume": "hardenerWeight / hardenerDensity",
    "totalWeight": "resinWeight + hardenerWeight"
  },
  "outputs": {
    "primary": "totalWeight",
    "breakdown": [
      "resinWeight",
      "hardenerWeight",
      "resinVolume",
      "hardenerVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalWeight",
    "unit": "m²"
  },

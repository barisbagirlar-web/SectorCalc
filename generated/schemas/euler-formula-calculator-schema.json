    "imagFromPolar": "modulus * Math.sin(angleDeg * Math.PI / 180)",
    "modulusFromRect": "Math.sqrt(realPart * realPart + imagPart * imagPart)",
    "angleFromRect": "Math.atan2(imagPart, realPart) * 180 / Math.PI",

    "VariancePct": "Variance / TotalFoodSales",
    "WasteCost": "RecordedWaste * AvgPortionCost",
    "TheftLoss": "Variance - WasteCost - CompMeals",
    "IdealMargin": "1 - (TheoreticalFoodCost / TotalFoodSales)",

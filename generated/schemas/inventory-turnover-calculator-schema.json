        "fr": "Days in Period",
        "es": "Days in Period",
        "ar": "Days in Period"
      }
    }
  ],
  "formulas": {
    "averageInventory": "(beginInventory + endInventory) / 2",
    "inventoryTurnover": "cogs / averageInventory",

{
  "toolName": "kombinasyon-hesaplayici",
  "inputs": [
    {
      "id": "n",
      "label": "Toplam Eleman Sayısı (n)",
      "type": "number",
      "unit": "adet",
      "default": 10,
      "businessContext": "Kümenin toplam eleman sayısı"
    },
    {
      "id": "r",
      "label": "Seçilecek Eleman Sayısı (r)",
      "type": "number",
      "unit": "adet",
      "default": 3,
      "businessContext": "Kombinasyon için seçilecek eleman sayısı"
    }
  ],
  "formulas": {
    "combination": "Math.round(Math.exp(lnFactorial(n) - lnFactorial(r) - lnFactorial(n - r)))",
    "lnFactorial": "function(x) { if (x <= 1) return 0; let sum = 0; for (let i = 2; i <= x; i++) sum += Math.log(i); return sum; }"
  },
  "outputs": {
    "primary": "Kombinasyon Sayısı",
    "breakdown": [
      "C(n, r) = n! / (r! * (n-r)!)",
      "Hesaplanan değer: {combination}"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

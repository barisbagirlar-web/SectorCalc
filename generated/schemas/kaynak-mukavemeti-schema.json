  "formulas": {
    "ThroatThickness": "Leg * COS(45)",
    "Area_Shear": "ThroatThickness * Length",
    "AllowableShearStress": "0.3 * TensileStrength_Electrode",
    "MaxLoad_Shear": "Area_Shear * AllowableShearStress",
    "SafetyFactor": "MaxLoad_Shear / AppliedLoad",
    "BendingStress": "(AppliedMoment * ThroatThickness) / MomentOfInertia",
    "CombinedStress": "SQRT(ShearStress^2 + BendingStress^2)"
  },

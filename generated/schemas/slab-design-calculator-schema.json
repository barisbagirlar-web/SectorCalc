  "formulas": {
    "self_weight": "thickness * 25 / 1000",
    "total_dead": "dead_load + self_weight",
    "factored_load": "1.35 * total_dead + 1.5 * live_load",
    "factored_moment": "factored_load * span * span / 8",
    "d": "thickness - cover - 5",
    "K": "factored_moment * 1e6 / (1000 * d * d * concrete_strength)"
  },
  "outputs": {
    "primary": "K",
    "breakdown": [
      "factored_moment",
      "steel_ratio",

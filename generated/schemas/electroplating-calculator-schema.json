{
  "toolName": "electroplating-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Surface Area",
      "type": "number",
      "unit": "cm²",
      "default": 100,
      "businessContext": "total area to be plated",
      "label_i18n": {
        "en": "Surface Area",
        "tr": "Surface Area",
        "de": "Surface Area",
        "fr": "Surface Area",
        "es": "Surface Area",
        "ar": "Surface Area"
      }
    },
    {
      "id": "thickness",
      "label": "Plating Thickness",
      "type": "number",
      "unit": "µm",
      "default": 10,
      "businessContext": "desired coating thickness",
      "label_i18n": {
        "en": "Plating Thickness",
        "tr": "Plating Thickness",
        "de": "Plating Thickness",
        "fr": "Plating Thickness",
        "es": "Plating Thickness",
        "ar": "Plating Thickness"
      }
    },
    {
      "id": "currentDensity",
      "label": "Current Density",
      "type": "number",
      "unit": "A/dm²",
      "default": 2,
      "businessContext": "applied current per unit area",
      "label_i18n": {
        "en": "Current Density",
        "tr": "Current Density",
        "de": "Current Density",
        "fr": "Current Density",
        "es": "Current Density",
        "ar": "Current Density"
      }
    },
    {
      "id": "efficiency",
      "label": "Cathode Efficiency",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "percentage of current used for metal deposition",
      "label_i18n": {
        "en": "Cathode Efficiency",
        "tr": "Cathode Efficiency",
        "de": "Cathode Efficiency",
        "fr": "Cathode Efficiency",
        "es": "Cathode Efficiency",
        "ar": "Cathode Efficiency"
      }
    },
    {
      "id": "density",
      "label": "Metal Density",
      "type": "number",
      "unit": "g/cm³",
      "default": 8.96,
      "businessContext": "density of plating metal",
      "label_i18n": {
        "en": "Metal Density",
        "tr": "Metal Density",
        "de": "Metal Density",
        "fr": "Metal Density",
        "es": "Metal Density",
        "ar": "Metal Density"
      }
    },
    {
      "id": "atomicWeight",
      "label": "Atomic Weight",
      "type": "number",
      "unit": "g/mol",
      "default": 63.55,
      "businessContext": "molar mass of metal",
      "label_i18n": {
        "en": "Atomic Weight",
        "tr": "Atomic Weight",
        "de": "Atomic Weight",
        "fr": "Atomic Weight",
        "es": "Atomic Weight",
        "ar": "Atomic Weight"
      }
    },
    {
      "id": "valence",
      "label": "Valence",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "number of electrons transferred per ion",
      "label_i18n": {
        "en": "Valence",
        "tr": "Valence",
        "de": "Valence",
        "fr": "Valence",
        "es": "Valence",
        "ar": "Valence"
      }
    }
  ],
  "formulas": {
    "areaDm2": "inputs.area / 100",
    "current": "inputs.currentDensity * areaDm2",
    "mass": "inputs.area * (inputs.thickness / 10000) * inputs.density",
    "timeSeconds": "(mass * inputs.valence * 96485) / (current * inputs.atomicWeight * (inputs.efficiency / 100))",
    "time": "timeSeconds / 60",
    "charge": "current * timeSeconds"
  },
  "outputs": {
    "primary": "time",
    "breakdown": [
      "mass",
      "charge",
      "current"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "catalogCategory": "chemistry-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "metal-plastics-forming",
  "premiumRequired": false
}

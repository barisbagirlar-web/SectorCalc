  "formulas": {
    "basePremium": "0.002 * buildingValue",
    "riskFactor": "seismicZone * constructionType",
    "riskAdjustedPremium": "basePremium * riskFactor",
    "ageFactor": "1 + buildingAge * 0.01",
    "ageAdjustedPremium": "riskAdjustedPremium * ageFactor",
    "deductibleFactor": "1 - deductible / 100",
    "finalPremium": "ageAdjustedPremium * deductibleFactor"
  },
  "outputs": {
    "primary": "finalPremium",

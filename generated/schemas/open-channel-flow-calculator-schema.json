      "label": "Channel Slope (S)",
      "type": "number",
      "unit": "m/m",
      "default": 0.001,
      "businessContext": "Longitudinal slope of the channel bed",
      "label_i18n": {
        "en": "Channel Slope (S)",
        "tr": "Channel Slope (S)",
        "de": "Channel Slope (S)",
        "fr": "Channel Slope (S)",
        "es": "Channel Slope (S)",

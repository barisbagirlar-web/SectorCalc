    },
    {
      "id": "gravity",
      "label": "Gravity (g)",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Acceleration due to gravity",
      "label_i18n": {
        "en": "Gravity (g)",
        "tr": "Gravity (g)",
        "de": "Gravity (g)",
        "fr": "Gravity (g)",
        "es": "Gravity (g)",
        "ar": "Gravity (g)"
      }
    }
  ],
  "formulas": {
    "A": "(bottomWidth + sideSlope * depth) * depth",
    "P": "bottomWidth + 2 * depth * Math.sqrt(1 + sideSlope * sideSlope)",
    "R": "A / P",
    "Discharge": "(1 / manningN) * A * Math.pow(R, 2 / 3) * Math.sqrt(slope)",
    "Velocity": "Discharge / A",
    "TopWidth": "bottomWidth + 2 * sideSlope * depth",
    "HydraulicDepth": "A / TopWidth",
    "FroudeNumber": "Velocity / Math.sqrt(gravity * HydraulicDepth)",
    "SpecificEnergy": "depth + (Velocity * Velocity) / (2 * gravity)",
    "Velocity__m_s_": "Velocity (m/s)",
    "Froude_Number": "Froude Number",
    "Hydraulic_Radius__m_": "Hydraulic Radius (m)",
    "result": "Discharge (m³/s)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Velocity (m/s)",
      "Froude Number",
      "Hydraulic Radius (m)"
    ]
  },

{
  "toolName": "open-channel-flow-calculator",
  "inputs": [
    {
      "id": "bottomWidth",
      "label": "Bottom Width (b)",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Width of the channel base"
    },
    {
      "id": "depth",
      "label": "Flow Depth (y)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Vertical distance from channel bottom to water surface"
    },
    {
      "id": "sideSlope",
      "label": "Side Slope (z)",
      "type": "number",
      "unit": "m/m",
      "default": 1.5,
      "businessContext": "Horizontal distance per unit vertical rise of the channel bank"
    },
    {
      "id": "manningN",
      "label": "Manning's n",
      "type": "number",
      "unit": "s/m^(1/3)",
      "default": 0.013,
      "businessContext": "Roughness coefficient of the channel lining"
    },
    {
      "id": "slope",
      "label": "Channel Slope (S)",
      "type": "number",
      "unit": "m/m",
      "default": 0.001,
      "businessContext": "Longitudinal slope of the channel bed"
    },
    {
      "id": "gravity",
      "label": "Gravity (g)",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Acceleration due to gravity"
    }
  ],
  "formulas": {
    "A": "(bottomWidth + sideSlope * depth) * depth",
    "P": "bottomWidth + 2 * depth * Math.sqrt(1 + sideSlope * sideSlope)",
    "R": "A / P",
    "Discharge": "(1 / manningN) * A * Math.pow(R, 2 / 3) * Math.sqrt(slope)",
    "Velocity": "Discharge / A",
    "TopWidth": "bottomWidth + 2 * sideSlope * depth",
    "HydraulicDepth": "A / TopWidth",
    "FroudeNumber": "Velocity / Math.sqrt(gravity * HydraulicDepth)",
    "SpecificEnergy": "depth + (Velocity * Velocity) / (2 * gravity)"
  },
  "outputs": {
    "primary": "Discharge (m³/s)",
    "breakdown": [
      "Velocity (m/s)",
      "Froude Number",
      "Hydraulic Radius (m)"
    ]
  },
  "category": "İnşaat & Saha",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management"
}

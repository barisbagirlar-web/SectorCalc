{
  "toolName": "natural-log-calculator",
  "inputs": [
    {
      "id": "inputValue",
      "label": "Input Value",
      "type": "number",
      "unit": "dimensionless",
      "default": 2.71828,
      "businessContext": "Value to compute natural logarithm of (e.g., process ratio, dimensionless parameter)",
      "label_i18n": {
        "en": "Input Value",
        "tr": "Input Value",
        "de": "Input Value",
        "fr": "Input Value",
        "es": "Input Value",
        "ar": "Input Value"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "digits",
      "default": 4,
      "businessContext": "Number of decimal places for output",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "scaleFactor",
      "label": "Scale Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.434294,
      "businessContext": "Multiply the natural log by this factor (e.g., 0.434294 converts to log10)",
      "label_i18n": {
        "en": "Scale Factor",
        "tr": "Scale Factor",
        "de": "Scale Factor",
        "fr": "Scale Factor",
        "es": "Scale Factor",
        "ar": "Scale Factor"
      }
    },
    {
      "id": "offset",
      "label": "Offset",
      "type": "number",
      "unit": "dimensionless",
      "default": 0,
      "businessContext": "Add or subtract an offset to the scaled log value",
      "label_i18n": {
        "en": "Offset",
        "tr": "Offset",
        "de": "Offset",
        "fr": "Offset",
        "es": "Offset",
        "ar": "Offset"
      }
    },
    {
      "id": "expDisplay",
      "label": "Display e^x",
      "type": "number",
      "unit": "dimensionless",
      "default": 0,
      "businessContext": "Set to 1 to output e^x instead of the scaled natural log",
      "label_i18n": {
        "en": "Display e^x",
        "tr": "Display e^x",
        "de": "Display e^x",
        "fr": "Display e^x",
        "es": "Display e^x",
        "ar": "Display e^x"
      }
    }
  ],
  "formulas": {
    "rawNaturalLog": "Math.log(inputValue)",
    "scaledValue": "rawNaturalLog * scaleFactor + offset",
    "exponentialValue": "Math.exp(inputValue)",
    "naturalLogValue": "Number((expDisplay === 1 ? Math.exp(inputValue) : (Math.log(inputValue) * scaleFactor + offset)).toFixed(precision))"
  },
  "outputs": {
    "primary": "naturalLogValue",
    "breakdown": [
      "rawNaturalLog",
      "scaledValue",
      "exponentialValue"
    ]
  },

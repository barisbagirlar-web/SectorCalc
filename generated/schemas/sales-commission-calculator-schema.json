      "id": "baseSalary",
      "label": "Base Salary",
      "type": "number",
      "unit": "currency",
      "default": 2000,
      "businessContext": "Fixed base salary regardless of sales.",
      "label_i18n": {
        "en": "Base Salary",
        "tr": "Temel Maaş",
        "de": "Base Salary",

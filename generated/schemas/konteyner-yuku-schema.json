  "formulas": {
    "Volume_Utilization": "SUM(ItemVolume_i) / ContainerMaxVolume",
    "Weight_Utilization": "SUM(ItemWeight_i) / ContainerMaxPayload",
    "ChargeableWeight": "MAX(GrossWeight, VolumetricWeight)",
    "LoadEfficiency": "MIN(Volume_Utilization, Weight_Utilization)",
    "WastedSpaceCost": "(1 - LoadEfficiency) * FreightCost",
    "PalletStacking": "Floor(ContainerHeight / PalletHeight)",
    "MaxPallets": "MIN(PalletStacking * FloorArea_Pallets, WeightLimit / PalletWeight)"
  },

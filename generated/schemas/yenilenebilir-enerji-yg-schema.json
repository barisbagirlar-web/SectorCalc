  "formulas": {
    "AnnualGeneration": "SystemCapacity * CapacityFactor * 8760",
    "AnnualSavings": "AnnualGeneration * GridElectricityRate",
    "AnnualOPEX": "Maintenance + Insurance + InverterReplacementFund",
    "NetCashFlow": "AnnualSavings - AnnualOPEX + Incentives",
    "PaybackPeriod": "TotalCapex / NetCashFlow",
    "LCOE": "(TotalCapex + SUM(OPEX_t / (1+r)^t)) / SUM(Generation_t / (1+r)^t)",
    "NPV": "SUM(NetCashFlow_t / (1+WACC)^t) - TotalCapex"
  },

{
  "toolName": "us-dress-size-to-eu-calculator",
  "inputs": [
    {
      "id": "usDressSize",
      "label": "US dress size",
      "type": "number",
      "unit": "size",
      "default": 4,
      "businessContext": "Numeric US women's dress size (e.g., 0, 2, 4, ...). Typically even numbers, but decimals are accepted.",
      "label_i18n": {
        "en": "US dress size",
        "tr": "US dress size",
        "de": "US dress size",
        "fr": "US dress size",
        "es": "US dress size",
        "ar": "US dress size"
      }
    },
    {
      "id": "ageGroup",
      "label": "Age group",
      "type": "number",
      "unit": "option",
      "default": 0,
      "businessContext": "0: Women (standard), 1: Juniors, 2: Plus size. Affects base offset for EU conversion.",
      "label_i18n": {
        "en": "Age group",
        "tr": "Age group",
        "de": "Age group",
        "fr": "Age group",
        "es": "Age group",
        "ar": "Age group"
      }
    },
    {
      "id": "brandAdjustment",
      "label": "Brand adjustment",
      "type": "number",
      "unit": "size",
      "default": 0,
      "businessContext": "Manual adjustment for brand-specific fit (e.g., -1 for smaller fit, +1 for larger fit). Can be negative.",
      "label_i18n": {
        "en": "Brand adjustment",
        "tr": "Brand adjustment",
        "de": "Brand adjustment",
        "fr": "Brand adjustment",
        "es": "Brand adjustment",
        "ar": "Brand adjustment"
      }
    },
    {
      "id": "precision",
      "label": "Precision",
      "type": "number",
      "unit": "decimal places",
      "default": 0,
      "businessContext": "Number of decimal places for the EU size output. Use 0 for integer sizes.",
      "label_i18n": {
        "en": "Precision",
        "tr": "Precision",
        "de": "Precision",
        "fr": "Precision",
        "es": "Precision",
        "ar": "Precision"
      }
    }
  ],
  "formulas": {
    "baseOffset": "ageGroup == 1 ? 30 : (ageGroup == 2 ? 34 : 32)",
    "rawEuSize": "usDressSize + baseOffset + brandAdjustment"
  },
  "outputs": {
    "primary": "baseOffset",
    "breakdown": [
      "US input: {usDressSize}",
      "Base offset: {baseOffset}",
      "Adjusted EU size (before rounding): {rawEuSize}",
      "Final EU size: {euSize}"

{
  "toolName": "roth-ira-vs-traditional-ira-calculator",
  "inputs": [
    {
      "id": "annualContribution",
      "label": "Annual Contribution",
      "type": "number",
      "unit": "currency",
      "default": 6000,
      "businessContext": "Amount you plan to contribute each year to the IRA (pre-tax for Traditional, after tax for Roth).",
      "label_i18n": {
        "en": "Annual Contribution",
        "tr": "Annual Contribution",
        "de": "Annual Contribution",
        "fr": "Annual Contribution",
        "es": "Annual Contribution",
        "ar": "Annual Contribution"
      }
    },
    {
      "id": "currentAge",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Your current age.",
      "label_i18n": {
        "en": "Current Age",
        "tr": "Current Age",
        "de": "Current Age",
        "fr": "Current Age",
        "es": "Current Age",
        "ar": "Current Age"
      }
    },
    {
      "id": "retirementAge",
      "label": "Retirement Age",
      "type": "number",
      "unit": "years",
      "default": 65,
      "businessContext": "Age at which you plan to retire and start withdrawals.",
      "label_i18n": {
        "en": "Retirement Age",
        "tr": "Retirement Age",
        "de": "Retirement Age",
        "fr": "Retirement Age",
        "es": "Retirement Age",
        "ar": "Retirement Age"
      }
    },
    {
      "id": "currentTaxRate",
      "label": "Current Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 22,
      "businessContext": "Your current marginal income tax rate (e.g., 22 for 22%).",
      "label_i18n": {
        "en": "Current Tax Rate",
        "tr": "Current Tax Rate",
        "de": "Current Tax Rate",
        "fr": "Current Tax Rate",
        "es": "Current Tax Rate",
        "ar": "Current Tax Rate"
      }
    },
    {
      "id": "retirementTaxRate",
      "label": "Expected Retirement Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 22,
      "businessContext": "Your expected marginal tax rate in retirement (e.g., 22 for 22%).",
      "label_i18n": {
        "en": "Expected Retirement Tax Rate",
        "tr": "Expected Retirement Tax Rate",
        "de": "Expected Retirement Tax Rate",
        "fr": "Expected Retirement Tax Rate",
        "es": "Expected Retirement Tax Rate",
        "ar": "Expected Retirement Tax Rate"
      }
    },
    {
      "id": "annualReturnRate",
      "label": "Expected Annual Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected average annual return on investments (assumed > 0%).",
      "label_i18n": {
        "en": "Expected Annual Return",
        "tr": "Expected Annual Return",
        "de": "Expected Annual Return",
        "fr": "Expected Annual Return",
        "es": "Expected Annual Return",
        "ar": "Expected Annual Return"
      }
    }
  ],
  "formulas": {
    "n": "retirementAge - currentAge",
    "r": "annualReturnRate / 100",
    "fvFactor": "(1 + r) ** n",
    "fvContributionsTraditional": "annualContribution * ((fvFactor - 1) / r)",
    "traditionalAfterTax": "fvContributionsTraditional * (1 - retirementTaxRate / 100)",
    "effectiveRothContribution": "annualContribution * (1 - currentTaxRate / 100)",
    "fvContributionsRoth": "effectiveRothContribution * ((fvFactor - 1) / r)",
    "rothAfterTax": "fvContributionsRoth"
  },
  "outputs": {
    "primary": "n",
    "breakdown": [
      {
        "label": "Roth After-Tax Value",
        "formula": "rothAfterTax",
        "unit": "currency"
      },
      {
        "label": "Traditional After-Tax Value",
        "formula": "traditionalAfterTax",
        "unit": "currency"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rothAfterTax",
    "unit": "currency"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

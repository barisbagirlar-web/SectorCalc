{
  "toolName": "diet-break-calculator",
  "inputs": [
    {
      "id": "dailyCalories",
      "label": "Günlük Kalori Hedefi",
      "type": "number",
      "unit": "kcal",
      "default": 2000,
      "businessContext": "Çalışanın günlük enerji ihtiyacı"
    },
    {
      "id": "dietDays",
      "label": "Diyet Gün Sayısı",
      "type": "number",
      "unit": "days",
      "default": 5,
      "businessContext": "Diyet uygulanacak gün sayısı"
    },
    {
      "id": "breakDays",
      "label": "Diyet Arası Gün Sayısı",
      "type": "number",
      "unit": "days",
      "default": 2,
      "businessContext": "Diyete ara verilecek gün sayısı"
    },
    {
      "id": "activityFactor",
      "label": "Aktivite Faktörü",
      "type": "number",
      "unit": "multiplier",
      "default": 1.2,
      "businessContext": "Sedanter (1.2), Hafif Aktif (1.375), Orta Aktif (1.55), Çok Aktif (1.725)"
    },
    {
      "id": "weight",
      "label": "Vücut Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Çalışanın vücut ağırlığı"
    }
  ],
  "formulas": {
    "totalWeeklyCalories": "dailyCalories * dietDays + (dailyCalories * activityFactor) * breakDays",
    "averageDailyCalories": "(dailyCalories * dietDays + (dailyCalories * activityFactor) * breakDays) / (dietDays + breakDays)",
    "breakDayCalories": "dailyCalories * activityFactor",
    "calorieDifference": "(dailyCalories * dietDays + (dailyCalories * activityFactor) * breakDays) / (dietDays + breakDays) - dailyCalories"
  },
  "outputs": {
    "primary": "Ortalama Günlük Kalori",
    "breakdown": [
      "Diyet Arası Gün Kalorisi",
      "Toplam Haftalık Kalori",
      "Kalori Açığı/Fazlası"
    ]
  },
  "category": "Finans & İK",
  "sector": "Perakende & Gıda",
  "premiumRequired": false
}
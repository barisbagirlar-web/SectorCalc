  "formulas": {
    "totalWeeklyCalories": "dailyCalories * dietDays + (dailyCalories * activityFactor) * breakDays",
    "averageDailyCalories": "(dailyCalories * dietDays + (dailyCalories * activityFactor) * breakDays) / (dietDays + breakDays)",
    "breakDayCalories": "dailyCalories * activityFactor",
    "calorieDifference": "(dailyCalories * dietDays + (dailyCalories * activityFactor) * breakDays) / (dietDays + breakDays) - dailyCalories"
  },
  "outputs": {
    "primary": "totalWeeklyCalories",
    "breakdown": [

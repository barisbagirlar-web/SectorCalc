      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Number of times to apply L'Hopital's rule (differentiate numerator and denominator).",
      "label_i18n": {
        "en": "L'Hopital Iterations",
        "tr": "L'Hopital Iterations",

        "ar": "L'Hopital Iterations"
      }
    }
  ],
  "formulas": {
    "numerator_derivative": "numerator_coeff * numerator_power * (limit_point ** (numerator_power - 1))",
    "denominator_derivative": "denominator_coeff * denominator_power * (limit_point ** (denominator_power - 1))",
    "limit_value": "numerator_derivative / denominator_derivative"
  },
  "outputs": {
    "primary": "limit_value",
    "breakdown": [
      "numerator_derivative",
      "denominator_derivative"

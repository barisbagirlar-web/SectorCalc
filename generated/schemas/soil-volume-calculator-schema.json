      }
    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Width of the excavation or fill area (meters)",
      "label_i18n": {
        "en": "Width",
        "tr": "Width",
        "de": "Width",
        "fr": "Width",
        "es": "Width",
        "ar": "Width"
      }
    },
    {
      "id": "depth",
      "label": "Depth",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "Depth of soil to be moved (meters)",
      "label_i18n": {
        "en": "Depth",
        "tr": "Depth",
        "de": "Depth",
        "fr": "Depth",
        "es": "Depth",
        "ar": "Depth"
      }
    },
    {
      "id": "density",
      "label": "Soil Density",
      "type": "number",
      "unit": "t/m³",
      "default": 1.6,
      "businessContext": "Average bulk density of the soil (tonnes per cubic meter, typically 1.2-2.0)",
      "label_i18n": {
        "en": "Soil Density",
        "tr": "Soil Density",
        "de": "Soil Density",
        "fr": "Soil Density",
        "es": "Soil Density",
        "ar": "Soil Density"
      }
    },
    {
      "id": "compactionFactor",
      "label": "Swell / Compaction Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.2,
      "businessContext": "Factor accounting for soil swell after excavation or compaction requirement (1.0 = no change, >1 for extra volume needed)",
      "label_i18n": {
        "en": "Swell / Compaction Factor",
        "tr": "Swell / Compaction Factor",
        "de": "Swell / Compaction Factor",
        "fr": "Swell / Compaction Factor",
        "es": "Swell / Compaction Factor",
        "ar": "Swell / Compaction Factor"
      }
    }
  ],
  "formulas": {
    "soilVolume": "length * width * depth * compactionFactor",
    "soilVolumeYards": "length * width * depth * compactionFactor * 1.30795",
    "soilWeight": "length * width * depth * compactionFactor * density"
  },
  "outputs": {
    "primary": "soilVolume",
    "breakdown": [
      "soilVolumeYards",
      "soilWeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "soilWeight",
    "unit": "m"
  },

{
  "toolName": "julian-date-calculator",
  "inputs": [
    {
      "id": "year",
      "label": "Year",
      "type": "number",
      "unit": "",
      "default": 2000,
      "businessContext": "Gregorian year (e.g., 2023)"
    },
    {
      "id": "month",
      "label": "Month",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Month (1-12)"
    },
    {
      "id": "day",
      "label": "Day",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Day of month (1-31)"
    },
    {
      "id": "hour",
      "label": "Hour",
      "type": "number",
      "unit": "",
      "default": 12,
      "businessContext": "Hour in UT (0-23)"
    },
    {
      "id": "minute",
      "label": "Minute",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Minute (0-59)"
    },
    {
      "id": "second",
      "label": "Second",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Second (0-59, decimal allowed)"
    }
  ],
  "formulas": {
    "a": "Math.floor((14 - month) / 12)",
    "y": "year + 4800 - a",
    "m": "month + 12 * a - 3",
    "julianDayNumber": "day + Math.floor((153 * m + 2) / 5) + 365 * y + Math.floor(y / 4) - Math.floor(y / 100) + Math.floor(y / 400) - 32045",
    "fractionOfDay": "(hour - 12) / 24 + minute / 1440 + second / 86400",
    "julianDate": "julianDayNumber + fractionOfDay"
  },
  "outputs": {
    "primary": "julianDate",
    "breakdown": [
      "julianDayNumber",
      "fractionOfDay"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "date-time",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

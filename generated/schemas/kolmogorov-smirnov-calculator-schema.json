      }
    },
    {
      "id": "n2",
      "label": "Sample Size 2",
      "type": "number",
      "unit": "samples",
      "default": 30,
      "businessContext": "Number of observations in second sample",
      "label_i18n": {
        "en": "Sample Size 2",
        "tr": "Sample Size 2",
        "de": "Sample Size 2",
        "fr": "Sample Size 2",
        "es": "Sample Size 2",
        "ar": "Sample Size 2"
      }
    },
    {
      "id": "alpha",
      "label": "Significance Level",
      "type": "number",
      "unit": "probability",
      "default": 0.05,
      "businessContext": "Type I error probability threshold",
      "label_i18n": {
        "en": "Significance Level",
        "tr": "Significance Level",
        "de": "Significance Level",
        "fr": "Significance Level",
        "es": "Significance Level",
        "ar": "Significance Level"
      }
    }
  ],
  "formulas": {
    "x": "Math.sqrt(n1 * n2 / (n1 + n2)) * dStat",
    "pValue": "2 * (Math.exp(-2 * x**2) - Math.exp(-8 * x**2) + Math.exp(-18 * x**2) - Math.exp(-32 * x**2))",
    "c": "Math.sqrt(-0.5 * Math.log(alpha / 2))",
    "criticalD": "c * Math.sqrt((n1 + n2) / (n1 * n2))",
    "decision": "dStat > criticalD ? 1 : 0"
  },
  "outputs": {
    "primary": "pValue",
    "breakdown": [
      "criticalD",
      "decision"
    ]
  },

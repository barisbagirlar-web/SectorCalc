{
  "toolName": "kolmogorov-smirnov-calculator",
  "inputs": [
    {
      "id": "dStat",
      "label": "Test Statistic D",
      "type": "number",
      "unit": "unitless",
      "default": 0.1,
      "businessContext": "Maximum difference between empirical cumulative distribution functions",
      "label_i18n": {
        "en": "Test Statistic D",
        "tr": "Test Statistic D",
        "de": "Test Statistic D",
        "fr": "Test Statistic D",
        "es": "Test Statistic D",
        "ar": "Test Statistic D"
      }
    },
    {
      "id": "n1",
      "label": "Sample Size 1",
      "type": "number",
      "unit": "samples",
      "default": 30,
      "businessContext": "Number of observations in first sample",
      "label_i18n": {
        "en": "Sample Size 1",
        "tr": "Sample Size 1",
        "de": "Sample Size 1",
        "fr": "Sample Size 1",
        "es": "Sample Size 1",

{
  "toolName": "discounted-payback-period",
  "inputs": [
    {
      "id": "initialInvestment",
      "label": "Başlangıç Yatırımı",
      "type": "number",
      "unit": "₺",
      "default": 50000,
      "businessContext": "Projenin gerektirdiği başlangıç sermaye harcaması."
    },
    {
      "id": "discountRate",
      "label": "İskonto Oranı",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Sermaye maliyeti veya beklenen getiri oranı."
    },
    {
      "id": "cashFlowYear1",
      "label": "Net Nakit Akışı Yıl 1",
      "type": "number",
      "unit": "₺",
      "default": 10000,
      "businessContext": "1. yıl sonundaki net nakit girişi."
    },
    {
      "id": "cashFlowYear2",
      "label": "Net Nakit Akışı Yıl 2",
      "type": "number",
      "unit": "₺",
      "default": 20000,
      "businessContext": "2. yıl sonundaki net nakit girişi."
    },
    {
      "id": "cashFlowYear3",
      "label": "Net Nakit Akışı Yıl 3",
      "type": "number",
      "unit": "₺",
      "default": 30000,
      "businessContext": "3. yıl sonundaki net nakit girişi."
    },
    {
      "id": "cashFlowYear4",
      "label": "Net Nakit Akışı Yıl 4",
      "type": "number",
      "unit": "₺",
      "default": 40000,
      "businessContext": "4. yıl sonundaki net nakit girişi."
    },
    {
      "id": "cashFlowYear5",
      "label": "Net Nakit Akışı Yıl 5",
      "type": "number",
      "unit": "₺",
      "default": 50000,
      "businessContext": "5. yıl sonundaki net nakit girişi."
    }
  ],
  "formulas": {
    "dcf1": "cashFlowYear1 / (1 + discountRate/100) ** 1",
    "dcf2": "cashFlowYear2 / (1 + discountRate/100) ** 2",
    "dcf3": "cashFlowYear3 / (1 + discountRate/100) ** 3",
    "dcf4": "cashFlowYear4 / (1 + discountRate/100) ** 4",
    "dcf5": "cashFlowYear5 / (1 + discountRate/100) ** 5",
    "cumulative0": "-initialInvestment",
    "cumulative1": "cumulative0 + dcf1",
    "cumulative2": "cumulative1 + dcf2",
    "cumulative3": "cumulative2 + dcf3",
    "cumulative4": "cumulative3 + dcf4",
    "cumulative5": "cumulative4 + dcf5",
    "discountedPayback": "cumulative1 >= 0 ? initialInvestment / dcf1 : cumulative2 >= 0 ? 1 + Math.abs(cumulative1) / dcf2 : cumulative3 >= 0 ? 2 + Math.abs(cumulative2) / dcf3 : cumulative4 >= 0 ? 3 + Math.abs(cumulative3) / dcf4 : cumulative5 >= 0 ? 4 + Math.abs(cumulative4) / dcf5 : null"
  },
  "outputs": {
    "primary": "discountedPayback",
    "breakdown": [
      "dcf1",
      "dcf2",
      "dcf3",
      "dcf4",
      "dcf5",
      "cumulative1",
      "cumulative2",
      "cumulative3",
      "cumulative4",
      "cumulative5"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

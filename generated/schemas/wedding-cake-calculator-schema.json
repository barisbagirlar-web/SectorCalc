{
  "toolName": "wedding-cake-calculator",
  "inputs": [
    {
      "id": "guestCount",
      "label": "Guest Count",
      "type": "number",
      "unit": "people",
      "default": 100,
      "businessContext": "The total number of wedding guests to be served cake, determines the total quantity needed and drives portion sizing to avoid shortage or excess.",
      "label_i18n": {
        "en": "Guest Count",
        "tr": "Guest Count",
        "de": "Guest Count",
        "fr": "Guest Count",
        "es": "Guest Count",
        "ar": "Guest Count"
      }
    },
    {
      "id": "portionGrams",
      "label": "Portion Size",
      "type": "number",
      "unit": "g",
      "default": 150,
      "businessContext": "Average weight of a single serving of cake in grams, based on typical dessert portions; affects total cake mass and ingredient requirements.",
      "label_i18n": {
        "en": "Portion Size",
        "tr": "Portion Size",
        "de": "Portion Size",
        "fr": "Portion Size",
        "es": "Portion Size",
        "ar": "Portion Size"
      }
    },
    {
      "id": "ingredientCostPerKg",
      "label": "Ingredient Cost per kg",
      "type": "number",
      "unit": "USD/kg",
      "default": 5,
      "businessContext": "Cost of raw materials (flour, sugar, eggs, etc.) per kilogram; fundamental for calculating the base food cost of the cake.",
      "label_i18n": {
        "en": "Ingredient Cost per kg",
        "tr": "Ingredient Cost per kg",
        "de": "Ingredient Cost per kg",
        "fr": "Ingredient Cost per kg",
        "es": "Ingredient Cost per kg",
        "ar": "Ingredient Cost per kg"
      }
    },
    {
      "id": "laborHours",
      "label": "Labor Hours",
      "type": "number",
      "unit": "h",
      "default": 4,
      "businessContext": "Total direct labor time spent on baking and decorating the cake; used to compute labor expense.",
      "label_i18n": {
        "en": "Labor Hours",
        "tr": "Labor Hours",
        "de": "Labor Hours",
        "fr": "Labor Hours",
        "es": "Labor Hours",
        "ar": "Labor Hours"
      }
    },
    {
      "id": "laborRate",
      "label": "Labor Rate",
      "type": "number",
      "unit": "USD/h",
      "default": 20,
      "businessContext": "Hourly wage of the pastry chef or baker; multiplied by labor hours to get total labor cost.",
      "label_i18n": {
        "en": "Labor Rate",
        "tr": "Labor Rate",
        "de": "Labor Rate",
        "fr": "Labor Rate",
        "es": "Labor Rate",
        "ar": "Labor Rate"
      }
    },
    {
      "id": "overheadPercent",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Indirect costs (utilities, rent, equipment amortization) expressed as a percentage of direct costs (ingredients + labor); ensures full cost recovery.",
      "label_i18n": {
        "en": "Overhead Percentage",
        "tr": "Overhead Percentage",
        "de": "Overhead Percentage",
        "fr": "Overhead Percentage",
        "es": "Overhead Percentage",
        "ar": "Overhead Percentage"
      }
    },
    {
      "id": "profitMarginPercent",
      "label": "Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Desired net profit as a percentage of total cost; used to set the final selling price and ensure business sustainability.",
      "label_i18n": {
        "en": "Profit Margin",
        "tr": "Profit Margin",
        "de": "Profit Margin",
        "fr": "Profit Margin",
        "es": "Profit Margin",
        "ar": "Profit Margin"
      }
    }
  ],
  "formulas": {
    "totalCakeWeightKg": "(guestCount * portionGrams) / 1000",
    "ingredientCost": "totalCakeWeightKg * ingredientCostPerKg",
    "laborCost": "laborHours * laborRate",
    "overheadCost": "(ingredientCost + laborCost) * (overheadPercent / 100)",
    "totalCost": "ingredientCost + laborCost + overheadCost",
    "totalPrice": "totalCost * (1 + profitMarginPercent / 100)",
    "pricePerServing": "totalPrice / guestCount"
  },
  "outputs": {
    "primary": "totalPrice",
    "breakdown": [
      "totalCakeWeightKg",
      "ingredientCost",
      "laborCost",
      "overheadCost",
      "pricePerServing"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pricePerServing",
    "unit": "people",
    "breakdownUnits": {
      "totalCakeWeightKg": "kg"
    }
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "gida",
  "profession": "Gıda Mühendisi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "thin-wall-vessel-stress-check-calculator",
  "inputs": [
    {
      "id": "P",
      "label": "Internal Pressure (P)",
      "type": "number",
      "unit": "MPa",
      "default": 1,
      "businessContext": "Internal design pressure of the vessel",
      "label_i18n": {
        "en": "Internal Pressure (P)",
        "tr": "Internal Pressure (P)",
        "de": "Internal Pressure (P)",
        "fr": "Internal Pressure (P)",
        "es": "Internal Pressure (P)",
        "ar": "Internal Pressure (P)"
      }
    },
    {
      "id": "D",
      "label": "Inside Diameter (D)",
      "type": "number",
      "unit": "mm",
      "default": 1000,
      "businessContext": "Nominal inner diameter of the shell",
      "label_i18n": {
        "en": "Inside Diameter (D)",
        "tr": "Inside Diameter (D)",
        "de": "Inside Diameter (D)",
        "fr": "Inside Diameter (D)",
        "es": "Inside Diameter (D)",
        "ar": "Inside Diameter (D)"
      }
    },
    {
      "id": "t",
      "label": "Wall Thickness (t)",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Minimum required wall thickness after corrosion allowance",
      "label_i18n": {
        "en": "Wall Thickness (t)",
        "tr": "Wall Thickness (t)",
        "de": "Wall Thickness (t)",
        "fr": "Wall Thickness (t)",
        "es": "Wall Thickness (t)",
        "ar": "Wall Thickness (t)"
      }
    },
    {
      "id": "S",
      "label": "Allowable Stress (S)",
      "type": "number",
      "unit": "MPa",
      "default": 150,
      "businessContext": "Maximum allowable stress of material at design temperature",
      "label_i18n": {
        "en": "Allowable Stress (S)",
        "tr": "Allowable Stress (S)",
        "de": "Allowable Stress (S)",
        "fr": "Allowable Stress (S)",
        "es": "Allowable Stress (S)",
        "ar": "Allowable Stress (S)"
      }
    },
    {
      "id": "E",
      "label": "Weld Joint Efficiency (E)",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Joint efficiency factor per design code (e.g., ASME UW-12)",
      "label_i18n": {
        "en": "Weld Joint Efficiency (E)",
        "tr": "Weld Joint Efficiency (E)",
        "de": "Weld Joint Efficiency (E)",
        "fr": "Weld Joint Efficiency (E)",
        "es": "Weld Joint Efficiency (E)",
        "ar": "Weld Joint Efficiency (E)"
      }
    }
  ],
  "formulas": {
    "hoopStress": "(P * D) / (2 * t * E)",
    "longStress": "(P * D) / (4 * t * E)",
    "safetyFactor": "(S * 2 * t * E) / (P * D)"
  },
  "outputs": {
    "primary": "safetyFactor",
    "breakdown": [
      "hoopStress",
      "longStress"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "safetyFactor"
  },

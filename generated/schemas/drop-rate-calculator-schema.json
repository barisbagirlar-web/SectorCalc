{
  "toolName": "drop-rate-calculator",
  "inputs": [
    {
      "id": "drops",
      "label": "Number of Drops",
      "type": "number",
      "unit": "drops",
      "default": 0,
      "businessContext": "Total dropped items during observation",
      "label_i18n": {
        "en": "Number of Drops",
        "tr": "Number of Drops",
        "de": "Number of Drops",
        "fr": "Number of Drops",
        "es": "Number of Drops",
        "ar": "Number of Drops"
      }
    },
    {
      "id": "totalItems",
      "label": "Total Items Handled",
      "type": "number",
      "unit": "items",
      "default": 1000,
      "businessContext": "Total items processed in the same period",
      "label_i18n": {
        "en": "Total Items Handled",
        "tr": "Total Items Handled",
        "de": "Total Items Handled",
        "fr": "Total Items Handled",
        "es": "Total Items Handled",
        "ar": "Total Items Handled"
      }
    },
    {
      "id": "timePeriod",
      "label": "Time Period",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Duration of observation in hours",
      "label_i18n": {
        "en": "Time Period",
        "tr": "Time Period",
        "de": "Time Period",
        "fr": "Time Period",
        "es": "Time Period",
        "ar": "Time Period"
      }
    },
    {
      "id": "costPerDrop",
      "label": "Cost per Drop",
      "type": "number",
      "unit": "currency",
      "default": 0.5,
      "businessContext": "Average financial loss per dropped item",
      "label_i18n": {
        "en": "Cost per Drop",
        "tr": "Cost per Drop",
        "de": "Cost per Drop",
        "fr": "Cost per Drop",
        "es": "Cost per Drop",
        "ar": "Cost per Drop"
      }
    }
  ],
  "formulas": {
    "dropRatePercentage": "(drops / totalItems) * 100",
    "dropsPerHour": "drops / timePeriod",
    "annualDropCost": "costPerDrop * (drops / timePeriod) * 24 * 365"
  },
  "outputs": {
    "primary": "dropRatePercentage",
    "breakdown": [
      "dropsPerHour",
      "annualDropCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualDropCost",
    "unit": "%",
    "breakdownUnits": {
      "dropsPerHour": "h"
    }
  },

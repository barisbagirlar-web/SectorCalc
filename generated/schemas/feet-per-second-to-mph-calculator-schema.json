  "formulas": {
    "convertToMph": "const mph = (feetPerSecond + calibrationOffset) * (3600 / 5280) * outputUnitScaling; return +mph.toFixed(precision);",
    "adjustedSpeed___feetPerSecond___calibrat": "adjustedSpeed = feetPerSecond + calibrationOffset",
    "mphRaw___adjustedSpeed____3600___5280___": "mphRaw = adjustedSpeed * (3600 / 5280) * outputUnitScaling",
    "round_mphRaw__precision_": "round(mphRaw, precision)"
  },
  "outputs": {
    "primary": "convertToMph",
    "breakdown": [
      "adjustedSpeed = feetPerSecond + calibrationOffset",
      "mphRaw = adjustedSpeed * (3600 / 5280) * outputUnitScaling",
      "round(mphRaw, precision)"
    ]
  },

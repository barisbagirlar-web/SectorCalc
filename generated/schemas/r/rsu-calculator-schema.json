{
  "toolName": "rsu-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Business",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "hisseSayisi",
      "label": "RSU Shares Granted",
      "type": "number",
      "unit": "shares",
      "default": 1000,
      "min": 0,
      "businessContext": "Vested RSU shares."
    },
    {
      "id": "hakKazanma",
      "label": "Vesting Percentage (%)",
      "type": "number",
      "unit": "%",
      "default": 25,
      "min": 0,
      "max": 100,
      "businessContext": "Vesting percentage."
    },
    {
      "id": "vergi",
      "label": "Tax Withholding (%)",
      "type": "number",
      "unit": "%",
      "default": 25,
      "min": 0,
      "max": 100,
      "businessContext": "Withholding tax rate."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(hisseSayisi * hakKazanma / 100) * (1 - vergi / 100)"
  },
  "outputs": {
    "primary": "result",
    "unit": "shares",
    "breakdown": {
      "result": "Net Shares"
    },
    "breakdownUnits": {
      "result": "shares"
    },

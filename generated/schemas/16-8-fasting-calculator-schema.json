{
  "toolName": "16-8-fasting-calculator",
  "inputs": [
    {
      "id": "currentHour",
      "label": "Mevcut Saat (0-23)",
      "type": "number",
      "unit": "saat",
      "default": 12,
      "businessContext": "Şu anki saat dilimi."
    },
    {
      "id": "fastingStartHour",
      "label": "Oruç Başlangıç Saati",
      "type": "number",
      "unit": "saat",
      "default": 20,
      "businessContext": "16 saatlik oruç penceresinin başlangıç saati (örn. 20:00)."
    },
    {
      "id": "fastingDuration",
      "label": "Oruç Süresi",
      "type": "number",
      "unit": "saat",
      "default": 16,
      "businessContext": "Oruç penceresinin toplam süresi (standart 16 saat)."
    },
    {
      "id": "eatingDuration",
      "label": "Yeme Penceresi Süresi",
      "type": "number",
      "unit": "saat",
      "default": 8,
      "businessContext": "Yeme penceresi süresi (genelde 8 saat)."
    }
  ],
  "formulas": {
    "fastingEndHour": "(fastingStartHour + fastingDuration) % 24",
    "eatingWindowEndHour": "((fastingStartHour + fastingDuration) % 24 + eatingDuration) % 24",
    "remainingFastingTime": "Math.max(0, fastingDuration - (currentHour >= fastingStartHour ? currentHour - fastingStartHour : currentHour + 24 - fastingStartHour))",
    "progressPercent": "Math.min(100, ((currentHour >= fastingStartHour ? currentHour - fastingStartHour : currentHour + 24 - fastingStartHour) / fastingDuration) * 100)"
  },
  "outputs": {
    "primary": "remainingFastingTime",
    "breakdown": [
      "fastingEndHour",
      "eatingWindowEndHour",
      "progressPercent"
    ]
  },
  "category": "Diğer",
  "sector": "Plastik & Enjeksiyon",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "electrical-power-systems",
  "sectorId": "plastik",
  "profession": "Proses Mühendisi",
  "categoryId": "diger"
}

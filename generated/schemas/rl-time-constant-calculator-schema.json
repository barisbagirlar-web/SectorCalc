{
  "toolName": "rl-time-constant-calculator",
  "inputs": [
    {
      "id": "resistance",
      "label": "Nominal Resistance",
      "type": "number",
      "unit": "Ω",
      "default": 1000,
      "businessContext": "Resistance value of the resistor",
      "label_i18n": {
        "en": "Nominal Resistance",
        "tr": "Nominal Resistance",
        "de": "Nominal Resistance",
        "fr": "Nominal Resistance",
        "es": "Nominal Resistance",
        "ar": "Nominal Resistance"
      }
    },
    {
      "id": "resistanceTolerance",
      "label": "Resistance Tolerance",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Tolerance of the resistor in percent",
      "label_i18n": {
        "en": "Resistance Tolerance",
        "tr": "Resistance Tolerance",
        "de": "Resistance Tolerance",
        "fr": "Resistance Tolerance",
        "es": "Resistance Tolerance",
        "ar": "Resistance Tolerance"
      }
    },
    {
      "id": "inductance",
      "label": "Nominal Inductance",
      "type": "number",
      "unit": "H",
      "default": 0.001,
      "businessContext": "Inductance value of the inductor",
      "label_i18n": {
        "en": "Nominal Inductance",
        "tr": "Nominal Inductance",
        "de": "Nominal Inductance",
        "fr": "Nominal Inductance",
        "es": "Nominal Inductance",
        "ar": "Nominal Inductance"
      }
    },
    {
      "id": "inductanceTolerance",
      "label": "Inductance Tolerance",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Tolerance of the inductor in percent",
      "label_i18n": {
        "en": "Inductance Tolerance",
        "tr": "Inductance Tolerance",
        "de": "Inductance Tolerance",
        "fr": "Inductance Tolerance",
        "es": "Inductance Tolerance",
        "ar": "Inductance Tolerance"
      }
    }
  ],
  "formulas": {
    "tauNominal": "inductance / resistance",
    "tauMax": "(inductance * (1 + inductanceTolerance / 100)) / (resistance * (1 - resistanceTolerance / 100))",
    "tauMin": "(inductance * (1 - inductanceTolerance / 100)) / (resistance * (1 + resistanceTolerance / 100))"
  },
  "outputs": {
    "primary": "tauMin",
    "breakdown": [
      "Maximum Time Constant: ${tauMax.toFixed(6)} s",
      "Minimum Time Constant: ${tauMin.toFixed(6)} s",
      "Tolerance Range: ±${((tauMax - tauMin) / (2 * tauNominal) * 100).toFixed(2)}%"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "tauMin"
  },
  "category": "Diğer",
  "sector": "Elektronik & Devre",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems",

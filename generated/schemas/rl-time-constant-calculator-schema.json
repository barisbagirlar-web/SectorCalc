{
  "toolName": "rl-time-constant-calculator",
  "inputs": [
    {
      "id": "resistance",
      "label": "Nominal Resistance",
      "type": "number",
      "unit": "Ω",
      "default": 1000,
      "businessContext": "Resistance value of the resistor",
      "label_i18n": {
        "en": "Nominal Resistance",
        "tr": "Nominal Direnç",
        "de": "Nennwiderstand",
        "fr": "Résistance nominale",
        "es": "Resistencia nominal",
        "ar": "المقاومة الاسمية"
      },
      "businessContext_i18n": {
        "en": "Resistance value of the resistor",
        "tr": "Direncin direnç değeri",
        "de": "Widerstandswert des Widerstands",
        "fr": "Valeur de la résistance",
        "es": "Valor de resistencia del resistor",
        "ar": "قيمة المقاومة للمقاومة"
      }
    },
    {
      "id": "resistanceTolerance",
      "label": "Resistance Tolerance",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Tolerance of the resistor in percent",
      "label_i18n": {
        "en": "Resistance Tolerance",
        "tr": "Direnç Toleransı",
        "de": "Widerstandstoleranz",
        "fr": "Tolérance de la résistance",
        "es": "Tolerancia de la resistencia",
        "ar": "تفاوت المقاومة"
      },
      "businessContext_i18n": {
        "en": "Tolerance of the resistor in percent",
        "tr": "Direncin yüzde toleransı",
        "de": "Toleranz des Widerstands in Prozent",
        "fr": "Tolérance de la résistance en pourcentage",
        "es": "Tolerancia del resistor en porcentaje",
        "ar": "تفاوت المقاومة بالنسبة المئوية"
      }
    },
    {
      "id": "inductance",
      "label": "Nominal Inductance",
      "type": "number",
      "unit": "H",
      "default": 0.001,
      "businessContext": "Inductance value of the inductor",
      "label_i18n": {
        "en": "Nominal Inductance",
        "tr": "Nominal Endüktans",
        "de": "Nenninduktivität",
        "fr": "Inductance nominale",
        "es": "Inductancia nominal",
        "ar": "الحث الاسمي"
      },
      "businessContext_i18n": {
        "en": "Inductance value of the inductor",
        "tr": "Bobinin endüktans değeri",
        "de": "Induktivitätswert der Spule",
        "fr": "Valeur de l'inductance de la bobine",
        "es": "Valor de inductancia del inductor",
        "ar": "قيمة محاثة الملف"
      }
    },
    {
      "id": "inductanceTolerance",
      "label": "Inductance Tolerance",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Tolerance of the inductor in percent",
      "label_i18n": {
        "en": "Inductance Tolerance",
        "tr": "Endüktans Toleransı",
        "de": "Induktivitätstoleranz",
        "fr": "Tolérance de l'inductance",
        "es": "Tolerancia de inductancia",
        "ar": "تفاوت الحث"
      },
      "businessContext_i18n": {
        "en": "Tolerance of the inductor in percent",
        "tr": "Bobinin yüzde toleransı",
        "de": "Toleranz der Induktivität in Prozent",
        "fr": "Tolérance de l'inducteur en pourcentage",
        "es": "Tolerancia del inductor en porcentaje",
        "ar": "تفاوت الملف بالنسبة المئوية"
      }
    }
  ],
  "formulas": {
    "tauNominal": "inductance / resistance",
    "tauMax": "(inductance * (1 + inductanceTolerance / 100)) / (resistance * (1 - resistanceTolerance / 100))",
    "tauMin": "(inductance * (1 - inductanceTolerance / 100)) / (resistance * (1 + resistanceTolerance / 100))"
  },
  "outputs": {
    "primary": "tauMin",
    "breakdown": [
      "Maximum Time Constant: ${tauMax.toFixed(6)} s",
      "Minimum Time Constant: ${tauMin.toFixed(6)} s",
      "Tolerance Range: ±${((tauMax - tauMin) / (2 * tauNominal) * 100).toFixed(2)}%"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "tauMin",
    "unit": "Ω"
  },
  "category": "Teknik & Mühendislik",
  "sector": "Elektronik & Devre",
  "premiumRequired": false,

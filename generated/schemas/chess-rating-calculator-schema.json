        "de": "Spielergebnis: 1 (Sieg), 0,5 (Unentschieden), 0 (Niederlage)",
        "fr": "Résultat du match : 1 (victoire), 0.5 (nul), 0 (défaite)",
        "es": "Resultado del partido: 1 (victoria), 0.5 (empate), 0 (derrota)",
        "ar": "نتيجة المباراة: 1 (فوز)، 0.5 (تعادل)، 0 (خسارة)"
      }
    },
    {
      "id": "kFactor",
      "label": "K Factor",
      "type": "number",
      "unit": "unit",
      "default": 32,
      "businessContext": "Development coefficient, usually between 20-40",
      "label_i18n": {
        "en": "K Factor",
        "tr": "K Faktörü",
        "de": "K-Faktor",
        "fr": "Facteur K",
        "es": "Factor K",
        "ar": "معامل K"
      },
      "businessContext_i18n": {
        "en": "Development coefficient, usually between 20-40",
        "tr": "Gelişim katsayısı, genellikle 20-40 arası",
        "de": "Entwicklungskoeffizient, normalerweise zwischen 20 und 40",
        "fr": "Coefficient de développement, généralement entre 20 et 40",
        "es": "Coeficiente de desarrollo, generalmente entre 20 y 40",
        "ar": "معامل التطوير، عادة بين 20-40"
      }
    }
  ],
  "formulas": {
    "expectedScore": "1 / (1 + 10 ** ((opponentRating - currentRating) / 400))",
    "ratingChange": "kFactor * (result - expectedScore)",
    "newRating": "currentRating + ratingChange"
  },
  "outputs": {
    "primary": "newRating",
    "breakdown": [
      "expectedScore",
      "ratingChange"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "newRating",

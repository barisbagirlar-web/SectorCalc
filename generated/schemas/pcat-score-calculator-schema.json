    },
    {
      "id": "stddev",
      "label": "Standart Sapma",
      "type": "number",
      "unit": "mm",
      "default": 0.5,
      "businessContext": "Prosesin değişkenlik ölçüsü",
      "label_i18n": {
        "en": "Standart Sapma",
        "tr": "Standart Sapma",
        "de": "Standart Sapma",
        "fr": "Standart Sapma",
        "es": "Standart Sapma",
        "ar": "Standart Sapma"
      }
    }
  ],
  "formulas": {
    "cp": "(usl - lsl) / (6 * stddev)",
    "cpk": "Math.min((usl - mean) / (3 * stddev), (mean - lsl) / (3 * stddev))",
    "pcatScore": "(Math.min((usl - lsl) / (6 * stddev), Math.min((usl - mean) / (3 * stddev), (mean - lsl) / (3 * stddev))) / 1.33) * 100"
  },
  "outputs": {
    "primary": "pcatScore",
    "breakdown": [
      "cp",
      "cpk"
    ]
  },

      "label_i18n": {
        "en": "Miscellaneous (%)",
        "tr": "Çeşitli (%)",
        "de": "Sonstiges (%)",
        "fr": "Divers (%)",
        "es": "Imprevistos (%)",
        "ar": "متنوعة (%)"
      },
      "businessContext_i18n": {
        "en": "Percentage of base cost reserved for unexpected expenses",
        "tr": "Beklenmeyen giderler için ayrılan temel maliyet yüzdesi",
        "de": "Prozentsatz der Basiskosten, der für unerwartete Ausgaben reserviert wird",
        "fr": "Pourcentage du coût de base réservé aux dépenses imprévues",
        "es": "Porcentaje del coste base reservado para gastos imprevistos",
        "ar": "نسبة من التكلفة الأساسية محجوزة للنفقات غير المتوقعة"
      }
    }
  ],
  "formulas": {
    "baseCost": "venueCost + decorationCost + entertainmentCost + (costPerPlate * guestCount)",
    "miscAmount": "baseCost * (miscPercent / 100)",
    "totalWeddingBudget": "baseCost + miscAmount",
    "costPerGuest": "totalWeddingBudget / guestCount"
  },
  "outputs": {
    "primary": "totalWeddingBudget",
    "breakdown": [
      "baseCost",
      "miscAmount",
      "costPerGuest"
    ],

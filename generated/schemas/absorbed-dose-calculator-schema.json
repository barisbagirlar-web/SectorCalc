{
  "toolName": "absorbed-dose-calculator",
  "inputs": [
    {
      "id": "mass",
      "label": "Mass of Absorbing Material",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of the material that absorbs the radiation energy.",
      "label_i18n": {
        "en": "Mass of Absorbing Material",
        "tr": "Mass of Absorbing Material",
        "de": "Mass of Absorbing Material",
        "fr": "Mass of Absorbing Material",
        "es": "Mass of Absorbing Material",
        "ar": "Mass of Absorbing Material"
      }
    },
    {
      "id": "energy",
      "label": "Total Energy Deposited",
      "type": "number",
      "unit": "J",
      "default": 100,
      "businessContext": "Total energy deposited by ionizing radiation into the material.",
      "label_i18n": {
        "en": "Total Energy Deposited",
        "tr": "Total Energy Deposited",
        "de": "Total Energy Deposited",
        "fr": "Total Energy Deposited",
        "es": "Total Energy Deposited",
        "ar": "Total Energy Deposited"
      }
    },
    {
      "id": "time",
      "label": "Exposure Time",
      "type": "number",
      "unit": "s",
      "default": 3600,
      "businessContext": "Duration of radiation exposure.",
      "label_i18n": {
        "en": "Exposure Time",
        "tr": "Exposure Time",
        "de": "Exposure Time",
        "fr": "Exposure Time",
        "es": "Exposure Time",
        "ar": "Exposure Time"
      }
    },
    {
      "id": "density",
      "label": "Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Density of the absorbing material (e.g., water = 1000 kg/m³).",
      "label_i18n": {
        "en": "Material Density",
        "tr": "Material Density",
        "de": "Material Density",
        "fr": "Material Density",
        "es": "Material Density",
        "ar": "Material Density"
      }
    },
    {
      "id": "volume",
      "label": "Volume of Material",
      "type": "number",
      "unit": "m³",
      "default": 0.001,
      "businessContext": "Volume of the absorbing material.",
      "label_i18n": {
        "en": "Volume of Material",
        "tr": "Volume of Material",
        "de": "Volume of Material",
        "fr": "Volume of Material",
        "es": "Volume of Material",
        "ar": "Volume of Material"
      }
    }
  ],
  "formulas": {
    "absorbedDose": "energy / mass",
    "doseRate": "absorbedDose / time",
    "massFromDensity": "density * volume",
    "checkMass": "mass === massFromDensity ? mass : (mass + massFromDensity) / 2"
  },
  "outputs": {
    "primary": "absorbedDose",
    "breakdown": [
      "absorbedDose",
      "doseRate",
      "massFromDensity",
      "checkMass"
    ],

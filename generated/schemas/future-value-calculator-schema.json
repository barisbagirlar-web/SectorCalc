{
  "toolName": "future-value-calculator",
  "inputs": [
    {
      "id": "presentValue",
      "label": "Initial Investment (PV)",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "The amount of money you start with.",
      "label_i18n": {
        "en": "Initial Investment (PV)",
        "tr": "Initial Investment (PV)",
        "de": "Initial Investment (PV)",
        "fr": "Initial Investment (PV)",
        "es": "Initial Investment (PV)",
        "ar": "Initial Investment (PV)"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "The annual nominal interest rate.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "periods",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "The total number of years the money is invested for.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Number of Years",
        "de": "Number of Years",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      }
    },
    {
      "id": "compoundingFrequency",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "times per year",
      "default": 12,
      "businessContext": "How often interest is compounded per year (e.g., 1 for annual, 12 for monthly).",
      "label_i18n": {
        "en": "Compounding Frequency",
        "tr": "Compounding Frequency",
        "de": "Compounding Frequency",
        "fr": "Compounding Frequency",
        "es": "Compounding Frequency",
        "ar": "Compounding Frequency"
      }
    },
    {
      "id": "periodicPayment",
      "label": "Periodic Payment (PMT)",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "The amount added to the investment at each compounding period. Positive for contributions.",
      "label_i18n": {
        "en": "Periodic Payment (PMT)",
        "tr": "Periodic Payment (PMT)",
        "de": "Periodic Payment (PMT)",
        "fr": "Periodic Payment (PMT)",
        "es": "Periodic Payment (PMT)",
        "ar": "Periodic Payment (PMT)"
      }
    }
  ],
  "formulas": {
    "totalContributions": "presentValue+periodicPayment*periods*compoundingFrequency",
    "totalContributions_aux": "presentValue+periodicPayment*periods*compoundingFrequency"
  },
  "outputs": {
    "primary": "totalContributions_aux",
    "breakdown": [
      "totalContributions",
      "totalInterest"

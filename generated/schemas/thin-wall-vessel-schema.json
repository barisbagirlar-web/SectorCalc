      }
    },
    {
      "id": "allowableStress",
      "label": "Allowable Stress",
      "type": "number",
      "unit": "MPa",
      "default": 200,
      "businessContext": "Maximum allowable stress of the material",
      "label_i18n": {
        "en": "Allowable Stress",
        "tr": "Allowable Stress",
        "de": "Allowable Stress",
        "fr": "Allowable Stress",
        "es": "Allowable Stress",
        "ar": "Allowable Stress"
      }
    },
    {
      "id": "jointEfficiency",
      "label": "Joint Efficiency",
      "type": "number",
      "unit": "unit",
      "default": 0.85,
      "businessContext": "Efficiency of welded joints (0-1)",
      "label_i18n": {
        "en": "Joint Efficiency",
        "tr": "Joint Efficiency",
        "de": "Joint Efficiency",
        "fr": "Joint Efficiency",
        "es": "Joint Efficiency",
        "ar": "Joint Efficiency"
      }
    },
    {
      "id": "corrosionAllowance",
      "label": "Corrosion Allowance",
      "type": "number",
      "unit": "mm",
      "default": 2,
      "businessContext": "Additional thickness for corrosion",
      "label_i18n": {
        "en": "Corrosion Allowance",
        "tr": "Corrosion Allowance",
        "de": "Corrosion Allowance",
        "fr": "Corrosion Allowance",
        "es": "Corrosion Allowance",
        "ar": "Corrosion Allowance"
      }
    }
  ],
  "formulas": {
    "hoopStress": "internalPressure * (innerRadius + wallThickness/2) / wallThickness",
    "longitudinalStress": "internalPressure * (innerRadius + wallThickness/2) / (2 * wallThickness)",
    "requiredThickness": "(internalPressure * innerRadius) / (allowableStress * jointEfficiency - 0.6 * internalPressure) + corrosionAllowance",
    "safetyFactorHoop": "allowableStress / hoopStress",
    "safetyFactorLong": "allowableStress / longitudinalStress"
  },
  "outputs": {
    "primary": "hoopStress",
    "breakdown": [
      "hoopStress",
      "longitudinalStress",
      "requiredThickness",
      "safetyFactorHoop",
      "safetyFactorLong"
    ]
  },

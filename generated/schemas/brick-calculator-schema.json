    {
      "id": "wastagePercentage",
      "label": "Wastage Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Extra bricks for breakage and cuts",
      "label_i18n": {
        "en": "Wastage Percentage",
        "tr": "Wastage Percentage",
        "de": "Wastage Percentage",
        "fr": "Wastage Percentage",
        "es": "Wastage Percentage",
        "ar": "Wastage Percentage"
      }
    }
  ],
  "formulas": {
    "wallArea": "wallLength * wallHeight - openingArea",
    "brickLengthM": "brickLength / 1000",
    "brickHeightM": "brickHeight / 1000",
    "mortarThicknessM": "mortarThickness / 1000",
    "effectiveLength": "brickLengthM + mortarThicknessM",
    "effectiveHeight": "brickHeightM + mortarThicknessM",
    "bricksPerSquareMeter": "1 / (effectiveLength * effectiveHeight)",
    "netBricks": "wallArea * bricksPerSquareMeter",
    "wastageMultiplier": "1 + wastagePercentage / 100",
    "grossBricks": "netBricks * wastageMultiplier"
  },
  "outputs": {
    "primary": "grossBricks",
    "breakdown": [
      "wallArea",
      "bricksPerSquareMeter",
      "netBricks",
      "grossBricks"
    ],

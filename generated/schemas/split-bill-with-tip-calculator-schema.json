{
  "toolName": "split-bill-with-tip-calculator",
  "inputs": [
    {
      "id": "billAmount",
      "label": "Bill Amount",
      "type": "number",
      "unit": "$",
      "default": 100,
      "businessContext": "Total bill subtotal before tax and tip",
      "label_i18n": {
        "en": "Bill Amount",
        "tr": "Fatura Tutarı",
        "de": "Bill Amount",
        "fr": "Bill Amount",
        "es": "Bill Amount",
        "ar": "Bill Amount"
      },
      "businessContext_i18n": {
        "en": "Total bill subtotal before tax and tip",
        "tr": "Vergi ve bahşiş öncesi toplam fatura ara toplamı"
      }
    },
    {
      "id": "tipPercentage",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tip percentage to add, e.g., 15, 18, 20",
      "label_i18n": {
        "en": "Tip Percentage",
        "tr": "Bahşiş Yüzdesi",
        "de": "Tip Percentage",
        "fr": "Tip Percentage",
        "es": "Tip Percentage",
        "ar": "Tip Percentage"
      },
      "businessContext_i18n": {
        "en": "Tip percentage to add, e.g., 15, 18, 20",
        "tr": "Eklenecek bahşiş yüzdesi, örn. 15, 18, 20"
      }
    },
    {
      "id": "taxPercentage",
      "label": "Tax Percentage",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Sales tax percentage applied to bill",
      "label_i18n": {
        "en": "Tax Percentage",
        "tr": "Vergi Yüzdesi",
        "de": "Tax Percentage",
        "fr": "Tax Percentage",
        "es": "Tax Percentage",
        "ar": "Tax Percentage"
      },
      "businessContext_i18n": {
        "en": "Sales tax percentage applied to bill",
        "tr": "Faturaya uygulanan satış vergisi yüzdesi"
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "people",
      "default": 2,
      "businessContext": "Number of people splitting the bill",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Kişi Sayısı",
        "de": "Number of People",
        "fr": "Number of People",
        "es": "Number of People",
        "ar": "Number of People"
      },
      "businessContext_i18n": {
        "en": "Number of people splitting the bill",
        "tr": "Faturayı bölen kişi sayısı"
      }
    }
  ],
  "formulas": {
    "subtotalPerPerson": "billAmount / numberOfPeople",
    "tipAmount": "billAmount * (tipPercentage / 100)",
    "taxAmount": "billAmount * (taxPercentage / 100)",
    "tipPerPerson": "billAmount * (tipPercentage / 100) / numberOfPeople",
    "taxPerPerson": "billAmount * (taxPercentage / 100) / numberOfPeople",
    "totalPerPerson": "(billAmount * (1 + tipPercentage / 100 + taxPercentage / 100)) / numberOfPeople"
  },
  "outputs": {
    "primary": "totalPerPerson",
    "breakdown": [
      "subtotalText",
      "tipText",
      "taxText",
      "totalText"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPerPerson",
    "unit": "$"
  },

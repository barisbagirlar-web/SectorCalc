{
  "toolName": "split-bill-with-tip-calculator",
  "inputs": [
    {
      "id": "billAmount",
      "label": "Bill Amount",
      "type": "number",
      "unit": "$",
      "default": 100,
      "businessContext": "Total bill subtotal before tax and tip",
      "label_i18n": {
        "en": "Bill Amount",
        "tr": "Fatura Tutarı",
        "de": "Rechnungsbetrag",
        "fr": "Montant de la facture",
        "es": "Monto de la cuenta",
        "ar": "Bill Amount"
      },
      "businessContext_i18n": {
        "en": "Total bill subtotal before tax and tip",
        "tr": "Vergi ve bahşiş öncesi toplam fatura ara toplamı",
        "de": "Zwischensumme der Rechnung vor Steuern und Trinkgeld",
        "fr": "Sous-total de la facture avant taxes et pourboire"
      }
    },
    {
      "id": "tipPercentage",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tip percentage to add, e.g., 15, 18, 20",
      "label_i18n": {
        "en": "Tip Percentage",
        "tr": "Bahşiş Yüzdesi",
        "de": "Trinkgeldprozentsatz",
        "fr": "Pourcentage de pourboire",
        "es": "Porcentaje de propina",
        "ar": "Tip Percentage"
      },
      "businessContext_i18n": {
        "en": "Tip percentage to add, e.g., 15, 18, 20",
        "tr": "Eklenecek bahşiş yüzdesi, örn. 15, 18, 20",
        "de": "Trinkgeldprozentsatz, z.B. 15, 18, 20",
        "fr": "Pourcentage de pourboire à ajouter, ex. 15, 18, 20"
      }
    },
    {
      "id": "taxPercentage",
      "label": "Tax Percentage",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Sales tax percentage applied to bill",
      "label_i18n": {
        "en": "Tax Percentage",
        "tr": "Vergi Yüzdesi",
        "de": "Steuerprozentsatz",
        "fr": "Pourcentage de taxe",
        "es": "Porcentaje de impuesto",
        "ar": "Tax Percentage"
      },
      "businessContext_i18n": {
        "en": "Sales tax percentage applied to bill",
        "tr": "Faturaya uygulanan satış vergisi yüzdesi",
        "de": "Umsatzsteuerprozentsatz, der auf die Rechnung angewendet wird",
        "fr": "Pourcentage de taxe de vente appliqué à la facture"
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "people",
      "default": 2,
      "businessContext": "Number of people splitting the bill",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Kişi Sayısı",
        "de": "Anzahl der Personen",
        "fr": "Nombre de personnes",
        "es": "Número de personas",
        "ar": "Number of People"
      },
      "businessContext_i18n": {
        "en": "Number of people splitting the bill",
        "tr": "Faturayı bölen kişi sayısı",
        "de": "Anzahl der Personen, die die Rechnung teilen",
        "fr": "Nombre de personnes divisant la facture"
      }
    }
  ],
  "formulas": {
    "subtotalPerPerson": "billAmount / numberOfPeople",
    "tipAmount": "billAmount * (tipPercentage / 100)",
    "taxAmount": "billAmount * (taxPercentage / 100)",
    "tipPerPerson": "billAmount * (tipPercentage / 100) / numberOfPeople",
    "taxPerPerson": "billAmount * (taxPercentage / 100) / numberOfPeople",
    "totalPerPerson": "(billAmount * (1 + tipPercentage / 100 + taxPercentage / 100)) / numberOfPeople"
  },
  "outputs": {
    "primary": "totalPerPerson",
    "breakdown": [
      "subtotalText",
      "tipText",
      "taxText",
      "totalText"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPerPerson",
    "unit": "$"
  },

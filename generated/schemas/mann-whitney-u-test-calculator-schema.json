    "U1": "((g1v1 < g2v1 ? 1 : (g1v1 === g2v1 ? 0.5 : 0)) + (g1v1 < g2v2 ? 1 : (g1v1 === g2v2 ? 0.5 : 0)) + (g1v1 < g2v3 ? 1 : (g1v1 === g2v3 ? 0.5 : 0)) + (g1v2 < g2v1 ? 1 : (g1v2 === g2v1 ? 0.5 : 0)) + (g1v2 < g2v2 ? 1 : (g1v2 === g2v2 ? 0.5 : 0)) + (g1v2 < g2v3 ? 1 : (g1v2 === g2v3 ? 0.5 : 0)) + (g1v3 < g2v1 ? 1 : (g1v3 === g2v1 ? 0.5 : 0)) + (g1v3 < g2v2 ? 1 : (g1v3 === g2v2 ? 0.5 : 0)) + (g1v3 < g2v3 ? 1 : (g1v3 === g2v3 ? 0.5 : 0)))",
    "U2": "9 - U1",
    "U": "Math.min(U1, U2)"

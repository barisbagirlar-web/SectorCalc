        "ar": "القيمة الاسمية للسند"
      }
    },
    {
      "id": "couponRate",
      "label": "Coupon Rate",
      "type": "number",
      "unit": "% p.a.",
      "default": 5,
      "businessContext": "Annual coupon rate",
      "label_i18n": {
        "en": "Coupon Rate",
        "tr": "Kupon Oranı",

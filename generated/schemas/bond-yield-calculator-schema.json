{
  "toolName": "bond-yield-calculator",
  "inputs": [
    {
      "id": "faceValue",
      "label": "Face Value",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "Par value of the bond",
      "label_i18n": {
        "en": "Face Value",
        "tr": "Face Value",
        "de": "Face Value",
        "fr": "Face Value",
        "es": "Face Value",
        "ar": "Face Value"
      }
    },
    {
      "id": "couponRate",
      "label": "Coupon Rate",
      "type": "number",
      "unit": "% p.a.",
      "default": 5,
      "businessContext": "Annual coupon rate",
      "label_i18n": {
        "en": "Coupon Rate",
        "tr": "Coupon Rate",
        "de": "Coupon Rate",
        "fr": "Coupon Rate",
        "es": "Coupon Rate",
        "ar": "Coupon Rate"
      }
    },
    {
      "id": "currentPrice",
      "label": "Current Market Price",
      "type": "number",
      "unit": "$",
      "default": 950,
      "businessContext": "Current trading price",
      "label_i18n": {
        "en": "Current Market Price",
        "tr": "Current Market Price",
        "de": "Current Market Price",
        "fr": "Current Market Price",
        "es": "Current Market Price",
        "ar": "Current Market Price"
      }
    },
    {
      "id": "yearsToMaturity",
      "label": "Years to Maturity",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time until bond matures",
      "label_i18n": {
        "en": "Years to Maturity",
        "tr": "Years to Maturity",
        "de": "Years to Maturity",
        "fr": "Years to Maturity",
        "es": "Years to Maturity",
        "ar": "Years to Maturity"
      }
    },
    {
      "id": "frequency",
      "label": "Coupon Frequency",
      "type": "number",
      "unit": "times per year",
      "default": 1,
      "businessContext": "Number of coupon payments per year",
      "label_i18n": {
        "en": "Coupon Frequency",
        "tr": "Coupon Frequency",
        "de": "Coupon Frequency",
        "fr": "Coupon Frequency",
        "es": "Coupon Frequency",
        "ar": "Coupon Frequency"
      }
    }
  ],
  "formulas": {
    "annualCoupon": "faceValue * couponRate / 100",
    "currentYield": "annualCoupon / currentPrice * 100",
    "approxYTM": "(annualCoupon + (faceValue - currentPrice) / yearsToMaturity) / ((faceValue + currentPrice) / 2) * 100"
  },
  "outputs": {
    "primary": "annualCoupon",
    "breakdown": [
      {
        "id": "currentYield",
        "label": "Current Yield",
        "unit": "%",
        "value": "currentYield"
      },
      {
        "id": "annualCoupon",
        "label": "Annual Coupon Payment",
        "unit": "$",
        "value": "annualCoupon"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "approxYTM"
  },
  "category": "Maliyet & Bütçeleme",

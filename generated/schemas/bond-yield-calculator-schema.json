        "fr": "Prix de négociation actuel",
        "es": "Precio de negociación actual",
        "ar": "سعر التداول الحالي"
      }
    },
    {
      "id": "yearsToMaturity",
      "label": "Years to Maturity",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time until bond matures",
      "label_i18n": {
        "en": "Years to Maturity",
        "tr": "Vadeye Kalan Yıl",
        "de": "Jahre bis Fälligkeit",
        "fr": "Années jusqu'à l'échéance",
        "es": "Años hasta el vencimiento",
        "ar": "السنوات حتى الاستحقاق"
      },
      "businessContext_i18n": {
        "en": "Time until bond matures",
        "tr": "Tahvilin vadesine kadar kalan süre",
        "de": "Zeit bis zur Fälligkeit der Anleihe",
        "fr": "Temps restant avant l'échéance de l'obligation",
        "es": "Tiempo hasta que el bono vence",
        "ar": "الوقت حتى استحقاق السند"
      }
    },
    {
      "id": "frequency",
      "label": "Coupon Frequency",
      "type": "number",
      "unit": "times per year",
      "default": 1,
      "businessContext": "Number of coupon payments per year",
      "label_i18n": {
        "en": "Coupon Frequency",
        "tr": "Kupon Sıklığı",
        "de": "Kuponhäufigkeit",
        "fr": "Fréquence du coupon",
        "es": "Frecuencia de cupón",
        "ar": "تكرار القسيمة"
      },
      "businessContext_i18n": {
        "en": "Number of coupon payments per year",
        "tr": "Yıllık kupon ödemesi sayısı",
        "de": "Anzahl der Kuponzahlungen pro Jahr",
        "fr": "Nombre de paiements de coupon par an",
        "es": "Número de pagos de cupón por año",
        "ar": "عدد دفعات القسيمة في السنة"
      }
    }
  ],
  "formulas": {
    "annualCoupon": "faceValue * couponRate / 100",
    "currentYield": "annualCoupon / currentPrice * 100",
    "approxYTM": "(annualCoupon + (faceValue - currentPrice) / yearsToMaturity) / ((faceValue + currentPrice) / 2) * 100"
  },
  "outputs": {
    "primary": "annualCoupon",
    "breakdown": [
      {
        "id": "currentYield",
        "label": "Current Yield",
        "unit": "%",
        "value": "currentYield"
      },
      {
        "id": "annualCoupon",
        "label": "Annual Coupon Payment",
        "unit": "$",
        "value": "annualCoupon"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "approxYTM",
    "unit": "$"
  },

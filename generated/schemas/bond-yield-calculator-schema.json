        "de": "Jährlicher Kuponzinssatz",
        "fr": "Taux du coupon annuel",
        "es": "Tasa de cupón anual",
        "ar": "معدل القسيمة السنوي"
      }
    },
    {
      "id": "currentPrice",
      "label": "Current Market Price",
      "type": "number",
      "unit": "$",
      "default": 950,
      "businessContext": "Current trading price",
      "label_i18n": {
        "en": "Current Market Price",
        "tr": "Güncel Piyasa Fiyatı",
        "de": "Aktueller Marktpreis",
        "fr": "Prix actuel du marché",

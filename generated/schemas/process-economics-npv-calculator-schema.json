{
  "toolName": "process-economics-npv-calculator",
  "inputs": [
    {
      "id": "initialInvestment",
      "label": "Initial Capital Investment",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "The upfront capital cost required for the process improvement or new equipment.",
      "label_i18n": {
        "en": "Initial Capital Investment",
        "tr": "Initial Capital Investment",
        "de": "Initial Capital Investment",
        "fr": "Initial Capital Investment",
        "es": "Initial Capital Investment",
        "ar": "Initial Capital Investment"
      }
    },
    {
      "id": "annualCostSavings",
      "label": "Annual Cost Savings",
      "type": "number",
      "unit": "currency",
      "default": 25000,
      "businessContext": "Expected annual reduction in operating costs (e.g., labor, materials, energy) from the investment.",
      "label_i18n": {
        "en": "Annual Cost Savings",
        "tr": "Annual Cost Savings",
        "de": "Annual Cost Savings",
        "fr": "Annual Cost Savings",
        "es": "Annual Cost Savings",
        "ar": "Annual Cost Savings"
      }
    },
    {
      "id": "projectLife",
      "label": "Project Life",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "The number of years over which the investment will generate savings.",
      "label_i18n": {
        "en": "Project Life",
        "tr": "Project Life",
        "de": "Project Life",
        "fr": "Project Life",
        "es": "Project Life",
        "ar": "Project Life"
      }
    },
    {
      "id": "discountRate",
      "label": "Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "The annual discount rate reflecting the cost of capital or required rate of return.",
      "label_i18n": {
        "en": "Discount Rate",
        "tr": "Discount Rate",
        "de": "Discount Rate",
        "fr": "Discount Rate",
        "es": "Discount Rate",
        "ar": "Discount Rate"
      }
    }
  ],
  "formulas": {
    "netPresentValue": "annualCostSavings * ((1 - (1 + discountRate/100) ** (-projectLife)) / (discountRate/100)) - initialInvestment",
    "paybackPeriod": "initialInvestment / annualCostSavings",
    "annualROI": "(annualCostSavings / initialInvestment) * 100"
  },
  "outputs": {
    "primary": "netPresentValue",
    "breakdown": [
      "paybackPeriod",
      "annualROI"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualROI",
    "unit": "currency"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

{
  "toolName": "npu-npi-profil-agirlik-hesaplama",
  "inputs": [
    {
      "id": "profilTipi",
      "label": "Profil Tipi",
      "type": "select",
      "unit": "",
      "default": "NPU",
      "min": null,
      "max": null,
      "options": [
        "NPU",
        "NPI"
      ],
      "businessContext": "NPU ve NPI profilleri farklı geometrik özelliklere sahiptir. Standart: DIN 1026-1 (NPU) ve DIN 1026-2 (NPI)."
    },
    {
      "id": "profilBoyutu",
      "label": "Profil Boyutu (mm)",
      "type": "select",
      "unit": "mm",
      "default": "100",
      "min": null,
      "max": null,
      "options": [
        "80",
        "100",
        "120",
        "140",
        "160",
        "180",
        "200",
        "220",
        "240",
        "260",
        "280",
        "300"
      ],
      "businessContext": "Profilin nominal yüksekliği (h). Standart boyutlar DIN 1026'ya göre belirlenmiştir."
    },
    {
      "id": "profilKalitesi",
      "label": "Profil Kalitesi (Çelik Sınıfı)",
      "type": "select",
      "unit": "",
      "default": "S235JR",
      "min": null,
      "max": null,
      "options": [
        "S235JR",
        "S275JR",
        "S355JR",
        "S420N",
        "S460N"
      ],
      "businessContext": "Çelik sınıfı, yoğunluğu ve mekanik özellikleri etkiler. Standart: EN 10025-2."
    },
    {
      "id": "profilUzunlugu",
      "label": "Profil Uzunluğu (m)",
      "type": "number",
      "unit": "m",
      "default": 6,
      "min": 1,
      "max": 18,
      "businessContext": "Standart profil boyu genellikle 6 m veya 12 m'dir. Müşteri talebine göre değişebilir."
    },
    {
      "id": "adet",
      "label": "Adet",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "min": 1,
      "max": 10000,
      "businessContext": "Hesaplanacak profil sayısı."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güvenilirliği",
      "type": "select",
      "unit": "",
      "default": "yuksek",
      "min": null,
      "max": null,
      "options": [
        "dusuk",
        "orta",
        "yuksek"
      ],
      "businessContext": "Kullanılan verilerin güvenilirlik seviyesi. Düşük güvenilirlikte sonuçlar bir güvenlik faktörü ile çarpılır."
    }
  ],
  "validation": {
    "rules": [
      "profilUzunlugu >= 1 ve <= 18",
      "adet >= 1",
      "profilBoyutu seçili olmalı",
      "profilTipi seçili olmalı"
    ],
    "thresholds": {
      "profilUzunlugu > 12": "Uzun profil taşıma ve işleme maliyetlerini artırabilir.",
      "adet > 100": "Toplu siparişlerde indirim uygulanabilir."
    }
  },
  "formulas": {
    "birimAgirlik": "kesitAlani * 7850 / 1000000",
    "kesitAlani": "profilTipi == 'NPU' ? (profilBoyutu * 0.1 + 0.5) : (profilBoyutu * 0.12 + 0.6)",
    "toplamAgirlik": "birimAgirlik * profilUzunlugu * adet",
    "dataConfidenceAdjusted": "dataConfidence == 'dusuk' ? toplamAgirlik * 1.1 : (dataConfidence == 'orta' ? toplamAgirlik * 1.05 : toplamAgirlik)"
  },
  "outputs": {
    "primary": "toplamAgirlik",
    "breakdown": {
      "birimAgirlik": "birimAgirlik",
      "kesitAlani": "kesitAlani",
      "toplamAgirlik": "toplamAgirlik"
    },
    "hiddenLossDrivers": [
      "profilUzunlugu > 12 ? 'Uzun profil taşıma maliyeti artar' : ''",
      "adet > 100 ? 'Toplu sipariş indirimi uygulanabilir' : ''"
    ],
    "suggestedActions": [
      "Profil boyutunu optimize ederek malzeme israfını azaltın.",
      "Toplu siparişlerde tedarikçi indirimi talep edin.",
      "Uzun profiller için özel taşıma planı yapın."
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

  "formulas": {
    "effective_consumption": "base_consumption * temperature_factor * driving_style_factor + (auxiliary_power / average_speed)",
    "optimal_range_km": "(battery_capacity * 1000) / base_consumption",
    "estimated_range_km": "(battery_capacity * 1000) / (base_consumption * temperature_factor * driving_style_factor + (auxiliary_power / average_speed))"
  },
  "outputs": {
    "primary": "effective_consumption",
    "breakdown": [

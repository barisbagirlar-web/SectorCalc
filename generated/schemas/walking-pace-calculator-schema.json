{
  "toolName": "walking-pace-calculator",
  "inputs": [
    {
      "id": "distanceMeters",
      "label": "Distance (meters)",
      "type": "number",
      "unit": "m",
      "default": 1000,
      "businessContext": "Total walking distance in meters, e.g., from one workstation to another in a factory layout.",
      "label_i18n": {
        "en": "Distance (meters)",
        "tr": "Distance (meters)",
        "de": "Distance (meters)",
        "fr": "Distance (meters)",
        "es": "Distance (meters)",
        "ar": "Distance (meters)"
      }
    },
    {
      "id": "timeHours",
      "label": "Time (hours)",
      "type": "number",
      "unit": "h",
      "default": 0,
      "businessContext": "Hours part of the walking time.",
      "label_i18n": {
        "en": "Time (hours)",
        "tr": "Time (hours)",
        "de": "Time (hours)",
        "fr": "Time (hours)",
        "es": "Time (hours)",
        "ar": "Time (hours)"
      }
    },
    {
      "id": "timeMinutes",
      "label": "Time (minutes)",
      "type": "number",
      "unit": "min",
      "default": 15,
      "businessContext": "Minutes part of the walking time.",
      "label_i18n": {
        "en": "Time (minutes)",
        "tr": "Time (minutes)",
        "de": "Time (minutes)",
        "fr": "Time (minutes)",
        "es": "Time (minutes)",

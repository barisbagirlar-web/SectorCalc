      }
    },
    {
      "id": "timeSeconds",
      "label": "Time (seconds)",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Seconds part of the walking time.",
      "label_i18n": {
        "en": "Time (seconds)",
        "tr": "Time (seconds)",
        "de": "Time (seconds)",
        "fr": "Time (seconds)",
        "es": "Time (seconds)",
        "ar": "Time (seconds)"
      }
    },
    {
      "id": "strideLengthCm",
      "label": "Stride Length (cm)",
      "type": "number",
      "unit": "cm",
      "default": 0,
      "businessContext": "Optional: average stride length in centimeters for step-based distance calculation.",
      "label_i18n": {
        "en": "Stride Length (cm)",
        "tr": "Stride Length (cm)",
        "de": "Stride Length (cm)",
        "fr": "Stride Length (cm)",
        "es": "Stride Length (cm)",
        "ar": "Stride Length (cm)"
      }
    },
    {
      "id": "steps",
      "label": "Steps",
      "type": "number",
      "unit": "count",
      "default": 0,
      "businessContext": "Optional: number of steps taken. Used with stride length to estimate distance if distance is not directly entered.",
      "label_i18n": {
        "en": "Steps",
        "tr": "Steps",
        "de": "Steps",
        "fr": "Steps",
        "es": "Steps",
        "ar": "Steps"
      }
    }
  ],
  "formulas": {
    "distanceMetersCalc": "distanceMeters > 0 ? distanceMeters : (steps * strideLengthCm / 100)",
    "totalSeconds": "timeHours * 3600 + timeMinutes * 60 + timeSeconds",
    "speedKmh": "(distanceMetersCalc * 3.6) / totalSeconds",
    "paceMinPerKm": "totalSeconds / distanceMetersCalc * 1000 / 60",
    "totalDistanceKm": "distanceMetersCalc / 1000"
  },
  "outputs": {
    "primary": "paceMinPerKm",
    "breakdown": [
      "speedKmh",
      "totalDistanceKm"
    ]
  },

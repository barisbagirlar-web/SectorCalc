{
  "toolName": "ucgen-alani-cevresi-hesaplama",
  "inputs": [
    {
      "id": "kenarA",
      "label": "Kenar A",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0.001,
      "max": 1000000,
      "options": null,
      "businessContext": "Üçgenin birinci kenar uzunluğu. Geometrik hesaplamalar için temel girdi."
    },
    {
      "id": "kenarB",
      "label": "Kenar B",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0.001,
      "max": 1000000,
      "options": null,
      "businessContext": "Üçgenin ikinci kenar uzunluğu."
    },
    {
      "id": "kenarC",
      "label": "Kenar C",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0.001,
      "max": 1000000,
      "options": null,
      "businessContext": "Üçgenin üçüncü kenar uzunluğu."
    },
    {
      "id": "birim",
      "label": "Birim",
      "type": "select",
      "unit": "",
      "default": "m",
      "min": null,
      "max": null,
      "options": [
        "m",
        "cm",
        "mm",
        "ft",
        "in"
      ],
      "businessContext": "Uzunluk birimi seçimi. Tüm girdiler aynı birimde olmalıdır."
    }
  ],
  "validation": {
    "rules": [
      "kenarA > 0",
      "kenarB > 0",
      "kenarC > 0",
      "kenarA + kenarB > kenarC",
      "kenarA + kenarC > kenarB",
      "kenarB + kenarC > kenarA"
    ],
    "thresholds": {
      "kenarA <= 0.01": "Kenar A çok küçük, hassasiyet sorunu olabilir.",
      "kenarB <= 0.01": "Kenar B çok küçük, hassasiyet sorunu olabilir.",
      "kenarC <= 0.01": "Kenar C çok küçük, hassasiyet sorunu olabilir."
    }
  },
  "formulas": {
    "cevre": "kenarA + kenarB + kenarC",
    "yarimCevre": "(kenarA + kenarB + kenarC) / 2",
    "alan": "Math.sqrt(yarimCevre * (yarimCevre - kenarA) * (yarimCevre - kenarB) * (yarimCevre - kenarC))"
  },
  "outputs": {
    "primary": "alan",
    "breakdown": {
      "cevre": "cevre",
      "yarimCevre": "yarimCevre"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [],
    "dataConfidenceAdjusted": "alan"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Comparison"
  ],
  "premiumRequired": false
}

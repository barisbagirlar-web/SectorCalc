        "ar": "Compression Ratio (r)"
      }
    },
    {
      "id": "specificHeatRatio",
      "label": "Specific Heat Ratio (k)",
      "type": "number",
      "unit": "unit",
      "default": 1.4,
      "businessContext": "Adiabatic index (cp/cv) of the working fluid, typically 1.4 for air",
      "label_i18n": {
        "en": "Specific Heat Ratio (k)",
        "tr": "Specific Heat Ratio (k)",
        "de": "Specific Heat Ratio (k)",
        "fr": "Specific Heat Ratio (k)",
        "es": "Specific Heat Ratio (k)",
        "ar": "Specific Heat Ratio (k)"
      }
    },
    {
      "id": "initialTemperature",
      "label": "Initial Temperature (T1)",
      "type": "number",
      "unit": "K",
      "default": 300,
      "businessContext": "Temperature at the start of compression stroke",
      "label_i18n": {
        "en": "Initial Temperature (T1)",
        "tr": "Initial Temperature (T1)",
        "de": "Initial Temperature (T1)",
        "fr": "Initial Temperature (T1)",
        "es": "Initial Temperature (T1)",
        "ar": "Initial Temperature (T1)"
      }
    },
    {
      "id": "initialPressure",
      "label": "Initial Pressure (P1)",
      "type": "number",
      "unit": "kPa",
      "default": 100,
      "businessContext": "Pressure at the start of compression stroke (intake pressure)",
      "label_i18n": {
        "en": "Initial Pressure (P1)",
        "tr": "Initial Pressure (P1)",
        "de": "Initial Pressure (P1)",
        "fr": "Initial Pressure (P1)",
        "es": "Initial Pressure (P1)",
        "ar": "Initial Pressure (P1)"
      }
    },
    {
      "id": "maxTemperature",
      "label": "Maximum Temperature (T3)",
      "type": "number",
      "unit": "K",
      "default": 2000,
      "businessContext": "Temperature after constant volume heat addition (combustion)",
      "label_i18n": {
        "en": "Maximum Temperature (T3)",
        "tr": "Maximum Temperature (T3)",
        "de": "Maximum Temperature (T3)",
        "fr": "Maximum Temperature (T3)",
        "es": "Maximum Temperature (T3)",
        "ar": "Maximum Temperature (T3)"
      }
    },
    {
      "id": "specificHeatCv",
      "label": "Specific Heat (Cv)",
      "type": "number",
      "unit": "kJ/(kg·K)",
      "default": 0.718,
      "businessContext": "Specific heat at constant volume of the working fluid (air ≈ 0.718 kJ/kg·K)",
      "label_i18n": {
        "en": "Specific Heat (Cv)",
        "tr": "Specific Heat (Cv)",
        "de": "Specific Heat (Cv)",
        "fr": "Specific Heat (Cv)",
        "es": "Specific Heat (Cv)",
        "ar": "Specific Heat (Cv)"
      }
    }
  ],
  "formulas": {
    "thermalefficiency": "(1 - 1 / Math.pow(compressionRatio, specificHeatRatio - 1)) * 100",
    "temperatureAfterCompression": "initialTemperature * Math.pow(compressionRatio, specificHeatRatio - 1)",
    "temperatureAfterExpansion": "maxTemperature / Math.pow(compressionRatio, specificHeatRatio - 1)",
    "pressureAfterCompression": "initialPressure * Math.pow(compressionRatio, specificHeatRatio)",
    "netWorkPerMass": "specificHeatCv * (maxTemperature - initialTemperature * Math.pow(compressionRatio, specificHeatRatio - 1) - maxTemperature / Math.pow(compressionRatio, specificHeatRatio - 1) + initialTemperature)",
    "heatAdditionPerMass": "specificHeatCv * (maxTemperature - initialTemperature * Math.pow(compressionRatio, specificHeatRatio - 1))"
  },
  "outputs": {
    "primary": "thermalefficiency",
    "breakdown": [
      "temperatureAfterCompression",
      "temperatureAfterExpansion",
      "netWorkPerMass"
    ]
  },

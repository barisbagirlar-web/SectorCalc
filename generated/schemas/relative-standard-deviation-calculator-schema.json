  "formulas": {
    "mean": "(value1 + value2 + value3 + value4 + value5) / 5",
    "stdDev": "Math.sqrt( ( (value1 - mean) ** 2 + (value2 - mean) ** 2 + (value3 - mean) ** 2 + (value4 - mean) ** 2 + (value5 - mean) ** 2 ) / 4 )",
    "rsd": "(stdDev / mean) * 100"
  },
  "outputs": {
    "primary": "rsd",
    "breakdown": [
      "mean",
      "stdDev"
    ]

        "de": "Other Cards Remaining",
        "fr": "Other Cards Remaining",
        "es": "Other Cards Remaining",
        "ar": "Other Cards Remaining"
      }
    }
  ],
  "formulas": {
    "blackjackProbability": "((acesRemaining / (acesRemaining + tensRemaining + otherCardsRemaining)) * (tensRemaining / (acesRemaining + tensRemaining + otherCardsRemaining - 1)) + (tensRemaining / (acesRemaining + tensRemaining + otherCardsRemaining)) * (acesRemaining / (acesRemaining + tensRemaining + otherCardsRemaining - 1))) * 100",
    "aceThenTenProbability": "(acesRemaining / (acesRemaining + tensRemaining + otherCardsRemaining)) * (tensRemaining / (acesRemaining + tensRemaining + otherCardsRemaining - 1)) * 100",
    "tenThenAceProbability": "(tensRemaining / (acesRemaining + tensRemaining + otherCardsRemaining)) * (acesRemaining / (acesRemaining + tensRemaining + otherCardsRemaining - 1)) * 100"
  },
  "outputs": {
    "primary": "blackjackProbability",
    "breakdown": [
      "aceThenTenProbability",
      "tenThenAceProbability"
    ],

{
  "toolName": "gratitude-calculator",
  "inputs": [
    {
      "id": "daily_acts",
      "label": "Daily Acts of Gratitude",
      "type": "number",
      "unit": "acts",
      "default": 3,
      "businessContext": "Number of gratitude practices performed per day",
      "label_i18n": {
        "en": "Daily Acts of Gratitude",
        "tr": "Daily Acts of Gratitude",
        "de": "Daily Acts of Gratitude",
        "fr": "Daily Acts of Gratitude",
        "es": "Daily Acts of Gratitude",
        "ar": "Daily Acts of Gratitude"
      }
    },
    {
      "id": "days_practiced",
      "label": "Days Practiced",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Total days gratitude practice has been maintained",
      "label_i18n": {
        "en": "Days Practiced",
        "tr": "Days Practiced",
        "de": "Days Practiced",
        "fr": "Days Practiced",
        "es": "Days Practiced",
        "ar": "Days Practiced"
      }
    },
    {
      "id": "intensity_factor",
      "label": "Intensity Factor",
      "type": "number",
      "unit": "1-10",
      "default": 7,
      "businessContext": "Self-rated intensity of gratitude experience (1=low, 10=high)",
      "label_i18n": {
        "en": "Intensity Factor",
        "tr": "Intensity Factor",
        "de": "Intensity Factor",
        "fr": "Intensity Factor",
        "es": "Intensity Factor",
        "ar": "Intensity Factor"
      }
    },
    {
      "id": "social_shares",
      "label": "Social Shares",
      "type": "number",
      "unit": "shares",
      "default": 2,
      "businessContext": "Number of times gratitude is expressed to others per day",
      "label_i18n": {
        "en": "Social Shares",
        "tr": "Social Shares",
        "de": "Social Shares",
        "fr": "Social Shares",
        "es": "Social Shares",
        "ar": "Social Shares"
      }
    },
    {
      "id": "journal_entries",
      "label": "Journal Entries",
      "type": "number",
      "unit": "entries",
      "default": 1,
      "businessContext": "Number of gratitude journal entries per day",
      "label_i18n": {
        "en": "Journal Entries",
        "tr": "Journal Entries",
        "de": "Journal Entries",
        "fr": "Journal Entries",
        "es": "Journal Entries",
        "ar": "Journal Entries"
      }
    },
    {
      "id": "baseline_happiness",
      "label": "Baseline Happiness",
      "type": "number",
      "unit": "1-10",
      "default": 5,
      "businessContext": "Self-rated happiness level before starting practice",
      "label_i18n": {
        "en": "Baseline Happiness",
        "tr": "Baseline Happiness",
        "de": "Baseline Happiness",
        "fr": "Baseline Happiness",
        "es": "Baseline Happiness",
        "ar": "Baseline Happiness"
      }
    }
  ],
  "formulas": {
    "gratitude_score": "daily_acts * days_practiced * (intensity_factor / 10)",
    "social_impact": "social_shares * days_practiced * 0.5",
    "reflection_depth": "journal_entries * days_practiced * Math.log(intensity_factor + 1)",
    "happiness_gain": "(gratitude_score + social_impact + reflection_depth) / 100 + (baseline_happiness * 0.1)",
    "overall_gratitude_index": "Math.sqrt(gratitude_score * social_impact * reflection_depth) + happiness_gain"
  },
  "outputs": {
    "primary": "overall_gratitude_index",
    "breakdown": [
      "gratitude_score: Total gratitude actions weighted by intensity",
      "social_impact: Effect of sharing gratitude with others",
      "reflection_depth: Depth of gratitude reflection through journaling",
      "happiness_gain: Estimated increase in happiness level"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

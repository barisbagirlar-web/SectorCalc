{
  "toolName": "recipe-nutrition-calculator",
  "inputs": [
    {
      "id": "totalProtein",
      "label": "Total Protein",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Total protein in entire recipe"
    },
    {
      "id": "totalCarbs",
      "label": "Total Carbohydrates",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Total carbohydrates in entire recipe"
    },
    {
      "id": "totalFat",
      "label": "Total Fat",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Total fat in entire recipe"
    },
    {
      "id": "totalWeight",
      "label": "Total Weight",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Total weight of entire recipe"
    },
    {
      "id": "numberOfServings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 4,
      "businessContext": "Number of servings the recipe yields"
    }
  ],
  "formulas": {
    "totalCalories": "totalProtein * 4 + totalCarbs * 4 + totalFat * 9",
    "perServingWeight": "totalWeight / numberOfServings",
    "perServingProtein": "totalProtein / numberOfServings",
    "perServingCarbs": "totalCarbs / numberOfServings",
    "perServingFat": "totalFat / numberOfServings",
    "perServingCalories": "totalCalories / numberOfServings"
  },
  "outputs": {
    "primary": "perServingCalories",
    "breakdown": [
      "perServingProtein",
      "perServingCarbs",
      "perServingFat",
      "totalCalories"
    ]
  },
  "category": "Gıda & Tarım",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "food-cold-chain-hygiene",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "conversion"
}

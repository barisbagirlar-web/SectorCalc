{
  "toolName": "scs-method-calculator",
  "inputs": [
    {
      "id": "rainfall",
      "label": "Rainfall Depth (P)",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "Total 24-hour rainfall depth in millimeters.",
      "label_i18n": {
        "en": "Rainfall Depth (P)",
        "tr": "Rainfall Depth (P)",
        "de": "Rainfall Depth (P)",
        "fr": "Rainfall Depth (P)",
        "es": "Rainfall Depth (P)",
        "ar": "Rainfall Depth (P)"
      }
    },
    {
      "id": "curveNumber",
      "label": "Curve Number (CN2)",
      "type": "number",
      "unit": "dimensionless",
      "default": 75,
      "businessContext": "SCS Curve Number for normal (AMC II) conditions. Range 30-100.",
      "label_i18n": {
        "en": "Curve Number (CN2)",
        "tr": "Curve Number (CN2)",
        "de": "Curve Number (CN2)",
        "fr": "Curve Number (CN2)",
        "es": "Curve Number (CN2)",
        "ar": "Curve Number (CN2)"
      }
    },
    {
      "id": "amc",
      "label": "Antecedent Moisture Condition",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "1 = Dry (AMC I), 2 = Normal (AMC II), 3 = Wet (AMC III).",
      "label_i18n": {
        "en": "Antecedent Moisture Condition",
        "tr": "Antecedent Moisture Condition",
        "de": "Antecedent Moisture Condition",
        "fr": "Antecedent Moisture Condition",
        "es": "Antecedent Moisture Condition",
        "ar": "Antecedent Moisture Condition"
      }
    },
    {
      "id": "iaRatio",
      "label": "Initial Abstraction Ratio",
      "type": "number",
      "unit": "unit",
      "default": 0.2,
      "businessContext": "Ratio of initial abstraction to potential maximum retention (commonly 0.2).",
      "label_i18n": {
        "en": "Initial Abstraction Ratio",
        "tr": "Initial Abstraction Ratio",
        "de": "Initial Abstraction Ratio",
        "fr": "Initial Abstraction Ratio",
        "es": "Initial Abstraction Ratio",
        "ar": "Initial Abstraction Ratio"
      }
    }
  ],
  "formulas": {
    "adjustedCN": "Math.min(100, Math.max(0, amc === 1 ? curveNumber / (2.334 - 0.01334 * curveNumber) : amc === 3 ? curveNumber / (0.4036 + 0.0059 * curveNumber) : curveNumber))",
    "S": "(25400 / adjustedCN) - 254",
    "Ia": "iaRatio * S",
    "runoff": "rainfall > Ia ? Math.pow(rainfall - Ia, 2) / (rainfall - Ia + S) : 0"
  },
  "outputs": {
    "primary": "runoff",
    "breakdown": [
      "adjustedCN",
      "S",
      "Ia",
      "runoff"
    ]
  },
  "category": "Diğer",
  "sector": "Makine & Ekipman",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "diger"
}

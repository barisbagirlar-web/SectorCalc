{
  "toolName": "interval-calculator",
  "inputs": [
    {
      "id": "nominal",
      "label": "Nominal Value",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Target dimension",
      "label_i18n": {
        "en": "Nominal Value",
        "tr": "Nominal Value",
        "de": "Nominal Value",
        "fr": "Nominal Value",
        "es": "Nominal Value",
        "ar": "Nominal Value"
      }
    },
    {
      "id": "plusTol",
      "label": "Upper Tolerance",
      "type": "number",
      "unit": "mm",
      "default": 0.1,
      "businessContext": "Plus tolerance from engineering drawing",
      "label_i18n": {
        "en": "Upper Tolerance",
        "tr": "Upper Tolerance",
        "de": "Upper Tolerance",
        "fr": "Upper Tolerance",
        "es": "Upper Tolerance",
        "ar": "Upper Tolerance"
      }
    },
    {
      "id": "minusTol",
      "label": "Lower Tolerance",
      "type": "number",
      "unit": "mm",
      "default": 0.05,
      "businessContext": "Minus tolerance, entered as positive value",
      "label_i18n": {
        "en": "Lower Tolerance",
        "tr": "Lower Tolerance",
        "de": "Lower Tolerance",
        "fr": "Lower Tolerance",
        "es": "Lower Tolerance",
        "ar": "Lower Tolerance"
      }
    },
    {
      "id": "scaleFactor",
      "label": "Unit Conversion Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 = mm; 0.03937 = inch; 0.1 = cm",
      "label_i18n": {
        "en": "Unit Conversion Factor",
        "tr": "Unit Conversion Factor",
        "de": "Unit Conversion Factor",
        "fr": "Unit Conversion Factor",
        "es": "Unit Conversion Factor",
        "ar": "Unit Conversion Factor"
      }
    }
  ],
  "formulas": {
    "upper_limit": "scaleFactor * (nominal + plusTol)",
    "lower_limit": "scaleFactor * (nominal - minusTol)",
    "tolerance_range": "scaleFactor * (plusTol + minusTol)",
    "midpoint": "scaleFactor * (nominal + (plusTol - minusTol) / 2)"
  },
  "outputs": {
    "primary": "tolerance_range",
    "breakdown": [
      "upper_limit",
      "lower_limit",
      "midpoint"
    ]
  },

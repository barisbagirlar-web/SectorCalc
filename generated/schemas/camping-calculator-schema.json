{
  "toolName": "camping-calculator",
  "inputs": [
    {
      "id": "numberOfCampers",
      "label": "Number of Campers",
      "type": "number",
      "unit": "people",
      "default": 1,
      "businessContext": "Total number of people on the camping trip",
      "label_i18n": {
        "en": "Number of Campers",
        "tr": "Number of Campers",
        "de": "Number of Campers",
        "fr": "Number of Campers",
        "es": "Number of Campers",
        "ar": "Number of Campers"
      }
    },
    {
      "id": "numberOfNights",
      "label": "Number of Nights",
      "type": "number",
      "unit": "nights",
      "default": 2,
      "businessContext": "Duration of the camping trip in nights",
      "label_i18n": {
        "en": "Number of Nights",
        "tr": "Number of Nights",
        "de": "Number of Nights",
        "fr": "Number of Nights",
        "es": "Number of Nights",
        "ar": "Number of Nights"
      }
    },
    {
      "id": "waterPerPerson",
      "label": "Daily Water per Person",
      "type": "number",
      "unit": "liters/day",
      "default": 5,
      "businessContext": "Recommended water per person per day for drinking, cooking, and hygiene",
      "label_i18n": {
        "en": "Daily Water per Person",
        "tr": "Daily Water per Person",
        "de": "Daily Water per Person",
        "fr": "Daily Water per Person",
        "es": "Daily Water per Person",
        "ar": "Daily Water per Person"
      }
    },
    {
      "id": "foodPerPerson",
      "label": "Daily Food Energy per Person",
      "type": "number",
      "unit": "kcal/day",
      "default": 2500,
      "businessContext": "Average daily calorie intake per person",
      "label_i18n": {
        "en": "Daily Food Energy per Person",
        "tr": "Daily Food Energy per Person",
        "de": "Daily Food Energy per Person",
        "fr": "Daily Food Energy per Person",
        "es": "Daily Food Energy per Person",
        "ar": "Daily Food Energy per Person"
      }
    },
    {
      "id": "firewoodPerNight",
      "label": "Firewood per Night",
      "type": "number",
      "unit": "kg/night",
      "default": 10,
      "businessContext": "Estimated firewood needed per evening campfire",
      "label_i18n": {
        "en": "Firewood per Night",
        "tr": "Firewood per Night",
        "de": "Firewood per Night",
        "fr": "Firewood per Night",
        "es": "Firewood per Night",
        "ar": "Firewood per Night"
      }
    },
    {
      "id": "temperatureAdjust",
      "label": "Temperature Adjustment Factor",
      "type": "number",
      "unit": "unitless",
      "default": 0,
      "businessContext": "Adjust water needs: 0 for normal, positive for hot (e.g., 0.2 for >30°C), negative for cold",
      "label_i18n": {
        "en": "Temperature Adjustment Factor",
        "tr": "Temperature Adjustment Factor",
        "de": "Temperature Adjustment Factor",
        "fr": "Temperature Adjustment Factor",
        "es": "Temperature Adjustment Factor",
        "ar": "Temperature Adjustment Factor"
      }
    },
    {
      "id": "safetyMargin",
      "label": "Safety Margin",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage of extra supplies for unforeseen circumstances",
      "label_i18n": {
        "en": "Safety Margin",
        "tr": "Safety Margin",
        "de": "Safety Margin",
        "fr": "Safety Margin",
        "es": "Safety Margin",
        "ar": "Safety Margin"
      }
    }
  ],
  "formulas": {
    "totalWater": "numberOfCampers * waterPerPerson * numberOfNights * (1 + temperatureAdjust) * (1 + safetyMargin/100)",
    "totalFood": "numberOfCampers * foodPerPerson * numberOfNights * (1 + safetyMargin/100)",
    "totalFirewood": "firewoodPerNight * numberOfNights * (1 + safetyMargin/100)"
  },
  "outputs": {
    "primary": "totalWater",
    "breakdown": [
      "totalFood",
      "totalFirewood"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalFirewood"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "gida",
  "profession": "Gıda Mühendisi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

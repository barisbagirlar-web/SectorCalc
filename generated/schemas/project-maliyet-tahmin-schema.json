  "formulas": {
    "DirectLabor": "SUM(Hours_i * Rate_i)",
    "DirectMaterial": "SUM(Quantity_j * Price_j)",
    "Equipment": "SUM(RentalDays_k * DailyRate_k)",
    "Subcontractor": "SUM(LumpSum_m)",
    "Overhead": "(DirectLabor + DirectMaterial) * OverheadRate",
    "Contingency": "(Direct + Overhead) * RiskFactor",
    "TotalEstimate": "DirectLabor + DirectMaterial + Equipment + Subcontractor + Overhead + Contingency",
    "CostVariance": "TotalEstimate - Budget"
  },

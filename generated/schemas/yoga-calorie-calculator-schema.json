{
  "toolName": "yoga-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms."
    },
    {
      "id": "height",
      "label": "Body Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "User's height in centimeters."
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years."
    },
    {
      "id": "gender",
      "label": "Gender (0=Male, 1=Female)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Biological gender for BMR calculation: 0 for male, 1 for female."
    },
    {
      "id": "duration",
      "label": "Yoga Duration",
      "type": "number",
      "unit": "min",
      "default": 60,
      "businessContext": "Duration of the yoga session in minutes."
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 3,
      "businessContext": "Metabolic Equivalent of Task for the specific yoga style (e.g., Hatha=2.5, Power=4.0)."
    }
  ],
  "formulas": {
    "bmr": "gender === 0 ? (10 * weight + 6.25 * height - 5 * age + 5) : (10 * weight + 6.25 * height - 5 * age - 161)",
    "totalCalories": "met * weight * (duration / 60)",
    "restingDuring": "bmr * (duration / 1440)",
    "netCalories": "totalCalories - restingDuring"
  },
  "outputs": {
    "primary": "netCalories",
    "breakdown": [
      "totalCalories",
      "restingDuring",
      "bmr"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

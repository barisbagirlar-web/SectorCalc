  "formulas": {
    "bmr": "gender === 0 ? (10 * weight + 6.25 * height - 5 * age + 5) : (10 * weight + 6.25 * height - 5 * age - 161)",
    "totalCalories": "met * weight * (duration / 60)",
    "restingDuring": "bmr * (duration / 1440)",
    "netCalories": "totalCalories - restingDuring"
  },
  "outputs": {
    "primary": "netCalories",
    "breakdown": [
      "totalCalories",
      "restingDuring",
      "bmr"
    ],

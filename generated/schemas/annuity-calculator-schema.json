        "tr": "Her dönem sonunda ödenen tutar.",
        "de": "Der Betrag, der jede Periode (am Ende der Periode) gezahlt wird."
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual nominal interest rate in percent.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Yıllık Faiz Oranı",
        "de": "Jährlicher Zinssatz",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual nominal interest rate in percent.",
        "tr": "Yıllık nominal faiz oranı (yüzde).",
        "de": "Jährlicher nominaler Zinssatz in Prozent."
      }
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Total number of years.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Yıl Sayısı",
        "de": "Anzahl der Jahre",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      },
      "businessContext_i18n": {
        "en": "Total number of years.",
        "tr": "Toplam yıl sayısı.",
        "de": "Gesamtzahl der Jahre."
      }
    },
    {
      "id": "compounding",
      "label": "Compounding Periods per Year",
      "type": "number",
      "unit": "times/year",
      "default": 12,
      "businessContext": "Number of times interest compounds per year (e.g., 12 for monthly).",
      "label_i18n": {
        "en": "Compounding Periods per Year",
        "tr": "Yıllık Bileşik Dönem Sayısı",
        "de": "Zinsperioden pro Jahr",
        "fr": "Compounding Periods per Year",
        "es": "Compounding Periods per Year",
        "ar": "Compounding Periods per Year"
      },
      "businessContext_i18n": {
        "en": "Number of times interest compounds per year (e.g., 12 for monthly).",
        "tr": "Faizin yılda kaç kez bileşiklendiği (örneğin aylık için 12).",
        "de": "Anzahl der Zinseszinsperioden pro Jahr (z. B. 12 für monatlich)."
      }
    }
  ],
  "formulas": {
    "presentValue": "payment * ((1 - (1 + (annualRate/100/compounding)) ** -(years*compounding)) / (annualRate/100/compounding))",
    "futureValue": "payment * (((1 + (annualRate/100/compounding)) ** (years*compounding) - 1) / (annualRate/100/compounding))",
    "totalPayments": "payment * years * compounding"
  },
  "outputs": {
    "primary": "presentValue",
    "breakdown": [
      "futureValue",
      "totalPayments"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPayments",
    "unit": "$"
  },

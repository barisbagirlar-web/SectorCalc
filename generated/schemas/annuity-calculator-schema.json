{
  "toolName": "annuity-calculator",
  "inputs": [
    {
      "id": "payment",
      "label": "Payment per Period",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "The amount paid each period (end of period).",
      "label_i18n": {
        "en": "Payment per Period",
        "tr": "Payment per Period",
        "de": "Payment per Period",
        "fr": "Payment per Period",
        "es": "Payment per Period",
        "ar": "Payment per Period"
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual nominal interest rate in percent.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Total number of years.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Number of Years",
        "de": "Number of Years",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      }
    },
    {
      "id": "compounding",
      "label": "Compounding Periods per Year",
      "type": "number",
      "unit": "times/year",
      "default": 12,
      "businessContext": "Number of times interest compounds per year (e.g., 12 for monthly).",
      "label_i18n": {
        "en": "Compounding Periods per Year",
        "tr": "Compounding Periods per Year",
        "de": "Compounding Periods per Year",
        "fr": "Compounding Periods per Year",
        "es": "Compounding Periods per Year",
        "ar": "Compounding Periods per Year"
      }
    }
  ],
  "formulas": {
    "presentValue": "payment * ((1 - (1 + (annualRate/100/compounding)) ** -(years*compounding)) / (annualRate/100/compounding))",
    "futureValue": "payment * (((1 + (annualRate/100/compounding)) ** (years*compounding) - 1) / (annualRate/100/compounding))",
    "totalPayments": "payment * years * compounding"
  },
  "outputs": {
    "primary": "presentValue",
    "breakdown": [
      "futureValue",
      "totalPayments"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPayments"
  },
  "category": "Diğer",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

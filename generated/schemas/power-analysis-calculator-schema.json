{
  "toolName": "power-analysis-calculator",
  "inputs": [
    {
      "id": "voltage",
      "label": "Voltage (V)",
      "type": "number",
      "unit": "V",
      "default": 230,
      "businessContext": "The electrical potential difference in volts"
    },
    {
      "id": "current",
      "label": "Current (I)",
      "type": "number",
      "unit": "A",
      "default": 10,
      "businessContext": "The electrical current in amperes"
    },
    {
      "id": "resistance",
      "label": "Resistance (R)",
      "type": "number",
      "unit": "Ω",
      "default": 23,
      "businessContext": "The electrical resistance in ohms"
    },
    {
      "id": "time",
      "label": "Time (t)",
      "type": "number",
      "unit": "h",
      "default": 1,
      "businessContext": "The duration of operation in hours"
    }
  ],
  "formulas": {
    "power": "voltage * current",
    "power_VI": "voltage * current",
    "power_VR": "(voltage ** 2) / resistance",
    "power_IR": "(current ** 2) * resistance",
    "energy": "power_VI * time"
  },
  "outputs": {
    "primary": "power",
    "breakdown": [
      "power_VI",
      "power_VR",
      "power_IR",
      "energy"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",

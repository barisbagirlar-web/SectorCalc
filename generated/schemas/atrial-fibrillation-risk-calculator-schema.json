    "agePoints": "age >= 75 ? 2 : (age >= 65 ? 1 : 0)",
    "dmPoints": "diabetes",
    "strokePoints": "priorStrokeOrTIA || vascularDisease ? 2 : 0",
    "sexPoints": "sex",
    "riskScore": "chfPoints + htnPoints + agePoints + dmPoints + strokePoints + sexPoints"

{
  "toolName": "split-bill-calculator",
  "inputs": [
    {
      "id": "totalBill",
      "label": "Total Bill",
      "type": "number",
      "unit": "$",
      "default": 100,
      "businessContext": "The total bill amount before tax and tip.",
      "label_i18n": {
        "en": "Total Bill",
        "tr": "Toplam Fatura",
        "de": "Total Bill",
        "fr": "Total Bill",
        "es": "Total Bill",
        "ar": "Total Bill"
      },
      "businessContext_i18n": {
        "en": "The total bill amount before tax and tip.",
        "tr": "Vergi ve bahşiş öncesi toplam fatura tutarı."
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of individuals sharing the bill.",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Kişi Sayısı",
        "de": "Anzahl der Personen",
        "fr": "Number of People",
        "es": "Number of People",
        "ar": "Number of People"
      },
      "businessContext_i18n": {
        "en": "Number of individuals sharing the bill.",
        "tr": "Faturayı paylaşan kişi sayısı."
      }
    },
    {
      "id": "taxPercent",
      "label": "Tax Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Tax rate applied to the bill.",
      "label_i18n": {
        "en": "Tax Percentage",
        "tr": "Vergi Yüzdesi",
        "de": "Steuerprozentsatz",
        "fr": "Tax Percentage",
        "es": "Tax Percentage",
        "ar": "Tax Percentage"
      },
      "businessContext_i18n": {
        "en": "Tax rate applied to the bill.",
        "tr": "Faturaya uygulanan vergi oranı."
      }
    },
    {
      "id": "tipPercent",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tip percentage on the bill.",
      "label_i18n": {
        "en": "Tip Percentage",
        "tr": "Bahşiş Yüzdesi",
        "de": "Trinkgeldprozentsatz",
        "fr": "Tip Percentage",
        "es": "Tip Percentage",
        "ar": "Tip Percentage"
      },
      "businessContext_i18n": {
        "en": "Tip percentage on the bill.",
        "tr": "Faturaya eklenecek bahşiş yüzdesi."
      }
    }
  ],
  "formulas": {
    "totalWithTax": "totalBill * (1 + taxPercent / 100)",
    "totalWithTip": "totalWithTax * (1 + tipPercent / 100)",
    "perPerson": "totalWithTip / numberOfPeople"
  },
  "outputs": {
    "primary": "perPerson",
    "breakdown": [
      "totalWithTax",
      "totalWithTip"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "perPerson",
    "unit": "$"
  },

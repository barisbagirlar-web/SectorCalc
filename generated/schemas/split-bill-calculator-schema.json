{
  "toolName": "split-bill-calculator",
  "inputs": [
    {
      "id": "totalBill",
      "label": "Total Bill",
      "type": "number",
      "unit": "$",
      "default": 100,
      "businessContext": "The total bill amount before tax and tip.",
      "label_i18n": {
        "en": "Total Bill",
        "tr": "Total Bill",
        "de": "Total Bill",
        "fr": "Total Bill",
        "es": "Total Bill",
        "ar": "Total Bill"
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of individuals sharing the bill.",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Number of People",
        "de": "Number of People",
        "fr": "Number of People",
        "es": "Number of People",
        "ar": "Number of People"
      }
    },
    {
      "id": "taxPercent",
      "label": "Tax Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Tax rate applied to the bill.",
      "label_i18n": {
        "en": "Tax Percentage",
        "tr": "Tax Percentage",
        "de": "Tax Percentage",
        "fr": "Tax Percentage",
        "es": "Tax Percentage",
        "ar": "Tax Percentage"
      }
    },
    {
      "id": "tipPercent",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tip percentage on the bill.",
      "label_i18n": {
        "en": "Tip Percentage",
        "tr": "Tip Percentage",
        "de": "Tip Percentage",
        "fr": "Tip Percentage",
        "es": "Tip Percentage",
        "ar": "Tip Percentage"
      }
    }
  ],
  "formulas": {
    "totalWithTax": "totalBill * (1 + taxPercent / 100)",
    "totalWithTip": "totalWithTax * (1 + tipPercent / 100)",
    "perPerson": "totalWithTip / numberOfPeople"
  },
  "outputs": {
    "primary": "perPerson",
    "breakdown": [
      "totalWithTax",
      "totalWithTip"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "perPerson"
  },

  "formulas": {
    "volumePerPiece": "length * width * thickness / 1e9",
    "totalVolume": "volumePerPiece * quantity",
    "totalVolumeWithWaste": "totalVolume * (1 + wastePercent / 100)",
    "totalWeight": "totalVolumeWithWaste * density",
    "totalCost": "totalVolumeWithWaste * costPerM3"
  },
  "outputs": {
    "primary": "totalCost",

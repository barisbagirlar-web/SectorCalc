{
  "toolName": "ear-calculator",
  "inputs": [
    {
      "id": "nominalRate",
      "label": "Nominal Annual Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "The stated annual interest rate before compounding.",
      "label_i18n": {
        "en": "Nominal Annual Rate",
        "tr": "Nominal Annual Rate",
        "de": "Nominal Annual Rate",
        "fr": "Nominal Annual Rate",
        "es": "Nominal Annual Rate",
        "ar": "Nominal Annual Rate"
      }
    },
    {
      "id": "compoundingPeriods",
      "label": "Compounding Periods per Year",
      "type": "number",
      "unit": "per year",
      "default": 12,
      "businessContext": "Number of times interest is compounded annually.",
      "label_i18n": {
        "en": "Compounding Periods per Year",
        "tr": "Compounding Periods per Year",
        "de": "Compounding Periods per Year",
        "fr": "Compounding Periods per Year",
        "es": "Compounding Periods per Year",
        "ar": "Compounding Periods per Year"
      }
    },
    {
      "id": "years",
      "label": "Time Period",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "Investment duration in years for growth factor computation.",
      "label_i18n": {
        "en": "Time Period",
        "tr": "Time Period",
        "de": "Time Period",
        "fr": "Time Period",
        "es": "Time Period",
        "ar": "Time Period"
      }
    },
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "currency",
      "default": 1,
      "businessContext": "Initial investment amount (use 1 for factor-only calculations).",
      "label_i18n": {
        "en": "Principal Amount",
        "tr": "Principal Amount",
        "de": "Principal Amount",
        "fr": "Principal Amount",
        "es": "Principal Amount",
        "ar": "Principal Amount"
      }
    }
  ],
  "formulas": {
    "periodicRate": "nominalRate / 100 / compoundingPeriods",
    "effectiveAnnualRate": "((1 + periodicRate) ** compoundingPeriods - 1) * 100",
    "growthFactor": "((1 + periodicRate) ** (compoundingPeriods * years))",
    "futureValue": "principal * growthFactor"
  },
  "outputs": {
    "primary": "effectiveAnnualRate",
    "breakdown": [
      "periodicRate",
      "growthFactor",
      "futureValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

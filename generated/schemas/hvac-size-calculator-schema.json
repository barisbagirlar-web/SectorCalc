  "formulas": {
    "sensible_heat_gain_kw": "(room_area * ceiling_height * (outdoor_temperature - indoor_temperature) * insulation_factor * 0.1 + window_area * (outdoor_temperature - indoor_temperature) * 5 + number_of_occupants * 75 + room_area * 10) / 1000",
    "latent_heat_gain_kw": "(number_of_occupants * 75) / 1000",
    "required_cooling_capacity_kw": "(room_area * ceiling_height * (outdoor_temperature - indoor_temperature) * insulation_factor * 0.1 + window_area * (outdoor_temperature - indoor_temperature) * 5 + number_of_occupants * 150 + room_area * 10) / 1000"
  },

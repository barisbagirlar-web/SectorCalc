  "formulas": {
    "z_statistic": "(successes / sample_size - hypothesized_proportion) / Math.sqrt(hypothesized_proportion * (1 - hypothesized_proportion) / sample_size)",
    "p_value": "2 * (1 - (1 / (1 + Math.exp(-1.59791 * Math.abs(z_statistic)))))",
    "reject": "p_value < significance_level"
  },
  "outputs": {
    "primary": "p_value",
    "breakdown": [
      "z_statistic",
      "reject"
    ]
  },

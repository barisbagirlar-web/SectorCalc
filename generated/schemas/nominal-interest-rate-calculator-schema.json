{
  "toolName": "nominal-interest-rate-calculator",
  "inputs": [
    {
      "id": "realRate",
      "label": "Real Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The real interest rate adjusted for inflation.",
      "label_i18n": {
        "en": "Real Interest Rate",
        "tr": "Reel Faiz Oranı",
        "de": "Realzinssatz",
        "fr": "Taux d'intérêt réel",
        "es": "Tasa de interés real",
        "ar": "Real Interest Rate"
      },
      "businessContext_i18n": {
        "en": "The real interest rate adjusted for inflation.",
        "tr": "Enflasyona göre düzeltilmiş reel faiz oranı.",
        "de": "Der um die Inflation bereinigte Realzinssatz.",
        "fr": "Le taux d'intérêt réel ajusté de l'inflation.",
        "es": "La tasa de interés real ajustada por inflación."
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "The expected inflation rate.",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Enflasyon Oranı",
        "de": "Inflationsrate",
        "fr": "Taux d'inflation",
        "es": "Tasa de inflación",
        "ar": "Inflation Rate"
      },
      "businessContext_i18n": {
        "en": "The expected inflation rate.",
        "tr": "Beklenen enflasyon oranı.",
        "de": "Die erwartete Inflationsrate.",
        "fr": "Le taux d'inflation attendu.",
        "es": "La tasa de inflación esperada."
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate on Interest Income",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "The tax rate applied to interest income.",
      "label_i18n": {
        "en": "Tax Rate on Interest Income",
        "tr": "Faiz Geliri Vergi Oranı",
        "de": "Steuersatz auf Zinserträge",
        "fr": "Taux d'imposition sur les revenus d'intérêts",
        "es": "Tasa impositiva sobre ingresos por intereses",
        "ar": "Tax Rate on Interest Income"
      },
      "businessContext_i18n": {
        "en": "The tax rate applied to interest income.",
        "tr": "Faiz gelirine uygulanan vergi oranı.",
        "de": "Der auf Zinserträge angewandte Steuersatz.",
        "fr": "Le taux d'imposition appliqué aux revenus d'intérêts.",
        "es": "La tasa impositiva aplicada a los ingresos por intereses."
      }
    },
    {
      "id": "feePercentage",
      "label": "Annual Fee Percentage",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "Annual fee as a percentage of the principal.",
      "label_i18n": {
        "en": "Annual Fee Percentage",
        "tr": "Yıllık Ücret Yüzdesi",
        "de": "Jährlicher Gebührenprozentsatz",
        "fr": "Pourcentage de frais annuels",
        "es": "Porcentaje de comisión anual",
        "ar": "Annual Fee Percentage"
      },
      "businessContext_i18n": {
        "en": "Annual fee as a percentage of the principal.",
        "tr": "Anaparanın yüzdesi olarak yıllık ücret.",
        "de": "Jährliche Gebühr als Prozentsatz des Kapitals.",
        "fr": "Frais annuels en pourcentage du principal.",
        "es": "Comisión anual como porcentaje del principal."
      }
    }
  ],
  "formulas": {
    "realDecimal": "realRate / 100",
    "inflDecimal": "inflationRate / 100",
    "taxDecimal": "taxRate / 100",
    "feeDecimal": "feePercentage / 100",
    "nominalDecimal": "(1 + realDecimal) * (1 + inflDecimal) - 1",
    "nominalRatePercent": "nominalDecimal * 100",
    "afterTaxDecimal": "nominalDecimal * (1 - taxDecimal)",
    "afterTaxRatePercent": "afterTaxDecimal * 100",
    "afterFeesDecimal": "afterTaxDecimal - feeDecimal",
    "afterFeesRatePercent": "afterFeesDecimal * 100"
  },
  "outputs": {
    "primary": "afterFeesRatePercent",
    "breakdown": [
      "Real Rate (decimal)",
      "Inflation Rate (decimal)",
      "Nominal Rate (decimal)",
      "After-Tax Nominal Rate (%)",
      "After-Fees Nominal Rate (%)"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "afterFeesRatePercent",
    "unit": "%"
  },
  "category": "Finans & Yatırım",

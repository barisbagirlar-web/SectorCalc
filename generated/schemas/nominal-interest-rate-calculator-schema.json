{
  "toolName": "nominal-interest-rate-calculator",
  "inputs": [
    {
      "id": "realRate",
      "label": "Real Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The real interest rate adjusted for inflation.",
      "label_i18n": {
        "en": "Real Interest Rate",
        "tr": "Real Interest Rate",
        "de": "Real Interest Rate",
        "fr": "Real Interest Rate",
        "es": "Real Interest Rate",
        "ar": "Real Interest Rate"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "The expected inflation rate.",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Inflation Rate",
        "de": "Inflation Rate",
        "fr": "Inflation Rate",
        "es": "Inflation Rate",
        "ar": "Inflation Rate"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate on Interest Income",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "The tax rate applied to interest income.",
      "label_i18n": {
        "en": "Tax Rate on Interest Income",
        "tr": "Tax Rate on Interest Income",
        "de": "Tax Rate on Interest Income",
        "fr": "Tax Rate on Interest Income",
        "es": "Tax Rate on Interest Income",
        "ar": "Tax Rate on Interest Income"
      }
    },
    {
      "id": "feePercentage",
      "label": "Annual Fee Percentage",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "Annual fee as a percentage of the principal.",
      "label_i18n": {
        "en": "Annual Fee Percentage",
        "tr": "Annual Fee Percentage",
        "de": "Annual Fee Percentage",
        "fr": "Annual Fee Percentage",
        "es": "Annual Fee Percentage",
        "ar": "Annual Fee Percentage"
      }
    }
  ],
  "formulas": {
    "realDecimal": "realRate / 100",
    "inflDecimal": "inflationRate / 100",
    "taxDecimal": "taxRate / 100",
    "feeDecimal": "feePercentage / 100",
    "nominalDecimal": "(1 + realDecimal) * (1 + inflDecimal) - 1",
    "nominalRatePercent": "nominalDecimal * 100",
    "afterTaxDecimal": "nominalDecimal * (1 - taxDecimal)",
    "afterTaxRatePercent": "afterTaxDecimal * 100",
    "afterFeesDecimal": "afterTaxDecimal - feeDecimal",
    "afterFeesRatePercent": "afterFeesDecimal * 100"
  },
  "outputs": {
    "primary": "afterFeesRatePercent",
    "breakdown": [
      "Real Rate (decimal)",
      "Inflation Rate (decimal)",
      "Nominal Rate (decimal)",
      "After-Tax Nominal Rate (%)",
      "After-Fees Nominal Rate (%)"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "afterFeesRatePercent"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

{
  "toolName": "electric-field-calculator",
  "inputs": [
    {
      "id": "Q1",
      "label": "Charge 1",
      "type": "number",
      "unit": "C",
      "default": 0.000001,
      "businessContext": "Charge of first point charge (Q1)"
    },
    {
      "id": "r1",
      "label": "Distance 1",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Distance from first charge (r1)"
    },
    {
      "id": "Q2",
      "label": "Charge 2",
      "type": "number",
      "unit": "C",
      "default": -0.000001,
      "businessContext": "Charge of second point charge (Q2)"
    },
    {
      "id": "r2",
      "label": "Distance 2",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Distance from second charge (r2)"
    },
    {
      "id": "theta",
      "label": "Angle",
      "type": "number",
      "unit": "°",
      "default": 90,
      "businessContext": "Angle between the individual electric field vectors at the point (theta)"
    },
    {
      "id": "epsilon_r",
      "label": "Relative Permittivity",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Relative permittivity of the medium (εr), dimensionless"
    }
  ],
  "formulas": {
    "k": "1/(4*Math.PI*8.854e-12*epsilon_r)",
    "E1": "k*Math.abs(Q1)/(r1**2)",
    "E2": "k*Math.abs(Q2)/(r2**2)",
    "thetaRad": "theta*Math.PI/180",
    "E_resultant": "Math.sqrt(E1**2 + E2**2 + 2*E1*E2*Math.cos(thetaRad))"
  },
  "outputs": {
    "primary": "E_resultant",
    "breakdown": [
      "E1",
      "E2"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

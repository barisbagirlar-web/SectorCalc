{
  "toolName": "decompression-calculator",
  "inputs": [
    {
      "id": "initialPressure",
      "label": "Initial Pressure",
      "type": "number",
      "unit": "bar",
      "default": 200,
      "businessContext": "Vessel pressure before decompression",
      "label_i18n": {
        "en": "Initial Pressure",
        "tr": "Başlangıç Basıncı",
        "de": "Anfangsdruck",
        "fr": "Pression initiale",
        "es": "Presión inicial",
        "ar": "Initial Pressure"
      },
      "businessContext_i18n": {
        "en": "Vessel pressure before decompression",
        "tr": "Dekompresyon öncesi kap basıncı",
        "de": "Behälterdruck vor der Dekompression",
        "fr": "Pression du récipient avant décompression",
        "es": "Presión del recipiente antes de la descompresión"
      }
    },
    {
      "id": "finalPressure",
      "label": "Final Pressure",
      "type": "number",
      "unit": "bar",
      "default": 1,
      "businessContext": "Target pressure after decompression",
      "label_i18n": {
        "en": "Final Pressure",
        "tr": "Nihai Basınç",
        "de": "Enddruck",
        "fr": "Pression finale",
        "es": "Presión final",
        "ar": "Final Pressure"
      },
      "businessContext_i18n": {
        "en": "Target pressure after decompression",
        "tr": "Dekompresyon sonrası hedef basınç",
        "de": "Zieldruck nach der Dekompression",
        "fr": "Pression cible après décompression",
        "es": "Presión objetivo después de la descompresión"
      }
    },
    {
      "id": "volume",
      "label": "Vessel Volume",
      "type": "number",
      "unit": "L",
      "default": 1000,
      "businessContext": "Internal volume of the pressure vessel",
      "label_i18n": {
        "en": "Vessel Volume",
        "tr": "Kap Hacmi",
        "de": "Behältervolumen",
        "fr": "Volume du récipient",
        "es": "Volumen del recipiente",
        "ar": "Vessel Volume"
      },
      "businessContext_i18n": {
        "en": "Internal volume of the pressure vessel",
        "tr": "Basınçlı kabın iç hacmi",
        "de": "Innenvolumen des Druckbehälters",
        "fr": "Volume interne du récipient sous pression",
        "es": "Volumen interno del recipiente a presión"
      }
    },
    {
      "id": "flowRate",
      "label": "Flow Rate (Std)",
      "type": "number",
      "unit": "SLPM",
      "default": 50,
      "businessContext": "Standard flow rate (1 atm, 20°C) of gas release",
      "label_i18n": {
        "en": "Flow Rate (Std)",
        "tr": "Debi (Std)",
        "de": "Durchflussrate (Norm)",
        "fr": "Débit (standard)",
        "es": "Caudal (estándar)",
        "ar": "Flow Rate (Std)"
      },
      "businessContext_i18n": {
        "en": "Standard flow rate (1 atm, 20°C) of gas release",
        "tr": "Standart debi (1 atm, 20°C) gaz çıkışı",
        "de": "Normdurchflussrate (1 atm, 20°C) der Gasfreisetzung",
        "fr": "Débit standard (1 atm, 20°C) du gaz libéré",
        "es": "Caudal estándar (1 atm, 20°C) de liberación de gas"
      }
    },
    {
      "id": "temperature",
      "label": "Gas Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Operating temperature of the gas, used for correction",
      "label_i18n": {
        "en": "Gas Temperature",
        "tr": "Gaz Sıcaklığı",
        "de": "Gastemperatur",
        "fr": "Température du gaz",
        "es": "Temperatura del gas",
        "ar": "Gas Temperature"
      },
      "businessContext_i18n": {
        "en": "Operating temperature of the gas, used for correction",
        "tr": "Gazın çalışma sıcaklığı, düzeltme için kullanılır",
        "de": "Betriebstemperatur des Gases, für Korrektur verwendet",
        "fr": "Température de fonctionnement du gaz, utilisée pour la correction",
        "es": "Temperatura de operación del gas, utilizada para corrección"
      }
    }
  ],
  "formulas": {
    "pressureDifference": "initialPressure - finalPressure",
    "timeUncorrected": "(pressureDifference * volume) / flowRate",
    "temperatureKelvin": "temperature + 273.15",
    "decompressionTime": "timeUncorrected * (temperatureKelvin / 293.15)"
  },
  "outputs": {
    "primary": "decompressionTime",
    "breakdown": [
      "pressureDifference",
      "timeUncorrected",
      "decompressionTime"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "decompressionTime",
    "unit": "bar"
  },

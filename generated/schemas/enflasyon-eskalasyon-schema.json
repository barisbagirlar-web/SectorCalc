  "formulas": {
    "Esc_Mat": "(1 + Infl_Mat)^Years",
    "Esc_Lab": "(1 + Infl_Lab)^Years",
    "BaseAdj": "BaseMat * Esc_Mat + BaseLab * Esc_Lab",
    "RealDisc": "((1 + Nominal) / (1 + Infl)) - 1",
    "NPV_Nom": "SUM(Cash * Esc / (1 + Nom)^t)",
    "NPV_Real": "SUM(Cash / (1 + Real)^t)",
    "Contingency": "BaseAdj * ConfFactor",
    "Total": "BaseAdj + Contingency"
  },

      }
    },
    {
      "id": "outerWidth",
      "label": "Outer Width",
      "type": "number",
      "unit": "m",
      "default": 1.5,
      "businessContext": "External width of the tank including wall thickness",
      "label_i18n": {
        "en": "Outer Width",
        "tr": "Outer Width",
        "de": "Outer Width",
        "fr": "Outer Width",

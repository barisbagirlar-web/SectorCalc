      }
    },
    {
      "id": "outerHeight",
      "label": "Outer Height",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "External height of the tank including top and bottom",
      "label_i18n": {
        "en": "Outer Height",
        "tr": "Outer Height",
        "de": "Outer Height",
        "fr": "Outer Height",
        "es": "Outer Height",
        "ar": "Outer Height"
      }
    },
    {
      "id": "wallThickness",
      "label": "Wall Thickness",
      "type": "number",
      "unit": "m",
      "default": 0.05,
      "businessContext": "Uniform thickness of walls, roof, and floor",
      "label_i18n": {
        "en": "Wall Thickness",
        "tr": "Wall Thickness",
        "de": "Wall Thickness",
        "fr": "Wall Thickness",
        "es": "Wall Thickness",
        "ar": "Wall Thickness"
      }
    },
    {
      "id": "fillLevel",
      "label": "Fill Level",
      "type": "number",
      "unit": "m",
      "default": 0.8,
      "businessContext": "Liquid height measured from inside bottom, must not exceed inner height",
      "label_i18n": {
        "en": "Fill Level",
        "tr": "Fill Level",
        "de": "Fill Level",
        "fr": "Fill Level",
        "es": "Fill Level",
        "ar": "Fill Level"
      }
    }
  ],
  "formulas": {
    "outerVolume": "outerLength * outerWidth * outerHeight",
    "innerVolume": "(outerLength - 2*wallThickness) * (outerWidth - 2*wallThickness) * (outerHeight - 2*wallThickness)",
    "materialVolume": "outerVolume - innerVolume"
  },
  "outputs": {
    "primary": "materialVolume",
    "breakdown": [
      "outerVolume",
      "innerVolume",
      "materialVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

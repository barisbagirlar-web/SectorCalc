{
  "toolName": "car-affordability-calculator",
  "inputs": [
    {
      "id": "monthlyNetIncome",
      "label": "Monthly Net Income",
      "type": "number",
      "unit": "USD",
      "default": 5000,
      "businessContext": "Your monthly take-home pay after taxes and deductions.",
      "label_i18n": {
        "en": "Monthly Net Income",
        "tr": "Monthly Net Income",
        "de": "Monthly Net Income",
        "fr": "Monthly Net Income",
        "es": "Monthly Net Income",
        "ar": "Monthly Net Income"
      }
    },
    {
      "id": "monthlyExpenses",
      "label": "Monthly Expenses (excl. car)",
      "type": "number",
      "unit": "USD",
      "default": 3000,
      "businessContext": "Total monthly living expenses excluding any car-related costs.",
      "label_i18n": {
        "en": "Monthly Expenses (excl. car)",
        "tr": "Monthly Expenses (excl. car)",
        "de": "Monthly Expenses (excl. car)",
        "fr": "Monthly Expenses (excl. car)",
        "es": "Monthly Expenses (excl. car)",
        "ar": "Monthly Expenses (excl. car)"
      }
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "number",
      "unit": "USD",
      "default": 5000,
      "businessContext": "Cash available for down payment on the car.",
      "label_i18n": {
        "en": "Down Payment",
        "tr": "Down Payment",
        "de": "Down Payment",
        "fr": "Down Payment",
        "es": "Down Payment",
        "ar": "Down Payment"
      }
    },
    {
      "id": "loanTermMonths",
      "label": "Loan Term (Months)",
      "type": "number",
      "unit": "months",
      "default": 60,
      "businessContext": "Desired loan term in months (e.g., 36, 48, 60).",
      "label_i18n": {
        "en": "Loan Term (Months)",
        "tr": "Loan Term (Months)",
        "de": "Loan Term (Months)",
        "fr": "Loan Term (Months)",
        "es": "Loan Term (Months)",
        "ar": "Loan Term (Months)"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected annual interest rate for the auto loan.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "otherCarCosts",
      "label": "Monthly Other Car Costs",
      "type": "number",
      "unit": "USD",
      "default": 200,
      "businessContext": "Estimated monthly costs for insurance, maintenance, fuel, etc.",
      "label_i18n": {
        "en": "Monthly Other Car Costs",
        "tr": "Monthly Other Car Costs",
        "de": "Monthly Other Car Costs",
        "fr": "Monthly Other Car Costs",
        "es": "Monthly Other Car Costs",
        "ar": "Monthly Other Car Costs"
      }
    },
    {
      "id": "maxPaymentPercent",
      "label": "Max Car Payment % of Disposable Income",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Maximum percentage of your disposable income (after expenses) you are willing to allocate to total car costs (loan payment + other costs).",
      "label_i18n": {
        "en": "Max Car Payment % of Disposable Income",
        "tr": "Max Car Payment % of Disposable Income",
        "de": "Max Car Payment % of Disposable Income",
        "fr": "Max Car Payment % of Disposable Income",
        "es": "Max Car Payment % of Disposable Income",
        "ar": "Max Car Payment % of Disposable Income"
      }
    }
  ],
  "formulas": {
    "disposableIncome": "monthlyNetIncome - monthlyExpenses",
    "maxTotalCarBudget": "disposableIncome * (maxPaymentPercent / 100)",
    "maxLoanPayment": "maxTotalCarBudget - otherCarCosts",
    "monthlyInterestRate": "annualInterestRate / 12 / 100"
  },
  "outputs": {
    "primary": "monthlyInterestRate",
    "breakdown": [
      "disposableIncome",
      "maxTotalCarBudget",
      "maxLoanPayment",
      "monthlyInterestRate",
      "maxLoan"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "maxCarPrice"
  },
  "category": "Otomotiv",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "maintenance-reliability",

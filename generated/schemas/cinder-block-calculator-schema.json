    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of extra blocks to account for cutting and breakage.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "netWallArea": "wallLength * wallHeight",
    "effectiveBlockLength": "blockLength + (mortarJointThickness / 1000)",
    "effectiveBlockHeight": "blockHeight + (mortarJointThickness / 1000)",
    "blockFaceArea": "effectiveBlockLength * effectiveBlockHeight",
    "netBlocksExact": "netWallArea / blockFaceArea",
    "totalBlocksExact": "netBlocksExact * (1 + wasteFactor / 100)",
    "wasteBlocksExact": "totalBlocksExact - netBlocksExact"
  },
  "outputs": {
    "primary": "totalBlocksExact",
    "breakdown": [
      "netBlocksExact",
      "wasteBlocksExact"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

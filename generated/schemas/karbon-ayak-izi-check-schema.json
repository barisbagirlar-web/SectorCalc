  "formulas": {
    "Scope1": "SUM(FuelConsumption_i * EmissionFactor_i) + FugitiveEmissions",
    "Scope2_Location": "ElectricityConsumption * GridEmissionFactor",
    "Scope2_Market": "ElectricityConsumption * (GridFactor - REC_Factor)",
    "Scope3_Upstream": "SUM(Material_i * MaterialEF_i) + Logistics_Emissions",
    "TotalCarbon": "Scope1 + Scope2_Market + Scope3_Upstream",
    "CarbonIntensity": "TotalCarbon / ProductionVolume",
    "FinancialRisk": "TotalCarbon * ForecastedCarbonPrice"
  },

    {
      "id": "lrdi_total",
      "label": "LRDI Total Candidates",
      "type": "number",
      "unit": "count",
      "default": 200000,
      "businessContext": "Total candidates for LRDI",
      "label_i18n": {
        "en": "LRDI Total Candidates",
        "tr": "LRDI Toplam Aday",
        "de": "LRDI-Gesamtkandidaten",
        "fr": "Total des candidats LRDI",

    },
    {
      "id": "lrdi_total",
      "label": "LRDI Total Candidates",
      "type": "number",
      "unit": "count",
      "default": 200000,
      "businessContext": "Total candidates for LRDI",
      "label_i18n": {
        "en": "LRDI Total Candidates",
        "tr": "LRDI Toplam Aday",
        "de": "LRDI Total Candidates",
        "fr": "LRDI Total Candidates",
        "es": "LRDI Total Candidates",
        "ar": "LRDI Total Candidates"
      },
      "businessContext_i18n": {
        "en": "Total candidates for LRDI",
        "tr": "LRDI için toplam aday sayısı"
      }
    }
  ],
  "formulas": {
    "overall_percentile": "(1 - (overall_rank / total_candidates)) * 100",
    "qa_percentile": "(1 - (qa_rank / qa_total)) * 100",
    "varc_percentile": "(1 - (varc_rank / varc_total)) * 100",
    "lrdi_percentile": "(1 - (lrdi_rank / lrdi_total)) * 100"
  },
  "outputs": {
    "primary": "lrdi_percentile",
    "breakdown": [
      "QA Percentile: <%= qa_percentile.toFixed(2) %>%",
      "VARC Percentile: <%= varc_percentile.toFixed(2) %>%",
      "LRDI Percentile: <%= lrdi_percentile.toFixed(2) %>%"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "lrdi_percentile",
    "unit": "%",
    "breakdownUnits": {
      "QA Percentile: <%= qa_percentile.toFixed(2) %>%": "%",
      "VARC Percentile: <%= varc_percentile.toFixed(2) %>%": "%",
      "LRDI Percentile: <%= lrdi_percentile.toFixed(2) %>%": "%"
    }
  },

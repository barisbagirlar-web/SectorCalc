{
  "toolName": "highway-design-calculator",
  "inputs": [
    {
      "id": "designSpeed",
      "label": "Design Speed",
      "type": "number",
      "unit": "km/h",
      "default": 80,
      "businessContext": "The design speed of the highway segment, typically between 40-140 km/h.",
      "label_i18n": {
        "en": "Design Speed",
        "tr": "Design Speed",
        "de": "Design Speed",
        "fr": "Design Speed",
        "es": "Design Speed",
        "ar": "Design Speed"
      }
    },
    {
      "id": "superelevation",
      "label": "Maximum Superelevation Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "The maximum superelevation (cross-slope) rate applied to the curve, usually 4%-12%.",
      "label_i18n": {
        "en": "Maximum Superelevation Rate",
        "tr": "Maximum Superelevation Rate",
        "de": "Maximum Superelevation Rate",
        "fr": "Maximum Superelevation Rate",
        "es": "Maximum Superelevation Rate",
        "ar": "Maximum Superelevation Rate"
      }
    },
    {
      "id": "frictionFactor",
      "label": "Side Friction Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.14,
      "businessContext": "The allowable side friction factor depending on design speed and surface conditions (e.g., 0.17 for low speeds, 0.10 for high speeds).",
      "label_i18n": {
        "en": "Side Friction Factor",
        "tr": "Side Friction Factor",
        "de": "Side Friction Factor",
        "fr": "Side Friction Factor",
        "es": "Side Friction Factor",
        "ar": "Side Friction Factor"
      }
    },
    {
      "id": "desiredRadius",
      "label": "Desired Curve Radius",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "The actual or desired radius of the horizontal curve. Set to 0 if unknown; otherwise used to compute required friction demand.",
      "label_i18n": {
        "en": "Desired Curve Radius",
        "tr": "Desired Curve Radius",
        "de": "Desired Curve Radius",
        "fr": "Desired Curve Radius",
        "es": "Desired Curve Radius",
        "ar": "Desired Curve Radius"
      }
    }
  ],
  "formulas": {
    "minRadius": "designSpeed ** 2 / (127 * (superelevation / 100 + frictionFactor))",
    "frictionDemand": "desiredRadius > 0 ? (designSpeed ** 2 / (127 * desiredRadius) - superelevation / 100) : 0",
    "isRadiusAdequate": "desiredRadius > 0 && desiredRadius >= (designSpeed ** 2 / (127 * (superelevation / 100 + frictionFactor))) ? 1 : (desiredRadius > 0 ? 0 : 0)"
  },
  "outputs": {
    "primary": "minRadius",
    "breakdown": [
      "frictionDemand",
      "isRadiusAdequate"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

{
  "toolName": "abc-classification-calculator",
  "inputs": [
    {
      "id": "annualDemand",
      "label": "Annual Demand",
      "type": "number",
      "unit": "units",
      "default": 0,
      "businessContext": "The number of units consumed annually for this item.",
      "label_i18n": {
        "en": "Annual Demand",
        "tr": "Annual Demand",
        "de": "Annual Demand",
        "fr": "Annual Demand",
        "es": "Annual Demand",
        "ar": "Annual Demand"
      }
    },
    {
      "id": "unitCost",
      "label": "Unit Cost",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "The cost per unit of the item.",
      "label_i18n": {
        "en": "Unit Cost",
        "tr": "Unit Cost",
        "de": "Unit Cost",
        "fr": "Unit Cost",
        "es": "Unit Cost",
        "ar": "Unit Cost"
      }
    },
    {
      "id": "totalAnnualValue",
      "label": "Total Annual Usage Value of All Items",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Sum of annual usage values of all items in inventory.",
      "label_i18n": {
        "en": "Total Annual Usage Value of All Items",
        "tr": "Total Annual Usage Value of All Items",
        "de": "Total Annual Usage Value of All Items",
        "fr": "Total Annual Usage Value of All Items",
        "es": "Total Annual Usage Value of All Items",
        "ar": "Total Annual Usage Value of All Items"
      }
    },
    {
      "id": "cumulativeBefore",
      "label": "Cumulative Percentage Before This Item",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "The cumulative percentage of total annual usage value accounted for by items ranked before this one (should be 0 for first item).",
      "label_i18n": {
        "en": "Cumulative Percentage Before This Item",
        "tr": "Cumulative Percentage Before This Item",
        "de": "Cumulative Percentage Before This Item",
        "fr": "Cumulative Percentage Before This Item",
        "es": "Cumulative Percentage Before This Item",
        "ar": "Cumulative Percentage Before This Item"
      }
    }
  ],
  "formulas": {
    "annualValue": "annualDemand * unitCost",
    "percentage": "totalAnnualValue !== 0 ? (annualValue / totalAnnualValue) * 100 : 0",
    "cumulativeAfter": "cumulativeBefore + percentage"
  },
  "outputs": {
    "primary": "cumulativeAfter",
    "breakdown": [
      "annualValue",
      "percentage",
      "cumulativeAfter"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "classification",
    "unit": "currency",
    "breakdownUnits": {
      "percentage": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",

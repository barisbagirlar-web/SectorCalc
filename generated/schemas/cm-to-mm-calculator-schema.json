      }
    },
    {
      "id": "correction_factor",
      "label": "Correction Factor",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Systematic measurement correction factor (dimensionless).",
      "label_i18n": {
        "en": "Correction Factor",
        "tr": "Correction Factor",
        "de": "Correction Factor",
        "fr": "Correction Factor",
        "es": "Correction Factor",
        "ar": "Correction Factor"
      }
    },
    {
      "id": "temperature_c",
      "label": "Temperature (°C)",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Ambient temperature in degrees Celsius.",
      "label_i18n": {
        "en": "Temperature (°C)",
        "tr": "Temperature (°C)",
        "de": "Temperature (°C)",
        "fr": "Temperature (°C)",
        "es": "Temperature (°C)",
        "ar": "Temperature (°C)"
      }
    },
    {
      "id": "expansion_coefficient",
      "label": "Expansion Coefficient",
      "type": "number",
      "unit": "1/°C",
      "default": 0.000012,
      "businessContext": "Linear thermal expansion coefficient of material in per degree Celsius.",
      "label_i18n": {
        "en": "Expansion Coefficient",
        "tr": "Expansion Coefficient",
        "de": "Expansion Coefficient",
        "fr": "Expansion Coefficient",
        "es": "Expansion Coefficient",
        "ar": "Expansion Coefficient"
      }
    },
    {
      "id": "tolerance_cm",
      "label": "Tolerance (cm)",
      "type": "number",
      "unit": "cm",
      "default": 0.1,
      "businessContext": "Manufacturing tolerance limit in centimeters.",
      "label_i18n": {
        "en": "Tolerance (cm)",
        "tr": "Tolerance (cm)",
        "de": "Tolerance (cm)",
        "fr": "Tolerance (cm)",
        "es": "Tolerance (cm)",
        "ar": "Tolerance (cm)"
      }
    },
    {
      "id": "batch_quantity",
      "label": "Batch Quantity",
      "type": "number",
      "unit": "pieces",
      "default": 1,
      "businessContext": "Number of identical pieces.",
      "label_i18n": {
        "en": "Batch Quantity",
        "tr": "Batch Quantity",
        "de": "Batch Quantity",
        "fr": "Batch Quantity",
        "es": "Batch Quantity",
        "ar": "Batch Quantity"
      }
    },
    {
      "id": "decimal_places",
      "label": "Decimal Places",
      "type": "number",
      "unit": "dp",
      "default": 2,
      "businessContext": "Number of decimal places for output formatting.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "thermal_effect": "1 + expansion_coefficient * (temperature_c - 20)",
    "corrected_length_cm": "length_cm * correction_factor * thermal_effect",
    "converted_mm": "corrected_length_cm * 10",
    "tolerance_mm": "tolerance_cm * 10",
    "total_batch_mm": "converted_mm * batch_quantity",
    "formatted_converted_mm": "Math.round(converted_mm * Math.pow(10, decimal_places)) / Math.pow(10, decimal_places)"
  },
  "outputs": {
    "primary": "formatted_converted_mm",
    "breakdown": [
      "tolerance_mm",
      "total_batch_mm"
    ]
  },

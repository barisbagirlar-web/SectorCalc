    {
      "id": "originX",
      "label": "Origin X-coordinate",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "X coordinate of the polar origin",
      "label_i18n": {
        "en": "Origin X-coordinate",
        "tr": "Origin X-coordinate",
        "de": "Origin X-coordinate",
        "fr": "Origin X-coordinate",
        "es": "Origin X-coordinate",
        "ar": "Origin X-coordinate"
      }
    },
    {
      "id": "originY",
      "label": "Origin Y-coordinate",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Y coordinate of the polar origin",
      "label_i18n": {
        "en": "Origin Y-coordinate",
        "tr": "Origin Y-coordinate",
        "de": "Origin Y-coordinate",
        "fr": "Origin Y-coordinate",
        "es": "Origin Y-coordinate",
        "ar": "Origin Y-coordinate"
      }
    }
  ],
  "formulas": {
    "r": "Math.sqrt(Math.pow(pointX - originX, 2) + Math.pow(pointY - originY, 2))",
    "theta_rad": "Math.atan2(pointY - originY, pointX - originX)",
    "theta_deg": "(Math.atan2(pointY - originY, pointX - originX) * 180) / Math.PI"
  },
  "outputs": {
    "primary": "r",
    "breakdown": [
      "theta_rad",
      "theta_deg"
    ]
  },

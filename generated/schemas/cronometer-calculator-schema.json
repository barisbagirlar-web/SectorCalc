{
  "toolName": "cronometer-calculator",
  "inputs": [
    {
      "id": "observedTime",
      "label": "Gözlemlenen Süre (saniye)",
      "type": "number",
      "unit": "s",
      "default": 60,
      "businessContext": "Kronometre ile ölçülen çevrim süresi"
    },
    {
      "id": "cycles",
      "label": "Tekrar Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Ölçülen parça veya operasyon sayısı"
    },
    {
      "id": "ratingFactor",
      "label": "Tempo Takdiri (%)",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "İşçinin normal tempoya göre performans yüzdesi (100 = normal)"
    },
    {
      "id": "allowanceFactor",
      "label": "Pay (Avans) (%)",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Dinlenme, gecikme ve kişisel ihtiyaç payı"
    }
  ],
  "formulas": {
    "totalObservedTime": "observedTime * cycles",
    "normalTime": "observedTime * (ratingFactor / 100)",
    "standardTime": "observedTime * (ratingFactor / 100) * (1 + allowanceFactor / 100)"
  },
  "outputs": {
    "primary": "standardTime",
    "breakdown": [
      "totalObservedTime",
      "normalTime",
      "standardTime"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "categorySlug": "technology-ai-cloud-cyber",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning"
}

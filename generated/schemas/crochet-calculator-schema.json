  "formulas": {
    "totalWeight": "(projectWidth * projectHeight) * (swatchWeight / (swatchWidth * swatchHeight))",
    "totalMeters": "((projectWidth * projectHeight) * (swatchWeight / (swatchWidth * swatchHeight)) / skeinWeight) * skeinLength"
  },
  "outputs": {
    "primary": "totalMeters",

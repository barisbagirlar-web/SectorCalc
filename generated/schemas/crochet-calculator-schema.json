{
  "toolName": "crochet-calculator",
  "inputs": [
    {
      "id": "projectWidth",
      "label": "Project Width",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "businessContext": "Width of the finished crochet project in centimeters."
    },
    {
      "id": "projectHeight",
      "label": "Project Height",
      "type": "number",
      "unit": "cm",
      "default": 150,
      "businessContext": "Height of the finished crochet project in centimeters."
    },
    {
      "id": "swatchWidth",
      "label": "Swatch Width",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Width of the gauge swatch made with the same stitch and yarn as the project."
    },
    {
      "id": "swatchHeight",
      "label": "Swatch Height",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Height of the gauge swatch."
    },
    {
      "id": "swatchWeight",
      "label": "Swatch Weight",
      "type": "number",
      "unit": "g",
      "default": 10,
      "businessContext": "Weight of the dry gauge swatch in grams."
    },
    {
      "id": "skeinWeight",
      "label": "Skein Weight",
      "type": "number",
      "unit": "g",
      "default": 50,
      "businessContext": "Net weight of one full skein of yarn in grams."
    },
    {
      "id": "skeinLength",
      "label": "Skein Length",
      "type": "number",
      "unit": "m",
      "default": 100,
      "businessContext": "Length of yarn per skein in meters, for estimating total yarn length needed."
    },
    {
      "id": "yarnCostPerSkein",
      "label": "Cost per Skein",
      "type": "number",
      "unit": "$",
      "default": 5,
      "businessContext": "Purchase price per skein of yarn in currency unit."
    }
  ],
  "formulas": {
    "skeinsNeeded": "Math.ceil((projectWidth * projectHeight) * (swatchWeight / (swatchWidth * swatchHeight)) / skeinWeight)",
    "totalWeight": "(projectWidth * projectHeight) * (swatchWeight / (swatchWidth * swatchHeight))",
    "totalMeters": "((projectWidth * projectHeight) * (swatchWeight / (swatchWidth * swatchHeight)) / skeinWeight) * skeinLength",
    "totalCost": "Math.ceil((projectWidth * projectHeight) * (swatchWeight / (swatchWidth * swatchHeight)) / skeinWeight) * yarnCostPerSkein"
  },
  "outputs": {
    "primary": "skeinsNeeded",
    "breakdown": [
      "totalWeight",
      "totalMeters",
      "totalCost"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost"
}

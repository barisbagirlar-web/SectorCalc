{
  "toolName": "working-capital-turnover-calculator",
  "inputs": [
    {
      "id": "netSales",
      "label": "Net Annual Sales",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Total net sales revenue for the period",
      "label_i18n": {
        "en": "Net Annual Sales",
        "tr": "Net Annual Sales",
        "de": "Net Annual Sales",
        "fr": "Net Annual Sales",
        "es": "Net Annual Sales",
        "ar": "Net Annual Sales"
      }
    },
    {
      "id": "begCurrentAssets",
      "label": "Beginning Current Assets",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Current assets at the start of the period",
      "label_i18n": {
        "en": "Beginning Current Assets",
        "tr": "Beginning Current Assets",
        "de": "Beginning Current Assets",
        "fr": "Beginning Current Assets",
        "es": "Beginning Current Assets",
        "ar": "Beginning Current Assets"
      }
    },
    {
      "id": "endCurrentAssets",
      "label": "Ending Current Assets",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Current assets at the end of the period",
      "label_i18n": {
        "en": "Ending Current Assets",
        "tr": "Ending Current Assets",
        "de": "Ending Current Assets",
        "fr": "Ending Current Assets",
        "es": "Ending Current Assets",
        "ar": "Ending Current Assets"
      }
    },
    {
      "id": "begCurrentLiabilities",
      "label": "Beginning Current Liabilities",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Current liabilities at the start of the period",
      "label_i18n": {
        "en": "Beginning Current Liabilities",
        "tr": "Beginning Current Liabilities",
        "de": "Beginning Current Liabilities",
        "fr": "Beginning Current Liabilities",
        "es": "Beginning Current Liabilities",
        "ar": "Beginning Current Liabilities"
      }
    },
    {
      "id": "endCurrentLiabilities",
      "label": "Ending Current Liabilities",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Current liabilities at the end of the period",
      "label_i18n": {
        "en": "Ending Current Liabilities",
        "tr": "Ending Current Liabilities",
        "de": "Ending Current Liabilities",
        "fr": "Ending Current Liabilities",
        "es": "Ending Current Liabilities",
        "ar": "Ending Current Liabilities"
      }
    }
  ],
  "formulas": {
    "averageCurrentAssets": "(begCurrentAssets + endCurrentAssets) / 2",
    "averageCurrentLiabilities": "(begCurrentLiabilities + endCurrentLiabilities) / 2",
    "averageWorkingCapital": "averageCurrentAssets - averageCurrentLiabilities",
    "workingCapitalTurnover": "averageWorkingCapital !== 0 ? netSales / averageWorkingCapital : 0"
  },
  "outputs": {
    "primary": "workingCapitalTurnover",
    "breakdown": [
      "averageCurrentAssets",
      "averageCurrentLiabilities",
      "averageWorkingCapital"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "workingCapitalTurnover"
  },
  "category": "İK & Personel",
  "sector": "Perakende & Ticaret",

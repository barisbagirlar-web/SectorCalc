{
  "toolName": "buffet-calculator",
  "inputs": [
    {
      "id": "numberOfGuests",
      "label": "Guest Count",
      "type": "number",
      "unit": "persons",
      "default": 50,
      "businessContext": "The number of guests expected at the buffet.",
      "label_i18n": {
        "en": "Guest Count",
        "tr": "Guest Count",
        "de": "Guest Count",
        "fr": "Guest Count",
        "es": "Guest Count",
        "ar": "Guest Count"
      }
    },
    {
      "id": "pricePerGuest",
      "label": "Ticket Price",
      "type": "number",
      "unit": "EUR per guest",
      "default": 30,
      "businessContext": "The price each guest pays for the buffet.",
      "label_i18n": {
        "en": "Ticket Price",
        "tr": "Ticket Price",
        "de": "Ticket Price",
        "fr": "Ticket Price",
        "es": "Ticket Price",
        "ar": "Ticket Price"
      }
    },
    {
      "id": "foodCostPerGuest",
      "label": "Food Cost",
      "type": "number",
      "unit": "EUR per guest",
      "default": 10,
      "businessContext": "The average cost of food ingredients per guest.",
      "label_i18n": {
        "en": "Food Cost",
        "tr": "Food Cost",
        "de": "Food Cost",
        "fr": "Food Cost",
        "es": "Food Cost",
        "ar": "Food Cost"
      }
    },
    {
      "id": "laborCost",
      "label": "Labor Cost",
      "type": "number",
      "unit": "EUR",
      "default": 500,
      "businessContext": "Total labor cost for the event, including preparation and service.",
      "label_i18n": {
        "en": "Labor Cost",
        "tr": "Labor Cost",
        "de": "Labor Cost",
        "fr": "Labor Cost",
        "es": "Labor Cost",
        "ar": "Labor Cost"
      }
    },
    {
      "id": "overheadCost",
      "label": "Overhead Cost",
      "type": "number",
      "unit": "EUR",
      "default": 200,
      "businessContext": "Fixed overhead costs such as rent, utilities, equipment rental.",
      "label_i18n": {
        "en": "Overhead Cost",
        "tr": "Overhead Cost",
        "de": "Overhead Cost",
        "fr": "Overhead Cost",
        "es": "Overhead Cost",
        "ar": "Overhead Cost"
      }
    },
    {
      "id": "wastePercentage",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of food cost expected to be wasted (spoilage, leftovers).",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Waste Percentage",
        "de": "Waste Percentage",
        "fr": "Waste Percentage",
        "es": "Waste Percentage",
        "ar": "Waste Percentage"
      }
    }
  ],
  "formulas": {
    "totalRevenue": "numberOfGuests * pricePerGuest",
    "totalFoodCost": "numberOfGuests * foodCostPerGuest * (1 + wastePercentage / 100)",
    "totalCost": "totalFoodCost + laborCost + overheadCost",
    "profit": "totalRevenue - totalCost",
    "profitMargin": "(profit / totalRevenue) * 100"
  },
  "outputs": {
    "primary": "totalRevenue",
    "breakdown": [
      "totalRevenue",
      "totalCost",
      "profit"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitMargin"
  },

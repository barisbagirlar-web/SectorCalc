      "businessContext": "Üretim sürecinde beklenen fire yüzdesi",
      "label_i18n": {
        "en": "Fire Oranı",
        "tr": "Fire Oranı",
        "de": "Fire Oranı",
        "fr": "Fire Oranı",
        "es": "Fire Oranı",
        "ar": "Fire Oranı"
      }
    },
    {
      "id": "machineEfficiency",
      "label": "Makine Verimi",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Makinelerin ortalama verimliliği",
      "label_i18n": {
        "en": "Makine Verimi",
        "tr": "Makine Verimi",
        "de": "Makine Verimi",
        "fr": "Makine Verimi",
        "es": "Makine Verimi",
        "ar": "Makine Verimi"
      }
    },
    {
      "id": "materialCostPerKg",
      "label": "Hammadde Maliyeti",
      "type": "number",
      "unit": "TL/kg",
      "default": 12.5,
      "businessContext": "Kg başına hammadde maliyeti",
      "label_i18n": {
        "en": "Hammadde Maliyeti",
        "tr": "Hammadde Maliyeti",
        "de": "Hammadde Maliyeti",
        "fr": "Hammadde Maliyeti",
        "es": "Hammadde Maliyeti",
        "ar": "Hammadde Maliyeti"
      }
    }
  ],
  "formulas": {
    "totalMaterialWeight": "orderQuantity * unitWeight * (1 + scrapRate / 100)",
    "effectiveMaterialWeight": "totalMaterialWeight / (machineEfficiency / 100)",
    "totalCost": "effectiveMaterialWeight * materialCostPerKg"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalMaterialWeight",
      "effectiveMaterialWeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

      "type": "number",
      "unit": "TL/kg",
      "default": 12.5,
      "businessContext": "Kg başına hammadde maliyeti",
      "label_i18n": {
        "en": "Hammadde Maliyeti",
        "tr": "Raw Material Cost",
        "de": "Rohstoffkosten",

      "label_i18n": {
        "en": "Birim Ağırlık",
        "tr": "Birim Ağırlık",
        "de": "Birim Ağırlık",
        "fr": "Birim Ağırlık",
        "es": "Birim Ağırlık",
        "ar": "Birim Ağırlık"
      }
    },
    {

  "formulas": {
    "ToolLife_T": "C / (V_c^n * f^m * a_p^k)",
    "TaylorExponent_n": "-LOG(T1/T2) / LOG(V1/V2)",
    "CostPerPart_Tool": "(ToolCost / Edges) * (MachiningTime / ToolLife)",
    "OptimalToolLife_Cost": "((1/n - 1) * (ToolChangeTime + ToolCost/Edges / MachineRate))",
    "Optimal_Vc": "C / (OptimalToolLife_Cost^n)",
    "ProductionRate": "1 / (MachiningTime + (MachiningTime / ToolLife) * ToolChangeTime)"
  },

      "label_i18n": {
        "en": "Discharge Coefficient",
        "tr": "Discharge Coefficient",
        "de": "Discharge Coefficient",
        "fr": "Discharge Coefficient",
        "es": "Discharge Coefficient",
        "ar": "Discharge Coefficient"
      }
    },
    {
      "id": "H",
      "label": "Effective Head",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Difference between upstream water surface elevation and the center of the culvert outlet (for outlet control) or inlet (for inlet control). For submerged inlet control, H = HW - D/2.",
      "label_i18n": {
        "en": "Effective Head",
        "tr": "Effective Head",
        "de": "Effective Head",
        "fr": "Effective Head",
        "es": "Effective Head",
        "ar": "Effective Head"
      }
    },
    {
      "id": "g",

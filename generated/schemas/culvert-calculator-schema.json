{
  "toolName": "culvert-calculator",
  "inputs": [
    {
      "id": "D",
      "label": "Culvert Diameter",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "The internal diameter of the circular culvert.",
      "label_i18n": {
        "en": "Culvert Diameter",
        "tr": "Culvert Diameter",
        "de": "Culvert Diameter",
        "fr": "Culvert Diameter",

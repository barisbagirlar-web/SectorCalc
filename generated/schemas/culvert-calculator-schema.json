        "en": "Gravitational Acceleration",
        "tr": "Gravitational Acceleration",
        "de": "Gravitational Acceleration",
        "fr": "Gravitational Acceleration",
        "es": "Gravitational Acceleration",
        "ar": "Gravitational Acceleration"
      }
    },
    {
      "id": "n",
      "label": "Number of Barrels",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of identical culvert barrels in parallel.",
      "label_i18n": {
        "en": "Number of Barrels",
        "tr": "Number of Barrels",
        "de": "Number of Barrels",
        "fr": "Number of Barrels",
        "es": "Number of Barrels",
        "ar": "Number of Barrels"
      }
    }
  ],
  "formulas": {
    "area": "(Math.PI * D * D) / 4",

      }
    },
    {
      "id": "inputUnit",
      "label": "Input Unit (0: acres, 1: hectares)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Select input unit: 0 for acres, 1 for hectares.",
      "label_i18n": {
        "en": "Input Unit (0: acres, 1: hectares)",
        "tr": "Input Unit (0: acres, 1: hectares)",

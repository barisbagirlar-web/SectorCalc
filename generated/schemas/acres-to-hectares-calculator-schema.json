        "es": "Input Unit (0: acres, 1: hectares)",
        "ar": "Input Unit (0: acres, 1: hectares)"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the result.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (ha/ac)",
      "type": "number",
      "unit": "ha/ac",
      "default": 0.40468564224,
      "businessContext": "Conversion factor from acres to hectares (default: 1 ac = 0.40468564224 ha).",
      "label_i18n": {
        "en": "Conversion Factor (ha/ac)",
        "tr": "Conversion Factor (ha/ac)",
        "de": "Conversion Factor (ha/ac)",
        "fr": "Conversion Factor (ha/ac)",
        "es": "Conversion Factor (ha/ac)",
        "ar": "Conversion Factor (ha/ac)"
      }
    }
  ],
  "formulas": {
    "acres": "inputUnit === 0 ? inputValue : inputValue / conversionFactor",
    "hectares": "inputUnit === 0 ? inputValue * conversionFactor : inputValue",
    "roundedAcres": "Math.round(acres * (10 ** decimalPlaces)) / (10 ** decimalPlaces)",
    "roundedHectares": "Math.round(hectares * (10 ** decimalPlaces)) / (10 ** decimalPlaces)"
  },
  "outputs": {
    "primary": "roundedHectares",
    "breakdown": [
      "roundedAcres",
      "roundedHectares"
    ]
  },

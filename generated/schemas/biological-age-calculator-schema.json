{
  "toolName": "biological-age-calculator",
  "inputs": [
    {
      "id": "chronologicalAge",
      "label": "Chronological Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Current age in years"
    },
    {
      "id": "systolicBP",
      "label": "Systolic Blood Pressure",
      "type": "number",
      "unit": "mmHg",
      "default": 120,
      "businessContext": "Top number of blood pressure reading"
    },
    {
      "id": "bmi",
      "label": "Body Mass Index (BMI)",
      "type": "number",
      "unit": "kg/m²",
      "default": 24,
      "businessContext": "Weight in kg divided by height in meters squared"
    },
    {
      "id": "fastingGlucose",
      "label": "Fasting Glucose",
      "type": "number",
      "unit": "mg/dL",
      "default": 90,
      "businessContext": "Blood sugar level after fasting"
    },
    {
      "id": "totalCholesterol",
      "label": "Total Cholesterol",
      "type": "number",
      "unit": "mg/dL",
      "default": 180,
      "businessContext": "Total cholesterol level in blood"
    },
    {
      "id": "weeklyExercise",
      "label": "Weekly Exercise",
      "type": "number",
      "unit": "hours",
      "default": 3,
      "businessContext": "Average hours of exercise per week"
    },
    {
      "id": "smoking",
      "label": "Smoking (pack-years)",
      "type": "number",
      "unit": "pack-years",
      "default": 0,
      "businessContext": "Number of packs per day times years smoked"
    },
    {
      "id": "restingHeartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Heart beats per minute at rest"
    }
  ],
  "formulas": {
    "biologicalAge": "chronologicalAge + (systolicBP - 120) * 0.1 + (bmi - 25) * 0.2 + (fastingGlucose - 100) * 0.05 + (totalCholesterol - 200) * 0.02 - weeklyExercise * 0.5 + smoking * 0.5 + (restingHeartRate - 70) * 0.05",
    "bpYears": "(systolicBP - 120) * 0.1",
    "bmiYears": "(bmi - 25) * 0.2",
    "glucoseYears": "(fastingGlucose - 100) * 0.05",
    "cholesterolYears": "(totalCholesterol - 200) * 0.02",
    "exerciseYears": "- weeklyExercise * 0.5",
    "smokingYears": "smoking * 0.5",
    "hrYears": "(restingHeartRate - 70) * 0.05"
  },
  "outputs": {
    "primary": "biologicalAge",
    "breakdown": [
      "bpYears",
      "bmiYears",
      "glucoseYears",
      "cholesterolYears",
      "exerciseYears",
      "smokingYears",
      "hrYears"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

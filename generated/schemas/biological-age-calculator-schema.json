  "formulas": {
    "biologicalAge": "chronologicalAge + (systolicBP - 120) * 0.1 + (bmi - 25) * 0.2 + (fastingGlucose - 100) * 0.05 + (totalCholesterol - 200) * 0.02 - weeklyExercise * 0.5 + smoking * 0.5 + (restingHeartRate - 70) * 0.05",
    "bpYears": "(systolicBP - 120) * 0.1",
    "bmiYears": "(bmi - 25) * 0.2",
    "glucoseYears": "(fastingGlucose - 100) * 0.05",
    "cholesterolYears": "(totalCholesterol - 200) * 0.02",
    "exerciseYears": "- weeklyExercise * 0.5",
    "smokingYears": "smoking * 0.5",
    "hrYears": "(restingHeartRate - 70) * 0.05"
  },
  "outputs": {
    "primary": "biologicalAge",
    "breakdown": [
      "bpYears",
      "bmiYears",
      "glucoseYears",
      "cholesterolYears",
      "exerciseYears",
      "smokingYears",
      "hrYears"
    ],

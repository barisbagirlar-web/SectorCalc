{
  "toolName": "breast-milk-calculator",
  "inputs": [
    {
      "id": "babyWeight",
      "label": "Baby Weight",
      "type": "number",
      "unit": "kg",
      "default": 3.5,
      "businessContext": "Current weight of the infant",
      "label_i18n": {
        "en": "Baby Weight",
        "tr": "Baby Weight",
        "de": "Baby Weight",
        "fr": "Baby Weight",
        "es": "Baby Weight",
        "ar": "Baby Weight"
      }
    },
    {
      "id": "dailyMilkPerKg",
      "label": "Daily Milk per kg",
      "type": "number",
      "unit": "ml/kg",
      "default": 150,
      "businessContext": "Recommended daily milk intake per kg of body weight",
      "label_i18n": {
        "en": "Daily Milk per kg",
        "tr": "Daily Milk per kg",
        "de": "Daily Milk per kg",
        "fr": "Daily Milk per kg",
        "es": "Daily Milk per kg",
        "ar": "Daily Milk per kg"
      }
    },
    {
      "id": "feedingsPerDay",
      "label": "Feedings per Day",
      "type": "number",
      "unit": "times/day",
      "default": 8,
      "businessContext": "Average number of feeding sessions per day",
      "label_i18n": {
        "en": "Feedings per Day",
        "tr": "Feedings per Day",
        "de": "Feedings per Day",
        "fr": "Feedings per Day",
        "es": "Feedings per Day",
        "ar": "Feedings per Day"
      }
    },
    {
      "id": "milkPerSession",
      "label": "Milk per Session",
      "type": "number",
      "unit": "ml",
      "default": 90,
      "businessContext": "Amount of breast milk per feeding session",
      "label_i18n": {
        "en": "Milk per Session",
        "tr": "Milk per Session",
        "de": "Milk per Session",
        "fr": "Milk per Session",
        "es": "Milk per Session",
        "ar": "Milk per Session"
      }
    }
  ],
  "formulas": {
    "dailyNeeded": "babyWeight * dailyMilkPerKg",
    "dailySupplied": "milkPerSession * feedingsPerDay",
    "deficit": "dailySupplied - dailyNeeded",
    "perFeedingNeeded": "dailyNeeded / feedingsPerDay",
    "perFeedingSupplied": "milkPerSession"
  },
  "outputs": {
    "primary": "deficit",
    "breakdown": [
      "dailyNeeded",
      "dailySupplied",
      "perFeedingNeeded",
      "perFeedingSupplied"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "perFeedingSupplied",
    "unit": "kg"
  },

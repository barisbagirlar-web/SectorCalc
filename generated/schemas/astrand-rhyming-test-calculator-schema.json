    {
      "id": "workRate",
      "label": "Work Rate",
      "type": "number",
      "unit": "W",
      "default": 100,
      "businessContext": "Work rate in watts during steady-state cycling at 50 rpm",
      "label_i18n": {
        "en": "Work Rate",
        "tr": "Work Rate",
        "de": "Work Rate",
        "fr": "Work Rate",
        "es": "Work Rate",
        "ar": "Work Rate"
      }
    },
    {
      "id": "heartRate",
      "label": "Steady-State Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 140,
      "businessContext": "Average heart rate during the last minute of the 6-minute test (range 125–170 bpm)",
      "label_i18n": {
        "en": "Steady-State Heart Rate",
        "tr": "Steady-State Heart Rate",
        "de": "Steady-State Heart Rate",
        "fr": "Steady-State Heart Rate",
        "es": "Steady-State Heart Rate",
        "ar": "Steady-State Heart Rate"
      }
    }
  ],
  "formulas": {
    "workRateKgm": "workRate * 6.118",
    "genderFactor": "sex == 1 ? 1 : 0.85",
    "ageFactor": "age <= 25 ? 1 : Math.max(0.5, 1 - 0.008 * (age - 25))",
    "baseVO2": "(1.8 * workRateKgm) / (heartRate - 60)",
    "absoluteVO2": "baseVO2 * genderFactor * ageFactor",
    "relativeVO2": "absoluteVO2 * 1000 / weight"
  },
  "outputs": {
    "primary": "relativeVO2",
    "breakdown": [
      "absoluteVO2",
      "relativeVO2"
    ]
  },

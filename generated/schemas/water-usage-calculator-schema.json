{
  "toolName": "water-usage-calculator",
  "inputs": [
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "people",
      "default": 4,
      "businessContext": "Total number of individuals using water (family, employees, etc.)",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Number of People",
        "de": "Number of People",
        "fr": "Number of People",
        "es": "Number of People",
        "ar": "Number of People"
      }
    },
    {
      "id": "showerMinutesPerDay",
      "label": "Shower Minutes per Day per Person",
      "type": "number",
      "unit": "minutes",
      "default": 5,
      "businessContext": "Average shower duration per person per day in minutes",
      "label_i18n": {
        "en": "Shower Minutes per Day per Person",
        "tr": "Shower Minutes per Day per Person",
        "de": "Shower Minutes per Day per Person",
        "fr": "Shower Minutes per Day per Person",
        "es": "Shower Minutes per Day per Person",
        "ar": "Shower Minutes per Day per Person"
      }
    },
    {
      "id": "flowRateShower",
      "label": "Shower Flow Rate",
      "type": "number",
      "unit": "L/min",
      "default": 9,
      "businessContext": "Water flow rate of the shower head in liters per minute",
      "label_i18n": {
        "en": "Shower Flow Rate",
        "tr": "Shower Flow Rate",
        "de": "Shower Flow Rate",
        "fr": "Shower Flow Rate",
        "es": "Shower Flow Rate",
        "ar": "Shower Flow Rate"
      }
    },
    {
      "id": "toiletFlushesPerDay",
      "label": "Toilet Flushes per Day per Person",
      "type": "number",
      "unit": "flushes",
      "default": 5,
      "businessContext": "Average number of toilet flushes per person per day",
      "label_i18n": {
        "en": "Toilet Flushes per Day per Person",
        "tr": "Toilet Flushes per Day per Person",
        "de": "Toilet Flushes per Day per Person",
        "fr": "Toilet Flushes per Day per Person",
        "es": "Toilet Flushes per Day per Person",
        "ar": "Toilet Flushes per Day per Person"
      }
    },
    {
      "id": "flushVolume",
      "label": "Flush Volume",
      "type": "number",
      "unit": "L",
      "default": 6,
      "businessContext": "Water volume per toilet flush in liters (modern dual-flush ~6L)",
      "label_i18n": {
        "en": "Flush Volume",
        "tr": "Flush Volume",
        "de": "Flush Volume",
        "fr": "Flush Volume",
        "es": "Flush Volume",
        "ar": "Flush Volume"
      }
    },
    {
      "id": "washingMachineLoadsPerWeek",
      "label": "Washing Machine Loads per Week",
      "type": "number",
      "unit": "loads",
      "default": 5,
      "businessContext": "Number of washing machine cycles per week (total for all people)",
      "label_i18n": {
        "en": "Washing Machine Loads per Week",
        "tr": "Washing Machine Loads per Week",
        "de": "Washing Machine Loads per Week",
        "fr": "Washing Machine Loads per Week",
        "es": "Washing Machine Loads per Week",
        "ar": "Washing Machine Loads per Week"
      }
    },
    {
      "id": "waterPerLoad",
      "label": "Water per Load",
      "type": "number",
      "unit": "L",
      "default": 50,
      "businessContext": "Water consumption per washing machine cycle in liters",
      "label_i18n": {
        "en": "Water per Load",
        "tr": "Water per Load",
        "de": "Water per Load",
        "fr": "Water per Load",
        "es": "Water per Load",
        "ar": "Water per Load"
      }
    },
    {
      "id": "otherDailyUsage",
      "label": "Other Daily Usage per Person",
      "type": "number",
      "unit": "L",
      "default": 30,
      "businessContext": "Additional water usage per person per day (drinking, cooking, cleaning, etc.)",
      "label_i18n": {
        "en": "Other Daily Usage per Person",
        "tr": "Other Daily Usage per Person",
        "de": "Other Daily Usage per Person",
        "fr": "Other Daily Usage per Person",
        "es": "Other Daily Usage per Person",
        "ar": "Other Daily Usage per Person"
      }
    }
  ],
  "formulas": {
    "showerUsagePerPersonPerDay": "showerMinutesPerDay * flowRateShower",
    "toiletUsagePerPersonPerDay": "toiletFlushesPerDay * flushVolume",
    "laundryUsagePerPersonPerDay": "(washingMachineLoadsPerWeek * waterPerLoad) / 7",
    "totalUsagePerPersonPerDay": "showerUsagePerPersonPerDay + toiletUsagePerPersonPerDay + laundryUsagePerPersonPerDay + otherDailyUsage",
    "totalUsagePerDay": "totalUsagePerPersonPerDay * numberOfPeople",
    "totalUsagePerMonth": "totalUsagePerDay * 30",
    "totalUsagePerYear": "totalUsagePerDay * 365"
  },
  "outputs": {
    "primary": "totalUsagePerDay",
    "breakdown": [
      "totalUsagePerPersonPerDay",
      "showerUsagePerPersonPerDay",
      "toiletUsagePerPersonPerDay",
      "laundryUsagePerPersonPerDay",
      "otherDailyUsage",
      "totalUsagePerMonth",
      "totalUsagePerYear"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalUsagePerYear"
  },
  "category": "İK & Personel",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "ecology-environment",
  "sectorSlug": "energy-carbon",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "hr",

  "formulas": {
    "inherentScore": "likelihood * impact",
    "residualScore": "residualLikelihood * residualImpact * (1 - controlEffectiveness / 100)",
    "overallScore": "inherentScore * inherentWeight + residualScore * residualWeight"
  },

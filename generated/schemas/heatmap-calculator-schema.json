      }
    },
    {
      "id": "inherentWeight",
      "label": "Inherent Weight",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Weight of inherent risk in overall score, 0-1",
      "label_i18n": {
        "en": "Inherent Weight",
        "tr": "Inherent Weight",
        "de": "Inherent Weight",
        "fr": "Inherent Weight",
        "es": "Inherent Weight",
        "ar": "Inherent Weight"
      }
    },
    {
      "id": "residualWeight",
      "label": "Residual Weight",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Weight of residual risk in overall score, 0-1",
      "label_i18n": {
        "en": "Residual Weight",
        "tr": "Residual Weight",
        "de": "Residual Weight",
        "fr": "Residual Weight",
        "es": "Residual Weight",
        "ar": "Residual Weight"
      }
    }
  ],
  "formulas": {
    "inherentScore": "likelihood * impact",
    "residualScore": "residualLikelihood * residualImpact * (1 - controlEffectiveness / 100)",
    "overallScore": "inherentScore * inherentWeight + residualScore * residualWeight"
  },
  "outputs": {
    "primary": "overallScore",
    "breakdown": [
      "inherentScore",
      "residualScore"
    ]
  },

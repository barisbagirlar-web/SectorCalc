{
  "toolName": "heatmap-calculator",
  "inputs": [
    {
      "id": "likelihood",
      "label": "Likelihood Rating",
      "type": "number",
      "unit": "points",
      "default": 3,
      "businessContext": "Probability of risk event occurring, rated 1-5"
    },
    {
      "id": "impact",
      "label": "Impact Rating",
      "type": "number",
      "unit": "points",
      "default": 3,
      "businessContext": "Severity of consequences if risk occurs, rated 1-5"
    },
    {
      "id": "controlEffectiveness",
      "label": "Control Effectiveness",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "How effectively existing controls reduce risk, 0-100%"
    },
    {
      "id": "residualLikelihood",
      "label": "Residual Likelihood",
      "type": "number",
      "unit": "points",
      "default": 2,
      "businessContext": "Probability after controls, rated 1-5"
    },
    {
      "id": "residualImpact",
      "label": "Residual Impact",
      "type": "number",
      "unit": "points",
      "default": 2,
      "businessContext": "Severity after controls, rated 1-5"
    },
    {
      "id": "inherentWeight",
      "label": "Inherent Weight",
      "type": "number",
      "unit": "",
      "default": 0.5,
      "businessContext": "Weight of inherent risk in overall score, 0-1"
    },
    {
      "id": "residualWeight",
      "label": "Residual Weight",
      "type": "number",
      "unit": "",
      "default": 0.5,
      "businessContext": "Weight of residual risk in overall score, 0-1"
    }
  ],
  "formulas": {
    "inherentScore": "likelihood * impact",
    "residualScore": "residualLikelihood * residualImpact * (1 - controlEffectiveness / 100)",
    "overallScore": "inherentScore * inherentWeight + residualScore * residualWeight"
  },
  "outputs": {
    "primary": "overallScore",
    "breakdown": [
      "inherentScore",
      "residualScore"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

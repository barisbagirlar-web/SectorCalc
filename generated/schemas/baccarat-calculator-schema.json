  "formulas": {
    "directCosts": "rawMaterialCost + laborCostPerHour * hoursPerUnit + energyCostPerUnit",
    "overheadAmount": "directCosts * overheadRate / 100",
    "totalProductionCost": "directCosts + additionalCost + overheadAmount",
    "profitAmount": "totalProductionCost * profitMargin / 100",
    "sellingPrice": "totalProductionCost + profitAmount"
  },

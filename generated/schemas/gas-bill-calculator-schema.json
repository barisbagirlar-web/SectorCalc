{
  "toolName": "gas-bill-calculator",
  "inputs": [
    {
      "id": "consumption",
      "label": "Gas Consumption",
      "type": "number",
      "unit": "m³",
      "default": 0,
      "businessContext": "Actual meter reading difference or estimated monthly consumption",
      "label_i18n": {
        "en": "Gas Consumption",
        "tr": "Gaz Tüketimi",
        "de": "Gas Consumption",
        "fr": "Gas Consumption",
        "es": "Gas Consumption",
        "ar": "Gas Consumption"
      },
      "businessContext_i18n": {
        "en": "Actual meter reading difference or estimated monthly consumption",
        "tr": "Gerçek sayaç okuma farkı veya tahmini aylık tüketim"
      }
    },
    {
      "id": "calorificValue",
      "label": "Calorific Value",
      "type": "number",
      "unit": "kWh/m³",
      "default": 11.2,
      "businessContext": "Average calorific value of gas supply as per gas network operator",
      "label_i18n": {
        "en": "Calorific Value",
        "tr": "Kalorifik Değer",
        "de": "Calorific Value",
        "fr": "Calorific Value",
        "es": "Calorific Value",
        "ar": "Calorific Value"
      },
      "businessContext_i18n": {
        "en": "Average calorific value of gas supply as per gas network operator",
        "tr": "Gaz şebekesi operatörüne göre gaz beslemesinin ortalama kalorifik değeri"
      }
    },
    {
      "id": "unitRate",
      "label": "Unit Rate",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.04,
      "businessContext": "Unit price of gas per kWh from tariff",
      "label_i18n": {
        "en": "Unit Rate",
        "tr": "Birim Fiyat",
        "de": "Unit Rate",
        "fr": "Unit Rate",
        "es": "Unit Rate",
        "ar": "Unit Rate"
      },
      "businessContext_i18n": {
        "en": "Unit price of gas per kWh from tariff",
        "tr": "Tarifeden kWh başına gaz birim fiyatı"
      }
    },
    {
      "id": "standingCharge",
      "label": "Standing Charge",
      "type": "number",
      "unit": "currency/month",
      "default": 10,
      "businessContext": "Fixed monthly charge by supplier",
      "label_i18n": {
        "en": "Standing Charge",
        "tr": "Sabit Ücret",
        "de": "Standing Charge",
        "fr": "Standing Charge",
        "es": "Standing Charge",
        "ar": "Standing Charge"
      },
      "businessContext_i18n": {
        "en": "Fixed monthly charge by supplier",
        "tr": "Tedarikçi tarafından belirlenen sabit aylık ücret"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Applicable VAT rate, e.g., 20%",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "VAT Rate",
        "fr": "VAT Rate",
        "es": "VAT Rate",
        "ar": "VAT Rate"
      },
      "businessContext_i18n": {
        "en": "Applicable VAT rate, e.g., 20%",
        "tr": "Geçerli KDV oranı, örn. %20"
      }
    }
  ],
  "formulas": {
    "energyConsumed": "consumption * calorificValue",
    "energyCost": "energyConsumed * unitRate",
    "subtotal": "energyCost + standingCharge",
    "vatAmount": "subtotal * vatRate / 100",
    "totalBill": "subtotal + vatAmount"
  },
  "outputs": {
    "primary": "totalBill",
    "breakdown": [
      "energyCost",
      "standingCharge",
      "vatAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalBill",
    "unit": "m³"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",

        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    },
    {
      "id": "coverage_per_liter",
      "label": "Coverage per Liter",
      "type": "number",
      "unit": "m²/L",
      "default": 12,
      "businessContext": "Manufacturer's stated coverage in m² per liter.",
      "label_i18n": {
        "en": "Coverage per Liter",
        "tr": "Coverage per Liter",
        "de": "Coverage per Liter",
        "fr": "Coverage per Liter",
        "es": "Coverage per Liter",
        "ar": "Coverage per Liter"
      }
    },
    {
      "id": "waste_factor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Expected paint wastage as percentage (e.g., overspray, spillage).",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "roughness_factor",
      "label": "Surface Roughness Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.2,
      "businessContext": "Multiplier for rough surfaces (1.0=smooth, 1.5=rough).",
      "label_i18n": {
        "en": "Surface Roughness Factor",
        "tr": "Surface Roughness Factor",
        "de": "Surface Roughness Factor",
        "fr": "Surface Roughness Factor",
        "es": "Surface Roughness Factor",
        "ar": "Surface Roughness Factor"
      }
    },
    {
      "id": "paint_price_per_liter",
      "label": "Paint Price per Liter",
      "type": "number",
      "unit": "currency/L",
      "default": 30,
      "businessContext": "Cost of paint per liter in local currency.",
      "label_i18n": {
        "en": "Paint Price per Liter",
        "tr": "Paint Price per Liter",
        "de": "Paint Price per Liter",
        "fr": "Paint Price per Liter",
        "es": "Paint Price per Liter",
        "ar": "Paint Price per Liter"
      }
    }
  ],
  "formulas": {
    "paint_liters": "(area_sqm * coats) / (coverage_per_liter / roughness_factor) * (1 + waste_factor / 100)",
    "total_cost": "(area_sqm * coats) / (coverage_per_liter / roughness_factor) * (1 + waste_factor / 100) * paint_price_per_liter"
  },
  "outputs": {
    "primary": "paint_liters",

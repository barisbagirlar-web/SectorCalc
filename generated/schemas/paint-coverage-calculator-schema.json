{
  "toolName": "paint-coverage-calculator",
  "inputs": [
    {
      "id": "area_sqm",
      "label": "Area to Paint",
      "type": "number",
      "unit": "m²",
      "default": 50,
      "businessContext": "Total area to be painted in square meters.",
      "label_i18n": {
        "en": "Area to Paint",
        "tr": "Area to Paint",
        "de": "Area to Paint",
        "fr": "Area to Paint",
        "es": "Area to Paint",
        "ar": "Area to Paint"
      }
    },
    {
      "id": "coats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "coats",

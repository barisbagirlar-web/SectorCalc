{
  "toolName": "thou-to-mm-calculator",
  "inputs": [
    {
      "id": "nominalThou",
      "label": "Nominal Dimension",
      "type": "number",
      "unit": "thou",
      "default": 0,
      "businessContext": "Nominal dimension in thou (thousandths of an inch) to be converted",
      "label_i18n": {
        "en": "Nominal Dimension",
        "tr": "Nominal Dimension",
        "de": "Nominal Dimension",
        "fr": "Nominal Dimension",
        "es": "Nominal Dimension",
        "ar": "Nominal Dimension"
      }
    },
    {
      "id": "upperToleranceThou",
      "label": "Upper Tolerance",
      "type": "number",
      "unit": "thou",
      "default": 0,
      "businessContext": "Upper tolerance limit in thou",
      "label_i18n": {
        "en": "Upper Tolerance",
        "tr": "Upper Tolerance",
        "de": "Upper Tolerance",
        "fr": "Upper Tolerance",
        "es": "Upper Tolerance",
        "ar": "Upper Tolerance"
      }
    },
    {
      "id": "lowerToleranceThou",
      "label": "Lower Tolerance",
      "type": "number",
      "unit": "thou",
      "default": 0,
      "businessContext": "Lower tolerance limit in thou (use negative value if below nominal)",
      "label_i18n": {
        "en": "Lower Tolerance",
        "tr": "Lower Tolerance",
        "de": "Lower Tolerance",
        "fr": "Lower Tolerance",
        "es": "Lower Tolerance",
        "ar": "Lower Tolerance"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "mm/thou",
      "default": 0.0254,
      "businessContext": "Fixed conversion factor from thou to millimeters (1 thou = 0.0254 mm)",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Number of decimal places for rounding results",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "nominalMM": "Math.round(nominalThou * conversionFactor * Math.pow(10, precision)) / Math.pow(10, precision)",
    "upperMM": "Math.round(upperToleranceThou * conversionFactor * Math.pow(10, precision)) / Math.pow(10, precision)",
    "lowerMM": "Math.round(lowerToleranceThou * conversionFactor * Math.pow(10, precision)) / Math.pow(10, precision)"
  },
  "outputs": {
    "primary": "nominalMM",
    "breakdown": [
      "upperMM",
      "lowerMM"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Makine & Ekipman",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "conversion"
}

{
  "toolName": "land-transfer-tax-calculator",
  "inputs": [
    {
      "id": "propertyValue",
      "label": "Property Value",
      "type": "number",
      "unit": "$",
      "default": 500000,
      "businessContext": "The total purchase price or assessed value of the property.",
      "label_i18n": {
        "en": "Property Value",
        "tr": "Property Value",
        "de": "Property Value",
        "fr": "Property Value",
        "es": "Property Value",
        "ar": "Property Value"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 2.5,
      "businessContext": "The applicable land transfer tax rate as a percentage (e.g., 2.5 for 2.5%).",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "exemptionAmount",
      "label": "First-Time Buyer Exemption",
      "type": "number",
      "unit": "$",
      "default": 4000,
      "businessContext": "Maximum exemption amount available for first-time home buyers. Set to 0 if not applicable.",
      "label_i18n": {
        "en": "First-Time Buyer Exemption",
        "tr": "First-Time Buyer Exemption",
        "de": "First-Time Buyer Exemption",
        "fr": "First-Time Buyer Exemption",
        "es": "First-Time Buyer Exemption",
        "ar": "First-Time Buyer Exemption"
      }
    },
    {
      "id": "isFirstTimeBuyer",
      "label": "First-Time Buyer?",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "1 if buyer qualifies as a first-time buyer, else 0.",
      "label_i18n": {
        "en": "First-Time Buyer?",
        "tr": "First-Time Buyer?",
        "de": "First-Time Buyer?",
        "fr": "First-Time Buyer?",
        "es": "First-Time Buyer?",
        "ar": "First-Time Buyer?"
      }
    },
    {
      "id": "fixedFee",
      "label": "Administrative Fee",
      "type": "number",
      "unit": "$",
      "default": 250,
      "businessContext": "Government administrative or registration fee, if any.",
      "label_i18n": {
        "en": "Administrative Fee",
        "tr": "Administrative Fee",
        "de": "Administrative Fee",
        "fr": "Administrative Fee",
        "es": "Administrative Fee",
        "ar": "Administrative Fee"
      }
    }
  ],
  "formulas": {
    "baseTax": "propertyValue * (taxRate / 100)",
    "exemptionApplied": "isFirstTimeBuyer * exemptionAmount",
    "netTax": "baseTax - exemptionApplied > 0 ? baseTax - exemptionApplied : 0",
    "totalTax": "netTax + fixedFee"
  },
  "outputs": {
    "primary": "totalTax",
    "breakdown": [
      "baseTax",
      "exemptionApplied",
      "netTax"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTax"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

  "formulas": {
    "totalAreaM2": "(backsplashWidth * backsplashHeight) / 10000",
    "wasteAreaM2": "totalAreaM2 * (wastePercentage / 100)",
    "totalAreaWithWasteM2": "totalAreaM2 * (1 + wastePercentage / 100)",
    "exactTilesNeeded": "(backsplashWidth * backsplashHeight) / (tileWidth * tileHeight) * (1 + wastePercentage / 100)"
  },

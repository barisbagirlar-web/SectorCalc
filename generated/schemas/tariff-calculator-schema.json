{
  "toolName": "tariff-calculator",
  "inputs": [
    {
      "id": "consumption",
      "label": "Consumption",
      "type": "number",
      "unit": "kWh",
      "default": 1000,
      "businessContext": "Total energy consumption in kilowatt-hours for the billing period",
      "label_i18n": {
        "en": "Consumption",
        "tr": "Consumption",
        "de": "Consumption",
        "fr": "Consumption",
        "es": "Consumption",
        "ar": "Consumption"
      }
    },
    {
      "id": "peakRate",
      "label": "Peak Rate",
      "type": "number",
      "unit": "€/kWh",
      "default": 0.15,
      "businessContext": "Price per kilowatt-hour during peak usage hours",
      "label_i18n": {
        "en": "Peak Rate",
        "tr": "Peak Rate",
        "de": "Peak Rate",
        "fr": "Peak Rate",
        "es": "Peak Rate",
        "ar": "Peak Rate"
      }
    },
    {
      "id": "offPeakRate",
      "label": "Off-Peak Rate",
      "type": "number",
      "unit": "€/kWh",
      "default": 0.1,
      "businessContext": "Price per kilowatt-hour during off-peak usage hours",
      "label_i18n": {
        "en": "Off-Peak Rate",
        "tr": "Off-Peak Rate",
        "de": "Off-Peak Rate",
        "fr": "Off-Peak Rate",
        "es": "Off-Peak Rate",
        "ar": "Off-Peak Rate"
      }
    },
    {
      "id": "peakUsage",
      "label": "Peak Usage Fraction",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Estimated percentage of total consumption that occurs during peak hours (0-100)",
      "label_i18n": {
        "en": "Peak Usage Fraction",
        "tr": "Peak Usage Fraction",
        "de": "Peak Usage Fraction",
        "fr": "Peak Usage Fraction",
        "es": "Peak Usage Fraction",
        "ar": "Peak Usage Fraction"
      }
    },
    {
      "id": "standingCharge",
      "label": "Standing Charge",
      "type": "number",
      "unit": "€/day",
      "default": 0.5,
      "businessContext": "Fixed daily charge applied by the energy supplier regardless of consumption",
      "label_i18n": {
        "en": "Standing Charge",
        "tr": "Standing Charge",
        "de": "Standing Charge",
        "fr": "Standing Charge",
        "es": "Standing Charge",
        "ar": "Standing Charge"
      }
    },
    {
      "id": "days",
      "label": "Billing Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of days in the billing period",
      "label_i18n": {
        "en": "Billing Days",
        "tr": "Billing Days",
        "de": "Billing Days",
        "fr": "Billing Days",
        "es": "Billing Days",
        "ar": "Billing Days"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Value-added tax (VAT) or similar tax percentage applied to the subtotal",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "peakEnergyFraction": "peakUsage / 100",
    "peakEnergy": "consumption * peakEnergyFraction",
    "offPeakEnergy": "consumption - peakEnergy",
    "energyCost": "peakEnergy * peakRate + offPeakEnergy * offPeakRate",
    "standingCost": "standingCharge * days",
    "subtotal": "energyCost + standingCost",
    "taxAmount": "subtotal * (taxRate / 100)",
    "total": "subtotal + taxAmount"
  },
  "outputs": {
    "primary": "total",
    "breakdown": [
      "subtotal",
      "taxAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "total"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,

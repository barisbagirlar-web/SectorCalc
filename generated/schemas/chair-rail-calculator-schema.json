      }
    },
    {
      "id": "pricePerFoot",
      "label": "Price per Linear Foot",
      "type": "number",
      "unit": "USD/ft",
      "default": 0,
      "businessContext": "Cost of chair rail material per linear foot",
      "label_i18n": {
        "en": "Price per Linear Foot",
        "tr": "Price per Linear Foot",
        "de": "Price per Linear Foot",
        "fr": "Price per Linear Foot",
        "es": "Price per Linear Foot",
        "ar": "Price per Linear Foot"
      }
    }
  ],
  "formulas": {
    "perimeter": "2 * (roomLength + roomWidth)",
    "openings": "doorCount * doorWidth + windowCount * windowWidth",
    "netLength": "perimeter - openings",
    "wasteAmount": "netLength * (wasteFactor / 100)",
    "totalLength": "netLength + wasteAmount",
    "totalCost": "totalLength * pricePerFoot"
  },
  "outputs": {
    "primary": "totalLength",
    "breakdown": [
      "netLength",
      "wasteAmount",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

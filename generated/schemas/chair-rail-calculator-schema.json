    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional material percentage to account for cutting waste and miter errors",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",

    },
    {
      "id": "b",
      "label": "2. Terim Katsayısı",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "İkinci terimin katsayısı"
    },
    {
      "id": "m",
      "label": "2. Terim Üssü",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "İkinci terimin üssü"
    },
    {
      "id": "c",
      "label": "3. Terim Katsayısı",

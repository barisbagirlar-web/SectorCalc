  "formulas": {
    "derivativeTerm1": "a * n === 0 ? 0 : a * n * Math.pow(x, n - 1)",
    "derivativeTerm2": "b * m === 0 ? 0 : b * m * Math.pow(x, m - 1)",
    "derivativeTerm3": "c * p === 0 ? 0 : c * p * Math.pow(x, p - 1)",
    "derivativeTotal": "((a * n === 0 ? 0 : a * n * Math.pow(x, n - 1)) + (b * m === 0 ? 0 : b * m * Math.pow(x, m - 1)) + (c * p === 0 ? 0 : c * p * Math.pow(x, p - 1)))"
  },

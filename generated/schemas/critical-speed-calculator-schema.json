{
  "toolName": "critical-speed-calculator",
  "inputs": [
    {
      "id": "shaftLength",
      "label": "Shaft Length (L)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the shaft between supports.",
      "label_i18n": {
        "en": "Shaft Length (L)",
        "tr": "Shaft Length (L)",
        "de": "Shaft Length (L)",
        "fr": "Shaft Length (L)",
        "es": "Shaft Length (L)",
        "ar": "Shaft Length (L)"
      }
    },
    {
      "id": "shaftDiameter",
      "label": "Shaft Diameter (D)",
      "type": "number",
      "unit": "m",
      "default": 0.05,
      "businessContext": "Diameter of the solid cylindrical shaft.",
      "label_i18n": {
        "en": "Shaft Diameter (D)",
        "tr": "Shaft Diameter (D)",
        "de": "Shaft Diameter (D)",
        "fr": "Shaft Diameter (D)",
        "es": "Shaft Diameter (D)",
        "ar": "Shaft Diameter (D)"
      }
    },
    {
      "id": "youngsModulus",
      "label": "Young's Modulus (E)",
      "type": "number",
      "unit": "Pa",
      "default": 210000000000,
      "businessContext": "Material's modulus of elasticity, e.g., steel ~210 GPa.",
      "label_i18n": {
        "en": "Young's Modulus (E)",
        "tr": "Young's Modulus (E)",
        "de": "Young's Modulus (E)",
        "fr": "Young's Modulus (E)",
        "es": "Young's Modulus (E)",
        "ar": "Young's Modulus (E)"
      }
    },
    {
      "id": "density",
      "label": "Material Density (ρ)",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "businessContext": "Density of the shaft material, e.g., steel ~7850 kg/m³.",
      "label_i18n": {
        "en": "Material Density (ρ)",
        "tr": "Material Density (ρ)",
        "de": "Material Density (ρ)",
        "fr": "Material Density (ρ)",
        "es": "Material Density (ρ)",
        "ar": "Material Density (ρ)"
      }
    },
    {
      "id": "supportFactor",
      "label": "Support Factor (C)",
      "type": "number",
      "unit": "unit",
      "default": 3.141592653589793,
      "businessContext": "Dimensionless factor based on end conditions: π for pinned-pinned, 4.730 for fixed-fixed, 3.927 for fixed-pinned, 1.875 for fixed-free.",
      "label_i18n": {
        "en": "Support Factor (C)",
        "tr": "Support Factor (C)",
        "de": "Support Factor (C)",
        "fr": "Support Factor (C)",
        "es": "Support Factor (C)",
        "ar": "Support Factor (C)"
      }
    }
  ],
  "formulas": {
    "crossSectionArea": "Math.PI * (shaftDiameter/2) ** 2",
    "momentOfInertia": "Math.PI/64 * shaftDiameter ** 4",
    "massPerUnitLength": "density * crossSectionArea",
    "angularFrequency": "(supportFactor / shaftLength) ** 2 * Math.sqrt(youngsModulus * momentOfInertia / massPerUnitLength)",
    "criticalSpeedRPM": "angularFrequency * 30 / Math.PI"
  },
  "outputs": {
    "primary": "criticalSpeedRPM",
    "breakdown": [
      "angularFrequency",
      "criticalSpeedRPM"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Metal & Sac İşleme",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",
  "categoryId": "conversion"
}

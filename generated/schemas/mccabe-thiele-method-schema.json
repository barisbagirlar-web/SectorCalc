  "formulas": {
    "nMin": "Math.log((xd*(1-xb))/(xb*(1-xd)))/Math.log(alpha)",
    "rMin": "(xd - xf)/(xf - xb) * (1 - xb)/(1 - xd)",
    "nActual": "(r - rMin)/(r + 1) * nMin + nMin",
    "feedLineSlope": "q/(q-1)",
    "feedLineIntercept": "xf/(1-q)",
    "operatingLineSlope": "r/(r+1)",
    "operatingLineIntercept": "xd/(r+1)",
    "Slope_of_operating_line__rectifying_sect": "Slope of operating line (rectifying section)",
    "Intercept_of_operating_line__rectifying_": "Intercept of operating line (rectifying section)"
  },
  "outputs": {
    "primary": "nActual",
    "breakdown": [
      "nMin: Minimum number of theoretical stages",
      "rMin: Minimum reflux ratio",
      "nActual: Actual number of theoretical stages",
      "feedLineSlope: Slope of feed line",
      "feedLineIntercept: Intercept of feed line",
      "operatingLineSlope: Slope of operating line (rectifying section)",
      "operatingLineIntercept: Intercept of operating line (rectifying section)"
    ]
  },

{
  "toolName": "creatine-calculator",
  "inputs": [
    {
      "id": "totalUnits",
      "label": "Total Production Quantity",
      "type": "number",
      "unit": "adet",
      "default": 1000,
      "businessContext": "Total number of supplements to be produced",
      "label_i18n": {
        "en": "Total production quantity",
        "tr": "Toplam Üretim Adedi",
        "de": "Gesamtproduktionsmenge",
        "fr": "Quantité totale de production",
        "es": "Cantidad total de producción",
        "ar": "إجمالي عدد الوحدات المنتجة"
      },
      "businessContext_i18n": {
        "en": "Total number of supplements to be produced",
        "tr": "Toplam üretilecek takviye adedi",
        "de": "Gesamtzahl der herzustellenden Nahrungsergänzungsmittel",
        "fr": "Nombre total de suppléments à produire",
        "es": "Cantidad total de suplementos a producir",
        "ar": "إجمالي عدد المكملات المراد إنتاجها"
      }
    },
    {
      "id": "dosagePerUnit",
      "label": "Birim Dozaj (g)",
      "type": "number",
      "unit": "g",
      "default": 5,
      "businessContext": "Amount of creatine per product",
      "label_i18n": {
        "en": "Birim Dozaj (g)",
        "tr": "Unit Dosage (g)",
        "de": "Einzeldosis (g)",
        "fr": "Dosage unitaire (g)",
        "es": "Dosis unitaria (g)",
        "ar": "الجرعة لكل وحدة (جم)"
      },
      "businessContext_i18n": {
        "en": "Creatine amount per product",
        "tr": "Her bir ürün başına kreatin miktarı",
        "de": "Kreatinmenge pro Produkt",
        "fr": "Quantité de créatine par produit",
        "es": "Cantidad de creatina por producto",
        "ar": "كمية الكرياتين لكل منتج"
      }
    },
    {
      "id": "lossRate",
      "label": "Production Loss Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Creatine waste rate during production",
      "label_i18n": {
        "en": "Production loss rate (%)",
        "tr": "Üretim Kayıp Oranı (%)",
        "de": "Produktionsausfallrate (%)",
        "fr": "Taux de perte de production (%)",
        "es": "Tasa de pérdida de producción (%)",
        "ar": "نسبة الفقد في الإنتاج (%)"
      },
      "businessContext_i18n": {
        "en": "Creatine waste rate during production",
        "tr": "Üretim sürecinde meydana gelen kreatin fire oranı",
        "de": "Kreatin-Ausschussrate während der Produktion",
        "fr": "Taux de perte de créatine survenant pendant le processus de production",
        "es": "Porcentaje de desperdicio de creatina durante el proceso de producción",
        "ar": "نسبة الفقد في الكرياتين أثناء عملية الإنتاج"
      }
    },
    {
      "id": "purity",
      "label": "Creatine Purity Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 99,
      "businessContext": "Purity percentage of the creatine raw material used",
      "label_i18n": {
        "en": "Creatine purity rate (%)",
        "tr": "Kreatin Saflık Oranı (%)",
        "de": "Kreatin-Reinheitsgrad (%)",
        "fr": "Taux de pureté de la créatine (%)",
        "es": "Tasa de pureza de la creatina (%)",
        "ar": "نسبة نقاء الكرياتين (%)"
      },
      "businessContext_i18n": {
        "en": "Purity percentage of creatine raw material used",
        "tr": "Kullanılan kreatin hammaddesinin saflık yüzdesi",
        "de": "Reinheitsprozentsatz des verwendeten Kreatin-Rohmaterials",
        "fr": "Pourcentage de pureté de la matière première de créatine utilisée",
        "es": "Porcentaje de pureza de la materia prima de creatina utilizada",
        "ar": "نسبة نقاء مادة الكرياتين الخام المستخدمة"
      }
    },
    {
      "id": "costPerKg",
      "label": "Kreatin Birim Maliyeti (TL/kg)",
      "type": "number",
      "unit": "TL/kg",
      "default": 500,
      "businessContext": "Cost per kg of creatine raw material",
      "label_i18n": {
        "en": "Kreatin Birim Maliyeti (TL/kg)",
        "tr": "Creatine Unit Cost (TL/kg)",
        "de": "Kreatin-Stückkosten (TL/kg)",
        "fr": "Coût unitaire de la créatine (TL/kg)",
        "es": "Costo unitario de la creatina (TL/kg)",
        "ar": "تكلفة وحدة الكرياتين (ليرة تركية/كجم)"
      },
      "businessContext_i18n": {
        "en": "Cost per kg of creatine raw material",
        "tr": "Kreatin hammaddesinin kg başına maliyeti",
        "de": "Kosten pro kg Kreatin-Rohmaterial",
        "fr": "Coût par kg de matière première de créatine",
        "es": "Costo por kg de la materia prima de creatina",
        "ar": "تكلفة الكيلوغرام من مادة الكرياتين الخام"
      }
    }
  ],
  "formulas": {
    "netDosagePerUnit": "dosagePerUnit / (purity / 100)",
    "totalTheoreticalKg": "(totalUnits * netDosagePerUnit) / 1000",
    "totalNeededKg": "totalTheoreticalKg / (1 - lossRate / 100)",
    "totalCost": "totalNeededKg * costPerKg"
  },
  "outputs": {
    "primary": "netDosagePerUnit",
    "breakdown": [
      "Net Kreatin Miktarı: ${totalNeededKg} kg",
      "Toplam Maliyet: ${totalCost} TL"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "adet",
    "breakdownUnits": {
      "Net Kreatin Miktarı: ${totalNeededKg} kg": "kg"
    }
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",

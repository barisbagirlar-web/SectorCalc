{
  "toolName": "gross-to-net-calculator",
  "inputs": [
    {
      "id": "grossSalary",
      "label": "Gross Salary",
      "type": "number",
      "unit": "currency",
      "default": 5000,
      "businessContext": "The total gross salary before any deductions.",
      "label_i18n": {
        "en": "Gross Salary",
        "tr": "Gross Salary",
        "de": "Gross Salary",
        "fr": "Gross Salary",
        "es": "Gross Salary",
        "ar": "Gross Salary"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Income tax rate applied to gross salary.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "socialSecurityRate",
      "label": "Social Security Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Social security contribution rate.",
      "label_i18n": {
        "en": "Social Security Rate",
        "tr": "Social Security Rate",
        "de": "Social Security Rate",
        "fr": "Social Security Rate",
        "es": "Social Security Rate",
        "ar": "Social Security Rate"
      }
    },
    {
      "id": "otherDeductions",
      "label": "Other Deductions",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Any other fixed deductions from the salary.",
      "label_i18n": {
        "en": "Other Deductions",
        "tr": "Other Deductions",
        "de": "Other Deductions",
        "fr": "Other Deductions",
        "es": "Other Deductions",
        "ar": "Other Deductions"
      }
    }
  ],
  "formulas": {
    "taxAmount": "grossSalary * (taxRate / 100)",
    "socialSecurityAmount": "grossSalary * (socialSecurityRate / 100)",
    "totalDeductions": "taxAmount + socialSecurityAmount + otherDeductions",
    "netSalary": "grossSalary - totalDeductions"
  },
  "outputs": {
    "primary": "netSalary",
    "breakdown": [
      "taxAmount",
      "socialSecurityAmount",
      "totalDeductions",
      "netSalary"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netSalary",
    "unit": "currency"
  },

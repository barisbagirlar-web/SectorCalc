{
  "toolName": "schrodinger-equation",
  "inputs": [
    {
      "id": "mass",
      "label": "Particle Mass",
      "type": "number",
      "unit": "kg",
      "default": 9.10938356e-31,
      "businessContext": "Mass of the particle (e.g., electron mass)"
    },
    {
      "id": "potential",
      "label": "Potential Energy",
      "type": "number",
      "unit": "J",
      "default": 0,
      "businessContext": "Constant potential energy in the region"
    },
    {
      "id": "energy",
      "label": "Total Energy",
      "type": "number",
      "unit": "J",
      "default": 1.602176634e-19,
      "businessContext": "Total energy of the particle (e.g., 1 eV)"
    },
    {
      "id": "hbar",
      "label": "Reduced Planck Constant",
      "type": "number",
      "unit": "J·s",
      "default": 1.054571817e-34,
      "businessContext": "Fundamental constant h/(2π)"
    },
    {
      "id": "position",
      "label": "Position",
      "type": "number",
      "unit": "m",
      "default": 1e-10,
      "businessContext": "Spatial coordinate for wavefunction evaluation"
    }
  ],
  "formulas": {
    "waveNumber": "Math.sqrt(2 * mass * (energy - potential)) / hbar",
    "waveFunction": "Math.sin(waveNumber * position)",
    "probabilityDensity": "waveFunction ** 2"
  },
  "outputs": {
    "primary": "probabilityDensity",
    "breakdown": [
      "waveNumber",
      "waveFunction",
      "probabilityDensity"
    ]
  },
  "category": "Enerji & Sürdürülebilirlik",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "physics-science",

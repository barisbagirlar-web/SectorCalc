{
  "toolName": "hydroponics-calculator",
  "inputs": [
    {
      "id": "fertilizerMass",
      "label": "Fertilizer Mass",
      "type": "number",
      "unit": "g",
      "default": 100,
      "businessContext": "Mass of fertilizer used to prepare stock solution",
      "label_i18n": {
        "en": "Fertilizer Mass",
        "tr": "Fertilizer Mass",
        "de": "Fertilizer Mass",
        "fr": "Fertilizer Mass",
        "es": "Fertilizer Mass",
        "ar": "Fertilizer Mass"
      }
    },
    {
      "id": "nutrientPercentage",
      "label": "Nutrient Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Nutrient content by weight in fertilizer",
      "label_i18n": {
        "en": "Nutrient Percentage",
        "tr": "Nutrient Percentage",
        "de": "Nutrient Percentage",
        "fr": "Nutrient Percentage",
        "es": "Nutrient Percentage",
        "ar": "Nutrient Percentage"
      }
    },
    {
      "id": "waterVolumeForStock",
      "label": "Water Volume for Stock",
      "type": "number",
      "unit": "L",
      "default": 1,
      "businessContext": "Volume of water used to dissolve fertilizer for stock solution",
      "label_i18n": {
        "en": "Water Volume for Stock",
        "tr": "Water Volume for Stock",
        "de": "Water Volume for Stock",
        "fr": "Water Volume for Stock",
        "es": "Water Volume for Stock",
        "ar": "Water Volume for Stock"
      }
    },
    {
      "id": "targetPpm",
      "label": "Target PPM",
      "type": "number",
      "unit": "ppm",
      "default": 150,
      "businessContext": "Desired final nutrient concentration in reservoir",
      "label_i18n": {
        "en": "Target PPM",
        "tr": "Target PPM",
        "de": "Target PPM",
        "fr": "Target PPM",
        "es": "Target PPM",
        "ar": "Target PPM"
      }
    },
    {
      "id": "reservoirWaterVolume",
      "label": "Reservoir Water Volume",
      "type": "number",
      "unit": "L",
      "default": 100,
      "businessContext": "Total water volume in hydroponic reservoir to be treated",
      "label_i18n": {
        "en": "Reservoir Water Volume",
        "tr": "Reservoir Water Volume",
        "de": "Reservoir Water Volume",
        "fr": "Reservoir Water Volume",
        "es": "Reservoir Water Volume",
        "ar": "Reservoir Water Volume"
      }
    }
  ],
  "formulas": {
    "stockPpm": "(fertilizerMass * 10 * nutrientPercentage) / waterVolumeForStock",
    "stockVolumeL": "(targetPpm * reservoirWaterVolume) / stockPpm",
    "stockVolumeML": "stockVolumeL * 1000"
  },
  "outputs": {
    "primary": "stockVolumeML",
    "breakdown": [
      "stockPpm",
      "stockVolumeL"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "stockVolumeML"
  },

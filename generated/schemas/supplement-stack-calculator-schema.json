{
  "toolName": "supplement-stack-calculator",
  "inputs": [
    {
      "id": "supp1Amount",
      "label": "Supplement 1 Active (g)",
      "type": "number",
      "unit": "g",
      "default": 5,
      "businessContext": "Amount of active ingredient per serving of supplement 1"
    },
    {
      "id": "supp1Price",
      "label": "Supplement 1 Price",
      "type": "number",
      "unit": "EUR",
      "default": 30,
      "businessContext": "Price per container of supplement 1"
    },
    {
      "id": "supp1ContainerServings",
      "label": "Supplement 1 Container Servings",
      "type": "number",
      "unit": "servings",
      "default": 30,
      "businessContext": "Number of servings per container of supplement 1"
    },
    {
      "id": "supp1DailyServings",
      "label": "Supplement 1 Daily Servings",
      "type": "number",
      "unit": "servings",
      "default": 2,
      "businessContext": "Number of servings taken per day of supplement 1"
    },
    {
      "id": "supp2Amount",
      "label": "Supplement 2 Active (g)",
      "type": "number",
      "unit": "g",
      "default": 3,
      "businessContext": "Amount of active ingredient per serving of supplement 2"
    },
    {
      "id": "supp2Price",
      "label": "Supplement 2 Price",
      "type": "number",
      "unit": "EUR",
      "default": 25,
      "businessContext": "Price per container of supplement 2"
    },
    {
      "id": "supp2ContainerServings",
      "label": "Supplement 2 Container Servings",
      "type": "number",
      "unit": "servings",
      "default": 60,
      "businessContext": "Number of servings per container of supplement 2"
    },
    {
      "id": "supp2DailyServings",
      "label": "Supplement 2 Daily Servings",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "Number of servings taken per day of supplement 2"
    }
  ],
  "formulas": {
    "dailyActive": "supp1Amount * supp1DailyServings + supp2Amount * supp2DailyServings",
    "dailyCost": "(supp1Price / supp1ContainerServings) * supp1DailyServings + (supp2Price / supp2ContainerServings) * supp2DailyServings",
    "costPerGram": "dailyCost / dailyActive"
  },
  "outputs": {
    "primary": "dailyCost",
    "breakdown": [
      "dailyActive",
      "dailyCost",
      "costPerGram"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

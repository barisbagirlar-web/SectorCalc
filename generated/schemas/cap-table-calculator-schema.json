{
  "toolName": "cap-table-calculator",
  "inputs": [
    {
      "id": "totalAuthorizedShares",
      "label": "Total Authorized Shares",
      "type": "number",
      "unit": "shares",
      "default": 10000000,
      "businessContext": "The maximum number of shares the company is authorized to issue.",
      "label_i18n": {
        "en": "Total Authorized Shares",
        "tr": "Total Authorized Shares",
        "de": "Total Authorized Shares",
        "fr": "Total Authorized Shares",
        "es": "Total Authorized Shares",
        "ar": "Total Authorized Shares"
      }
    },
    {
      "id": "sharesOutstanding",
      "label": "Shares Outstanding",
      "type": "number",
      "unit": "shares",
      "default": 5000000,
      "businessContext": "Current number of shares held by all shareholders before new investment.",
      "label_i18n": {
        "en": "Shares Outstanding",
        "tr": "Shares Outstanding",
        "de": "Shares Outstanding",
        "fr": "Shares Outstanding",
        "es": "Shares Outstanding",
        "ar": "Shares Outstanding"
      }
    },
    {
      "id": "optionPoolSize",
      "label": "Option Pool Size",
      "type": "number",
      "unit": "shares",
      "default": 500000,
      "businessContext": "Number of shares reserved for employee stock options.",
      "label_i18n": {
        "en": "Option Pool Size",
        "tr": "Option Pool Size",
        "de": "Option Pool Size",
        "fr": "Option Pool Size",
        "es": "Option Pool Size",
        "ar": "Option Pool Size"
      }
    },
    {
      "id": "newInvestment",
      "label": "New Investment Amount",
      "type": "number",
      "unit": "currency",
      "default": 1000000,
      "businessContext": "Amount of money being invested in the company.",
      "label_i18n": {
        "en": "New Investment Amount",
        "tr": "New Investment Amount",
        "de": "New Investment Amount",
        "fr": "New Investment Amount",
        "es": "New Investment Amount",
        "ar": "New Investment Amount"
      }
    },
    {
      "id": "preMoneyValuation",
      "label": "Pre-Money Valuation",
      "type": "number",
      "unit": "currency",
      "default": 10000000,
      "businessContext": "Valuation of the company prior to the new investment.",
      "label_i18n": {
        "en": "Pre-Money Valuation",
        "tr": "Pre-Money Valuation",
        "de": "Pre-Money Valuation",
        "fr": "Pre-Money Valuation",
        "es": "Pre-Money Valuation",
        "ar": "Pre-Money Valuation"
      }
    }
  ],
  "formulas": {
    "fullyDilutedPre": "sharesOutstanding + optionPoolSize",
    "pricePerShare": "preMoneyValuation / fullyDilutedPre",
    "newSharesIssued": "newInvestment / pricePerShare",
    "postMoneyValuation": "preMoneyValuation + newInvestment",
    "totalPostShares": "fullyDilutedPre + newSharesIssued",
    "investorOwnershipPct": "(newSharesIssued / totalPostShares) * 100"
  },
  "outputs": {
    "primary": "investorOwnershipPct",
    "breakdown": [
      "postMoneyValuation",
      "newSharesIssued",
      "pricePerShare",
      "totalPostShares"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "investorOwnershipPct"
  },

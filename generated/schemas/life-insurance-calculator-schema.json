  "formulas": {
    "ageLoading": "(age - 20) * 0.1",
    "smokerLoading": "smokingStatus * 2",
    "healthLoading": "(100 - healthScore) * 0.05"
  },
  "outputs": {
    "primary": "healthLoading",
    "breakdown": [
      "Base Premium: $${((coverageAmount / 1000) * baseRate).toFixed(2)}/year",
      "Age Loading: $${((coverageAmount / 1000) * ageLoading).toFixed(2)}/year",
      "Smoker Loading: $${((coverageAmount / 1000) * smokerLoading).toFixed(2)}/year",
      "Health Loading: $${((coverageAmount / 1000) * healthLoading).toFixed(2)}/year",
      "Annual Premium: $${annualPremium.toFixed(2)}/year",
      "Monthly Premium: $${monthlyPremium.toFixed(2)}/month"
    ],

{
  "toolName": "life-insurance-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the insured person in years",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "coverageAmount",
      "label": "Coverage Amount",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Total coverage amount (death benefit) in USD",
      "label_i18n": {
        "en": "Coverage Amount",
        "tr": "Coverage Amount",
        "de": "Coverage Amount",
        "fr": "Coverage Amount",
        "es": "Coverage Amount",
        "ar": "Coverage Amount"
      }
    },
    {
      "id": "term",
      "label": "Term Length",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "Length of the policy term in years",
      "label_i18n": {
        "en": "Term Length",
        "tr": "Term Length",
        "de": "Term Length",
        "fr": "Term Length",
        "es": "Term Length",
        "ar": "Term Length"
      }
    },
    {
      "id": "smokingStatus",
      "label": "Smoking Status",
      "type": "number",
      "unit": "unitless",
      "default": 0,
      "businessContext": "0 for non-smoker, 1 for smoker",
      "label_i18n": {
        "en": "Smoking Status",
        "tr": "Smoking Status",
        "de": "Smoking Status",
        "fr": "Smoking Status",
        "es": "Smoking Status",
        "ar": "Smoking Status"
      }
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "unitless",
      "default": 0,
      "businessContext": "0 for male, 1 for female (used for risk adjustment)",
      "label_i18n": {
        "en": "Gender",
        "tr": "Gender",
        "de": "Gender",
        "fr": "Gender",
        "es": "Gender",
        "ar": "Gender"
      }
    },
    {
      "id": "healthScore",
      "label": "Health Score",
      "type": "number",
      "unit": "points",
      "default": 80,
      "businessContext": "Health score from 0-100, higher is better",
      "label_i18n": {
        "en": "Health Score",
        "tr": "Health Score",
        "de": "Health Score",
        "fr": "Health Score",
        "es": "Health Score",
        "ar": "Health Score"
      }
    }
  ],
  "formulas": {
    "baseRate": "3",
    "ageLoading": "(age - 20) * 0.1",
    "smokerLoading": "smokingStatus * 2",
    "healthLoading": "(100 - healthScore) * 0.05",
    "annualPremium": "(coverageAmount / 1000) * (baseRate + ageLoading + smokerLoading + healthLoading)",
    "monthlyPremium": "annualPremium / 12",
    "_____coverageAmount___1000____baseRate__": "$${((coverageAmount / 1000) * baseRate).toFixed(2)}/year",
    "_____coverageAmount___1000____ageLoading": "$${((coverageAmount / 1000) * ageLoading).toFixed(2)}/year",
    "_____coverageAmount___1000____smokerLoad": "$${((coverageAmount / 1000) * smokerLoading).toFixed(2)}/year",
    "_____coverageAmount___1000____healthLoad": "$${((coverageAmount / 1000) * healthLoading).toFixed(2)}/year",
    "___annualPremium_toFixed_2___year": "$${annualPremium.toFixed(2)}/year",
    "___monthlyPremium_toFixed_2___month": "$${monthlyPremium.toFixed(2)}/month",
    "result": "`$${monthlyPremium.toFixed(2)}/month`"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Base Premium: $${((coverageAmount / 1000) * baseRate).toFixed(2)}/year",
      "Age Loading: $${((coverageAmount / 1000) * ageLoading).toFixed(2)}/year",
      "Smoker Loading: $${((coverageAmount / 1000) * smokerLoading).toFixed(2)}/year",
      "Health Loading: $${((coverageAmount / 1000) * healthLoading).toFixed(2)}/year",
      "Annual Premium: $${annualPremium.toFixed(2)}/year",
      "Monthly Premium: $${monthlyPremium.toFixed(2)}/month"
    ]
  },
  "category": "İK & Personel",
  "sector": "Finans & Sigorta",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "finans",
  "profession": "Risk Uzmanı",
  "categoryId": "hr"
}

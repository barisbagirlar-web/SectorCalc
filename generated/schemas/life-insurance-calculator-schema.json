    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "unitless",
      "default": 0,
      "businessContext": "0 for male, 1 for female (used for risk adjustment)",
      "label_i18n": {
        "en": "Gender",
        "tr": "Cinsiyet",

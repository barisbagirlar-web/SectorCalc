{
  "toolName": "password-generator",
  "inputs": [
    {
      "id": "length",
      "label": "Password Length",
      "type": "number",
      "unit": "characters",
      "default": 12,
      "businessContext": "Number of characters in the generated password"
    },
    {
      "id": "uppercase",
      "label": "Uppercase Letters",
      "type": "number",
      "unit": "count",
      "default": 2,
      "businessContext": "Minimum number of uppercase letters"
    },
    {
      "id": "lowercase",
      "label": "Lowercase Letters",
      "type": "number",
      "unit": "count",
      "default": 4,
      "businessContext": "Minimum number of lowercase letters"
    },
    {
      "id": "digits",
      "label": "Digits",
      "type": "number",
      "unit": "count",
      "default": 2,
      "businessContext": "Minimum number of digits"
    },
    {
      "id": "special",
      "label": "Special Characters",
      "type": "number",
      "unit": "count",
      "default": 2,
      "businessContext": "Minimum number of special characters"
    },
    {
      "id": "excludeSimilar",
      "label": "Exclude Similar Characters",
      "type": "number",
      "unit": "boolean",
      "default": 1,
      "businessContext": "1 to exclude similar characters (e.g., l,1,I,0,O), 0 to include"
    }
  ],
  "formulas": {
    "entropy": "length * Math.log2(uppercase + lowercase + digits + special + (excludeSimilar ? 0 : 0))",
    "strength": "entropy >= 80 ? 'Strong' : entropy >= 60 ? 'Moderate' : 'Weak'"
  },
  "outputs": {
    "primary": "Generated password",
    "breakdown": [
      "Entropy: {entropy} bits",
      "Strength: {strength}"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

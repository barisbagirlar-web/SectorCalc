{
  "toolName": "auto-loan-calculator",
  "inputs": [
    {
      "id": "vehiclePrice",
      "label": "Vehicle Price",
      "type": "number",
      "unit": "$",
      "default": 30000,
      "businessContext": "Total price of the vehicle including any additional fees.",
      "label_i18n": {
        "en": "Vehicle Price",
        "tr": "Vehicle Price",
        "de": "Vehicle Price",
        "fr": "Vehicle Price",
        "es": "Vehicle Price",
        "ar": "Vehicle Price"
      }
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "number",
      "unit": "$",
      "default": 5000,
      "businessContext": "Amount paid upfront that reduces the loan principal.",
      "label_i18n": {
        "en": "Down Payment",
        "tr": "Down Payment",
        "de": "Down Payment",
        "fr": "Down Payment",
        "es": "Down Payment",
        "ar": "Down Payment"
      }
    },
    {
      "id": "tradeInValue",
      "label": "Trade-In Value",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Value of a vehicle traded in, which reduces the amount to finance.",
      "label_i18n": {
        "en": "Trade-In Value",
        "tr": "Trade-In Value",
        "de": "Trade-In Value",
        "fr": "Trade-In Value",
        "es": "Trade-In Value",
        "ar": "Trade-In Value"
      }
    },
    {
      "id": "salesTaxRate",
      "label": "Sales Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Applicable sales tax percentage on the taxable amount (vehicle price minus trade-in).",
      "label_i18n": {
        "en": "Sales Tax Rate",
        "tr": "Sales Tax Rate",
        "de": "Sales Tax Rate",
        "fr": "Sales Tax Rate",
        "es": "Sales Tax Rate",
        "ar": "Sales Tax Rate"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate (APR)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual Percentage Rate for the loan.",
      "label_i18n": {
        "en": "Interest Rate (APR)",
        "tr": "Interest Rate (APR)",
        "de": "Interest Rate (APR)",
        "fr": "Interest Rate (APR)",
        "es": "Interest Rate (APR)",
        "ar": "Interest Rate (APR)"
      }
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "months",
      "default": 60,
      "businessContext": "Duration of the loan in months.",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    }
  ],
  "formulas": {
    "loanAmount": "vehiclePrice + (vehiclePrice - tradeInValue) * salesTaxRate / 100 - downPayment - tradeInValue",
    "monthlyInterestRate": "interestRate / 100 / 12"
  },
  "outputs": {
    "primary": "monthlyInterestRate",
    "breakdown": [
      "totalInterest",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

{
  "toolName": "pascal-to-psi-calculator",
  "inputs": [
    {
      "id": "pressurePascals",
      "label": "Pressure Reading (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 101325,
      "businessContext": "Actual pressure reading from sensor in pascals.",
      "label_i18n": {
        "en": "Pressure Reading (Pa)",
        "tr": "Basınç Okuması (Pa)",
        "de": "Pressure Reading (Pa)",
        "fr": "Pressure Reading (Pa)",
        "es": "Pressure Reading (Pa)",
        "ar": "Pressure Reading (Pa)"
      },
      "businessContext_i18n": {
        "en": "Actual pressure reading from sensor in pascals.",
        "tr": "Sensörden paskal cinsinden gerçek basınç okuması."
      }
    },
    {
      "id": "calibrationFactor",
      "label": "Calibration Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Multiplier for sensor calibration, typically 0.95-1.05.",
      "label_i18n": {
        "en": "Calibration Factor",
        "tr": "Kalibrasyon Faktörü",
        "de": "Kalibrierfaktor",
        "fr": "Calibration Factor",
        "es": "Calibration Factor",
        "ar": "Calibration Factor"
      },
      "businessContext_i18n": {
        "en": "Multiplier for sensor calibration, typically 0.95-1.05.",
        "tr": "Sensör kalibrasyonu için çarpan, tipik olarak 0,95-1,05."
      }
    },
    {
      "id": "sensorMaxPa",
      "label": "Sensor Full Scale (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 100000,
      "businessContext": "Maximum pressure rating of the sensor.",
      "label_i18n": {
        "en": "Sensor Full Scale (Pa)",
        "tr": "Sensör Tam Ölçek (Pa)",
        "de": "Sensor Full Scale (Pa)",
        "fr": "Sensor Full Scale (Pa)",
        "es": "Sensor Full Scale (Pa)",
        "ar": "Sensor Full Scale (Pa)"
      },
      "businessContext_i18n": {
        "en": "Maximum pressure rating of the sensor.",
        "tr": "Sensörün maksimum basınç değeri."
      }
    },
    {
      "id": "sensorAccuracyClass",
      "label": "Sensor Accuracy Class",
      "type": "number",
      "unit": "% FS",
      "default": 0.5,
      "businessContext": "Accuracy as a percentage of full scale (e.g., 0.5 for 0.5% FS).",
      "label_i18n": {
        "en": "Sensor Accuracy Class",
        "tr": "Sensör Doğruluk Sınıfı",
        "de": "Sensor Accuracy Class",
        "fr": "Sensor Accuracy Class",
        "es": "Sensor Accuracy Class",
        "ar": "Sensor Accuracy Class"
      },
      "businessContext_i18n": {
        "en": "Accuracy as a percentage of full scale (e.g., 0.5 for 0.5% FS).",
        "tr": "Tam ölçeğin yüzdesi olarak doğruluk (örn. %0,5 FS için 0,5)."
      }
    },
    {
      "id": "outputDecimals",
      "label": "Output Decimal Places",
      "type": "number",
      "unit": "digits",
      "default": 4,
      "businessContext": "Number of decimal digits for psi output; must be integer >=0.",
      "label_i18n": {
        "en": "Output Decimal Places",
        "tr": "Çıktı Ondalık Basamakları",
        "de": "Output Decimal Places",
        "fr": "Output Decimal Places",
        "es": "Output Decimal Places",
        "ar": "Output Decimal Places"
      },
      "businessContext_i18n": {
        "en": "Number of decimal digits for psi output; must be integer >=0.",
        "tr": "psi çıktısı için ondalık basamak sayısı; tamsayı >=0 olmalıdır."
      }
    }
  ],
  "formulas": {
    "rawPsi": "pressurePascals / 6894.76 * calibrationFactor",
    "uncertaintyPsi": "(sensorMaxPa * sensorAccuracyClass / 100) / 6894.76",
    "relativeUncertaintyPercent": "rawPsi !== 0 ? (uncertaintyPsi / rawPsi) * 100 : 0"
  },
  "outputs": {
    "primary": "relativeUncertaintyPercent",
    "breakdown": [
      "rawPsi",
      "uncertaintyPsi",
      "relativeUncertaintyPercent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "primaryOutput",
    "unit": "%",
    "breakdownUnits": {
      "relativeUncertaintyPercent": "%"
    }
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,

{
  "toolName": "plastic-footprint-calculator",
  "inputs": [
    {
      "id": "productionVolume",
      "label": "Production Volume",
      "type": "number",
      "unit": "pieces",
      "default": 1000,
      "businessContext": "Total number of units produced",
      "label_i18n": {
        "en": "Production Volume",
        "tr": "Üretim Hacmi",
        "de": "Production Volume",
        "fr": "Production Volume",
        "es": "Production Volume",
        "ar": "Production Volume"
      },
      "businessContext_i18n": {
        "en": "Total number of units produced",
        "tr": "Üretilen toplam birim sayısı"
      }
    },
    {
      "id": "plasticPerUnit",
      "label": "Plastic per Unit",
      "type": "number",
      "unit": "g",
      "default": 10,
      "businessContext": "Weight of plastic used per unit product",
      "label_i18n": {
        "en": "Plastic per Unit",
        "tr": "Birim Başına Plastik",
        "de": "Plastic per Unit",
        "fr": "Plastic per Unit",
        "es": "Plastic per Unit",
        "ar": "Plastic per Unit"
      },
      "businessContext_i18n": {
        "en": "Weight of plastic used per unit product",
        "tr": "Birim ürün başına kullanılan plastik ağırlığı"
      }
    },
    {
      "id": "recycleRate",
      "label": "Recycling Rate",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage of plastic that is recycled content",
      "label_i18n": {
        "en": "Recycling Rate",
        "tr": "Geri Dönüşüm Oranı",
        "de": "Recyclingquote",
        "fr": "Recycling Rate",
        "es": "Recycling Rate",
        "ar": "Recycling Rate"
      },
      "businessContext_i18n": {
        "en": "Percentage of plastic that is recycled content",
        "tr": "Geri dönüştürülmüş içerik yüzdesi"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Production Waste",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of plastic wasted during manufacturing",
      "label_i18n": {
        "en": "Production Waste",
        "tr": "Üretim Firesi",
        "de": "Production Waste",
        "fr": "Production Waste",
        "es": "Production Waste",
        "ar": "Production Waste"
      },
      "businessContext_i18n": {
        "en": "Percentage of plastic wasted during manufacturing",
        "tr": "Üretim sırasında israf edilen plastik yüzdesi"
      }
    },
    {
      "id": "carbonFactor",
      "label": "Carbon Factor (Virgin)",
      "type": "number",
      "unit": "kgCO2/kg",
      "default": 6,
      "businessContext": "Carbon footprint of virgin plastic per kg",
      "label_i18n": {
        "en": "Carbon Factor (Virgin)",
        "tr": "Karbon Faktörü (Saf)",
        "de": "Carbon Factor (Virgin)",
        "fr": "Carbon Factor (Virgin)",
        "es": "Carbon Factor (Virgin)",
        "ar": "Carbon Factor (Virgin)"
      },
      "businessContext_i18n": {
        "en": "Carbon footprint of virgin plastic per kg",
        "tr": "Saf plastiğin kg başına karbon ayak izi"
      }
    },
    {
      "id": "recycledEmissionReduction",
      "label": "Emission Reduction (Recycled)",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Percentage reduction in carbon footprint for recycled plastic",
      "label_i18n": {
        "en": "Emission Reduction (Recycled)",
        "tr": "Emisyon Azaltımı (Geri Dönüştürülmüş)",
        "de": "Emission Reduction (Recycled)",
        "fr": "Emission Reduction (Recycled)",
        "es": "Emission Reduction (Recycled)",
        "ar": "Emission Reduction (Recycled)"
      },
      "businessContext_i18n": {
        "en": "Percentage reduction in carbon footprint for recycled plastic",
        "tr": "Geri dönüştürülmüş plastik için karbon ayak izindeki azalma yüzdesi"
      }
    }
  ],
  "formulas": {
    "totalPlasticKg": "(productionVolume * plasticPerUnit) / 1000",
    "recycledPlasticKg": "totalPlasticKg * recycleRate / 100",
    "wasteKg": "totalPlasticKg * wasteFactor / 100",
    "totalCarbon": "totalPlasticKg * carbonFactor * (1 - (recycleRate / 100) * (recycledEmissionReduction / 100))"
  },
  "outputs": {
    "primary": "totalCarbon",
    "breakdown": [
      "totalPlasticKg",
      "recycledPlasticKg",
      "wasteKg"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCarbon",
    "unit": "pieces",
    "breakdownUnits": {
      "totalPlasticKg": "kg",
      "recycledPlasticKg": "kg",
      "wasteKg": "kg"
    }
  },
  "category": "Sürdürülebilirlik",
  "sector": "Çevre & Sürdürülebilirlik",

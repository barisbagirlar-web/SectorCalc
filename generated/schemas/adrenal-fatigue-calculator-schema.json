{
  "toolName": "adrenal-fatigue-calculator",
  "inputs": [
    {
      "id": "shift_length",
      "label": "Shift Length",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Duration of a single work shift in hours.",
      "label_i18n": {
        "en": "Shift Length",
        "tr": "Shift Length",
        "de": "Shift Length",
        "fr": "Shift Length",
        "es": "Shift Length",
        "ar": "Shift Length"
      }
    },
    {
      "id": "consecutive_shifts",
      "label": "Consecutive Shifts",
      "type": "number",
      "unit": "count",
      "default": 5,
      "businessContext": "Number of consecutive work days without a day off.",
      "label_i18n": {
        "en": "Consecutive Shifts",
        "tr": "Consecutive Shifts",
        "de": "Consecutive Shifts",
        "fr": "Consecutive Shifts",
        "es": "Consecutive Shifts",
        "ar": "Consecutive Shifts"
      }
    },
    {
      "id": "rest_between_shifts",
      "label": "Rest Between Shifts",
      "type": "number",
      "unit": "hours",
      "default": 16,
      "businessContext": "Average rest time between end of one shift and start of next.",
      "label_i18n": {
        "en": "Rest Between Shifts",
        "tr": "Rest Between Shifts",
        "de": "Rest Between Shifts",
        "fr": "Rest Between Shifts",
        "es": "Rest Between Shifts",
        "ar": "Rest Between Shifts"
      }
    },
    {
      "id": "noise_level",
      "label": "Noise Level",
      "type": "number",
      "unit": "dB",
      "default": 70,
      "businessContext": "Average workplace noise exposure in decibels.",
      "label_i18n": {
        "en": "Noise Level",
        "tr": "Noise Level",
        "de": "Noise Level",
        "fr": "Noise Level",
        "es": "Noise Level",
        "ar": "Noise Level"
      }
    },
    {
      "id": "temperature",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 22,
      "businessContext": "Workplace temperature in Celsius.",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ambient Temperature",
        "de": "Ambient Temperature",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      }
    },
    {
      "id": "load_factor",
      "label": "Workload Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Physical and mental workload intensity factor (1.0 = normal, >1.0 = high).",
      "label_i18n": {
        "en": "Workload Factor",
        "tr": "Workload Factor",
        "de": "Workload Factor",
        "fr": "Workload Factor",
        "es": "Workload Factor",
        "ar": "Workload Factor"
      }
    }
  ],
  "formulas": {
    "fatigue_index": "(shift_length * load_factor * Math.log(noise_level + 1) * Math.sqrt(temperature ** 2 + 1) / (rest_between_shifts + 1)) + consecutive_shifts * 2",
    "shift_contribution": "shift_length * load_factor / (rest_between_shifts + 1) * 10",
    "environment_contribution": "Math.log(noise_level + 1) * Math.sqrt(temperature ** 2 + 1) * 5",
    "cumulative_contribution": "consecutive_shifts * 2"
  },
  "outputs": {
    "primary": "fatigue_index",
    "breakdown": [
      {
        "id": "shift_contribution",
        "label": "Shift Contribution",
        "unit": "points",
        "description": "Contribution from shift length and workload relative to rest."
      },
      {
        "id": "environment_contribution",
        "label": "Environment Contribution",
        "unit": "points",
        "description": "Contribution from noise and temperature stressors."
      },
      {
        "id": "cumulative_contribution",
        "label": "Cumulative Contribution",
        "unit": "points",
        "description": "Contribution from consecutive work days accumulation."
      }
    ]
  },
  "category": "Makine & Tasarım",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "cnc-additive-manufacturing"
}

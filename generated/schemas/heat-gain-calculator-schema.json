  "formulas": {
    "conductionHeatGain": "wallArea * wallUvalue * tempDiff + windowArea * windowUvalue * tempDiff",
    "solarHeatGain": "windowArea * windowSHGC * solarRadiation",
    "totalHeatGain": "conductionHeatGain + solarHeatGain"
  },
  "outputs": {
    "primary": "totalHeatGain",
    "breakdown": [
      "conductionHeatGain",

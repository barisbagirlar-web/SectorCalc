{
  "toolName": "skin-age-calculator",
  "inputs": [
    {
      "id": "chronologicalAge",
      "label": "Chronological Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Actual age in years"
    },
    {
      "id": "sunExposure",
      "label": "Daily Sun Exposure",
      "type": "number",
      "unit": "hours",
      "default": 2,
      "businessContext": "Average hours of direct sun exposure per day"
    },
    {
      "id": "smokingYears",
      "label": "Smoking Years",
      "type": "number",
      "unit": "years",
      "default": 0,
      "businessContext": "Number of years as a smoker"
    },
    {
      "id": "skincareScore",
      "label": "Skincare Routine Score",
      "type": "number",
      "unit": "points",
      "default": 5,
      "businessContext": "Effectiveness of skincare routine on a scale of 1-10"
    },
    {
      "id": "sleepHours",
      "label": "Sleep Duration",
      "type": "number",
      "unit": "hours",
      "default": 7,
      "businessContext": "Average nightly sleep in hours"
    },
    {
      "id": "stressLevel",
      "label": "Stress Level",
      "type": "number",
      "unit": "scale",
      "default": 3,
      "businessContext": "Perceived stress on a scale of 1-10"
    }
  ],
  "formulas": {
    "estimatedSkinAge": "chronologicalAge + Math.max(0, (sunExposure - 1) * 0.5) + smokingYears * 0.3 - Math.max(0, (skincareScore - 5) * 0.2) + (sleepHours < 7 ? (7 - sleepHours) * 0.5 : sleepHours > 9 ? (sleepHours - 9) * 0.2 : 0) + (stressLevel > 5 ? (stressLevel - 5) * 0.3 : 0)",
    "sunDamage": "Math.max(0, (sunExposure - 1) * 0.5)",
    "smokingImpact": "smokingYears * 0.3",
    "skincareBenefit": "Math.max(0, (skincareScore - 5) * 0.2)",
    "sleepImpact": "(sleepHours < 7 ? (7 - sleepHours) * 0.5 : sleepHours > 9 ? (sleepHours - 9) * 0.2 : 0)",
    "stressImpact": "stressLevel > 5 ? (stressLevel - 5) * 0.3 : 0"
  },
  "outputs": {
    "primary": "estimatedSkinAge",
    "breakdown": [
      "sunDamage",
      "smokingImpact",
      "skincareBenefit",
      "sleepImpact",
      "stressImpact"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

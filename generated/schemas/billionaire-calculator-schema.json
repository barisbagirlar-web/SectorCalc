      "label": "Hedef Net Varlık ($)",
      "type": "number",
      "unit": "$",
      "default": 1000000000,
      "businessContext": "Ulaşılmak istenen servet miktarı (varsayılan 1 milyar)",
      "label_i18n": {
        "en": "Hedef Net Varlık ($)",
        "tr": "Hedef Net Varlık ($)",
        "de": "Hedef Net Varlık ($)",
        "fr": "Hedef Net Varlık ($)",
        "es": "Hedef Net Varlık ($)",
        "ar": "Hedef Net Varlık ($)"
      }
    }
  ],
  "formulas": {
    "r": "annualReturn / 100",
    "S": "annualIncome * (savingsRate / 100)",
    "yearsToBillionaire": "Math.log((desiredNetWorth * r + S) / (currentNetWorth * r + S)) / Math.log(1 + r)",
    "annualSavings": "S",
    "totalContributions": "S * yearsToBillionaire",
    "totalInterestEarned": "desiredNetWorth - currentNetWorth - (S * yearsToBillionaire)"
  },
  "outputs": {
    "primary": "yearsToBillionaire",
    "breakdown": [
      "annualSavings",
      "totalContributions",
      "totalInterestEarned"
    ]
  },

    }
  ],
  "formulas": {
    "Fb": "c0*b + c1*(b**2)/2 + c2*(b**3)/3 + c3*(b**4)/4",
    "Fa": "c0*a + c1*(a**2)/2 + c2*(a**3)/3 + c3*(a**4)/4",
    "primary": "Fb - Fa"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "F(b) = c₀b + c₁b²/2 + c₂b³/3 + c₃b⁴/4 = ${Fb}",
      "F(a) = c₀a + c₁a²/2 + c₂a³/3 + c₃a⁴/4 = ${Fa}",
      "∫_a^b f(x) dx = F(b) - F(a) = ${primary}"
    ]
  },

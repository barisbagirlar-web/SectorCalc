    },
    {
      "id": "c1",
      "label": "Linear Coefficient (c₁)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "x terimi katsayısı"
    },
    {
      "id": "c2",
      "label": "Quadratic Coefficient (c₂)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "x² terimi katsayısı"
    },
    {
      "id": "c3",
      "label": "Cubic Coefficient (c₃)",

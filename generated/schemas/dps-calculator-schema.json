{
  "toolName": "dps-calculator",
  "inputs": [
    {
      "id": "dividendsTotal",
      "label": "Toplam Temettü",
      "type": "number",
      "unit": "TRY",
      "default": 100000,
      "businessContext": "Dağıtılan toplam kâr payı (TL)",
      "label_i18n": {
        "en": "Total Dividend",
        "tr": "Toplam Temettü",
        "de": "Gesamtdividende",
        "fr": "Dividende total",
        "es": "Dividendo total",
        "ar": "إجمالي الأرباح الموزعة"
      },
      "businessContext_i18n": {
        "en": "Total distributed profit (TL)",
        "tr": "Dağıtılan toplam kâr payı (TL)",
        "de": "Ausgeschütteter Gesamtgewinn (TL)",
        "fr": "Bénéfice total distribué (TL)",
        "es": "Beneficio total distribuido (TL)",
        "ar": "إجمالي الأرباح الموزعة (ليرة تركية)"
      }
    },
    {
      "id": "sharesOutstanding",
      "label": "Hisse Senedi Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 10000,
      "businessContext": "Ödenmiş sermaye hisse adedi",
      "label_i18n": {
        "en": "Number of Shares",
        "tr": "Hisse Senedi Sayısı",
        "de": "Anzahl der Aktien",
        "fr": "Nombre d'actions",
        "es": "Número de acciones",
        "ar": "عدد الأسهم"
      },
      "businessContext_i18n": {
        "en": "Number of paid-in capital shares",
        "tr": "Ödenmiş sermaye hisse adedi",
        "de": "Anzahl der Aktien des eingezahlten Kapitals",
        "fr": "Nombre d'actions du capital libéré",
        "es": "Número de acciones del capital pagado",
        "ar": "عدد أسهم رأس المال المدفوع"
      }
    },
    {
      "id": "netIncome",
      "label": "Net Kâr",
      "type": "number",
      "unit": "TRY",
      "default": 200000,
      "businessContext": "Şirketin net dönem kârı",
      "label_i18n": {
        "en": "Net Profit",
        "tr": "Net Kâr",
        "de": "Nettogewinn",
        "fr": "Bénéfice net",
        "es": "Beneficio neto",
        "ar": "صافي الربح"
      },
      "businessContext_i18n": {
        "en": "Company's net profit for the period",
        "tr": "Şirketin net dönem kârı",
        "de": "Nettogewinn des Unternehmens für den Zeitraum",
        "fr": "Bénéfice net de la période de l'entreprise",
        "es": "Beneficio neto del período de la empresa",
        "ar": "صافي ربح الشركة للفترة"
      }
    },
    {
      "id": "payoutRatio",
      "label": "Temettü Dağıtım Oranı",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Kârın dağıtılma oranı (yüzde)",
      "label_i18n": {
        "en": "Dividend Payout Ratio",
        "tr": "Temettü Dağıtım Oranı",
        "de": "Dividendenausschüttungsquote",
        "fr": "Taux de distribution des dividendes",
        "es": "Tasa de distribución de dividendos",
        "ar": "نسبة توزيع الأرباح"
      },
      "businessContext_i18n": {
        "en": "Profit distribution ratio (percent)",
        "tr": "Kârın dağıtılma oranı (yüzde)",
        "de": "Ausschüttungsquote des Gewinns (Prozent)",
        "fr": "Taux de distribution des bénéfices (pourcentage)",
        "es": "Porcentaje de distribución del beneficio",
        "ar": "نسبة توزيع الأرباح (نسبة مئوية)"
      }
    }
  ],
  "formulas": {
    "dps": "sharesOutstanding !== 0 ? dividendsTotal / sharesOutstanding : 0",
    "payoutRatioCalculated": "netIncome !== 0 ? (dividendsTotal / netIncome) * 100 : 0",
    "dpsFromPayout": "sharesOutstanding !== 0 ? (netIncome * (payoutRatio / 100)) / sharesOutstanding : 0"
  },
  "outputs": {
    "primary": "dps",
    "breakdown": [
      "payoutRatioCalculated",
      "dpsFromPayout"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dpsFromPayout",
    "unit": "TRY",
    "breakdownUnits": {
      "payoutRatioCalculated": "%"
    }
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

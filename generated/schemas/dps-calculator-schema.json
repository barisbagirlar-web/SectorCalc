{
  "toolName": "dps-calculator",
  "inputs": [
    {
      "id": "dividendsTotal",
      "label": "Toplam Temettü",
      "type": "number",
      "unit": "TRY",
      "default": 100000,
      "businessContext": "Dağıtılan toplam kâr payı (TL)",
      "label_i18n": {
        "en": "Toplam Temettü",
        "tr": "Toplam Temettü",
        "de": "Toplam Temettü",
        "fr": "Toplam Temettü",
        "es": "Toplam Temettü",
        "ar": "Toplam Temettü"
      }
    },
    {
      "id": "sharesOutstanding",
      "label": "Hisse Senedi Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 10000,
      "businessContext": "Ödenmiş sermaye hisse adedi",
      "label_i18n": {
        "en": "Hisse Senedi Sayısı",
        "tr": "Hisse Senedi Sayısı",
        "de": "Hisse Senedi Sayısı",
        "fr": "Hisse Senedi Sayısı",
        "es": "Hisse Senedi Sayısı",
        "ar": "Hisse Senedi Sayısı"
      }
    },
    {
      "id": "netIncome",
      "label": "Net Kâr",
      "type": "number",
      "unit": "TRY",
      "default": 200000,
      "businessContext": "Şirketin net dönem kârı",
      "label_i18n": {
        "en": "Net Kâr",
        "tr": "Net Kâr",
        "de": "Net Kâr",
        "fr": "Net Kâr",
        "es": "Net Kâr",
        "ar": "Net Kâr"
      }
    },
    {
      "id": "payoutRatio",
      "label": "Temettü Dağıtım Oranı",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Kârın dağıtılma oranı (yüzde)",
      "label_i18n": {
        "en": "Temettü Dağıtım Oranı",
        "tr": "Temettü Dağıtım Oranı",
        "de": "Temettü Dağıtım Oranı",
        "fr": "Temettü Dağıtım Oranı",
        "es": "Temettü Dağıtım Oranı",
        "ar": "Temettü Dağıtım Oranı"
      }
    }
  ],
  "formulas": {
    "dps": "sharesOutstanding !== 0 ? dividendsTotal / sharesOutstanding : 0",
    "payoutRatioCalculated": "netIncome !== 0 ? (dividendsTotal / netIncome) * 100 : 0",
    "dpsFromPayout": "sharesOutstanding !== 0 ? (netIncome * (payoutRatio / 100)) / sharesOutstanding : 0"
  },
  "outputs": {
    "primary": "dps",
    "breakdown": [
      "payoutRatioCalculated",
      "dpsFromPayout"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dpsFromPayout"
  },
  "category": "Diğer",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

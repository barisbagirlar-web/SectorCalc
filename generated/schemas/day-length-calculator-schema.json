      "unit": "saat",
      "default": 3,
      "businessContext": "Zaman dilimi UTC farkı (Türkiye için +3)",
      "label_i18n": {
        "en": "UTC Sapması",
        "tr": "UTC Sapması",
        "de": "UTC Sapması",
        "fr": "UTC Sapması",
        "es": "UTC Sapması",
        "ar": "UTC Sapması"
      }
    }
  ],
  "formulas": {
    "dayOfYear": "Math.floor((275 * month) / 9) - Math.floor((month + 9) / 12) * Math.floor((1 + Math.floor((year - 4 * Math.floor(year / 4) + 2) / 3)) / 30) + day - 30",
    "declination": "23.45 * Math.sin((360 / 365) * (284 + dayOfYear) * Math.PI / 180)",
    "hourAngle": "Math.acos(-Math.tan(latitude * Math.PI / 180) * Math.tan(declination * Math.PI / 180)) * 180 / Math.PI",
    "dayLength": "2 * hourAngle / 15"
  },
  "outputs": {
    "primary": "dayLength",
    "breakdown": [
      "declination",
      "hourAngle"
    ]
  },

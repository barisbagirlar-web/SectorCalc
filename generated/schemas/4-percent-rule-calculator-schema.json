  "formulas": {
    "netAnnualIncome": "desiredAnnualIncome - otherAnnualIncome",
    "requiredSavings": "netAnnualIncome / (withdrawalRate / 100)",
    "monthlyIncome": "netAnnualIncome / 12",
    "savingsGap": "requiredSavings - currentSavings"
  },
  "outputs": {
    "primary": "requiredSavings",
    "breakdown": [
      "netAnnualIncome",
      "monthlyIncome",
      "savingsGap"

{
  "toolName": "burn-rate-calculator",
  "inputs": [
    {
      "id": "cashReserves",
      "label": "Nakit Rezervi",
      "type": "number",
      "unit": "TRY",
      "default": 100000,
      "businessContext": "Mevcut toplam nakit rezervi miktarı.",
      "label_i18n": {
        "en": "Nakit Rezervi",
        "tr": "Nakit Rezervi",
        "de": "Nakit Rezervi",
        "fr": "Nakit Rezervi",
        "es": "Nakit Rezervi",
        "ar": "Nakit Rezervi"
      }
    },
    {
      "id": "monthlyFixedExpenses",
      "label": "Aylık Sabit Giderler",
      "type": "number",
      "unit": "TRY",
      "default": 20000,
      "businessContext": "Kira, maaşlar, sabit abonelikler gibi her ay düzenli ödenen giderler.",
      "label_i18n": {
        "en": "Aylık Sabit Giderler",
        "tr": "Aylık Sabit Giderler",
        "de": "Aylık Sabit Giderler",
        "fr": "Aylık Sabit Giderler",
        "es": "Aylık Sabit Giderler",
        "ar": "Aylık Sabit Giderler"
      }
    },
    {
      "id": "monthlyVariableExpenses",
      "label": "Aylık Değişken Giderler",
      "type": "number",
      "unit": "TRY",
      "default": 10000,
      "businessContext": "Pazarlama, hammadde, seyahat gibi aydan aya değişen giderler.",
      "label_i18n": {
        "en": "Aylık Değişken Giderler",
        "tr": "Aylık Değişken Giderler",
        "de": "Aylık Değişken Giderler",
        "fr": "Aylık Değişken Giderler",
        "es": "Aylık Değişken Giderler",
        "ar": "Aylık Değişken Giderler"
      }
    },
    {
      "id": "monthlyRevenue",
      "label": "Aylık Gelir",
      "type": "number",
      "unit": "TRY",
      "default": 5000,
      "businessContext": "Satışlardan veya diğer kaynaklardan elde edilen aylık toplam gelir.",
      "label_i18n": {
        "en": "Aylık Gelir",
        "tr": "Aylık Gelir",
        "de": "Aylık Gelir",
        "fr": "Aylık Gelir",
        "es": "Aylık Gelir",
        "ar": "Aylık Gelir"
      }
    }
  ],
  "formulas": {
    "totalExpenses": "monthlyFixedExpenses + monthlyVariableExpenses",
    "grossBurnRate": "monthlyFixedExpenses + monthlyVariableExpenses",
    "netBurnRate": "monthlyFixedExpenses + monthlyVariableExpenses - monthlyRevenue",
    "runway": "netBurnRate > 0 ? cashReserves / netBurnRate : null"
  },
  "outputs": {
    "primary": "runway",
    "breakdown": [
      "totalExpenses",
      "grossBurnRate",
      "netBurnRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "runway"
  },
  "category": "Diğer",
  "sector": "Finans & Muhasebe",

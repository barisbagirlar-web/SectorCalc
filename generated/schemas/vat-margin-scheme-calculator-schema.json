    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Standard VAT rate percentage applicable to the goods.",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "VAT Rate",
        "fr": "VAT Rate",
        "es": "VAT Rate",
        "ar": "VAT Rate"
      },
      "businessContext_i18n": {
        "en": "Standard VAT rate percentage applicable to the goods.",
        "tr": "Mala uygulanan standart KDV oranı yüzdesi."
      }
    },
    {
      "id": "allowableCosts",
      "label": "Allowable Costs",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Costs directly attributable to the sale that reduce the margin (e.g., refurbishment, transport).",
      "label_i18n": {
        "en": "Allowable Costs",
        "tr": "İzin Verilen Maliyetler",
        "de": "Allowable Costs",
        "fr": "Allowable Costs",
        "es": "Allowable Costs",
        "ar": "Allowable Costs"
      },
      "businessContext_i18n": {
        "en": "Costs directly attributable to the sale that reduce the margin (e.g., refurbishment, transport).",
        "tr": "Satışa doğrudan atfedilebilen ve marjı azaltan maliyetler (ör. yenileme, nakliye)."
      }
    }
  ],
  "formulas": {
    "grossMargin": "sellingPrice - purchasePrice - allowableCosts",
    "vatDue": "grossMargin * vatRate / (100 + vatRate)",
    "netMargin": "grossMargin - vatDue"
  },
  "outputs": {
    "primary": "vatDue",
    "breakdown": [
      "grossMargin",
      "vatDue",
      "netMargin"
    ],

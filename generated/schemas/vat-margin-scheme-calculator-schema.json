{
  "toolName": "vat-margin-scheme-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Purchase Price",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Price paid to acquire the goods (VAT-inclusive).",
      "label_i18n": {
        "en": "Purchase Price",
        "tr": "Purchase Price",
        "de": "Purchase Price",
        "fr": "Purchase Price",
        "es": "Purchase Price",
        "ar": "Purchase Price"
      }
    },
    {
      "id": "sellingPrice",
      "label": "Selling Price",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Price charged to the customer (VAT-inclusive).",
      "label_i18n": {
        "en": "Selling Price",
        "tr": "Selling Price",
        "de": "Selling Price",
        "fr": "Selling Price",
        "es": "Selling Price",
        "ar": "Selling Price"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Standard VAT rate percentage applicable to the goods.",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "VAT Rate",
        "de": "VAT Rate",
        "fr": "VAT Rate",
        "es": "VAT Rate",
        "ar": "VAT Rate"
      }
    },
    {
      "id": "allowableCosts",
      "label": "Allowable Costs",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Costs directly attributable to the sale that reduce the margin (e.g., refurbishment, transport).",
      "label_i18n": {
        "en": "Allowable Costs",
        "tr": "Allowable Costs",
        "de": "Allowable Costs",
        "fr": "Allowable Costs",
        "es": "Allowable Costs",
        "ar": "Allowable Costs"
      }
    }
  ],
  "formulas": {
    "grossMargin": "sellingPrice - purchasePrice - allowableCosts",
    "vatDue": "grossMargin * vatRate / (100 + vatRate)",
    "netMargin": "grossMargin - vatDue"
  },
  "outputs": {
    "primary": "vatDue",
    "breakdown": [
      "grossMargin",
      "vatDue",
      "netMargin"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netMargin"
  },

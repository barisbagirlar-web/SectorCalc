      "id": "sellingPrice",
      "label": "Selling Price",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Price charged to the customer (VAT-inclusive).",
      "label_i18n": {
        "en": "Selling Price",
        "tr": "Satış fiyatı",
        "de": "Selling Price",
        "fr": "Selling Price",
        "es": "Selling Price",
        "ar": "Selling Price"
      },

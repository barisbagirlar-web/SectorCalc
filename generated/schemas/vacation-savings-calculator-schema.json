{
  "toolName": "vacation-savings-calculator",
  "inputs": [
    {
      "id": "targetAmount",
      "label": "Target Savings Amount",
      "type": "number",
      "unit": "currency",
      "default": 5000,
      "businessContext": "Total amount needed for vacation",
      "label_i18n": {
        "en": "Target Savings Amount",
        "tr": "Hedef Tasarruf Tutarı",
        "de": "Zielsparbetrag",
        "fr": "Montant d'épargne cible",
        "es": "Target Savings Amount",
        "ar": "Target Savings Amount"
      },
      "businessContext_i18n": {
        "en": "Total amount needed for vacation",
        "tr": "Tatil için gereken toplam miktar",
        "de": "Gesamtbetrag für den Urlaub benötigt",
        "fr": "Montant total nécessaire pour les vacances"
      }
    },
    {
      "id": "currentSavings",
      "label": "Current Savings",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "Amount already saved",
      "label_i18n": {
        "en": "Current Savings",
        "tr": "Mevcut Birikimler",
        "de": "Aktuelle Ersparnisse",
        "fr": "Épargne actuelle",
        "es": "Ahorros actuales",
        "ar": "Current Savings"
      },
      "businessContext_i18n": {
        "en": "Amount already saved",
        "tr": "Zaten biriktirilmiş miktar",
        "de": "Bereits gesparter Betrag",
        "fr": "Montant déjà épargné"
      }
    },
    {
      "id": "monthlyContribution",
      "label": "Monthly Contribution",
      "type": "number",
      "unit": "currency/month",
      "default": 500,
      "businessContext": "Amount added to savings each month",
      "label_i18n": {
        "en": "Monthly Contribution",
        "tr": "Aylık Katkı",
        "de": "Monatlicher Beitrag",
        "fr": "Cotisation mensuelle",
        "es": "Aporte mensual",
        "ar": "Monthly Contribution"
      },
      "businessContext_i18n": {
        "en": "Amount added to savings each month",
        "tr": "Her ay birikime eklenen miktar",
        "de": "Monatlicher Sparbetrag",
        "fr": "Montant ajouté à l'épargne chaque mois"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Expected annual return on savings (e.g., savings account interest)",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Yıllık Faiz Oranı",
        "de": "Jährlicher Zinssatz",
        "fr": "Taux d'intérêt annuel",
        "es": "Tasa de Interés Anual",
        "ar": "Annual Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Expected annual return on savings (e.g., savings account interest)",
        "tr": "Birikimlerden beklenen yıllık getiri (ör. tasarruf hesabı faizi)",
        "de": "Erwartete jährliche Rendite auf Ersparnisse (z. B. Sparzins)",
        "fr": "Rendement annuel attendu sur l'épargne (ex. intérêts du compte d'épargne)"
      }
    },
    {
      "id": "monthsUntilVacation",
      "label": "Months Until Vacation",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Time remaining before vacation",
      "label_i18n": {
        "en": "Months Until Vacation",
        "tr": "Tatile Kalan Ay",
        "de": "Monate bis zum Urlaub",
        "fr": "Mois avant les vacances",
        "es": "Months Until Vacation",
        "ar": "Months Until Vacation"
      },
      "businessContext_i18n": {
        "en": "Time remaining before vacation",
        "tr": "Tatile kalan süre",
        "de": "Verbleibende Zeit vor dem Urlaub",
        "fr": "Temps restant avant les vacances"
      }
    }
  ],
  "formulas": {
    "totalSavings": "currentSavings * (1 + (annualInterestRate/100/12 + 1e-10)) ** monthsUntilVacation + monthlyContribution * (((1 + (annualInterestRate/100/12 + 1e-10)) ** monthsUntilVacation - 1) / (annualInterestRate/100/12 + 1e-10))",
    "totalContributions": "monthlyContribution * monthsUntilVacation",
    "interestEarned": "totalSavings - currentSavings - totalContributions",
    "surplusShortfall": "totalSavings - targetAmount"
  },
  "outputs": {
    "primary": "surplusShortfall",
    "breakdown": [
      "totalSavings",
      "totalContributions",
      "interestEarned"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "surplusShortfall",
    "unit": "currency"
  },
  "category": "Diğer",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "electrical-power-systems",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "diger",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

  "formulas": {
    "distillateFlowRate": "feedFlow * (feedComposition - bottomsComposition) / (distillateComposition - bottomsComposition)",
    "bottomFlowRate": "feedFlow * (distillateComposition - feedComposition) / (distillateComposition - bottomsComposition)",
    "minimumRefluxRatio": "(1 / (relativeVolatility - 1)) * ((distillateComposition / feedComposition) - relativeVolatility * (1 - distillateComposition) / (1 - feedComposition))"
  },
  "outputs": {
    "primary": "distillateFlowRate",
    "breakdown": [
      "bottomFlowRate",
      "minimumRefluxRatio",
      "minimumTheoreticalPlates"
    ],

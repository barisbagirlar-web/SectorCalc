{
  "toolName": "convertible-note-calculator",
  "inputs": [
    {
      "id": "investmentAmount",
      "label": "Investment Amount",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Amount invested in the convertible note.",
      "label_i18n": {
        "en": "Investment Amount",
        "tr": "Investment Amount",
        "de": "Investment Amount",
        "fr": "Investment Amount",
        "es": "Investment Amount",
        "ar": "Investment Amount"
      }
    },
    {
      "id": "discountRate",
      "label": "Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Discount applied to next round price per share.",
      "label_i18n": {
        "en": "Discount Rate",
        "tr": "Discount Rate",
        "de": "Discount Rate",
        "fr": "Discount Rate",
        "es": "Discount Rate",
        "ar": "Discount Rate"
      }
    },
    {
      "id": "valuationCap",
      "label": "Valuation Cap",
      "type": "number",
      "unit": "USD",
      "default": 5000000,
      "businessContext": "Maximum company valuation for conversion price cap.",
      "label_i18n": {
        "en": "Valuation Cap",
        "tr": "Valuation Cap",
        "de": "Valuation Cap",
        "fr": "Valuation Cap",
        "es": "Valuation Cap",
        "ar": "Valuation Cap"
      }
    },
    {
      "id": "nextRoundPricePerShare",
      "label": "Next Round Price Per Share",
      "type": "number",
      "unit": "USD/share",
      "default": 1,
      "businessContext": "Price per share in the qualified financing round.",
      "label_i18n": {
        "en": "Next Round Price Per Share",
        "tr": "Next Round Price Per Share",
        "de": "Next Round Price Per Share",
        "fr": "Next Round Price Per Share",
        "es": "Next Round Price Per Share",
        "ar": "Next Round Price Per Share"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "% p.a.",
      "default": 5,
      "businessContext": "Annual simple interest rate accrued on the note.",
      "label_i18n": {
        "en": "Interest Rate",
        "tr": "Interest Rate",
        "de": "Interest Rate",
        "fr": "Interest Rate",
        "es": "Interest Rate",
        "ar": "Interest Rate"
      }
    },
    {
      "id": "maturity",
      "label": "Maturity",
      "type": "number",
      "unit": "years",
      "default": 2,
      "businessContext": "Time until conversion, used to calculate accrued interest.",
      "label_i18n": {
        "en": "Maturity",
        "tr": "Maturity",
        "de": "Maturity",
        "fr": "Maturity",
        "es": "Maturity",
        "ar": "Maturity"
      }
    },
    {
      "id": "preMoneyFullyDilutedShares",
      "label": "Pre-Money Fully Diluted Shares",
      "type": "number",
      "unit": "shares",
      "default": 10000000,
      "businessContext": "Number of fully diluted shares before the next round.",
      "label_i18n": {
        "en": "Pre-Money Fully Diluted Shares",
        "tr": "Pre-Money Fully Diluted Shares",
        "de": "Pre-Money Fully Diluted Shares",
        "fr": "Pre-Money Fully Diluted Shares",
        "es": "Pre-Money Fully Diluted Shares",
        "ar": "Pre-Money Fully Diluted Shares"
      }
    }
  ],
  "formulas": {
    "accruedPrincipal": "investmentAmount * (1 + interestRate/100 * maturity)",
    "discountPrice": "nextRoundPricePerShare * (1 - discountRate/100)",
    "capPrice": "valuationCap / preMoneyFullyDilutedShares"
  },
  "outputs": {
    "primary": "capPrice",
    "breakdown": [
      "conversionPrice",
      "ownershipPercentage"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "ownershipPercentage"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "conversion",

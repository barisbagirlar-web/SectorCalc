{
  "toolName": "sleep-efficiency-calculator",
  "inputs": [
    {
      "id": "timeInBed",
      "label": "Total Time in Bed (minutes)",
      "type": "number",
      "unit": "min",
      "default": 480,
      "businessContext": "Time from going to bed until final awakening.",
      "label_i18n": {
        "en": "Total Time in Bed (minutes)",
        "tr": "Total Time in Bed (minutes)",
        "de": "Total Time in Bed (minutes)",
        "fr": "Total Time in Bed (minutes)",
        "es": "Total Time in Bed (minutes)",
        "ar": "Total Time in Bed (minutes)"
      }
    },
    {
      "id": "sleepLatency",
      "label": "Sleep Latency (minutes)",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Time taken to fall asleep initially.",
      "label_i18n": {
        "en": "Sleep Latency (minutes)",
        "tr": "Sleep Latency (minutes)",
        "de": "Sleep Latency (minutes)",
        "fr": "Sleep Latency (minutes)",
        "es": "Sleep Latency (minutes)",
        "ar": "Sleep Latency (minutes)"
      }
    },
    {
      "id": "waso",
      "label": "Wake After Sleep Onset (minutes)",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Total time spent awake during the night after initially falling asleep.",
      "label_i18n": {
        "en": "Wake After Sleep Onset (minutes)",
        "tr": "Wake After Sleep Onset (minutes)",
        "de": "Wake After Sleep Onset (minutes)",
        "fr": "Wake After Sleep Onset (minutes)",
        "es": "Wake After Sleep Onset (minutes)",
        "ar": "Wake After Sleep Onset (minutes)"
      }
    },
    {
      "id": "awakenings",
      "label": "Number of Awakenings",
      "type": "number",
      "unit": "count",
      "default": 0,
      "businessContext": "Count of distinct awakenings during the night.",
      "label_i18n": {
        "en": "Number of Awakenings",
        "tr": "Number of Awakenings",
        "de": "Number of Awakenings",
        "fr": "Number of Awakenings",
        "es": "Number of Awakenings",
        "ar": "Number of Awakenings"
      }
    }
  ],
  "formulas": {
    "totalSleepTime": "timeInBed - sleepLatency - waso",
    "sleepEfficiency": "(totalSleepTime / timeInBed) * 100",
    "qualityScore": "sleepEfficiency - awakenings * 2"
  },
  "outputs": {
    "primary": "sleepEfficiency",
    "breakdown": [

{
  "toolName": "life-insurance-needs-calculator",
  "inputs": [
    {
      "id": "annual_income",
      "label": "Annual Income",
      "type": "number",
      "unit": "currency",
      "default": 50000,
      "businessContext": "The policyholder's current annual after-tax income that needs replacement.",
      "label_i18n": {
        "en": "Annual Income",
        "tr": "Annual Income",
        "de": "Annual Income",
        "fr": "Annual Income",
        "es": "Annual Income",
        "ar": "Annual Income"
      }
    },
    {
      "id": "years_needed",
      "label": "Years of Need",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "Number of years the dependents will require income replacement.",
      "label_i18n": {
        "en": "Years of Need",
        "tr": "Years of Need",
        "de": "Years of Need",
        "fr": "Years of Need",
        "es": "Years of Need",
        "ar": "Years of Need"
      }
    },
    {
      "id": "current_savings",
      "label": "Current Savings & Investments",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "Total liquid assets that can be used toward future needs.",
      "label_i18n": {
        "en": "Current Savings & Investments",
        "tr": "Current Savings & Investments",
        "de": "Current Savings & Investments",
        "fr": "Current Savings & Investments",
        "es": "Current Savings & Investments",
        "ar": "Current Savings & Investments"
      }
    },
    {
      "id": "outstanding_debts",
      "label": "Outstanding Debts (e.g., mortgage, loans)",
      "type": "number",
      "unit": "currency",
      "default": 150000,
      "businessContext": "Total debts that must be paid off upon death.",
      "label_i18n": {
        "en": "Outstanding Debts (e.g., mortgage, loans)",
        "tr": "Outstanding Debts (e.g., mortgage, loans)",
        "de": "Outstanding Debts (e.g., mortgage, loans)",
        "fr": "Outstanding Debts (e.g., mortgage, loans)",
        "es": "Outstanding Debts (e.g., mortgage, loans)",
        "ar": "Outstanding Debts (e.g., mortgage, loans)"
      }
    },
    {
      "id": "education_expenses",
      "label": "Future Education Expenses",
      "type": "number",
      "unit": "currency",
      "default": 50000,
      "businessContext": "Estimated total cost for children's education.",
      "label_i18n": {
        "en": "Future Education Expenses",
        "tr": "Future Education Expenses",
        "de": "Future Education Expenses",
        "fr": "Future Education Expenses",
        "es": "Future Education Expenses",
        "ar": "Future Education Expenses"
      }
    },
    {
      "id": "final_expenses",
      "label": "Final Expenses (funeral, estate settlement)",
      "type": "number",
      "unit": "currency",
      "default": 20000,
      "businessContext": "Estimated cost for funeral and estate settlement.",
      "label_i18n": {
        "en": "Final Expenses (funeral, estate settlement)",
        "tr": "Final Expenses (funeral, estate settlement)",
        "de": "Final Expenses (funeral, estate settlement)",
        "fr": "Final Expenses (funeral, estate settlement)",
        "es": "Final Expenses (funeral, estate settlement)",
        "ar": "Final Expenses (funeral, estate settlement)"
      }
    }
  ],
  "formulas": {
    "income_replacement": "annual_income * years_needed",
    "total_needs": "income_replacement + outstanding_debts + education_expenses + final_expenses",
    "recommended_coverage": "total_needs - current_savings"
  },
  "outputs": {
    "primary": "recommended_coverage",
    "breakdown": [
      "income_replacement",
      "outstanding_debts",
      "education_expenses",
      "final_expenses",
      "total_needs",
      "current_savings",
      "recommended_coverage"
    ],

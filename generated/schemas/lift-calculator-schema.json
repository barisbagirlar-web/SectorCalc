    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.5,
      "businessContext": "Safety factor for mechanical design",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Güvenlik Faktörü",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",

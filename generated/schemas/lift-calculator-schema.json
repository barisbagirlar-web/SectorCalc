        "tr": "Mekanik tasarım için güvenlik faktörü"
      }
    }
  ],
  "formulas": {
    "counterweightMass": "counterweightRatio * (carMass + loadMass)",
    "gravitationalForce": "(carMass + loadMass - counterweightMass) * 9.81",
    "inertialForce": "(carMass + loadMass + counterweightMass) * acceleration",
    "totalForce": "gravitationalForce + inertialForce + frictionForce",
    "requiredForce": "totalForce * safetyFactor"
  },
  "outputs": {
    "primary": "requiredForce",
    "breakdown": [
      "counterweightMass",
      "gravitationalForce",
      "inertialForce",
      "totalForce"
    ],

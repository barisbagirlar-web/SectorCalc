{
  "toolName": "segment-area-calculator",
  "inputs": [
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "The radius of the circle from which the segment is taken."
    },
    {
      "id": "centralAngle",
      "label": "Central Angle",
      "type": "number",
      "unit": "°",
      "default": 90,
      "businessContext": "The central angle of the segment in degrees."
    },
    {
      "id": "scaleFactor",
      "label": "Scale Factor",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "Factor to account for safety or overage, e.g., 1.1 for 10% extra."
    },
    {
      "id": "numberOfSegments",
      "label": "Number of Segments",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of identical segments to calculate total area."
    }
  ],
  "formulas": {
    "thetaRad": "centralAngle * Math.PI / 180",
    "areaSingle": "0.5 * radius ** 2 * (thetaRad - Math.sin(thetaRad))",
    "chordLength": "2 * radius * Math.sin(thetaRad / 2)",
    "arcLength": "radius * thetaRad",
    "height": "radius * (1 - Math.cos(thetaRad / 2))",
    "totalArea": "areaSingle * numberOfSegments * scaleFactor"
  },
  "outputs": {
    "primary": "totalArea",
    "breakdown": [
      "areaSingle",
      "chordLength",
      "arcLength",
      "height",
      "thetaRad"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

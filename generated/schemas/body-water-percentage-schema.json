{
  "toolName": "body-water-percentage",
  "inputs": [
    {
      "id": "gender",
      "label": "Gender (Male=1, Female=0)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Biyolojik cinsiyet (1: Erkek, 0: Kadın)"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Yaş (yıl)"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Boy (cm)"
    },
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Ağırlık (kg)"
    }
  ],
  "formulas": {
    "totalBodyWater": "gender * (2.447 - 0.09156 * age + 0.1074 * height + 0.3362 * weight) + (1 - gender) * (-2.097 + 0.1069 * height + 0.2466 * weight)",
    "bodyWaterPercentage": "(gender * (2.447 - 0.09156 * age + 0.1074 * height + 0.3362 * weight) + (1 - gender) * (-2.097 + 0.1069 * height + 0.2466 * weight)) / weight * 100"
  },
  "outputs": {
    "primary": "bodyWaterPercentage",
    "breakdown": [
      "totalBodyWater"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

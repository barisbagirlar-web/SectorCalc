{
  "toolName": "sep-ira-calculator",
  "inputs": [
    {
      "id": "annualCompensation",
      "label": "Annual Compensation",
      "type": "number",
      "unit": "$",
      "default": 100000,
      "businessContext": "Total compensation from employment or net earnings from self-employment (before any contribution).",
      "label_i18n": {
        "en": "Annual Compensation",
        "tr": "Annual Compensation",
        "de": "Annual Compensation",
        "fr": "Annual Compensation",
        "es": "Annual Compensation",
        "ar": "Annual Compensation"
      }
    },
    {
      "id": "contributionRatePercent",
      "label": "Contribution Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "The percentage of compensation you contribute to the SEP IRA, up to 25% for employees and effectively lower for self-employed.",
      "label_i18n": {
        "en": "Contribution Rate (%)",
        "tr": "Contribution Rate (%)",
        "de": "Contribution Rate (%)",
        "fr": "Contribution Rate (%)",
        "es": "Contribution Rate (%)",
        "ar": "Contribution Rate (%)"
      }
    },
    {
      "id": "isSelfEmployed",
      "label": "Self-Employed (0/1)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Enter 1 if you are self-employed (the calculation adjusts for self-employment), otherwise 0 for employee.",
      "label_i18n": {
        "en": "Self-Employed (0/1)",
        "tr": "Self-Employed (0/1)",
        "de": "Self-Employed (0/1)",
        "fr": "Self-Employed (0/1)",
        "es": "Self-Employed (0/1)",
        "ar": "Self-Employed (0/1)"
      }
    },
    {
      "id": "contributionLimit",
      "label": "IRS Contribution Limit",
      "type": "number",
      "unit": "$",
      "default": 66000,
      "businessContext": "The maximum annual contribution limit set by the IRS (e.g., $66,000 for 2023).",
      "label_i18n": {
        "en": "IRS Contribution Limit",
        "tr": "IRS Contribution Limit",
        "de": "IRS Contribution Limit",
        "fr": "IRS Contribution Limit",
        "es": "IRS Contribution Limit",
        "ar": "IRS Contribution Limit"
      }
    }
  ],
  "formulas": {
    "result": "annualCompensation + contributionRatePercent + isSelfEmployed",

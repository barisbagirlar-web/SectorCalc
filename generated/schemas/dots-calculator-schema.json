      }
    },
    {
      "id": "averageDailyUsage",
      "label": "Average Daily Usage",
      "type": "number",
      "unit": "units/day",
      "default": 200,
      "businessContext": "Average number of units consumed per day.",
      "label_i18n": {
        "en": "Average Daily Usage",
        "tr": "Average Daily Usage",
        "de": "Average Daily Usage",
        "fr": "Average Daily Usage",
        "es": "Average Daily Usage",
        "ar": "Average Daily Usage"
      }
    },
    {
      "id": "safetyStock",
      "label": "Safety Stock",
      "type": "number",
      "unit": "units",
      "default": 1000,
      "businessContext": "Buffer inventory held to prevent stockouts from variability.",
      "label_i18n": {
        "en": "Safety Stock",
        "tr": "Safety Stock",
        "de": "Safety Stock",
        "fr": "Safety Stock",
        "es": "Safety Stock",
        "ar": "Safety Stock"
      }
    },
    {
      "id": "leadTimeDays",
      "label": "Lead Time",
      "type": "number",
      "unit": "days",
      "default": 7,
      "businessContext": "Average time (in days) from order placement to delivery.",

{
  "toolName": "dots-calculator",
  "inputs": [
    {
      "id": "onHandInventory",
      "label": "On-Hand Inventory",
      "type": "number",
      "unit": "units",
      "default": 5000,
      "businessContext": "Current quantity of items available in stock."
    },
    {
      "id": "averageDailyUsage",
      "label": "Average Daily Usage",
      "type": "number",
      "unit": "units/day",
      "default": 200,
      "businessContext": "Average number of units consumed per day."
    },
    {
      "id": "safetyStock",
      "label": "Safety Stock",
      "type": "number",
      "unit": "units",
      "default": 1000,
      "businessContext": "Buffer inventory held to prevent stockouts from variability."
    },
    {
      "id": "leadTimeDays",
      "label": "Lead Time",
      "type": "number",
      "unit": "days",
      "default": 7,
      "businessContext": "Average time (in days) from order placement to delivery."
    }
  ],
  "formulas": {
    "dos": "onHandInventory / averageDailyUsage",
    "dosWithSafety": "(onHandInventory + safetyStock) / averageDailyUsage",
    "reorderPoint": "leadTimeDays * averageDailyUsage"
  },
  "outputs": {
    "primary": "dos",
    "breakdown": [
      "dos",
      "dosWithSafety",
      "reorderPoint"
    ]
  },
  "category": "Lojistik & Tedarik Zinciri",
  "sector": "Lojistik & Sevkiyat",
  "premiumRequired": false,
  "categorySlug": "procurement-supply-chain",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning"
}

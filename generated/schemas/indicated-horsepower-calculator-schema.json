      }
    }
  ],
  "formulas": {
    "pistonArea": "Math.PI * bore * bore / 4",
    "strokeFt": "stroke / 12",
    "powerStrokesPerMinute": "speed * cylinders * 2 / cycles",
    "indicatedHorsepower": "pressure * strokeFt * pistonArea * powerStrokesPerMinute / 33000"
  },
  "outputs": {
    "primary": "indicatedHorsepower",
    "breakdown": [
      "pistonArea",
      "strokeFt",
      "powerStrokesPerMinute"
    ]
  },

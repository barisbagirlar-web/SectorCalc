        "fr": "Trade Size (Lots)",
        "es": "Trade Size (Lots)",
        "ar": "Trade Size (Lots)"
      }
    },
    {
      "id": "contract_size",
      "label": "Contract Size (Units per Lot)",
      "type": "number",
      "unit": "units",
      "default": 100000,
      "businessContext": "Number of base currency units per standard lot",
      "label_i18n": {
        "en": "Contract Size (Units per Lot)",
        "tr": "Contract Size (Units per Lot)",
        "de": "Contract Size (Units per Lot)",
        "fr": "Contract Size (Units per Lot)",
        "es": "Contract Size (Units per Lot)",
        "ar": "Contract Size (Units per Lot)"
      }
    },
    {
      "id": "pip_definition",
      "label": "Pip Size (Quote Currency)",
      "type": "number",
      "unit": "quote currency",
      "default": 0.0001,
      "businessContext": "Pip definition in quote currency (e.g., 0.0001 for most pairs, 0.01 for JPY pairs)",
      "label_i18n": {
        "en": "Pip Size (Quote Currency)",
        "tr": "Pip Size (Quote Currency)",
        "de": "Pip Size (Quote Currency)",
        "fr": "Pip Size (Quote Currency)",
        "es": "Pip Size (Quote Currency)",
        "ar": "Pip Size (Quote Currency)"
      }
    },
    {
      "id": "quote_to_account_rate",
      "label": "Quote to Account Currency Rate",
      "type": "number",
      "unit": "rate",
      "default": 1.2,
      "businessContext": "Exchange rate from quote currency to account currency (amount of account currency per 1 unit of quote currency)",
      "label_i18n": {
        "en": "Quote to Account Currency Rate",
        "tr": "Quote to Account Currency Rate",
        "de": "Quote to Account Currency Rate",
        "fr": "Quote to Account Currency Rate",
        "es": "Quote to Account Currency Rate",
        "ar": "Quote to Account Currency Rate"
      }
    }
  ],
  "formulas": {
    "pipValueInQuote": "trade_size_lots * contract_size * pip_definition",
    "pipValueInAccount": "pipValueInQuote * quote_to_account_rate"
  },
  "outputs": {
    "primary": "pipValueInAccount",
    "breakdown": [
      "pipValueInQuote",
      "quote_to_account_rate"

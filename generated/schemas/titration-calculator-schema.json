{
  "toolName": "titration-calculator",
  "inputs": [
    {
      "id": "titrantConc",
      "label": "Titrant Concentration",
      "type": "number",
      "unit": "mol/L",
      "default": 0.1,
      "businessContext": "Concentration of the standard solution used for titration.",
      "label_i18n": {
        "en": "Titrant Concentration",

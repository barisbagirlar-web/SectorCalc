      "unit": "mL",
      "default": 20,
      "businessContext": "Volume of titrant added to reach the endpoint.",
      "label_i18n": {
        "en": "Volume of Titrant",
        "tr": "Volume of Titrant",
        "de": "Volume of Titrant",
        "fr": "Volume of Titrant",
        "es": "Volume of Titrant",
        "ar": "Volume of Titrant"
      }
    },
    {
      "id": "analyteVol",
      "label": "Volume of Analyte",
      "type": "number",
      "unit": "mL",
      "default": 25,

      "label_i18n": {
        "en": "Volume of Analyte",
        "tr": "Volume of Analyte",
        "de": "Volume of Analyte",
        "fr": "Volume of Analyte",
        "es": "Volume of Analyte",
        "ar": "Volume of Analyte"
      }
    },
    {
      "id": "stoichCoeffTitrant",
      "label": "Stoichiometric Coefficient (Titrant)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Mole ratio of titrant in the balanced reaction equation.",
      "label_i18n": {
        "en": "Stoichiometric Coefficient (Titrant)",
        "tr": "Stoichiometric Coefficient (Titrant)",
        "de": "Stoichiometric Coefficient (Titrant)",
        "fr": "Stoichiometric Coefficient (Titrant)",
        "es": "Stoichiometric Coefficient (Titrant)",
        "ar": "Stoichiometric Coefficient (Titrant)"
      }
    },
    {
      "id": "stoichCoeffAnalyte",
      "label": "Stoichiometric Coefficient (Analyte)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Mole ratio of analyte in the balanced reaction equation.",
      "label_i18n": {
        "en": "Stoichiometric Coefficient (Analyte)",
        "tr": "Stoichiometric Coefficient (Analyte)",
        "de": "Stoichiometric Coefficient (Analyte)",
        "fr": "Stoichiometric Coefficient (Analyte)",
        "es": "Stoichiometric Coefficient (Analyte)",
        "ar": "Stoichiometric Coefficient (Analyte)"
      }
    }
  ],
  "formulas": {
    "titrantMoles": "titrantConc * (titrantVol / 1000)",
    "analyteMoles": "titrantMoles * (stoichCoeffAnalyte / stoichCoeffTitrant)",
    "analyteConcentration": "analyteMoles / (analyteVol / 1000)"
  },
  "outputs": {
    "primary": "analyteConcentration",
    "breakdown": [
      "titrantMoles",
      "analyteMoles"

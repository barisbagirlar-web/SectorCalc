      }
    },
    {
      "id": "laborHours",
      "label": "Labor Hours",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Total labor hours required for the job",
      "label_i18n": {
        "en": "Labor Hours",
        "tr": "İşçilik Saati",
        "de": "Labor Hours",

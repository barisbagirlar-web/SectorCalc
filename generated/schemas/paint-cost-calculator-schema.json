        "ar": "Paint Price per Liter"
      },
      "businessContext_i18n": {
        "en": "Cost of one liter of paint",
        "tr": "Bir litre boyanın maliyeti"
      }
    },
    {
      "id": "coats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "coats",

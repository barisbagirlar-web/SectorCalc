      }
    },
    {
      "id": "laborRate",
      "label": "Labor Rate",
      "type": "number",
      "unit": "$/hour",
      "default": 50,
      "businessContext": "Hourly labor cost",
      "label_i18n": {
        "en": "Labor Rate",
        "tr": "İşçilik ücreti",
        "de": "Labor Rate",
        "fr": "Labor Rate",
        "es": "Labor Rate",
        "ar": "Labor Rate"
      },
      "businessContext_i18n": {
        "en": "Hourly labor cost",
        "tr": "Saatlik işçilik maliyeti"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Extra paint needed due to spillage, overspray, etc.",
      "label_i18n": {
        "en": "Waste Factor (%)",
        "tr": "Fire Faktörü (%)",
        "de": "Waste Factor (%)",
        "fr": "Waste Factor (%)",
        "es": "Waste Factor (%)",
        "ar": "Waste Factor (%)"
      },
      "businessContext_i18n": {
        "en": "Extra paint needed due to spillage, overspray, etc.",
        "tr": "Dökülme, fazla püskürtme vb. nedeniyle ihtiyaç duyulan ekstra boya"
      }
    }
  ],
  "formulas": {
    "totalPaintNeeded": "surfaceArea / paintCoverage * coats * (1 + wasteFactor / 100)",
    "totalPaintCost": "totalPaintNeeded * paintPrice",
    "totalLaborCost": "laborHours * laborRate",
    "totalCost": "totalPaintCost + totalLaborCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalPaintNeeded",
      "totalPaintCost",
      "totalLaborCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "m²"
  },

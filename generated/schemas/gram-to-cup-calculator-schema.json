{
  "toolName": "gram-to-cup-calculator",
  "inputs": [
    {
      "id": "grams",
      "label": "Ağırlık (g)",
      "type": "number",
      "unit": "g",
      "default": 100,
      "businessContext": "Malzemenin gram cinsinden ağırlığı."
    },
    {
      "id": "density",
      "label": "Yoğunluk (g/mL)",
      "type": "number",
      "unit": "g/mL",
      "default": 0.59,
      "businessContext": "Malzemenin yoğunluğu (gram/mililitre). Un için yaklaşık 0.59, şeker için 0.85, su için 1.0."
    },
    {
      "id": "cupVolume",
      "label": "Bardak Hacmi (mL)",
      "type": "number",
      "unit": "mL",
      "default": 240,
      "businessContext": "Kullanılan standart bardağın mililitre cinsinden hacmi. ABD'de genellikle 240 mL, metrik sistemde 250 mL."
    },
    {
      "id": "packingFactor",
      "label": "Sıkıştırma Faktörü",
      "type": "number",
      "unit": "oransız",
      "default": 1,
      "businessContext": "Malzemenin ne kadar sıkıştırıldığını gösteren faktör (1 = normal, >1 daha yoğun)."
    }
  ],
  "formulas": {
    "cups": "grams / (density * packingFactor * cupVolume)",
    "volumeML": "grams / (density * packingFactor)",
    "gramsPerCup": "density * packingFactor * cupVolume"
  },
  "outputs": {
    "primary": "cups",
    "breakdown": [
      "volumeML",
      "gramsPerCup"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

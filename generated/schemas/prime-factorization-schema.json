  "formulas": {
    "primeFactors": "function primeFactors(n) { let factors = []; let d = 2; while (n > 1 && d <= Math.sqrt(n) + 1) { while (n % d === 0) { factors.push(d); n = n / d; } d++; } if (n > 1) factors.push(n); return factors; }",
    "exponentForm": "function exponentForm(factors) { let map = {}; factors.forEach(f => map[f] = (map[f] || 0) + 1); return Object.entries(map).map(([p, e]) => p + (e > 1 ? '^' + e : '')).join(' × '); }",
    "isPrime": "function isPrime(num) { if (num < 2) return false; for (let i = 2; i <= Math.sqrt(num); i++) { if (num % i === 0) return false; } return true; }",
    "_primeFactors_": "{primeFactors}",

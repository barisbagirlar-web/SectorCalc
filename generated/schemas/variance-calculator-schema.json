  "formulas": {
    "variance": "(n > 1) ? ( (isPopulation == 1) ? (sumX2 - (sumX * sumX) / n) / n : (sumX2 - (sumX * sumX) / n) / (n - 1) ) : 0",
    "mean": "(n > 0) ? sumX / n : 0",
    "sumOfSquaredDeviations": "(n > 1) ? (sumX2 - (sumX * sumX) / n) : 0"
  },
  "outputs": {
    "primary": "variance",
    "breakdown": [

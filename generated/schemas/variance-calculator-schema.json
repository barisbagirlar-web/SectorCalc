{
  "toolName": "variance-calculator",
  "inputs": [
    {
      "id": "n",
      "label": "Gözlem Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Veri setindeki gözlem sayısı (örn. 10)",
      "label_i18n": {
        "en": "Gözlem Sayısı",
        "tr": "Gözlem Sayısı",
        "de": "Gözlem Sayısı",
        "fr": "Gözlem Sayısı",
        "es": "Gözlem Sayısı",
        "ar": "Gözlem Sayısı"
      }
    },
    {
      "id": "sumX",
      "label": "Toplam (∑x)",
      "type": "number",
      "unit": "birim",
      "default": 0,
      "businessContext": "Tüm gözlem değerlerinin toplamı",
      "label_i18n": {
        "en": "Toplam (∑x)",
        "tr": "Toplam (∑x)",
        "de": "Toplam (∑x)",
        "fr": "Toplam (∑x)",
        "es": "Toplam (∑x)",
        "ar": "Toplam (∑x)"
      }
    },
    {
      "id": "sumX2",
      "label": "Kareler Toplamı (∑x²)",
      "type": "number",
      "unit": "birim²",
      "default": 0,
      "businessContext": "Her bir gözlem değerinin karesinin toplamı",
      "label_i18n": {
        "en": "Kareler Toplamı (∑x²)",
        "tr": "Kareler Toplamı (∑x²)",
        "de": "Kareler Toplamı (∑x²)",
        "fr": "Kareler Toplamı (∑x²)",
        "es": "Kareler Toplamı (∑x²)",
        "ar": "Kareler Toplamı (∑x²)"
      }
    },
    {
      "id": "isPopulation",
      "label": "Popülasyon mu?",
      "type": "number",
      "unit": "yok",
      "default": 1,
      "businessContext": "1: Popülasyon varyansı, 0: Örneklem varyansı",
      "label_i18n": {
        "en": "Popülasyon mu?",
        "tr": "Popülasyon mu?",
        "de": "Popülasyon mu?",
        "fr": "Popülasyon mu?",
        "es": "Popülasyon mu?",
        "ar": "Popülasyon mu?"
      }
    }
  ],
  "formulas": {
    "variance": "(n > 1) ? ( (isPopulation == 1) ? (sumX2 - (sumX * sumX) / n) / n : (sumX2 - (sumX * sumX) / n) / (n - 1) ) : 0",
    "mean": "(n > 0) ? sumX / n : 0",
    "standardDeviation": "Math.sqrt( Math.max(0, (n > 1) ? ( (isPopulation == 1) ? (sumX2 - (sumX * sumX) / n) / n : (sumX2 - (sumX * sumX) / n) / (n - 1) ) : 0 ) )",
    "sumOfSquaredDeviations": "(n > 1) ? (sumX2 - (sumX * sumX) / n) : 0"
  },
  "outputs": {
    "primary": "variance",
    "breakdown": [
      "mean",
      "standardDeviation",
      "sumOfSquaredDeviations"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

    },
    {
      "id": "sumX",
      "label": "Total (∑x)",
      "type": "number",
      "unit": "birim",
      "default": 0,
      "businessContext": "Sum of all observation values",
      "label_i18n": {
        "en": "Total (∑x)",
        "tr": "Toplam (∑x)",
        "de": "Summe (∑x)",
        "fr": "Somme (∑x)",
        "es": "Suma total (∑x)",
        "ar": "المجموع (∑x)"
      },
      "businessContext_i18n": {
        "en": "Sum of all observation values",
        "tr": "Tüm gözlem değerlerinin toplamı",
        "de": "Summe aller Beobachtungswerte",
        "fr": "Somme de toutes les valeurs d'observation",
        "es": "Suma de todos los valores de las observaciones",
        "ar": "مجموع جميع قيم المشاهدات"
      }
    },
    {
      "id": "sumX2",
      "label": "Sum of Squares (∑x²)",
      "type": "number",
      "unit": "birim²",
      "default": 0,
      "businessContext": "Sum of squares of each observation value",
      "label_i18n": {
        "en": "Sum of squares (∑x²)",
        "tr": "Kareler Toplamı (∑x²)",
        "de": "Summe der Quadrate (∑x²)",
        "fr": "Somme des carrés (∑x²)",
        "es": "Suma de cuadrados (∑x²)",
        "ar": "مجموع المربعات (∑x²)"
      },
      "businessContext_i18n": {
        "en": "Sum of squares of each observation value",
        "tr": "Her bir gözlem değerinin karesinin toplamı",
        "de": "Summe der Quadrate jedes Beobachtungswertes",
        "fr": "Somme des carrés de chaque valeur d'observation",
        "es": "Suma de los cuadrados de cada valor de observación",
        "ar": "مجموع مربع كل قيمة مشاهدة"
      }
    },
    {
      "id": "isPopulation",
      "label": "Population?",
      "type": "number",
      "unit": "yok",
      "default": 1,
      "businessContext": "1: Population variance, 0: Sample variance",
      "label_i18n": {
        "en": "Is it population?",
        "tr": "Popülasyon mu?",
        "de": "Grundgesamtheit?",
        "fr": "Population ?",
        "es": "¿Población?",
        "ar": "هل هو المجتمع؟"
      },
      "businessContext_i18n": {
        "en": "1: Population variance, 0: Sample variance",
        "tr": "1: Popülasyon varyansı, 0: Örneklem varyansı",
        "de": "1: Varianz der Grundgesamtheit, 0: Stichprobenvarianz",
        "fr": "1 : Variance de population, 0 : Variance d'échantillon",
        "es": "1: Varianza poblacional, 0: Varianza muestral",
        "ar": "1: تباين المجتمع، 0: تباين العينة"
      }
    }
  ],
  "formulas": {
    "variance": "(n > 1) ? ( (isPopulation == 1) ? (sumX2 - (sumX * sumX) / n) / n : (sumX2 - (sumX * sumX) / n) / (n - 1) ) : 0",
    "mean": "(n > 0) ? sumX / n : 0",
    "sumOfSquaredDeviations": "(n > 1) ? (sumX2 - (sumX * sumX) / n) : 0"
  },
  "outputs": {
    "primary": "variance",
    "breakdown": [
      "mean",
      "standardDeviation",
      "sumOfSquaredDeviations"
    ],

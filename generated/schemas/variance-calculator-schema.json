      "label": "Popülasyon mu?",
      "type": "number",
      "unit": "yok",
      "default": 1,
      "businessContext": "1: Popülasyon varyansı, 0: Örneklem varyansı",
      "label_i18n": {
        "en": "Popülasyon mu?",
        "tr": "Popülasyon mu?",
        "de": "Grundgesamtheit?",
        "fr": "Population ?",
        "es": "Popülasyon mu?",
        "ar": "Popülasyon mu?"
      },
      "businessContext_i18n": {
        "en": "1: Popülasyon varyansı, 0: Örneklem varyansı",
        "tr": "1: Popülasyon varyansı, 0: Örneklem varyansı",

{
  "toolName": "variance-calculator",
  "inputs": [
    {
      "id": "n",
      "label": "Number of Observations",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Number of observations in the dataset (e.g., 10)",
      "label_i18n": {
        "en": "Number of observations",
        "tr": "Gözlem Sayısı",
        "de": "Anzahl der Beobachtungen",
        "fr": "Nombre d'observations",
        "es": "Número de observaciones",
        "ar": "عدد المشاهدات"
      },
      "businessContext_i18n": {
        "en": "Number of observations in dataset (e.g., 10)",
        "tr": "Veri setindeki gözlem sayısı (örn. 10)",
        "de": "Anzahl der Beobachtungen im Datensatz (z. B. 10)",

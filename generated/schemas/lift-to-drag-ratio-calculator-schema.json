      }
    },
    {
      "id": "dragCoefficient",
      "label": "Drag Coefficient (CD)",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.04,
      "businessContext": "Non-dimensional drag coefficient of the aerodynamic body.",
      "label_i18n": {
        "en": "Drag Coefficient (CD)",
        "tr": "Drag Coefficient (CD)",
        "de": "Drag Coefficient (CD)",
        "fr": "Drag Coefficient (CD)",
        "es": "Drag Coefficient (CD)",
        "ar": "Drag Coefficient (CD)"
      }
    },
    {
      "id": "airDensity",
      "label": "Air Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1.225,
      "businessContext": "Air density at current altitude and temperature (ISA sea level standard).",
      "label_i18n": {
        "en": "Air Density",
        "tr": "Air Density",
        "de": "Air Density",
        "fr": "Air Density",
        "es": "Air Density",
        "ar": "Air Density"
      }
    },
    {
      "id": "velocity",
      "label": "Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 50,
      "businessContext": "Relative airspeed of the body through the fluid.",
      "label_i18n": {
        "en": "Velocity",
        "tr": "Velocity",
        "de": "Velocity",
        "fr": "Velocity",
        "es": "Velocity",
        "ar": "Velocity"
      }
    },
    {
      "id": "referenceArea",
      "label": "Reference Area",
      "type": "number",
      "unit": "m²",
      "default": 10,
      "businessContext": "Characteristic planform area (e.g., wing area).",
      "label_i18n": {
        "en": "Reference Area",
        "tr": "Reference Area",
        "de": "Reference Area",
        "fr": "Reference Area",
        "es": "Reference Area",
        "ar": "Reference Area"
      }
    }
  ],
  "formulas": {
    "dynamicPressure": "0.5 * airDensity * velocity ** 2",
    "liftForce": "liftCoefficient * dynamicPressure * referenceArea",
    "dragForce": "dragCoefficient * dynamicPressure * referenceArea",
    "liftToDragRatio": "liftCoefficient / dragCoefficient"
  },
  "outputs": {
    "primary": "liftToDragRatio",
    "breakdown": [
      "liftForce",
      "dragForce"
    ],
    "hiddenLossDrivers": [],

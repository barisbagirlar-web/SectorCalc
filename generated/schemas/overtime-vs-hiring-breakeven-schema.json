  "formulas": {
    "OvertimeCost_Hour": "RegularRate * OvertimeMultiplier * (1 + BurdenRate)",
    "HiringCost_Total": "Recruitment + Onboarding + Training + RampUpProductivityLoss",
    "AnnualNewHireCost": "(RegularRate * AnnualHours) * (1 + BurdenRate) + Benefits",
    "BreakevenHours": "HiringCost_Total / (AnnualNewHireCost / AnnualHours - OvertimeCost_Hour)",
    "Decision": "IF(ExpectedOvertimeHours > BreakevenHours, \"Hire\", \"Overtime\")",
    "QualityCost_OT": "OvertimeHours * FatigueDefectRate * DefectCost"
  },

  "formulas": {
    "total_time_seconds": "time_minutes * 60 + time_seconds",
    "pace_500m_seconds": "total_time_seconds * 500 / distance",
    "projected_time_seconds": "pace_500m_seconds * target_distance / 500",
    "speed_ms": "distance / total_time_seconds",
    "speed_kmh": "speed_ms * 3.6"
  },

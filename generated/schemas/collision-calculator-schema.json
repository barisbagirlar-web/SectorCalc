  "formulas": {
    "finalVelocityMass1": "((mass1 - mass2) * velocity1 + 2 * mass2 * velocity2) / (mass1 + mass2)",
    "finalVelocityMass2": "(2 * mass1 * velocity1 + (mass2 - mass1) * velocity2) / (mass1 + mass2)",
    "initialKineticEnergy": "0.5 * mass1 * velocity1 * velocity1 + 0.5 * mass2 * velocity2 * velocity2",
    "finalKineticEnergy": "0.5 * mass1 * finalVelocityMass1 * finalVelocityMass1 + 0.5 * mass2 * finalVelocityMass2 * finalVelocityMass2"
  },

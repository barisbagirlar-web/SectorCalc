{
  "toolName": "fault-current-calculator",
  "inputs": [
    {
      "id": "primaryVoltage",
      "label": "Primary Voltage",
      "type": "number",
      "unit": "kV",
      "default": 34.5,
      "businessContext": "Line-to-line voltage on the primary side of the transformer."
    },
    {
      "id": "secondaryVoltage",
      "label": "Secondary Voltage",
      "type": "number",
      "unit": "V",
      "default": 480,
      "businessContext": "Line-to-line voltage on the secondary side of the transformer (fault location)."
    },
    {
      "id": "sourceSCMVA",
      "label": "Source Short-Circuit MVA",
      "type": "number",
      "unit": "MVA",
      "default": 500,
      "businessContext": "Available short-circuit MVA from the upstream source at the primary voltage level."
    },
    {
      "id": "transformerKVA",
      "label": "Transformer Rating",
      "type": "number",
      "unit": "kVA",
      "default": 1000,
      "businessContext": "Power rating of the transformer."
    },
    {
      "id": "transformerPercentZ",
      "label": "Transformer %Z",
      "type": "number",
      "unit": "%",
      "default": 5.75,
      "businessContext": "Percent impedance of the transformer based on its own kVA rating."
    }
  ],
  "formulas": {
    "sourceImpedancePrim": "Math.pow(primaryVoltage, 2) / sourceSCMVA",
    "sourceImpedanceSec": "sourceImpedancePrim * Math.pow((secondaryVoltage / 1000) / primaryVoltage, 2)",
    "transformerImpedance": "(transformerPercentZ / 100) * Math.pow(secondaryVoltage, 2) / (transformerKVA * 1000)",
    "totalImpedance": "sourceImpedanceSec + transformerImpedance",
    "faultCurrentKA": "secondaryVoltage / (Math.sqrt(3) * totalImpedance) / 1000"
  },
  "outputs": {
    "primary": "faultCurrentKA",
    "breakdown": [
      "sourceImpedancePrim",
      "sourceImpedanceSec",
      "transformerImpedance",
      "totalImpedance"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "electrical-power-systems",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "energy"
}

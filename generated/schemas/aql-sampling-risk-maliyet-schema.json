  "formulas": {
    "CodeLetter": "LookupCodeLetter(LotSize, InspectionLevel)",
    "n": "SampleSize(CodeLetter, AQL)",
    "Ac": "AcceptanceNumber(CodeLetter, AQL)",
    "Pa_producer": "BINOMDIST(Ac, n, p_AQL, TRUE)",
    "Alpha": "1 - Pa_producer",
    "Pa_consumer": "BINOMDIST(Ac, n, p_LTPD, TRUE)",
    "Beta": "Pa_consumer",
    "ATI": "n + (1 - Pa) * (N - n)",
    "TotalRiskCost": "(N * p * (1 - Pa) * (1 - DetectionRate)) * CostPerDefect"
  },

{
  "toolName": "paint-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Surface Area",
      "type": "number",
      "unit": "m²",
      "default": 100,
      "businessContext": "Total paintable surface area in square meters",
      "label_i18n": {
        "en": "Surface Area",
        "tr": "Surface Area",
        "de": "Surface Area",
        "fr": "Surface Area",
        "es": "Surface Area",
        "ar": "Surface Area"
      }
    },
    {
      "id": "coverage",
      "label": "Coverage Rate",
      "type": "number",
      "unit": "m²/L",
      "default": 10,
      "businessContext": "Paint coverage rate from manufacturer data sheet (m² per liter)",
      "label_i18n": {
        "en": "Coverage Rate",
        "tr": "Coverage Rate",
        "de": "Coverage Rate",
        "fr": "Coverage Rate",
        "es": "Coverage Rate",
        "ar": "Coverage Rate"
      }
    },
    {
      "id": "coats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of paint coats to apply",
      "label_i18n": {
        "en": "Number of Coats",
        "tr": "Number of Coats",
        "de": "Number of Coats",
        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    },
    {
      "id": "wastage",
      "label": "Wastage Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of extra paint needed for spillage, uneven surfaces, etc.",
      "label_i18n": {
        "en": "Wastage Factor",
        "tr": "Wastage Factor",
        "de": "Wastage Factor",
        "fr": "Wastage Factor",
        "es": "Wastage Factor",
        "ar": "Wastage Factor"
      }
    }
  ],
  "formulas": {
    "netPaint": "(area * coats) / coverage",
    "wastagePaint": "netPaint * (wastage / 100)",
    "totalPaint": "netPaint + wastagePaint"
  },
  "outputs": {
    "primary": "totalPaint",
    "breakdown": [
      "netPaint",
      "wastagePaint"
    ]
  },

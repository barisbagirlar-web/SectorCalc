  "formulas": {
    "agePoints": "(age > 50 ? age - 50 : 0)",
    "respiratoryRatePoints": "(respiratoryRate > 30 ? 20 : 0)",
    "systolicBPPoints": "(systolicBP < 90 ? 20 : 0)",
    "bunPoints": "(bun > 30 ? 20 : 0)",
    "sodiumPoints": "(sodium < 130 ? 20 : 0)",
    "glucosePoints": "(glucose >= 250 ? 10 : 0)",
    "hematocritPoints": "(hematocrit < 30 ? 10 : 0)",
    "paO2Points": "(paO2 < 60 ? 10 : 0)",
    "psiScore": "agePoints + respiratoryRatePoints + systolicBPPoints + bunPoints + sodiumPoints + glucosePoints + hematocritPoints + paO2Points",
    "mortalityRiskPercentage": "psiScore <= 50 ? 0.1 : (psiScore <= 70 ? 0.6 : (psiScore <= 90 ? 0.9 : (psiScore <= 130 ? 9.3 : 27)))"
  },
  "outputs": {
    "primary": "psiScore",
    "breakdown": [
      "riskClass",
      "mortalityRiskPercentage"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "mortalityRiskPercentage",
    "unit": "years",
    "breakdownUnits": {
      "mortalityRiskPercentage": "%"
    }
  },

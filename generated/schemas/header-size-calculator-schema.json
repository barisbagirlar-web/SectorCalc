{
  "toolName": "header-size-calculator",
  "inputs": [
    {
      "id": "span",
      "label": "Span",
      "type": "number",
      "unit": "ft",
      "default": 8,
      "businessContext": "Clear span of the opening in feet",
      "label_i18n": {
        "en": "Span",
        "tr": "Span",
        "de": "Span",
        "fr": "Span",

      }
    },
    {
      "id": "load",
      "label": "Total Uniform Load",
      "type": "number",
      "unit": "plf",
      "default": 500,
      "businessContext": "Sum of live and dead loads per linear foot on the header",
      "label_i18n": {
        "en": "Total Uniform Load",
        "tr": "Total Uniform Load",
        "de": "Total Uniform Load",
        "fr": "Total Uniform Load",
        "es": "Total Uniform Load",
        "ar": "Total Uniform Load"
      }
    },
    {
      "id": "fb",
      "label": "Allowable Bending Stress",
      "type": "number",
      "unit": "psi",
      "default": 1000,
      "businessContext": "Design bending stress (Fb) of the header material",
      "label_i18n": {
        "en": "Allowable Bending Stress",
        "tr": "Allowable Bending Stress",
        "de": "Allowable Bending Stress",
        "fr": "Allowable Bending Stress",
        "es": "Allowable Bending Stress",
        "ar": "Allowable Bending Stress"
      }
    },
    {
      "id": "plies",
      "label": "Number of Plies",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of laminated 2x members (e.g., 2 for double 2x)",
      "label_i18n": {
        "en": "Number of Plies",
        "tr": "Number of Plies",
        "de": "Number of Plies",
        "fr": "Number of Plies",
        "es": "Number of Plies",
        "ar": "Number of Plies"
      }
    }
  ],
  "formulas": {
    "span_in": "span * 12",
    "M": "1.5 * load * (span ** 2)",
    "S_req": "M / fb",
    "b": "plies * 1.5",
    "d_required": "Math.sqrt((6 * S_req) / b)"
  },
  "outputs": {
    "primary": "d_required",
    "breakdown": [
      "M",
      "S_req",
      "d_required"
    ]
  },

{
  "toolName": "cycling-wkg-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Rider Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Total mass of the cyclist including clothing and helmet."
    },
    {
      "id": "bikeWeight",
      "label": "Bike Weight",
      "type": "number",
      "unit": "kg",
      "default": 9,
      "businessContext": "Mass of the bicycle including accessories."
    },
    {
      "id": "power",
      "label": "Power Output",
      "type": "number",
      "unit": "W",
      "default": 250,
      "businessContext": "Average power generated by the cyclist over the duration."
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "min",
      "default": 60,
      "businessContext": "Time period over which the power is sustained."
    }
  ],
  "formulas": {
    "totalWeight": "weight + bikeWeight",
    "wkg": "power / totalWeight",
    "normalizedWkg": "wkg * (1 + 0.005 * (duration / 60 - 1))"
  },
  "outputs": {
    "primary": "wkg",
    "breakdown": [
      "totalWeight",
      "normalizedWkg"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems"
}

{
  "toolName": "millibar-to-psi-calculator",
  "inputs": [
    {
      "id": "millibarValue",
      "label": "Millibar Value",
      "type": "number",
      "unit": "mbar",
      "default": 0,
      "businessContext": "Gauge or absolute pressure in millibars",
      "label_i18n": {
        "en": "Millibar Value",
        "tr": "Millibar Value",
        "de": "Millibar Value",
        "fr": "Millibar Value",
        "es": "Millibar Value",
        "ar": "Millibar Value"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "psi/mbar",
      "default": 0.0145037738,
      "businessContext": "Standard millibar to psi conversion factor",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "calibrationOffset",
      "label": "Calibration Offset",
      "type": "number",
      "unit": "psi",
      "default": 0,
      "businessContext": "Instrument offset from last calibration certificate",
      "label_i18n": {
        "en": "Calibration Offset",
        "tr": "Calibration Offset",
        "de": "Calibration Offset",
        "fr": "Calibration Offset",
        "es": "Calibration Offset",
        "ar": "Calibration Offset"
      }
    },
    {
      "id": "temperatureCorrection",
      "label": "Temperature Correction",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Dimensionless correction for medium temperature deviation from reference",
      "label_i18n": {
        "en": "Temperature Correction",
        "tr": "Temperature Correction",
        "de": "Temperature Correction",
        "fr": "Temperature Correction",
        "es": "Temperature Correction",
        "ar": "Temperature Correction"
      }
    }
  ],
  "formulas": {
    "rawConversionPsi": "millibarValue * conversionFactor",
    "calibrationAppliedPsi": "rawConversionPsi + calibrationOffset",
    "finalPressurePsi": "calibrationAppliedPsi * temperatureCorrection"
  },
  "outputs": {
    "primary": "finalPressurePsi",
    "breakdown": [
      "rawConversionPsi",
      "calibrationAppliedPsi",
      "finalPressurePsi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalPressurePsi",
    "unit": "mbar",
    "breakdownUnits": {
      "calibrationAppliedPsi": "%"
    }
  },

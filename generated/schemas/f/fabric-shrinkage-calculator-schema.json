{
  "toolName": "fabric-shrinkage-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "hamOlcu",
      "label": "Greige Dimension (cm)",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "min": 0,
      "businessContext": "Pre-processing fabric size."
    },
    {
      "id": "bitmisOlcu",
      "label": "Finished Dimension (cm)",
      "type": "number",
      "unit": "cm",
      "default": 96,
      "min": 0,
      "businessContext": "Post-processing fabric size."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "((hamOlcu - bitmisOlcu) / Math.max(0.0001, hamOlcu)) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "Tmostsion Ratio"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling process for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate fabric shrinkage percentage after processing.",

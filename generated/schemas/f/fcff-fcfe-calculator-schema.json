      "businessContext": "Net profit for the period."
    },
    {
      "id": "amortisman",
      "label": "Depreciation (USD)",
      "type": "number",
      "unit": "USD",
      "default": 30000,
      "min": 0,
      "businessContext": "Period depreciation expense."
    },
    {
      "id": "isletmeSermayesi",
      "label": "Working Capital Change (USD)",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "min": 0,
      "businessContext": "Increase in net working capital."
    },
    {
      "id": "capex",
      "label": "CapEx (USD)",
      "type": "number",
      "unit": "USD",
      "default": 40000,
      "min": 0,
      "businessContext": "Capital expenditures on fixed assets."
    },
    {
      "id": "debt",
      "label": "Net Debt Change (USD)",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "min": 0,
      "businessContext": "New debt issuance minus principal payments."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "fcff": "netKar + amortisman - isletmeSermayesi - capex",
    "result": "netKar + amortisman - isletmeSermayesi - capex + debt"

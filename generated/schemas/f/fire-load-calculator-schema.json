{
  "toolName": "fire-load-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "electrical-power-systems",
  "sector": "Yangin, Electrical and Electronics",
  "sectorId": "electrical-power-systems",
  "inputs": [
    {
      "id": "yaniciKutle",
      "label": "Combustible Mass (kg)",
      "type": "number",
      "unit": "kg",
      "default": 5000,
      "min": 0,
      "businessContext": "Combustible material on floor."
    },
    {
      "id": "isilDeger",
      "label": "Calorific Value (MJ/kg)",
      "type": "number",
      "unit": "MJ/kg",
      "default": 18,
      "min": 0,
      "businessContext": "Material energy per kg."
    },
    {
      "id": "katAlani",
      "label": "Floor Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 200,
      "min": 0,
      "businessContext": "Fire compartment area."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(yaniciKutle * isilDeger) / Math.max(0.0001, katAlani)"
  },
  "outputs": {
    "primary": "result",
    "unit": "MJ/m2",
    "breakdown": {
      "result": "Scrap Load"
    },
    "breakdownUnits": {
      "result": "MJ/m2"
    },
    "hiddenLossDrivers": [
      "Low Q factor indicates broader frequency response."
    ],
    "suggestedActions": [
      "Verify component tolerances affect circuit performance.",
      "Use proper safety equipment for high voltage/current work."
    ],
    "dataConfidenceAdjusted": "result"
  },

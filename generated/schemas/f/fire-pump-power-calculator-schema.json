{
  "toolName": "fire-pump-power-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "electrical-power-systems",
  "sector": "Yangin, Electrical and Electronics",
  "sectorId": "electrical-power-systems",
  "inputs": [
    {
      "id": "flow",
      "label": "Flow Rate (L/min)",
      "type": "number",
      "unit": "L/min",
      "default": 1000,
      "min": 0,
      "businessContext": "System flow rate."
    },
    {
      "id": "pressure",
      "label": "Pressure (bar)",
      "type": "number",
      "unit": "bar",
      "default": 7,
      "min": 0,
      "businessContext": "Required pressure."
    },
    {
      "id": "pompaVerim",
      "label": "Pump Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 75,
      "min": 0,
      "businessContext": "Pump efficiency."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(flow * pressure * 100) / Math.max(0.0001, (600 * (pompaVerim / 100) * 746))"
  },
  "outputs": {
    "primary": "result",
    "unit": "HP",
    "breakdown": {
      "result": "Pump Motor Power"
    },
    "breakdownUnits": {
      "result": "HP"
    },
    "hiddenLossDrivers": [
      "Low Q factor indicates broader frequency response."
    ],

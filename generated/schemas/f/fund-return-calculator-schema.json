{
  "toolName": "fund-return-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "baslangicNAV",
      "label": "Start NAV (USD)",
      "type": "number",
      "unit": "USD",
      "default": 10,
      "min": 0,
      "businessContext": "Fund unit price at period start."
    },
    {
      "id": "bitisNAV",
      "label": "End NAV (USD)",
      "type": "number",
      "unit": "USD",
      "default": 12,
      "min": 0,
      "businessContext": "Fund unit price at period end."
    },
    {
      "id": "dagitim",
      "label": "Distribution (USD)",
      "type": "number",
      "unit": "USD",
      "default": 0.5,
      "min": 0,
      "businessContext": "Dividend distributed during period."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "((bitisNAV + dagitim - baslangicNAV) / Math.max(1, baslangicNAV)) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "Fon Getirisi"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate total investor return of a mutual fund.",
      "long": "Calculate total investor return of a mutual fund."
    }
  },
  "sectorSlug": "daily-renovation"
}

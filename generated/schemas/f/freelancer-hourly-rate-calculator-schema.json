  "formulas": {
    "brutHedef": "(hedefNet + expense) / Math.max(0.0001, (1 - vergi / 100))",
    "result": "((hedefNet + expense) / Math.max(0.0001, (1 - vergi / 100))) / Math.max(1, calismaSaati)"

        "es": "Kalibrasyon Ofseti (psi)",
        "ar": "Kalibrasyon Ofseti (psi)"
      }
    }
  ],
  "formulas": {
    "intermediatePsi": "torrValue * conversionFactor",
    "adjustedPsi": "torrValue * conversionFactor + offset",
    "roundedPsi": "Math.round((torrValue * conversionFactor + offset) * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)"
  },
  "outputs": {
    "primary": "roundedPsi",
    "breakdown": [
      "intermediatePsi",
      "adjustedPsi"
    ]
  },

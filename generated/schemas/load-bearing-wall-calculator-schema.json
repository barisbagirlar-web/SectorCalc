        "es": "Basınç Dayanımı",
        "ar": "Basınç Dayanımı"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Güvenlik Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Güvenlik faktörü (birimsiz)",
      "label_i18n": {
        "en": "Güvenlik Faktörü",
        "tr": "Güvenlik Faktörü",
        "de": "Güvenlik Faktörü",
        "fr": "Güvenlik Faktörü",
        "es": "Güvenlik Faktörü",
        "ar": "Güvenlik Faktörü"
      }
    }
  ],
  "formulas": {
    "area": "wallThickness / 1000 * wallLength",
    "slendernessRatio": "wallHeight * Math.sqrt(12) * 1000 / wallThickness",
    "axialStress": "compressiveStrength / safetyFactor",
    "maxLoad": "area * compressiveStrength * 1000 / safetyFactor"
  },
  "outputs": {
    "primary": "maxLoad",
    "breakdown": [
      "area",
      "slendernessRatio",
      "axialStress"
    ]
  },

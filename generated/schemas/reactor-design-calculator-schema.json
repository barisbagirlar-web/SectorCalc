        "ar": "Inlet Concentration"
      },
      "businessContext_i18n": {
        "en": "Concentration of reactant A at reactor inlet.",
        "tr": "Reaktör girişinde A reaktantının konsantrasyonu."
      }
    },
    {
      "id": "conversion",
      "label": "Desired Conversion",
      "type": "number",
      "unit": "fraction (0-1)",
      "default": 0.9,
      "businessContext": "Fraction of reactant A to be converted to products.",
      "label_i18n": {
        "en": "Desired Conversion",
        "tr": "İstenen Dönüşüm",
        "de": "Desired Conversion",
        "fr": "Desired Conversion",
        "es": "Desired Conversion",
        "ar": "Desired Conversion"
      },
      "businessContext_i18n": {
        "en": "Fraction of reactant A to be converted to products.",
        "tr": "A reaktantının ürünlere dönüştürülecek kesri."
      }
    },
    {
      "id": "rateConstant",
      "label": "Rate Constant",
      "type": "number",
      "unit": "variable",
      "default": 0.5,
      "businessContext": "Reaction rate constant. For first-order, units are s⁻¹; for second-order, m³/(mol·s).",
      "label_i18n": {
        "en": "Rate Constant",
        "tr": "Hız Sabiti",
        "de": "Rate Constant",
        "fr": "Rate Constant",
        "es": "Rate Constant",
        "ar": "Rate Constant"
      },
      "businessContext_i18n": {
        "en": "Reaction rate constant. For first-order, units are s⁻¹; for second-order, m³/(mol·s).",
        "tr": "Reaksiyon hız sabiti. Birinci derece için birim s⁻¹; ikinci derece için m³/(mol·s)."
      }
    },
    {
      "id": "reactionOrder",
      "label": "Reaction Order",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Order of reaction with respect to reactant A.",
      "label_i18n": {
        "en": "Reaction Order",
        "tr": "Reaksiyon Mertebesi",
        "de": "Reaktionsordnung",
        "fr": "Reaction Order",
        "es": "Reaction Order",
        "ar": "Reaction Order"
      },
      "businessContext_i18n": {
        "en": "Order of reaction with respect to reactant A.",
        "tr": "A reaktantına göre reaksiyon derecesi."
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.2,
      "businessContext": "Safety factor to account for uncertainties in kinetics and operation.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Güvenlik Faktörü",
        "de": "Sicherheitsfaktor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      },
      "businessContext_i18n": {
        "en": "Safety factor to account for uncertainties in kinetics and operation.",
        "tr": "Kinetik ve operasyondaki belirsizlikleri hesaba katmak için güvenlik faktörü."
      }
    }
  ],
  "formulas": {
    "outletConcentration": "inletConcentration * (1 - conversion)",

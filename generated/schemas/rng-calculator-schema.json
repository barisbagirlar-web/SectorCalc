  "formulas": {
    "generate": "const x = Math.sin(seed + 1) * 10000; const r = x - Math.floor(x); const scaled = min + r * (max - min); return Math.round(scaled * 100) / 100;",
    "generateMultiple": "const results = []; for (let i = 0; i < count; i++) { const x = Math.sin(seed + i + 1) * 10000; const r = x - Math.floor(x); const scaled = min + r * (max - min); results.push(Math.round(scaled * 100) / 100); } return results;",

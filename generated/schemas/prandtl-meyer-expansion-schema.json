  "formulas": {
    "prandtlMeyerFunction": "Math.sqrt((gamma+1)/(gamma-1))*Math.atan(Math.sqrt((gamma-1)/(gamma+1)*(mach1**2-1)))-Math.atan(Math.sqrt(mach1**2-1))",
    "mach2": "let f = (mach) => Math.sqrt((gamma+1)/(gamma-1))*Math.atan(Math.sqrt((gamma-1)/(gamma+1)*(mach**2-1)))-Math.atan(Math.sqrt(mach**2-1)); let target = f(mach1) + deflectionAngle * Math.PI / 180; let low = 1.001, high = 100, mid; for(let i=0;i<100;i++){ mid=(low+high)/2; if(f(mid)<target) low=mid; else high=mid; } return mid;",
    "pressureRatio": "( (1+(gamma-1)/2*mach1**2) / (1+(gamma-1)/2*mach2**2) )**(gamma/(gamma-1))",
    "temperatureRatio": "(1+(gamma-1)/2*mach1**2)/(1+(gamma-1)/2*mach2**2)",
    "densityRatio": "( (1+(gamma-1)/2*mach1**2) / (1+(gamma-1)/2*mach2**2) )**(1/(gamma-1))",
    "Pressure_Ratio__P2_P1_": "Pressure Ratio (P2/P1)",
    "Temperature_Ratio__T2_T1_": "Temperature Ratio (T2/T1)",
    "Density_Ratio___2__1_": "Density Ratio (ρ2/ρ1)",
    "result": "Downstream Mach Number (M2)"
  },

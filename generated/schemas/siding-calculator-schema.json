        "tr": "Duvarların tabandan saçaklara kadar yüksekliği."
      }
    },
    {
      "id": "windowCount",
      "label": "Number of Windows",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Total count of window openings.",
      "label_i18n": {
        "en": "Number of Windows",
        "tr": "Pencere Sayısı",
        "de": "Anzahl der Fenster",

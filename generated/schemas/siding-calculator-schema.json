        "tr": "Tek bir pencere açıklığının ortalama alanı."
      }
    },
    {
      "id": "doorCount",
      "label": "Number of Doors",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total count of door openings.",
      "label_i18n": {
        "en": "Number of Doors",
        "tr": "Kapı sayısı",
        "de": "Anzahl der Türen",
        "fr": "Number of Doors",
        "es": "Number of Doors",
        "ar": "Number of Doors"
      },

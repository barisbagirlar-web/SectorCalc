      }
    },
    {
      "id": "doorArea",
      "label": "Area per Door",
      "type": "number",
      "unit": "m²",
      "default": 2,
      "businessContext": "Average area of a single door opening.",
      "label_i18n": {
        "en": "Area per Door",
        "tr": "Kapı Başına Alan",
        "de": "Area per Door",
        "fr": "Area per Door",
        "es": "Area per Door",
        "ar": "Area per Door"
      },
      "businessContext_i18n": {
        "en": "Average area of a single door opening.",
        "tr": "Tek bir kapı açıklığının ortalama alanı."
      }
    },
    {
      "id": "sidingCoverage",
      "label": "Siding Panel Coverage",
      "type": "number",
      "unit": "m² per panel",
      "default": 1,
      "businessContext": "Surface area covered by one siding panel.",
      "label_i18n": {
        "en": "Siding Panel Coverage",
        "tr": "Dış Cephe Paneli Kaplaması",
        "de": "Siding Panel Coverage",
        "fr": "Siding Panel Coverage",
        "es": "Siding Panel Coverage",
        "ar": "Siding Panel Coverage"
      },
      "businessContext_i18n": {
        "en": "Surface area covered by one siding panel.",
        "tr": "Bir dış cephe panelinin kapladığı yüzey alanı."
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.1,
      "businessContext": "Extra material to account for cuts and waste (e.g., 0.1 for 10%).",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Atık Faktörü",
        "de": "Abfallfaktor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      },
      "businessContext_i18n": {
        "en": "Extra material to account for cuts and waste (e.g., 0.1 for 10%).",
        "tr": "Kesim ve fireyi hesaba katmak için ek malzeme (ör. %10 için 0,1)."
      }
    }
  ],
  "formulas": {
    "totalWallArea": "wallLength * wallHeight",
    "windowOpeningsArea": "windowCount * windowArea",
    "doorOpeningsArea": "doorCount * doorArea",
    "netWallArea": "totalWallArea - (windowOpeningsArea + doorOpeningsArea)",
    "panelsWithoutWaste": "netWallArea / sidingCoverage",
    "wastePanels": "panelsWithoutWaste * wasteFactor",
    "panelsNeeded": "panelsWithoutWaste + wastePanels"
  },
  "outputs": {
    "primary": "panelsNeeded",
    "breakdown": [
      "totalWallArea",
      "netWallArea",
      "panelsWithoutWaste",
      "wastePanels"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "panelsNeeded",
    "unit": "m"
  },
  "category": "Enerji & Karbon",

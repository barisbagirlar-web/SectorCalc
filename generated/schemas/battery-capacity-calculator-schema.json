        "tr": "İnvertör ve kablo kombinasyon verimliliği (0-1)"
      }
    },
    {
      "id": "depthOfDischarge",
      "label": "Depth of Discharge (DoD)",
      "type": "number",
      "unit": "unit",
      "default": 0.8,
      "businessContext": "Maximum discharge depth (e.g., 0.8 means 80% usable)",
      "label_i18n": {
        "en": "Depth of Discharge (DoD)",
        "tr": "Deşarj Derinliği (DoD)",
        "de": "Depth of Discharge (DoD)",
        "fr": "Depth of Discharge (DoD)",
        "es": "Depth of Discharge (DoD)",
        "ar": "Depth of Discharge (DoD)"
      },
      "businessContext_i18n": {
        "en": "Maximum discharge depth (e.g., 0.8 means 80% usable)",
        "tr": "Maksimum deşarj derinliği (örn. 0,8 %80 kullanılabilir anlamına gelir)"
      }
    }
  ],
  "formulas": {
    "capacityAh": "(loadPower * backupTime) / (voltage * efficiency * depthOfDischarge)",
    "energyWh": "(loadPower * backupTime) / (efficiency * depthOfDischarge)"
  },
  "outputs": {
    "primary": "energyWh",
    "breakdown": [
      "Required energy: ${energyWh.toFixed(2)} Wh",
      "Battery capacity: ${capacityAh.toFixed(2)} Ah"
    ],

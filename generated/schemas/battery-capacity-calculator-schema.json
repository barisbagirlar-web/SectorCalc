      "label_i18n": {
        "en": "System Voltage",
        "tr": "Sistem Gerilimi",
        "de": "System Voltage",
        "fr": "System Voltage",
        "es": "System Voltage",
        "ar": "System Voltage"
      },
      "businessContext_i18n": {

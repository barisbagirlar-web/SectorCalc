    {
      "id": "efficiency",
      "label": "System Efficiency",
      "type": "number",
      "unit": "unit",
      "default": 0.9,
      "businessContext": "Combined efficiency of inverter and cabling (0-1)",
      "label_i18n": {
        "en": "System Efficiency",
        "tr": "Sistem Verimliliği",
        "de": "System Efficiency",
        "fr": "System Efficiency",
        "es": "System Efficiency",
        "ar": "System Efficiency"
      },
      "businessContext_i18n": {

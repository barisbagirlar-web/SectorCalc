        "ar": "الكفاءة المشتركة للعاكس والكابلات (0-1)"
      }
    },
    {
      "id": "depthOfDischarge",
      "label": "Depth of Discharge (DoD)",
      "type": "number",
      "unit": "unit",
      "default": 0.8,
      "businessContext": "Maximum discharge depth (e.g., 0.8 means 80% usable)",
      "label_i18n": {
        "en": "Depth of Discharge (DoD)",
        "tr": "Deşarj Derinliği (DoD)",
        "de": "Entladetiefe (DoD)",
        "fr": "Profondeur de décharge (DoD)",
        "es": "Profundidad de descarga (DoD)",
        "ar": "عمق التفريغ (DoD)"
      },
      "businessContext_i18n": {
        "en": "Maximum discharge depth (e.g., 0.8 means 80% usable)",
        "tr": "Maksimum deşarj derinliği (örn. 0,8 %80 kullanılabilir anlamına gelir)",
        "de": "Maximale Entladetiefe (z. B. 0,8 bedeutet 80 % nutzbar)",
        "fr": "Profondeur de décharge maximale (ex. 0,8 signifie 80 % utilisable)",
        "es": "Profundidad máxima de descarga (p. ej., 0.8 significa 80% utilizable)",
        "ar": "أقصى عمق تفريغ (مثل 0.8 يعني 80% قابل للاستخدام)"
      }
    }
  ],
  "formulas": {
    "capacityAh": "(loadPower * backupTime) / (voltage * efficiency * depthOfDischarge)",
    "energyWh": "(loadPower * backupTime) / (efficiency * depthOfDischarge)"
  },
  "outputs": {
    "primary": "energyWh",
    "breakdown": [
      "Required energy: ${energyWh.toFixed(2)} Wh",
      "Battery capacity: ${capacityAh.toFixed(2)} Ah"
    ],

{
  "toolName": "roth-conversion-calculator",
  "inputs": [
    {
      "id": "currentBalance",
      "label": "Current Traditional IRA Balance",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Total pre-tax balance in traditional IRA account before conversion.",
      "label_i18n": {
        "en": "Current Traditional IRA Balance",
        "tr": "Current Traditional IRA Balance",
        "de": "Current Traditional IRA Balance",
        "fr": "Current Traditional IRA Balance",
        "es": "Current Traditional IRA Balance",
        "ar": "Current Traditional IRA Balance"
      }
    },
    {
      "id": "amountToConvert",
      "label": "Amount to Convert",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Portion of the traditional IRA balance to convert to a Roth IRA; cannot exceed currentBalance.",
      "label_i18n": {
        "en": "Amount to Convert",
        "tr": "Amount to Convert",
        "de": "Amount to Convert",
        "fr": "Amount to Convert",
        "es": "Amount to Convert",
        "ar": "Amount to Convert"
      }
    },
    {
      "id": "currentTaxRate",
      "label": "Current Marginal Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 24,
      "businessContext": "Expected income tax rate in the year of conversion, expressed as a percentage.",
      "label_i18n": {
        "en": "Current Marginal Tax Rate",
        "tr": "Current Marginal Tax Rate",
        "de": "Current Marginal Tax Rate",
        "fr": "Current Marginal Tax Rate",
        "es": "Current Marginal Tax Rate",
        "ar": "Current Marginal Tax Rate"
      }
    },
    {
      "id": "expectedRetirementTaxRate",
      "label": "Expected Retirement Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 24,
      "businessContext": "Estimated marginal tax rate during retirement when traditional IRA withdrawals will be taxed.",
      "label_i18n": {
        "en": "Expected Retirement Tax Rate",
        "tr": "Expected Retirement Tax Rate",
        "de": "Expected Retirement Tax Rate",
        "fr": "Expected Retirement Tax Rate",
        "es": "Expected Retirement Tax Rate",
        "ar": "Expected Retirement Tax Rate"
      }
    },
    {
      "id": "yearsToRetirement",
      "label": "Years to Retirement",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "Number of years until retirement, during which converted funds grow tax-free.",
      "label_i18n": {
        "en": "Years to Retirement",
        "tr": "Years to Retirement",
        "de": "Years to Retirement",
        "fr": "Years to Retirement",
        "es": "Years to Retirement",
        "ar": "Years to Retirement"
      }
    },
    {
      "id": "annualReturnRate",
      "label": "Expected Annual Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Assumed average annual investment return before inflation.",
      "label_i18n": {
        "en": "Expected Annual Return",
        "tr": "Expected Annual Return",
        "de": "Expected Annual Return",
        "fr": "Expected Annual Return",
        "es": "Expected Annual Return",
        "ar": "Expected Annual Return"
      }
    }
  ],
  "formulas": {
    "result": "currentBalance + amountToConvert + currentTaxRate",
    "result_copy": "currentBalance + amountToConvert + currentTaxRate"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      {
        "id": "convertAfterTaxValue",
        "label": "Roth Conversion After-Tax Value",
        "unit": "USD"
      },
      {
        "id": "noConvertAfterTaxValue",
        "label": "Traditional IRA After-Tax Value",
        "unit": "USD"
      }
    ],

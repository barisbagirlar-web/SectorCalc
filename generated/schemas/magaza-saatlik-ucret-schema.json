  "formulas": {
    "DirectLabor": "SUM(TechnicianWages)",
    "IndirectLabor": "SUM(ManagerWages + AdminWages)",
    "Overhead": "Rent + Utilities + Insurance + Tools + Depreciation",
    "TotalShopCost": "DirectLabor + IndirectLabor + Overhead",
    "BillableHours": "TotalAvailableHours * UtilizationRate",
    "ShopHourlyRate": "TotalShopCost / BillableHours",
    "EffectiveMargin": "(ActualBillingRate - ShopHourlyRate) / ActualBillingRate"
  },

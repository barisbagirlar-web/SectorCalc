  "formulas": {
    "vo2MaxRelative": "132.853 - (0.0769 * weight) - (0.3877 * age) + (6.315 * gender) - (3.2649 * time) - (0.1565 * heartRate)",
    "weightKg": "weight / 2.20462",
    "vo2MaxAbsolute": "vo2MaxRelative * weightKg / 1000"
  },
  "outputs": {
    "primary": "vo2MaxRelative",
    "breakdown": [
      "vo2MaxAbsolute",
      "weightKg"

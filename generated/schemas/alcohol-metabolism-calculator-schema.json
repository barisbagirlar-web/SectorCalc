{
  "toolName": "alcohol-metabolism-calculator",
  "inputs": [
    {
      "id": "gender",
      "label": "Gender (Male=1, Female=0)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Select gender: 1 for male, 0 for female",
      "label_i18n": {
        "en": "Gender (Male=1, Female=0)",
        "tr": "Gender (Male=1, Female=0)",
        "de": "Gender (Male=1, Female=0)",
        "fr": "Gender (Male=1, Female=0)",
        "es": "Gender (Male=1, Female=0)",
        "ar": "Gender (Male=1, Female=0)"
      }
    },
    {
      "id": "alcohol_grams",
      "label": "Pure Alcohol Consumed",
      "type": "number",
      "unit": "g",
      "default": 14,
      "businessContext": "Total pure alcohol in grams (typical drink: 14g)",
      "label_i18n": {
        "en": "Pure Alcohol Consumed",
        "tr": "Pure Alcohol Consumed",
        "de": "Pure Alcohol Consumed",
        "fr": "Pure Alcohol Consumed",
        "es": "Pure Alcohol Consumed",
        "ar": "Pure Alcohol Consumed"
      }
    },
    {
      "id": "body_weight_kg",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight in kilograms",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "time_hours",
      "label": "Time Elapsed",
      "type": "number",
      "unit": "h",
      "default": 1,
      "businessContext": "Time since drinking began in hours",
      "label_i18n": {
        "en": "Time Elapsed",
        "tr": "Time Elapsed",
        "de": "Time Elapsed",
        "fr": "Time Elapsed",
        "es": "Time Elapsed",
        "ar": "Time Elapsed"
      }
    },
    {
      "id": "elimination_rate",
      "label": "Elimination Rate",
      "type": "number",
      "unit": "g/dL/h",
      "default": 0.015,
      "businessContext": "Alcohol elimination rate (standard 0.015 g/dL per hour)",
      "label_i18n": {
        "en": "Elimination Rate",
        "tr": "Elimination Rate",
        "de": "Elimination Rate",
        "fr": "Elimination Rate",
        "es": "Elimination Rate",
        "ar": "Elimination Rate"
      }
    }
  ],
  "formulas": {
    "bac_without_time": "(alcohol_grams / (body_weight_kg * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100",
    "current_bac": "Math.max(0, (alcohol_grams / (body_weight_kg * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100 - (elimination_rate * time_hours))",
    "time_to_zero": "current_bac > 0 ? current_bac / elimination_rate : 0"
  },
  "outputs": {
    "primary": "current_bac",
    "breakdown": [
      "bac_without_time",
      "time_to_zero"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics",

{
  "toolName": "email-open-rate-calculator",
  "inputs": [
    {
      "id": "sentCount",
      "label": "Emails Sent",
      "type": "number",
      "unit": "count",
      "default": 1000,
      "businessContext": "Total number of emails sent in the campaign",
      "label_i18n": {
        "en": "Emails Sent",
        "tr": "Emails Sent",
        "de": "Emails Sent",
        "fr": "Emails Sent",
        "es": "Emails Sent",
        "ar": "Emails Sent"
      }
    },
    {
      "id": "bounceCount",
      "label": "Bounces",
      "type": "number",
      "unit": "count",
      "default": 50,
      "businessContext": "Number of emails that bounced (hard and soft bounces)",
      "label_i18n": {
        "en": "Bounces",
        "tr": "Bounces",
        "de": "Bounces",
        "fr": "Bounces",
        "es": "Bounces",
        "ar": "Bounces"
      }
    },
    {
      "id": "openCount",
      "label": "Opens",
      "type": "number",
      "unit": "count",
      "default": 200,
      "businessContext": "Number of emails opened (total opens, not necessarily unique)",
      "label_i18n": {
        "en": "Opens",
        "tr": "Opens",
        "de": "Opens",
        "fr": "Opens",
        "es": "Opens",
        "ar": "Opens"
      }
    },
    {
      "id": "clickCount",
      "label": "Clicks",
      "type": "number",
      "unit": "count",
      "default": 80,
      "businessContext": "Number of link clicks received",
      "label_i18n": {
        "en": "Clicks",
        "tr": "Clicks",
        "de": "Clicks",
        "fr": "Clicks",
        "es": "Clicks",
        "ar": "Clicks"
      }
    }
  ],
  "formulas": {
    "deliveredFormula": "sentCount - bounceCount",
    "openRateFormula": "(openCount / (sentCount - bounceCount)) * 100",
    "clickRateFormula": "(clickCount / (sentCount - bounceCount)) * 100",
    "clickToOpenRateFormula": "(clickCount / openCount) * 100"
  },
  "outputs": {
    "primary": "deliveredFormula",
    "breakdown": [
      {
        "id": "deliveredCount",
        "label": "Delivered Emails",
        "unit": "count",
        "formula": "deliveredFormula"
      },
      {
        "id": "openRate",
        "label": "Open Rate",
        "unit": "%",
        "formula": "openRateFormula"
      },
      {
        "id": "clickRate",
        "label": "Click Rate",
        "unit": "%",
        "formula": "clickRateFormula"
      },
      {
        "id": "clickToOpenRate",
        "label": "Click-to-Open Rate",
        "unit": "%",
        "formula": "clickToOpenRateFormula"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "clickToOpenRateFormula"
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

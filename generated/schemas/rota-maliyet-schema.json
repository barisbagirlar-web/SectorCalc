  "formulas": {
    "DistanceCost": "TotalDistance * FuelConsumption * FuelPrice",
    "TimeCost": "TotalTime * (DriverWage + VehicleDepreciation)",
    "TollCost": "SUM(Tolls_i)",
    "MaintenanceCost": "TotalDistance * MaintRatePerKm",
    "Overhead": "(DistanceCost + TimeCost) * OverheadPct",
    "TotalRouteCost": "DistanceCost + TimeCost + TollCost + MaintenanceCost + Overhead",
    "CostPerKm": "TotalRouteCost / TotalDistance",
    "CostPerDrop": "TotalRouteCost / NumberOfDrops"

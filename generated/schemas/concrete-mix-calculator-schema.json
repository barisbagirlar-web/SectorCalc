{
  "toolName": "concrete-mix-calculator",
  "inputs": [
    {
      "id": "concreteVolume",
      "label": "Concrete Volume",
      "type": "number",
      "unit": "m³",
      "default": 1,
      "businessContext": "Required volume of concrete in cubic meters.",
      "label_i18n": {
        "en": "Concrete Volume",
        "tr": "Concrete Volume",
        "de": "Concrete Volume",
        "fr": "Concrete Volume",
        "es": "Concrete Volume",
        "ar": "Concrete Volume"
      }
    },
    {
      "id": "cementRatio",
      "label": "Cement Ratio",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "Part of cement in the concrete mix ratio (e.g., 1 for 1:2:4).",
      "label_i18n": {
        "en": "Cement Ratio",
        "tr": "Cement Ratio",
        "de": "Cement Ratio",
        "fr": "Cement Ratio",
        "es": "Cement Ratio",
        "ar": "Cement Ratio"
      }
    },
    {
      "id": "sandRatio",
      "label": "Sand Ratio",
      "type": "number",
      "unit": "-",
      "default": 1.5,
      "businessContext": "Part of sand in the concrete mix ratio.",
      "label_i18n": {
        "en": "Sand Ratio",
        "tr": "Sand Ratio",
        "de": "Sand Ratio",
        "fr": "Sand Ratio",
        "es": "Sand Ratio",
        "ar": "Sand Ratio"
      }
    },
    {
      "id": "aggregateRatio",
      "label": "Aggregate Ratio",
      "type": "number",
      "unit": "-",
      "default": 3,
      "businessContext": "Part of aggregate (coarse aggregate) in the mix ratio.",
      "label_i18n": {
        "en": "Aggregate Ratio",
        "tr": "Aggregate Ratio",
        "de": "Aggregate Ratio",
        "fr": "Aggregate Ratio",
        "es": "Aggregate Ratio",
        "ar": "Aggregate Ratio"
      }
    },
    {
      "id": "waterCementRatio",
      "label": "Water-Cement Ratio",
      "type": "number",
      "unit": "-",
      "default": 0.5,
      "businessContext": "Ratio of water to cement by weight for desired workability.",
      "label_i18n": {
        "en": "Water-Cement Ratio",
        "tr": "Water-Cement Ratio",
        "de": "Water-Cement Ratio",
        "fr": "Water-Cement Ratio",
        "es": "Water-Cement Ratio",
        "ar": "Water-Cement Ratio"
      }
    },
    {
      "id": "dryFactor",
      "label": "Dry Volume Factor",
      "type": "number",
      "unit": "-",
      "default": 1.54,
      "businessContext": "Multiplication factor to convert wet volume to dry volume, accounting for air voids.",
      "label_i18n": {
        "en": "Dry Volume Factor",
        "tr": "Dry Volume Factor",
        "de": "Dry Volume Factor",
        "fr": "Dry Volume Factor",
        "es": "Dry Volume Factor",
        "ar": "Dry Volume Factor"
      }
    },
    {
      "id": "wastagePercent",
      "label": "Wastage %",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of extra material to account for handling and compaction losses.",
      "label_i18n": {
        "en": "Wastage %",
        "tr": "Wastage %",
        "de": "Wastage %",
        "fr": "Wastage %",
        "es": "Wastage %",
        "ar": "Wastage %"
      }
    }
  ],
  "formulas": {
    "sumRatio": "cementRatio + sandRatio + aggregateRatio",
    "dryVolume": "concreteVolume * dryFactor",
    "cementVolume": "(cementRatio / sumRatio) * dryVolume",
    "cementWeightBase": "cementVolume * 1440",
    "sandVolume": "(sandRatio / sumRatio) * dryVolume",
    "sandWeightBase": "sandVolume * 1600",
    "aggregateVolume": "(aggregateRatio / sumRatio) * dryVolume",
    "aggregateWeightBase": "aggregateVolume * 1500",
    "waterWeightBase": "cementWeightBase * waterCementRatio",
    "wastageFactor": "1 + wastagePercent / 100",
    "cementWeight": "cementWeightBase * wastageFactor",
    "sandWeight": "sandWeightBase * wastageFactor",
    "aggregateWeight": "aggregateWeightBase * wastageFactor",
    "waterWeight": "waterWeightBase * wastageFactor",
    "totalDryWeight": "cementWeight + sandWeight + aggregateWeight",
    "totalMixWeight": "totalDryWeight + waterWeight"
  },
  "outputs": {
    "primary": "totalMixWeight",
    "breakdown": [
      "cementWeight",
      "sandWeight",
      "aggregateWeight",
      "waterWeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMixWeight"
  },
  "category": "İnşaat & Yapı",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,

{
  "toolName": "cheat-day-calculator",
  "inputs": [
    {
      "id": "normalOEE",
      "label": "Normal OEE (%)",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Normal çalışma günlerinde beklenen OEE değeri."
    },
    {
      "id": "targetWeeklyOEE",
      "label": "Hedef Haftalık OEE (%)",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Hafta sonunda ulaşılmak istenen ortalama OEE."
    },
    {
      "id": "workingDays",
      "label": "Çalışma Günü Sayısı",
      "type": "number",
      "unit": "gün",
      "default": 5,
      "businessContext": "Haftadaki toplam çalışma günü sayısı."
    },
    {
      "id": "cheatDays",
      "label": "Cheat Day Sayısı",
      "type": "number",
      "unit": "gün",
      "default": 1,
      "businessContext": "Haftada izin verilen düşük performanslı gün sayısı."
    }
  ],
  "formulas": {
    "requiredCheatDayOEE": "(targetWeeklyOEE * workingDays - normalOEE * (workingDays - cheatDays)) / cheatDays",
    "normalContribution": "normalOEE * (workingDays - cheatDays) / workingDays",
    "cheatContribution": "requiredCheatDayOEE * cheatDays / workingDays",
    "weeklyOEECheck": "normalContribution + cheatContribution"
  },
  "outputs": {
    "primary": "requiredCheatDayOEE",
    "breakdown": [
      "normalContribution",
      "cheatContribution",
      "weeklyOEECheck"
    ]
  },
  "category": "Malzeme, Fire & OEE",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

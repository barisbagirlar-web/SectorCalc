{
  "toolName": "cheat-day-calculator",
  "inputs": [
    {
      "id": "normalDailyOutput",
      "label": "Normal Daily Output",
      "type": "number",
      "unit": "units",
      "default": 100,
      "businessContext": "Standard number of units produced per normal working day.",
      "label_i18n": {
        "en": "Normal Daily Output",
        "tr": "Normal Daily Output",
        "de": "Normal Daily Output",
        "fr": "Normal Daily Output",
        "es": "Normal Daily Output",
        "ar": "Normal Daily Output"
      }
    },
    {
      "id": "cheatDayOutputPercent",
      "label": "Cheat Day Output (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Percentage of normal output achieved on a cheat day.",
      "label_i18n": {
        "en": "Cheat Day Output (%)",
        "tr": "Cheat Day Output (%)",
        "de": "Cheat Day Output (%)",
        "fr": "Cheat Day Output (%)",
        "es": "Cheat Day Output (%)",
        "ar": "Cheat Day Output (%)"
      }
    },
    {
      "id": "numCheatDays",
      "label": "Number of Cheat Days",
      "type": "number",
      "unit": "days",
      "default": 1,
      "businessContext": "Number of cheat days in the period.",
      "label_i18n": {
        "en": "Number of Cheat Days",
        "tr": "Number of Cheat Days",
        "de": "Number of Cheat Days",
        "fr": "Number of Cheat Days",
        "es": "Number of Cheat Days",
        "ar": "Number of Cheat Days"
      }
    },
    {
      "id": "totalDays",
      "label": "Total Days in Period",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Total working days in the calculation period (e.g., month).",
      "label_i18n": {
        "en": "Total Days in Period",
        "tr": "Total Days in Period",
        "de": "Total Days in Period",
        "fr": "Total Days in Period",
        "es": "Total Days in Period",
        "ar": "Total Days in Period"
      }
    }
  ],
  "formulas": {
    "normalContribution": "normalDailyOutput * (totalDays - numCheatDays)",
    "cheatContribution": "normalDailyOutput * (cheatDayOutputPercent / 100) * numCheatDays",
    "effectiveOutput": "normalDailyOutput * (totalDays - numCheatDays) + normalDailyOutput * (cheatDayOutputPercent / 100) * numCheatDays",
    "potentialFullOutput": "normalDailyOutput * totalDays",
    "loss": "normalDailyOutput * totalDays - (normalDailyOutput * (totalDays - numCheatDays) + normalDailyOutput * (cheatDayOutputPercent / 100) * numCheatDays)"
  },
  "outputs": {
    "primary": "effectiveOutput",
    "breakdown": [
      "normalContribution",
      "cheatContribution",
      "potentialFullOutput",
      "loss"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "loss",
    "unit": "%"
  },
  "category": "Enerji & Karbon",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "categorySlug": "process-chemical",
  "catalogCategory": "health-body",

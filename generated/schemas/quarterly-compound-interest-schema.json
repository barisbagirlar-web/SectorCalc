{
  "toolName": "quarterly-compound-interest",
  "inputs": [
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "Initial lump sum invested"
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Nominal annual interest rate"
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Investment duration in years"
    },
    {
      "id": "quarterlyContribution",
      "label": "Quarterly Contribution",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Additional amount added at end of each quarter (0 if none)"
    }
  ],
  "formulas": {
    "quarterlyRate": "annualRate / 100 / 4",
    "periods": "years * 4",
    "fvPrincipal": "principal * Math.pow(1 + quarterlyRate, periods)",
    "fvContributions": "quarterlyContribution > 0 ? quarterlyContribution * (Math.pow(1 + quarterlyRate, periods) - 1) / quarterlyRate : 0",
    "totalFutureValue": "fvPrincipal + fvContributions",
    "totalContributions": "principal + quarterlyContribution * periods",
    "totalInterest": "totalFutureValue - totalContributions"
  },
  "outputs": {
    "primary": "totalFutureValue",
    "breakdown": [
      "fvPrincipal",
      "fvContributions",
      "totalContributions",
      "totalInterest"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

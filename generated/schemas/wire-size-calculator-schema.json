{
  "toolName": "wire-size-calculator",
  "inputs": [
    {
      "id": "current",
      "label": "Nominal Current",
      "type": "number",
      "unit": "A",
      "default": 10,
      "businessContext": "Continuous load current"
    },
    {
      "id": "voltage",
      "label": "System Voltage",
      "type": "number",
      "unit": "V",
      "default": 230,
      "businessContext": "Nominal system voltage"
    },
    {
      "id": "length",
      "label": "Cable Length",
      "type": "number",
      "unit": "m",
      "default": 50,
      "businessContext": "One-way cable length"
    },
    {
      "id": "material",
      "label": "Conductor Material",
      "type": "number",
      "unit": "-",
      "default": 0,
      "businessContext": "0: Copper, 1: Aluminum"
    },
    {
      "id": "voltageDropPercent",
      "label": "Max Voltage Drop Percentage",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Allowable voltage drop"
    },
    {
      "id": "phases",
      "label": "Number of Phases",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "1: Single-phase/DC, 3: Three-phase"
    }
  ],
  "formulas": {
    "requiredArea": "(phases == 1 ? 2 : Math.sqrt(3)) * length * current * (material == 0 ? 0.0172 : 0.0282) / (voltage * (voltageDropPercent / 100))",
    "voltageDrop": "(phases == 1 ? 2 : Math.sqrt(3)) * length * current * (material == 0 ? 0.0172 : 0.0282) / requiredArea",
    "powerLoss": "current * voltageDrop",
    "recommendedSize": "requiredArea <= 1.5 ? 1.5 : requiredArea <= 2.5 ? 2.5 : requiredArea <= 4 ? 4 : requiredArea <= 6 ? 6 : requiredArea <= 10 ? 10 : requiredArea <= 16 ? 16 : requiredArea <= 25 ? 25 : requiredArea <= 35 ? 35 : requiredArea <= 50 ? 50 : requiredArea <= 70 ? 70 : requiredArea <= 95 ? 95 : requiredArea <= 120 ? 120 : requiredArea <= 150 ? 150 : requiredArea <= 185 ? 185 : requiredArea <= 240 ? 240 : requiredArea <= 300 ? 300 : requiredArea <= 400 ? 400 : 500"
  },
  "outputs": {
    "primary": "requiredArea",
    "breakdown": [
      "voltageDrop",
      "powerLoss",
      "recommendedSize"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Metal & Sac İşleme",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "electrical-power-systems",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",
  "categoryId": "conversion"
}

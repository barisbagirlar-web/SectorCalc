  "formulas": {
    "surfaceArea": "2 * (length * width + length * height + width * height)",
    "totalWireLengthCm": "(4 / barSpacing) * (width * height + length * height + length * width) + 4 * (length + width + height)",
    "totalWireLength": "totalWireLengthCm / 100",
    "meshArea": "surfaceArea / 10000"
  },

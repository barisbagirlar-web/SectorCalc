{
  "toolName": "pulse-pressure-calculator",
  "inputs": [
    {
      "id": "systolicBP",
      "label": "Systolic Blood Pressure",
      "type": "number",
      "unit": "mmHg",
      "default": 120,
      "businessContext": "Measured systolic pressure in the brachial artery using a validated oscillometric device.",
      "label_i18n": {
        "en": "Systolic Blood Pressure",
        "tr": "Systolic Blood Pressure",
        "de": "Systolic Blood Pressure",
        "fr": "Systolic Blood Pressure",
        "es": "Systolic Blood Pressure",
        "ar": "Systolic Blood Pressure"
      }
    },
    {
      "id": "diastolicBP",
      "label": "Diastolic Blood Pressure",
      "type": "number",
      "unit": "mmHg",
      "default": 80,
      "businessContext": "Measured diastolic pressure, Korotkoff phase V.",
      "label_i18n": {
        "en": "Diastolic Blood Pressure",
        "tr": "Diastolic Blood Pressure",
        "de": "Diastolic Blood Pressure",
        "fr": "Diastolic Blood Pressure",
        "es": "Diastolic Blood Pressure",
        "ar": "Diastolic Blood Pressure"
      }
    },
    {
      "id": "heartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Palpated or electronically measured pulse rate per minute, at rest for at least 5 minutes.",
      "label_i18n": {
        "en": "Resting Heart Rate",
        "tr": "Resting Heart Rate",
        "de": "Resting Heart Rate",
        "fr": "Resting Heart Rate",
        "es": "Resting Heart Rate",
        "ar": "Resting Heart Rate"
      }
    },
    {
      "id": "age",
      "label": "Patient Age",
      "type": "number",
      "unit": "years",
      "default": 50,
      "businessContext": "Age of the patient for normalization of expected pulse pressure.",
      "label_i18n": {
        "en": "Patient Age",
        "tr": "Patient Age",
        "de": "Patient Age",
        "fr": "Patient Age",
        "es": "Patient Age",
        "ar": "Patient Age"
      }
    }
  ],
  "formulas": {
    "pulsePressure": "systolicBP - diastolicBP",
    "meanArterialPressure": "diastolicBP + pulsePressure / 3",
    "ratePressureProduct": "systolicBP * heartRate",
    "expectedPulsePressure": "35 + 0.4 * age",
    "pulsePressureDeviation": "pulsePressure - expectedPulsePressure"
  },
  "outputs": {
    "primary": "pulsePressure",
    "breakdown": [
      "meanArterialPressure",
      "ratePressureProduct",
      "expectedPulsePressure",
      "pulsePressureDeviation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pulsePressureDeviation"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Fizik & Mekanik",
  "premiumRequired": false,

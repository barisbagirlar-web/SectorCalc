{
  "toolName": "bayes-theorem-calculator",
  "inputs": [
    {
      "id": "prior",
      "label": "P(A) - Prior Probability",
      "type": "number",
      "unit": "unit",
      "default": 0.01,
      "businessContext": "Base rate or prevalence of the condition (between 0 and 1)",
      "label_i18n": {

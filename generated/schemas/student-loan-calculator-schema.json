{
  "toolName": "student-loan-calculator",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "businessContext": "Total principal amount borrowed for education expenses",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Loan Amount",
        "de": "Loan Amount",
        "fr": "Loan Amount",
        "es": "Loan Amount",
        "ar": "Loan Amount"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 4.5,
      "businessContext": "Fixed annual interest rate on the student loan",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Repayment period in years after any deferment ends",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    },
    {
      "id": "defermentMonths",
      "label": "Deferment Period",
      "type": "number",
      "unit": "months",
      "default": 6,
      "businessContext": "Number of months before repayment starts, during which interest accrues and capitalizes",
      "label_i18n": {
        "en": "Deferment Period",
        "tr": "Deferment Period",
        "de": "Deferment Period",
        "fr": "Deferment Period",
        "es": "Deferment Period",
        "ar": "Deferment Period"
      }
    }
  ],
  "formulas": {
    "monthlyRate": "annualInterestRate / 100 / 12",
    "effectivePrincipal": "loanAmount * (1 + monthlyRate) ** defermentMonths",
    "n": "loanTermYears * 12",
    "monthlyPayment": "effectivePrincipal * monthlyRate * (1 + monthlyRate) ** n / ((1 + monthlyRate) ** n - 1)",
    "totalPayment": "monthlyPayment * n",
    "totalInterest": "totalPayment - effectivePrincipal"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "totalPayment",
      "totalInterest",
      "effectivePrincipal"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalInterest"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "education-academic",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

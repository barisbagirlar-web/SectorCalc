{
  "toolName": "vacuum-pump-time-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "posetHacim",
      "label": "Bag Volume (m³)",
      "type": "number",
      "unit": "m3",
      "default": 0.01,
      "min": 0,
      "businessContext": "Package volume."
    },
    {
      "id": "pompaDebi",
      "label": "Pump Flow (m³/s)",
      "type": "number",
      "unit": "m3/s",
      "default": 0.0005,
      "min": 0,
      "businessContext": "Vacuum pump flow."
    },
    {
      "id": "baslangicBasinc",
      "label": "Initial Pressure (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 101325,
      "min": 0,
      "businessContext": "Atmospheric pressure."
    },
    {
      "id": "hedefBasinc",
      "label": "Target Pressure (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 5000,
      "min": 0,
      "businessContext": "Target vacuum pressure."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(posetHacim / Math.max(0.0001, pompaDebi)) * Math.log(Math.max(0.0001, baslangicBasinc / Math.max(0.0001, hedefBasinc)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "s",
    "breakdown": {
      "result": "Vakum Time"
    },
    "breakdownUnits": {
      "result": "s"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling parameters for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate vacuum pump time to reach target pressure.",
      "long": "Calculate vacuum pump time to reach target pressure."
    }
  },
  "sectorSlug": "daily-renovation"
}

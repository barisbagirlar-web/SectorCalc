{
  "toolName": "viscous-pump-power-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "flow",
      "label": "Flow Rate (m³/s)",
      "type": "number",
      "unit": "m3/s",
      "default": 0.005,
      "min": 0,
      "businessContext": "Liquid flow rate."
    },
    {
      "id": "basincDusumu",
      "label": "Pressure Drop (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 200000,
      "min": 0,
      "businessContext": "Total pipe pressure loss."
    },
    {
      "id": "pompaVerim",
      "label": "Pump Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 75,
      "min": 0,
      "businessContext": "Pump efficiency."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(flow * basincDusumu) / Math.max(0.0001, (pompaVerim / 100))"
  },
  "outputs": {
    "primary": "result",
    "unit": "W",
    "breakdown": {
      "result": "Gerekmost Pump Power"
    },
    "breakdownUnits": {
      "result": "W"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling parameters for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,

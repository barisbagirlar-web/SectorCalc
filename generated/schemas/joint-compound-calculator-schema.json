{
  "toolName": "joint-compound-calculator",
  "inputs": [
    {
      "id": "numSheets",
      "label": "Number of Drywall Sheets",
      "type": "number",
      "unit": "adet",
      "default": 10,
      "businessContext": "Total number of drywall sheets to be taped and finished.",
      "label_i18n": {
        "en": "Number of Drywall Sheets",
        "tr": "Number of Drywall Sheets",
        "de": "Number of Drywall Sheets",
        "fr": "Number of Drywall Sheets",
        "es": "Number of Drywall Sheets",
        "ar": "Number of Drywall Sheets"
      }
    },
    {
      "id": "jointLength",
      "label": "Average Joint Length per Sheet",
      "type": "number",
      "unit": "m",
      "default": 3.6,
      "businessContext": "Average linear length of joints per sheet (including butt and tapered joints).",
      "label_i18n": {
        "en": "Average Joint Length per Sheet",
        "tr": "Average Joint Length per Sheet",
        "de": "Average Joint Length per Sheet",
        "fr": "Average Joint Length per Sheet",
        "es": "Average Joint Length per Sheet",
        "ar": "Average Joint Length per Sheet"
      }
    },
    {
      "id": "jointWidth",
      "label": "Joint Width",
      "type": "number",
      "unit": "mm",
      "default": 150,
      "businessContext": "Width of the joint compound application area across the joint.",
      "label_i18n": {
        "en": "Joint Width",
        "tr": "Joint Width",
        "de": "Joint Width",
        "fr": "Joint Width",
        "es": "Joint Width",
        "ar": "Joint Width"
      }
    },
    {
      "id": "thickness",
      "label": "Compound Thickness per Coat",
      "type": "number",
      "unit": "mm",
      "default": 1.5,
      "businessContext": "Applied wet thickness of joint compound per coat.",
      "label_i18n": {
        "en": "Compound Thickness per Coat",
        "tr": "Compound Thickness per Coat",
        "de": "Compound Thickness per Coat",
        "fr": "Compound Thickness per Coat",
        "es": "Compound Thickness per Coat",
        "ar": "Compound Thickness per Coat"
      }
    },
    {
      "id": "numCoats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Number of coats applied (e.g., tape coat, fill coat, finish coat).",
      "label_i18n": {
        "en": "Number of Coats",
        "tr": "Number of Coats",
        "de": "Number of Coats",
        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    },
    {
      "id": "coverageFactor",
      "label": "Coverage Factor",
      "type": "number",
      "unit": "m²·mm/kg",
      "default": 1.2,
      "businessContext": "Manufacturer-specified coverage rate per mm thickness per kg of compound.",
      "label_i18n": {
        "en": "Coverage Factor",
        "tr": "Coverage Factor",
        "de": "Coverage Factor",
        "fr": "Coverage Factor",
        "es": "Coverage Factor",
        "ar": "Coverage Factor"
      }
    }
  ],
  "formulas": {
    "totalJointArea": "numSheets * jointLength * (jointWidth / 1000) * numCoats",
    "totalThickness": "thickness * numCoats",
    "totalCompound": "(numSheets * jointLength * (jointWidth / 1000) * thickness * numCoats) / coverageFactor"
  },
  "outputs": {
    "primary": "totalCompound",
    "breakdown": [
      "totalJointArea",
      "totalThickness"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCompound",
    "unit": "lb"
  },
  "category": "Diğer",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,

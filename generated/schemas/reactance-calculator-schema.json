        "ar": "Frequency"
      },
      "businessContext_i18n": {
        "en": "Operating frequency of the AC circuit",
        "tr": "AC devresinin çalışma frekansı"
      }
    },
    {
      "id": "capacitance",
      "label": "Capacitance",
      "type": "number",
      "unit": "F",
      "default": 0.000001,
      "businessContext": "Capacitance value of the capacitor",
      "label_i18n": {
        "en": "Capacitance",
        "tr": "Kapasitans",
        "de": "Capacitance",
        "fr": "Capacitance",
        "es": "Capacitance",
        "ar": "Capacitance"
      },
      "businessContext_i18n": {
        "en": "Capacitance value of the capacitor",
        "tr": "Kondansatörün kapasitans değeri"
      }
    },
    {
      "id": "inductance",
      "label": "Inductance",
      "type": "number",
      "unit": "H",
      "default": 0.1,
      "businessContext": "Inductance value of the inductor",
      "label_i18n": {
        "en": "Inductance",
        "tr": "Endüktans",
        "de": "Inductance",
        "fr": "Inductance",
        "es": "Inductance",
        "ar": "Inductance"
      },
      "businessContext_i18n": {
        "en": "Inductance value of the inductor",
        "tr": "Bobinin endüktans değeri"
      }
    },
    {
      "id": "connectionType",
      "label": "Connection Type",
      "type": "number",
      "unit": "0=Series, 1=Parallel",
      "default": 0,
      "businessContext": "Connection configuration of LC circuit",
      "label_i18n": {
        "en": "Connection Type",
        "tr": "Bağlantı Türü",
        "de": "Connection Type",
        "fr": "Connection Type",
        "es": "Connection Type",
        "ar": "Connection Type"
      },
      "businessContext_i18n": {
        "en": "Connection configuration of LC circuit",
        "tr": "LC devresinin bağlantı konfigürasyonu"
      }
    }
  ],
  "formulas": {
    "Xc": "1 / (2 * Math.PI * frequency * capacitance)",
    "Xl": "2 * Math.PI * frequency * inductance",
    "totalReactance": "connectionType === 0 ? (Xl - Xc) : ((Xc * Xl) / (Xl - Xc))"
  },
  "outputs": {
    "primary": "totalReactance",
    "breakdown": [
      "Xc",
      "Xl"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalReactance",
    "unit": "Hz"
  },

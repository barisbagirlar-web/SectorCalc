{
  "toolName": "reactance-calculator",
  "inputs": [
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 50,
      "businessContext": "Operating frequency of the AC circuit",
      "label_i18n": {
        "en": "Frequency",
        "tr": "Frekans",
        "de": "Frequency",

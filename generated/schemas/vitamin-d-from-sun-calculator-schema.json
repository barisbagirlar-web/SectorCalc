{
  "toolName": "vitamin-d-from-sun-calculator",
  "inputs": [
    {
      "id": "uv_index",
      "label": "UV Index",
      "type": "number",
      "unit": "unit",
      "default": 5,
      "businessContext": "UV Index at the location (0-11+, typically from weather service)",
      "label_i18n": {
        "en": "UV Index",
        "tr": "UV Index",
        "de": "UV Index",
        "fr": "UV Index",
        "es": "UV Index",
        "ar": "UV Index"
      }
    },
    {
      "id": "exposure_time_minutes",
      "label": "Exposure Time",
      "type": "number",
      "unit": "minutes",
      "default": 15,
      "businessContext": "Duration of sun exposure in minutes",
      "label_i18n": {
        "en": "Exposure Time",
        "tr": "Exposure Time",
        "de": "Exposure Time",
        "fr": "Exposure Time",
        "es": "Exposure Time",
        "ar": "Exposure Time"
      }
    },
    {
      "id": "body_area_percent",
      "label": "Body Area Exposed",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage of body surface area exposed (e.g., face and hands ~10%, full body ~100%)",
      "label_i18n": {
        "en": "Body Area Exposed",
        "tr": "Body Area Exposed",
        "de": "Body Area Exposed",
        "fr": "Body Area Exposed",
        "es": "Body Area Exposed",
        "ar": "Body Area Exposed"
      }
    },
    {
      "id": "skin_type",
      "label": "Skin Type (Fitzpatrick)",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Fitzpatrick skin type (1=very fair, 6=very dark)",
      "label_i18n": {
        "en": "Skin Type (Fitzpatrick)",
        "tr": "Skin Type (Fitzpatrick)",
        "de": "Skin Type (Fitzpatrick)",
        "fr": "Skin Type (Fitzpatrick)",
        "es": "Skin Type (Fitzpatrick)",
        "ar": "Skin Type (Fitzpatrick)"
      }
    },
    {
      "id": "cloud_cover_percent",
      "label": "Cloud Cover",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of sky covered by clouds (0=clear, 100=overcast)",
      "label_i18n": {
        "en": "Cloud Cover",
        "tr": "Cloud Cover",
        "de": "Cloud Cover",
        "fr": "Cloud Cover",
        "es": "Cloud Cover",
        "ar": "Cloud Cover"
      }
    }
  ],
  "formulas": {
    "skin_factor": "2.2 - 0.3 * skin_type",
    "cloud_factor": "1 - (cloud_cover_percent / 100) * 0.5",
    "effective_uv_index": "uv_index * cloud_factor",
    "estimated_vitamin_d_iu": "effective_uv_index * exposure_time_minutes * 50 * body_area_percent / 100 * skin_factor"
  },
  "outputs": {
    "primary": "estimated_vitamin_d_iu",
    "breakdown": [
      "skin_factor",
      "cloud_factor",
      "effective_uv_index"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "estimated_vitamin_d_iu",
    "unit": "minutes"
  },

        "fr": "Type d'affectation de quart",
        "es": "Tipo de asignación de turno",
        "ar": "نوع نوبة العمل"
      }
    },
    {
      "id": "sleepQuality",
      "label": "Sleep Quality",
      "type": "number",
      "unit": "scale 1-10",
      "default": 5,
      "businessContext": "Self-assessed sleep quality rating",
      "label_i18n": {
        "en": "Sleep Quality",
        "tr": "Uyku Kalitesi",
        "de": "Schlafqualität",
        "fr": "Qualité du sommeil",
        "es": "Calidad del sueño",
        "ar": "جودة النوم"
      },
      "businessContext_i18n": {

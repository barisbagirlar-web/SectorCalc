{
  "toolName": "sleep-need-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Worker's age in years"
    },
    {
      "id": "shiftType",
      "label": "Shift Type",
      "type": "number",
      "unit": "code (0: day, 1: night, 2: rotating)",
      "default": 0,
      "businessContext": "Type of shift assignment"
    },
    {
      "id": "sleepQuality",
      "label": "Sleep Quality",
      "type": "number",
      "unit": "scale 1-10",
      "default": 5,
      "businessContext": "Self-assessed sleep quality rating"
    },
    {
      "id": "desiredWakeUp",
      "label": "Desired Wake-up Time",
      "type": "number",
      "unit": "minutes from midnight",
      "default": 420,
      "businessContext": "Desired wake-up time in minutes past midnight"
    },
    {
      "id": "sleepLatency",
      "label": "Sleep Latency",
      "type": "number",
      "unit": "minutes",
      "default": 15,
      "businessContext": "Average time to fall asleep"
    },
    {
      "id": "physicalActivity",
      "label": "Physical Activity",
      "type": "number",
      "unit": "hours/week",
      "default": 2,
      "businessContext": "Weekly physical activity hours"
    }
  ],
  "formulas": {
    "baseSleepMinutes": "(age < 18 ? 540 : (age > 65 ? 450 : 480))",
    "shiftAdjustment": "(shiftType === 1 ? 30 : (shiftType === 2 ? 15 : 0))",
    "qualityAdjustment": "(sleepQuality - 5) * 5",
    "activityAdjustment": "(physicalActivity > 5 ? -10 : 0)",
    "totalSleepMinutes": "baseSleepMinutes + shiftAdjustment + qualityAdjustment + activityAdjustment",
    "bedtimeMinutes": "(desiredWakeUp - totalSleepMinutes + 1440) % 1440",
    "sleepDurationHours": "totalSleepMinutes / 60"
  },
  "outputs": {
    "primary": "'Recommended sleep: ' + Math.round(totalSleepMinutes / 60 * 10) / 10 + ' hours'",
    "breakdown": [
      "'Bedtime: ' + Math.floor(bedtimeMinutes / 60) + ':' + ('0' + (bedtimeMinutes % 60)).slice(-2)",
      "'Sleep duration: ' + Math.round(totalSleepMinutes) + ' minutes (' + Math.round(totalSleepMinutes / 60 * 10) / 10 + ' hours)'"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

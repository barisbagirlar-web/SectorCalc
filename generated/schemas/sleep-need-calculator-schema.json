{
  "toolName": "sleep-need-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Worker's age in years",
      "label_i18n": {
        "en": "Age",
        "tr": "Yaş",
        "de": "Alter",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      },
      "businessContext_i18n": {
        "en": "Worker's age in years",
        "tr": "İşçinin yıl cinsinden yaşı"
      }
    },
    {
      "id": "shiftType",
      "label": "Shift Type",
      "type": "number",
      "unit": "code (0: day, 1: night, 2: rotating)",
      "default": 0,
      "businessContext": "Type of shift assignment",
      "label_i18n": {
        "en": "Shift Type",
        "tr": "Vardiya Türü",
        "de": "Schichttyp",
        "fr": "Shift Type",
        "es": "Shift Type",
        "ar": "Shift Type"
      },
      "businessContext_i18n": {
        "en": "Type of shift assignment",
        "tr": "Vardiya atama türü"
      }
    },
    {
      "id": "sleepQuality",
      "label": "Sleep Quality",
      "type": "number",
      "unit": "scale 1-10",
      "default": 5,
      "businessContext": "Self-assessed sleep quality rating",
      "label_i18n": {
        "en": "Sleep Quality",
        "tr": "Uyku Kalitesi",
        "de": "Sleep Quality",
        "fr": "Sleep Quality",
        "es": "Sleep Quality",
        "ar": "Sleep Quality"
      },
      "businessContext_i18n": {
        "en": "Self-assessed sleep quality rating",
        "tr": "Kendi değerlendirilen uyku kalitesi puanı"
      }
    },
    {
      "id": "desiredWakeUp",
      "label": "Desired Wake-up Time",
      "type": "number",
      "unit": "minutes from midnight",
      "default": 420,
      "businessContext": "Desired wake-up time in minutes past midnight",
      "label_i18n": {
        "en": "Desired Wake-up Time",
        "tr": "İstenen Uyanma Saati",
        "de": "Desired Wake-up Time",
        "fr": "Desired Wake-up Time",
        "es": "Desired Wake-up Time",
        "ar": "Desired Wake-up Time"
      },
      "businessContext_i18n": {
        "en": "Desired wake-up time in minutes past midnight",
        "tr": "Gece yarısından sonra dakika cinsinden istenen uyanma saati"
      }
    },
    {
      "id": "sleepLatency",
      "label": "Sleep Latency",
      "type": "number",
      "unit": "minutes",
      "default": 15,
      "businessContext": "Average time to fall asleep",
      "label_i18n": {
        "en": "Sleep Latency",
        "tr": "Uykuya Dalma Süresi",
        "de": "Sleep Latency",
        "fr": "Sleep Latency",
        "es": "Sleep Latency",
        "ar": "Sleep Latency"
      },
      "businessContext_i18n": {
        "en": "Average time to fall asleep",
        "tr": "Uykuya dalmak için ortalama süre"
      }
    },
    {
      "id": "physicalActivity",
      "label": "Physical Activity",
      "type": "number",
      "unit": "hours/week",
      "default": 2,
      "businessContext": "Weekly physical activity hours",
      "label_i18n": {
        "en": "Physical Activity",
        "tr": "Fiziksel Aktivite",
        "de": "Körperliche Aktivität",
        "fr": "Physical Activity",
        "es": "Physical Activity",
        "ar": "Physical Activity"
      },
      "businessContext_i18n": {
        "en": "Weekly physical activity hours",
        "tr": "Haftalık fiziksel aktivite saati"
      }
    }
  ],
  "formulas": {
    "baseSleepMinutes": "(age < 18 ? 540 : (age > 65 ? 450 : 480))",
    "shiftAdjustment": "(shiftType === 1 ? 30 : (shiftType === 2 ? 15 : 0))",
    "qualityAdjustment": "(sleepQuality - 5) * 5",
    "activityAdjustment": "(physicalActivity > 5 ? -10 : 0)",
    "totalSleepMinutes": "baseSleepMinutes + shiftAdjustment + qualityAdjustment + activityAdjustment",
    "bedtimeMinutes": "(desiredWakeUp - totalSleepMinutes + 1440) % 1440",
    "sleepDurationHours": "totalSleepMinutes / 60"
  },
  "outputs": {
    "primary": "sleepDurationHours",
    "breakdown": [
      "'Bedtime: ' + Math.floor(bedtimeMinutes / 60) + ':' + ('0' + (bedtimeMinutes % 60)).slice(-2)",
      "'Sleep duration: ' + Math.round(totalSleepMinutes) + ' minutes (' + Math.round(totalSleepMinutes / 60 * 10) / 10 + ' hours)'"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result",
    "unit": "%",
    "breakdownUnits": {
      "'Bedtime: ' + Math.floor(bedtimeMinutes / 60) + ':' + ('0' + (bedtimeMinutes % 60)).slice(-2)": "min",
      "'Sleep duration: ' + Math.round(totalSleepMinutes) + ' minutes (' + Math.round(totalSleepMinutes / 60 * 10) / 10 + ' hours)'": "%"
    }
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Sağlık & Tıp",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "workforce-hr",
  "sectorId": "saglik",
  "profession": "Biyomedikal Mühendisi",
  "categoryId": "quality",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

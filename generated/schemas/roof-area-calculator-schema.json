{
  "toolName": "roof-area-calculator",
  "inputs": [
    {
      "id": "buildingWidth",
      "label": "Building Width",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Total external width of the building footprint in meters"
    },
    {
      "id": "buildingLength",
      "label": "Building Length",
      "type": "number",
      "unit": "m",
      "default": 12,
      "businessContext": "Total external length of the building footprint in meters"
    },
    {
      "id": "roofPitch",
      "label": "Roof Pitch",
      "type": "number",
      "unit": "°",
      "default": 30,
      "businessContext": "Inclination angle of the roof slope in degrees (0 < angle < 90)"
    },
    {
      "id": "overhang",
      "label": "Overhang",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "Horizontal projection of the roof beyond the walls on all sides (uniform)"
    }
  ],
  "formulas": {
    "effectiveWidth": "buildingWidth + 2 * overhang",
    "effectiveLength": "buildingLength + 2 * overhang",
    "angleRad": "roofPitch * Math.PI / 180",
    "slopeFactor": "1 / Math.cos(angleRad)",
    "footprintArea": "effectiveWidth * effectiveLength",
    "roofArea": "footprintArea / Math.cos(angleRad)"
  },
  "outputs": {
    "primary": "roofArea",
    "breakdown": [
      "footprintArea",
      "slopeFactor"
    ]
  },
  "category": "İnşaat & Yapı",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "insaat",
  "profession": "Proje Müdürü",
  "categoryId": "diger"
}

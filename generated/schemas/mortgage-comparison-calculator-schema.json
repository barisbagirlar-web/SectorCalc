  "formulas": {
    "taksit1": "faiz1 === 0 ? kredi1 / Math.max(1, vade) : kredi1 * ((faiz1 / 1200) / (1 - Math.pow(1 + faiz1 / 1200, -vade)))",
    "taksit2": "faiz2 === 0 ? kredi2 / Math.max(1, vade) : kredi2 * ((faiz2 / 1200) / (1 - Math.pow(1 + faiz2 / 1200, -vade)))",
    "sonuc": "(faiz1 === 0 ? kredi1 / Math.max(1, vade) : kredi1 * ((faiz1 / 1200) / (1 - Math.pow(1 + faiz1 / 1200, -vade)))) - (faiz2 === 0 ? kredi2 / Math.max(1, vade) : kredi2 * ((faiz2 / 1200) / (1 - Math.pow(1 + faiz2 / 1200, -vade))))"
  },

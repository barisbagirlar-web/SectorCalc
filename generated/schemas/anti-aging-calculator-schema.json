  "formulas": {
    "accelerationFactor": "Math.exp((activationEnergy/8.617333262145e-5) * (1/(referenceTemperature+273.15) - 1/(temperature+273.15)))",
    "treatmentEffectivenessFactor": "1 - treatmentEffectiveness",
    "equivalentTime": "referenceTime * (Math.exp((activationEnergy/8.617333262145e-5) * (1/(referenceTemperature+273.15) - 1/(temperature+273.15))) * (1 - treatmentEffectiveness))"
  },
  "outputs": {
    "primary": "equivalentTime",
    "breakdown": [
      "accelerationFactor",
      "treatmentEffectivenessFactor"
    ]
  },

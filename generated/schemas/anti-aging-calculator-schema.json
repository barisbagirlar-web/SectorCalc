      "label": "Treatment Effectiveness",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Effectiveness factor of the anti-aging treatment, ranging from 0 (no effect) to 1 (fully effective).",
      "label_i18n": {
        "en": "Treatment Effectiveness",

  "formulas": {
    "flowRateFromAreaVelocity": "velocity * (crossSectionArea > 0 ? crossSectionArea : (innerDiameter > 0 ? Math.PI * (innerDiameter / 2000) ** 2 : 0))",
    "flowRateFromMass": "fluidDensity > 0 ? massFlowRate / fluidDensity : 0"
  },
  "outputs": {
    "primary": "flowRateFromAreaVelocity",
    "breakdown": [

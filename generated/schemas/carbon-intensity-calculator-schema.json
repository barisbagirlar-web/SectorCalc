  "formulas": {
    "totalEmissions": "electricityConsumption * electricityEmissionFactor + naturalGasConsumption * naturalGasEmissionFactor + dieselConsumption * dieselEmissionFactor",
    "electricityEmissions": "electricityConsumption * electricityEmissionFactor",
    "naturalGasEmissions": "naturalGasConsumption * naturalGasEmissionFactor",
    "dieselEmissions": "dieselConsumption * dieselEmissionFactor",
    "carbonIntensity": "totalEmissions / productionOutput"
  },
  "outputs": {
    "primary": "carbonIntensity",

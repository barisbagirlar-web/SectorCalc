{
  "toolName": "runoff-calculator",
  "inputs": [
    {
      "id": "catchmentArea",
      "label": "Catchment Area",
      "type": "number",
      "unit": "m²",
      "defaultValue": 1000,
      "businessContext": "The surface area of the catchment contributing to runoff.",
      "label_i18n": {
        "en": "Catchment Area",
        "tr": "Catchment Area",
        "de": "Catchment Area",
        "fr": "Catchment Area",
        "es": "Catchment Area",
        "ar": "Catchment Area"
      }
    },
    {
      "id": "runoffCoefficient",
      "label": "Runoff Coefficient (C)",
      "type": "number",
      "unit": "unit",
      "defaultValue": 0.5,
      "businessContext": "Dimensionless coefficient representing the fraction of rainfall that becomes runoff, depending on surface type and slope.",
      "label_i18n": {
        "en": "Runoff Coefficient (C)",
        "tr": "Runoff Coefficient (C)",
        "de": "Runoff Coefficient (C)",
        "fr": "Runoff Coefficient (C)",
        "es": "Runoff Coefficient (C)",
        "ar": "Runoff Coefficient (C)"
      }
    },
    {
      "id": "rainfallIntensity",
      "label": "Rainfall Intensity (I)",
      "type": "number",
      "unit": "mm/h",
      "defaultValue": 50,
      "businessContext": "Design rainfall intensity in millimeters per hour, typically derived from IDF curves for the specified duration and return period.",
      "label_i18n": {
        "en": "Rainfall Intensity (I)",
        "tr": "Rainfall Intensity (I)",
        "de": "Rainfall Intensity (I)",
        "fr": "Rainfall Intensity (I)",
        "es": "Rainfall Intensity (I)",
        "ar": "Rainfall Intensity (I)"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "defaultValue": 1.1,
      "businessContext": "Multiplier applied to the calculated runoff to account for uncertainties and future changes in catchment conditions.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "runoffBase": "runoffCoefficient * rainfallIntensity * catchmentArea / 3600",
    "runoffLps": "runoffBase * safetyFactor",
    "runoffM3s": "runoffLps / 1000"
  },
  "outputs": {
    "primary": "runoffLps",
    "breakdown": [
      "runoffLps",
      "runoffM3s"
    ]
  },
  "category": "İSG & Risk",
  "sector": "Makine & Ekipman",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "hse-ergonomics",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "safety"
}

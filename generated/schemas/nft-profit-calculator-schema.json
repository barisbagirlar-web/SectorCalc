      }
    },
    {
      "id": "salePrice",
      "label": "Estimated Sale Price",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "The expected price at which the NFT will be sold on the secondary market.",
      "label_i18n": {
        "en": "Estimated Sale Price",
        "tr": "Estimated Sale Price",
        "de": "Estimated Sale Price",
        "fr": "Estimated Sale Price",
        "es": "Estimated Sale Price",
        "ar": "Estimated Sale Price"
      }
    },
    {
      "id": "royaltyPercent",
      "label": "Royalty Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of the sale price paid to the original creator as a royalty.",
      "label_i18n": {
        "en": "Royalty Percentage",
        "tr": "Royalty Percentage",
        "de": "Royalty Percentage",
        "fr": "Royalty Percentage",
        "es": "Royalty Percentage",
        "ar": "Royalty Percentage"
      }
    }
  ],
  "formulas": {
    "totalCost": "purchasePrice + gasFee + listingFee + (salePrice * royaltyPercent / 100)",
    "netProfit": "salePrice - (purchasePrice + gasFee + listingFee + (salePrice * royaltyPercent / 100))",
    "roiPercent": "((salePrice - (purchasePrice + gasFee + listingFee + (salePrice * royaltyPercent / 100))) / (purchasePrice + gasFee + listingFee + (salePrice * royaltyPercent / 100))) * 100"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "totalCost",
      "roiPercent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

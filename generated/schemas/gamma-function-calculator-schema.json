  "formulas": {
    "gammaLanczos": "function gammaLanczos(x, tol, maxIter) { if (x < 0.5) { return Math.PI / (Math.sin(Math.PI * x) * gammaLanczos(1 - x, tol, maxIter)); } x -= 1; const p = [0.99999999999980993, 676.5203681218851, -1259.1392167224028, 771.32342877765313, -176.61502916214059, 12.507343278686905, -0.13857109526572012, 9.9843695780195716e-6, 1.5056327351493116e-7]; let g = 7; let z = x + 0.5; let sum = p[0]; for (let i = 1; i < p.length; i++) { sum += p[i] / (x + i); } const t = x + g + 0.5; return Math.sqrt(2 * Math.PI) * Math.pow(t, x + 0.5) * Math.exp(-t) * sum; }",
    "gammaStirling": "function gammaStirling(x) { return Math.sqrt(2 * Math.PI / x) * Math.pow(x / Math.E, x); }",
    "gamma": "function gamma(x, tol, maxIter, useStirling) { if (x <= 0 && Number.isInteger(x)) { return NaN; } if (useStirling && x > 10) { return gammaStirling(x); } return gammaLanczos(x, tol, maxIter); }",

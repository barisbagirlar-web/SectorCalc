      "label_i18n": {
        "en": "Child's Gender",
        "tr": "Child's Gender",
        "de": "Child's Gender",
        "fr": "Child's Gender",
        "es": "Child's Gender",
        "ar": "Child's Gender"
      }
    },
    {
      "id": "currentHeight",
      "label": "Current Height",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "businessContext": "Current measured height of the child in centimeters. Used to adjust prediction toward the mid-parental height.",
      "label_i18n": {
        "en": "Current Height",
        "tr": "Current Height",
        "de": "Current Height",
        "fr": "Current Height",
        "es": "Current Height",
        "ar": "Current Height"
      }
    }
  ],
  "formulas": {
    "midParentalHeight": "gender * (motherHeight + 13 + fatherHeight) / 2 + (1 - gender) * (fatherHeight - 13 + motherHeight) / 2",
    "predictedHeight": "(midParentalHeight + currentHeight) / 2"
  },
  "outputs": {
    "primary": "predictedHeight",
    "breakdown": [
      "midParentalHeight",
      "predictedHeight"

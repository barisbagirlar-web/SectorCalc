  "formulas": {
    "factorial": "inputs.n < 0 ? NaN : (function f(n) { return n<=1 ? 1 : n * f(n-1); })(Math.floor(inputs.n))",
    "steps": "inputs.n < 0 ? 'Invalid input for factorial' : (inputs.n < 2 ? '1! = 1' : (Math.floor(inputs.n) + '! = ' + Array.from({length: Math.floor(inputs.n)}, (_, i) => Math.floor(inputs.n) - i).join(' × ') + ' = ' + (function f(n) { return n<=1 ? 1 : n * f(n-1); })(Math.floor(inputs.n))))"
  },

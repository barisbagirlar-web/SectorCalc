{
  "toolName": "sample-size-calculator",
  "inputs": [
    {
      "id": "populationSize",
      "label": "Population Size",
      "type": "number",
      "unit": "units",
      "default": 10000,
      "businessContext": "The total number of individuals in the population.",
      "label_i18n": {
        "en": "Population Size",
        "tr": "Population Size",
        "de": "Population Size",
        "fr": "Population Size",
        "es": "Population Size",
        "ar": "Population Size"
      }
    },
    {
      "id": "proportion",
      "label": "Expected Proportion",
      "type": "number",
      "unit": "fraction",
      "default": 0.5,
      "businessContext": "The estimated proportion of the population possessing the attribute of interest. If unsure, use 0.5 for maximum variability.",
      "label_i18n": {
        "en": "Expected Proportion",
        "tr": "Expected Proportion",
        "de": "Expected Proportion",
        "fr": "Expected Proportion",
        "es": "Expected Proportion",
        "ar": "Expected Proportion"
      }
    },
    {
      "id": "marginOfError",
      "label": "Margin of Error",
      "type": "number",
      "unit": "fraction (e.g., 0.05 for ±5%)",
      "default": 0.05,
      "businessContext": "The maximum acceptable difference between the sample estimate and the true population value.",
      "label_i18n": {
        "en": "Margin of Error",
        "tr": "Margin of Error",
        "de": "Margin of Error",
        "fr": "Margin of Error",
        "es": "Margin of Error",
        "ar": "Margin of Error"
      }
    },
    {
      "id": "zScore",
      "label": "Z-score",
      "type": "number",
      "unit": "standard deviations",
      "default": 1.96,
      "businessContext": "The Z-value corresponding to the desired confidence level (e.g., 1.96 for 95% confidence).",
      "label_i18n": {
        "en": "Z-score",
        "tr": "Z-score",
        "de": "Z-score",
        "fr": "Z-score",
        "es": "Z-score",
        "ar": "Z-score"
      }
    }
  ],
  "formulas": {
    "sampleSizeInfinite": "(zScore**2 * proportion * (1 - proportion)) / (marginOfError**2)",
    "sampleSizeFinite": "sampleSizeInfinite / (1 + (sampleSizeInfinite - 1) / populationSize)"
  },
  "outputs": {
    "primary": "sampleSizeFinite",
    "breakdown": [
      "sampleSizeInfinite",
      "sampleSizeFinite"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "sampleSizeFinite"
  },

{
  "toolName": "calorie-burn-by-activity-calculator",
  "inputs": [
    {
      "id": "weight_kg",
      "label": "Body Weight (kg)",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms."
    },
    {
      "id": "duration_min",
      "label": "Activity Duration (minutes)",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Duration of the physical activity in minutes."
    },
    {
      "id": "met_value",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 5,
      "businessContext": "Metabolic Equivalent of Task for the activity (e.g., walking = 3.5, jogging = 7, running = 10)."
    },
    {
      "id": "efficiency_factor",
      "label": "Efficiency Factor",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Personal adjustment factor accounting for individual metabolic efficiency (0.5–1.5)."
    }
  ],
  "formulas": {
    "total_calories_burned": "weight_kg * met_value * (duration_min / 60) * efficiency_factor",
    "duration_hours": "duration_min / 60",
    "met_hours": "met_value * (duration_min / 60)",
    "calories_per_hour": "met_value * weight_kg * efficiency_factor"
  },
  "outputs": {
    "primary": "total_calories_burned",
    "breakdown": [
      "duration_hours",
      "met_hours",
      "calories_per_hour"
    ]
  },
  "category": "Enerji & Sürdürülebilirlik",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "sustainability-resource-esg"
}

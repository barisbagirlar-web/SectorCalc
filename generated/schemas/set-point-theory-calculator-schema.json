{
  "toolName": "set-point-theory-calculator",
  "inputs": [
    {
      "id": "targetValue",
      "label": "Target Value",
      "type": "number",
      "unit": "°C",
      "default": 100,
      "businessContext": "Desired process target value (e.g., temperature)",
      "label_i18n": {
        "en": "Target Value",
        "tr": "Target Value",

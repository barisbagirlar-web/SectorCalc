{
  "toolName": "set-point-theory-calculator",
  "inputs": [
    {
      "id": "targetValue",
      "label": "Target Value",
      "type": "number",
      "unit": "°C",
      "default": 100,
      "businessContext": "Desired process target value (e.g., temperature)"
    },
    {
      "id": "processValue",
      "label": "Current Process Value",
      "type": "number",
      "unit": "°C",
      "default": 90,
      "businessContext": "Measured actual process value"
    },
    {
      "id": "gain",
      "label": "Controller Gain",
      "type": "number",
      "unit": "",
      "default": 1.5,
      "businessContext": "Proportional gain factor for control"
    },
    {
      "id": "baseSetPoint",
      "label": "Base Set Point",
      "type": "number",
      "unit": "°C",
      "default": 0,
      "businessContext": "Initial or bias set point value"
    }
  ],
  "formulas": {
    "error": "targetValue - processValue",
    "correction": "gain * (targetValue - processValue)",
    "adjustedSetPoint": "baseSetPoint + gain * (targetValue - processValue)"
  },
  "outputs": {
    "primary": "adjustedSetPoint",
    "breakdown": [
      "error",
      "correction"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

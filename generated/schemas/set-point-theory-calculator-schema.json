        "en": "Measured actual process value",
        "tr": "Ölçülen gerçek proses değeri"
      }
    },
    {
      "id": "gain",
      "label": "Controller Gain",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Proportional gain factor for control",
      "label_i18n": {
        "en": "Controller Gain",
        "tr": "Kontrolör Kazancı",
        "de": "Controller Gain",
        "fr": "Controller Gain",

      },
      "businessContext_i18n": {
        "en": "Proportional gain factor for control",
        "tr": "Kontrol için oransal kazanç faktörü"
      }
    },
    {
      "id": "baseSetPoint",
      "label": "Base Set Point",
      "type": "number",
      "unit": "°C",
      "default": 0,
      "businessContext": "Initial or bias set point value",
      "label_i18n": {
        "en": "Base Set Point",
        "tr": "Temel Ayarlanan Değer",
        "de": "Base Set Point",
        "fr": "Base Set Point",
        "es": "Base Set Point",
        "ar": "Base Set Point"
      },
      "businessContext_i18n": {
        "en": "Initial or bias set point value",
        "tr": "Başlangıç veya referans ayar noktası değeri"
      }
    }
  ],
  "formulas": {
    "error": "targetValue - processValue",
    "correction": "gain * (targetValue - processValue)",
    "adjustedSetPoint": "baseSetPoint + gain * (targetValue - processValue)"
  },
  "outputs": {
    "primary": "adjustedSetPoint",
    "breakdown": [
      "error",
      "correction"
    ],

{
  "toolName": "set-point-theory-calculator",
  "inputs": [
    {
      "id": "targetOutput",
      "label": "Target Output",
      "type": "number",
      "unit": "",
      "default": 100,
      "businessContext": "The desired process output value (e.g., temperature, pressure)."
    },
    {
      "id": "measuredDisturbance",
      "label": "Measured Disturbance",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "The measured disturbance affecting the process (same unit as output)."
    },
    {
      "id": "processGain",
      "label": "Process Gain",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Process gain: change in output per unit change in input."
    },
    {
      "id": "processOffset",
      "label": "Process Offset",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Systematic bias or offset in the process characteristic."
    },
    {
      "id": "safetyMargin",
      "label": "Safety Margin (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage safety margin to reduce set point and avoid overshoot."
    },
    {
      "id": "setPointMin",
      "label": "Set Point Min",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Minimum allowed set point value."
    },
    {
      "id": "setPointMax",
      "label": "Set Point Max",
      "type": "number",
      "unit": "",
      "default": 200,
      "businessContext": "Maximum allowed set point value."
    }
  ],
  "formulas": {
    "effectiveTarget": "targetOutput - processOffset",
    "gainAdjusted": "effectiveTarget - measuredDisturbance",
    "rawSetPoint": "gainAdjusted / processGain",
    "setPointAfterMargin": "rawSetPoint * (1 - safetyMargin / 100)",
    "recommendedSetPoint": "Math.min(Math.max(setPointAfterMargin, setPointMin), setPointMax)",
    "marginAdjustment": "rawSetPoint - setPointAfterMargin"
  },
  "outputs": {
    "primary": "recommendedSetPoint",
    "breakdown": [
      "rawSetPoint",
      "effectiveTarget",
      "gainAdjusted",
      "marginAdjustment"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

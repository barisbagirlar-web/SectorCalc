        "ar": "Target Value"
      }
    },
    {
      "id": "processValue",
      "label": "Current Process Value",
      "type": "number",
      "unit": "°C",
      "default": 90,
      "businessContext": "Measured actual process value",
      "label_i18n": {
        "en": "Current Process Value",
        "tr": "Current Process Value",
        "de": "Current Process Value",
        "fr": "Current Process Value",
        "es": "Current Process Value",
        "ar": "Current Process Value"
      }
    },
    {
      "id": "gain",
      "label": "Controller Gain",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Proportional gain factor for control",
      "label_i18n": {
        "en": "Controller Gain",
        "tr": "Controller Gain",
        "de": "Controller Gain",
        "fr": "Controller Gain",
        "es": "Controller Gain",
        "ar": "Controller Gain"
      }
    },
    {
      "id": "baseSetPoint",
      "label": "Base Set Point",
      "type": "number",
      "unit": "°C",
      "default": 0,
      "businessContext": "Initial or bias set point value",
      "label_i18n": {
        "en": "Base Set Point",
        "tr": "Base Set Point",
        "de": "Base Set Point",
        "fr": "Base Set Point",
        "es": "Base Set Point",
        "ar": "Base Set Point"
      }
    }
  ],
  "formulas": {
    "error": "targetValue - processValue",
    "correction": "gain * (targetValue - processValue)",
    "adjustedSetPoint": "baseSetPoint + gain * (targetValue - processValue)"
  },
  "outputs": {
    "primary": "adjustedSetPoint",
    "breakdown": [
      "error",
      "correction"
    ]
  },

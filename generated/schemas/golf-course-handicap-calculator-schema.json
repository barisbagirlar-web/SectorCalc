{
  "toolName": "golf-course-handicap-calculator",
  "inputs": [
    {
      "id": "adjustedGrossScore",
      "label": "Adjusted Gross Score",
      "type": "number",
      "unit": "strokes",
      "default": 85,
      "businessContext": "Player's adjusted gross score for the round (actual strokes taken after any adjustments).",
      "label_i18n": {

        "es": "Adjusted Gross Score",
        "ar": "Adjusted Gross Score"
      }
    },
    {
      "id": "courseRating",
      "label": "Course Rating",
      "type": "number",
      "unit": "unit",
      "default": 72,
      "businessContext": "Course rating from scorecard, representing difficulty for a scratch golfer.",
      "label_i18n": {
        "en": "Course Rating",
        "tr": "Course Rating",
        "de": "Course Rating",
        "fr": "Course Rating",
        "es": "Course Rating",
        "ar": "Course Rating"
      }
    },
    {
      "id": "slopeRating",
      "label": "Slope Rating",
      "type": "number",
      "unit": "unit",
      "default": 130,
      "businessContext": "Slope rating from scorecard (typically 55-155), indicating relative difficulty for bogey golfers.",
      "label_i18n": {
        "en": "Slope Rating",
        "tr": "Slope Rating",
        "de": "Slope Rating",
        "fr": "Slope Rating",
        "es": "Slope Rating",
        "ar": "Slope Rating"
      }
    },
    {
      "id": "par",
      "label": "Par",
      "type": "number",
      "unit": "strokes",
      "default": 72,
      "businessContext": "Par for the course, used in course handicap calculation.",
      "label_i18n": {
        "en": "Par",
        "tr": "Par",
        "de": "Par",
        "fr": "Par",
        "es": "Par",
        "ar": "Par"
      }
    },
    {
      "id": "handicapIndex",
      "label": "Handicap Index",
      "type": "number",
      "unit": "unit",
      "default": 10,
      "businessContext": "Player's current Handicap Index (for course handicap calculation; set to 0 if unknown).",
      "label_i18n": {
        "en": "Handicap Index",
        "tr": "Handicap Index",
        "de": "Handicap Index",
        "fr": "Handicap Index",
        "es": "Handicap Index",
        "ar": "Handicap Index"
      }
    }
  ],
  "formulas": {
    "handicapDifferential": "(adjustedGrossScore - courseRating) * 113 / slopeRating",
    "courseHandicap": "handicapIndex * (slopeRating / 113) + (courseRating - par)"
  },
  "outputs": {
    "primary": "handicapDifferential",
    "breakdown": [
      "handicapDifferential",
      "courseHandicap"
    ],

        "de": "Scrap Units",
        "fr": "Scrap Units",
        "es": "Scrap Units",
        "ar": "Scrap Units"
      }
    }
  ],
  "formulas": {
    "overallYield": "(goodUnitsFirstPass + reworkedUnits) / totalUnits * 100",

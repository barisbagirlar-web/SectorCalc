        "ar": "Reworked Units"
      }
    },
    {
      "id": "scrapUnits",
      "label": "Scrap Units",
      "type": "number",
      "unit": "units",
      "default": 50,
      "businessContext": "Number of units that were scrapped or deemed irreparable.",

  "formulas": {
    "originalGravity": "1 + (grainWeight * 300 * (efficiency / 100)) / (boilVolume * 1000)",
    "finalGravity": "originalGravity - (originalGravity - 1) * (attenuation / 100)",
    "abv": "(originalGravity - finalGravity) * 131.25"
  },
  "outputs": {
    "primary": "abv",

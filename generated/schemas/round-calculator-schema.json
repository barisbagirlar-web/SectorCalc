  "formulas": {
    "weightPerBar": "3.141592653589793 * diameter**2 * length * density / 4000000",
    "volumePerBar": "3.141592653589793 * diameter**2 * length / 4000",
    "surfaceAreaPerBar": "(3.141592653589793 * diameter**2 / 2 + 3.141592653589793 * diameter * length) / 100",
    "totalWeight": "(3.141592653589793 * diameter**2 * length * density / 4000000) * quantity",
    "totalVolume": "(3.141592653589793 * diameter**2 * length / 4000) * quantity",
    "totalSurfaceArea": "((3.141592653589793 * diameter**2 / 2 + 3.141592653589793 * diameter * length) / 100) * quantity"
  },

    {
      "id": "faceWidthFactor",
      "label": "Diş Genişliği Faktörü (k)",
      "type": "number",
      "unit": "unit",
      "default": 0.3,
      "businessContext": "Diş genişliğinin konik mesafeye oranı (genelde 0,2 – 0,3 aralığında).",
      "label_i18n": {
        "en": "Diş Genişliği Faktörü (k)",
        "tr": "Diş Genişliği Faktörü (k)",
        "de": "Diş Genişliği Faktörü (k)",
        "fr": "Diş Genişliği Faktörü (k)",
        "es": "Diş Genişliği Faktörü (k)",
        "ar": "Diş Genişliği Faktörü (k)"
      }
    }
  ],
  "formulas": {
    "gearRatio": "z2 / z1",
    "d1": "module * z1",
    "d2": "module * z2",
    "shaftAngleRad": "shaftAngle * Math.PI / 180",
    "delta1Rad": "Math.atan( Math.sin(shaftAngleRad) / ((z2/z1) + Math.cos(shaftAngleRad)) )",
    "delta2Rad": "shaftAngleRad - delta1Rad",
    "delta1Deg": "delta1Rad * 180 / Math.PI",
    "delta2Deg": "delta2Rad * 180 / Math.PI",
    "R": "d2 / (2 * Math.sin(delta2Rad))",
    "b": "faceWidthFactor * R",
    "ha": "module",
    "hf": "1.25 * module",
    "h": "ha + hf"
  },
  "outputs": {
    "primary": "gearRatio",
    "breakdown": [
      "d1",
      "d2",
      "delta1Deg",
      "delta2Deg",
      "R",
      "b",
      "ha",
      "hf",
      "h"
    ]
  },

{
  "toolName": "shopify-profit-calculator",
  "inputs": [
    {
      "id": "averageOrderValue",
      "label": "Average Order Value",
      "type": "number",
      "unit": "€",
      "default": 50,
      "businessContext": "Average revenue per order",
      "label_i18n": {
        "en": "Average Order Value",
        "tr": "Average Order Value",
        "de": "Average Order Value",
        "fr": "Average Order Value",
        "es": "Average Order Value",
        "ar": "Average Order Value"
      }
    },
    {
      "id": "costOfGoodsPerOrder",
      "label": "Cost of Goods per Order",
      "type": "number",
      "unit": "€",
      "default": 20,
      "businessContext": "Direct cost of goods sold per order",
      "label_i18n": {
        "en": "Cost of Goods per Order",
        "tr": "Cost of Goods per Order",
        "de": "Cost of Goods per Order",
        "fr": "Cost of Goods per Order",
        "es": "Cost of Goods per Order",
        "ar": "Cost of Goods per Order"
      }
    },
    {
      "id": "monthlyOrders",
      "label": "Monthly Number of Orders",
      "type": "number",
      "unit": "orders",
      "default": 200,
      "businessContext": "Number of orders per month",
      "label_i18n": {
        "en": "Monthly Number of Orders",
        "tr": "Monthly Number of Orders",
        "de": "Monthly Number of Orders",
        "fr": "Monthly Number of Orders",
        "es": "Monthly Number of Orders",
        "ar": "Monthly Number of Orders"
      }
    },
    {
      "id": "shippingCostPerOrder",
      "label": "Shipping Cost per Order",
      "type": "number",
      "unit": "€",
      "default": 5,
      "businessContext": "Average shipping cost paid by seller per order",
      "label_i18n": {
        "en": "Shipping Cost per Order",
        "tr": "Shipping Cost per Order",
        "de": "Shipping Cost per Order",
        "fr": "Shipping Cost per Order",
        "es": "Shipping Cost per Order",
        "ar": "Shipping Cost per Order"
      }
    },
    {
      "id": "transactionFeeRate",
      "label": "Transaction Fee Rate",
      "type": "number",
      "unit": "%",
      "default": 2.9,
      "businessContext": "Shopify transaction fee + payment processing fee percentage",
      "label_i18n": {
        "en": "Transaction Fee Rate",
        "tr": "Transaction Fee Rate",
        "de": "Transaction Fee Rate",
        "fr": "Transaction Fee Rate",
        "es": "Transaction Fee Rate",
        "ar": "Transaction Fee Rate"
      }
    },
    {
      "id": "monthlyMarketing",
      "label": "Monthly Marketing Spend",
      "type": "number",
      "unit": "€",
      "default": 500,
      "businessContext": "Monthly cost for ads and promotions",
      "label_i18n": {
        "en": "Monthly Marketing Spend",
        "tr": "Monthly Marketing Spend",
        "de": "Monthly Marketing Spend",
        "fr": "Monthly Marketing Spend",
        "es": "Monthly Marketing Spend",
        "ar": "Monthly Marketing Spend"
      }
    },
    {
      "id": "monthlyFixedCosts",
      "label": "Monthly Fixed Costs",
      "type": "number",
      "unit": "€",
      "default": 300,
      "businessContext": "Other monthly overheads (apps, subscriptions, etc.)",
      "label_i18n": {
        "en": "Monthly Fixed Costs",
        "tr": "Monthly Fixed Costs",
        "de": "Monthly Fixed Costs",
        "fr": "Monthly Fixed Costs",
        "es": "Monthly Fixed Costs",
        "ar": "Monthly Fixed Costs"
      }
    }
  ],
  "formulas": {
    "totalRevenue": "averageOrderValue * monthlyOrders",
    "totalCOGS": "costOfGoodsPerOrder * monthlyOrders",
    "totalShipping": "shippingCostPerOrder * monthlyOrders",
    "totalTransactionFees": "totalRevenue * (transactionFeeRate / 100)",
    "grossProfit": "totalRevenue - totalCOGS",
    "operatingExpenses": "totalShipping + totalTransactionFees + monthlyMarketing + monthlyFixedCosts",
    "netProfit": "grossProfit - operatingExpenses",
    "profitMargin": "(netProfit / totalRevenue) * 100"
  },
  "outputs": {
    "primary": "totalRevenue",
    "breakdown": [
      {
        "id": "grossProfit",
        "label": "Gross Profit",
        "unit": "€"
      },
      {
        "id": "totalCosts",
        "label": "Total Costs",
        "unit": "€",
        "formula": "totalCOGS + totalShipping + totalTransactionFees + monthlyMarketing + monthlyFixedCosts"
      },
      {
        "id": "profitMargin",
        "label": "Profit Margin",
        "unit": "%"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitMargin"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",

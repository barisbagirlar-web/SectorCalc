    },
    {
      "id": "monthlyMarketing",
      "label": "Monthly Marketing Spend",
      "type": "number",
      "unit": "€",
      "default": 500,
      "businessContext": "Monthly cost for ads and promotions",
      "label_i18n": {
        "en": "Monthly Marketing Spend",
        "tr": "Aylık Pazarlama Harcaması",
        "de": "Monthly Marketing Spend",
        "fr": "Monthly Marketing Spend",
        "es": "Monthly Marketing Spend",
        "ar": "Monthly Marketing Spend"

  "formulas": {
    "total": "baseSalary + bonus + loyalty + safety",
    "bonus": "baseSalary * (bonusPercent / 100) * (performanceScore / 100) * teamMultiplier",
    "loyalty": "baseSalary * 0.01 * tenureYears",
    "safety": "baseSalary * (safetyRating / 100) * 0.05"
  },

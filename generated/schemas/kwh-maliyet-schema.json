  "formulas": {
    "EnergyCharge": "ActiveEnergy * EnergyRate",
    "DemandCharge": "PeakDemand * DemandRate",
    "ReactivePenalty": "IF(PowerFactor < Threshold, ReactiveEnergy * PenaltyRate, 0)",
    "TaxesAndFees": "(EnergyCharge + DemandCharge) * TaxRate",
    "TotalBill": "EnergyCharge + DemandCharge + ReactivePenalty + TaxesAndFees",
    "UnitCost_kWh": "TotalBill / ActiveEnergy",
    "PeakShavingSavings": "(OldPeak - NewPeak) * DemandRate"
  },
  "outputs": {
    "primary": "PeakShavingSavings",

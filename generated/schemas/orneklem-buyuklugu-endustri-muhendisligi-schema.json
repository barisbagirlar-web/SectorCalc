  "formulas": {
    "n_Infinite": "(Z^2 * p * (1-p)) / E^2",
    "n_Finite": "n_Infinite / (1 + ((n_Infinite - 1) / N))",
    "n_Continuous": "(Z * Sigma / E)^2",
    "Power_Adjusted": "n * (1 + (Z_beta / Z_alpha)^2)",
    "DesignEffect": "1 + (ClusterSize - 1) * ICC",
    "Final_n": "n_Finite * DesignEffect",
    "Cost_Sampling": "Final_n * CostPerUnit"
  },

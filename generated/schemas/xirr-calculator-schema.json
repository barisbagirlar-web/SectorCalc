    {
      "id": "finalDays",
      "label": "Final Days",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "Number of days from start to the final cash flow.",
      "label_i18n": {
        "en": "Final Days",
        "tr": "Final Days",
        "de": "Final Days",
        "fr": "Final Days",
        "es": "Final Days",
        "ar": "Final Days"
      }
    }
  ],
  "formulas": {
    "npv": "function(r){var c=[initialInvestment,cf1Amount,cf2Amount,finalValue],d=[initialDate,cf1Days,cf2Days,finalDays],d0=d[0],n=0;for(var i=0;i<c.length;i++){n+=c[i]/Math.pow(1+r,(d[i]-d0)/365);}return n;}",
    "xirr": "function(){var r=0.1;for(var i=0;i<100;i++){var f=npv(r);var df=0;var c=[initialInvestment,cf1Amount,cf2Amount,finalValue],d=[initialDate,cf1Days,cf2Days,finalDays],d0=d[0];for(var j=0;j<c.length;j++){var t=(d[j]-d0)/365;df-=t*c[j]/Math.pow(1+r,t+1);}if(Math.abs(f)<1e-6)break;r-=f/df;}return r;}",
    "npv_xirr_": "npv(xirr)"
  },
  "outputs": {
    "primary": "xirr",
    "breakdown": [
      "npv(xirr)"
    ]
  },

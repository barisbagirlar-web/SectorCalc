        "tr": "Geri kazanılan metalin ton başına piyasa fiyatı."
      }
    },
    {
      "id": "processing_cost",
      "label": "Processing Cost",
      "type": "number",
      "unit": "USD/ton",
      "default": 10,
      "businessContext": "Cost to process one ton of ore.",
      "label_i18n": {
        "en": "Processing Cost",
        "tr": "İşleme Maliyeti",
        "de": "Processing Cost",
        "fr": "Processing Cost",

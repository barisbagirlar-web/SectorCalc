  "formulas": {
    "Cost_Dye": "SUM(Conc * Price) / BathRatio",
    "Cost_Chem": "SUM(Dosage * Price)",
    "Cost_Water": "LiquorRatio * Weight * WaterTariff",
    "Cost_Energy": "Heating + Holding + Drying",
    "Cost_Waste": "Effluent * TreatCost + Surcharge",
    "TotalBatch": "Dye + Chem + Water + Energy + Waste",
    "RFT_Savings": "Rework * (1 - RFT)",
    "CostPerKg": "(TotalBatch + RFT_Savings) / Weight"
  },

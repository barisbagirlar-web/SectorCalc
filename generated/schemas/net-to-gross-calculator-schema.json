{
  "toolName": "net-to-gross-calculator",
  "inputs": [
    {
      "id": "netAmount",
      "label": "Net Amount",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "The net amount after deductions",
      "label_i18n": {
        "en": "Net Amount",
        "tr": "Net Amount",
        "de": "Net Amount",
        "fr": "Net Amount",
        "es": "Net Amount",
        "ar": "Net Amount"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Tax rate applied to gross amount",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "socialInsuranceRate",
      "label": "Social Insurance Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Social insurance contribution rate on gross",
      "label_i18n": {
        "en": "Social Insurance Rate",
        "tr": "Social Insurance Rate",
        "de": "Social Insurance Rate",
        "fr": "Social Insurance Rate",
        "es": "Social Insurance Rate",
        "ar": "Social Insurance Rate"
      }
    },
    {
      "id": "additionalDeductionRate",
      "label": "Additional Deduction Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Other deduction rate (e.g., union fees) from gross",
      "label_i18n": {
        "en": "Additional Deduction Rate",
        "tr": "Additional Deduction Rate",
        "de": "Additional Deduction Rate",
        "fr": "Additional Deduction Rate",
        "es": "Additional Deduction Rate",
        "ar": "Additional Deduction Rate"
      }
    },
    {
      "id": "otherDeductionsFixed",
      "label": "Other Fixed Deductions",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Fixed amount deductions before rate deduction",
      "label_i18n": {
        "en": "Other Fixed Deductions",
        "tr": "Other Fixed Deductions",
        "de": "Other Fixed Deductions",
        "fr": "Other Fixed Deductions",
        "es": "Other Fixed Deductions",
        "ar": "Other Fixed Deductions"
      }
    }
  ],
  "formulas": {
    "totalRate": "(taxRate + socialInsuranceRate + additionalDeductionRate) / 100",
    "grossAmount": "(netAmount + otherDeductionsFixed) / (1 - totalRate)",
    "taxAmount": "grossAmount * (taxRate / 100)",
    "socialInsuranceAmount": "grossAmount * (socialInsuranceRate / 100)",
    "additionalDeductionAmount": "grossAmount * (additionalDeductionRate / 100)",
    "totalDeductions": "taxAmount + socialInsuranceAmount + additionalDeductionAmount + otherDeductionsFixed"
  },
  "outputs": {
    "primary": "grossAmount",
    "breakdown": [
      "taxAmount",
      "socialInsuranceAmount",
      "additionalDeductionAmount",
      "otherDeductionsFixed",
      "totalDeductions"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalDeductions"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",

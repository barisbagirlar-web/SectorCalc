{
  "toolName": "pendulum-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length (m)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Effective length of the pendulum from pivot to center of mass."
    },
    {
      "id": "gravity",
      "label": "Gravity (m/s²)",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Acceleration due to gravity (standard Earth gravity is 9.81 m/s²)."
    },
    {
      "id": "initialAngle",
      "label": "Initial Angle (deg)",
      "type": "number",
      "unit": "deg",
      "default": 5,
      "businessContext": "Initial release angle from vertical in degrees. Keep small for accurate simple harmonic approximation."
    },
    {
      "id": "numberOfOscillations",
      "label": "Number of Oscillations",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Number of full oscillations for total time calculation."
    }
  ],
  "formulas": {
    "period": "2 * Math.PI * Math.sqrt(length / gravity)",
    "frequency": "1 / (2 * Math.PI * Math.sqrt(length / gravity))",
    "angularFrequency": "Math.sqrt(gravity / length)",
    "maxSpeed": "Math.sqrt(2 * gravity * length * (1 - Math.cos(initialAngle * Math.PI / 180)))",
    "totalTime": "(2 * Math.PI * Math.sqrt(length / gravity)) * numberOfOscillations",
    "maxHeight": "length * (1 - Math.cos(initialAngle * Math.PI / 180))"
  },
  "outputs": {
    "primary": "period",
    "breakdown": [
      "period",
      "frequency",
      "angularFrequency",
      "maxSpeed",
      "totalTime",
      "maxHeight"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

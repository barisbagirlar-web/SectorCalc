{
  "toolName": "rental-property-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Purchase Price",
      "type": "number",
      "unit": "EUR",
      "default": 200000,
      "businessContext": "Total purchase price of the property",
      "label_i18n": {
        "en": "Purchase Price",
        "tr": "Satın Alma Fiyatı",
        "de": "Kaufpreis",

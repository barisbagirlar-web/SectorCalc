        "es": "Purchase Price",
        "ar": "Purchase Price"
      },
      "businessContext_i18n": {
        "en": "Total purchase price of the property",
        "tr": "Mülkün toplam satın alma fiyatı",
        "de": "Gesamtkaufpreis der Immobilie"
      }
    },
    {
      "id": "downPaymentPercent",
      "label": "Down Payment (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage of purchase price paid upfront",
      "label_i18n": {
        "en": "Down Payment (%)",
        "tr": "Peşinat (%)",
        "de": "Anzahlung (%)",
        "fr": "Down Payment (%)",
        "es": "Down Payment (%)",
        "ar": "Down Payment (%)"
      },
      "businessContext_i18n": {
        "en": "Percentage of purchase price paid upfront",
        "tr": "Peşin ödenen satın alma fiyatı yüzdesi"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "% p.a.",
      "default": 4,
      "businessContext": "Annual nominal interest rate for mortgage loan",
      "label_i18n": {
        "en": "Interest Rate",
        "tr": "Faiz Oranı",
        "de": "Zinssatz",
        "fr": "Interest Rate",
        "es": "Interest Rate",
        "ar": "Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual nominal interest rate for mortgage loan",
        "tr": "Mortgage kredisi için yıllık nominal faiz oranı"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 25,
      "businessContext": "Duration of mortgage loan in years",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Kredi Vadesi",
        "de": "Darlehenslaufzeit",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      },
      "businessContext_i18n": {
        "en": "Duration of mortgage loan in years",
        "tr": "Mortgage kredisinin yıl cinsinden süresi"
      }
    },
    {
      "id": "monthlyRent",
      "label": "Monthly Rent",
      "type": "number",
      "unit": "EUR",
      "default": 1500,
      "businessContext": "Expected gross monthly rental income",
      "label_i18n": {
        "en": "Monthly Rent",
        "tr": "Aylık Kira",
        "de": "Monatsmiete",
        "fr": "Monthly Rent",
        "es": "Monthly Rent",
        "ar": "Monthly Rent"
      },
      "businessContext_i18n": {
        "en": "Expected gross monthly rental income",
        "tr": "Beklenen brüt aylık kira geliri",
        "de": "Erwartete monatliche Bruttomieteinnahmen"
      }
    },
    {
      "id": "annualExpensePercent",
      "label": "Annual Operating Expenses (% of Rent)",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Annual operating expenses as percentage of annual gross rent, including maintenance, insurance, taxes",
      "label_i18n": {
        "en": "Annual Operating Expenses (% of Rent)",
        "tr": "Yıllık İşletme Giderleri (Kiranın %'si)",
        "de": "Annual Operating Expenses (% of Rent)",
        "fr": "Annual Operating Expenses (% of Rent)",
        "es": "Annual Operating Expenses (% of Rent)",
        "ar": "Annual Operating Expenses (% of Rent)"
      },
      "businessContext_i18n": {
        "en": "Annual operating expenses as percentage of annual gross rent, including maintenance, insurance, taxes",
        "tr": "Bakım, sigorta, vergiler dahil yıllık brüt kiranın yüzdesi olarak yıllık işletme giderleri"
      }
    },
    {
      "id": "vacancyRate",
      "label": "Vacancy Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Estimated percentage of time the property is vacant, reducing rental income",
      "label_i18n": {
        "en": "Vacancy Rate (%)",
        "tr": "Boşluk Oranı (%)",
        "de": "Vacancy Rate (%)",
        "fr": "Vacancy Rate (%)",
        "es": "Vacancy Rate (%)",
        "ar": "Vacancy Rate (%)"
      },
      "businessContext_i18n": {
        "en": "Estimated percentage of time the property is vacant, reducing rental income",
        "tr": "Mülkün boş olduğu tahmini süre yüzdesi, kira gelirini azaltır"
      }
    }
  ],
  "formulas": {
    "monthlyGrossRent": "monthlyRent",
    "annualGrossRent": "monthlyRent * 12",
    "effectiveAnnualRent": "annualGrossRent * (1 - vacancyRate/100)",
    "annualExpenses": "effectiveAnnualRent * annualExpensePercent/100",
    "netOperatingIncome": "effectiveAnnualRent - annualExpenses",
    "loanAmount": "purchasePrice * (1 - downPaymentPercent/100)",
    "monthlyInterestRate": "interestRate/100/12",
    "loanTermMonths": "loanTermYears * 12",
    "totalCashInvested": "purchasePrice * downPaymentPercent/100",
    "capRate": "(netOperatingIncome / purchasePrice) * 100"
  },
  "outputs": {
    "primary": "capRate",
    "breakdown": [
      "annualCashFlow",
      "monthlyCashFlow",
      "capRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "capRate",
    "unit": "EUR"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

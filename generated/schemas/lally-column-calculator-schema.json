{
  "toolName": "lally-column-calculator",
  "inputs": [
    {
      "id": "column_height",
      "label": "Column Height",
      "type": "number",
      "unit": "m",
      "default": 2.5,
      "businessContext": "Effective height of the lally column from base to top anchorage (unbraced length).",
      "label_i18n": {
        "en": "Column Height",
        "tr": "Column Height",
        "de": "Column Height",
        "fr": "Column Height",
        "es": "Column Height",
        "ar": "Column Height"
      }
    },
    {
      "id": "outer_diameter",
      "label": "Outer Diameter",
      "type": "number",
      "unit": "mm",
      "default": 89,
      "businessContext": "Outer diameter of the steel pipe column.",
      "label_i18n": {
        "en": "Outer Diameter",
        "tr": "Outer Diameter",
        "de": "Outer Diameter",
        "fr": "Outer Diameter",
        "es": "Outer Diameter",
        "ar": "Outer Diameter"
      }
    },
    {
      "id": "wall_thickness",
      "label": "Wall Thickness",
      "type": "number",
      "unit": "mm",
      "default": 3,
      "businessContext": "Thickness of the steel pipe wall.",
      "label_i18n": {
        "en": "Wall Thickness",
        "tr": "Wall Thickness",
        "de": "Wall Thickness",
        "fr": "Wall Thickness",
        "es": "Wall Thickness",
        "ar": "Wall Thickness"
      }
    },
    {
      "id": "steel_yield_strength",
      "label": "Steel Yield Strength",
      "type": "number",
      "unit": "MPa",
      "default": 250,
      "businessContext": "Minimum guaranteed yield stress of the steel material.",
      "label_i18n": {
        "en": "Steel Yield Strength",
        "tr": "Steel Yield Strength",
        "de": "Steel Yield Strength",
        "fr": "Steel Yield Strength",
        "es": "Steel Yield Strength",
        "ar": "Steel Yield Strength"
      }
    },
    {
      "id": "effective_length_factor",
      "label": "Effective Length Factor K",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Buckling length coefficient depending on end conditions (1.0 for pinned-pinned, 0.5 for fixed-fixed, 2.0 for fixed-free).",
      "label_i18n": {
        "en": "Effective Length Factor K",
        "tr": "Effective Length Factor K",
        "de": "Effective Length Factor K",
        "fr": "Effective Length Factor K",
        "es": "Effective Length Factor K",
        "ar": "Effective Length Factor K"
      }
    },
    {
      "id": "safety_factor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Design safety factor to ensure TÜV-compliant structural reliability.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    },
    {
      "id": "youngs_modulus",
      "label": "Young's Modulus",
      "type": "number",
      "unit": "MPa",
      "default": 200000,
      "businessContext": "Modulus of elasticity of the steel (typically 200,000 MPa for structural steel).",
      "label_i18n": {
        "en": "Young's Modulus",
        "tr": "Young's Modulus",
        "de": "Young's Modulus",
        "fr": "Young's Modulus",
        "es": "Young's Modulus",
        "ar": "Young's Modulus"
      }
    }
  ],
  "formulas": {
    "allowable_yield_load": "(Math.PI/4 * (outer_diameter**2 - (outer_diameter - 2*wall_thickness)**2) * steel_yield_strength) / safety_factor / 1000",
    "allowable_euler_load": "(Math.PI**2 * youngs_modulus * (Math.PI/64 * (outer_diameter**4 - (outer_diameter - 2*wall_thickness)**4)) / ((effective_length_factor * column_height * 1000)**2)) / safety_factor / 1000"
  },
  "outputs": {
    "primary": "allowable_euler_load",
    "breakdown": [
      "allowable_yield_load",
      "allowable_euler_load",
      "slenderness_ratio"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "slenderness_ratio"
  },

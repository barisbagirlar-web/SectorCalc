  "formulas": {
    "OverrunRequests": "MAX(0, TotalRequests - IncludedRequests)",
    "OverrunCost": "OverrunRequests * OverageRate",
    "ThrottlingCost": "ThrottledRequests * RetryCost * AvgRetries",
    "DataEgressCost": "DataOutGB * EgressRate",
    "SLABreachPenalty": "IF(Availability < SLA, MonthlyFee * CreditPct, 0)",
    "TotalOverrunCost": "OverrunCost + ThrottlingCost + DataEgressCost + SLABreachPenalty"
  },

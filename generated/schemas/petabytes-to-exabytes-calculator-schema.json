{
  "toolName": "petabytes-to-exabytes-calculator",
  "inputs": [
    {
      "id": "rawPetabytes",
      "label": "Raw Data Volume (PB)",
      "type": "number",
      "unit": "PB",
      "default": 100,
      "businessContext": "The raw data volume in petabytes.",
      "label_i18n": {
        "en": "Raw Data Volume (PB)",
        "tr": "Raw Data Volume (PB)",
        "de": "Raw Data Volume (PB)",
        "fr": "Raw Data Volume (PB)",
        "es": "Raw Data Volume (PB)",
        "ar": "Raw Data Volume (PB)"
      }
    },
    {
      "id": "replicationFactor",
      "label": "Replication Factor",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Number of replicas (e.g., HDFS replication factor).",
      "label_i18n": {
        "en": "Replication Factor",
        "tr": "Replication Factor",
        "de": "Replication Factor",
        "fr": "Replication Factor",
        "es": "Replication Factor",
        "ar": "Replication Factor"
      }
    },
    {
      "id": "redundancyOverhead",
      "label": "Redundancy Overhead (%)",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage overhead for RAID, erasure coding, or other redundancy.",
      "label_i18n": {
        "en": "Redundancy Overhead (%)",
        "tr": "Redundancy Overhead (%)",
        "de": "Redundancy Overhead (%)",
        "fr": "Redundancy Overhead (%)",
        "es": "Redundancy Overhead (%)",
        "ar": "Redundancy Overhead (%)"
      }
    },
    {
      "id": "provisioningBuffer",
      "label": "Provisioning Buffer (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Extra capacity for future growth or temporary spikes.",
      "label_i18n": {
        "en": "Provisioning Buffer (%)",
        "tr": "Provisioning Buffer (%)",
        "de": "Provisioning Buffer (%)",
        "fr": "Provisioning Buffer (%)",
        "es": "Provisioning Buffer (%)",
        "ar": "Provisioning Buffer (%)"
      }
    },
    {
      "id": "compressionRatio",
      "label": "Compression Ratio",
      "type": "number",
      "unit": ":1",
      "default": 2,
      "businessContext": "Lossless compression ratio (e.g., 2 means 2:1 compression).",
      "label_i18n": {
        "en": "Compression Ratio",
        "tr": "Compression Ratio",
        "de": "Compression Ratio",
        "fr": "Compression Ratio",
        "es": "Compression Ratio",
        "ar": "Compression Ratio"
      }
    },
    {
      "id": "decimalPrecision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Number of decimal places for the output.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    }
  ],
  "formulas": {
    "effectiveEB": "Number((rawPetabytes * replicationFactor * (1 + redundancyOverhead / 100) * (1 + provisioningBuffer / 100) / compressionRatio / 1000).toFixed(decimalPrecision))",
    "rawPB": "rawPetabytes * replicationFactor * (1 + redundancyOverhead / 100) * (1 + provisioningBuffer / 100)",
    "compressedPB": "rawPetabytes * replicationFactor * (1 + redundancyOverhead / 100) * (1 + provisioningBuffer / 100) / compressionRatio",
    "finalEB": "Number((rawPetabytes * replicationFactor * (1 + redundancyOverhead / 100) * (1 + provisioningBuffer / 100) / compressionRatio / 1000).toFixed(decimalPrecision))"
  },
  "outputs": {
    "primary": "effectiveEB",
    "breakdown": [
      "rawPB",
      "compressedPB",
      "finalEB"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "bilisim",
  "profession": "Sistem Mühendisi",
  "categoryId": "conversion"
}

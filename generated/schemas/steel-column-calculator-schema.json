{
  "toolName": "steel-column-calculator",
  "inputs": [
    {
      "id": "effectiveLengthFactor",
      "label": "Effective Length Factor (K)",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "End condition factor: 1.0 for pinned-pinned, 0.5 for fixed-fixed, 0.7 for fixed-pinned, 2.0 for fixed-free."
    },
    {
      "id": "unbracedLength",
      "label": "Unbraced Length (L)",
      "type": "number",
      "unit": "mm",
      "default": 3000,
      "businessContext": "Actual length between lateral supports."
    },
    {
      "id": "width",
      "label": "Cross-Section Width (b)",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Width of rectangular solid section."
    },
    {
      "id": "thickness",
      "label": "Cross-Section Thickness (t)",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Thickness of rectangular solid section."
    },
    {
      "id": "elasticModulus",
      "label": "Modulus of Elasticity (E)",
      "type": "number",
      "unit": "GPa",
      "default": 200,
      "businessContext": "Steel typically 200 GPa."
    },
    {
      "id": "yieldStrength",
      "label": "Yield Strength (Fy)",
      "type": "number",
      "unit": "MPa",
      "default": 250,
      "businessContext": "Typical S235 steel yield strength."
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.67,
      "businessContext": "AISC ASD typical factor of safety for compression."
    }
  ],
  "formulas": {
    "A": "width * thickness",
    "I": "(width * Math.pow(thickness,3)) / 12",
    "P_euler": "(Math.PI * Math.PI * elasticModulus * 1000 * I) / Math.pow(effectiveLengthFactor * unbracedLength, 2)",
    "P_yield": "yieldStrength * A",
    "criticalLoad": "Math.min(P_euler, P_yield)",
    "allowableLoad": "criticalLoad / safetyFactor",
    "eulerStress": "P_euler / A",
    "yieldStress": "yieldStrength"
  },
  "outputs": {
    "primary": "allowableLoad",
    "breakdown": [
      "criticalLoad",
      "P_euler",
      "P_yield",
      "eulerStress",
      "yieldStress",
      "A",
      "I"
    ]
  },
  "category": "İSG & Risk",
  "sector": "Metal & Sac İşleme",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "project-construction-management",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",
  "categoryId": "safety"
}

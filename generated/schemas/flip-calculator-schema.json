  "formulas": {
    "totalInvestment": "purchasePrice + renovationCost + holdingCosts",
    "grossProfit": "sellingPrice - totalInvestment - sellingCosts - financingCosts",
    "netProfit": "grossProfit",
    "roi": "totalInvestment !== 0 ? (netProfit / totalInvestment) * 100 : 0"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "totalInvestment",

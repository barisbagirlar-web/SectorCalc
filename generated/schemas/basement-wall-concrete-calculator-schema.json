{
  "toolName": "basement-wall-concrete-calculator",
  "inputs": [
    {
      "id": "wallHeight",
      "label": "Wall Height",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "The height of the basement wall from footing to top."
    },
    {
      "id": "wallLength",
      "label": "Wall Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "The length of the basement wall."
    },
    {
      "id": "wallThickness",
      "label": "Wall Thickness",
      "type": "number",
      "unit": "mm",
      "default": 300,
      "businessContext": "Thickness of the concrete wall."
    },
    {
      "id": "concreteDensity",
      "label": "Concrete Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 2400,
      "businessContext": "Density of concrete used for weight calculation."
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage added for material waste during construction."
    },
    {
      "id": "numWalls",
      "label": "Number of Walls",
      "type": "number",
      "unit": "pieces",
      "default": 1,
      "businessContext": "Number of identical basement walls."
    }
  ],
  "formulas": {
    "volumePerWall": "wallHeight * wallLength * (wallThickness / 1000)",
    "totalVolume": "volumePerWall * numWalls",
    "totalVolumeWithWaste": "totalVolume * (1 + wasteFactor / 100)",
    "weightPerWall": "volumePerWall * concreteDensity",
    "totalWeight": "totalVolume * concreteDensity",
    "totalWeightWithWaste": "totalVolumeWithWaste * concreteDensity"
  },
  "outputs": {
    "primary": "totalVolumeWithWaste",
    "breakdown": [
      "volumePerWall",
      "totalWeightWithWaste"
    ]
  },
  "category": "İnşaat & Yapı",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "sustainability"
}

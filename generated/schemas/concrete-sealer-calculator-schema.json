{
  "toolName": "concrete-sealer-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Surface Area",
      "type": "number",
      "unit": "sq ft",
      "default": 1000,
      "businessContext": "Total surface area of concrete to be sealed",
      "label_i18n": {
        "en": "Surface Area",
        "tr": "Surface Area",
        "de": "Surface Area",
        "fr": "Surface Area",
        "es": "Surface Area",
        "ar": "Surface Area"
      }
    },
    {
      "id": "coverageRate",
      "label": "Coverage Rate",
      "type": "number",
      "unit": "sq ft/gal",
      "default": 200,
      "businessContext": "Manufacturer's stated coverage rate per coat",
      "label_i18n": {
        "en": "Coverage Rate",
        "tr": "Coverage Rate",
        "de": "Coverage Rate",
        "fr": "Coverage Rate",
        "es": "Coverage Rate",
        "ar": "Coverage Rate"
      }
    },
    {
      "id": "numCoats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "coats",
      "default": 2,
      "businessContext": "Number of coats to apply",
      "label_i18n": {
        "en": "Number of Coats",
        "tr": "Number of Coats",
        "de": "Number of Coats",
        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Extra material to account for spillage, overspray, and uneven application",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "porosityFactor",
      "label": "Porosity Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for coverage based on concrete surface roughness (1.0 for smooth, 1.2 for medium, 1.5 for rough)",
      "label_i18n": {
        "en": "Porosity Factor",
        "tr": "Porosity Factor",
        "de": "Porosity Factor",
        "fr": "Porosity Factor",
        "es": "Porosity Factor",
        "ar": "Porosity Factor"
      }
    },
    {
      "id": "pricePerUnit",
      "label": "Price per Gallon",
      "type": "number",
      "unit": "$/gal",
      "default": 30,
      "businessContext": "Cost of one gallon of sealer",
      "label_i18n": {
        "en": "Price per Gallon",
        "tr": "Price per Gallon",
        "de": "Price per Gallon",
        "fr": "Price per Gallon",
        "es": "Price per Gallon",
        "ar": "Price per Gallon"
      }
    }
  ],
  "formulas": {
    "adjustedCoverage": "coverageRate / porosityFactor",
    "totalSealer": "(area * numCoats * (1 + wasteFactor / 100) * porosityFactor) / coverageRate",
    "totalCost": "totalSealer * pricePerUnit"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalSealer",
      "adjustedCoverage"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "category": "İnşaat & Yapı",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "cost",

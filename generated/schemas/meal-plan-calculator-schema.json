        "de": "Durchschnittliche Zeit zur Zubereitung einer Mahlzeit",
        "fr": "Temps moyen pour préparer un repas",
        "es": "Tiempo promedio para preparar una comida"
      }
    },
    {
      "id": "overheadPercent",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Overhead costs as percentage of direct costs",
      "label_i18n": {
        "en": "Overhead Percentage",
        "tr": "Genel Gider Yüzdesi",
        "de": "Gemeinkostenprozentsatz",
        "fr": "Pourcentage de frais généraux",
        "es": "Porcentaje de gastos generales",
        "ar": "Overhead Percentage"
      },
      "businessContext_i18n": {
        "en": "Overhead costs as percentage of direct costs",
        "tr": "Doğrudan maliyetlerin yüzdesi olarak genel giderler",
        "de": "Gemeinkosten als Prozentsatz der direkten Kosten",
        "fr": "Frais généraux en pourcentage des coûts directs",
        "es": "Costos indirectos como porcentaje de los costos directos"
      }
    },
    {
      "id": "wastePercent",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected food waste percentage",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Fire Yüzdesi",
        "de": "Abfallprozentsatz",
        "fr": "Pourcentage de déchets",
        "es": "Porcentaje de desperdicio",
        "ar": "Waste Percentage"
      },
      "businessContext_i18n": {
        "en": "Expected food waste percentage",
        "tr": "Beklenen gıda israfı yüzdesi",
        "de": "Erwarteter Lebensmittelabfall in Prozent",
        "fr": "Pourcentage attendu de gaspillage alimentaire",
        "es": "Porcentaje esperado de desperdicio de alimentos"
      }
    }
  ],
  "formulas": {
    "laborCostPerMeal": "laborCostPerHour * (prepTimePerMeal / 60)",
    "totalIngredientCostNoWaste": "ingredientCostPerMeal * mealsPerDay",
    "wasteCost": "totalIngredientCostNoWaste * (wastePercent / 100)",
    "totalIngredientCostWithWaste": "totalIngredientCostNoWaste + wasteCost",
    "totalLaborCost": "laborCostPerMeal * mealsPerDay",
    "directCost": "totalIngredientCostWithWaste + totalLaborCost",
    "overheadCost": "directCost * (overheadPercent / 100)",
    "totalCost": "directCost + overheadCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalIngredientCostNoWaste",
      "totalLaborCost",
      "wasteCost",
      "overheadCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "meals"
  },

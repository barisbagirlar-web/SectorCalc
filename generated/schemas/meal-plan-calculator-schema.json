      "businessContext": "Average time to prepare one meal",
      "label_i18n": {
        "en": "Preparation Time per Meal",
        "tr": "Öğün Başına Hazırlık Süresi",
        "de": "Zubereitungszeit pro Mahlzeit",
        "fr": "Temps de préparation par repas",

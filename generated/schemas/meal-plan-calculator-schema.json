{
  "toolName": "meal-plan-calculator",
  "inputs": [
    {
      "id": "mealsPerDay",
      "label": "Meals per Day",
      "type": "number",
      "unit": "meals",
      "default": 100,
      "businessContext": "Number of meals served daily"
    },
    {
      "id": "ingredientCostPerMeal",
      "label": "Ingredient Cost per Meal",
      "type": "number",
      "unit": "USD",
      "default": 3.5,
      "businessContext": "Average ingredient cost per meal"
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour",
      "type": "number",
      "unit": "USD",
      "default": 20,
      "businessContext": "Hourly rate for kitchen staff"
    },
    {
      "id": "prepTimePerMeal",
      "label": "Preparation Time per Meal",
      "type": "number",
      "unit": "minutes",
      "default": 10,
      "businessContext": "Average time to prepare one meal"
    },
    {
      "id": "overheadPercent",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Overhead costs as percentage of direct costs"
    },
    {
      "id": "wastePercent",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected food waste percentage"
    }
  ],
  "formulas": {
    "laborCostPerMeal": "laborCostPerHour * (prepTimePerMeal / 60)",
    "totalIngredientCostNoWaste": "ingredientCostPerMeal * mealsPerDay",
    "wasteCost": "totalIngredientCostNoWaste * (wastePercent / 100)",
    "totalIngredientCostWithWaste": "totalIngredientCostNoWaste + wasteCost",
    "totalLaborCost": "laborCostPerMeal * mealsPerDay",
    "directCost": "totalIngredientCostWithWaste + totalLaborCost",
    "overheadCost": "directCost * (overheadPercent / 100)",
    "totalCost": "directCost + overheadCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalIngredientCostNoWaste",
      "totalLaborCost",
      "wasteCost",
      "overheadCost"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "cost"
}

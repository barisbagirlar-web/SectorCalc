{
  "toolName": "bolt-stretch-calculator",
  "inputs": [
    {
      "id": "preload",
      "label": "Preload Force",
      "type": "number",
      "unit": "N",
      "default": 50000,
      "businessContext": "The tensile force applied to the bolt during tightening, typically achieved by torque or tension.",
      "label_i18n": {
        "en": "Preload Force",
        "tr": "Preload Force",
        "de": "Preload Force",
        "fr": "Preload Force",
        "es": "Preload Force",
        "ar": "Preload Force"
      }
    },
    {
      "id": "gripLength",
      "label": "Grip Length",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "The length of the bolt between the nut and the bolt head, or the clamped length.",
      "label_i18n": {
        "en": "Grip Length",
        "tr": "Grip Length",
        "de": "Grip Length",
        "fr": "Grip Length",
        "es": "Grip Length",
        "ar": "Grip Length"
      }
    },
    {
      "id": "area",
      "label": "Tensile Stress Area",
      "type": "number",
      "unit": "mm²",
      "default": 58,
      "businessContext": "The effective cross-sectional area of the bolt thread under tension.",
      "label_i18n": {
        "en": "Tensile Stress Area",
        "tr": "Tensile Stress Area",
        "de": "Tensile Stress Area",
        "fr": "Tensile Stress Area",
        "es": "Tensile Stress Area",
        "ar": "Tensile Stress Area"
      }
    },
    {
      "id": "modulus",
      "label": "Modulus of Elasticity",
      "type": "number",
      "unit": "N/mm²",
      "default": 200000,
      "businessContext": "Young's modulus of the bolt material, e.g., 200,000 N/mm² for steel.",
      "label_i18n": {
        "en": "Modulus of Elasticity",
        "tr": "Modulus of Elasticity",
        "de": "Modulus of Elasticity",
        "fr": "Modulus of Elasticity",
        "es": "Modulus of Elasticity",
        "ar": "Modulus of Elasticity"
      }
    }
  ],
  "formulas": {
    "stretch": "preload * gripLength / (area * modulus)",
    "stress": "preload / area",
    "strain": "stress / modulus"
  },
  "outputs": {
    "primary": "stretch",
    "breakdown": [
      "stress",
      "strain"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "strain"
  },

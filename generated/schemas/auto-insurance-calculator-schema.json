    {
      "id": "annualMileage",
      "label": "Annual Mileage",
      "type": "number",
      "unit": "km/year",
      "default": 12000,
      "businessContext": "Estimated distance driven per year in kilometers.",
      "label_i18n": {
        "en": "Annual Mileage",
        "tr": "Yıllık Kilometre",
        "de": "Jährliche Fahrleistung",
        "fr": "Annual Mileage",
        "es": "Annual Mileage",
        "ar": "Annual Mileage"
      },
      "businessContext_i18n": {
        "en": "Estimated distance driven per year in kilometers.",
        "tr": "Yıllık tahmini sürüş mesafesi (kilometre).",
        "de": "Geschätzte jährliche Fahrleistung in Kilometern."
      }
    }
  ],
  "formulas": {
    "basePremium": "vehicleValue * 0.02",
    "ageFactor": "driverAge < 25 ? 1.5 : (driverAge >= 65 ? 1.3 : 1.0)",
    "experienceFactor": "drivingExperience < 3 ? 1.4 : 1.0",
    "coverageFactor": "coverageLevel",
    "vehicleAgeFactor": "vehicleAge < 3 ? 1.1 : (vehicleAge > 10 ? 0.9 : 1.0)",
    "mileageFactor": "annualMileage > 15000 ? 1.2 : (annualMileage < 5000 ? 0.8 : 1.0)"
  },
  "outputs": {
    "primary": "mileageFactor",
    "breakdown": [
      "basePremium",
      "ageFactor",
      "experienceFactor",
      "coverageFactor",
      "deductibleFactor",
      "vehicleAgeFactor",
      "mileageFactor"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualPremium",
    "unit": "$"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Birim & Dönüşüm",

{
  "toolName": "auto-insurance-calculator",
  "inputs": [
    {
      "id": "vehicleValue",
      "label": "Vehicle Value",
      "type": "number",
      "unit": "$",
      "default": 25000,
      "businessContext": "Current market value of the vehicle in USD."
    },
    {
      "id": "driverAge",
      "label": "Driver Age",
      "type": "number",
      "unit": "years",
      "default": 35,
      "businessContext": "Age of the primary driver (18-100)."
    },
    {
      "id": "drivingExperience",
      "label": "Driving Experience",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Total years of driving experience."
    },
    {
      "id": "coverageLevel",
      "label": "Coverage Level",
      "type": "number",
      "unit": "factor",
      "default": 2,
      "businessContext": "Coverage type: 1 = Liability only, 2 = Standard, 3 = Comprehensive. Acts as multiplier."
    },
    {
      "id": "deductible",
      "label": "Deductible Amount",
      "type": "number",
      "unit": "$",
      "default": 500,
      "businessContext": "Amount the insured pays out-of-pocket before coverage kicks in."
    },
    {
      "id": "vehicleAge",
      "label": "Vehicle Age",
      "type": "number",
      "unit": "years",
      "default": 3,
      "businessContext": "Age of the vehicle from manufacturing year."
    },
    {
      "id": "annualMileage",
      "label": "Annual Mileage",
      "type": "number",
      "unit": "km/year",
      "default": 12000,
      "businessContext": "Estimated distance driven per year in kilometers."
    }
  ],
  "formulas": {
    "basePremium": "vehicleValue * 0.02",
    "ageFactor": "driverAge < 25 ? 1.5 : (driverAge >= 65 ? 1.3 : 1.0)",
    "experienceFactor": "drivingExperience < 3 ? 1.4 : 1.0",
    "coverageFactor": "coverageLevel",
    "deductibleFactor": "Math.max(0.7, 1 - deductible / vehicleValue)",
    "vehicleAgeFactor": "vehicleAge < 3 ? 1.1 : (vehicleAge > 10 ? 0.9 : 1.0)",
    "mileageFactor": "annualMileage > 15000 ? 1.2 : (annualMileage < 5000 ? 0.8 : 1.0)",
    "annualPremium": "basePremium * ageFactor * experienceFactor * coverageFactor * deductibleFactor * vehicleAgeFactor * mileageFactor"
  },
  "outputs": {
    "primary": "annualPremium",
    "breakdown": [
      "basePremium",
      "ageFactor",
      "experienceFactor",
      "coverageFactor",
      "deductibleFactor",
      "vehicleAgeFactor",
      "mileageFactor"
    ]
  },
  "category": "Diğer",
  "sector": "Otomotiv & Taşıt",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "maintenance-reliability",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "diger"
}

      "type": "number",
      "unit": "years",
      "default": 3,
      "businessContext": "Age of the vehicle from manufacturing year.",
      "label_i18n": {
        "en": "Vehicle Age",
        "tr": "Araç Yaşı",
        "de": "Fahrzeugalter",
        "fr": "Vehicle Age",

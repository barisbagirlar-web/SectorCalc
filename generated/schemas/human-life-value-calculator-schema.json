        "ar": "عدد السنوات حتى التقاعد"
      }
    },
    {
      "id": "expenseRatio",
      "label": "Personal Expense Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.3,
      "businessContext": "Fraction of income spent on personal expenses (e.g., 0.3 for 30%)",
      "label_i18n": {
        "en": "Personal Expense Ratio",
        "tr": "Kişisel Harcama Oranı",
        "de": "Persönliche Ausgabenquote",
        "fr": "Ratio de dépenses personnelles",
        "es": "Relación de gastos personales",
        "ar": "نسبة المصروفات الشخصية"
      },
      "businessContext_i18n": {
        "en": "Fraction of income spent on personal expenses (e.g., 0.3 for 30%)",
        "tr": "Kişisel harcamalara harcanan gelir oranı (örn. %30 için 0,3)",
        "de": "Anteil des Einkommens für persönliche Ausgaben (z. B. 0,3 für 30%)",
        "fr": "Fraction du revenu consacrée aux dépenses personnelles (par ex. 0,3 pour 30%)",
        "es": "Fracción del ingreso gastada en gastos personales (ej. 0.3 para 30%)",
        "ar": "نسبة الدخل المنفق على المصروفات الشخصية (مثل 0.3 لـ 30%)"
      }
    },
    {
      "id": "rateOfReturn",
      "label": "Rate of Return",
      "type": "number",
      "unit": "decimal",
      "default": 0.05,
      "businessContext": "Expected annual investment return (e.g., 0.05 for 5%)",
      "label_i18n": {
        "en": "Rate of Return",
        "tr": "Getiri Oranı",
        "de": "Rendite",
        "fr": "Taux de rendement",
        "es": "Tasa de rendimiento",
        "ar": "معدل العائد"
      },
      "businessContext_i18n": {
        "en": "Expected annual investment return (e.g., 0.05 for 5%)",
        "tr": "Beklenen yıllık yatırım getirisi (örn. %5 için 0,05)",
        "de": "Erwartete jährliche Kapitalrendite (z. B. 0,05 für 5%)",
        "fr": "Rendement annuel attendu des investissements (par ex. 0,05 pour 5%)",
        "es": "Rendimiento anual esperado de la inversión (ej. 0.05 para 5%)",
        "ar": "معدل العائد السنوي المتوقع على الاستثمار (مثل 0.05 لـ 5%)"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "decimal",
      "default": 0.02,
      "businessContext": "Expected annual inflation rate (e.g., 0.02 for 2%)",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Enflasyon Oranı",
        "de": "Inflationsrate",
        "fr": "Taux d'inflation",
        "es": "Tasa de inflación",
        "ar": "معدل التضخم"
      },
      "businessContext_i18n": {
        "en": "Expected annual inflation rate (e.g., 0.02 for 2%)",
        "tr": "Beklenen yıllık enflasyon oranı (örn. %2 için 0,02)",
        "de": "Erwartete jährliche Inflationsrate (z. B. 0,02 für 2%)",
        "fr": "Taux d'inflation annuel attendu (par ex. 0,02 pour 2%)",
        "es": "Tasa de inflación anual esperada (ej. 0.02 para 2%)",
        "ar": "معدل التضخم السنوي المتوقع (مثل 0.02 لـ 2%)"
      }
    },
    {
      "id": "currentSavings",
      "label": "Current Savings",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Existing savings or liquid assets",
      "label_i18n": {
        "en": "Current Savings",
        "tr": "Mevcut Birikimler",
        "de": "Aktuelle Ersparnisse",
        "fr": "Épargne actuelle",
        "es": "Ahorros actuales",
        "ar": "المدخرات الحالية"
      },
      "businessContext_i18n": {
        "en": "Existing savings or liquid assets",
        "tr": "Mevcut birikimler veya likit varlıklar",
        "de": "Vorhandene Ersparnisse oder liquide Mittel",
        "fr": "Épargne ou actifs liquides existants",
        "es": "Ahorros existentes o activos líquidos",
        "ar": "المدخرات الحالية أو الأصول السائلة"
      }
    }
  ],
  "formulas": {
    "netAnnualContribution": "annualIncome * (1 - expenseRatio)",
    "realRate": "(1 + rateOfReturn) / (1 + inflationRate) - 1"
  },
  "outputs": {
    "primary": "realRate",
    "breakdown": [
      "netAnnualContribution",
      "realRate",
      "presentValue"
    ],

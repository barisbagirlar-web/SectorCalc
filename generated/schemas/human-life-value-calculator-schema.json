      "businessContext": "Expected annual inflation rate (e.g., 0.02 for 2%)",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Inflation Rate",
        "de": "Inflation Rate",
        "fr": "Inflation Rate",
        "es": "Inflation Rate",
        "ar": "Inflation Rate"
      }
    },
    {
      "id": "currentSavings",
      "label": "Current Savings",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Existing savings or liquid assets",

{
  "toolName": "human-life-value-calculator",
  "inputs": [
    {
      "id": "annualIncome",
      "label": "Annual Income",
      "type": "number",
      "unit": "USD/year",
      "default": 50000,
      "businessContext": "Gross annual income of the individual",
      "label_i18n": {
        "en": "Annual Income",
        "tr": "Yıllık Gelir",
        "de": "Jahreseinkommen",
        "fr": "Revenu annuel",
        "es": "Ingreso anual",
        "ar": "الدخل السنوي"
      },
      "businessContext_i18n": {
        "en": "Gross annual income of the individual",
        "tr": "Bireyin brüt yıllık geliri",

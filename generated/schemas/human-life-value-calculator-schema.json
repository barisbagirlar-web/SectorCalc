{
  "toolName": "human-life-value-calculator",
  "inputs": [
    {
      "id": "annualIncome",
      "label": "Annual Income",
      "type": "number",
      "unit": "USD/year",
      "default": 50000,
      "businessContext": "Gross annual income of the individual",
      "label_i18n": {
        "en": "Annual Income",
        "tr": "Annual Income",
        "de": "Annual Income",

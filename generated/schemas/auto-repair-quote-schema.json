  "formulas": {
    "QuoteVariance": "STDEV(QuoteAmounts) / AVERAGE(QuoteAmounts)",
    "PartPriceDeviation": "(QuotedPartPrice - MarketAvg) / MarketAvg",
    "LaborTimeDeviation": "(QuotedLaborHours - StandardHours) / StandardHours",
    "ConsistencyScore": "100 - (QuoteVariance * 50 + ABS(PartPriceDeviation) * 25 + ABS(LaborTimeDeviation) * 25)",
    "MarginLeak": "SUM((MarketPrice - QuotedPrice) * Quantity)"
  },

    {
      "id": "falseNegatives",
      "label": "False Negatives (FN)",
      "type": "number",
      "unit": "count",
      "default": 10,
      "businessContext": "Number of incorrectly identified negative cases (e.g., defective products missed)",
      "label_i18n": {
        "en": "False Negatives (FN)",

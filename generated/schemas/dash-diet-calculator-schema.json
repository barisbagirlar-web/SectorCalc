  "formulas": {
    "bmr": "gender === 1 ? 10*weight_kg + 6.25*height_cm - 5*age + 5 : 10*weight_kg + 6.25*height_cm - 5*age - 161",
    "tdee": "bmr * (activity_level === 1 ? 1.2 : activity_level === 2 ? 1.375 : activity_level === 3 ? 1.55 : activity_level === 4 ? 1.725 : 1.9)",
    "carb_g": "(tdee * 0.55) / 4",
    "protein_g": "(tdee * 0.18) / 4",
    "fat_g": "(tdee * 0.27) / 9"
  },
  "outputs": {
    "primary": "tdee",
    "breakdown": [

      }
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "0=Female,1=Male",
      "default": 1,
      "businessContext": "0 for female, 1 for male",
      "label_i18n": {
        "en": "Gender",
        "tr": "Cinsiyet",
        "de": "Geschlecht",

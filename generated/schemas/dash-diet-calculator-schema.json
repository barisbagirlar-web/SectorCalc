        "ar": "Gender"
      },
      "businessContext_i18n": {
        "en": "0 for female, 1 for male",
        "tr": "0 kadın, 1 erkek",
        "de": "0 für weiblich, 1 für männlich"
      }
    },
    {
      "id": "height_cm",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Height in centimeters",
      "label_i18n": {
        "en": "Height",
        "tr": "Boy",
        "de": "Größe",
        "fr": "Height",
        "es": "Height",
        "ar": "Height"
      },
      "businessContext_i18n": {
        "en": "Height in centimeters",
        "tr": "Santimetre cinsinden boy",
        "de": "Größe in Zentimetern"
      }
    },
    {
      "id": "weight_kg",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Weight in kilograms",
      "label_i18n": {
        "en": "Weight",
        "tr": "Ağırlık",
        "de": "Gewicht",
        "fr": "Weight",
        "es": "Weight",
        "ar": "Weight"
      },
      "businessContext_i18n": {
        "en": "Weight in kilograms",
        "tr": "Ağırlık (kg)",
        "de": "Gewicht in Kilogramm"
      }
    },
    {
      "id": "activity_level",
      "label": "Activity Level",
      "type": "number",
      "unit": "1-5",
      "default": 3,
      "businessContext": "1=Sedentary,2=Light,3=Moderate,4=Active,5=Very Active",
      "label_i18n": {
        "en": "Activity Level",
        "tr": "Aktivite Seviyesi",
        "de": "Aktivitätsniveau",
        "fr": "Activity Level",
        "es": "Activity Level",
        "ar": "Activity Level"
      },
      "businessContext_i18n": {
        "en": "1=Sedentary,2=Light,3=Moderate,4=Active,5=Very Active",
        "tr": "1=Hareketsiz, 2=Hafif, 3=Orta, 4=Aktif, 5=Çok Aktif",
        "de": "1=Sitzend, 2=Leicht, 3=Mäßig, 4=Aktiv, 5=Sehr aktiv"
      }
    }
  ],
  "formulas": {
    "bmr": "gender === 1 ? 10*weight_kg + 6.25*height_cm - 5*age + 5 : 10*weight_kg + 6.25*height_cm - 5*age - 161",
    "tdee": "bmr * (activity_level === 1 ? 1.2 : activity_level === 2 ? 1.375 : activity_level === 3 ? 1.55 : activity_level === 4 ? 1.725 : 1.9)",
    "carb_g": "(tdee * 0.55) / 4",
    "protein_g": "(tdee * 0.18) / 4",
    "fat_g": "(tdee * 0.27) / 9"
  },
  "outputs": {
    "primary": "tdee",
    "breakdown": [
      "carb_g",
      "protein_g",
      "fat_g"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "fat_g",
    "unit": "years",
    "breakdownUnits": {
      "carb_g": "g",
      "protein_g": "g",
      "fat_g": "g"
    }
  },

        "es": "Peso añadido después de cada sesión completada",
        "ar": "الوزن المضاف بعد كل جلسة مكتملة"
      }
    },
    {
      "id": "sessionsPerWeek",
      "label": "Sessions per Week",
      "type": "number",
      "unit": "sessions/week",
      "default": 3,
      "businessContext": "Training frequency per week",
      "label_i18n": {
        "en": "Sessions per Week",
        "tr": "Haftalık Seans Sayısı",
        "de": "Trainingseinheiten pro Woche",
        "fr": "Séances par semaine",
        "es": "Sesiones por Semana",
        "ar": "الجلسات في الأسبوع"
      },
      "businessContext_i18n": {
        "en": "Training frequency per week",
        "tr": "Haftalık antrenman sıklığı",
        "de": "Trainingshäufigkeit pro Woche",
        "fr": "Fréquence d'entraînement par semaine",
        "es": "Frecuencia de entrenamiento por semana",
        "ar": "تكرار التدريب في الأسبوع"
      }
    },
    {
      "id": "weeks",
      "label": "Number of Weeks",
      "type": "number",
      "unit": "weeks",
      "default": 4,
      "businessContext": "Duration of training cycle",
      "label_i18n": {
        "en": "Number of Weeks",
        "tr": "Hafta Sayısı",
        "de": "Anzahl der Wochen",
        "fr": "Nombre de semaines",
        "es": "Número de semanas",
        "ar": "عدد الأسابيع"
      },
      "businessContext_i18n": {
        "en": "Duration of training cycle",
        "tr": "Antrenman döngüsü süresi",
        "de": "Dauer des Trainingszyklus",
        "fr": "Durée du cycle d'entraînement",
        "es": "Duración del ciclo de entrenamiento",
        "ar": "مدة دورة التدريب"
      }
    }
  ],
  "formulas": {
    "totalSessions": "weeks * sessionsPerWeek",
    "finalWeight": "startingWeight + totalSessions * incrementPerSession",
    "estimated1RM": "finalWeight * (1 + 0.0333 * 5)"
  },
  "outputs": {
    "primary": "finalWeight",
    "breakdown": [
      "totalSessions",
      "estimated1RM"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "estimated1RM",
    "unit": "kg"
  },

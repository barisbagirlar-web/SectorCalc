        "es": "Peso inicial levantado en la primera sesión",
        "ar": "الوزن المرفوع في الجلسة الأولى"
      }
    },
    {
      "id": "incrementPerSession",
      "label": "Increment per Session",
      "type": "number",
      "unit": "kg",
      "default": 2.5,
      "businessContext": "Weight added after each completed session",
      "label_i18n": {
        "en": "Increment per Session",
        "tr": "Seans Başına Artış",

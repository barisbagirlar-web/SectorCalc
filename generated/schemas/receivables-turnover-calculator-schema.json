{
  "toolName": "receivables-turnover-calculator",
  "inputs": [
    {
      "id": "netCreditSales",
      "label": "Net Credit Sales",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "Total credit sales minus returns and allowances.",
      "label_i18n": {
        "en": "Net Credit Sales",
        "tr": "Net Kredi Satışları",
        "de": "Net Credit Sales",
        "fr": "Net Credit Sales",
        "es": "Net Credit Sales",
        "ar": "Net Credit Sales"
      },
      "businessContext_i18n": {
        "en": "Total credit sales minus returns and allowances.",
        "tr": "İadeler ve indirimler hariç toplam kredi satışları."
      }
    },
    {
      "id": "beginningAR",
      "label": "Beginning Accounts Receivable",
      "type": "number",
      "unit": "currency",
      "default": 20000,
      "businessContext": "Accounts receivable at start of period.",
      "label_i18n": {
        "en": "Beginning Accounts Receivable",
        "tr": "Dönem Başı Alacak Hesapları",
        "de": "Beginning Accounts Receivable",
        "fr": "Beginning Accounts Receivable",
        "es": "Beginning Accounts Receivable",
        "ar": "Beginning Accounts Receivable"
      },
      "businessContext_i18n": {
        "en": "Accounts receivable at start of period.",
        "tr": "Dönem başındaki alacak hesapları."
      }
    },
    {
      "id": "endingAR",
      "label": "Ending Accounts Receivable",
      "type": "number",
      "unit": "currency",
      "default": 25000,
      "businessContext": "Accounts receivable at end of period.",
      "label_i18n": {
        "en": "Ending Accounts Receivable",
        "tr": "Dönem Sonu Alacak Hesapları",
        "de": "Ending Accounts Receivable",
        "fr": "Ending Accounts Receivable",
        "es": "Ending Accounts Receivable",
        "ar": "Ending Accounts Receivable"
      },
      "businessContext_i18n": {
        "en": "Accounts receivable at end of period.",
        "tr": "Dönem sonundaki alacak hesapları."
      }
    },
    {
      "id": "daysInPeriod",
      "label": "Days in Period",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "Number of days in the accounting period (e.g., 365 for year).",
      "label_i18n": {
        "en": "Days in Period",
        "tr": "Dönemdeki Gün Sayısı",
        "de": "Days in Period",
        "fr": "Days in Period",
        "es": "Days in Period",
        "ar": "Days in Period"
      },
      "businessContext_i18n": {
        "en": "Number of days in the accounting period (e.g., 365 for year).",
        "tr": "Muhasebe dönemindeki gün sayısı (örneğin, yıl için 365)."
      }
    }
  ],
  "formulas": {
    "averageAccountsReceivable": "(beginningAR + endingAR) / 2",
    "receivablesTurnoverRatio": "netCreditSales / averageAccountsReceivable",
    "daysSalesOutstanding": "daysInPeriod / receivablesTurnoverRatio"
  },
  "outputs": {
    "primary": "receivablesTurnoverRatio",
    "breakdown": [
      "averageAccountsReceivable",
      "daysSalesOutstanding"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "daysSalesOutstanding",
    "unit": "%"
  },

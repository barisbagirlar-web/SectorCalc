{
  "toolName": "airbnb-cost-calculator",
  "inputs": [
    {
      "id": "nightlyRate",
      "label": "Nightly Rate",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "The base price per night for the listing",
      "label_i18n": {
        "en": "Nightly Rate",
        "tr": "Nightly Rate",
        "de": "Nightly Rate",
        "fr": "Nightly Rate",
        "es": "Nightly Rate",
        "ar": "Nightly Rate"
      }
    },
    {
      "id": "numNights",
      "label": "Number of Nights",
      "type": "number",
      "unit": "nights",
      "default": 1,
      "businessContext": "Duration of stay",
      "label_i18n": {
        "en": "Number of Nights",
        "tr": "Number of Nights",
        "de": "Number of Nights",
        "fr": "Number of Nights",
        "es": "Number of Nights",
        "ar": "Number of Nights"
      }
    },
    {
      "id": "cleaningFee",
      "label": "Cleaning Fee",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "One-time cleaning fee charged per booking",
      "label_i18n": {
        "en": "Cleaning Fee",
        "tr": "Cleaning Fee",
        "de": "Cleaning Fee",
        "fr": "Cleaning Fee",
        "es": "Cleaning Fee",
        "ar": "Cleaning Fee"
      }
    },
    {
      "id": "serviceFeeRate",
      "label": "Service Fee Rate",
      "type": "number",
      "unit": "%",
      "default": 14,
      "businessContext": "Airbnb host service fee percentage",
      "label_i18n": {
        "en": "Service Fee Rate",
        "tr": "Service Fee Rate",
        "de": "Service Fee Rate",
        "fr": "Service Fee Rate",
        "es": "Service Fee Rate",
        "ar": "Service Fee Rate"
      }
    },
    {
      "id": "occupancyTaxRate",
      "label": "Occupancy Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Local occupancy / transient tax percentage",
      "label_i18n": {
        "en": "Occupancy Tax Rate",
        "tr": "Occupancy Tax Rate",
        "de": "Occupancy Tax Rate",
        "fr": "Occupancy Tax Rate",
        "es": "Occupancy Tax Rate",
        "ar": "Occupancy Tax Rate"
      }
    },
    {
      "id": "extraGuestFee",
      "label": "Additional Guest Fee (per guest per night)",
      "type": "number",
      "unit": "USD",
      "default": 20,
      "businessContext": "Fee per extra guest per night beyond base occupancy",
      "label_i18n": {
        "en": "Additional Guest Fee (per guest per night)",
        "tr": "Additional Guest Fee (per guest per night)",
        "de": "Additional Guest Fee (per guest per night)",
        "fr": "Additional Guest Fee (per guest per night)",
        "es": "Additional Guest Fee (per guest per night)",
        "ar": "Additional Guest Fee (per guest per night)"
      }
    },
    {
      "id": "extraGuests",
      "label": "Number of Extra Guests",
      "type": "number",
      "unit": "guests",
      "default": 0,
      "businessContext": "Number of guests exceeding the base occupancy (e.g., beyond 2)",
      "label_i18n": {
        "en": "Number of Extra Guests",
        "tr": "Number of Extra Guests",
        "de": "Number of Extra Guests",
        "fr": "Number of Extra Guests",
        "es": "Number of Extra Guests",
        "ar": "Number of Extra Guests"
      }
    },
    {
      "id": "discountRate",
      "label": "Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage discount applied to the total (e.g., long-stay discount)",
      "label_i18n": {
        "en": "Discount Rate",
        "tr": "Discount Rate",
        "de": "Discount Rate",
        "fr": "Discount Rate",
        "es": "Discount Rate",
        "ar": "Discount Rate"
      }
    }
  ],
  "formulas": {
    "nightlyTotal": "nightlyRate * numNights",
    "extraGuestCost": "extraGuestFee * extraGuests * numNights",
    "subtotal": "nightlyTotal + cleaningFee + extraGuestCost",
    "serviceFee": "subtotal * (serviceFeeRate / 100)",
    "taxableAmount": "subtotal + serviceFee",
    "tax": "taxableAmount * (occupancyTaxRate / 100)",
    "totalBeforeDiscount": "taxableAmount + tax",
    "discountAmount": "totalBeforeDiscount * (discountRate / 100)",
    "totalCost": "totalBeforeDiscount - discountAmount"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "nightlyTotal",
      "cleaningFee",
      "extraGuestCost",
      "serviceFee",
      "tax",
      "discountAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

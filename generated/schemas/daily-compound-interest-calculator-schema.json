{
  "toolName": "daily-compound-interest-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "EUR",
      "default": 1000,
      "businessContext": "Initial investment or loan amount.",
      "label_i18n": {
        "en": "Principal Amount",
        "tr": "Anapara Tutarı",
        "de": "Kapitalbetrag",
        "fr": "Principal Amount",
        "es": "Principal Amount",
        "ar": "Principal Amount"
      },
      "businessContext_i18n": {
        "en": "Initial investment or loan amount.",
        "tr": "İlk yatırım veya kredi tutarı",
        "de": "Anfangsinvestition oder Darlehensbetrag."
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Nominal annual interest rate.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Yıllık Faiz Oranı",
        "de": "Jährlicher Zinssatz",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Nominal annual interest rate.",
        "tr": "Nominal yıllık faiz oranı",
        "de": "Nominaler jährlicher Zinssatz."
      }
    },
    {
      "id": "timeInDays",
      "label": "Time Period",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "Total number of days the money is invested or borrowed for.",
      "label_i18n": {
        "en": "Time Period",
        "tr": "Zaman Periyodu",
        "de": "Zeitraum",
        "fr": "Time Period",
        "es": "Time Period",
        "ar": "Time Period"
      },
      "businessContext_i18n": {
        "en": "Total number of days the money is invested or borrowed for.",
        "tr": "Paranın yatırıldığı veya ödünç alındığı toplam gün sayısı",
        "de": "Gesamtzahl der Tage, an denen das Geld angelegt oder geliehen wird."
      }
    },
    {
      "id": "daysInYear",
      "label": "Days in Year",
      "type": "number",
      "unit": "days/year",
      "default": 365,
      "businessContext": "Day count convention: 365 for standard, 360 for some financial markets.",
      "label_i18n": {
        "en": "Days in Year",
        "tr": "Yıldaki Gün Sayısı",
        "de": "Tage im Jahr",
        "fr": "Days in Year",
        "es": "Days in Year",
        "ar": "Days in Year"
      },
      "businessContext_i18n": {
        "en": "Day count convention: 365 for standard, 360 for some financial markets.",
        "tr": "Gün sayım kuralı: standart için 365, bazı finans piyasaları için 360",
        "de": "Tagezählungskonvention: 365 für Standard, 360 für einige Finanzmärkte."
      }
    }
  ],
  "formulas": {
    "futureValue": "principal * (1 + annualRate / 100 / daysInYear) ** timeInDays",
    "totalInterest": "futureValue - principal",
    "effectiveAnnualRate": "((1 + annualRate / 100 / daysInYear) ** daysInYear - 1) * 100"
  },
  "outputs": {
    "primary": "futureValue",
    "breakdown": [
      "totalInterest",
      "effectiveAnnualRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveAnnualRate",
    "unit": "EUR"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

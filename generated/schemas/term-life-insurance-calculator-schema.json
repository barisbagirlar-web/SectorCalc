{
  "toolName": "term-life-insurance-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the insured person",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "isSmoker",
      "label": "Smoker",
      "type": "number",
      "unit": "binary (1=Yes, 0=No)",
      "default": 0,
      "businessContext": "Indicates if the insured is a smoker",
      "label_i18n": {
        "en": "Smoker",
        "tr": "Smoker",
        "de": "Smoker",
        "fr": "Smoker",
        "es": "Smoker",
        "ar": "Smoker"
      }
    },
    {
      "id": "coverageAmount",
      "label": "Coverage Amount",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Death benefit amount",
      "label_i18n": {
        "en": "Coverage Amount",
        "tr": "Coverage Amount",
        "de": "Coverage Amount",
        "fr": "Coverage Amount",
        "es": "Coverage Amount",
        "ar": "Coverage Amount"
      }
    },
    {
      "id": "termYears",
      "label": "Term (Years)",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "Policy term length",
      "label_i18n": {
        "en": "Term (Years)",
        "tr": "Term (Years)",
        "de": "Term (Years)",
        "fr": "Term (Years)",
        "es": "Term (Years)",
        "ar": "Term (Years)"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual discount rate for present value calculation",
      "label_i18n": {
        "en": "Interest Rate",
        "tr": "Interest Rate",
        "de": "Interest Rate",
        "fr": "Interest Rate",
        "es": "Interest Rate",
        "ar": "Interest Rate"
      }
    }
  ],
  "formulas": {
    "primary": "coverageAmount * (0.001 * (age - 20 + 5 * isSmoker)) / Math.pow(1 + interestRate/100, termYears)",
    "breakdown": "age",
    "__breakdown0_": "${breakdown0}",
    "__breakdown1_": "${breakdown1}",
    "__breakdown2_": "${breakdown2}"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "Mortality Probability: ${breakdown0}",
      "Discount Factor: ${breakdown1}",
      "Coverage Amount: ${breakdown2}"
    ]
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

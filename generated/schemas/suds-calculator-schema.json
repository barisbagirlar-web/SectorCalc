{
  "toolName": "suds-calculator",
  "inputs": [
    {
      "id": "catchmentArea",
      "label": "Catchment Area",
      "type": "number",
      "unit": "m²",
      "default": 1000,
      "businessContext": "Total impervious area draining to the SUDS feature.",
      "label_i18n": {
        "en": "Catchment Area",
        "tr": "Catchment Area",
        "de": "Catchment Area",
        "fr": "Catchment Area",
        "es": "Catchment Area",
        "ar": "Catchment Area"
      }
    },
    {
      "id": "rainfallIntensity",
      "label": "Design Rainfall Intensity",
      "type": "number",
      "unit": "mm/hr",
      "default": 50,
      "businessContext": "Intensity for the design storm event, typically from IDF curves.",
      "label_i18n": {
        "en": "Design Rainfall Intensity",
        "tr": "Design Rainfall Intensity",
        "de": "Design Rainfall Intensity",
        "fr": "Design Rainfall Intensity",
        "es": "Design Rainfall Intensity",
        "ar": "Design Rainfall Intensity"
      }
    },
    {
      "id": "runoffCoefficient",
      "label": "Runoff Coefficient",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.9,
      "businessContext": "Ratio of runoff to rainfall, based on surface type.",
      "label_i18n": {
        "en": "Runoff Coefficient",
        "tr": "Runoff Coefficient",
        "de": "Runoff Coefficient",
        "fr": "Runoff Coefficient",
        "es": "Runoff Coefficient",
        "ar": "Runoff Coefficient"
      }
    },
    {
      "id": "stormDuration",
      "label": "Storm Duration",
      "type": "number",
      "unit": "min",
      "default": 60,
      "businessContext": "Duration of the design storm event.",
      "label_i18n": {
        "en": "Storm Duration",
        "tr": "Storm Duration",
        "de": "Storm Duration",
        "fr": "Storm Duration",
        "es": "Storm Duration",
        "ar": "Storm Duration"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.2,
      "businessContext": "Factor of safety to account for uncertainties.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "durationHours": "stormDuration / 60",
    "rainfallDepthM": "(rainfallIntensity * durationHours) / 1000",
    "runoffVolume": "catchmentArea * rainfallDepthM * runoffCoefficient",
    "requiredStorage": "runoffVolume * safetyFactor"
  },
  "outputs": {
    "primary": "requiredStorage",
    "breakdown": [
      "runoffVolume",
      "rainfallDepthM",
      "durationHours"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "requiredStorage"
  },

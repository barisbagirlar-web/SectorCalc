  "formulas": {
    "HV": "scaleFrom == 1 ? hardnessValue / 0.8 : (scaleFrom == 2 ? (hardnessValue / 1.2) * 30 : (scaleFrom == 3 ? hardnessValue : (scaleFrom == 4 ? (hardnessValue * 0.7 + 10) * 30 : (scaleFrom == 5 ? (hardnessValue * 0.8 + 12) * 30 : 0))))",
    "HRB": "scaleFrom == 1 ? (hardnessValue * 0.8 - 20) : (scaleFrom == 2 ? hardnessValue : (scaleFrom == 3 ? (hardnessValue / 30 * 0.7 + 10) : (scaleFrom == 4 ? hardnessValue : (scaleFrom == 5 ? hardnessValue * 1.1 + 5 : 0))))",
    "HRA": "scaleFrom == 1 ? (hardnessValue * 0.9 - 15) : (scaleFrom == 2 ? hardnessValue : (scaleFrom == 3 ? (hardnessValue / 30 * 0.8 + 12) : (scaleFrom == 4 ? (hardnessValue - 5) / 1.1 : (scaleFrom == 5 ? hardnessValue : 0))))"

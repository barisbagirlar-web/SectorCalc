{
  "toolName": "dividend-calculator",
  "inputs": [
    {
      "id": "sharePrice",
      "label": "Current Share Price",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Market price per share at current time.",
      "label_i18n": {
        "en": "Current Share Price",
        "tr": "Current Share Price",
        "de": "Current Share Price",
        "fr": "Current Share Price",
        "es": "Current Share Price",
        "ar": "Current Share Price"
      }
    },
    {
      "id": "purchasePrice",
      "label": "Average Purchase Price per Share",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "The average price paid per share (cost basis).",
      "label_i18n": {
        "en": "Average Purchase Price per Share",
        "tr": "Average Purchase Price per Share",
        "de": "Average Purchase Price per Share",
        "fr": "Average Purchase Price per Share",
        "es": "Average Purchase Price per Share",
        "ar": "Average Purchase Price per Share"
      }
    },
    {
      "id": "annualDividendPerShare",
      "label": "Annual Dividend per Share",
      "type": "number",
      "unit": "USD",
      "default": 5,
      "businessContext": "Total dividends paid per share over the last fiscal year.",
      "label_i18n": {
        "en": "Annual Dividend per Share",
        "tr": "Annual Dividend per Share",
        "de": "Annual Dividend per Share",
        "fr": "Annual Dividend per Share",
        "es": "Annual Dividend per Share",
        "ar": "Annual Dividend per Share"
      }
    },
    {
      "id": "numberOfShares",
      "label": "Number of Shares Owned",
      "type": "number",
      "unit": "shares",
      "default": 100,
      "businessContext": "Total number of shares held in the portfolio.",
      "label_i18n": {
        "en": "Number of Shares Owned",
        "tr": "Number of Shares Owned",
        "de": "Number of Shares Owned",
        "fr": "Number of Shares Owned",
        "es": "Number of Shares Owned",
        "ar": "Number of Shares Owned"
      }
    },
    {
      "id": "dividendGrowthRate",
      "label": "Expected Dividend Growth Rate",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Annual projected growth rate of dividends, as a percentage.",
      "label_i18n": {
        "en": "Expected Dividend Growth Rate",
        "tr": "Expected Dividend Growth Rate",
        "de": "Expected Dividend Growth Rate",
        "fr": "Expected Dividend Growth Rate",
        "es": "Expected Dividend Growth Rate",
        "ar": "Expected Dividend Growth Rate"
      }
    }
  ],
  "formulas": {
    "annualIncome": "annualDividendPerShare * numberOfShares",
    "dividendYield": "(annualDividendPerShare / sharePrice) * 100",
    "yieldOnCost": "(annualDividendPerShare / purchasePrice) * 100",
    "projectedAnnualIncome": "(annualDividendPerShare * (1 + dividendGrowthRate / 100)) * numberOfShares"
  },
  "outputs": {
    "primary": "dividendYield",
    "breakdown": [
      "annualIncome",
      "yieldOnCost",
      "projectedAnnualIncome"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "projectedAnnualIncome"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

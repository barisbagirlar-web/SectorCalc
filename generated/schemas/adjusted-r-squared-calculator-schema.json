    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Number of decimal places for rounding the final result.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "numerator": "(1 - rSquared) * (sampleSize - 1)",
    "denominator": "sampleSize - predictors - 1",
    "adjustedRSquared": "denominator > 0 ? 1 - (numerator / denominator) : NaN",
    "adjustedRSquaredFormatted": "Number.isFinite(adjustedRSquared) ? Math.round(adjustedRSquared * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces) : NaN",
    "rSquared": "rSquared",
    "sampleSize": "sampleSize",
    "predictors": "predictors"
  },
  "outputs": {
    "primary": "adjustedRSquaredFormatted",
    "breakdown": [
      "rSquared",
      "sampleSize",
      "predictors",
      "numerator",
      "denominator",
      "adjustedRSquared"
    ]
  },

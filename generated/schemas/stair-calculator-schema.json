{
  "toolName": "stair-calculator",
  "inputs": [
    {
      "id": "totalRise",
      "label": "Total Rise",
      "type": "number",
      "unit": "cm",
      "default": 280,
      "businessContext": "floor-to-floor height",
      "label_i18n": {
        "en": "Total Rise",
        "tr": "Total Rise",
        "de": "Total Rise",
        "fr": "Total Rise",
        "es": "Total Rise",
        "ar": "Total Rise"
      }
    },
    {
      "id": "numberOfRisers",
      "label": "Number of Risers",
      "type": "number",
      "unit": "count",
      "default": 15,
      "businessContext": "desired number of steps (risers)",
      "label_i18n": {
        "en": "Number of Risers",
        "tr": "Number of Risers",
        "de": "Number of Risers",
        "fr": "Number of Risers",
        "es": "Number of Risers",
        "ar": "Number of Risers"
      }
    },
    {
      "id": "treadDepth",
      "label": "Tread Depth",
      "type": "number",
      "unit": "cm",
      "default": 28,
      "businessContext": "horizontal depth of each tread",
      "label_i18n": {
        "en": "Tread Depth",
        "tr": "Tread Depth",
        "de": "Tread Depth",
        "fr": "Tread Depth",
        "es": "Tread Depth",
        "ar": "Tread Depth"
      }
    },
    {
      "id": "stairWidth",
      "label": "Stair Width",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "businessContext": "width of the staircase",
      "label_i18n": {
        "en": "Stair Width",
        "tr": "Stair Width",
        "de": "Stair Width",
        "fr": "Stair Width",
        "es": "Stair Width",
        "ar": "Stair Width"
      }
    }
  ],
  "formulas": {
    "riserHeight": "inputs.totalRise / inputs.numberOfRisers",
    "numberOfTreads": "inputs.numberOfRisers - 1",
    "totalRun": "inputs.treadDepth * (inputs.numberOfRisers - 1)",
    "stringerLength": "Math.sqrt(Math.pow(inputs.totalRise, 2) + Math.pow(inputs.treadDepth * (inputs.numberOfRisers - 1), 2))",
    "stairAngle": "Math.atan(inputs.totalRise / (inputs.treadDepth * (inputs.numberOfRisers - 1))) * (180 / Math.PI)"
  },
  "outputs": {
    "primary": "stringerLength",
    "breakdown": [
      "riserHeight",
      "numberOfTreads",
      "totalRun",
      "stairAngle"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "diger"
}

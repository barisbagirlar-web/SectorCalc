        "es": "Sayı B",
        "ar": "Sayı B"
      }
    },
    {
      "id": "operation",
      "label": "İşlem",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1=Toplama, 2=Çıkarma, 3=Çarpma, 4=Bölme",
      "label_i18n": {
        "en": "İşlem",
        "tr": "İşlem",
        "de": "İşlem",
        "fr": "İşlem",

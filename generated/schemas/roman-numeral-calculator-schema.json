      }
    },
    {
      "id": "precision",
      "label": "Ondalık Basamak",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Sonuç ondalık basamak sayısı (0 tamsayıya yuvarla)",
      "label_i18n": {
        "en": "Ondalık Basamak",
        "tr": "Ondalık Basamak",
        "de": "Ondalık Basamak",
        "fr": "Ondalık Basamak",
        "es": "Ondalık Basamak",
        "ar": "Ondalık Basamak"
      }
    }
  ],
  "formulas": {
    "rawResult": "(operation == 1 ? numberA + numberB : operation == 2 ? numberA - numberB : operation == 3 ? numberA * numberB : operation == 4 ? (numberB != 0 ? numberA / numberB : NaN) : NaN)",
    "finalResult": "precision == 0 ? Math.round(rawResult) : Number(rawResult.toFixed(precision))",
    "_numberA___operation__1_____operation__2": "{numberA} {operation==1?'+':operation==2?'-':operation==3?'*':'/'} {numberB} = {rawResult}",
    "_finalResult_": "{finalResult}",
    "_romanResult_": "{romanResult}"
  },
  "outputs": {
    "primary": "rawResult",
    "breakdown": [
      "İşlem: {numberA} {operation==1?'+':operation==2?'-':operation==3?'*':'/'} {numberB} = {rawResult}",
      "Yuvarlanmış sonuç: {finalResult}",
      "Roma rakamı karşılığı: {romanResult}"
    ]
  },

{
  "toolName": "cup-to-gram-calculator",
  "inputs": [
    {
      "id": "cups",
      "label": "Cup Amount",
      "type": "number",
      "unit": "cups",
      "default": 1,
      "businessContext": "Number of standard cups to convert to grams.",
      "label_i18n": {
        "en": "Cup Amount",
        "tr": "Cup Amount",
        "de": "Cup Amount",
        "fr": "Cup Amount",
        "es": "Cup Amount",
        "ar": "Cup Amount"
      }
    },
    {
      "id": "cupVolume",
      "label": "Cup Volume",
      "type": "number",
      "unit": "mL",
      "default": 236.588,
      "businessContext": "Volume of one cup in milliliters. Standard US cup is 236.588 mL.",
      "label_i18n": {
        "en": "Cup Volume",
        "tr": "Cup Volume",
        "de": "Cup Volume",
        "fr": "Cup Volume",
        "es": "Cup Volume",
        "ar": "Cup Volume"
      }
    },
    {
      "id": "density",
      "label": "Density",
      "type": "number",
      "unit": "g/mL",
      "default": 1,
      "businessContext": "Density of the ingredient in grams per milliliter at 20°C. Water = 1 g/mL.",
      "label_i18n": {
        "en": "Density",
        "tr": "Density",
        "de": "Density",
        "fr": "Density",
        "es": "Density",
        "ar": "Density"
      }
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature of the ingredient for density correction. Default is 20°C.",
      "label_i18n": {
        "en": "Temperature",
        "tr": "Temperature",
        "de": "Temperature",
        "fr": "Temperature",
        "es": "Temperature",
        "ar": "Temperature"
      }
    },
    {
      "id": "densityCorrectionFactor",
      "label": "Temp. Correction Factor",
      "type": "number",
      "unit": "1/°C",
      "default": 0,
      "businessContext": "Linear temperature coefficient of density. Density(T) = density(20°C) × (1 + coeff × (T−20)). Usually small; set to 0 if no correction needed.",
      "label_i18n": {
        "en": "Temp. Correction Factor",
        "tr": "Temp. Correction Factor",
        "de": "Temp. Correction Factor",
        "fr": "Temp. Correction Factor",
        "es": "Temp. Correction Factor",
        "ar": "Temp. Correction Factor"
      }
    }
  ],
  "formulas": {
    "correctedDensity": "density * (1 + densityCorrectionFactor * (temperature - 20))",
    "volumeInML": "cups * cupVolume",
    "massInGrams": "volumeInML * correctedDensity"
  },
  "outputs": {
    "primary": "massInGrams",
    "breakdown": [
      "volumeInML",
      "correctedDensity"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "massInGrams"
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",

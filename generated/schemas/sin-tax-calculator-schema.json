        "es": "Vergisiz Birim Fiyat",
        "ar": "Vergisiz Birim Fiyat"
      }
    },
    {
      "id": "sinTaxRate",
      "label": "ÖTV Oranı",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Özel Tüketim Vergisi oranı",
      "label_i18n": {
        "en": "ÖTV Oranı",
        "tr": "ÖTV Oranı",
        "de": "ÖTV Oranı",
        "fr": "ÖTV Oranı",
        "es": "ÖTV Oranı",
        "ar": "ÖTV Oranı"
      }
    },
    {
      "id": "vatRate",
      "label": "KDV Oranı",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Katma Değer Vergisi oranı",
      "label_i18n": {
        "en": "KDV Oranı",
        "tr": "KDV Oranı",
        "de": "KDV Oranı",
        "fr": "KDV Oranı",
        "es": "KDV Oranı",
        "ar": "KDV Oranı"
      }
    },
    {
      "id": "quantity",
      "label": "Miktar",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Ürün miktarı",
      "label_i18n": {
        "en": "Miktar",
        "tr": "Miktar",
        "de": "Miktar",
        "fr": "Miktar",
        "es": "Miktar",
        "ar": "Miktar"
      }
    }
  ],
  "formulas": {
    "totalPrice": "quantity * basePrice * (1 + sinTaxRate / 100) * (1 + vatRate / 100)",
    "sinTaxAmount": "quantity * basePrice * sinTaxRate / 100",
    "vatAmount": "quantity * basePrice * (1 + sinTaxRate / 100) * vatRate / 100",
    "totalBeforeVat": "quantity * basePrice * (1 + sinTaxRate / 100)"
  },
  "outputs": {
    "primary": "totalPrice",
    "breakdown": [
      "sinTaxAmount",
      "vatAmount",
      "totalBeforeVat"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

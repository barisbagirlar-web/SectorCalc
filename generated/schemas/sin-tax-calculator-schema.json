{
  "toolName": "sin-tax-calculator",
  "inputs": [
    {
      "id": "basePrice",
      "label": "Vergisiz Birim Fiyat",
      "type": "number",
      "unit": "TRY",
      "default": 100,
      "businessContext": "Unit price of product before tax",
      "label_i18n": {
        "en": "Unit Price Without Tax",
        "tr": "Vergisiz Birim Fiyat",
        "de": "Preis ohne Steuern",
        "fr": "Prix unitaire hors taxe",
        "es": "Precio unitario sin impuestos",
        "ar": "سعر الوحدة بدون ضريبة"
      },
      "businessContext_i18n": {
        "en": "Unit price before tax (USD)",
        "tr": "Ürünün vergi öncesi birim fiyatı",
        "de": "Stückpreis des Produkts vor Steuern",
        "fr": "Prix unitaire du produit avant taxe",
        "es": "Precio unitario del producto antes de impuestos",
        "ar": "سعر الوحدة قبل الضريبة"
      }
    },
    {
      "id": "sinTaxRate",
      "label": "ÖTV Oranı",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Özel Tüketim Vergisi oranı",
      "label_i18n": {
        "en": "Special Consumption Tax rate (%)",
        "tr": "ÖTV Oranı",
        "de": "Verbrauchsteuersatz",
        "fr": "Taux de TVA",
        "es": "Tasa de impuesto especial al consumo",
        "ar": "نسبة ضريبة الاستهلاك الخاصة"
      },
      "businessContext_i18n": {
        "en": "Special Consumption Tax rate (%)",
        "tr": "Özel Tüketim Vergisi oranı",
        "de": "Satz der Sonderverbrauchsteuer",
        "fr": "Taux de taxe sur la consommation",
        "es": "Tasa del impuesto especial al consumo",
        "ar": "نسبة ضريبة الاستهلاك الخاصة"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Value Added Tax rate",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "Mehrwertsteuersatz",
        "fr": "Taux de TVA",
        "es": "Tasa de IVA",
        "ar": "نسبة ضريبة القيمة المضافة"
      },
      "businessContext_i18n": {
        "en": "Value Added Tax rate",
        "tr": "Katma Değer Vergisi oranı",
        "de": "Mehrwertsteuersatz",
        "fr": "Taux de TVA",
        "es": "Tasa del Impuesto al Valor Agregado",
        "ar": "نسبة ضريبة القيمة المضافة"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Product quantity",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Miktar",
        "de": "Menge",
        "fr": "Quantité",
        "es": "Cantidad",
        "ar": "الكمية"
      },
      "businessContext_i18n": {
        "en": "Product quantity",
        "tr": "Ürün miktarı",
        "de": "Produktmenge",
        "fr": "Quantité de produit",
        "es": "Cantidad de producto",
        "ar": "كمية المنتج"
      }
    }
  ],
  "formulas": {
    "totalPrice": "quantity * basePrice * (1 + sinTaxRate / 100) * (1 + vatRate / 100)",
    "sinTaxAmount": "quantity * basePrice * sinTaxRate / 100",
    "vatAmount": "quantity * basePrice * (1 + sinTaxRate / 100) * vatRate / 100",
    "totalBeforeVat": "quantity * basePrice * (1 + sinTaxRate / 100)"
  },
  "outputs": {
    "primary": "totalPrice",
    "breakdown": [
      "sinTaxAmount",
      "vatAmount",
      "totalBeforeVat"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalBeforeVat",
    "unit": "TRY"
  },
  "category": "Finans & Yatırım",

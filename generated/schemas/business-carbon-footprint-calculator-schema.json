      "label_i18n": {
        "en": "Business Air Travel",
        "tr": "Business Air Travel",
        "de": "Business Air Travel",
        "fr": "Business Air Travel",
        "es": "Business Air Travel",
        "ar": "Business Air Travel"
      }
    },
    {
      "id": "wasteGenerated",
      "label": "Waste Generated",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Total waste sent to landfill annually",
      "label_i18n": {
        "en": "Waste Generated",
        "tr": "Waste Generated",
        "de": "Waste Generated",
        "fr": "Waste Generated",
        "es": "Waste Generated",
        "ar": "Waste Generated"
      }
    }
  ],
  "formulas": {
    "scope1Emissions": "naturalGasUsage * 1.9 + vehicleFuel * 2.5",
    "scope2Emissions": "electricityUsage * 0.5",
    "scope3Emissions": "businessFlights * 0.15 + wasteGenerated * 1.0",
    "totalCarbonFootprint": "scope1Emissions + scope2Emissions + scope3Emissions"
  },
  "outputs": {
    "primary": "totalCarbonFootprint",
    "breakdown": [
      "scope1Emissions",
      "scope2Emissions",
      "scope3Emissions"
    ],

  "formulas": {
    "scope1Emissions": "naturalGasUsage * 1.9 + vehicleFuel * 2.5",
    "scope2Emissions": "electricityUsage * 0.5",
    "scope3Emissions": "businessFlights * 0.15 + wasteGenerated * 1.0",
    "totalCarbonFootprint": "scope1Emissions + scope2Emissions + scope3Emissions"
  },
  "outputs": {
    "primary": "totalCarbonFootprint",
    "breakdown": [
      "scope1Emissions",
      "scope2Emissions",
      "scope3Emissions"
    ],

    {
      "id": "wasteGenerated",
      "label": "Waste Generated",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Total waste sent to landfill annually",
      "label_i18n": {
        "en": "Waste Generated",
        "tr": "Oluşan Atık",
        "de": "Abfallaufkommen",
        "fr": "Waste Generated",
        "es": "Waste Generated",
        "ar": "Waste Generated"
      },

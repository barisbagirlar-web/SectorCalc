  "formulas": {
    "normalized_product": "initialInvestment * periodicCashFlow * periods * (discountRate / 100)",
    "result": "initialInvestment * periodicCashFlow * periods * (discountRate / 100) * (salvageValue)",
    "adjustment_factor": "salvageValue"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "normalized_product",
      "adjustment_factor"
    ],
    "hiddenLossDrivers": [
      "Model uses normalized input chain — validate units",
      "Assumption-heavy without site benchmark"
    ],

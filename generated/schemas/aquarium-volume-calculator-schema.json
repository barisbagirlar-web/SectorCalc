      }
    },
    {
      "id": "width",
      "label": "Tank Width (cm)",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "External width of the aquarium in centimeters.",
      "label_i18n": {
        "en": "Tank Width (cm)",
        "tr": "Tank Width (cm)",
        "de": "Tank Width (cm)",
        "fr": "Tank Width (cm)",
        "es": "Tank Width (cm)",
        "ar": "Tank Width (cm)"
      }
    },
    {
      "id": "height",
      "label": "Tank Height (cm)",
      "type": "number",
      "unit": "cm",
      "default": 36,
      "businessContext": "External height of the aquarium in centimeters.",
      "label_i18n": {
        "en": "Tank Height (cm)",
        "tr": "Tank Height (cm)",
        "de": "Tank Height (cm)",
        "fr": "Tank Height (cm)",
        "es": "Tank Height (cm)",
        "ar": "Tank Height (cm)"
      }
    },
    {
      "id": "waterFillDepth",
      "label": "Water Fill Depth (cm)",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "Depth of water from the inside bottom glass to the water surface, in centimeters.",
      "label_i18n": {
        "en": "Water Fill Depth (cm)",
        "tr": "Water Fill Depth (cm)",
        "de": "Water Fill Depth (cm)",
        "fr": "Water Fill Depth (cm)",
        "es": "Water Fill Depth (cm)",
        "ar": "Water Fill Depth (cm)"
      }
    },
    {
      "id": "substrateDepth",
      "label": "Substrate Depth (cm)",
      "type": "number",
      "unit": "cm",
      "default": 5,
      "businessContext": "Average depth of substrate (sand, gravel) inside the aquarium, in centimeters.",
      "label_i18n": {
        "en": "Substrate Depth (cm)",
        "tr": "Substrate Depth (cm)",
        "de": "Substrate Depth (cm)",
        "fr": "Substrate Depth (cm)",
        "es": "Substrate Depth (cm)",
        "ar": "Substrate Depth (cm)"
      }
    },
    {
      "id": "glassThickness",
      "label": "Glass Thickness (mm)",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Thickness of the glass panels used for the aquarium, in millimeters.",
      "label_i18n": {
        "en": "Glass Thickness (mm)",
        "tr": "Glass Thickness (mm)",
        "de": "Glass Thickness (mm)",
        "fr": "Glass Thickness (mm)",
        "es": "Glass Thickness (mm)",
        "ar": "Glass Thickness (mm)"
      }
    }
  ],
  "formulas": {
    "interiorLength": "length - 2 * (glassThickness / 10)",
    "interiorWidth": "width - 2 * (glassThickness / 10)",
    "effectiveWaterDepth": "waterFillDepth - substrateDepth",
    "volume_cm3": "interiorLength * interiorWidth * effectiveWaterDepth",
    "waterVolume_L": "volume_cm3 / 1000",
    "waterVolume_gal": "waterVolume_L * 0.264172",
    "____volume_cm3_toFixed_0______cm___": "' + volume_cm3.toFixed(0) + ' cm³)'",
    "waterVolume_gal_toFixed_2______US_gallon": "waterVolume_gal.toFixed(2) + ' US gallons'",
    "result": "waterVolume_L.toFixed(2) + ' L'"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "interiorLength.toFixed(1) + ' × ' + interiorWidth.toFixed(1) + ' × ' + effectiveWaterDepth.toFixed(1) + ' cm (internal volume: ' + volume_cm3.toFixed(0) + ' cm³)'",
      "waterVolume_gal.toFixed(2) + ' US gallons'"
    ]
  },

        "en": "Waitstaff, service equipment",
        "tr": "Garson, servis ekipmanı",
        "de": "Kellner, Serviceausrüstung",
        "fr": "Serveur, équipement de service",
        "es": "Mesero, equipo de servicio",
        "ar": "النادل، معدات الخدمة"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Preparation loss",
      "label_i18n": {
        "en": "Waste rate (%)",
        "tr": "Fire Oranı (%)",
        "de": "Ausschussrate (%)",
        "fr": "Taux de perte (%)",
        "es": "Tasa de desperdicio (%)",
        "ar": "نسبة الهدر (%)"
      },
      "businessContext_i18n": {
        "en": "Preparation loss",
        "tr": "Hazırlık kaybı",
        "de": "Zubereitungsverlust",
        "fr": "Perte de préparation",
        "es": "Pérdida de preparación",
        "ar": "فقدان التحضير"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Tax rate",
      "label_i18n": {
        "en": "VAT rate (%)",
        "tr": "KDV Oranı (%)",
        "de": "Mehrwertsteuersatz (%)",
        "fr": "Taux de TVA (%)",
        "es": "Tasa de IVA (%)",
        "ar": "نسبة ضريبة القيمة المضافة (%)"
      },
      "businessContext_i18n": {
        "en": "Tax rate",
        "tr": "Vergi oranı",
        "de": "Steuersatz",
        "fr": "Taux d'imposition",
        "es": "Tasa de impuesto",
        "ar": "نسبة الضريبة"
      }
    }
  ],
  "formulas": {
    "totalRawCost": "numberOfGuests * costPerMeal * numberOfCourses",
    "wasteCost": "totalRawCost * (wasteFactor / 100)",
    "serviceCost": "totalRawCost * (serviceChargePercent / 100)",
    "taxableAmount": "totalRawCost + wasteCost + serviceCost",
    "vatAmount": "taxableAmount * (vatRate / 100)",
    "totalCost": "taxableAmount + vatAmount",
    "costPerGuest": "totalCost / numberOfGuests"
  },
  "outputs": {
    "primary": "totalRawCost",
    "breakdown": [
      {
        "id": "costPerGuest",
        "label": "Misafir Başına Maliyet",
        "unit": "TRY"
      },
      {
        "id": "totalRawCost",
        "label": "Ham Maliyet",
        "unit": "TRY"
      },
      {
        "id": "vatAmount",
        "label": "KDV Tutarı",
        "unit": "TRY"
      },
      {
        "id": "serviceCost",
        "label": "Servis Ücreti",
        "unit": "TRY"
      }
    ],

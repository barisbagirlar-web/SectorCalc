      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 60,
      "businessContext": "Resting heart rate in beats per minute",
      "label_i18n": {
        "en": "Resting Heart Rate",
        "tr": "Resting Heart Rate",
        "de": "Resting Heart Rate",
        "fr": "Resting Heart Rate",
        "es": "Resting Heart Rate",
        "ar": "Resting Heart Rate"
      }
    },
    {
      "id": "lowerIntensity",
      "label": "Lower Zone Intensity",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Lower bound of target heart rate zone as percentage of heart rate reserve",
      "label_i18n": {
        "en": "Lower Zone Intensity",
        "tr": "Lower Zone Intensity",
        "de": "Lower Zone Intensity",
        "fr": "Lower Zone Intensity",
        "es": "Lower Zone Intensity",
        "ar": "Lower Zone Intensity"
      }
    },
    {
      "id": "upperIntensity",
      "label": "Upper Zone Intensity",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Upper bound of target heart rate zone as percentage of heart rate reserve",
      "label_i18n": {
        "en": "Upper Zone Intensity",
        "tr": "Upper Zone Intensity",
        "de": "Upper Zone Intensity",
        "fr": "Upper Zone Intensity",
        "es": "Upper Zone Intensity",
        "ar": "Upper Zone Intensity"
      }
    }
  ],
  "formulas": {
    "maxHR": "220 - age",
    "heartRateReserve": "maxHR - restingHeartRate",
    "lowerTarget": "restingHeartRate + (heartRateReserve * (lowerIntensity / 100))",
    "upperTarget": "restingHeartRate + (heartRateReserve * (upperIntensity / 100))",
    "midTarget": "(lowerTarget + upperTarget) / 2"
  },
  "outputs": {
    "primary": "midTarget",
    "breakdown": [
      "lowerTarget",
      "upperTarget"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "midTarget"
  },

  ],
  "formulas": {
    "weight_kg_total": "unit_system === 0 ? weight_kg : (weight_stones * 6.35029 + weight_pounds * 0.453592)",
    "height_m": "unit_system === 0 ? (height_cm / 100) : (height_feet * 0.3048 + height_inches * 0.0254)",
    "corpulence_index": "weight_kg_total / Math.pow(height_m, 3)"
  },
  "outputs": {
    "primary": "corpulence_index",
    "breakdown": [
      "weight_kg_total",
      "height_m"
    ]
  },

        "es": "Birim Yük Kapasitesi",
        "ar": "Birim Yük Kapasitesi"
      }
    },
    {
      "id": "volumePerUnit",
      "label": "Birim Yük Hacmi",
      "type": "number",
      "unit": "m³",
      "default": 1.5,
      "businessContext": "Bir birim yükün kapladığı hacim",
      "label_i18n": {
        "en": "Birim Yük Hacmi",
        "tr": "Birim Yük Hacmi",
        "de": "Birim Yük Hacmi",
        "fr": "Birim Yük Hacmi",
        "es": "Birim Yük Hacmi",
        "ar": "Birim Yük Hacmi"
      }
    }
  ],
  "formulas": {
    "volume": "(length * width * height) / 1000000",
    "volumeUnits": "volume / volumePerUnit",
    "weightUnits": "weight / unitLoadCapacity",
    "totalUnits": "Math.ceil(Math.max(volumeUnits, weightUnits))",
    "__volume__m_": "${volume} m³",
    "__volumeUnits_": "${volumeUnits}",
    "__weightUnits_": "${weightUnits}"
  },
  "outputs": {
    "primary": "volume",
    "breakdown": [
      "Toplam Hacim: ${volume} m³",
      "Hacim Bazlı Birim Gereksinimi: ${volumeUnits}",
      "Ağırlık Bazlı Birim Gereksinimi: ${weightUnits}"
    ]
  },

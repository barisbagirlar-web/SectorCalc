      "id": "concrete_strength",
      "label": "Concrete Strength",
      "type": "number",
      "unit": "MPa",
      "default": 25,
      "businessContext": "Compressive strength of concrete",
      "label_i18n": {
        "en": "Concrete Strength",
        "tr": "Concrete Strength",
        "de": "Concrete Strength",
        "fr": "Concrete Strength",
        "es": "Concrete Strength",
        "ar": "Concrete Strength"
      }
    },
    {
      "id": "steel_ratio",
      "label": "Steel Reinforcement Ratio",
      "type": "number",
      "unit": "%",
      "default": 1.5,
      "businessContext": "Percentage of steel reinforcement by volume",
      "label_i18n": {
        "en": "Steel Reinforcement Ratio",
        "tr": "Steel Reinforcement Ratio",
        "de": "Steel Reinforcement Ratio",
        "fr": "Steel Reinforcement Ratio",
        "es": "Steel Reinforcement Ratio",
        "ar": "Steel Reinforcement Ratio"
      }
    },
    {
      "id": "soil_pressure",
      "label": "Soil Lateral Pressure",
      "type": "number",
      "unit": "kN/m²",
      "default": 30,
      "businessContext": "Lateral pressure from soil",
      "label_i18n": {
        "en": "Soil Lateral Pressure",
        "tr": "Soil Lateral Pressure",
        "de": "Soil Lateral Pressure",
        "fr": "Soil Lateral Pressure",
        "es": "Soil Lateral Pressure",
        "ar": "Soil Lateral Pressure"
      }
    }
  ],
  "formulas": {
    "wall_volume": "wall_length * wall_height * wall_thickness",
    "concrete_volume": "wall_volume * (1 - steel_ratio / 100)",
    "steel_volume": "wall_volume * (steel_ratio / 100)",
    "steel_weight": "steel_volume * 7850",
    "moment_capacity": "concrete_strength * wall_thickness * wall_thickness / 6",
    "lateral_load": "soil_pressure * wall_height * wall_length / 2",
    "safety_factor_moment": "moment_capacity / (lateral_load * wall_height / 3)"
  },
  "outputs": {
    "primary": "wall_volume",
    "breakdown": [
      "concrete_volume",
      "steel_weight",
      "moment_capacity",
      "shear_capacity",
      "lateral_load",
      "safety_factor_moment",
      "safety_factor_shear"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "safety_factor_shear"
  },

{
  "toolName": "retaining-wall-drainage-calculator",
  "inputs": [
    {
      "id": "wallHeight",
      "label": "Wall Height",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "Height of retaining wall from base to top.",
      "label_i18n": {
        "en": "Wall Height",
        "tr": "Wall Height",
        "de": "Wall Height",
        "fr": "Wall Height",
        "es": "Wall Height",
        "ar": "Wall Height"
      }
    },
    {
      "id": "wallLength",
      "label": "Wall Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Length of wall section being drained.",
      "label_i18n": {
        "en": "Wall Length",
        "tr": "Wall Length",
        "de": "Wall Length",
        "fr": "Wall Length",
        "es": "Wall Length",
        "ar": "Wall Length"
      }
    },
    {
      "id": "soilPermeability",
      "label": "Soil Permeability (k)",
      "type": "number",
      "unit": "m/s",
      "default": 0.00001,
      "businessContext": "Hydraulic conductivity of backfill soil. Fine sand ~1e-5, gravel ~1e-3.",
      "label_i18n": {
        "en": "Soil Permeability (k)",
        "tr": "Soil Permeability (k)",
        "de": "Soil Permeability (k)",
        "fr": "Soil Permeability (k)",
        "es": "Soil Permeability (k)",
        "ar": "Soil Permeability (k)"
      }
    },
    {
      "id": "pipeDiameter",
      "label": "Drain Pipe Diameter",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Inner diameter of drainage pipe.",
      "label_i18n": {
        "en": "Drain Pipe Diameter",
        "tr": "Drain Pipe Diameter",
        "de": "Drain Pipe Diameter",
        "fr": "Drain Pipe Diameter",
        "es": "Drain Pipe Diameter",
        "ar": "Drain Pipe Diameter"
      }
    },
    {
      "id": "pipeSlope",
      "label": "Pipe Slope",
      "type": "number",
      "unit": "%",
      "default": 1,
      "businessContext": "Slope of drain pipe as percentage (e.g., 1 = 1%).",
      "label_i18n": {
        "en": "Pipe Slope",
        "tr": "Pipe Slope",
        "de": "Pipe Slope",
        "fr": "Pipe Slope",
        "es": "Pipe Slope",
        "ar": "Pipe Slope"
      }
    },
    {
      "id": "manningN",
      "label": "Manning's n",
      "type": "number",
      "unit": "unit",
      "default": 0.013,
      "businessContext": "Roughness coefficient for pipe material (e.g., concrete=0.013, corrugated metal=0.024).",
      "label_i18n": {
        "en": "Manning's n",
        "tr": "Manning's n",
        "de": "Manning's n",
        "fr": "Manning's n",
        "es": "Manning's n",
        "ar": "Manning's n"
      }
    }
  ],
  "formulas": {
    "inflowRate": "soilPermeability * wallHeight * wallLength",
    "pipeDiameterM": "pipeDiameter / 1000",
    "pipeSlopeDec": "pipeSlope / 100",
    "pipeArea": "Math.PI * Math.pow(pipeDiameterM/2, 2)",
    "hydraulicRadius": "pipeDiameterM / 4",
    "pipeCapacity": "(1 / manningN) * pipeArea * Math.pow(hydraulicRadius, 2/3) * Math.pow(pipeSlopeDec, 0.5)",
    "safetyFactor": "pipeCapacity / inflowRate"
  },
  "outputs": {
    "primary": "safetyFactor",
    "breakdown": [
      "inflowRate",
      "pipeCapacity"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Metal & Sac İşleme",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "process-chemical",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",
  "categoryId": "engineering"
}

{
  "toolName": "gross-margin-calculator",
  "inputs": [
    {
      "id": "sellingPricePerUnit",
      "label": "Selling Price per Unit",
      "type": "number",
      "unit": "currency/unit",
      "default": 100,
      "businessContext": "The price at which each unit is sold to customers.",
      "label_i18n": {
        "en": "Selling Price per Unit",
        "tr": "Selling Price per Unit",
        "de": "Selling Price per Unit",
        "fr": "Selling Price per Unit",
        "es": "Selling Price per Unit",
        "ar": "Selling Price per Unit"
      }
    },
    {
      "id": "costPerUnit",
      "label": "Cost per Unit",
      "type": "number",
      "unit": "currency/unit",
      "default": 70,
      "businessContext": "The direct material or purchase cost incurred for each unit.",
      "label_i18n": {
        "en": "Cost per Unit",
        "tr": "Cost per Unit",
        "de": "Cost per Unit",
        "fr": "Cost per Unit",
        "es": "Cost per Unit",
        "ar": "Cost per Unit"
      }
    },
    {
      "id": "unitsSold",
      "label": "Units Sold",
      "type": "number",
      "unit": "units",
      "default": 1000,
      "businessContext": "The total quantity of units sold in the period under consideration.",
      "label_i18n": {
        "en": "Units Sold",
        "tr": "Units Sold",
        "de": "Units Sold",
        "fr": "Units Sold",
        "es": "Units Sold",
        "ar": "Units Sold"
      }
    },
    {
      "id": "additionalVariableCostPerUnit",
      "label": "Additional Variable Cost per Unit",
      "type": "number",
      "unit": "currency/unit",
      "default": 5,
      "businessContext": "Any other variable costs per unit that are directly attributable to the product (e.g., shipping, packaging) and form part of cost of goods sold.",
      "label_i18n": {
        "en": "Additional Variable Cost per Unit",
        "tr": "Additional Variable Cost per Unit",
        "de": "Additional Variable Cost per Unit",
        "fr": "Additional Variable Cost per Unit",
        "es": "Additional Variable Cost per Unit",
        "ar": "Additional Variable Cost per Unit"
      }
    },
    {
      "id": "discountPercentage",
      "label": "Discount Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "The average discount or price reduction given on the selling price, expressed as a percentage.",
      "label_i18n": {
        "en": "Discount Percentage",
        "tr": "Discount Percentage",
        "de": "Discount Percentage",
        "fr": "Discount Percentage",
        "es": "Discount Percentage",
        "ar": "Discount Percentage"
      }
    }
  ],
  "formulas": {
    "totalRevenue": "sellingPricePerUnit * unitsSold * (1 - discountPercentage / 100)",
    "totalCOGS": "(costPerUnit + additionalVariableCostPerUnit) * unitsSold",
    "grossMarginAmount": "totalRevenue - totalCOGS",
    "grossMarginPercentage": "(grossMarginAmount / totalRevenue) * 100"
  },
  "outputs": {
    "primary": "grossMarginPercentage",
    "breakdown": [
      "totalRevenue",
      "totalCOGS",
      "grossMarginAmount",
      "grossMarginPercentage"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "grossMarginPercentage",
    "unit": "%",
    "breakdownUnits": {
      "grossMarginAmount": "%",
      "grossMarginPercentage": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

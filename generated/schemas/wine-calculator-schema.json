    {
      "id": "bottleVolume",
      "label": "Bottle Volume (L)",
      "type": "number",
      "unit": "L",
      "default": 0.75,
      "businessContext": "Standard bottle volume",
      "label_i18n": {
        "en": "Bottle volume (L)",
        "tr": "Şişe Hacmi (L)",
        "de": "Flaschenvolumen (L)",
        "fr": "Volume de la bouteille (L)",
        "es": "Volumen de Botella (L)",
        "ar": "حجم الزجاجة (لتر)"
      },
      "businessContext_i18n": {
        "en": "Standard bottle volume",
        "tr": "Standart şişe hacmi",
        "de": "Standard-Flaschenvolumen",

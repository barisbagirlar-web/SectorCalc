  "formulas": {
    "TotalFloat": "LateStart - EarlyStart",
    "CriticalDelay": "MAX(0, Actual - Planned - TotalFloat)",
    "ExcusableDelay": "ForceMajeure + OwnerCaused",
    "NonExcusable": "CriticalDelay - Excusable",
    "LiquidatedDamages": "NonExcusable * DailyPenalty",
    "AccelerationCost": "CrashingCost * DaysAccelerated",
    "NetPenalty": "LiquidatedDamages - AccelerationCost",
    "EOT_Claim": "Excusable * (1 - EffFactor)"
  },

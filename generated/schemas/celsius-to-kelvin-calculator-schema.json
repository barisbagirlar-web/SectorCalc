{
  "toolName": "celsius-to-kelvin-calculator",
  "inputs": [
    {
      "id": "celsiusTemp",
      "label": "Temperature in Celsius",
      "type": "number",
      "unit": "°C",
      "default": 0,
      "businessContext": "Measured temperature value from sensor or process",
      "label_i18n": {
        "en": "Temperature in Celsius",
        "tr": "Temperature in Celsius",
        "de": "Temperature in Celsius",
        "fr": "Temperature in Celsius",
        "es": "Temperature in Celsius",
        "ar": "Temperature in Celsius"
      }
    },
    {
      "id": "offset",
      "label": "Calibration Offset",
      "type": "number",
      "unit": "°C",
      "default": 0,
      "businessContext": "Instrument calibration offset to be added before conversion",
      "label_i18n": {
        "en": "Calibration Offset",
        "tr": "Calibration Offset",
        "de": "Calibration Offset",
        "fr": "Calibration Offset",
        "es": "Calibration Offset",
        "ar": "Calibration Offset"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of decimal places for output precision",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "uncertainty",
      "label": "Measurement Uncertainty",
      "type": "number",
      "unit": "°C",
      "default": 0.1,
      "businessContext": "Uncertainty of the temperature measurement",
      "label_i18n": {
        "en": "Measurement Uncertainty",
        "tr": "Measurement Uncertainty",
        "de": "Measurement Uncertainty",
        "fr": "Measurement Uncertainty",
        "es": "Measurement Uncertainty",
        "ar": "Measurement Uncertainty"
      }
    }
  ],
  "formulas": {
    "adjustedCelsius": "celsiusTemp + offset",
    "kelvinExact": "adjustedCelsius + 273.15",
    "roundedKelvin": "Math.round(kelvinExact * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "lowerBoundK": "kelvinExact - uncertainty",
    "upperBoundK": "kelvinExact + uncertainty"
  },
  "outputs": {
    "primary": "roundedKelvin",
    "breakdown": [
      "adjustedCelsius",
      "kelvinExact",
      "roundedKelvin",
      "lowerBoundK",
      "upperBoundK"
    ]
  },

  "formulas": {
    "Cost_Ded": "Mach_Ded + Setup_Ded * Changeovers + Inv_High",
    "Cost_Flex": "Mach_FMS + Tool_FMS + Prog + Maint",
    "FlexVal": "(TTM_Red * RevGain) + (CustPrem * Vol)",
    "InvSav": "(WIP_Ded - WIP_Flex) * CarryCost",
    "ScrapRed": "(Scrap_Ded - Scrap_Flex) * Vol * UnitCost",
    "ROI": "(Cost_Ded - Cost_Flex + FlexVal + InvSav + ScrapRed) / Capex"
  },

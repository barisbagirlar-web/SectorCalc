{
  "toolName": "soil-ph-calculator",
  "inputs": [
    {
      "id": "reading_mv",
      "label": "Sample mV Reading",
      "type": "number",
      "unit": "mV",
      "default": 0,
      "businessContext": "Millivolt reading of soil-water suspension from pH electrode",
      "label_i18n": {
        "en": "Sample mV Reading",
        "tr": "Sample mV Reading",
        "de": "Sample mV Reading",
        "fr": "Sample mV Reading",
        "es": "Sample mV Reading",
        "ar": "Sample mV Reading"
      }
    },
    {
      "id": "reference_mv",
      "label": "Reference mV Reading",
      "type": "number",
      "unit": "mV",
      "default": 0,
      "businessContext": "Millivolt reading of known pH buffer solution",
      "label_i18n": {
        "en": "Reference mV Reading",
        "tr": "Reference mV Reading",
        "de": "Reference mV Reading",
        "fr": "Reference mV Reading",
        "es": "Reference mV Reading",
        "ar": "Reference mV Reading"
      }
    },
    {
      "id": "buffer_ph",
      "label": "Buffer pH",
      "type": "number",
      "unit": "pH",
      "default": 7,
      "businessContext": "pH value of the reference buffer solution",
      "label_i18n": {
        "en": "Buffer pH",
        "tr": "Buffer pH",
        "de": "Buffer pH",
        "fr": "Buffer pH",
        "es": "Buffer pH",
        "ar": "Buffer pH"
      }
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Temperature of the samples and buffers (assumed equal)",
      "label_i18n": {
        "en": "Temperature",
        "tr": "Temperature",
        "de": "Temperature",
        "fr": "Temperature",
        "es": "Temperature",
        "ar": "Temperature"
      }
    },
    {
      "id": "slope_percent",
      "label": "Slope %",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Electrode slope percentage relative to theoretical Nernstian slope (100% = 59.16 mV/pH at 25°C)",
      "label_i18n": {
        "en": "Slope %",
        "tr": "Slope %",
        "de": "Slope %",
        "fr": "Slope %",
        "es": "Slope %",
        "ar": "Slope %"
      }
    }
  ],
  "formulas": {
    "theoretical_slope": "59.16 * ((temperature + 273.15) / 298.15) * (slope_percent / 100)",
    "mv_offset": "reference_mv - theoretical_slope * buffer_ph",
    "sample_ph": "(reading_mv - mv_offset) / theoretical_slope"
  },
  "outputs": {
    "primary": "sample_ph",
    "breakdown": [
      "theoretical_slope",
      "mv_offset",
      "sample_ph"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "sample_ph",
    "unit": "A",
    "breakdownUnits": {
      "sample_ph": "A"
    }
  },
  "category": "Sürdürülebilirlik",
  "sector": "Kimya & Proses",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",

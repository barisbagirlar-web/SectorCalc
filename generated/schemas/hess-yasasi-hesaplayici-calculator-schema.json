        "de": "Adım Sayısı",
        "fr": "Adım Sayısı",
        "es": "Adım Sayısı",
        "ar": "Adım Sayısı"
      }
    },
    {
      "id": "step1_dH",
      "label": "1. Adım ΔH",
      "type": "number",
      "unit": "kJ/mol",
      "default": 0,
      "businessContext": "Birinci reaksiyon adımının entalpi değişimi.",
      "label_i18n": {
        "en": "1. Adım ΔH",
        "tr": "1. Adım ΔH",
        "de": "1. Adım ΔH",
        "fr": "1. Adım ΔH",
        "es": "1. Adım ΔH",
        "ar": "1. Adım ΔH"
      }
    },
    {
      "id": "step2_dH",
      "label": "2. Adım ΔH",
      "type": "number",
      "unit": "kJ/mol",
      "default": 0,
      "businessContext": "İkinci reaksiyon adımının entalpi değişimi.",
      "label_i18n": {
        "en": "2. Adım ΔH",
        "tr": "2. Adım ΔH",
        "de": "2. Adım ΔH",
        "fr": "2. Adım ΔH",
        "es": "2. Adım ΔH",
        "ar": "2. Adım ΔH"
      }
    },
    {
      "id": "step3_dH",
      "label": "3. Adım ΔH",
      "type": "number",
      "unit": "kJ/mol",
      "default": 0,
      "businessContext": "Üçüncü reaksiyon adımının entalpi değişimi.",
      "label_i18n": {
        "en": "3. Adım ΔH",
        "tr": "3. Adım ΔH",
        "de": "3. Adım ΔH",
        "fr": "3. Adım ΔH",
        "es": "3. Adım ΔH",
        "ar": "3. Adım ΔH"
      }
    },
    {
      "id": "step4_dH",
      "label": "4. Adım ΔH",
      "type": "number",
      "unit": "kJ/mol",
      "default": 0,
      "businessContext": "Dördüncü reaksiyon adımının entalpi değişimi.",
      "label_i18n": {
        "en": "4. Adım ΔH",
        "tr": "4. Adım ΔH",
        "de": "4. Adım ΔH",
        "fr": "4. Adım ΔH",
        "es": "4. Adım ΔH",
        "ar": "4. Adım ΔH"
      }
    }
  ],
  "formulas": {
    "step1_eff": "step1_dH * (number_of_steps >= 1 ? 1 : 0)",
    "step2_eff": "step2_dH * (number_of_steps >= 2 ? 1 : 0)",
    "step3_eff": "step3_dH * (number_of_steps >= 3 ? 1 : 0)",
    "step4_eff": "step4_dH * (number_of_steps >= 4 ? 1 : 0)",
    "total": "step1_eff + step2_eff + step3_eff + step4_eff",
    "_step1_eff__kJ_mol": "{step1_eff} kJ/mol",
    "_step2_eff__kJ_mol": "{step2_eff} kJ/mol",
    "_step3_eff__kJ_mol": "{step3_eff} kJ/mol",
    "_step4_eff__kJ_mol": "{step4_eff} kJ/mol",
    "result": "Toplam entalpi değişimi (ΔH_toplam): {total} kJ/mol"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "1. adım katkısı: {step1_eff} kJ/mol",
      "2. adım katkısı: {step2_eff} kJ/mol",
      "3. adım katkısı: {step3_eff} kJ/mol",
      "4. adım katkısı: {step4_eff} kJ/mol"
    ]
  },

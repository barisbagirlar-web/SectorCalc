  "formulas": {
    "vdot": "(2 * Math.PI * frekans * genlik) / (sonumleme * malzemeFaktoru * guvenlikFaktoru)",
    "limit": "10",
    "acceptable": "vdot <= limit ? 'Evet' : 'Hayır'",
    "__frekans__Hz__Genlik____genlik__mm__S_n": "${frekans} Hz, Genlik: ${genlik} mm, Sönümleme: ${sonumleme}, Malzeme Faktörü: ${malzemeFaktoru} GPa, Güvenlik: ${guvenlikFaktoru}",
    "__vdot_toFixed_4___mm_s__Limit____limit_": "${vdot.toFixed(4)} mm/s, Limit: ${limit} mm/s, Uygunluk: ${acceptable}",
    "result": "VDOT: ${vdot.toFixed(2)} mm/s"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Frekans: ${frekans} Hz, Genlik: ${genlik} mm, Sönümleme: ${sonumleme}, Malzeme Faktörü: ${malzemeFaktoru} GPa, Güvenlik: ${guvenlikFaktoru}",
      "Hesaplanan VDOT: ${vdot.toFixed(4)} mm/s, Limit: ${limit} mm/s, Uygunluk: ${acceptable}"
    ]
  },

        "de": "Bag Yield",
        "fr": "Bag Yield",
        "es": "Bag Yield",
        "ar": "Bag Yield"
      }
    }
  ],
  "formulas": {
    "groutVolume": "(totalArea * gapDepth * gapWidth * (tileLength + tileWidth)) / (1000 * tileLength * tileWidth)",
    "wasteVolume": "groutVolume * wasteFactor / 100",
    "totalVolume": "groutVolume * (1 + wasteFactor / 100)",
    "exactBags": "totalVolume / bagYield"
  },
  "outputs": {
    "primary": "exactBags",
    "breakdown": [
      "groutVolume",
      "wasteVolume",
      "totalVolume",

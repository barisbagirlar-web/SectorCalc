{
  "toolName": "rest-day-calculator",
  "inputs": [
    {
      "id": "targetPercent",
      "label": "Required Strength",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Percentage of reference strength needed before loading",
      "label_i18n": {
        "en": "Required Strength",
        "tr": "Required Strength",
        "de": "Required Strength",
        "fr": "Required Strength",
        "es": "Required Strength",
        "ar": "Required Strength"
      }
    },
    {
      "id": "refStrength",
      "label": "Reference 28-Day Strength",
      "type": "number",
      "unit": "MPa",
      "default": 30,
      "businessContext": "Concrete strength at 28 days under standard conditions",
      "label_i18n": {
        "en": "Reference 28-Day Strength",
        "tr": "Reference 28-Day Strength",
        "de": "Reference 28-Day Strength",
        "fr": "Reference 28-Day Strength",
        "es": "Reference 28-Day Strength",
        "ar": "Reference 28-Day Strength"
      }
    },
    {
      "id": "tempCoeff",
      "label": "Temperature Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Adjustment for ambient temperature (1.0 at 20°C, increase for colder)",
      "label_i18n": {
        "en": "Temperature Factor",
        "tr": "Temperature Factor",
        "de": "Temperature Factor",
        "fr": "Temperature Factor",
        "es": "Temperature Factor",
        "ar": "Temperature Factor"
      }
    },
    {
      "id": "humidCoeff",
      "label": "Humidity Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Adjustment for relative humidity (1.0 at 60% RH)",
      "label_i18n": {
        "en": "Humidity Factor",
        "tr": "Humidity Factor",
        "de": "Humidity Factor",
        "fr": "Humidity Factor",
        "es": "Humidity Factor",
        "ar": "Humidity Factor"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.2,
      "businessContext": "Multiplier to ensure conservative estimate",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "primary": "safetyFactor * tempCoeff * humidCoeff * 28 * (targetPercent / 100) ** 2",
    "requiredStrength": "refStrength * targetPercent / 100"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "requiredStrength",
      "estimatedStrength"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "estimatedStrength",
    "unit": "%"
  },

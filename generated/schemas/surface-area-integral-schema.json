      }
    },
    {
      "id": "theta_min",
      "label": "Theta min (θ_min)",
      "type": "number",
      "unit": "rad",
      "default": 0,
      "businessContext": "Lower bound of polar angle for sphere",
      "label_i18n": {
        "en": "Theta min (θ_min)",
        "tr": "Theta min (θ_min)",
        "de": "Theta min (θ_min)",
        "fr": "Theta min (θ_min)",
        "es": "Theta min (θ_min)",
        "ar": "Theta min (θ_min)"
      }
    },
    {
      "id": "theta_max",
      "label": "Theta max (θ_max)",
      "type": "number",
      "unit": "rad",
      "default": 3.141592653589793,
      "businessContext": "Upper bound of polar angle for sphere (π)",
      "label_i18n": {
        "en": "Theta max (θ_max)",
        "tr": "Theta max (θ_max)",
        "de": "Theta max (θ_max)",
        "fr": "Theta max (θ_max)",
        "es": "Theta max (θ_max)",
        "ar": "Theta max (θ_max)"
      }
    },
    {
      "id": "phi_min",
      "label": "Phi min (φ_min)",
      "type": "number",
      "unit": "rad",
      "default": 0,
      "businessContext": "Lower bound of azimuthal angle",
      "label_i18n": {
        "en": "Phi min (φ_min)",
        "tr": "Phi min (φ_min)",
        "de": "Phi min (φ_min)",
        "fr": "Phi min (φ_min)",
        "es": "Phi min (φ_min)",
        "ar": "Phi min (φ_min)"
      }
    },
    {
      "id": "phi_max",
      "label": "Phi max (φ_max)",
      "type": "number",
      "unit": "rad",
      "default": 6.283185307179586,
      "businessContext": "Upper bound of azimuthal angle (2π)",
      "label_i18n": {
        "en": "Phi max (φ_max)",
        "tr": "Phi max (φ_max)",
        "de": "Phi max (φ_max)",
        "fr": "Phi max (φ_max)",
        "es": "Phi max (φ_max)",
        "ar": "Phi max (φ_max)"
      }
    }
  ],
  "formulas": {
    "sphereArea": "radius * radius * (theta_max - theta_min) * (phi_max - phi_min)",
    "cylinderLateralArea": "2 * Math.PI * radius * height",
    "totalArea": "shape === 0 ? sphereArea : cylinderLateralArea"
  },
  "outputs": {
    "primary": "totalArea",
    "breakdown": [
      "sphereArea",
      "cylinderLateralArea"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalArea"
  },

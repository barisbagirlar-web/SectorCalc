      "label_i18n": {
        "en": "Height (h)",
        "tr": "Height (h)",
        "de": "Height (h)",
        "fr": "Height (h)",
        "es": "Height (h)",
        "ar": "Height (h)"
      }
    },
    {
      "id": "shape",
      "label": "Shape (0=sphere, 1=cylinder)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 for sphere, 1 for cylinder (lateral surface)",
      "label_i18n": {
        "en": "Shape (0=sphere, 1=cylinder)",
        "tr": "Shape (0=sphere, 1=cylinder)",
        "de": "Shape (0=sphere, 1=cylinder)",

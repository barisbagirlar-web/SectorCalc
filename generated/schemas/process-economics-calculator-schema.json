{
  "toolName": "process-economics-calculator",
  "inputs": [
    {
      "id": "raw_material_cost",
      "label": "Raw Material Cost per Unit",
      "type": "number",
      "unit": "USD",
      "default": 10,
      "businessContext": "Cost of raw materials per unit of product"
    },
    {
      "id": "labor_cost",
      "label": "Labor Cost per Unit",
      "type": "number",
      "unit": "USD",
      "default": 5,
      "businessContext": "Direct labor cost per unit"
    },
    {
      "id": "overhead_cost",
      "label": "Overhead Cost per Unit",
      "type": "number",
      "unit": "USD",
      "default": 3,
      "businessContext": "Manufacturing overhead per unit"
    },
    {
      "id": "selling_price",
      "label": "Selling Price per Unit",
      "type": "number",
      "unit": "USD",
      "default": 25,
      "businessContext": "Price at which product is sold"
    },
    {
      "id": "production_volume",
      "label": "Production Volume",
      "type": "number",
      "unit": "units",
      "default": 1000,
      "businessContext": "Number of units produced per period"
    },
    {
      "id": "defect_rate",
      "label": "Defect Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Percentage of defective units"
    }
  ],
  "formulas": {
    "total_cost_per_unit": "raw_material_cost + labor_cost + overhead_cost",
    "gross_margin_per_unit": "selling_price - total_cost_per_unit",
    "gross_margin_percentage": "(gross_margin_per_unit / selling_price) * 100",
    "total_revenue": "selling_price * production_volume",
    "total_cost": "total_cost_per_unit * production_volume",
    "total_profit": "total_revenue - total_cost",
    "defect_cost": "total_cost_per_unit * production_volume * (defect_rate / 100)",
    "effective_profit": "total_profit - defect_cost"
  },
  "outputs": {
    "primary": "effective_profit",
    "breakdown": [
      "total_revenue",
      "total_cost",
      "total_profit",
      "defect_cost",
      "gross_margin_percentage"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Gıda & İçecek",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "cost"
}

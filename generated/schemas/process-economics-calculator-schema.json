  "formulas": {
    "total_cost_per_unit": "raw_material_cost + labor_cost + overhead_cost",
    "gross_margin_per_unit": "selling_price - total_cost_per_unit",
    "gross_margin_percentage": "(gross_margin_per_unit / selling_price) * 100",
    "total_revenue": "selling_price * production_volume",
    "total_cost": "total_cost_per_unit * production_volume",
    "total_profit": "total_revenue - total_cost",
    "defect_cost": "total_cost_per_unit * production_volume * (defect_rate / 100)",
    "effective_profit": "total_profit - defect_cost"
  },
  "outputs": {
    "primary": "effective_profit",
    "breakdown": [
      "total_revenue",
      "total_cost",
      "total_profit",
      "defect_cost",
      "gross_margin_percentage"
    ],

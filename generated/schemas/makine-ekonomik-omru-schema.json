  "formulas": {
    "EUAC_Capital": "(InitialCost - SalvageValue) * (A/P, i, n) + SalvageValue * i",
    "EUAC_Operating": "OpCost_t * (P/F + i + t)) * (A/P + i + n",
    "TotalEUAC": "EUAC_Capital + EUAC_Operating",
    "EconomicLife": "0.0",
    "Defender_EUAC": "CurrentMarketValue * (A/P, i, n) + OpCost_Defender",
    "Challenger_EUAC": "EUAC_NewMachine",
    "ReplacementDecision": "IF(Defender_EUAC > Challenger_EUAC, \"Replace\", \"Keep\")"
  },
  "outputs": {
    "primary": "ReplacementDecision",

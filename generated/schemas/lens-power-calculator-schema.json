{
  "toolName": "lens-power-calculator",
  "inputs": [
    {
      "id": "n",
      "label": "Refractive Index",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Refractive index of the lens material (dimensionless, typically 1.3-2.0).",
      "label_i18n": {
        "en": "Refractive Index",
        "tr": "Refractive Index",
        "de": "Refractive Index",
        "fr": "Refractive Index",
        "es": "Refractive Index",
        "ar": "Refractive Index"
      }
    },
    {
      "id": "R1",
      "label": "Radius R1",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Radius of curvature of the first lens surface. Positive for convex, negative for concave.",
      "label_i18n": {
        "en": "Radius R1",
        "tr": "Radius R1",
        "de": "Radius R1",
        "fr": "Radius R1",
        "es": "Radius R1",
        "ar": "Radius R1"
      }
    },
    {
      "id": "R2",
      "label": "Radius R2",
      "type": "number",
      "unit": "mm",
      "default": -100,
      "businessContext": "Radius of curvature of the second lens surface. Positive for convex, negative for concave.",
      "label_i18n": {
        "en": "Radius R2",
        "tr": "Radius R2",
        "de": "Radius R2",
        "fr": "Radius R2",
        "es": "Radius R2",
        "ar": "Radius R2"
      }
    },
    {
      "id": "d",
      "label": "Center Thickness",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Center thickness of the lens along the optical axis.",
      "label_i18n": {
        "en": "Center Thickness",
        "tr": "Center Thickness",
        "de": "Center Thickness",
        "fr": "Center Thickness",
        "es": "Center Thickness",
        "ar": "Center Thickness"
      }
    }
  ],
  "formulas": {
    "powerD": "1000 * (n - 1) * (1/R1 - 1/R2 + (n - 1) * d / (n * R1 * R2))",
    "focalLengthMM": "1 / ((n - 1) * (1/R1 - 1/R2 + (n - 1) * d / (n * R1 * R2)))"
  },
  "outputs": {
    "primary": "powerD",
    "breakdown": [
      "focalLengthMM"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "focalLengthMM"
  },

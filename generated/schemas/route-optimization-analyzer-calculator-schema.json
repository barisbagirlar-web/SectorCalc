{
  "slug": "route-optimization-analyzer",
  "premiumRequired": true,
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Multi-scenario comparison",
    "Real-time GPS integration"
  ],
  "inputs": [
    {
      "id": "num_stops",
      "label": "Number of Stops",
      "type": "number",
      "unit": "stops",
      "default": 10,
      "min": 1,
      "max": 200,
      "businessContext": "Total delivery or service stops on the route.",
      "label_i18n": {
        "en": "Number of Stops"
      },
      "businessContext_i18n": {
        "en": "Total delivery or service stops on the route."
      }
    },
    {
      "id": "total_distance",
      "label": "Total Route Distance",
      "type": "number",
      "unit": "km",
      "default": 150,
      "min": 0,
      "max": 5000,
      "businessContext": "Total distance traveled for the route in kilometers.",
      "label_i18n": {
        "en": "Total Route Distance"
      },
      "businessContext_i18n": {
        "en": "Total distance traveled for the route in kilometers."
      }
    },
    {
      "id": "avg_speed",
      "label": "Average Speed",
      "type": "number",
      "unit": "km/h",
      "default": 40,
      "min": 5,
      "max": 120,
      "businessContext": "Average vehicle speed including traffic and stops.",
      "label_i18n": {
        "en": "Average Speed"
      },
      "businessContext_i18n": {
        "en": "Average vehicle speed including traffic and stops."
      }
    },
    {
      "id": "dwell_time_per_stop",
      "label": "Dwell Time per Stop",
      "type": "number",
      "unit": "minutes",
      "default": 10,
      "min": 0,
      "max": 120,
      "businessContext": "Average time spent at each stop for loading/unloading.",
      "label_i18n": {
        "en": "Dwell Time per Stop"
      },
      "businessContext_i18n": {
        "en": "Average time spent at each stop for loading/unloading."
      }
    },
    {
      "id": "fuel_cost_per_km",
      "label": "Fuel Cost per km",
      "type": "number",
      "unit": "currency/km",
      "default": 1.2,
      "min": 0,
      "max": 10,
      "businessContext": "Fuel cost per kilometer driven.",
      "label_i18n": {
        "en": "Fuel Cost per km"
      },
      "businessContext_i18n": {
        "en": "Fuel cost per kilometer driven."
      }
    },
    {
      "id": "driver_hourly_rate",
      "label": "Driver Hourly Rate",
      "type": "number",
      "unit": "currency/hour",
      "default": 25,
      "min": 0,
      "max": 100,
      "businessContext": "Hourly wage cost for the driver.",
      "label_i18n": {
        "en": "Driver Hourly Rate"
      },
      "businessContext_i18n": {
        "en": "Hourly wage cost for the driver."
      }
    },
    {
      "id": "vehicle_type",
      "label": "Vehicle Type",
      "type": "select",
      "unit": "unit",
      "default": "van",
      "min": null,
      "max": null,
      "businessContext": "Type of vehicle used for the route.",
      "options": [
        "van",
        "truck_light",
        "truck_heavy",
        "refrigerated"
      ],
      "label_i18n": {
        "en": "Vehicle Type"
      },
      "businessContext_i18n": {
        "en": "Type of vehicle used for the route."
      }
    },
    {
      "id": "traffic_condition",
      "label": "Traffic Condition",
      "type": "select",
      "unit": "unit",
      "default": "moderate",
      "min": null,
      "max": null,
      "businessContext": "Expected traffic condition along the route.",
      "options": [
        "light",
        "moderate",
        "heavy"
      ],
      "label_i18n": {
        "en": "Traffic Condition"
      },
      "businessContext_i18n": {
        "en": "Expected traffic condition along the route."
      }
    }
  ],
  "validation": {
    "rules": [
      {
        "id": "rule_stops_distance",
        "condition": "num_stops > 0 AND total_distance > 0",
        "message": "Number of stops and total distance must be positive."
      },
      {
        "id": "rule_speed_range",
        "condition": "avg_speed >= 5 AND avg_speed <= 120",
        "message": "Average speed must be between 5 and 120 km/h."
      },
      {
        "id": "rule_dwell_time",
        "condition": "dwell_time_per_stop >= 0 AND dwell_time_per_stop <= 120",
        "message": "Dwell time per stop must be between 0 and 120 minutes."
      },
      {
        "id": "rule_vehicle_traffic",
        "condition": "vehicle_type == 'refrigerated' AND traffic_condition == 'heavy'",
        "message": "Refrigerated vehicles in heavy traffic may require additional fuel surcharge."
      }
    ],
    "thresholds": [
      {
        "id": "threshold_fuel_cost",
        "metric": "fuel_cost_total",
        "operator": ">",
        "value": 500,
        "alert": "Fuel cost exceeds 500 currency units. Consider route consolidation."
      },
      {
        "id": "threshold_time",
        "metric": "total_travel_time_hours",
        "operator": ">",
        "value": 8,
        "alert": "Total travel time exceeds 8 hours. Driver may require rest break."
      },
      {
        "id": "threshold_stops_per_hour",
        "metric": "stops_per_hour",
        "operator": "<",
        "value": 1.5,
        "alert": "Stops per hour below 1.5. Route density is low; consider merging stops."
      }
    ]
  },
  "formulas": {
    "result": "num_stops + total_distance + avg_speed",
    "result_copy": "num_stops + total_distance + avg_speed"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result",
    "unit": "stops"
  },
  "toolName": "route-optimization-analyzer-calculator",
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "procurement-supply-chain",
  "category": "Lojistik & Rota",
  "sector": "Otomotiv & Taşıt",
  "sectorId": "otomotiv",

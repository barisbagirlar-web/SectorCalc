{
  "toolName": "sphere-surface-area-calculator",
  "inputs": [
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "The radius of the sphere in meters",
      "label_i18n": {
        "en": "Radius",
        "tr": "Radius",
        "de": "Radius",
        "fr": "Radius",
        "es": "Radius",
        "ar": "Radius"
      }
    },
    {
      "id": "diameter",
      "label": "Diameter",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "The diameter of the sphere in meters, used if Input Type is 1",
      "label_i18n": {
        "en": "Diameter",
        "tr": "Diameter",
        "de": "Diameter",
        "fr": "Diameter",
        "es": "Diameter",
        "ar": "Diameter"
      }
    },
    {
      "id": "inputType",
      "label": "Input Type",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 = Use Radius, 1 = Use Diameter",
      "label_i18n": {
        "en": "Input Type",
        "tr": "Input Type",
        "de": "Input Type",
        "fr": "Input Type",
        "es": "Input Type",
        "ar": "Input Type"
      }
    },
    {
      "id": "outputUnit",
      "label": "Output Unit",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 = m², 1 = cm², 2 = mm², 3 = ft²",
      "label_i18n": {
        "en": "Output Unit",
        "tr": "Output Unit",
        "de": "Output Unit",
        "fr": "Output Unit",
        "es": "Output Unit",
        "ar": "Output Unit"
      }
    },
    {
      "id": "costPerSquareMeter",
      "label": "Cost per m²",
      "type": "number",
      "unit": "currency/m²",
      "default": 0,
      "businessContext": "Cost of material per square meter for coating or painting",
      "label_i18n": {
        "en": "Cost per m²",
        "tr": "Cost per m²",
        "de": "Cost per m²",
        "fr": "Cost per m²",
        "es": "Cost per m²",
        "ar": "Cost per m²"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage for material waste",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "radiusUsed": "inputType === 0 ? radius : diameter / 2",
    "areaM2": "4 * Math.PI * Math.pow(radiusUsed, 2)",
    "conversionFactor": "outputUnit === 0 ? 1 : outputUnit === 1 ? 10000 : outputUnit === 2 ? 1000000 : outputUnit === 3 ? 10.7639 : 1",
    "convertedArea": "areaM2 * conversionFactor",
    "totalCost": "areaM2 * costPerSquareMeter * (1 + wasteFactor / 100)",
    "_radiusUsed__m": "{radiusUsed} m",
    "_areaM2_": "{areaM2}",
    "_convertedArea_": "{convertedArea}",
    "_totalCost_": "{totalCost}"
  },
  "outputs": {
    "primary": "convertedArea",
    "breakdown": [
      "Effective radius: {radiusUsed} m",
      "Surface area (m²): {areaM2}",
      "Converted area: {convertedArea}",
      "Total cost including waste: {totalCost}"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "cost"
}

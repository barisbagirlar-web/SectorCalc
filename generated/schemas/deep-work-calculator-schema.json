      "businessContext": "Typical length of an uninterrupted deep work session",
      "label_i18n": {
        "en": "Deep Work Block Duration",
        "tr": "Derin Çalışma Blok Süresi",
        "de": "Dauer einer Tiefenarbeitsphase",
        "fr": "Deep Work Block Duration",
        "es": "Deep Work Block Duration",
        "ar": "Deep Work Block Duration"
      },
      "businessContext_i18n": {
        "en": "Typical length of an uninterrupted deep work session",
        "tr": "Kesintisiz derin çalışma oturumunun tipik uzunluğu",
        "de": "Typische Länge einer ununterbrochenen Tiefenarbeitssitzung"
      }
    },
    {
      "id": "shallowWorkPercent",
      "label": "Shallow Work %",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage of daily hours spent on shallow, low-value tasks",
      "label_i18n": {
        "en": "Shallow Work %",
        "tr": "Sığ Çalışma %",
        "de": "Anteil oberflächlicher Arbeit",
        "fr": "Shallow Work %",
        "es": "Shallow Work %",
        "ar": "Shallow Work %"
      },
      "businessContext_i18n": {
        "en": "Percentage of daily hours spent on shallow, low-value tasks",
        "tr": "Günlük saatlerin sığ, düşük değerli görevlere harcanan yüzdesi",
        "de": "Prozentsatz der täglichen Stunden für oberflächliche, geringwertige Aufgaben"
      }
    }
  ],
  "formulas": {
    "totalMinutes": "dailyWorkHours * 60",
    "meetingTimeMinutes": "meetingCount * meetingDuration",
    "interruptionTimeMinutes": "interruptionCount * recoveryTime",
    "shallowTimeMinutes": "(shallowWorkPercent / 100) * totalMinutes",
    "shallowWorkHours": "shallowTimeMinutes / 60",
    "meetingHours": "meetingTimeMinutes / 60",
    "interruptionHours": "interruptionTimeMinutes / 60"
  },
  "outputs": {
    "primary": "interruptionHours",
    "breakdown": [
      "shallowWorkHours",
      "meetingHours",
      "interruptionHours",
      "effectiveDeepWorkHours"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "productivityLossPercent",
    "unit": "h",
    "breakdownUnits": {
      "shallowWorkHours": "h",
      "meetingHours": "h",
      "interruptionHours": "h",
      "effectiveDeepWorkHours": "h"
    }
  },

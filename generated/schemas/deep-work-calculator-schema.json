        "tr": "Bir kesintiden sonra derin odaklanmayı yeniden kazanma dakikası",
        "de": "Minuten, um nach einer Unterbrechung wieder in den Tiefenfokus zu gelangen"
      }
    },
    {
      "id": "deepWorkBlock",
      "label": "Deep Work Block Duration",
      "type": "number",
      "unit": "minutes",

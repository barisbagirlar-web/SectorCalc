{
  "toolName": "geothermal-calculator",
  "inputs": [
    {
      "id": "reservoir_temp",
      "label": "Reservoir Temperature (°C)",
      "type": "number",
      "unit": "°C",
      "default": 150,
      "businessContext": "Temperature of the geothermal reservoir",
      "label_i18n": {
        "en": "Reservoir Temperature (°C)",
        "tr": "Reservoir Temperature (°C)",
        "de": "Reservoir Temperature (°C)",
        "fr": "Reservoir Temperature (°C)",
        "es": "Reservoir Temperature (°C)",
        "ar": "Reservoir Temperature (°C)"
      }
    },
    {
      "id": "ambient_temp",
      "label": "Ambient Temperature (°C)",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Ambient temperature at the surface",
      "label_i18n": {
        "en": "Ambient Temperature (°C)",
        "tr": "Ambient Temperature (°C)",
        "de": "Ambient Temperature (°C)",
        "fr": "Ambient Temperature (°C)",
        "es": "Ambient Temperature (°C)",
        "ar": "Ambient Temperature (°C)"
      }
    },
    {
      "id": "flow_rate",
      "label": "Flow Rate (kg/s)",
      "type": "number",
      "unit": "kg/s",
      "default": 50,
      "businessContext": "Mass flow rate of geothermal fluid",
      "label_i18n": {
        "en": "Flow Rate (kg/s)",
        "tr": "Flow Rate (kg/s)",
        "de": "Flow Rate (kg/s)",
        "fr": "Flow Rate (kg/s)",
        "es": "Flow Rate (kg/s)",
        "ar": "Flow Rate (kg/s)"
      }
    },
    {
      "id": "specific_heat",
      "label": "Specific Heat Capacity (kJ/kg·K)",
      "type": "number",
      "unit": "kJ/kg·K",
      "default": 4.2,
      "businessContext": "Specific heat capacity of the geothermal fluid",
      "label_i18n": {
        "en": "Specific Heat Capacity (kJ/kg·K)",
        "tr": "Specific Heat Capacity (kJ/kg·K)",
        "de": "Specific Heat Capacity (kJ/kg·K)",
        "fr": "Specific Heat Capacity (kJ/kg·K)",
        "es": "Specific Heat Capacity (kJ/kg·K)",
        "ar": "Specific Heat Capacity (kJ/kg·K)"
      }
    },
    {
      "id": "efficiency",
      "label": "Conversion Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Efficiency of converting thermal energy to electricity",
      "label_i18n": {
        "en": "Conversion Efficiency (%)",
        "tr": "Conversion Efficiency (%)",
        "de": "Conversion Efficiency (%)",
        "fr": "Conversion Efficiency (%)",
        "es": "Conversion Efficiency (%)",
        "ar": "Conversion Efficiency (%)"
      }
    },
    {
      "id": "capacity_factor",
      "label": "Capacity Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Fraction of time the plant operates at full capacity",
      "label_i18n": {
        "en": "Capacity Factor (%)",
        "tr": "Capacity Factor (%)",
        "de": "Capacity Factor (%)",
        "fr": "Capacity Factor (%)",
        "es": "Capacity Factor (%)",
        "ar": "Capacity Factor (%)"
      }
    },
    {
      "id": "operating_hours",
      "label": "Operating Hours per Year (hours)",
      "type": "number",
      "unit": "hours",
      "default": 8000,
      "businessContext": "Total operating hours per year",
      "label_i18n": {
        "en": "Operating Hours per Year (hours)",
        "tr": "Operating Hours per Year (hours)",
        "de": "Operating Hours per Year (hours)",
        "fr": "Operating Hours per Year (hours)",
        "es": "Operating Hours per Year (hours)",
        "ar": "Operating Hours per Year (hours)"
      }
    }
  ],
  "formulas": {
    "thermal_power_kW": "flow_rate * specific_heat * (reservoir_temp - ambient_temp)",
    "electric_power_kW": "thermal_power_kW * (efficiency / 100)",
    "annual_energy_MWh": "electric_power_kW * operating_hours * (capacity_factor / 100) / 1000",
    "co2_savings_tons": "annual_energy_MWh * 0.5"
  },
  "outputs": {
    "primary": "annual_energy_MWh",
    "breakdown": [
      "thermal_power_kW",
      "electric_power_kW",
      "co2_savings_tons"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

{
  "toolName": "makeup-calculator",
  "inputs": [
    {
      "id": "batchSize",
      "label": "Batch Size (g)",
      "type": "number",
      "unit": "g",
      "default": 1000,
      "businessContext": "Production batch size in grams, typical lab scale is 1000g.",
      "label_i18n": {
        "en": "Batch Size (g)",
        "tr": "Batch Size (g)",
        "de": "Batch Size (g)",
        "fr": "Batch Size (g)",
        "es": "Batch Size (g)",
        "ar": "Batch Size (g)"
      }
    },
    {
      "id": "unitWeight",
      "label": "Unit Weight (g)",
      "type": "number",
      "unit": "g",
      "default": 30,
      "businessContext": "Weight per finished product unit (e.g., a foundation is 30g, a lipstick 4g).",
      "label_i18n": {
        "en": "Unit Weight (g)",
        "tr": "Unit Weight (g)",
        "de": "Unit Weight (g)",
        "fr": "Unit Weight (g)",
        "es": "Unit Weight (g)",
        "ar": "Unit Weight (g)"
      }
    },
    {
      "id": "materialCostPerGram",
      "label": "Material Cost per Gram",
      "type": "number",
      "unit": "currency/g",
      "default": 0.05,
      "businessContext": "Average bulk raw material cost per gram including all ingredients.",
      "label_i18n": {
        "en": "Material Cost per Gram",
        "tr": "Material Cost per Gram",
        "de": "Material Cost per Gram",
        "fr": "Material Cost per Gram",
        "es": "Material Cost per Gram",
        "ar": "Material Cost per Gram"
      }
    },
    {
      "id": "containerCostPerUnit",
      "label": "Container Cost per Unit",
      "type": "number",
      "unit": "currency",
      "default": 0.5,
      "businessContext": "Packaging and container cost per finished product unit.",
      "label_i18n": {
        "en": "Container Cost per Unit",
        "tr": "Container Cost per Unit",
        "de": "Container Cost per Unit",
        "fr": "Container Cost per Unit",
        "es": "Container Cost per Unit",
        "ar": "Container Cost per Unit"
      }
    },
    {
      "id": "laborCostPerUnit",
      "label": "Labor Cost per Unit",
      "type": "number",
      "unit": "currency",
      "default": 0.2,
      "businessContext": "Direct labor cost allocated per finished product unit.",
      "label_i18n": {
        "en": "Labor Cost per Unit",
        "tr": "Labor Cost per Unit",
        "de": "Labor Cost per Unit",
        "fr": "Labor Cost per Unit",
        "es": "Labor Cost per Unit",
        "ar": "Labor Cost per Unit"
      }
    },
    {
      "id": "overheadPercentage",
      "label": "Overhead (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Manufacturing overhead as a percentage of total direct cost.",
      "label_i18n": {
        "en": "Overhead (%)",
        "tr": "Overhead (%)",
        "de": "Overhead (%)",
        "fr": "Overhead (%)",
        "es": "Overhead (%)",
        "ar": "Overhead (%)"
      }
    },
    {
      "id": "desiredMarginPercentage",
      "label": "Desired Margin (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Profit margin markup on total cost per unit to determine selling price.",
      "label_i18n": {
        "en": "Desired Margin (%)",
        "tr": "Desired Margin (%)",
        "de": "Desired Margin (%)",
        "fr": "Desired Margin (%)",
        "es": "Desired Margin (%)",
        "ar": "Desired Margin (%)"
      }
    }
  ],
  "formulas": {
    "totalUnits": "batchSize / unitWeight",
    "totalMaterialCost": "batchSize * materialCostPerGram",
    "totalContainerCost": "totalUnits * containerCostPerUnit",
    "totalLaborCost": "totalUnits * laborCostPerUnit",
    "totalDirectCost": "totalMaterialCost + totalContainerCost + totalLaborCost",
    "overheadCost": "totalDirectCost * (overheadPercentage / 100)",
    "totalCost": "totalDirectCost + overheadCost",
    "costPerUnit": "totalCost / totalUnits",
    "sellingPricePerUnit": "costPerUnit * (1 + desiredMarginPercentage / 100)"
  },
  "outputs": {
    "primary": "sellingPricePerUnit",
    "breakdown": [
      "costPerUnit",
      "totalCost",
      "totalMaterialCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "sellingPricePerUnit",
    "unit": "g"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Makine & Üretim",
  "premiumRequired": false,

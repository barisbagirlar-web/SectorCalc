    {
      "id": "coreTemp",
      "label": "Çekirdek Vücut Sıcaklığı",
      "type": "number",
      "unit": "°C",
      "default": 37,
      "businessContext": "Başlangıç vücut sıcaklığı"
    },
    {
      "id": "ambientTemp",
      "label": "Çevre Sıcaklığı",
      "type": "number",
      "unit": "°C",
      "default": 10,
      "businessContext": "Soğuk maruziyet sıcaklığı"
    },
    {
      "id": "exposureTime",
      "label": "Maruziyet Süresi",
      "type": "number",
      "unit": "dk",
      "default": 10,
      "businessContext": "Soğuk maruziyet süresi"
    }
  ],
  "formulas": {
    "bsa": "Math.sqrt((weight * height) / 3600)",
    "heatLossRate": "5 * Math.sqrt((weight * height) / 3600) * ((coreTemp - 2) - ambientTemp)",
    "metabolicIncrease": "(5 * Math.sqrt((weight * height) / 3600) * ((coreTemp - 2) - ambientTemp) * exposureTime * 60) / 4184"
  },

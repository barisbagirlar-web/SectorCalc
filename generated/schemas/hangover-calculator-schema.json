  "formulas": {
    "dehydration_factor": "(alcohol_grams) / (body_weight + hours + gender + food_intake + hydration) * 100",
    "food_impact": "(alcohol_grams) * (body_weight) * (hours)"
  },
  "outputs": {
    "primary": "food_impact",
    "breakdown": [
      "bac",
      "dehydration_factor",
      "food_impact"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "food_impact",
    "unit": "g",
    "breakdownUnits": {
      "bac": "%",
      "dehydration_factor": "%",
      "food_impact": "%"
    }
  },

    "rules": [
      {
        "field": "alcohol_grams",
        "min": 0,
        "max": 500
      },
      {
        "field": "body_weight",
        "min": 30,
        "max": 300
      },
      {
        "field": "hours",
        "min": 0,
        "max": 24
      },
      {
        "field": "gender",
        "min": 0,
        "max": 1
      },
      {
        "field": "food_intake",
        "min": 0,
        "max": 1
      },
      {
        "field": "hydration",
        "min": 0,
        "max": 1
      }
    ],
    "thresholds": {
      "hangover_score": {
        "low": 0,
        "medium": 0.5,
        "high": 1
      }
    }

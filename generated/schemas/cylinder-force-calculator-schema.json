        "tr": "Silindir deliğinin iç çapı"
      }
    },
    {
      "id": "rodDiameter",
      "label": "Rod Diameter",
      "type": "number",
      "unit": "mm",
      "default": 20,
      "businessContext": "Diameter of the piston rod (set to 0 for single-acting cylinder)",
      "label_i18n": {
        "en": "Rod Diameter",
        "tr": "Piston çubuğu çapı",
        "de": "Rod Diameter",
        "fr": "Rod Diameter",
        "es": "Rod Diameter",
        "ar": "Rod Diameter"
      },
      "businessContext_i18n": {
        "en": "Diameter of the piston rod (set to 0 for single-acting cylinder)",
        "tr": "Piston çubuğunun çapı (tek etkili silindir için 0 girin)"
      }
    },
    {
      "id": "pressure",
      "label": "Operating Pressure",
      "type": "number",
      "unit": "bar",
      "default": 100,
      "businessContext": "Fluid pressure supplied to the cylinder",
      "label_i18n": {
        "en": "Operating Pressure",
        "tr": "Çalışma basıncı",
        "de": "Operating Pressure",
        "fr": "Operating Pressure",
        "es": "Operating Pressure",
        "ar": "Operating Pressure"
      },
      "businessContext_i18n": {
        "en": "Fluid pressure supplied to the cylinder",
        "tr": "Silindire sağlanan akışkan basıncı"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency Factor",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Mechanical efficiency of the cylinder (typical range 85-95%)",
      "label_i18n": {
        "en": "Efficiency Factor",
        "tr": "Verimlilik Faktörü",
        "de": "Efficiency Factor",
        "fr": "Efficiency Factor",
        "es": "Efficiency Factor",
        "ar": "Efficiency Factor"
      },
      "businessContext_i18n": {
        "en": "Mechanical efficiency of the cylinder (typical range 85-95%)",
        "tr": "Silindirin mekanik verimliliği (tipik aralık %85-95)"
      }
    }
  ],
  "formulas": {
    "areaBore": "Math.PI * (boreDiameter / 2) ** 2",
    "areaRod": "Math.PI * (rodDiameter / 2) ** 2",
    "areaAnnulus": "areaBore - areaRod",
    "pressureNmm2": "pressure * 0.1",
    "efficiencyFraction": "efficiency / 100",
    "forceExtension_N": "pressureNmm2 * areaBore * efficiencyFraction",
    "forceRetraction_N": "pressureNmm2 * areaAnnulus * efficiencyFraction",
    "forceExtension_kN": "forceExtension_N / 1000",
    "forceRetraction_kN": "forceRetraction_N / 1000"
  },
  "outputs": {
    "primary": "forceExtension_kN",
    "breakdown": [
      "forceRetraction_kN",
      "areaBore",
      "areaAnnulus",
      "efficiencyFraction"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "forceRetraction_kN",
    "unit": "mm",
    "breakdownUnits": {
      "efficiencyFraction": "%"
    }
  },

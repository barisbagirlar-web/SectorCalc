{
  "toolName": "cylinder-force-calculator",
  "inputs": [
    {
      "id": "boreDiameter",
      "label": "Bore Diameter",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "Inner diameter of the cylinder bore",
      "label_i18n": {
        "en": "Bore Diameter",
        "tr": "Delik Çapı",

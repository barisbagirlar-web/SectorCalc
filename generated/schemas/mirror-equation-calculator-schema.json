{
  "toolName": "mirror-equation-calculator",
  "inputs": [
    {
      "id": "objectDistance",
      "label": "Object Distance (p)",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Distance from the object to the mirror. Positive for real objects (in front of the mirror).",
      "label_i18n": {
        "en": "Object Distance (p)",
        "tr": "Object Distance (p)",
        "de": "Object Distance (p)",
        "fr": "Object Distance (p)",
        "es": "Object Distance (p)",
        "ar": "Object Distance (p)"
      }
    },
    {
      "id": "radiusOfCurvature",
      "label": "Radius of Curvature (R)",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "Radius of curvature of the mirror. Positive for concave mirrors, negative for convex mirrors (use absolute value and set mirror type).",
      "label_i18n": {
        "en": "Radius of Curvature (R)",
        "tr": "Radius of Curvature (R)",
        "de": "Radius of Curvature (R)",
        "fr": "Radius of Curvature (R)",
        "es": "Radius of Curvature (R)",
        "ar": "Radius of Curvature (R)"
      }
    },
    {
      "id": "mirrorTypeSign",
      "label": "Mirror Type (Concave=1, Convex=-1)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 for concave (converging) mirror, -1 for convex (diverging) mirror. Used to set the sign of the focal length.",
      "label_i18n": {
        "en": "Mirror Type (Concave=1, Convex=-1)",
        "tr": "Mirror Type (Concave=1, Convex=-1)",
        "de": "Mirror Type (Concave=1, Convex=-1)",
        "fr": "Mirror Type (Concave=1, Convex=-1)",
        "es": "Mirror Type (Concave=1, Convex=-1)",
        "ar": "Mirror Type (Concave=1, Convex=-1)"
      }
    },
    {
      "id": "objectHeight",
      "label": "Object Height (h₀)",
      "type": "number",
      "unit": "cm",
      "default": 2,
      "businessContext": "Height of the object. Positive if upright relative to the optical axis.",
      "label_i18n": {
        "en": "Object Height (h₀)",
        "tr": "Object Height (h₀)",
        "de": "Object Height (h₀)",
        "fr": "Object Height (h₀)",
        "es": "Object Height (h₀)",
        "ar": "Object Height (h₀)"
      }
    }
  ],
  "formulas": {
    "result": "objectDistance + radiusOfCurvature + mirrorTypeSign",
    "result_copy": "objectDistance + radiusOfCurvature + mirrorTypeSign"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [

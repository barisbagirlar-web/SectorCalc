{
  "toolName": "nutrition-label-calculator",
  "inputs": [
    {
      "id": "servingSize",
      "label": "Serving Size",
      "type": "number",
      "unit": "g",
      "default": 100,
      "businessContext": "Standard serving size in grams as stated on the nutrition label."
    },
    {
      "id": "calories",
      "label": "Calories per Serving",
      "type": "number",
      "unit": "kcal",
      "default": 250,
      "businessContext": "Total caloric content per serving."
    },
    {
      "id": "totalFat",
      "label": "Total Fat",
      "type": "number",
      "unit": "g",
      "default": 12,
      "businessContext": "Amount of total fat per serving in grams."
    },
    {
      "id": "sodium",
      "label": "Sodium",
      "type": "number",
      "unit": "mg",
      "default": 500,
      "businessContext": "Sodium content per serving in milligrams."
    },
    {
      "id": "totalCarbs",
      "label": "Total Carbohydrates",
      "type": "number",
      "unit": "g",
      "default": 30,
      "businessContext": "Amount of total carbohydrates per serving in grams."
    },
    {
      "id": "protein",
      "label": "Protein",
      "type": "number",
      "unit": "g",
      "default": 5,
      "businessContext": "Protein content per serving in grams."
    }
  ],
  "formulas": {
    "caloriesPer100g": "(calories / servingSize) * 100",
    "totalFatPer100g": "(totalFat / servingSize) * 100",
    "sodiumPer100g": "(sodium / servingSize) * 100",
    "totalCarbsPer100g": "(totalCarbs / servingSize) * 100",
    "proteinPer100g": "(protein / servingSize) * 100"
  },
  "outputs": {
    "primary": "caloriesPer100g",
    "breakdown": [
      "totalFatPer100g",
      "sodiumPer100g",
      "totalCarbsPer100g",
      "proteinPer100g"
    ]
  },
  "category": "Gıda & Tarım",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "food-cold-chain-hygiene"
}

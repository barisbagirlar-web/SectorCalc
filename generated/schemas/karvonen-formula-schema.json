{
  "toolName": "karvonen-formula",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "resting_hr",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Heart rate at rest in beats per minute",
      "label_i18n": {
        "en": "Resting Heart Rate",
        "tr": "Resting Heart Rate",
        "de": "Resting Heart Rate",
        "fr": "Resting Heart Rate",
        "es": "Resting Heart Rate",
        "ar": "Resting Heart Rate"
      }
    },
    {
      "id": "max_hr",
      "label": "Maximum Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 190,
      "businessContext": "Maximum heart rate (can be estimated as 220 - age)",
      "label_i18n": {
        "en": "Maximum Heart Rate",
        "tr": "Maximum Heart Rate",
        "de": "Maximum Heart Rate",
        "fr": "Maximum Heart Rate",
        "es": "Maximum Heart Rate",
        "ar": "Maximum Heart Rate"
      }
    },
    {
      "id": "intensity_min",
      "label": "Minimum Intensity",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Lower bound of target heart rate zone as percentage of heart rate reserve",
      "label_i18n": {
        "en": "Minimum Intensity",
        "tr": "Minimum Intensity",
        "de": "Minimum Intensity",
        "fr": "Minimum Intensity",
        "es": "Minimum Intensity",
        "ar": "Minimum Intensity"
      }
    },
    {
      "id": "intensity_max",
      "label": "Maximum Intensity",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Upper bound of target heart rate zone as percentage of heart rate reserve",
      "label_i18n": {
        "en": "Maximum Intensity",
        "tr": "Maximum Intensity",
        "de": "Maximum Intensity",
        "fr": "Maximum Intensity",
        "es": "Maximum Intensity",
        "ar": "Maximum Intensity"
      }
    }
  ],
  "formulas": {
    "heartRateReserve": "max_hr - resting_hr",
    "targetHRMin": "Math.round(resting_hr + heartRateReserve * (intensity_min / 100))",
    "targetHRMax": "Math.round(resting_hr + heartRateReserve * (intensity_max / 100))",
    "heartRateReserve_bpm": "heartRateReserve bpm",
    "targetHRMin___targetHRMax_bpm": "targetHRMin - targetHRMax bpm",
    "result": "targetHRMin - targetHRMax bpm"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Heart Rate Reserve: heartRateReserve bpm",
      "Target HR Zone: targetHRMin - targetHRMax bpm"
    ]
  },
  "category": "İK & Personel",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "workforce-hr"
}

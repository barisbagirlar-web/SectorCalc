{
  "toolName": "breastfeeding-calculator",
  "inputs": [
    {
      "id": "babyWeight",
      "label": "Baby Weight",
      "type": "number",
      "unit": "kg",
      "default": 3.5,
      "businessContext": "The weight of the baby in kilograms, used to estimate daily milk intake requirement.",
      "label_i18n": {
        "en": "Baby Weight",
        "tr": "Baby Weight",
        "de": "Baby Weight",
        "fr": "Baby Weight",
        "es": "Baby Weight",
        "ar": "Baby Weight"
      }
    },
    {
      "id": "dailyFeeds",
      "label": "Feeds per Day",
      "type": "number",
      "unit": "feeds",
      "default": 8,
      "businessContext": "Number of times the baby feeds per day, used to divide total daily volume.",
      "label_i18n": {
        "en": "Feeds per Day",
        "tr": "Feeds per Day",
        "de": "Feeds per Day",
        "fr": "Feeds per Day",
        "es": "Feeds per Day",
        "ar": "Feeds per Day"
      }
    },
    {
      "id": "milkDensity",
      "label": "Milk Density",
      "type": "number",
      "unit": "g/mL",
      "default": 1.03,
      "businessContext": "Density of breast milk, typically 1.03 g/mL, for mass conversion.",
      "label_i18n": {
        "en": "Milk Density",
        "tr": "Milk Density",
        "de": "Milk Density",
        "fr": "Milk Density",
        "es": "Milk Density",
        "ar": "Milk Density"
      }
    },
    {
      "id": "wastageFactor",
      "label": "Wastage Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Estimated percentage of milk lost due to spillage or storage inefficiencies.",
      "label_i18n": {
        "en": "Wastage Factor",
        "tr": "Wastage Factor",
        "de": "Wastage Factor",
        "fr": "Wastage Factor",
        "es": "Wastage Factor",
        "ar": "Wastage Factor"
      }
    }
  ],
  "formulas": {
    "dailyVolume": "babyWeight * 150",
    "perFeedVolume": "dailyVolume / dailyFeeds",
    "totalMass": "dailyVolume * milkDensity",
    "productionVolume": "dailyVolume / (1 - wastageFactor / 100)"
  },
  "outputs": {
    "primary": "dailyVolume",
    "breakdown": [
      "perFeedVolume",
      "totalMass",
      "productionVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "productionVolume"
  },

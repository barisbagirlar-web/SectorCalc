      }
    },
    {
      "id": "activityLevel",
      "label": "Aktivite Seviyesi",
      "type": "number",
      "unit": "puan",
      "default": 2,
      "businessContext": "1: Düşük, 2: Orta, 3: Yüksek",
      "label_i18n": {
        "en": "Aktivite Seviyesi",
        "tr": "Aktivite Seviyesi",

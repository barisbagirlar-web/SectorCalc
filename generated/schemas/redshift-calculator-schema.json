{
  "toolName": "redshift-calculator",
  "inputs": [
    {
      "id": "observedWavelength",
      "label": "Observed Wavelength",
      "type": "number",
      "unit": "nm",
      "default": 656.3,
      "businessContext": "Measured wavelength of the spectral line from the astronomical source",
      "label_i18n": {
        "en": "Observed Wavelength",
        "tr": "Observed Wavelength",
        "de": "Observed Wavelength",
        "fr": "Observed Wavelength",
        "es": "Observed Wavelength",
        "ar": "Observed Wavelength"
      }
    },
    {
      "id": "emittedWavelength",
      "label": "Emitted Wavelength",
      "type": "number",
      "unit": "nm",
      "default": 656.3,
      "businessContext": "Rest wavelength of the same spectral line (e.g., Hα = 656.3 nm)",
      "label_i18n": {
        "en": "Emitted Wavelength",
        "tr": "Emitted Wavelength",
        "de": "Emitted Wavelength",
        "fr": "Emitted Wavelength",
        "es": "Emitted Wavelength",
        "ar": "Emitted Wavelength"
      }
    },
    {
      "id": "z",
      "label": "Redshift (z)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Direct redshift input; if non-zero, overrides wavelength-based calculation",
      "label_i18n": {
        "en": "Redshift (z)",
        "tr": "Redshift (z)",
        "de": "Redshift (z)",
        "fr": "Redshift (z)",
        "es": "Redshift (z)",
        "ar": "Redshift (z)"
      }
    },
    {
      "id": "hubbleConstant",
      "label": "Hubble Constant (H₀)",
      "type": "number",
      "unit": "km/s/Mpc",
      "default": 70,
      "businessContext": "Hubble constant value in km/s per Megaparsec",
      "label_i18n": {
        "en": "Hubble Constant (H₀)",
        "tr": "Hubble Constant (H₀)",
        "de": "Hubble Constant (H₀)",
        "fr": "Hubble Constant (H₀)",
        "es": "Hubble Constant (H₀)",
        "ar": "Hubble Constant (H₀)"
      }
    }
  ],
  "formulas": {
    "redshift": "(z !== undefined && z !== 0) ? z : (observedWavelength - emittedWavelength) / emittedWavelength",
    "velocity": "((z !== undefined && z !== 0) ? z : (observedWavelength - emittedWavelength) / emittedWavelength) * 299792.458",
    "distance": "(((z !== undefined && z !== 0) ? z : (observedWavelength - emittedWavelength) / emittedWavelength) * 299792.458) / hubbleConstant"
  },
  "outputs": {
    "primary": "distance",
    "breakdown": [
      "redshift",
      "velocity"
    ]
  },
  "category": "İK & Personel",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "workforce-hr"
}

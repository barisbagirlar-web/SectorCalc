{
  "toolName": "akaryakit-fiyati-ile-yol-butcesi",
  "inputs": [
    {
      "id": "fuelPricePerLiter",
      "label": "Akaryakıt Fiyatı (Litre Başına)",
      "type": "number",
      "unit": "TL/L",
      "default": 30,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Güncel akaryakıt litre fiyatı. Kaynak: EPDK, akaryakıt dağıtım şirketleri."
    },
    {
      "id": "fuelConsumptionPer100km",
      "label": "100 km'de Yakıt Tüketimi",
      "type": "number",
      "unit": "L/100km",
      "default": 8,
      "min": 0,
      "max": 50,
      "options": null,
      "businessContext": "Aracın ortalama yakıt tüketimi. Kaynak: Araç teknik verileri, sürüş deneyimi."
    },
    {
      "id": "distanceKm",
      "label": "Toplam Yol Mesafesi",
      "type": "number",
      "unit": "km",
      "default": 100,
      "min": 0,
      "max": 100000,
      "options": null,
      "businessContext": "Planlanan veya gerçekleşen yolculuk mesafesi."
    },
    {
      "id": "vehicleType",
      "label": "Araç Türü",
      "type": "select",
      "unit": "",
      "default": "binek",
      "min": null,
      "max": null,
      "options": [
        "binek",
        "ticari",
        "agir"
      ],
      "businessContext": "Araç sınıfı; bakım, lastik ve diğer maliyetleri etkiler."
    },
    {
      "id": "maintenanceCostPerKm",
      "label": "Bakım Maliyeti (km başına)",
      "type": "number",
      "unit": "TL/km",
      "default": 0.5,
      "min": 0,
      "max": 10,
      "options": null,
      "businessContext": "Aracın km başına ortalama bakım maliyeti (periyodik bakım, lastik, vb.)."
    },
    {
      "id": "tollCost",
      "label": "Köprü ve Otoyol Ücreti",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "min": 0,
      "max": 10000,
      "options": null,
      "businessContext": "Güzergah üzerindeki köprü, otoyol geçiş ücretleri."
    },
    {
      "id": "parkingCost",
      "label": "Otopark Ücreti",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "min": 0,
      "max": 5000,
      "options": null,
      "businessContext": "Varış noktasındaki otopark ücreti."
    },
    {
      "id": "driverCostPerHour",
      "label": "Sürücü Saat Ücreti",
      "type": "number",
      "unit": "TL/saat",
      "default": 0,
      "min": 0,
      "max": 1000,
      "options": null,
      "businessContext": "Sürücünün saatlik maliyeti (maaş, yemek, konaklama)."
    },
    {
      "id": "averageSpeedKmh",
      "label": "Ortalama Hız",
      "type": "number",
      "unit": "km/saat",
      "default": 80,
      "min": 0,
      "max": 200,
      "options": null,
      "businessContext": "Trafik ve yol koşullarına bağlı ortalama hız."
    }
  ],
  "validation": {
    "rules": [
      "fuelPricePerLiter > 0",
      "fuelConsumptionPer100km > 0",
      "distanceKm > 0",
      "averageSpeedKmh > 0",
      "maintenanceCostPerKm >= 0",
      "tollCost >= 0",
      "parkingCost >= 0",
      "driverCostPerHour >= 0"
    ],
    "thresholds": {
      "fuelCostPerKm": "fuelCostPerKm > 5 ? 'Yüksek yakıt maliyeti' : ''",
      "totalCost": "totalCost > 10000 ? 'Bütçe aşımı uyarısı' : ''"
    }
  },
  "formulas": {
    "fuelCost": "fuelPricePerLiter * (fuelConsumptionPer100km / 100) * distanceKm",
    "maintenanceCost": "maintenanceCostPerKm * distanceKm",
    "travelTimeHours": "distanceKm / averageSpeedKmh",
    "driverCost": "driverCostPerHour * travelTimeHours",
    "totalCost": "fuelCost + maintenanceCost + tollCost + parkingCost + driverCost",
    "costPerKm": "totalCost / distanceKm",
    "fuelCostPerKm": "fuelCost / distanceKm"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": {
      "fuelCost": "fuelCost",
      "maintenanceCost": "maintenanceCost",
      "tollCost": "tollCost",
      "parkingCost": "parkingCost",
      "driverCost": "driverCost",
      "travelTimeHours": "travelTimeHours",
      "costPerKm": "costPerKm",
      "fuelCostPerKm": "fuelCostPerKm"
    },
    "hiddenLossDrivers": [
      "fuelCostPerKm > 5 ? 'Yüksek yakıt maliyeti' : ''",
      "totalCost > 10000 ? 'Bütçe aşımı uyarısı' : ''"
    ],
    "suggestedActions": [
      "Yakıt tüketimini azaltmak için araç bakımını düzenli yapın.",
      "Daha ekonomik sürüş teknikleri uygulayın.",
      "Alternatif güzergahlar ile köprü/otoyol ücretlerini minimize edin.",
      "Toplu taşıma veya araç paylaşımı seçeneklerini değerlendirin."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi (geçmiş verilerle karşılaştırma)",
    "Detaylı rapor (maliyet kırılımı grafikleri)",
    "Karşılaştırma (farklı araç/güzergah senaryoları)"
  ],
  "premiumRequired": false
}

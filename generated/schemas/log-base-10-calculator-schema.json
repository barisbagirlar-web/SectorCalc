        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "log10Result": "Number((Math.log(x)/Math.log(10)).toFixed(precision))",
    "productLog": "Number((Math.log(x*y)/Math.log(10)).toFixed(precision))",
    "quotientLog": "Number((Math.log(x/y)/Math.log(10)).toFixed(precision))",
    "powerLog": "Number((n * Math.log(x)/Math.log(10)).toFixed(precision))",
    "customBaseLog": "Number((Math.log(x)/Math.log(base)).toFixed(precision))",
    "antilog10": "Number(Math.pow(10, x).toFixed(precision))"
  },
  "outputs": {
    "primary": "log10Result",
    "breakdown": [
      "productLog",
      "quotientLog",
      "powerLog",
      "customBaseLog",
      "antilog10"
    ]
  },

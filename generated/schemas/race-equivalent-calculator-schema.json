        "ar": "Known Distance"
      }
    },
    {
      "id": "knownTimeHours",
      "label": "Hours",
      "type": "number",
      "unit": "h",
      "default": 0,
      "businessContext": "Hours part of your known race time",
      "label_i18n": {
        "en": "Hours",

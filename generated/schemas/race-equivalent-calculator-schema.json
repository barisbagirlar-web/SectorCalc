        "de": "Hours",
        "fr": "Hours",
        "es": "Hours",
        "ar": "Hours"
      }
    },
    {
      "id": "knownTimeMinutes",
      "label": "Minutes",
      "type": "number",
      "unit": "min",
      "default": 50,
      "businessContext": "Minutes part of your known race time",
      "label_i18n": {
        "en": "Minutes",
        "tr": "Minutes",
        "de": "Minutes",
        "fr": "Minutes",
        "es": "Minutes",
        "ar": "Minutes"
      }
    },
    {
      "id": "knownTimeSeconds",
      "label": "Seconds",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Seconds part of your known race time",
      "label_i18n": {
        "en": "Seconds",
        "tr": "Seconds",
        "de": "Seconds",
        "fr": "Seconds",
        "es": "Seconds",
        "ar": "Seconds"
      }
    },
    {
      "id": "targetDistance",
      "label": "Target Distance",
      "type": "number",
      "unit": "km",
      "default": 42.195,
      "businessContext": "Distance of the race you want to predict",
      "label_i18n": {
        "en": "Target Distance",
        "tr": "Target Distance",
        "de": "Target Distance",
        "fr": "Target Distance",
        "es": "Target Distance",
        "ar": "Target Distance"
      }
    }
  ],
  "formulas": {
    "equivalentTimeSeconds": "(knownTimeHours * 3600 + knownTimeMinutes * 60 + knownTimeSeconds) * Math.pow(targetDistance / knownDistance, 1.06)",
    "equivalentTimeMinutes": "equivalentTimeSeconds / 60",
    "equivalentPaceSecondsPerKm": "equivalentTimeSeconds / targetDistance"
  },
  "outputs": {
    "primary": "equivalentTimeSeconds",
    "breakdown": [
      "equivalentTimeMinutes",
      "equivalentPaceSecondsPerKm"
    ]
  },

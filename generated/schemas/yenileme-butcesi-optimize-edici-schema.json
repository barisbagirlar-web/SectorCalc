  "formulas": {
    "BaseCost": "Area * CostPerSqM_ByComplexity",
    "Escalation": "BaseCost * ((1 + InflationRate)^ProjectDuration - 1)",
    "Contingency": "(BaseCost + Escalation) * RiskFactor",
    "SoftCosts": "(BaseCost + Escalation) * (DesignFeePct + PermitFeePct)",
    "TotalBudget": "BaseCost + Escalation + Contingency + SoftCosts + FF_E",
    "ROI_Renovation": "(NewPropertyValue - OldPropertyValue - TotalBudget) / TotalBudget"
  },

{
  "toolName": "us-mpg-to-uk-mpg-calculator",
  "inputs": [
    {
      "id": "usMpg",
      "label": "US MPG",
      "type": "number",
      "unit": "mpg (US)",
      "default": 25,
      "businessContext": "Fuel economy in miles per US gallon",
      "label_i18n": {
        "en": "US MPG",
        "tr": "US MPG",
        "de": "US MPG",
        "fr": "US MPG",
        "es": "US MPG",
        "ar": "US MPG"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.20095,
      "businessContext": "Factor to convert US mpg to UK mpg. Based on 1 US gallon = 0.832674 UK gallon",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for rounded output",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "referenceValue",
      "label": "Reference Value",
      "type": "number",
      "unit": "mpg (UK)",
      "default": 30,
      "businessContext": "Optional reference UK mpg value for comparison",
      "label_i18n": {
        "en": "Reference Value",
        "tr": "Reference Value",
        "de": "Reference Value",
        "fr": "Reference Value",
        "es": "Reference Value",
        "ar": "Reference Value"
      }
    }
  ],
  "formulas": {
    "rawUkMpg": "usMpg * conversionFactor",
    "roundedUkMpg": "Math.round(rawUkMpg * Math.pow(10, precision)) / Math.pow(10, precision)",
    "ukMpg": "roundedUkMpg",
    "difference": "roundedUkMpg - referenceValue"
  },
  "outputs": {
    "primary": "ukMpg",
    "breakdown": [
      "rawUkMpg",
      "roundedUkMpg",
      "difference"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "maintenance-reliability",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "energy"
}

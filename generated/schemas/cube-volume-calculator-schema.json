{
  "toolName": "cube-volume-calculator",
  "inputs": [
    {
      "id": "sideLength",
      "label": "Side Length",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of one edge of the cube."
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of cubes."
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage for loss/waste."
    },
    {
      "id": "density",
      "label": "Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Material density for weight calculation."
    }
  ],
  "formulas": {
    "totalVolume": "sideLength ** 3 * quantity * (1 + wasteFactor / 100)",
    "singleCubeVolume": "sideLength ** 3",
    "totalWeight": "sideLength ** 3 * quantity * (1 + wasteFactor / 100) * density"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "singleCubeVolume",
      "totalWeight"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

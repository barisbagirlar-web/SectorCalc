{
  "toolName": "invisalign-calculator",
  "inputs": [
    {
      "id": "numberOfAligners",
      "label": "Number of Aligners",
      "type": "number",
      "unit": "pcs",
      "default": 20,
      "businessContext": "Total number of aligners in the treatment plan.",
      "label_i18n": {
        "en": "Number of Aligners",
        "tr": "Number of Aligners",
        "de": "Number of Aligners",
        "fr": "Number of Aligners",
        "es": "Number of Aligners",
        "ar": "Number of Aligners"
      }
    },
    {
      "id": "materialCostPerAligner",
      "label": "Material Cost per Aligner",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Cost of raw material for one aligner.",
      "label_i18n": {
        "en": "Material Cost per Aligner",
        "tr": "Material Cost per Aligner",
        "de": "Material Cost per Aligner",
        "fr": "Material Cost per Aligner",
        "es": "Material Cost per Aligner",
        "ar": "Material Cost per Aligner"
      }
    },
    {
      "id": "laborCostPerAligner",
      "label": "Labor Cost per Aligner",
      "type": "number",
      "unit": "USD",
      "default": 30,
      "businessContext": "Direct labor cost to produce one aligner.",
      "label_i18n": {
        "en": "Labor Cost per Aligner",
        "tr": "Labor Cost per Aligner",
        "de": "Labor Cost per Aligner",
        "fr": "Labor Cost per Aligner",
        "es": "Labor Cost per Aligner",
        "ar": "Labor Cost per Aligner"
      }
    },
    {
      "id": "overheadRate",
      "label": "Overhead Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Overhead percentage applied to direct costs (e.g., utilities, admin).",
      "label_i18n": {
        "en": "Overhead Rate",
        "tr": "Overhead Rate",
        "de": "Overhead Rate",
        "fr": "Overhead Rate",
        "es": "Overhead Rate",
        "ar": "Overhead Rate"
      }
    },
    {
      "id": "sellingPricePerAligner",
      "label": "Selling Price per Aligner",
      "type": "number",
      "unit": "USD",
      "default": 150,
      "businessContext": "Price charged to the customer per aligner.",
      "label_i18n": {
        "en": "Selling Price per Aligner",
        "tr": "Selling Price per Aligner",
        "de": "Selling Price per Aligner",
        "fr": "Selling Price per Aligner",
        "es": "Selling Price per Aligner",
        "ar": "Selling Price per Aligner"
      }
    }
  ],
  "formulas": {
    "totalDirectCost": "(materialCostPerAligner + laborCostPerAligner) * numberOfAligners",
    "totalOverhead": "totalDirectCost * (overheadRate / 100)",
    "totalCost": "totalDirectCost + totalOverhead",
    "totalRevenue": "sellingPricePerAligner * numberOfAligners",
    "profit": "totalRevenue - totalCost",
    "marginPercentage": "(profit / totalRevenue) * 100"
  },
  "outputs": {
    "primary": "marginPercentage",
    "breakdown": [
      "Total Cost: $${totalCost}",
      "Total Revenue: $${totalRevenue}",
      "Profit: $${profit}",
      "Margin: ${marginPercentage}%"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "marginPercentage"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

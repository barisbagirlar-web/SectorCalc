{
  "toolName": "horizontal-curve-calculator",
  "inputs": [
    {
      "id": "designSpeed",
      "label": "Design Speed (V)",
      "type": "number",
      "unit": "km/h",
      "default": 60,
      "businessContext": "Design speed of the road",
      "label_i18n": {
        "en": "Design Speed (V)",
        "tr": "Design Speed (V)",
        "de": "Design Speed (V)",
        "fr": "Design Speed (V)",
        "es": "Design Speed (V)",
        "ar": "Design Speed (V)"
      }
    },
    {
      "id": "superelevation",
      "label": "Superelevation (e)",
      "type": "number",
      "unit": "%",
      "default": 6,
      "businessContext": "Superelevation rate in percent",
      "label_i18n": {
        "en": "Superelevation (e)",
        "tr": "Superelevation (e)",
        "de": "Superelevation (e)",
        "fr": "Superelevation (e)",
        "es": "Superelevation (e)",
        "ar": "Superelevation (e)"
      }
    },
    {
      "id": "frictionFactor",
      "label": "Side Friction Factor (f)",
      "type": "number",
      "unit": "unit",
      "default": 0.15,
      "businessContext": "Side friction factor (typically 0.1-0.2)",
      "label_i18n": {
        "en": "Side Friction Factor (f)",
        "tr": "Side Friction Factor (f)",
        "de": "Side Friction Factor (f)",
        "fr": "Side Friction Factor (f)",
        "es": "Side Friction Factor (f)",
        "ar": "Side Friction Factor (f)"
      }
    },
    {
      "id": "centralAngle",
      "label": "Central Angle (Δ)",
      "type": "number",
      "unit": "deg",
      "default": 90,
      "businessContext": "Central or deflection angle of the curve",
      "label_i18n": {
        "en": "Central Angle (Δ)",
        "tr": "Central Angle (Δ)",
        "de": "Central Angle (Δ)",
        "fr": "Central Angle (Δ)",
        "es": "Central Angle (Δ)",
        "ar": "Central Angle (Δ)"
      }
    },
    {
      "id": "stationPI",
      "label": "Station at PI",
      "type": "number",
      "unit": "m",
      "default": 1000,
      "businessContext": "Station of Point of Intersection (PI)",
      "label_i18n": {
        "en": "Station at PI",
        "tr": "Station at PI",
        "de": "Station at PI",
        "fr": "Station at PI",
        "es": "Station at PI",
        "ar": "Station at PI"
      }
    }
  ],
  "formulas": {
    "radius": "Math.pow(designSpeed, 2) / (127 * (superelevation / 100 + frictionFactor))",
    "tangent": "radius * Math.tan(centralAngle * Math.PI / 360)",
    "curveLength": "(Math.PI * radius * centralAngle) / 180",
    "chord": "2 * radius * Math.sin(centralAngle * Math.PI / 360)",
    "externalDistance": "radius * (1 / Math.cos(centralAngle * Math.PI / 360) - 1)",
    "middleOrdinate": "radius * (1 - Math.cos(centralAngle * Math.PI / 360))",
    "stationPC": "stationPI - tangent",
    "stationPT": "stationPC + curveLength"
  },
  "outputs": {
    "primary": "curveLength",
    "breakdown": [
      "radius",
      "tangent",
      "chord",
      "externalDistance",
      "middleOrdinate",
      "stationPC",
      "stationPT"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

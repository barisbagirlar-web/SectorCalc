{
  "toolName": "beam-deflection-calculator",
  "catalogCategory": "construction-measurement",
  "categorySlug": "mechanical-hvac-energy-loss",
  "sector": "Mechanical Engineering",
  "sectorId": "mechanical-hvac-energy-loss",
  "inputs": [
    {
      "id": "load",
      "label": "Point Load (N)",
      "type": "number",
      "unit": "N",
      "default": 15000,
      "min": 0,
      "businessContext": "Mid-span point load."
    },
    {
      "id": "aciklik",
      "label": "Span (m)",
      "type": "number",
      "unit": "m",
      "default": 4,
      "min": 0,
      "businessContext": "Support spacing."
    },
    {
      "id": "elastisiteModulu",
      "label": "Young's Modulus (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 200000000000,
      "min": 0,
      "businessContext": "Material modulus."
    },
    {
      "id": "ataletMomenti",
      "label": "Moment of Inertia (m⁴)",
      "type": "number",
      "unit": "m4",
      "default": 0.0000083,
      "min": 0,
      "businessContext": "Section moment of inertia."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(load * Math.pow(aciklik, 3)) / Math.max(0.0001, (48 * elastisiteModulu * ataletMomenti))"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Orta Nokta Sehimi"
    },
    "breakdownUnits": {
      "result": "m"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify calculations with FEA or physical testing.",
      "Use appropriate safety factors for design."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate mid-span deflection of a simply supported beam under point load.",
      "long": "Calculate mid-span deflection of a simply supported beam under point load."
    }
  },
  "sectorSlug": "construction"

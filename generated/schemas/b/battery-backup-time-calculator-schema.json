{
  "toolName": "battery-backup-time-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "other",
  "sector": "Ileri Fizik, Kuantum ve Energy",
  "sectorId": "other",
  "inputs": [
    {
      "id": "akuKapasite",
      "label": "Battery Capacity (Ah)",
      "type": "number",
      "unit": "Ah",
      "default": 100,
      "min": 0,
      "businessContext": "Battery rated capacity."
    },
    {
      "id": "yukGucu",
      "label": "Load Power (W)",
      "type": "number",
      "unit": "W",
      "default": 500,
      "min": 0,
      "businessContext": "Total connected load power."
    },
    {
      "id": "dcVoltaj",
      "label": "DC System Voltage (V)",
      "type": "number",
      "unit": "V",
      "default": 12,
      "min": 0,
      "businessContext": "Battery system voltage."
    },
    {
      "id": "desarjDerinligi",
      "label": "Depth of Discharge (%)",
      "type": "number",
      "unit": "%",
      "default": 80,
      "min": 0,
      "businessContext": "Maximum allowed discharge."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(akuKapasite * dcVoltaj * (desarjDerinligi / 100)) / Math.max(0.0001, yukGucu)"
  },
  "outputs": {
    "primary": "result",
    "unit": "hours",
    "breakdown": {
      "result": "Yedekleme Time"
    },
    "breakdownUnits": {
      "result": "hours"
    },

{
  "toolName": "burn-rate-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Business",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "baslangicNakit",
      "label": "Start Cash (USD)",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "min": 0,
      "businessContext": "Cash at period start."
    },
    {
      "id": "bitisNakit",
      "label": "End Cash (USD)",
      "type": "number",
      "unit": "USD",
      "default": 200000,
      "min": 0,
      "businessContext": "Cash at period end."
    },
    {
      "id": "month",
      "label": "Period (Months)",
      "type": "number",
      "unit": "months",
      "default": 3,
      "min": 1,
      "businessContext": "Calculation period."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "burnRate": "(baslangicNakit - bitisNakit) / Math.max(1, month)",
    "result": "bitisNakit / Math.max(0.0001, ((baslangicNakit - bitisNakit) / Math.max(1, month)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "months",
    "breakdown": {
      "result": "KArea Duration (Runway)"
    },
    "breakdownUnits": {
      "result": "months"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify financial projections with actual data.",
      "Review assumptions quarterly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate runway (months until cash runs out) from burn rate.",
      "long": "Calculate runway (months until cash runs out) from burn rate."
    }
  },
  "sectorSlug": "daily-renovation"
}

      "label": "Peak Demand (kW)",
      "type": "number",
      "unit": "kW",
      "default": 150,
      "min": 0,
      "businessContext": "Measured peak power demand."
    },
    {
      "id": "kuruluGuc",
      "label": "Installed Capacity (kW)",
      "type": "number",
      "unit": "kW",
      "default": 250,
      "min": 0,
      "businessContext": "Transformer or panel rating."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(maksTalep / Math.max(0.0001, kuruluGuc)) * 100"
  },

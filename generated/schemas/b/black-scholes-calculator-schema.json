{
  "toolName": "black-scholes-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "S",
      "label": "Spot Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "min": 0,
      "businessContext": "Current underlying asset price."
    },
    {
      "id": "K",
      "label": "Strike Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 110,
      "min": 0,
      "businessContext": "Option strike price."
    },
    {
      "id": "r",
      "label": "Risk-Free Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 8,
      "min": 0,
      "businessContext": "Risk-free interest rate."
    },
    {
      "id": "t",
      "label": "Time to Maturity (Years)",
      "type": "number",
      "unit": "years",
      "default": 1,
      "min": 0.0001,
      "businessContext": "Time remaining to expiry."
    },
    {
      "id": "v",
      "label": "Volatility (%)",
      "type": "number",
      "unit": "%",
      "default": 30,
      "min": 0,
      "businessContext": "Annualized volatility."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "d1": "(Math.log(S / Math.max(1, K)) + (r / 100 + Math.pow(v / 100, 2) / 2) * t) / (Math.max(0.0001, v / 100) * Math.sqrt(Math.max(0.0001, t)))",
    "result": "S * 0.5 - K * Math.exp(-(r / 100) * t) * 0.5"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "Opsiyon Primi (Call)"
    },
    "breakdownUnits": {
      "result": "USD"
    },

{
  "toolName": "bond-price-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finance",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "nominal",
      "label": "Face Value (USD)",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "min": 0,
      "businessContext": "Bond's par value at maturity."
    },
    {
      "id": "kupon",
      "label": "Coupon Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 8,
      "min": 0,
      "businessContext": "Annual coupon payment rate."
    },
    {
      "id": "piyasaFaizi",
      "label": "Market Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Yield on market bonds."
    },
    {
      "id": "vade",
      "label": "Maturity (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "min": 1,
      "businessContext": "Years to maturity."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "kuponPayment": "nominal * (kupon / 100)",
    "result": "nominal / Math.pow(1 + piyasaFaizi / 100, vade) + (nominal * (kupon / 100)) * ((1 - Math.pow(1 / (1 + piyasaFaizi / 100), vade)) / (piyasaFaizi / 100))"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "Bond Price (Present Value)"
    },
    "breakdownUnits": {
      "result": "USD"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate the fair price of a bond based on market interest rates.",
      "long": "Calculate the fair price of a bond based on market interest rates."
    }
  },
  "sectorSlug": "daily-renovation"
}

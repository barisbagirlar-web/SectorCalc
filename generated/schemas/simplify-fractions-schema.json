    "fraction4": "(function(){const g=(a,b)=>b?g(b,a%b):a;const d=den4;if(d===0)return 'tanımsız';let n=num4;let x=g(Math.abs(n),Math.abs(d))||1;let sn=n/x,sd=d/x;if(sd<0){sn=-sn;sd=-sd;}return sn+'/'+sd;})()"

{
  "toolName": "concrete-cost-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Length of the concrete area",
      "label_i18n": {
        "en": "Length",
        "tr": "Length",
        "de": "Length",
        "fr": "Length",
        "es": "Length",
        "ar": "Length"
      }
    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Width of the concrete area",
      "label_i18n": {
        "en": "Width",
        "tr": "Width",
        "de": "Width",
        "fr": "Width",
        "es": "Width",
        "ar": "Width"
      }
    },
    {
      "id": "thickness",
      "label": "Thickness",
      "type": "number",
      "unit": "m",
      "default": 0.15,
      "businessContext": "Thickness of the concrete slab",
      "label_i18n": {
        "en": "Thickness",
        "tr": "Thickness",
        "de": "Thickness",
        "fr": "Thickness",
        "es": "Thickness",
        "ar": "Thickness"
      }
    },
    {
      "id": "costPerCubicMeter",
      "label": "Concrete Cost per m³",
      "type": "number",
      "unit": "EUR/m³",
      "default": 120,
      "businessContext": "Unit price of ready-mix concrete",
      "label_i18n": {
        "en": "Concrete Cost per m³",
        "tr": "Concrete Cost per m³",
        "de": "Concrete Cost per m³",
        "fr": "Concrete Cost per m³",
        "es": "Concrete Cost per m³",
        "ar": "Concrete Cost per m³"
      }
    },
    {
      "id": "wastePercentage",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Extra percentage for spillage and waste",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Waste Percentage",
        "de": "Waste Percentage",
        "fr": "Waste Percentage",
        "es": "Waste Percentage",
        "ar": "Waste Percentage"
      }
    },
    {
      "id": "deliveryCost",
      "label": "Delivery Cost",
      "type": "number",
      "unit": "EUR",
      "default": 200,
      "businessContext": "Flat delivery fee for concrete truck",
      "label_i18n": {
        "en": "Delivery Cost",
        "tr": "Delivery Cost",
        "de": "Delivery Cost",
        "fr": "Delivery Cost",
        "es": "Delivery Cost",
        "ar": "Delivery Cost"
      }
    }
  ],
  "formulas": {
    "volume": "length * width * thickness",
    "effectiveVolume": "volume * (1 + wastePercentage / 100)",
    "materialCost": "effectiveVolume * costPerCubicMeter",
    "totalCost": "materialCost + deliveryCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "materialCost",
      "deliveryCost",
      "volume",
      "effectiveVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

{
  "toolName": "4-rule-calculator",
  "inputs": [
    {
      "id": "portfolioValue",
      "label": "Portfolio Value",
      "type": "number",
      "unit": "USD",
      "default": 1000000,
      "businessContext": "Total investment portfolio value at retirement",
      "label_i18n": {
        "en": "Portfolio Value",
        "tr": "Portföy Değeri",
        "de": "Portfoliowert",
        "fr": "Valeur du portefeuille",
        "es": "Valor de la cartera",
        "ar": "Portfolio Value"
      },
      "businessContext_i18n": {
        "en": "Total investment portfolio value at retirement",
        "tr": "Emeklilikteki toplam yatırım portföyü değeri",
        "de": "Gesamtwert des Anlageportfolios zum Rentenbeginn",
        "fr": "Valeur totale du portefeuille d'investissement à la retraite",
        "es": "Valor total de la cartera de inversiones al momento de la jubilación"
      }
    },
    {
      "id": "withdrawalRate",
      "label": "Withdrawal Rate",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Annual withdrawal rate as a percentage of portfolio",
      "label_i18n": {
        "en": "Withdrawal Rate",
        "tr": "Çekme Oranı",
        "de": "Entnahmerate",
        "fr": "Taux de retrait",
        "es": "Tasa de retiro",
        "ar": "Withdrawal Rate"
      },
      "businessContext_i18n": {
        "en": "Annual withdrawal rate as a percentage of portfolio",
        "tr": "Portföyün yıllık çekme oranı",
        "de": "Jährliche Entnahmerate als Prozentsatz des Portfolios",
        "fr": "Taux de retrait annuel en pourcentage du portefeuille",
        "es": "Tasa de retiro anual como porcentaje de la cartera"
      }
    },
    {
      "id": "retirementYears",
      "label": "Retirement Years",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Expected duration of retirement in years",
      "label_i18n": {
        "en": "Retirement Years",
        "tr": "Emeklilik Yılları",
        "de": "Ruhestandsjahre",
        "fr": "Années de retraite",
        "es": "Años de jubilación",
        "ar": "Retirement Years"
      },
      "businessContext_i18n": {
        "en": "Expected duration of retirement in years",
        "tr": "Emekliliğin beklenen süresi (yıl olarak)",
        "de": "Erwartete Dauer des Ruhestands in Jahren",
        "fr": "Durée prévue de la retraite en années",
        "es": "Duración esperada de la jubilación en años"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Expected annual inflation rate",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Enflasyon Oranı",
        "de": "Inflationsrate",
        "fr": "Taux d'inflation",
        "es": "Tasa de inflación",
        "ar": "Inflation Rate"
      },
      "businessContext_i18n": {
        "en": "Expected annual inflation rate",
        "tr": "Beklenen yıllık enflasyon oranı",
        "de": "Erwartete jährliche Inflationsrate",
        "fr": "Taux d'inflation annuel attendu",
        "es": "Tasa de inflación anual esperada"
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual portfolio return",
      "label_i18n": {
        "en": "Expected Return",
        "tr": "Beklenen Getiri",
        "de": "Erwartete Rendite",
        "fr": "Rendement attendu",
        "es": "Rendimiento esperado",
        "ar": "Expected Return"
      },
      "businessContext_i18n": {
        "en": "Expected annual portfolio return",
        "tr": "Beklenen yıllık portföy getirisi",
        "de": "Erwartete jährliche Portfoliorendite",
        "fr": "Rendement annuel attendu du portefeuille",
        "es": "Rendimiento anual esperado de la cartera"
      }
    }
  ],
  "formulas": {
    "annualWithdrawal": "portfolioValue * (withdrawalRate / 100)",
    "monthlyWithdrawal": "annualWithdrawal / 12",
    "adjustedAnnualWithdrawal": "annualWithdrawal * (1 + inflationRate / 100)"
  },
  "outputs": {
    "primary": "annualWithdrawal",
    "breakdown": [
      "monthlyWithdrawal",
      "adjustedAnnualWithdrawal",
      "sustainableYears",
      "finalPortfolioValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalPortfolioValue",
    "unit": "USD"
  },
  "category": "Finans & Yatırım",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,

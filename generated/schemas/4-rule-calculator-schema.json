{
  "toolName": "4-rule-calculator",
  "inputs": [
    {
      "id": "portfolioValue",
      "label": "Portfolio Value",
      "type": "number",
      "unit": "USD",
      "default": 1000000,
      "businessContext": "Total investment portfolio value at retirement",
      "label_i18n": {
        "en": "Portfolio Value",
        "tr": "Portfolio Value",
        "de": "Portfolio Value",
        "fr": "Portfolio Value",
        "es": "Portfolio Value",
        "ar": "Portfolio Value"
      }
    },
    {
      "id": "withdrawalRate",
      "label": "Withdrawal Rate",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Annual withdrawal rate as a percentage of portfolio",
      "label_i18n": {
        "en": "Withdrawal Rate",
        "tr": "Withdrawal Rate",
        "de": "Withdrawal Rate",
        "fr": "Withdrawal Rate",
        "es": "Withdrawal Rate",
        "ar": "Withdrawal Rate"
      }
    },
    {
      "id": "retirementYears",
      "label": "Retirement Years",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Expected duration of retirement in years",
      "label_i18n": {
        "en": "Retirement Years",
        "tr": "Retirement Years",
        "de": "Retirement Years",
        "fr": "Retirement Years",
        "es": "Retirement Years",
        "ar": "Retirement Years"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Expected annual inflation rate",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Inflation Rate",
        "de": "Inflation Rate",
        "fr": "Inflation Rate",
        "es": "Inflation Rate",
        "ar": "Inflation Rate"
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual portfolio return",
      "label_i18n": {
        "en": "Expected Return",
        "tr": "Expected Return",
        "de": "Expected Return",
        "fr": "Expected Return",
        "es": "Expected Return",
        "ar": "Expected Return"
      }
    }
  ],
  "formulas": {
    "annualWithdrawal": "portfolioValue * (withdrawalRate / 100)",
    "monthlyWithdrawal": "annualWithdrawal / 12",
    "adjustedAnnualWithdrawal": "annualWithdrawal * (1 + inflationRate / 100)",
    "sustainableYears": "Math.log(1 + (expectedReturn / 100 - inflationRate / 100) / (withdrawalRate / 100)) / Math.log(1 + (expectedReturn / 100 - inflationRate / 100))",
    "finalPortfolioValue": "portfolioValue * (1 + expectedReturn / 100) ** retirementYears - annualWithdrawal * ((1 + expectedReturn / 100) ** retirementYears - 1) / (expectedReturn / 100)"
  },
  "outputs": {
    "primary": "annualWithdrawal",
    "breakdown": [
      "monthlyWithdrawal",
      "adjustedAnnualWithdrawal",
      "sustainableYears",
      "finalPortfolioValue"
    ]
  },
  "category": "Otomotiv",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "maintenance-reliability",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "finance"
}

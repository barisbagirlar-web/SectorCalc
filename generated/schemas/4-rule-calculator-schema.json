        "tr": "Beklenen yıllık enflasyon oranı"
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual portfolio return",
      "label_i18n": {
        "en": "Expected Return",
        "tr": "Beklenen Getiri",
        "de": "Expected Return",
        "fr": "Expected Return",

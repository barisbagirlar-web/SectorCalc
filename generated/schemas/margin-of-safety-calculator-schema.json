{
  "toolName": "margin-of-safety-calculator",
  "inputs": [
    {
      "id": "materialUltimateStrength",
      "label": "Material Ultimate Strength",
      "type": "number",
      "unit": "MPa",
      "default": 400,
      "businessContext": "Ultimate tensile or compressive strength value of the material",
      "label_i18n": {
        "en": "Ultimate Strength of Material",
        "tr": "Malzeme Nihai Dayanımı",
        "de": "Material-Endfestigkeit",
        "fr": "Résistance ultime du matériau",
        "es": "Resistencia última del material",
        "ar": "مقاومة المادة النهائية"
      },
      "businessContext_i18n": {
        "en": "Ultimate tensile or compressive strength value of the material",

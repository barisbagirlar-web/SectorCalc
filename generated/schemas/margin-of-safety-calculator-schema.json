        "ar": "قيمة مقاومة الشد أو الضغط النهائية للمادة"
      }
    },
    {
      "id": "crossSectionArea",
      "label": "Cross-sectional Area",
      "type": "number",
      "unit": "mm²",
      "default": 100,
      "businessContext": "Net cross-sectional area of the element",
      "label_i18n": {
        "en": "Cross-sectional Area",
        "tr": "Kesit Alanı",
        "de": "Querschnittsfläche",
        "fr": "Section transversale",
        "es": "Área de la sección transversal",
        "ar": "مساحة المقطع"
      },
      "businessContext_i18n": {
        "en": "Net cross-sectional area of the member",
        "tr": "Elemanın net kesit alanı",
        "de": "Nettoquerschnittsfläche des Bauteils",
        "fr": "Section nette de l'élément",
        "es": "Área neta de la sección transversal del elemento",
        "ar": "مساحة المقطع العرضي الصافية للعنصر"
      }
    },
    {
      "id": "appliedForce",
      "label": "Uygulanan Kuvvet",
      "type": "number",
      "unit": "N",
      "default": 10000,
      "businessContext": "Elemana etkiyen eksenel kuvvet",
      "label_i18n": {
        "en": "Uygulanan Kuvvet",
        "tr": "Applied Force",
        "de": "Angewandte Kraft",
        "fr": "Force appliquée",
        "es": "Fuerza aplicada",
        "ar": "القوة المطبقة"
      },
      "businessContext_i18n": {
        "en": "Elemana etkiyen eksenel kuvvet",
        "tr": "Axial force on element",
        "de": "Auf das Bauteil wirkende Axialkraft",
        "fr": "Force axiale agissant sur l'élément",
        "es": "Fuerza axial que actúa sobre el elemento",
        "ar": "القوة المحورية المؤثرة على العنصر"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "boyutsuz",
      "default": 1.5,
      "businessContext": "Safety factor used in design",
      "label_i18n": {
        "en": "Safety factor",
        "tr": "Güvenlik Katsayısı",
        "de": "Sicherheitsfaktor",
        "fr": "Coefficient de sécurité",
        "es": "Factor de seguridad",
        "ar": "معامل الأمان"
      },
      "businessContext_i18n": {
        "en": "Safety factor used in design",
        "tr": "Tasarımda kullanılan güvenlik faktörü",
        "de": "Im Entwurf verwendeter Sicherheitsfaktor",
        "fr": "Facteur de sécurité utilisé dans la conception",
        "es": "Factor de seguridad utilizado en el diseño",
        "ar": "عامل الأمان المستخدم في التصميم"
      }
    }
  ],
  "formulas": {
    "actualStress": "appliedForce / crossSectionArea",
    "allowableStress": "materialUltimateStrength / safetyFactor",
    "marginOfSafety": "(allowableStress / actualStress) - 1",
    "stressRatio": "allowableStress / actualStress"
  },
  "outputs": {
    "primary": "marginOfSafety",
    "breakdown": [
      "allowableStress",
      "actualStress",
      "stressRatio"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "stressRatio",
    "unit": "%",
    "breakdownUnits": {
      "stressRatio": "%"
    }
  },

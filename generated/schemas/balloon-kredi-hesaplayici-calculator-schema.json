    },
    {
      "id": "termMonths",
      "label": "Vade (Ay)",
      "type": "number",
      "unit": "ay",
      "default": 60,
      "businessContext": "Vade",
      "label_i18n": {
        "en": "Vade (Ay)",
        "tr": "Vade (Ay)",
        "de": "Vade (Ay)",
        "fr": "Vade (Ay)",
        "es": "Vade (Ay)",
        "ar": "Vade (Ay)"
      }
    },
    {
      "id": "balloonPercent",
      "label": "Balon Ödeme Yüzdesi",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Balon ödeme, anaparanın yüzdesi",
      "label_i18n": {
        "en": "Balon Ödeme Yüzdesi",
        "tr": "Balon Ödeme Yüzdesi",
        "de": "Balon Ödeme Yüzdesi",
        "fr": "Balon Ödeme Yüzdesi",
        "es": "Balon Ödeme Yüzdesi",
        "ar": "Balon Ödeme Yüzdesi"
      }
    }
  ],
  "formulas": {
    "compute": "function(inputs) { var P = inputs.principal; var r = inputs.annualInterestRate / 100 / 12; var n = inputs.termMonths; var B = (inputs.balloonPercent / 100) * P; var monthlyPayment = (P - B / Math.pow(1 + r, n)) * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1); var totalInterest = monthlyPayment * n + B - P; return { monthlyPayment: monthlyPayment, totalInterest: totalInterest, balloonAmount: B }; }",
    "totalInterest": "totalInterest",
    "balloonAmount": "balloonAmount"
  },
  "outputs": {
    "primary": "compute",
    "breakdown": [
      "totalInterest",
      "balloonAmount"
    ]
  },
  "category": "Vergi & Finansal Raporlama",

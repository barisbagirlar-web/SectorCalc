{
  "toolName": "mid-parental-height-calculator",
  "inputs": [
    {
      "id": "fatherHeight",
      "label": "Baba Boyu (cm)",
      "type": "number",
      "unit": "cm",
      "default": 180,
      "businessContext": "Babanın boyu santimetre cinsinden",
      "label_i18n": {
        "en": "Baba Boyu (cm)",
        "tr": "Baba Boyu (cm)",
        "de": "Baba Boyu (cm)",
        "fr": "Baba Boyu (cm)",
        "es": "Baba Boyu (cm)",
        "ar": "Baba Boyu (cm)"
      }
    },
    {
      "id": "motherHeight",
      "label": "Anne Boyu (cm)",
      "type": "number",
      "unit": "cm",
      "default": 165,
      "businessContext": "Annenin boyu santimetre cinsinden",
      "label_i18n": {
        "en": "Anne Boyu (cm)",
        "tr": "Anne Boyu (cm)",
        "de": "Anne Boyu (cm)",
        "fr": "Anne Boyu (cm)",
        "es": "Anne Boyu (cm)",
        "ar": "Anne Boyu (cm)"
      }
    },
    {
      "id": "childSex",
      "label": "Çocuk Cinsiyeti",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "0: Kiz, 1: Erkek",
      "label_i18n": {
        "en": "Çocuk Cinsiyeti",
        "tr": "Çocuk Cinsiyeti",
        "de": "Çocuk Cinsiyeti",
        "fr": "Çocuk Cinsiyeti",
        "es": "Çocuk Cinsiyeti",
        "ar": "Çocuk Cinsiyeti"
      }
    },
    {
      "id": "resultUnit",
      "label": "Sonuç Birimi",
      "type": "number",
      "unit": "none",
      "default": 0,
      "businessContext": "0: cm, 1: inç",
      "label_i18n": {
        "en": "Sonuç Birimi",
        "tr": "Sonuç Birimi",
        "de": "Sonuç Birimi",
        "fr": "Sonuç Birimi",
        "es": "Sonuç Birimi",
        "ar": "Sonuç Birimi"
      }
    }
  ],
  "formulas": {
    "midHeightCm": "childSex === 1 ? (fatherHeight + motherHeight + 13) / 2 : (fatherHeight + motherHeight - 13) / 2",
    "outputHeight": "resultUnit === 1 ? midHeightCm / 2.54 : midHeightCm",
    "outputUnit": "resultUnit === 1 ? 'inç' : 'cm'",
    "primaryText": "'Öngörülen boy: ' + outputHeight.toFixed(1) + ' ' + outputUnit",
    "breakdownStep1": "'Baba boyu: ' + fatherHeight + ' cm'",
    "breakdownStep2": "'Anne boyu: ' + motherHeight + ' cm'",
    "breakdownStep3": "'Cinsiyet: ' + (childSex === 1 ? 'Erkek' : 'Kiz')",
    "breakdownStep4": "'Formül: (baba + anne ' + (childSex === 1 ? '+ 13' : '- 13') + ') / 2'",
    "breakdownStep5": "'Hesaplanan: ' + midHeightCm.toFixed(1) + ' cm'",
    "breakdownStep6": "resultUnit === 1 ? 'İnçe çevrildi: ' + outputHeight.toFixed(1) + ' inç' : ''",
    "_breakdownStep1_": "{breakdownStep1}",
    "_breakdownStep2_": "{breakdownStep2}",
    "_breakdownStep3_": "{breakdownStep3}",
    "_breakdownStep4_": "{breakdownStep4}",
    "_breakdownStep5_": "{breakdownStep5}",
    "_breakdownStep6_": "{breakdownStep6}"
  },
  "outputs": {
    "primary": "midHeightCm",
    "breakdown": [
      "{breakdownStep1}",
      "{breakdownStep2}",
      "{breakdownStep3}",
      "{breakdownStep4}",
      "{breakdownStep5}",
      "{breakdownStep6}"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

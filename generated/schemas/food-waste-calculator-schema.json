{
  "toolName": "food-waste-calculator",
  "inputs": [
    {
      "id": "totalFoodProduced",
      "label": "Total Food Produced",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Total amount of food prepared or produced in the period.",
      "label_i18n": {
        "en": "Total Food Produced",
        "tr": "Total Food Produced",
        "de": "Total Food Produced",
        "fr": "Total Food Produced",
        "es": "Total Food Produced",
        "ar": "Total Food Produced"
      }
    },
    {
      "id": "totalFoodWasted",
      "label": "Total Food Wasted",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Total food discarded or not consumed.",
      "label_i18n": {
        "en": "Total Food Wasted",
        "tr": "Total Food Wasted",
        "de": "Total Food Wasted",
        "fr": "Total Food Wasted",
        "es": "Total Food Wasted",
        "ar": "Total Food Wasted"
      }
    },
    {
      "id": "costPerKg",
      "label": "Cost per kg",
      "type": "number",
      "unit": "currency/kg",
      "default": 0,
      "businessContext": "Average cost of food ingredients per kilogram.",
      "label_i18n": {
        "en": "Cost per kg",
        "tr": "Cost per kg",
        "de": "Cost per kg",
        "fr": "Cost per kg",
        "es": "Cost per kg",
        "ar": "Cost per kg"
      }
    },
    {
      "id": "mealsServed",
      "label": "Meals Served",
      "type": "number",
      "unit": "meals",
      "default": 0,
      "businessContext": "Number of meals served from the produced food.",
      "label_i18n": {
        "en": "Meals Served",
        "tr": "Meals Served",
        "de": "Meals Served",
        "fr": "Meals Served",
        "es": "Meals Served",
        "ar": "Meals Served"
      }
    }
  ],
  "formulas": {
    "totalWasteCost": "totalFoodWasted * costPerKg",
    "wastePercentage": "totalFoodProduced !== 0 ? (totalFoodWasted / totalFoodProduced) * 100 : 0",
    "wastePerMealKg": "mealsServed !== 0 ? totalFoodWasted / mealsServed : 0",
    "wasteCostPerMeal": "mealsServed !== 0 ? (totalFoodWasted * costPerKg) / mealsServed : 0"
  },
  "outputs": {
    "primary": "totalWasteCost",
    "breakdown": [
      "wastePercentage",
      "wasteCostPerMeal"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "wasteCostPerMeal",
    "unit": "kg",
    "breakdownUnits": {
      "wastePercentage": "%"
    }
  },

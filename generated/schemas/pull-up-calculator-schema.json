{
  "toolName": "pull-up-calculator",
  "inputs": [
    {
      "id": "loadWeight",
      "label": "Load Weight",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Weight of the load to be pulled up.",
      "label_i18n": {
        "en": "Load Weight",
        "tr": "Load Weight",
        "de": "Load Weight",
        "fr": "Load Weight",
        "es": "Load Weight",
        "ar": "Load Weight"
      }
    },
    {
      "id": "inclineAngle",
      "label": "Incline Angle",
      "type": "number",
      "unit": "°",
      "default": 30,
      "businessContext": "Angle of the incline from horizontal.",
      "label_i18n": {
        "en": "Incline Angle",
        "tr": "Incline Angle",
        "de": "Incline Angle",
        "fr": "Incline Angle",
        "es": "Incline Angle",
        "ar": "Incline Angle"
      }
    },
    {
      "id": "frictionCoefficient",
      "label": "Friction Coefficient",
      "type": "number",
      "unit": "unit",
      "default": 0.2,
      "businessContext": "Coefficient of friction between load and surface.",
      "label_i18n": {
        "en": "Friction Coefficient",
        "tr": "Friction Coefficient",
        "de": "Friction Coefficient",
        "fr": "Friction Coefficient",
        "es": "Friction Coefficient",
        "ar": "Friction Coefficient"
      }
    },
    {
      "id": "mechanicalAdvantage",
      "label": "Mechanical Advantage",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Mechanical advantage from pulley systems (1 for direct pull).",
      "label_i18n": {
        "en": "Mechanical Advantage",
        "tr": "Mechanical Advantage",
        "de": "Mechanical Advantage",
        "fr": "Mechanical Advantage",
        "es": "Mechanical Advantage",
        "ar": "Mechanical Advantage"
      }
    }
  ],
  "formulas": {
    "gravitationalForceComponent": "loadWeight * 9.81 * Math.sin(inclineAngle * Math.PI / 180)",
    "frictionForce": "frictionCoefficient * loadWeight * 9.81 * Math.cos(inclineAngle * Math.PI / 180)",
    "totalRequiredForce": "(gravitationalForceComponent + frictionForce) / mechanicalAdvantage"
  },
  "outputs": {
    "primary": "totalRequiredForce",
    "breakdown": [
      "gravitationalForceComponent",
      "frictionForce",
      "totalRequiredForce"
    ]
  },
  "category": "Makine & Tasarım",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "categorySlug": "cnc-additive-manufacturing",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",

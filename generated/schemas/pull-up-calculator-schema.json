{
  "toolName": "pull-up-calculator",
  "inputs": [
    {
      "id": "loadWeight",
      "label": "Load Weight",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Weight of the load to be pulled up."
    },
    {
      "id": "inclineAngle",
      "label": "Incline Angle",
      "type": "number",
      "unit": "°",
      "default": 30,
      "businessContext": "Angle of the incline from horizontal."
    },
    {
      "id": "frictionCoefficient",
      "label": "Friction Coefficient",
      "type": "number",
      "unit": "",
      "default": 0.2,
      "businessContext": "Coefficient of friction between load and surface."
    },
    {
      "id": "mechanicalAdvantage",
      "label": "Mechanical Advantage",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Mechanical advantage from pulley systems (1 for direct pull)."
    }
  ],
  "formulas": {
    "gravitationalForceComponent": "loadWeight * 9.81 * Math.sin(inclineAngle * Math.PI / 180)",
    "frictionForce": "frictionCoefficient * loadWeight * 9.81 * Math.cos(inclineAngle * Math.PI / 180)",
    "totalRequiredForce": "(gravitationalForceComponent + frictionForce) / mechanicalAdvantage"
  },
  "outputs": {
    "primary": "totalRequiredForce",
    "breakdown": [
      "gravitationalForceComponent",
      "frictionForce",
      "totalRequiredForce"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
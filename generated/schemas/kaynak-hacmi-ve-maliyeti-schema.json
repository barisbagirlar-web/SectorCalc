  "formulas": {
    "Area_Weld": "(Leg^2) / 2",
    "Volume_Weld": "Area_Weld * Length",
    "Weight_Deposited": "Volume_Weld * Density",
    "Weight_Electrode": "Weight_Deposited / DepositionEfficiency",
    "Cost_Filler": "Weight_Electrode * PricePerKg",
    "Cost_Gas": "GasFlowRate * ArcTime * GasPrice",
    "Cost_Power": "(Voltage * Current * ArcTime) / (1000 * MachineEff) * ElecRate",
    "TotalWeldCost": "Cost_Filler + Cost_Gas + Cost_Power + (ArcTime / DepositionRate) * LaborRate"
  },

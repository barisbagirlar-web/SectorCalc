    },
    {
      "id": "costPerPlate",
      "label": "Cost Per Plate",
      "type": "number",
      "unit": "TRY/guest",
      "default": 200,
      "businessContext": "Cost of food per guest.",
      "label_i18n": {
        "en": "Cost Per Plate",
        "tr": "Tabak Başına Maliyet",
        "de": "Kosten pro Teller",

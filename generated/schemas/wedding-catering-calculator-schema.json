{
  "toolName": "wedding-catering-calculator",
  "inputs": [
    {
      "id": "guestCount",
      "label": "Guest Count",
      "type": "number",
      "unit": "guests",
      "default": 100,
      "businessContext": "Number of guests attending the wedding.",
      "label_i18n": {
        "en": "Guest Count",
        "tr": "Guest Count",
        "de": "Guest Count",
        "fr": "Guest Count",
        "es": "Guest Count",
        "ar": "Guest Count"
      }
    },
    {
      "id": "costPerPlate",
      "label": "Cost Per Plate",
      "type": "number",
      "unit": "TRY/guest",
      "default": 200,
      "businessContext": "Cost of food per guest.",
      "label_i18n": {
        "en": "Cost Per Plate",
        "tr": "Cost Per Plate",
        "de": "Cost Per Plate",
        "fr": "Cost Per Plate",
        "es": "Cost Per Plate",
        "ar": "Cost Per Plate"
      }
    },
    {
      "id": "drinksPerGuest",
      "label": "Drinks Cost Per Guest",
      "type": "number",
      "unit": "TRY/guest",
      "default": 50,
      "businessContext": "Cost of beverages per guest.",
      "label_i18n": {
        "en": "Drinks Cost Per Guest",
        "tr": "Drinks Cost Per Guest",
        "de": "Drinks Cost Per Guest",
        "fr": "Drinks Cost Per Guest",
        "es": "Drinks Cost Per Guest",
        "ar": "Drinks Cost Per Guest"
      }
    },
    {
      "id": "serviceChargePercent",
      "label": "Service Charge",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Service charge percentage applied to food and drinks subtotal.",
      "label_i18n": {
        "en": "Service Charge",
        "tr": "Service Charge",
        "de": "Service Charge",
        "fr": "Service Charge",
        "es": "Service Charge",
        "ar": "Service Charge"
      }
    }
  ],
  "formulas": {
    "totalFoodCost": "guestCount * costPerPlate",
    "totalDrinksCost": "guestCount * drinksPerGuest",
    "serviceCharge": "(totalFoodCost + totalDrinksCost) * serviceChargePercent / 100",
    "totalCost": "totalFoodCost + totalDrinksCost + serviceCharge",
    "costPerGuest": "totalCost / guestCount"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalFoodCost",
      "totalDrinksCost",
      "serviceCharge",
      "costPerGuest"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerGuest"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,

{
  "toolName": "wedding-catering-calculator",
  "inputs": [
    {
      "id": "guestCount",
      "label": "Guest Count",
      "type": "number",
      "unit": "guests",
      "default": 100,
      "businessContext": "Number of guests attending the wedding.",

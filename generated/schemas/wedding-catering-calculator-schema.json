    },
    {
      "id": "drinksPerGuest",
      "label": "Drinks Cost Per Guest",
      "type": "number",
      "unit": "TRY/guest",
      "default": 50,
      "businessContext": "Cost of beverages per guest.",
      "label_i18n": {
        "en": "Drinks Cost Per Guest",
        "tr": "Misafir Başına İçecek Maliyeti",
        "de": "Getränkekosten pro Gast",
        "fr": "Coût des boissons par invité",
        "es": "Costo de bebidas por invitado",
        "ar": "تكلفة المشروبات لكل ضيف"
      },
      "businessContext_i18n": {
        "en": "Cost of beverages per guest.",
        "tr": "Misafir başına içecek maliyeti.",
        "de": "Kosten für Getränke pro Gast.",
        "fr": "Coût des boissons par invité.",
        "es": "Coste de bebidas por invitado.",
        "ar": "تكلفة المشروبات لكل ضيف."
      }
    },
    {
      "id": "serviceChargePercent",
      "label": "Service Charge",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Service charge percentage applied to food and drinks subtotal.",
      "label_i18n": {
        "en": "Service Charge",
        "tr": "Servis Ücreti",
        "de": "Servicegebühr",
        "fr": "Frais de service",
        "es": "Cargo por servicio",
        "ar": "رسوم الخدمة"
      },
      "businessContext_i18n": {
        "en": "Service charge percentage applied to food and drinks subtotal.",
        "tr": "Yiyecek ve içecek ara toplamına uygulanan hizmet ücreti yüzdesi.",
        "de": "Prozentsatz der Servicegebühr auf die Zwischensumme von Speisen und Getränken.",
        "fr": "Pourcentage de frais de service appliqué au sous-total des aliments et boissons.",
        "es": "Porcentaje de cargo por servicio aplicado al subtotal de comida y bebidas.",
        "ar": "نسبة رسوم الخدمة المطبقة على إجمالي الطعام والمشروبات."
      }
    }
  ],
  "formulas": {
    "totalFoodCost": "guestCount * costPerPlate",
    "totalDrinksCost": "guestCount * drinksPerGuest",
    "serviceCharge": "(totalFoodCost + totalDrinksCost) * serviceChargePercent / 100",
    "totalCost": "totalFoodCost + totalDrinksCost + serviceCharge",
    "costPerGuest": "totalCost / guestCount"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalFoodCost",
      "totalDrinksCost",
      "serviceCharge",
      "costPerGuest"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerGuest",
    "unit": "guests"
  },

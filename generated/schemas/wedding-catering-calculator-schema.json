        "ar": "تكلفة الطبق الواحد"
      },
      "businessContext_i18n": {
        "en": "Cost of food per guest.",
        "tr": "Misafir başına yiyecek maliyeti.",
        "de": "Lebensmittelkosten pro Gast.",

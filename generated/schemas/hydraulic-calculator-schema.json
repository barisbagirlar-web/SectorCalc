  "formulas": {
    "power": "(pressure * flowRate) / (600 * (efficiency / 100))",
    "pushForce": "(pressure * Math.PI * boreDia**2) / 40000",
    "pullForce": "(pressure * Math.PI * (boreDia**2 - rodDia**2)) / 40000"
  },
  "outputs": {
    "primary": "power",
    "breakdown": [

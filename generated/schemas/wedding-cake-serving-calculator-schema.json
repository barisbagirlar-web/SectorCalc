{
  "toolName": "wedding-cake-serving-calculator",
  "inputs": [
    {
      "id": "shape",
      "label": "Cake Shape (0=Round, 1=Square)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Select shape: 0 for round tiers, 1 for square tiers.",
      "label_i18n": {
        "en": "Cake Shape (0=Round, 1=Square)",
        "tr": "Cake Shape (0=Round, 1=Square)",
        "de": "Cake Shape (0=Round, 1=Square)",
        "fr": "Cake Shape (0=Round, 1=Square)",
        "es": "Cake Shape (0=Round, 1=Square)",
        "ar": "Cake Shape (0=Round, 1=Square)"
      }
    },
    {
      "id": "tier1Diameter",
      "label": "Tier 1 Diameter/Side",
      "type": "number",
      "unit": "in",
      "default": 6,
      "businessContext": "Diameter for round or side length for square tier.",
      "label_i18n": {
        "en": "Tier 1 Diameter/Side",
        "tr": "Tier 1 Diameter/Side",
        "de": "Tier 1 Diameter/Side",
        "fr": "Tier 1 Diameter/Side",
        "es": "Tier 1 Diameter/Side",
        "ar": "Tier 1 Diameter/Side"
      }
    },
    {
      "id": "tier2Diameter",
      "label": "Tier 2 Diameter/Side",
      "type": "number",
      "unit": "in",
      "default": 0,
      "businessContext": "Enter 0 if no second tier.",
      "label_i18n": {
        "en": "Tier 2 Diameter/Side",
        "tr": "Tier 2 Diameter/Side",
        "de": "Tier 2 Diameter/Side",
        "fr": "Tier 2 Diameter/Side",
        "es": "Tier 2 Diameter/Side",
        "ar": "Tier 2 Diameter/Side"
      }
    },
    {
      "id": "tier3Diameter",
      "label": "Tier 3 Diameter/Side",
      "type": "number",
      "unit": "in",
      "default": 0,
      "businessContext": "Enter 0 if no third tier.",
      "label_i18n": {
        "en": "Tier 3 Diameter/Side",
        "tr": "Tier 3 Diameter/Side",
        "de": "Tier 3 Diameter/Side",
        "fr": "Tier 3 Diameter/Side",
        "es": "Tier 3 Diameter/Side",
        "ar": "Tier 3 Diameter/Side"
      }
    },
    {
      "id": "servingSize",
      "label": "Serving Size (sq in)",
      "type": "number",
      "unit": "sq in",
      "default": 2,
      "businessContext": "Typical wedding serving is 1x2 inches = 2 sq in.",
      "label_i18n": {
        "en": "Serving Size (sq in)",
        "tr": "Serving Size (sq in)",
        "de": "Serving Size (sq in)",
        "fr": "Serving Size (sq in)",
        "es": "Serving Size (sq in)",
        "ar": "Serving Size (sq in)"
      }
    },
    {
      "id": "guestCount",
      "label": "Guest Count",
      "type": "number",
      "unit": "people",
      "default": 100,
      "businessContext": "Number of guests to serve. Used to compute surplus.",
      "label_i18n": {
        "en": "Guest Count",
        "tr": "Guest Count",
        "de": "Guest Count",
        "fr": "Guest Count",
        "es": "Guest Count",
        "ar": "Guest Count"
      }
    }
  ],
  "formulas": {
    "serv1": "tier1Diameter > 0 ? (shape == 0 ? Math.PI * Math.pow(tier1Diameter, 2) / (4 * servingSize) : Math.pow(tier1Diameter, 2) / servingSize) : 0",
    "serv2": "tier2Diameter > 0 ? (shape == 0 ? Math.PI * Math.pow(tier2Diameter, 2) / (4 * servingSize) : Math.pow(tier2Diameter, 2) / servingSize) : 0",
    "serv3": "tier3Diameter > 0 ? (shape == 0 ? Math.PI * Math.pow(tier3Diameter, 2) / (4 * servingSize) : Math.pow(tier3Diameter, 2) / servingSize) : 0",
    "totalServings": "serv1 + serv2 + serv3",
    "surplus": "totalServings - guestCount"
  },
  "outputs": {
    "primary": "totalServings",
    "breakdown": [
      "serv1",
      "serv2",
      "serv3",
      "surplus"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

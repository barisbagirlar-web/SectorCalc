    "stakeB": "(totalStake * (1/oddsB)) / (1/oddsA + 1/oddsB + 1/oddsC + 1/oddsD)",
    "stakeC": "(totalStake * (1/oddsC)) / (1/oddsA + 1/oddsB + 1/oddsC + 1/oddsD)",
    "stakeD": "(totalStake * (1/oddsD)) / (1/oddsA + 1/oddsB + 1/oddsC + 1/oddsD)"

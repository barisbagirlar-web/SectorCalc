      }
    },
    {
      "id": "loadMagnitude",
      "label": "Point Load",
      "type": "number",
      "unit": "kN",
      "default": 100,
      "businessContext": "Magnitude of the concentrated load",
      "label_i18n": {
        "en": "Point Load",
        "tr": "Point Load",
        "de": "Point Load",
        "fr": "Point Load",
        "es": "Point Load",
        "ar": "Point Load"
      }
    },
    {
      "id": "loadDistanceFromLeft",
      "label": "Load Distance from Left",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Distance from left support to the load application point",
      "label_i18n": {
        "en": "Load Distance from Left",
        "tr": "Load Distance from Left",
        "de": "Load Distance from Left",
        "fr": "Load Distance from Left",
        "es": "Load Distance from Left",
        "ar": "Load Distance from Left"
      }
    },
    {
      "id": "calculationPoint",
      "label": "Shear Force Location",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Distance from left support at which shear force is evaluated",
      "label_i18n": {
        "en": "Shear Force Location",
        "tr": "Shear Force Location",
        "de": "Shear Force Location",
        "fr": "Shear Force Location",
        "es": "Shear Force Location",
        "ar": "Shear Force Location"
      }
    }
  ],
  "formulas": {
    "leftReaction": "(loadMagnitude * (beamLength - loadDistanceFromLeft)) / beamLength",
    "rightReaction": "(loadMagnitude * loadDistanceFromLeft) / beamLength",
    "shearForce": "calculationPoint <= loadDistanceFromLeft ? (loadMagnitude * (beamLength - loadDistanceFromLeft)) / beamLength : -(loadMagnitude * loadDistanceFromLeft) / beamLength"
  },
  "outputs": {
    "primary": "shearForce",
    "breakdown": [
      "leftReaction",
      "rightReaction",
      "maxShearForce"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "maxShearForce",
    "unit": "m"
  },

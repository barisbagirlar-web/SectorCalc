{
  "toolName": "shear-force-diagram-calculator",
  "inputs": [
    {
      "id": "beamLength",
      "label": "Beam Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Length of the beam between supports",
      "label_i18n": {
        "en": "Beam Length",
        "tr": "Beam Length",

{
  "toolName": "weight-watchers-points-calculator",
  "inputs": [
    {
      "id": "calories",
      "label": "Calories",
      "type": "number",
      "unit": "kcal",
      "default": 0,
      "businessContext": "Total energy content per serving."
    },
    {
      "id": "saturatedFat",
      "label": "Saturated Fat",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Grams of saturated fat per serving."
    },
    {
      "id": "sugar",
      "label": "Sugar",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Grams of sugar per serving."
    },
    {
      "id": "protein",
      "label": "Protein",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Grams of protein per serving."
    }
  ],
  "formulas": {
    "rawPoints": "calories * 0.0305 + saturatedFat * 0.275 + sugar * 0.12 - protein * 0.098",
    "points": "Math.round(Math.max(0, rawPoints))",
    "caloriesContrib": "calories * 0.0305",
    "saturatedFatContrib": "saturatedFat * 0.275",
    "sugarContrib": "sugar * 0.12",
    "proteinContrib": "protein * 0.098"
  },
  "outputs": {
    "primary": "points",
    "breakdown": [
      "rawPoints",
      "caloriesContrib",
      "saturatedFatContrib",
      "sugarContrib",
      "proteinContrib"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false
}
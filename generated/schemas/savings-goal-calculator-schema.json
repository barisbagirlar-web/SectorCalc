{
  "toolName": "savings-goal-calculator",
  "inputs": [
    {
      "id": "currentSavings",
      "label": "Current Savings",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "The amount of money already saved.",
      "label_i18n": {
        "en": "Current Savings",
        "tr": "Current Savings",
        "de": "Current Savings",
        "fr": "Current Savings",
        "es": "Current Savings",
        "ar": "Current Savings"
      }
    },
    {
      "id": "monthlyContribution",
      "label": "Monthly Contribution",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "Amount added to savings each month.",
      "label_i18n": {
        "en": "Monthly Contribution",
        "tr": "Monthly Contribution",
        "de": "Monthly Contribution",
        "fr": "Monthly Contribution",
        "es": "Monthly Contribution",
        "ar": "Monthly Contribution"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected annual rate of return on savings.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "numberOfYears",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time horizon for savings goal.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Number of Years",
        "de": "Number of Years",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      }
    },
    {
      "id": "goalAmount",
      "label": "Goal Amount",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "The target amount you want to save.",
      "label_i18n": {
        "en": "Goal Amount",
        "tr": "Goal Amount",
        "de": "Goal Amount",
        "fr": "Goal Amount",
        "es": "Goal Amount",
        "ar": "Goal Amount"
      }
    }
  ],
  "formulas": {
    "monthlyRate": "annualInterestRate / 100 / 12",
    "totalFutureValue": "currentSavings * (1 + monthlyRate) ** (numberOfYears * 12) + monthlyContribution * (((1 + monthlyRate) ** (numberOfYears * 12) - 1) / monthlyRate)",
    "totalContributions": "currentSavings + monthlyContribution * numberOfYears * 12",
    "interestEarned": "totalFutureValue - totalContributions",
    "goalDifference": "totalFutureValue - goalAmount"
  },
  "outputs": {
    "primary": "totalFutureValue",
    "breakdown": [
      "totalContributions",
      "interestEarned",
      "goalDifference"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "goalDifference"
  },
  "category": "Diğer",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,

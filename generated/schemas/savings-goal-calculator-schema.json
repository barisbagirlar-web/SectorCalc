      }
    },
    {
      "id": "numberOfYears",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time horizon for savings goal.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Yıl Sayısı",
        "de": "Anzahl der Jahre",

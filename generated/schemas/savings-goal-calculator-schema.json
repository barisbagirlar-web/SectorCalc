      },
      "businessContext_i18n": {
        "en": "Time horizon for savings goal.",
        "tr": "Tasarruf hedefi için zaman ufku.",
        "de": "Zeithorizont für Sparziel.",
        "fr": "Horizon temporel pour l'objectif d'épargne.",
        "es": "Horizonte temporal para el objetivo de ahorro.",
        "ar": "الأفق الزمني لهدف الادخار"
      }
    },
    {
      "id": "goalAmount",
      "label": "Goal Amount",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "The target amount you want to save.",
      "label_i18n": {
        "en": "Goal Amount",
        "tr": "Hedef Miktar",
        "de": "Zielbetrag",
        "fr": "Montant objectif",
        "es": "Monto objetivo",
        "ar": "المبلغ المستهدف"
      },
      "businessContext_i18n": {
        "en": "The target amount you want to save.",
        "tr": "Biriktirmek istediğiniz hedef tutar.",
        "de": "Der Zielbetrag, den Sie sparen möchten.",
        "fr": "Le montant cible que vous souhaitez économiser.",
        "es": "La cantidad objetivo que desea ahorrar.",
        "ar": "المبلغ المستهدف الذي تريد ادخاره"
      }
    }
  ],
  "formulas": {
    "monthlyRate": "annualInterestRate / 100 / 12",
    "totalFutureValue": "currentSavings * (1 + monthlyRate) ** (numberOfYears * 12) + monthlyContribution * (((1 + monthlyRate) ** (numberOfYears * 12) - 1) / monthlyRate)",
    "totalContributions": "currentSavings + monthlyContribution * numberOfYears * 12",
    "interestEarned": "totalFutureValue - totalContributions",
    "goalDifference": "totalFutureValue - goalAmount"
  },
  "outputs": {
    "primary": "totalFutureValue",
    "breakdown": [
      "totalContributions",
      "interestEarned",
      "goalDifference"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "goalDifference",
    "unit": "currency"
  },

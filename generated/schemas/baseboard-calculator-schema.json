  "formulas": {
    "perimeter": "2 * (roomLength + roomWidth)",
    "doorTotalWidth": "numberOfDoors * doorWidth",
    "netLength": "perimeter - doorTotalWidth",
    "withWaste": "netLength * (1 + wasteFactor/100)",
    "wasteLength": "withWaste - netLength"
  },

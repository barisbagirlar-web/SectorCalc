      "label_i18n": {
        "en": "Parts Cost per Incident"
      },
      "businessContext_i18n": {
        "en": "Average cost of spare parts per maintenance event."
      }
    },
    {
      "id": "downtime_cost_per_hour",
      "label": "Downtime Cost per Hour",
      "type": "number",
      "unit": "USD/hour",
      "default": 1000,

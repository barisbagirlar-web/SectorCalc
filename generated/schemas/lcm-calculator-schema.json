    {
      "id": "energy_cost_per_kwh",
      "label": "Energy Cost per kWh",
      "type": "number",
      "unit": "USD/kWh",
      "default": 0.12,
      "min": 0,
      "max": 1,
      "businessContext": "Cost of electricity per kilowatt-hour.",
      "label_i18n": {
        "en": "Energy Cost per kWh"
      },
      "businessContext_i18n": {
        "en": "Cost of electricity per kilowatt-hour."

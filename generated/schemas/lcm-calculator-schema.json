  "validation": {
    "rules": [
      {
        "id": "life_years_positive",
        "condition": "expected_life_years > 0",
        "message": "Expected life must be greater than 0 years."
      },
      {
        "id": "operating_hours_range",
        "condition": "annual_operating_hours >= 0 AND annual_operating_hours <= 8760",
        "message": "Annual operating hours must be between 0 and 8760."
      },
      {
        "id": "acquisition_cost_positive",
        "condition": "acquisition_cost >= 0",
        "message": "Acquisition cost cannot be negative."
      },
      {
        "id": "discount_rate_positive",
        "condition": "discount_rate >= 0",
        "message": "Discount rate must be non-negative."
      },
      {
        "id": "data_confidence_range",
        "condition": "data_confidence >= 0 AND data_confidence <= 100",
        "message": "Data confidence must be between 0 and 100."
      }
    ],
    "thresholds": [
      {
        "id": "high_maintenance_cost_ratio",
        "condition": "total_maintenance_cost / acquisition_cost > 0.5",
        "level": "warning",
        "message": "Total maintenance cost exceeds 50% of acquisition cost. Consider asset replacement or strategy review."
      },
      {
        "id": "excessive_downtime_cost",
        "condition": "downtime_cost > 0.3 * total_life_cycle_cost",
        "level": "critical",
        "message": "Downtime cost exceeds 30% of total life cycle cost. Investigate reliability improvements."
      },
      {
        "id": "low_data_confidence",
        "condition": "data_confidence < 50",
        "level": "warning",
        "message": "Data confidence is low. Results may be unreliable. Consider data validation."
      }
    ]
  },
  "formulas": {
    "result": "acquisition_cost + expected_life_years + annual_operating_hours",
    "result_copy": "acquisition_cost + expected_life_years + annual_operating_hours"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result",
    "unit": "USD"
  },

      "businessContext": "Planned useful life of the asset per ISO 15686.",
      "label_i18n": {
        "en": "Expected Life (Years)"
      },
      "businessContext_i18n": {
        "en": "Planned useful life of the asset per ISO 15686."
      }
    },
    {

{
  "toolName": "points-calculator",
  "inputs": [
    {
      "id": "purchaseAmount",
      "label": "Purchase Amount",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "The total amount spent in the transaction.",
      "label_i18n": {
        "en": "Purchase Amount",
        "tr": "Purchase Amount",
        "de": "Purchase Amount",
        "fr": "Purchase Amount",
        "es": "Purchase Amount",
        "ar": "Purchase Amount"
      }
    },
    {
      "id": "basePointsRate",
      "label": "Base Points Rate",
      "type": "number",
      "unit": "points/currency",
      "default": 1,
      "businessContext": "Points earned per unit of currency spent before multipliers.",
      "label_i18n": {
        "en": "Base Points Rate",
        "tr": "Base Points Rate",
        "de": "Base Points Rate",
        "fr": "Base Points Rate",
        "es": "Base Points Rate",
        "ar": "Base Points Rate"
      }
    },
    {
      "id": "tierMultiplier",
      "label": "Tier Multiplier",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Multiplier based on customer loyalty tier (e.g., 1 for base, 1.5 for silver, 2 for gold).",
      "label_i18n": {
        "en": "Tier Multiplier",
        "tr": "Tier Multiplier",
        "de": "Tier Multiplier",
        "fr": "Tier Multiplier",
        "es": "Tier Multiplier",
        "ar": "Tier Multiplier"
      }
    },
    {
      "id": "bonusPoints",
      "label": "Bonus Points",
      "type": "number",
      "unit": "points",
      "default": 0,
      "businessContext": "Additional flat bonus points from promotions or campaigns.",
      "label_i18n": {
        "en": "Bonus Points",
        "tr": "Bonus Points",
        "de": "Bonus Points",
        "fr": "Bonus Points",
        "es": "Bonus Points",
        "ar": "Bonus Points"
      }
    },
    {
      "id": "capPoints",
      "label": "Points Cap",
      "type": "number",
      "unit": "points",
      "default": 1000,
      "businessContext": "Maximum points that can be earned in this transaction; 0 for no cap.",
      "label_i18n": {
        "en": "Points Cap",
        "tr": "Points Cap",
        "de": "Points Cap",
        "fr": "Points Cap",
        "es": "Points Cap",
        "ar": "Points Cap"
      }
    },
    {
      "id": "pointsConversionRate",
      "label": "Points to Currency Conversion",
      "type": "number",
      "unit": "currency/point",
      "default": 0.01,
      "businessContext": "Value of one point when redeemed (e.g., 0.01 means 1 point = 0.01 currency).",
      "label_i18n": {
        "en": "Points to Currency Conversion",
        "tr": "Points to Currency Conversion",
        "de": "Points to Currency Conversion",
        "fr": "Points to Currency Conversion",
        "es": "Points to Currency Conversion",
        "ar": "Points to Currency Conversion"
      }
    }
  ],
  "formulas": {
    "basePointsEarned": "purchaseAmount * basePointsRate",
    "totalBeforeCap": "basePointsEarned * tierMultiplier + bonusPoints"
  },
  "outputs": {
    "primary": "totalBeforeCap",
    "breakdown": [
      "basePointsEarned",
      "monetaryValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "monetaryValue"
  },

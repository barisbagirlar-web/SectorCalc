      "id": "annualPropertyTax",
      "label": "Annual Property Tax",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "The total property tax for the full year as assessed by the local government.",
      "label_i18n": {
        "en": "Annual Property Tax",
        "tr": "Annual Property Tax",
        "de": "Annual Property Tax",
        "fr": "Annual Property Tax",

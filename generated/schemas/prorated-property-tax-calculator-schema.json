        "ar": "Annual Property Tax"
      }
    },
    {
      "id": "daysInTaxYear",
      "label": "Days in Tax Year",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "The number of days in the tax year (typically 365, or 366 for a leap year).",
      "label_i18n": {
        "en": "Days in Tax Year",
        "tr": "Days in Tax Year",
        "de": "Days in Tax Year",
        "fr": "Days in Tax Year",
        "es": "Days in Tax Year",
        "ar": "Days in Tax Year"
      }
    },
    {
      "id": "daysOwned",
      "label": "Days Owned",
      "type": "number",
      "unit": "days",
      "default": 0,
      "businessContext": "Number of days the property was owned during the tax year.",
      "label_i18n": {
        "en": "Days Owned",
        "tr": "Days Owned",
        "de": "Days Owned",
        "fr": "Days Owned",
        "es": "Days Owned",
        "ar": "Days Owned"
      }
    },
    {
      "id": "otherFees",
      "label": "Other Fees",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Any additional fees or adjustments (e.g., closing costs, penalties, credits).",
      "label_i18n": {
        "en": "Other Fees",
        "tr": "Other Fees",
        "de": "Other Fees",
        "fr": "Other Fees",
        "es": "Other Fees",
        "ar": "Other Fees"
      }
    }
  ],
  "formulas": {
    "dailyTax": "annualPropertyTax / daysInTaxYear",
    "proratedTax": "dailyTax * daysOwned",
    "totalTaxDue": "proratedTax + otherFees"
  },
  "outputs": {
    "primary": "proratedTax",
    "breakdown": [

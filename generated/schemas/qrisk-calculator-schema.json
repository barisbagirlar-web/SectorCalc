    },
    {
      "id": "totalCholesterol",
      "label": "Total Cholesterol",
      "type": "number",
      "unit": "mg/dL",
      "default": 200,
      "businessContext": "Total cholesterol level",
      "label_i18n": {
        "en": "Total Cholesterol",
        "tr": "Total Cholesterol",
        "de": "Total Cholesterol",
        "fr": "Total Cholesterol",
        "es": "Total Cholesterol",
        "ar": "Total Cholesterol"
      }
    },
    {
      "id": "hdlCholesterol",
      "label": "HDL Cholesterol",
      "type": "number",
      "unit": "mg/dL",
      "default": 50,
      "businessContext": "High-density lipoprotein cholesterol",
      "label_i18n": {
        "en": "HDL Cholesterol",
        "tr": "HDL Cholesterol",
        "de": "HDL Cholesterol",
        "fr": "HDL Cholesterol",
        "es": "HDL Cholesterol",
        "ar": "HDL Cholesterol"
      }
    },
    {
      "id": "smoker",
      "label": "Smoking Status (0/1)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Current smoker (yes=1, no=0)",
      "label_i18n": {
        "en": "Smoking Status (0/1)",
        "tr": "Smoking Status (0/1)",
        "de": "Smoking Status (0/1)",
        "fr": "Smoking Status (0/1)",
        "es": "Smoking Status (0/1)",
        "ar": "Smoking Status (0/1)"
      }
    },
    {
      "id": "diabetes",
      "label": "Diabetes Status (0/1)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Diabetes diagnosis (yes=1, no=0)",
      "label_i18n": {
        "en": "Diabetes Status (0/1)",
        "tr": "Diabetes Status (0/1)",
        "de": "Diabetes Status (0/1)",
        "fr": "Diabetes Status (0/1)",
        "es": "Diabetes Status (0/1)",
        "ar": "Diabetes Status (0/1)"
      }
    }
  ],
  "formulas": {
    "beta": "-5.5 + 0.05 * age + 0.01 * systolicBP + 0.005 * totalCholesterol - 0.008 * hdlCholesterol + 0.5 * smoker + 0.3 * diabetes",
    "risk": "1 - Math.exp(-Math.exp(beta))",
    "percentage": "risk * 100"
  },
  "outputs": {
    "primary": "percentage",
    "breakdown": [
      "risk",
      "percentage"
    ]
  },

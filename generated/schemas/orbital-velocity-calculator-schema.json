{
  "toolName": "orbital-velocity-calculator",
  "inputs": [
    {
      "id": "centralBodyMass",
      "label": "Central Body Mass",
      "type": "number",
      "unit": "kg",
      "default": 5.972e+24,
      "businessContext": "Mass of the central body (e.g., Earth: 5.972×10^24 kg)",
      "label_i18n": {
        "en": "Central Body Mass",
        "tr": "Central Body Mass",
        "de": "Central Body Mass",
        "fr": "Central Body Mass",
        "es": "Central Body Mass",
        "ar": "Central Body Mass"
      }
    },
    {
      "id": "centralBodyRadius",
      "label": "Central Body Radius",
      "type": "number",
      "unit": "m",
      "default": 6371000,
      "businessContext": "Radius of the central body (e.g., Earth: 6,371,000 m)",
      "label_i18n": {
        "en": "Central Body Radius",
        "tr": "Central Body Radius",
        "de": "Central Body Radius",
        "fr": "Central Body Radius",
        "es": "Central Body Radius",
        "ar": "Central Body Radius"
      }
    },
    {
      "id": "altitude",
      "label": "Orbit Altitude",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Altitude of the satellite above the central body's surface",
      "label_i18n": {
        "en": "Orbit Altitude",
        "tr": "Orbit Altitude",
        "de": "Orbit Altitude",
        "fr": "Orbit Altitude",
        "es": "Orbit Altitude",
        "ar": "Orbit Altitude"
      }
    },
    {
      "id": "gravitationalConstant",
      "label": "Gravitational Constant",
      "type": "number",
      "unit": "m^3/(kg·s^2)",
      "default": 6.6743e-11,
      "businessContext": "Universal gravitational constant (G = 6.67430×10^-11 m^3/(kg·s^2))",
      "label_i18n": {
        "en": "Gravitational Constant",
        "tr": "Gravitational Constant",
        "de": "Gravitational Constant",
        "fr": "Gravitational Constant",
        "es": "Gravitational Constant",
        "ar": "Gravitational Constant"
      }
    }
  ],
  "formulas": {
    "orbitalVelocity_mps": "Math.sqrt((gravitationalConstant * centralBodyMass) / (centralBodyRadius + altitude))",
    "orbitalVelocity_kmps": "orbitalVelocity_mps / 1000",
    "orbitalPeriod_s": "2 * Math.PI * (centralBodyRadius + altitude) / orbitalVelocity_mps"
  },
  "outputs": {
    "primary": "orbitalVelocity_mps",
    "breakdown": [
      {
        "label": "Orbital Velocity (km/s)",
        "value": "orbitalVelocity_kmps",
        "unit": "km/s"
      },
      {
        "label": "Orbital Period",
        "value": "orbitalPeriod_s",
        "unit": "s"
      }
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",

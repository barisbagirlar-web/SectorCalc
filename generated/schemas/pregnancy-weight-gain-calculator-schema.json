{
  "toolName": "pregnancy-weight-gain-calculator",
  "inputs": [
    {
      "id": "prePregnancyWeight",
      "label": "Pre-pregnancy Weight",
      "type": "number",
      "unit": "kg",
      "default": 60,
      "businessContext": "Weight before pregnancy",
      "label_i18n": {
        "en": "Pre-pregnancy Weight",
        "tr": "Gebelik Öncesi Ağırlık",
        "de": "Pre-pregnancy Weight",
        "fr": "Pre-pregnancy Weight",
        "es": "Pre-pregnancy Weight",
        "ar": "Pre-pregnancy Weight"
      },
      "businessContext_i18n": {
        "en": "Weight before pregnancy",
        "tr": "Hamilelik öncesi ağırlık"
      }
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 165,
      "businessContext": "Height for BMI calculation",
      "label_i18n": {
        "en": "Height",
        "tr": "Boy",
        "de": "Größe",
        "fr": "Height",
        "es": "Height",
        "ar": "Height"
      },
      "businessContext_i18n": {
        "en": "Height for BMI calculation",
        "tr": "VKİ hesaplaması için boy"
      }
    },
    {
      "id": "currentWeight",
      "label": "Current Weight",
      "type": "number",
      "unit": "kg",
      "default": 65,
      "businessContext": "Current weight during pregnancy",
      "label_i18n": {
        "en": "Current Weight",
        "tr": "Mevcut Ağırlık",
        "de": "Aktuelles Gewicht",
        "fr": "Current Weight",
        "es": "Current Weight",
        "ar": "Current Weight"
      },
      "businessContext_i18n": {
        "en": "Current weight during pregnancy",
        "tr": "Hamilelik sırasında mevcut ağırlık"
      }
    },
    {
      "id": "currentWeek",
      "label": "Current Week of Pregnancy",
      "type": "number",
      "unit": "weeks",
      "default": 20,
      "businessContext": "Current gestational week",
      "label_i18n": {
        "en": "Current Week of Pregnancy",
        "tr": "Mevcut Hamilelik Haftası",
        "de": "Current Week of Pregnancy",
        "fr": "Current Week of Pregnancy",
        "es": "Current Week of Pregnancy",
        "ar": "Current Week of Pregnancy"
      },
      "businessContext_i18n": {
        "en": "Current gestational week",
        "tr": "Mevcut gebelik haftası"
      }
    }
  ],
  "formulas": {
    "bmi": "prePregnancyWeight / ((height / 100) ** 2)",
    "totalMinGain": "bmi < 18.5 ? 12.5 : bmi < 25 ? 11.5 : bmi < 30 ? 7 : 5",
    "totalMaxGain": "bmi < 18.5 ? 18 : bmi < 25 ? 16 : bmi < 30 ? 11.5 : 9",
    "minGainCurrent": "totalMinGain * (currentWeek / 40)",
    "maxGainCurrent": "totalMaxGain * (currentWeek / 40)",
    "recommendedMinWeight": "prePregnancyWeight + minGainCurrent",
    "recommendedMaxWeight": "prePregnancyWeight + maxGainCurrent",
    "weightGained": "currentWeight - prePregnancyWeight"
  },
  "outputs": {
    "primary": "weightGained",
    "breakdown": [
      "Current Weight: ${currentWeight} kg",
      "Recommended Weight Range: ${recommendedMinWeight.toFixed(1)} - ${recommendedMaxWeight.toFixed(1)} kg",
      "BMI: ${bmi.toFixed(1)}",
      "BMI Category: ${bmiCategory}",
      "Total Recommended Gain: ${totalMinGain} - ${totalMaxGain} kg",
      "Weight Gained So Far: ${weightGained} kg",
      "Status: ${status}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "status",
    "unit": "kg",
    "breakdownUnits": {
      "Current Weight: ${currentWeight} kg": "kg",
      "Recommended Weight Range: ${recommendedMinWeight.toFixed(1)} - ${recommendedMaxWeight.toFixed(1)} kg": "kg",
      "Total Recommended Gain: ${totalMinGain} - ${totalMaxGain} kg": "kg",
      "Weight Gained So Far: ${weightGained} kg": "kg"
    }
  },
  "category": "Dönüşüm & Ölçüm",

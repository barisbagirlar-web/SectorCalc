  "formulas": {
    "pooledSd": "Math.sqrt(((n1-1)*Math.pow(sd1,2) + (n2-1)*Math.pow(sd2,2))/(n1+n2-2))",
    "meanDiff": "mean1 - mean2",
    "d": "(mean1 - mean2) / pooledSd"
  },

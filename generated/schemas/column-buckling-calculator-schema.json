      "label_i18n": {
        "en": "Cross-Sectional Area (A)",
        "tr": "Kesit Alanı (A)",
        "de": "Querschnittsfläche (A)",
        "fr": "Cross-Sectional Area (A)",
        "es": "Cross-Sectional Area (A)",
        "ar": "Cross-Sectional Area (A)"
      },
      "businessContext_i18n": {
        "en": "Cross-sectional area of the column.",
        "tr": "Kolon kesitinin alanı.",

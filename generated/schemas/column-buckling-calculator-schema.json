    },
    {
      "id": "length",
      "label": "Unbraced Length (L)",
      "type": "number",
      "unit": "mm",
      "default": 3000,
      "businessContext": "Length of column between lateral supports.",
      "label_i18n": {
        "en": "Unbraced Length (L)",
        "tr": "Desteklenmeyen Uzunluk (L)",
        "de": "Unverschiebliche Länge (L)",
        "fr": "Unbraced Length (L)",
        "es": "Unbraced Length (L)",
        "ar": "Unbraced Length (L)"
      },
      "businessContext_i18n": {
        "en": "Length of column between lateral supports.",
        "tr": "Yanal destekler arasındaki kolon boyu.",
        "de": "Länge der Stütze zwischen seitlichen Abstützungen."
      }
    },
    {
      "id": "effectiveLengthFactor",
      "label": "Effective Length Factor (K)",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "K=0.5 fixed-fixed, 1 pinned-pinned, 2 fixed-free.",
      "label_i18n": {
        "en": "Effective Length Factor (K)",
        "tr": "Etkili Uzunluk Faktörü (K)",
        "de": "Knicklängenbeiwert (K)",
        "fr": "Effective Length Factor (K)",
        "es": "Effective Length Factor (K)",
        "ar": "Effective Length Factor (K)"
      },
      "businessContext_i18n": {
        "en": "K=0.5 fixed-fixed, 1 pinned-pinned, 2 fixed-free.",
        "tr": "K=0,5 ankastre-ankastre, 1 mafsallı-mafsallı, 2 ankastre-serbest.",
        "de": "K=0,5 eingespannt-eingespannt, 1 gelenkig-gelenkig, 2 eingespannt-frei."
      }
    },
    {
      "id": "appliedLoad",
      "label": "Applied Axial Load (P)",
      "type": "number",
      "unit": "N",
      "default": 50000,
      "businessContext": "Compressive load applied to the column.",
      "label_i18n": {
        "en": "Applied Axial Load (P)",
        "tr": "Uygulanan Eksenel Yük (P)",
        "de": "Angewandte Axiallast (P)",
        "fr": "Applied Axial Load (P)",
        "es": "Applied Axial Load (P)",
        "ar": "Applied Axial Load (P)"
      },
      "businessContext_i18n": {
        "en": "Compressive load applied to the column.",
        "tr": "Kolona uygulanan basınç yükü.",
        "de": "Auf die Stütze wirkende Drucklast."
      }
    }
  ],
  "formulas": {
    "criticalLoad": "Math.PI ** 2 * elasticModulus * momentInertia / ( (effectiveLengthFactor * length) ** 2 )",
    "criticalStress": "criticalLoad / area",
    "safetyFactor": "criticalLoad / appliedLoad"
  },
  "outputs": {
    "primary": "criticalLoad",
    "breakdown": [
      {
        "id": "criticalStress",
        "label": "Critical Stress",
        "unit": "MPa",
        "formula": "criticalStress"
      },
      {
        "id": "slendernessRatio",
        "label": "Slenderness Ratio",
        "unit": "",
        "formula": "slendernessRatio"
      },
      {
        "id": "safetyFactor",
        "label": "Safety Factor",
        "unit": "",
        "formula": "safetyFactor"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

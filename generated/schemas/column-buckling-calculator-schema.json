        "es": "Moment of Inertia (I)",
        "ar": "Moment of Inertia (I)"
      },
      "businessContext_i18n": {
        "en": "Second moment of area of column cross-section.",
        "tr": "Kolon kesitinin alan atalet momenti.",
        "de": "Flächenträgheitsmoment des Stützenquerschnitts."

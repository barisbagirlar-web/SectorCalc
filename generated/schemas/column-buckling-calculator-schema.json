        "tr": "Malzemenin elastisite modülü, örn. çelik için 200 GPa = 200.000 MPa.",
        "de": "Elastizitätsmodul des Materials, z. B. 200 GPa = 200.000 MPa für Stahl."
      }
    },
    {
      "id": "momentInertia",
      "label": "Moment of Inertia (I)",
      "type": "number",
      "unit": "mm⁴",
      "default": 1000000,

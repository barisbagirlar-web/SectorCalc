{
  "toolName": "long-term-care-insurance-calculator",
  "inputs": [
    {
      "id": "dailyBenefit",
      "label": "Daily Benefit Amount",
      "type": "number",
      "unit": "currency",
      "default": 150,
      "businessContext": "The amount paid per day of care",
      "label_i18n": {
        "en": "Daily Benefit Amount",
        "tr": "Daily Benefit Amount",
        "de": "Daily Benefit Amount",
        "fr": "Daily Benefit Amount",
        "es": "Daily Benefit Amount",
        "ar": "Daily Benefit Amount"
      }
    },
    {
      "id": "benefitPeriodYears",
      "label": "Benefit Period (Years)",
      "type": "number",
      "unit": "years",
      "default": 3,
      "businessContext": "Maximum number of years benefits are paid",
      "label_i18n": {
        "en": "Benefit Period (Years)",
        "tr": "Benefit Period (Years)",
        "de": "Benefit Period (Years)",
        "fr": "Benefit Period (Years)",
        "es": "Benefit Period (Years)",
        "ar": "Benefit Period (Years)"
      }
    },
    {
      "id": "eliminationDays",
      "label": "Elimination Period (Days)",
      "type": "number",
      "unit": "days",
      "default": 90,
      "businessContext": "Waiting period before benefits start",
      "label_i18n": {
        "en": "Elimination Period (Days)",
        "tr": "Elimination Period (Days)",
        "de": "Elimination Period (Days)",
        "fr": "Elimination Period (Days)",
        "es": "Elimination Period (Days)",
        "ar": "Elimination Period (Days)"
      }
    },
    {
      "id": "inflationProtection",
      "label": "Annual Inflation Protection",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Yearly percentage increase in daily benefit (informative, not used in core calculation)",
      "label_i18n": {
        "en": "Annual Inflation Protection",
        "tr": "Annual Inflation Protection",
        "de": "Annual Inflation Protection",
        "fr": "Annual Inflation Protection",
        "es": "Annual Inflation Protection",
        "ar": "Annual Inflation Protection"
      }
    }
  ],
  "formulas": {
    "totalEligibleDays": "Math.max(0, (benefitPeriodYears * 365) - eliminationDays)",
    "totalBenefit": "dailyBenefit * totalEligibleDays"
  },
  "outputs": {
    "primary": "totalBenefit",
    "breakdown": [
      "totalEligibleDays",
      "dailyBenefit"
    ]
  },

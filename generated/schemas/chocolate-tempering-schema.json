{
  "toolName": "chocolate-tempering",
  "inputs": [
    {
      "id": "cocoaButterPercent",
      "label": "Cocoa Butter Percentage",
      "type": "number",
      "unit": "%",
      "default": 35,
      "businessContext": "Percentage of cocoa butter in the chocolate mass",
      "label_i18n": {
        "en": "Cocoa Butter Percentage",
        "tr": "Cocoa Butter Percentage",
        "de": "Cocoa Butter Percentage",
        "fr": "Cocoa Butter Percentage",
        "es": "Cocoa Butter Percentage",
        "ar": "Cocoa Butter Percentage"
      }
    },
    {
      "id": "massKg",
      "label": "Chocolate Mass",
      "type": "number",
      "unit": "kg",
      "default": 10,
      "businessContext": "Total weight of chocolate to be tempered",
      "label_i18n": {
        "en": "Chocolate Mass",
        "tr": "Chocolate Mass",
        "de": "Chocolate Mass",
        "fr": "Chocolate Mass",
        "es": "Chocolate Mass",
        "ar": "Chocolate Mass"
      }
    },
    {
      "id": "targetTempC",
      "label": "Target Tempering Temperature",
      "type": "number",
      "unit": "°C",
      "default": 31,
      "businessContext": "Desired final temperature after tempering",
      "label_i18n": {
        "en": "Target Tempering Temperature",
        "tr": "Target Tempering Temperature",
        "de": "Target Tempering Temperature",
        "fr": "Target Tempering Temperature",
        "es": "Target Tempering Temperature",
        "ar": "Target Tempering Temperature"
      }
    },
    {
      "id": "coolingRate",
      "label": "Cooling Rate",
      "type": "number",
      "unit": "°C/min",
      "default": 2,
      "businessContext": "Rate at which chocolate is cooled during tempering",
      "label_i18n": {
        "en": "Cooling Rate",
        "tr": "Cooling Rate",
        "de": "Cooling Rate",
        "fr": "Cooling Rate",
        "es": "Cooling Rate",
        "ar": "Cooling Rate"
      }
    },
    {
      "id": "seedPercent",
      "label": "Seed Chocolate Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of already tempered chocolate used as seed",
      "label_i18n": {
        "en": "Seed Chocolate Percentage",
        "tr": "Seed Chocolate Percentage",
        "de": "Seed Chocolate Percentage",
        "fr": "Seed Chocolate Percentage",
        "es": "Seed Chocolate Percentage",
        "ar": "Seed Chocolate Percentage"
      }
    },
    {
      "id": "ambientTempC",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Room temperature where tempering occurs",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ambient Temperature",
        "de": "Ambient Temperature",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      }
    }
  ],
  "formulas": {
    "seedMass": "massKg * seedPercent / 100",
    "coolingTime": "(targetTempC - ambientTempC) / coolingRate",
    "cocoaButterMass": "massKg * cocoaButterPercent / 100",
    "totalMass": "massKg + seedMass",
    "temperIndex": "cocoaButterPercent * 0.8 + seedPercent * 0.2"
  },
  "outputs": {
    "primary": "temperIndex",
    "breakdown": [
      "seedMass",
      "coolingTime",
      "cocoaButterMass",
      "totalMass"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "temperIndex"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Metal & Kaynak",
  "premiumRequired": false,

        "de": "Kakaobutteranteil",
        "fr": "Cocoa Butter Percentage",
        "es": "Cocoa Butter Percentage",
        "ar": "Cocoa Butter Percentage"
      },
      "businessContext_i18n": {
        "en": "Percentage of cocoa butter in the chocolate mass",
        "tr": "Çikolata kütlesindeki kakao yağı yüzdesi",
        "de": "Prozentsatz der Kakaobutter in der Schokoladenmasse"
      }
    },
    {
      "id": "massKg",
      "label": "Chocolate Mass",
      "type": "number",
      "unit": "kg",
      "default": 10,
      "businessContext": "Total weight of chocolate to be tempered",
      "label_i18n": {
        "en": "Chocolate Mass",
        "tr": "Çikolata Kütlesi",
        "de": "Schokoladenmasse",
        "fr": "Chocolate Mass",
        "es": "Chocolate Mass",
        "ar": "Chocolate Mass"
      },
      "businessContext_i18n": {
        "en": "Total weight of chocolate to be tempered",

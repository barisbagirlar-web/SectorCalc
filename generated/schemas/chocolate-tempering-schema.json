      }
    },
    {
      "id": "targetTempC",
      "label": "Target Tempering Temperature",
      "type": "number",
      "unit": "°C",
      "default": 31,
      "businessContext": "Desired final temperature after tempering",
      "label_i18n": {
        "en": "Target Tempering Temperature",
        "tr": "Hedef Tavlama Sıcaklığı",
        "de": "Ziel-Temperiertemperatur",
        "fr": "Target Tempering Temperature",
        "es": "Target Tempering Temperature",
        "ar": "Target Tempering Temperature"
      },
      "businessContext_i18n": {
        "en": "Desired final temperature after tempering",
        "tr": "Temperleme sonrası istenen son sıcaklık",
        "de": "Gewünschte Endtemperatur nach dem Temperieren"
      }
    },
    {
      "id": "coolingRate",
      "label": "Cooling Rate",
      "type": "number",
      "unit": "°C/min",
      "default": 2,
      "businessContext": "Rate at which chocolate is cooled during tempering",
      "label_i18n": {
        "en": "Cooling Rate",
        "tr": "Soğutma Hızı",
        "de": "Kühlrate",
        "fr": "Cooling Rate",
        "es": "Cooling Rate",
        "ar": "Cooling Rate"
      },
      "businessContext_i18n": {
        "en": "Rate at which chocolate is cooled during tempering",
        "tr": "Temperleme sırasında çikolatanın soğutulma hızı",
        "de": "Geschwindigkeit, mit der die Schokolade während des Temperierens gekühlt wird"
      }
    },
    {
      "id": "seedPercent",
      "label": "Seed Chocolate Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of already tempered chocolate used as seed",
      "label_i18n": {
        "en": "Seed Chocolate Percentage",
        "tr": "Tohum Çikolata Yüzdesi",
        "de": "Impsschokoladenanteil",
        "fr": "Seed Chocolate Percentage",
        "es": "Seed Chocolate Percentage",
        "ar": "Seed Chocolate Percentage"
      },
      "businessContext_i18n": {
        "en": "Percentage of already tempered chocolate used as seed",
        "tr": "Tohum olarak kullanılan önceden temperlenmiş çikolata yüzdesi",
        "de": "Prozentsatz der bereits temperierten Schokolade, die als Impfschokolade verwendet wird"
      }
    },
    {
      "id": "ambientTempC",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Room temperature where tempering occurs",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ortam Sıcaklığı",
        "de": "Umgebungstemperatur",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      },
      "businessContext_i18n": {
        "en": "Room temperature where tempering occurs",
        "tr": "Temperlemenin gerçekleştiği oda sıcaklığı",
        "de": "Raumtemperatur, bei der das Temperieren stattfindet"
      }
    }
  ],
  "formulas": {
    "seedMass": "massKg * seedPercent / 100",
    "coolingTime": "(targetTempC - ambientTempC) / coolingRate",
    "cocoaButterMass": "massKg * cocoaButterPercent / 100",
    "totalMass": "massKg + seedMass",
    "temperIndex": "cocoaButterPercent * 0.8 + seedPercent * 0.2"
  },
  "outputs": {
    "primary": "temperIndex",
    "breakdown": [
      "seedMass",
      "coolingTime",
      "cocoaButterMass",
      "totalMass"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "temperIndex",
    "unit": "°C"
  },

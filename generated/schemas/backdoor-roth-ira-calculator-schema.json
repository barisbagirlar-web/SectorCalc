{
  "toolName": "backdoor-roth-ira-calculator",
  "inputs": [
    {
      "id": "traditionalIraBalance",
      "label": "Total Traditional IRA Balance",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "Total value of all your traditional IRA accounts before conversion.",
      "label_i18n": {
        "en": "Total Traditional IRA Balance",
        "tr": "Total Traditional IRA Balance",
        "de": "Total Traditional IRA Balance",
        "fr": "Total Traditional IRA Balance",
        "es": "Total Traditional IRA Balance",
        "ar": "Total Traditional IRA Balance"
      }
    },
    {
      "id": "afterTaxBasis",
      "label": "After-Tax Basis",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Total non-deductible contributions (already taxed).",
      "label_i18n": {
        "en": "After-Tax Basis",
        "tr": "After-Tax Basis",
        "de": "After-Tax Basis",
        "fr": "After-Tax Basis",
        "es": "After-Tax Basis",
        "ar": "After-Tax Basis"
      }
    },
    {
      "id": "conversionAmount",
      "label": "Conversion Amount",
      "type": "number",
      "unit": "$",
      "default": 6000,
      "businessContext": "Amount you wish to convert to Roth IRA.",
      "label_i18n": {
        "en": "Conversion Amount",
        "tr": "Conversion Amount",
        "de": "Conversion Amount",
        "fr": "Conversion Amount",
        "es": "Conversion Amount",
        "ar": "Conversion Amount"
      }
    },
    {
      "id": "marginalTaxRate",
      "label": "Marginal Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 24,
      "businessContext": "Your current federal marginal income tax rate.",
      "label_i18n": {
        "en": "Marginal Tax Rate",
        "tr": "Marginal Tax Rate",
        "de": "Marginal Tax Rate",
        "fr": "Marginal Tax Rate",
        "es": "Marginal Tax Rate",
        "ar": "Marginal Tax Rate"
      }
    }
  ],
  "formulas": {
    "taxableAmount": "conversionAmount * (1 - afterTaxBasis / traditionalIraBalance)",
    "taxDue": "taxableAmount * marginalTaxRate / 100",
    "afterTaxBasisPct": "afterTaxBasis / traditionalIraBalance * 100"
  },
  "outputs": {
    "primary": "taxDue",
    "breakdown": [
      "taxableAmount",
      "afterTaxBasisPct"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "afterTaxBasisPct"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,

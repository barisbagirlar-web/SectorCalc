{
  "toolName": "calendar-converter",
  "inputs": [
    {
      "id": "gregorianYear",
      "label": "Gregorian Year",
      "type": "number",
      "unit": "year",
      "default": 2025,
      "businessContext": "Gregorian calendar year to convert",
      "label_i18n": {
        "en": "Gregorian Year",
        "tr": "Gregorian Year",
        "de": "Gregorian Year",
        "fr": "Gregorian Year",
        "es": "Gregorian Year",
        "ar": "Gregorian Year"
      }
    },
    {
      "id": "gregorianMonth",
      "label": "Gregorian Month",
      "type": "number",
      "unit": "month",
      "default": 1,
      "businessContext": "Gregorian calendar month (1-12)",
      "label_i18n": {
        "en": "Gregorian Month",
        "tr": "Gregorian Month",
        "de": "Gregorian Month",
        "fr": "Gregorian Month",
        "es": "Gregorian Month",
        "ar": "Gregorian Month"
      }
    },
    {
      "id": "gregorianDay",
      "label": "Gregorian Day",
      "type": "number",
      "unit": "day",
      "default": 1,
      "businessContext": "Gregorian calendar day (1-31)",
      "label_i18n": {
        "en": "Gregorian Day",
        "tr": "Gregorian Day",
        "de": "Gregorian Day",
        "fr": "Gregorian Day",
        "es": "Gregorian Day",
        "ar": "Gregorian Day"
      }
    },
    {
      "id": "targetCalendar",
      "label": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 for Julian, 1 for Islamic, 2 for Hebrew",
      "label_i18n": {
        "en": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)",
        "tr": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)",
        "de": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)",
        "fr": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)",
        "es": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)",
        "ar": "Target Calendar (0=Julian, 1=Islamic, 2=Hebrew)"
      }
    }
  ],
  "formulas": {
    "julianDay": "367 * gregorianYear - Math.floor(7 * (gregorianYear + Math.floor((gregorianMonth + 9) / 12)) / 4) + Math.floor(275 * gregorianMonth / 9) + gregorianDay + 1721013.5 + 0.5",
    "julianYear": "Math.floor((julianDay - 1721013.5 - 0.5) / 365.25)",
    "julianMonth": "Math.floor((julianDay - 1721013.5 - 0.5 - Math.floor(365.25 * julianYear)) / 30.6001)",
    "julianDayOfMonth": "julianDay - 1721013.5 - 0.5 - Math.floor(365.25 * julianYear) - Math.floor(30.6001 * julianMonth)",
    "islamicYear": "Math.floor((julianDay - 1948439.5) / 354.367)",
    "islamicMonth": "Math.floor(((julianDay - 1948439.5) - Math.floor(354.367 * islamicYear)) / 29.53059) + 1",
    "islamicDay": "Math.floor((julianDay - 1948439.5) - Math.floor(354.367 * islamicYear) - Math.floor(29.53059 * (islamicMonth - 1))) + 1",
    "hebrewYear": "Math.floor((julianDay - 347997.5) / 365.2468)",
    "hebrewMonth": "Math.floor(((julianDay - 347997.5) - Math.floor(365.2468 * hebrewYear)) / 29.53059) + 1",
    "hebrewDay": "Math.floor((julianDay - 347997.5) - Math.floor(365.2468 * hebrewYear) - Math.floor(29.53059 * (hebrewMonth - 1))) + 1",
    "_julianYear___julianMonth___julianDayOfM": "{julianYear}-{julianMonth}-{julianDayOfMonth}",
    "_islamicYear___islamicMonth___islamicDay": "{islamicYear}-{islamicMonth}-{islamicDay}",
    "_hebrewYear___hebrewMonth___hebrewDay_": "{hebrewYear}-{hebrewMonth}-{hebrewDay}"
  },
  "outputs": {
    "primary": "julianDay",
    "breakdown": [
      "Julian: {julianYear}-{julianMonth}-{julianDayOfMonth}",
      "Islamic: {islamicYear}-{islamicMonth}-{islamicDay}",
      "Hebrew: {hebrewYear}-{hebrewMonth}-{hebrewDay}"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "date-time",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",

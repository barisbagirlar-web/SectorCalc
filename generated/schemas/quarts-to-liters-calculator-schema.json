{
  "toolName": "quarts-to-liters-calculator",
  "inputs": [
    {
      "id": "quartsPerContainer",
      "label": "Quarts per Container",
      "type": "number",
      "unit": "qt",
      "default": 1,
      "businessContext": "Volume of liquid in one container, in quarts (US liquid or Imperial based on type).",
      "label_i18n": {
        "en": "Quarts per Container",
        "tr": "Quarts per Container",
        "de": "Quarts per Container",
        "fr": "Quarts per Container",
        "es": "Quarts per Container",
        "ar": "Quarts per Container"
      }
    },
    {
      "id": "numberOfContainers",
      "label": "Number of Containers",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Total number of containers to be processed or converted.",
      "label_i18n": {
        "en": "Number of Containers",
        "tr": "Number of Containers",
        "de": "Number of Containers",
        "fr": "Number of Containers",
        "es": "Number of Containers",
        "ar": "Number of Containers"
      }
    },
    {
      "id": "quartType",
      "label": "Quart Type (0=US Liquid, 1=Imperial)",
      "type": "number",
      "unit": "type",
      "default": 0,
      "businessContext": "Specify the quart system: 0 for US liquid quart (0.946352946 L), 1 for Imperial quart (1.1365225 L).",
      "label_i18n": {
        "en": "Quart Type (0=US Liquid, 1=Imperial)",
        "tr": "Quart Type (0=US Liquid, 1=Imperial)",
        "de": "Quart Type (0=US Liquid, 1=Imperial)",
        "fr": "Quart Type (0=US Liquid, 1=Imperial)",
        "es": "Quart Type (0=US Liquid, 1=Imperial)",
        "ar": "Quart Type (0=US Liquid, 1=Imperial)"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of additional volume to account for waste, spillage, or safety margin.",
      "label_i18n": {
        "en": "Waste Factor (%)",
        "tr": "Waste Factor (%)",
        "de": "Waste Factor (%)",
        "fr": "Waste Factor (%)",
        "es": "Waste Factor (%)",
        "ar": "Waste Factor (%)"
      }
    }
  ],
  "formulas": {
    "totalQuarts": "quartsPerContainer * numberOfContainers",
    "conversionFactor": "quartType === 0 ? 0.946352946 : 1.1365225",
    "baseLiters": "totalQuarts * conversionFactor",
    "wasteLiters": "baseLiters * wasteFactor / 100",
    "totalLiters": "baseLiters + wasteLiters"
  },
  "outputs": {
    "primary": "totalLiters",
    "breakdown": [
      "baseLiters",
      "wasteLiters"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalLiters"
  },

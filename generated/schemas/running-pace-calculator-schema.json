{
  "toolName": "running-pace-calculator",
  "inputs": [
    {
      "id": "distance",
      "label": "Distance",
      "type": "number",
      "unit": "km",
      "default": 10,
      "businessContext": "Total distance of the run in kilometers"
    },
    {
      "id": "hours",
      "label": "Hours",
      "type": "number",
      "unit": "h",
      "default": 0,
      "businessContext": "Hours component of the total time"
    },
    {
      "id": "minutes",
      "label": "Minutes",
      "type": "number",
      "unit": "min",
      "default": 50,
      "businessContext": "Minutes component of the total time"
    },
    {
      "id": "seconds",
      "label": "Seconds",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Seconds component of the total time"
    }
  ],
  "formulas": {
    "totalTimeMin": "hours * 60 + minutes + seconds / 60",
    "paceMinPerKm": "(hours * 60 + minutes + seconds / 60) / distance",
    "speedKmPerHour": "distance / ((hours * 60 + minutes + seconds / 60) / 60)"
  },
  "outputs": {
    "primary": "paceMinPerKm",
    "breakdown": [
      "speedKmPerHour",
      "totalTimeMin"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

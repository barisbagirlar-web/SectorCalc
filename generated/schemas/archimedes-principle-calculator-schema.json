    {
      "id": "gravity",
      "label": "Gravitational Acceleration",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Standard gravity (9.81 m/s² on Earth)",
      "label_i18n": {
        "en": "Gravitational Acceleration",
        "tr": "Gravitational Acceleration",
        "de": "Gravitational Acceleration",
        "fr": "Gravitational Acceleration",
        "es": "Gravitational Acceleration",
        "ar": "Gravitational Acceleration"
      }
    }
  ],
  "formulas": {
    "buoyantForce": "(objectMass / objectVolume <= fluidDensity) ? (objectMass * gravity) : (fluidDensity * objectVolume * gravity)",
    "objectDensity": "objectMass / objectVolume",
    "netForce": "(objectMass / objectVolume <= fluidDensity) ? 0 : (gravity * (objectMass - fluidDensity * objectVolume))",
    "floats": "objectMass / objectVolume <= fluidDensity"
  },
  "outputs": {
    "primary": "buoyantForce",
    "breakdown": [
      "objectDensity",
      "netForce",
      "floats"
    ],

  "formulas": {
    "sum1": "x1*y2 + x2*y3 + x3*y4 + x4*y1",
    "sum2": "y1*x2 + y2*x3 + y3*x4 + y4*x1",
    "absDiff": "Math.abs(sum1 - sum2)",
    "area": "absDiff / 2"
  },
  "outputs": {
    "primary": "area",
    "breakdown": [
      "sum1",
      "sum2",
      "absDiff",

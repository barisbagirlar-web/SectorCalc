    },
    {
      "id": "laborCostPerUnit",
      "label": "Labor Cost per Unit",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "Direct labor cost per unit",
      "label_i18n": {
        "en": "Labor Cost per Unit",
        "tr": "Birim başına işçilik maliyeti",
        "de": "Labor Cost per Unit",
        "fr": "Labor Cost per Unit",

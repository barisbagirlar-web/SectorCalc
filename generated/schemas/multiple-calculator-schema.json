        "de": "Direkte Arbeitskosten pro Einheit"
      }
    },
    {
      "id": "overheadFixed",
      "label": "Fixed Overhead Costs",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "Total fixed overhead costs for the production run",
      "label_i18n": {
        "en": "Fixed Overhead Costs",
        "tr": "Sabit Genel Giderler",
        "de": "Fixed Overhead Costs",
        "fr": "Fixed Overhead Costs",
        "es": "Fixed Overhead Costs",
        "ar": "Fixed Overhead Costs"
      },
      "businessContext_i18n": {
        "en": "Total fixed overhead costs for the production run",
        "tr": "Üretim partisi için toplam sabit genel giderler"
      }
    },
    {
      "id": "profitMarginPercent",
      "label": "Profit Margin (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Desired profit margin as percentage of cost",
      "label_i18n": {
        "en": "Profit Margin (%)",
        "tr": "Kar Marjı (%)",
        "de": "Profit Margin (%)",
        "fr": "Profit Margin (%)",
        "es": "Profit Margin (%)",
        "ar": "Profit Margin (%)"
      },
      "businessContext_i18n": {
        "en": "Desired profit margin as percentage of cost",
        "tr": "Maliyetin yüzdesi olarak istenen kar marjı"
      }
    },
    {
      "id": "taxRatePercent",
      "label": "Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Applicable sales tax rate",
      "label_i18n": {
        "en": "Tax Rate (%)",
        "tr": "Vergi Oranı (%)",
        "de": "Tax Rate (%)",
        "fr": "Tax Rate (%)",
        "es": "Tax Rate (%)",
        "ar": "Tax Rate (%)"
      },
      "businessContext_i18n": {
        "en": "Applicable sales tax rate",
        "tr": "Geçerli satış vergisi oranı"
      }
    }
  ],
  "formulas": {
    "totalCost": "(materialCostPerUnit + laborCostPerUnit) * quantity + overheadFixed",
    "costPerUnit": "((materialCostPerUnit + laborCostPerUnit) * quantity + overheadFixed) / quantity",
    "sellingPrice": "((materialCostPerUnit + laborCostPerUnit) * quantity + overheadFixed) / quantity * (1 + profitMarginPercent / 100) * (1 + taxRatePercent / 100)",
    "profitPerUnit": "((materialCostPerUnit + laborCostPerUnit) * quantity + overheadFixed) / quantity * (profitMarginPercent / 100)"
  },
  "outputs": {
    "primary": "costPerUnit",
    "breakdown": [
      "totalCost",
      "sellingPrice",
      "profitPerUnit"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitPerUnit",
    "unit": "currency"
  },

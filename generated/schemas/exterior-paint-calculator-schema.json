  "formulas": {
    "netArea": "totalWallArea - (doorArea + windowArea + otherOpeningsArea)",
    "effectiveArea": "netArea * (1 + wasteFactor / 100)",
    "paintNeeded": "effectiveArea * numberOfCoats / paintCoverage"
  },
  "outputs": {
    "primary": "netArea",
    "breakdown": [

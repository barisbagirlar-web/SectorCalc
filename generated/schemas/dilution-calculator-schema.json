{
  "toolName": "dilution-calculator",
  "inputs": [
    {
      "id": "stockConcentration",
      "label": "Stock Concentration",
      "type": "number",
      "unit": "mg/mL",
      "default": 100,
      "businessContext": "Concentration of the stock solution",
      "label_i18n": {
        "en": "Stock Concentration",
        "tr": "Stock Concentration",
        "de": "Stock Concentration",
        "fr": "Stock Concentration",
        "es": "Stock Concentration",
        "ar": "Stock Concentration"
      }
    },
    {
      "id": "desiredConcentration",
      "label": "Desired Concentration",
      "type": "number",
      "unit": "mg/mL",
      "default": 10,
      "businessContext": "Target concentration after dilution",
      "label_i18n": {
        "en": "Desired Concentration",
        "tr": "Desired Concentration",
        "de": "Desired Concentration",
        "fr": "Desired Concentration",
        "es": "Desired Concentration",
        "ar": "Desired Concentration"
      }
    },
    {
      "id": "finalVolume",
      "label": "Final Volume",
      "type": "number",
      "unit": "mL",
      "default": 100,
      "businessContext": "Required total volume of the diluted solution",
      "label_i18n": {
        "en": "Final Volume",
        "tr": "Final Volume",
        "de": "Final Volume",
        "fr": "Final Volume",
        "es": "Final Volume",
        "ar": "Final Volume"
      }
    },
    {
      "id": "overagePercent",
      "label": "Overage Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Extra volume percentage to account for handling losses (0-100)",
      "label_i18n": {
        "en": "Overage Percentage",
        "tr": "Overage Percentage",
        "de": "Overage Percentage",
        "fr": "Overage Percentage",
        "es": "Overage Percentage",
        "ar": "Overage Percentage"
      }
    },
    {
      "id": "unitConversionFactor",
      "label": "Unit Conversion Factor",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Factor to convert stock concentration units to desired concentration units (e.g., if stock is in g/L and desired in mg/mL, use 1)",
      "label_i18n": {
        "en": "Unit Conversion Factor",
        "tr": "Unit Conversion Factor",
        "de": "Unit Conversion Factor",
        "fr": "Unit Conversion Factor",
        "es": "Unit Conversion Factor",
        "ar": "Unit Conversion Factor"
      }
    }
  ],
  "formulas": {
    "effectiveStockConcentration": "stockConcentration * unitConversionFactor",
    "adjustedFinalVolume": "finalVolume * (1 + overagePercent / 100)",
    "requiredStockVolume": "(desiredConcentration * adjustedFinalVolume) / effectiveStockConcentration"
  },
  "outputs": {
    "primary": "requiredStockVolume",
    "breakdown": [
      "effectiveStockConcentration",
      "adjustedFinalVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "requiredStockVolume"
  },

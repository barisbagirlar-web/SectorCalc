        "tr": "Stok çözeltinin konsantrasyonu"
      }
    },
    {
      "id": "desiredConcentration",
      "label": "Desired Concentration",
      "type": "number",
      "unit": "mg/mL",
      "default": 10,
      "businessContext": "Target concentration after dilution",
      "label_i18n": {
        "en": "Desired Concentration",
        "tr": "İstenen konsantrasyon",
        "de": "Desired Concentration",
        "fr": "Desired Concentration",
        "es": "Desired Concentration",
        "ar": "Desired Concentration"
      },
      "businessContext_i18n": {
        "en": "Target concentration after dilution",
        "tr": "Seyreltme sonrası hedef konsantrasyon"
      }
    },
    {
      "id": "finalVolume",
      "label": "Final Volume",
      "type": "number",
      "unit": "mL",
      "default": 100,
      "businessContext": "Required total volume of the diluted solution",
      "label_i18n": {
        "en": "Final Volume",
        "tr": "Son Hacim",
        "de": "Final Volume",
        "fr": "Final Volume",
        "es": "Final Volume",
        "ar": "Final Volume"
      },
      "businessContext_i18n": {
        "en": "Required total volume of the diluted solution",
        "tr": "Seyreltilmiş çözeltinin gerekli toplam hacmi"
      }
    },
    {
      "id": "overagePercent",
      "label": "Overage Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Extra volume percentage to account for handling losses (0-100)",
      "label_i18n": {
        "en": "Overage Percentage",
        "tr": "Fazlalık yüzdesi",
        "de": "Overage Percentage",
        "fr": "Overage Percentage",
        "es": "Overage Percentage",
        "ar": "Overage Percentage"
      },
      "businessContext_i18n": {
        "en": "Extra volume percentage to account for handling losses (0-100)",
        "tr": "Taşıma kayıplarını karşılamak için ekstra hacim yüzdesi (0-100)"
      }
    },
    {
      "id": "unitConversionFactor",
      "label": "Unit Conversion Factor",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Factor to convert stock concentration units to desired concentration units (e.g., if stock is in g/L and desired in mg/mL, use 1)",
      "label_i18n": {
        "en": "Unit Conversion Factor",
        "tr": "Birim Dönüşüm Faktörü",
        "de": "Unit Conversion Factor",
        "fr": "Unit Conversion Factor",
        "es": "Unit Conversion Factor",
        "ar": "Unit Conversion Factor"
      },
      "businessContext_i18n": {
        "en": "Factor to convert stock concentration units to desired concentration units (e.g., if stock is in g/L and desired in mg/mL, use 1)",
        "tr": "Stok konsantrasyon birimlerini istenen konsantrasyon birimlerine dönüştürmek için faktör (örneğin, stok g/L ve istenen mg/mL ise 1 kullanın)"
      }
    }
  ],
  "formulas": {
    "effectiveStockConcentration": "stockConcentration * unitConversionFactor",
    "adjustedFinalVolume": "finalVolume * (1 + overagePercent / 100)",
    "requiredStockVolume": "(desiredConcentration * adjustedFinalVolume) / effectiveStockConcentration"
  },
  "outputs": {
    "primary": "requiredStockVolume",
    "breakdown": [
      "effectiveStockConcentration",
      "adjustedFinalVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "requiredStockVolume",
    "unit": "mg/mL",
    "breakdownUnits": {
      "effectiveStockConcentration": "%"
    }
  },

{
  "toolName": "bmr-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight in kilograms"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Height in centimeters"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age in years"
    },
    {
      "id": "isMale",
      "label": "Sex (1=Male, 0=Female)",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Biological sex indicator: 1 for male, 0 for female"
    }
  ],
  "formulas": {
    "bmr": "isMale === 1 ? (10 * weight + 6.25 * height - 5 * age + 5) : (10 * weight + 6.25 * height - 5 * age - 161)",
    "maleBmr": "10 * weight + 6.25 * height - 5 * age + 5",
    "femaleBmr": "10 * weight + 6.25 * height - 5 * age - 161"
  },
  "outputs": {
    "primary": "bmr",
    "breakdown": [
      "Male BMR (if applicable): ${maleBmr} kcal/day",
      "Female BMR (if applicable): ${femaleBmr} kcal/day"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics",
  "sectorId": "diger",

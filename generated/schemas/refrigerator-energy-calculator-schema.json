{
  "toolName": "refrigerator-energy-calculator",
  "inputs": [
    {
      "id": "compressorPower",
      "label": "Compressor Power",
      "type": "number",
      "unit": "W",
      "default": 150,
      "businessContext": "Rated power consumption of the refrigerator compressor when active",
      "label_i18n": {
        "en": "Compressor Power",
        "tr": "Compressor Power",
        "de": "Compressor Power",
        "fr": "Compressor Power",
        "es": "Compressor Power",
        "ar": "Compressor Power"
      }
    },
    {
      "id": "dutyCycle",
      "label": "Duty Cycle",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Percentage of time the compressor runs",
      "label_i18n": {
        "en": "Duty Cycle",
        "tr": "Duty Cycle",
        "de": "Duty Cycle",
        "fr": "Duty Cycle",
        "es": "Duty Cycle",
        "ar": "Duty Cycle"
      }
    },
    {
      "id": "daysPerYear",
      "label": "Operating Days per Year",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "Number of days the refrigerator is in operation annually",
      "label_i18n": {
        "en": "Operating Days per Year",
        "tr": "Operating Days per Year",
        "de": "Operating Days per Year",
        "fr": "Operating Days per Year",
        "es": "Operating Days per Year",
        "ar": "Operating Days per Year"
      }
    },
    {
      "id": "costPerKwh",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost of electricity per kilowatt-hour",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Electricity Cost",
        "de": "Electricity Cost",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      }
    }
  ],
  "formulas": {
    "annualEnergyKwh": "(compressorPower * dutyCycle / 100 * 24 * daysPerYear) / 1000",
    "annualCost": "annualEnergyKwh * costPerKwh",
    "monthlyCost": "annualCost / 12",
    "dailyCost": "annualCost / daysPerYear"
  },
  "outputs": {
    "primary": "dailyCost",
    "breakdown": [
      "Annual Cost: ${annualCost.toFixed(2)}",
      "Monthly Cost: ${monthlyCost.toFixed(2)}",
      "Daily Cost: ${dailyCost.toFixed(4)}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dailyCost"
  },
  "category": "Enerji & Sürdürülebilirlik",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "energy-carbon",
  "sectorSlug": "energy-carbon",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "energy",

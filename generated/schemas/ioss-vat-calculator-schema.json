{
  "toolName": "ioss-vat-calculator",
  "inputs": [
    {
      "id": "netPrice",
      "label": "Net Item Price",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "The net price of the goods, excluding VAT and shipping.",

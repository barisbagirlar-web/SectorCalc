        "es": "Costo neto de envío, excluyendo IVA."
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 21,
      "businessContext": "The applicable VAT rate (e.g., 21 for 21%).",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "Mehrwertsteuersatz",
        "fr": "Taux de TVA",
        "es": "Tasa de IVA",
        "ar": "VAT Rate"
      },
      "businessContext_i18n": {
        "en": "The applicable VAT rate (e.g., 21 for 21%).",
        "tr": "Geçerli KDV oranı (ör. %21 için 21).",

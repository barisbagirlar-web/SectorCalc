        "fr": "Taux de TVA applicable (ex. 21 pour 21%).",
        "es": "Tasa de IVA aplicable (ej., 21 para 21%)."
      }
    }
  ],
  "formulas": {
    "totalExcl": "netPrice + shippingCost",
    "vatAmount": "totalExcl * vatRate / 100",
    "totalIncl": "totalExcl + vatAmount"

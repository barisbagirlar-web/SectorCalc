{
  "toolName": "mortgage-points-calculator",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "number",
      "unit": "$",
      "default": 300000,
      "businessContext": "Total principal of the mortgage",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Kredi Tutarı",
        "de": "Darlehensbetrag",
        "fr": "Montant du prêt",
        "es": "Monto del préstamo",
        "ar": "Loan Amount"
      },
      "businessContext_i18n": {
        "en": "Total principal of the mortgage",
        "tr": "Mortgage anaparası",
        "de": "Gesamtdarlehensbetrag der Hypothek",
        "fr": "Capital total du prêt hypothécaire",
        "es": "Capital total de la hipoteca"
      }
    },
    {
      "id": "baseInterestRate",
      "label": "Base Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 6.5,
      "businessContext": "Annual interest rate without points",
      "label_i18n": {
        "en": "Base Interest Rate",
        "tr": "Temel Faiz Oranı",
        "de": "Basiszinssatz",
        "fr": "Taux d'intérêt de base",
        "es": "Tasa de interés base",
        "ar": "Base Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual interest rate without points",
        "tr": "Puantajsız yıllık faiz oranı",
        "de": "Jährlicher Zinssatz ohne Punkte",
        "fr": "Taux d'intérêt annuel sans points",
        "es": "Tasa de interés anual sin puntos"
      }
    },
    {
      "id": "pointsPurchased",
      "label": "Points Purchased",
      "type": "number",
      "unit": "points",
      "default": 2,
      "businessContext": "Number of discount points (each point costs 1% of loan amount)",
      "label_i18n": {
        "en": "Points Purchased",
        "tr": "Satın Alınan Puanlar",
        "de": "Gekaufte Punkte",
        "fr": "Points achetés",
        "es": "Puntos comprados",
        "ar": "Points Purchased"
      },
      "businessContext_i18n": {
        "en": "Number of discount points (each point costs 1% of loan amount)",
        "tr": "İndirim puanı sayısı (her puan kredi tutarının %1'i kadardır)",
        "de": "Anzahl der Abschlagspunkte (jeder Punkt kostet 1 % des Darlehensbetrags)",
        "fr": "Nombre de points d'escompte (chaque point coûte 1 % du montant du prêt)",
        "es": "Número de puntos de descuento (cada punto cuesta el 1% del monto del préstamo)"
      }
    },
    {
      "id": "rateReductionPerPoint",
      "label": "Rate Reduction per Point",
      "type": "number",
      "unit": "%",
      "default": 0.25,
      "businessContext": "Reduction in interest rate per point",
      "label_i18n": {
        "en": "Rate Reduction per Point",
        "tr": "Puan Başına Oran Düşüşü",
        "de": "Zinssatzreduktion pro Punkt",
        "fr": "Réduction de taux par point",
        "es": "Reducción de tasa por punto",
        "ar": "Rate Reduction per Point"
      },
      "businessContext_i18n": {
        "en": "Reduction in interest rate per point",
        "tr": "Puan başına faiz oranındaki düşüş",
        "de": "Senkung des Zinssatzes pro Punkt",
        "fr": "Réduction du taux d'intérêt par point",
        "es": "Reducción en la tasa de interés por punto"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Duration of the mortgage in years",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Kredi Vadesi",
        "de": "Darlehenslaufzeit",
        "fr": "Durée du prêt",
        "es": "Plazo del préstamo",
        "ar": "Loan Term"
      },
      "businessContext_i18n": {
        "en": "Duration of the mortgage in years",
        "tr": "Mortgage süresi (yıl olarak)",
        "de": "Laufzeit der Hypothek in Jahren",
        "fr": "Durée du prêt hypothécaire en années",
        "es": "Duración de la hipoteca en años"
      }
    }
  ],
  "formulas": {
    "monthlyRateBase": "baseInterestRate / 100 / 12",
    "monthlyRateWithPoints": "(baseInterestRate - pointsPurchased * rateReductionPerPoint) / 100 / 12",
    "n": "loanTermYears * 12",
    "upfrontCost": "loanAmount * pointsPurchased * 0.01"
  },
  "outputs": {
    "primary": "upfrontCost",
    "breakdown": [
      "monthlyPaymentWithoutPoints",
      "monthlyPaymentWithPoints",
      "upfrontCost",
      "monthlySavings",
      "totalSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalSavings",
    "unit": "$"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Emlak & Gayrimenkul",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

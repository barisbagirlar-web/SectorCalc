{
  "toolName": "mortgage-points-calculator",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "number",
      "unit": "$",
      "default": 300000,
      "businessContext": "Total principal of the mortgage",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Kredi Tutarı",
        "de": "Darlehensbetrag",
        "fr": "Loan Amount",
        "es": "Loan Amount",
        "ar": "Loan Amount"
      },
      "businessContext_i18n": {
        "en": "Total principal of the mortgage",
        "tr": "Mortgage anaparası"
      }
    },
    {
      "id": "baseInterestRate",
      "label": "Base Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 6.5,
      "businessContext": "Annual interest rate without points",
      "label_i18n": {
        "en": "Base Interest Rate",
        "tr": "Temel Faiz Oranı",
        "de": "Base Interest Rate",
        "fr": "Base Interest Rate",
        "es": "Base Interest Rate",
        "ar": "Base Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual interest rate without points",
        "tr": "Puantajsız yıllık faiz oranı"
      }
    },
    {
      "id": "pointsPurchased",
      "label": "Points Purchased",
      "type": "number",
      "unit": "points",
      "default": 2,
      "businessContext": "Number of discount points (each point costs 1% of loan amount)",
      "label_i18n": {
        "en": "Points Purchased",
        "tr": "Satın Alınan Puanlar",
        "de": "Points Purchased",
        "fr": "Points Purchased",
        "es": "Points Purchased",
        "ar": "Points Purchased"
      },
      "businessContext_i18n": {
        "en": "Number of discount points (each point costs 1% of loan amount)",
        "tr": "İndirim puanı sayısı (her puan kredi tutarının %1'i kadardır)"
      }
    },
    {
      "id": "rateReductionPerPoint",
      "label": "Rate Reduction per Point",
      "type": "number",
      "unit": "%",
      "default": 0.25,
      "businessContext": "Reduction in interest rate per point",
      "label_i18n": {
        "en": "Rate Reduction per Point",
        "tr": "Puan Başına Oran Düşüşü",
        "de": "Rate Reduction per Point",
        "fr": "Rate Reduction per Point",
        "es": "Rate Reduction per Point",
        "ar": "Rate Reduction per Point"
      },
      "businessContext_i18n": {
        "en": "Reduction in interest rate per point",
        "tr": "Puan başına faiz oranındaki düşüş"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Duration of the mortgage in years",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Kredi Vadesi",
        "de": "Darlehenslaufzeit",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      },
      "businessContext_i18n": {
        "en": "Duration of the mortgage in years",
        "tr": "Mortgage süresi (yıl olarak)"
      }
    }
  ],
  "formulas": {
    "monthlyRateBase": "baseInterestRate / 100 / 12",
    "monthlyRateWithPoints": "(baseInterestRate - pointsPurchased * rateReductionPerPoint) / 100 / 12",
    "n": "loanTermYears * 12",
    "upfrontCost": "loanAmount * pointsPurchased * 0.01"
  },
  "outputs": {
    "primary": "upfrontCost",
    "breakdown": [
      "monthlyPaymentWithoutPoints",
      "monthlyPaymentWithPoints",
      "upfrontCost",
      "monthlySavings",
      "totalSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalSavings",
    "unit": "$"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Emlak & Gayrimenkul",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "emlak",
  "profession": "Emlak Danışmanı",

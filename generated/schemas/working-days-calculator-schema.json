  "formulas": {
    "totalCalendarDays": "endDate - startDate + includeStart + includeEnd - 1",
    "estimatedWeekendDays": "(weekendDaysPerWeek / 7) * totalCalendarDays",
    "workingDays": "totalCalendarDays - estimatedWeekendDays - holidays",
    "holidays": "holidays"
  },

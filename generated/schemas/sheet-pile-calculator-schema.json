      }
    },
    {
      "id": "steelDensity",
      "label": "Steel Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "businessContext": "Density of steel used for piles",
      "label_i18n": {
        "en": "Steel Density",
        "tr": "Çelik Yoğunluğu",
        "de": "Stahldichte",
        "fr": "Densité de l'acier",
        "es": "Densidad del acero",
        "ar": "كثافة الفولاذ"
      },
      "businessContext_i18n": {

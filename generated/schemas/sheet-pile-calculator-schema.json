{
  "toolName": "sheet-pile-calculator",
  "inputs": [
    {
      "id": "pileLength",
      "label": "Pile Length",
      "type": "number",
      "unit": "m",
      "default": 12,
      "businessContext": "Total length of each sheet pile",
      "label_i18n": {
        "en": "Pile Length",
        "tr": "Kazık Uzunluğu",
        "de": "Pile Length",
        "fr": "Pile Length",
        "es": "Pile Length",
        "ar": "Pile Length"
      },
      "businessContext_i18n": {
        "en": "Total length of each sheet pile",
        "tr": "Her bir sac kazığın toplam uzunluğu"
      }
    },
    {
      "id": "pileWidth",
      "label": "Pile Width",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "Effective width of each sheet pile",
      "label_i18n": {
        "en": "Pile Width",
        "tr": "Kazık Genişliği",
        "de": "Pile Width",
        "fr": "Pile Width",
        "es": "Pile Width",
        "ar": "Pile Width"
      },
      "businessContext_i18n": {
        "en": "Effective width of each sheet pile",
        "tr": "Her bir sac kazığın etkili genişliği"
      }
    },
    {
      "id": "numberOfPiles",
      "label": "Number of Piles",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Total number of sheet piles required",
      "label_i18n": {
        "en": "Number of Piles",
        "tr": "Kazık Sayısı",
        "de": "Number of Piles",
        "fr": "Number of Piles",
        "es": "Number of Piles",
        "ar": "Number of Piles"
      },
      "businessContext_i18n": {
        "en": "Total number of sheet piles required",
        "tr": "Gerekli toplam sac kazık sayısı"
      }
    },
    {
      "id": "steelDensity",
      "label": "Steel Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "businessContext": "Density of steel used for piles",
      "label_i18n": {
        "en": "Steel Density",
        "tr": "Çelik Yoğunluğu",
        "de": "Steel Density",
        "fr": "Steel Density",
        "es": "Steel Density",
        "ar": "Steel Density"
      },
      "businessContext_i18n": {
        "en": "Density of steel used for piles",
        "tr": "Kazıklar için kullanılan çeliğin yoğunluğu"
      }
    },
    {
      "id": "unitCost",
      "label": "Unit Cost",
      "type": "number",
      "unit": "USD/kg",
      "default": 1.2,
      "businessContext": "Cost per kilogram of steel",
      "label_i18n": {
        "en": "Unit Cost",
        "tr": "Birim Maliyet",
        "de": "Unit Cost",
        "fr": "Unit Cost",
        "es": "Unit Cost",
        "ar": "Unit Cost"
      },
      "businessContext_i18n": {
        "en": "Cost per kilogram of steel",
        "tr": "Kilogram başına çelik maliyeti"
      }
    },
    {
      "id": "installationCostPerPile",
      "label": "Installation Cost per Pile",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Cost to install one pile",
      "label_i18n": {
        "en": "Installation Cost per Pile",
        "tr": "Kazık Başına Montaj Maliyeti",
        "de": "Installation Cost per Pile",
        "fr": "Installation Cost per Pile",
        "es": "Installation Cost per Pile",
        "ar": "Installation Cost per Pile"
      },
      "businessContext_i18n": {
        "en": "Cost to install one pile",
        "tr": "Bir kazığı monte etme maliyeti"
      }
    }
  ],
  "formulas": {
    "totalSteelVolume": "pileLength * pileWidth * numberOfPiles * 0.01",
    "totalWeight": "totalSteelVolume * steelDensity",
    "materialCost": "totalWeight * unitCost",
    "installationCost": "numberOfPiles * installationCostPerPile",
    "totalCost": "materialCost + installationCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalWeight",
      "materialCost",
      "installationCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "m"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Metal & Kaynak",
  "premiumRequired": false,

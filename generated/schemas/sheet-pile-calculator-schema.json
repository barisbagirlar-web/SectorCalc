        "es": "Densidad del acero utilizado para los pilotes",
        "ar": "كثافة الفولاذ المستخدم للركائز"
      }
    },
    {
      "id": "unitCost",
      "label": "Unit Cost",
      "type": "number",
      "unit": "USD/kg",
      "default": 1.2,
      "businessContext": "Cost per kilogram of steel",
      "label_i18n": {
        "en": "Unit Cost",
        "tr": "Birim Maliyet",
        "de": "Stückkosten",
        "fr": "Coût unitaire",
        "es": "Costo unitario",
        "ar": "تكلفة الوحدة"
      },
      "businessContext_i18n": {
        "en": "Cost per kilogram of steel",
        "tr": "Kilogram başına çelik maliyeti",
        "de": "Kosten pro Kilogramm Stahl",
        "fr": "Coût par kilogramme d'acier",
        "es": "Coste por kilogramo de acero",
        "ar": "التكلفة لكل كيلوغرام من الفولاذ"
      }
    },
    {
      "id": "installationCostPerPile",
      "label": "Installation Cost per Pile",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Cost to install one pile",
      "label_i18n": {
        "en": "Installation Cost per Pile",
        "tr": "Kazık Başına Montaj Maliyeti",
        "de": "Installationskosten pro Spundbohle",
        "fr": "Coût d'installation par palplanche",
        "es": "Coste de instalación por pilote",
        "ar": "تكلفة التركيب لكل ركيزة"
      },
      "businessContext_i18n": {
        "en": "Cost to install one pile",
        "tr": "Bir kazığı monte etme maliyeti",
        "de": "Kosten für die Installation einer Spundbohle",
        "fr": "Coût pour installer une palplanche",
        "es": "Coste de instalar un pilote",
        "ar": "تكلفة تركيب ركيزة واحدة"
      }
    }
  ],
  "formulas": {
    "totalSteelVolume": "pileLength * pileWidth * numberOfPiles * 0.01",
    "totalWeight": "totalSteelVolume * steelDensity",
    "materialCost": "totalWeight * unitCost",
    "installationCost": "numberOfPiles * installationCostPerPile",
    "totalCost": "materialCost + installationCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalWeight",
      "materialCost",
      "installationCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "m"
  },

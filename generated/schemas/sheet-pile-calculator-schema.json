        "de": "Effektive Breite jeder Spundbohle",
        "fr": "Largeur effective de chaque palplanche",
        "es": "Ancho efectivo de cada tablestaca",
        "ar": "العرض الفعال لكل ركيزة صفائحية"
      }
    },
    {
      "id": "numberOfPiles",
      "label": "Number of Piles",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Total number of sheet piles required",

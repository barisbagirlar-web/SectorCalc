{
  "toolName": "short-term-savings-calculator",
  "inputs": [
    {
      "id": "initialSavings",
      "label": "Initial Savings",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Initial lump sum amount saved.",
      "label_i18n": {
        "en": "Initial Savings",
        "tr": "Başlangıç Tasarrufu",
        "de": "Initial Savings",
        "fr": "Initial Savings",
        "es": "Initial Savings",
        "ar": "Initial Savings"
      },
      "businessContext_i18n": {
        "en": "Initial lump sum amount saved.",
        "tr": "Birikmiş toplu tasarruf miktarı."
      }
    },
    {
      "id": "monthlyContribution",
      "label": "Monthly Contribution",
      "type": "number",
      "unit": "currency/month",
      "default": 0,
      "businessContext": "Amount added to savings each month.",
      "label_i18n": {
        "en": "Monthly Contribution",
        "tr": "Aylık Katkı",
        "de": "Monthly Contribution",
        "fr": "Monthly Contribution",
        "es": "Monthly Contribution",
        "ar": "Monthly Contribution"
      },
      "businessContext_i18n": {
        "en": "Amount added to savings each month.",
        "tr": "Her ay tasarrufa eklenen miktar."
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual interest rate.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Yıllık Faiz Oranı",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual interest rate.",
        "tr": "Yıllık faiz oranı."
      }
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "Number of years.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Yıl Sayısı",
        "de": "Number of Years",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      },
      "businessContext_i18n": {
        "en": "Number of years.",
        "tr": "Yıl sayısı."
      }
    }
  ],
  "formulas": {
    "futureValue": "initialSavings * (1 + annualRate/100/12) ** (12 * years) + monthlyContribution * (((1 + annualRate/100/12) ** (12 * years) - 1) / (annualRate/100/12))",
    "totalContributions": "initialSavings + monthlyContribution * 12 * years",
    "totalInterest": "initialSavings * (1 + annualRate/100/12) ** (12 * years) + monthlyContribution * (((1 + annualRate/100/12) ** (12 * years) - 1) / (annualRate/100/12)) - (initialSavings + monthlyContribution * 12 * years)"
  },
  "outputs": {
    "primary": "futureValue",
    "breakdown": [
      "totalContributions",
      "totalInterest"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalInterest",
    "unit": "currency"
  },

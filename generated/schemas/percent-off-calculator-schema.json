{
  "toolName": "percent-off-calculator",
  "inputs": [
    {
      "id": "original_price",
      "label": "Original Price",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "The initial price before any discounts.",
      "label_i18n": {
        "en": "Original Price",
        "tr": "Orijinal Fiyat",
        "de": "Original Price",
        "fr": "Original Price",
        "es": "Original Price",
        "ar": "Original Price"
      },
      "businessContext_i18n": {
        "en": "The initial price before any discounts.",
        "tr": "Herhangi bir indirim öncesindeki başlangıç fiyatı."
      }
    },
    {
      "id": "discount_percent",
      "label": "Discount Percent",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "The primary discount percentage.",
      "label_i18n": {
        "en": "Discount Percent",
        "tr": "İndirim Yüzdesi",
        "de": "Discount Percent",
        "fr": "Discount Percent",
        "es": "Discount Percent",
        "ar": "Discount Percent"
      },
      "businessContext_i18n": {
        "en": "The primary discount percentage.",
        "tr": "Birincil indirim yüzdesi."
      }
    },
    {
      "id": "additional_discount_percent",
      "label": "Additional Discount Percent",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "An extra discount applied after the first discount (e.g., loyalty discount).",
      "label_i18n": {
        "en": "Additional Discount Percent",
        "tr": "Ek İndirim Yüzdesi",
        "de": "Additional Discount Percent",
        "fr": "Additional Discount Percent",
        "es": "Additional Discount Percent",
        "ar": "Additional Discount Percent"
      },
      "businessContext_i18n": {
        "en": "An extra discount applied after the first discount (e.g., loyalty discount).",
        "tr": "İlk indirimden sonra uygulanan ek indirim (örneğin, sadakat indirimi)."
      }
    },
    {
      "id": "tax_rate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Sales tax rate applied to the discounted price.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Vergi Oranı",
        "de": "Steuersatz",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Sales tax rate applied to the discounted price.",
        "tr": "İndirimli fiyata uygulanan satış vergisi oranı."
      }
    }
  ],
  "formulas": {
    "discounted_price": "original_price * (1 - discount_percent/100) * (1 - additional_discount_percent/100)",
    "tax_amount": "discounted_price * (tax_rate/100)",
    "final_price": "discounted_price + tax_amount",
    "total_savings": "original_price - final_price",
    "display_original_price": "original_price"
  },
  "outputs": {
    "primary": "final_price",
    "breakdown": [
      "display_original_price",
      "discounted_price",
      "total_savings",
      "tax_amount",
      "final_price"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "display_original_price",
    "unit": "currency"
  },

{
  "toolName": "floor-joist-calculator",
  "inputs": [
    {
      "id": "span_ft",
      "label": "Span (ft)",
      "type": "number",
      "unit": "ft",
      "default": 12,
      "businessContext": "Length of joist span in feet",

      }
    },
    {
      "id": "dead_load_psf",
      "label": "Dead Load (psf)",
      "type": "number",
      "unit": "psf",
      "default": 10,
      "businessContext": "Uniform dead load in pounds per square foot",
      "label_i18n": {
        "en": "Dead Load (psf)",
        "tr": "Dead Load (psf)",
        "de": "Dead Load (psf)",
        "fr": "Dead Load (psf)",
        "es": "Dead Load (psf)",
        "ar": "Dead Load (psf)"
      }
    },
    {
      "id": "live_load_psf",
      "label": "Live Load (psf)",
      "type": "number",
      "unit": "psf",
      "default": 40,
      "businessContext": "Uniform live load in pounds per square foot",
      "label_i18n": {
        "en": "Live Load (psf)",
        "tr": "Live Load (psf)",
        "de": "Live Load (psf)",
        "fr": "Live Load (psf)",
        "es": "Live Load (psf)",
        "ar": "Live Load (psf)"
      }
    },
    {
      "id": "E_psi",
      "label": "Modulus of Elasticity (psi)",
      "type": "number",
      "unit": "psi",
      "default": 1600000,
      "businessContext": "Modulus of elasticity of the joist material",
      "label_i18n": {
        "en": "Modulus of Elasticity (psi)",
        "tr": "Modulus of Elasticity (psi)",
        "de": "Modulus of Elasticity (psi)",
        "fr": "Modulus of Elasticity (psi)",
        "es": "Modulus of Elasticity (psi)",
        "ar": "Modulus of Elasticity (psi)"
      }
    },
    {
      "id": "I_in4",
      "label": "Moment of Inertia (in⁴)",
      "type": "number",
      "unit": "in⁴",
      "default": 98,
      "businessContext": "Moment of inertia of the joist cross-section",
      "label_i18n": {
        "en": "Moment of Inertia (in⁴)",
        "tr": "Moment of Inertia (in⁴)",
        "de": "Moment of Inertia (in⁴)",
        "fr": "Moment of Inertia (in⁴)",
        "es": "Moment of Inertia (in⁴)",
        "ar": "Moment of Inertia (in⁴)"
      }
    },
    {
      "id": "defl_limit_denom",
      "label": "Deflection Limit (L/x)",
      "type": "number",
      "unit": "unit",
      "default": 360,
      "businessContext": "Deflection limit denominator, e.g., 360 for L/360",
      "label_i18n": {
        "en": "Deflection Limit (L/x)",
        "tr": "Deflection Limit (L/x)",
        "de": "Deflection Limit (L/x)",
        "fr": "Deflection Limit (L/x)",
        "es": "Deflection Limit (L/x)",
        "ar": "Deflection Limit (L/x)"
      }
    }
  ],
  "formulas": {
    "w": "(dead_load_psf + live_load_psf) * spacing_in / 144",
    "span_in": "span_ft * 12",
    "actual_deflection_in": "(5 * w * Math.pow(span_in, 4)) / (384 * E_psi * I_in4)",
    "allowable_deflection_in": "span_in / defl_limit_denom",
    "deflection_ratio": "actual_deflection_in / allowable_deflection_in",
    "max_span_in": "Math.cbrt((384 * E_psi * I_in4) / (5 * w * defl_limit_denom))",
    "max_span_ft": "max_span_in / 12",
    "actual_deflection_str": "'Actual Deflection: ' + actual_deflection_in.toFixed(2) + ' in'",
    "allowable_deflection_str": "'Allowable Deflection: ' + allowable_deflection_in.toFixed(2) + ' in'",
    "max_span_str": "'Max Span: ' + max_span_ft.toFixed(2) + ' ft'"
  },
  "outputs": {
    "primary": "deflection_ratio",
    "breakdown": [
      "actual_deflection_str",
      "allowable_deflection_str",
      "max_span_str"
    ]
  },
  "category": "Makine & Tasarım",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",

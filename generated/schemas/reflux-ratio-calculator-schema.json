  "formulas": {
    "refluxRatio": "refluxFlow / distillateFlow",
    "bottomsFlow": "feedFlow - distillateFlow",
    "bottomsComposition": "(feedFlow * feedComposition - distillateFlow * distillateComposition) / (feedFlow - distillateFlow)",
    "vaporFlow": "refluxFlow + distillateFlow",
    "boilUpRatio": "(refluxFlow + distillateFlow) / (feedFlow - distillateFlow)"
  },
  "outputs": {
    "primary": "refluxRatio",
    "breakdown": [
      "boilUpRatio",
      "bottomsComposition",

      },
      "businessContext_i18n": {
        "en": "Consolidation loan term (months)",
        "tr": "Birleştirme Kredisi Vadesi (ay)",
        "de": "Laufzeit des Konsolidierungskredits (Monate)",
        "fr": "Durée du prêt de consolidation (en mois)",
        "es": "Plazo del préstamo de consolidación (en meses)",
        "ar": "أجل قرض التوحيد (شهر)"
      }
    },
    {
      "id": "consolidationFee",
      "label": "Konsolidasyon Ücreti",
      "type": "number",
      "unit": "TL",
      "default": 500,
      "businessContext": "Kredi yapılandırma veya dosya masrafı",
      "label_i18n": {
        "en": "Consolidation Fee",
        "tr": "Konsolidasyon Ücreti",
        "de": "Konsolidierungsgebühr",
        "fr": "Frais de consolidation",
        "es": "Comisión de consolidación",
        "ar": "رسوم التوحيد"
      },
      "businessContext_i18n": {
        "en": "Loan restructuring or processing fee",
        "tr": "Kredi yapılandırma veya dosya masrafı",
        "de": "Kreditbearbeitungs- oder Abschlussgebühr",
        "fr": "Frais de restructuration ou de dossier",
        "es": "Cargo por reestructuración o gastos de gestión",
        "ar": "رسوم إعادة هيكلة القرض أو رسوم الملف"
      }
    }
  ],
  "formulas": {
    "currentTotalCost": "currentMonthlyPayment * currentRemainingMonths",
    "newLoanAmount": "currentTotalDebt + consolidationFee",
    "monthlyRate": "newInterestRate / 100 / 12"
  },
  "outputs": {
    "primary": "monthlyRate",
    "breakdown": [
      "currentTotalCost",
      "newTotalCost",
      "newMonthlyPayment",
      "currentMonthlyPayment"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "savings",
    "unit": "TL"
  },
  "category": "Finans & Yatırım",

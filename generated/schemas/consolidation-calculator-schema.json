        "es": "Pago mensual total de todas las deudas actuales",
        "ar": "إجمالي الدفعة الشهرية لجميع الديون الحالية"
      }
    },
    {
      "id": "currentRemainingMonths",
      "label": "Kalan Vade",
      "type": "number",
      "unit": "ay",
      "default": 60,
      "businessContext": "Average remaining maturity of existing debts (in months)",
      "label_i18n": {
        "en": "Kalan Vade",

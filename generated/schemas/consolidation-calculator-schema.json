      }
    },
    {
      "id": "newTermMonths",
      "label": "Yeni Vade",
      "type": "number",
      "unit": "ay",
      "default": 48,
      "businessContext": "Konsolidasyon kredisi vadesi (ay)",
      "label_i18n": {
        "en": "Yeni Vade",
        "tr": "Yeni Vade (ay)",
        "de": "Neue Laufzeit",

      "label": "Yeni Faiz Oranı",
      "type": "number",
      "unit": "% yıllık",
      "default": 15,
      "businessContext": "Konsolidasyon kredisi yıllık faiz oranı",
      "label_i18n": {
        "en": "New Interest Rate",
        "tr": "Yeni Faiz Oranı",
        "de": "Neuer Zinssatz",
        "fr": "Nouveau taux d'intérêt",

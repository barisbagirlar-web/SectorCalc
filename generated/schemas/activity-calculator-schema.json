  "formulas": {
    "actualProductionTime": "availableTime - downtime",
    "activityRate": "actualOutput / actualProductionTime",
    "efficiency": "actualOutput / plannedOutput",
    "utilization": "actualProductionTime / availableTime",
    "theoreticalMaxOutput": "(availableTime * 3600) / cycleTime",
    "performance": "actualOutput / theoreticalMaxOutput"
  },
  "outputs": {
    "primary": "activityRate",

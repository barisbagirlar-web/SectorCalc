  "formulas": {
    "profit": "stake * (numerator / denominator)",
    "totalPayoutBeforeTax": "stake * (1 + numerator / denominator)",
    "decimalOdds": "1 + numerator / denominator",
    "impliedProbability": "(denominator / (numerator + denominator)) * 100",
    "netProfitAfterTax": "(stake * (numerator / denominator)) * (1 - taxRate / 100)",
    "netTotalPayoutAfterTax": "stake + (stake * (numerator / denominator)) * (1 - taxRate / 100)"
  },
  "outputs": {
    "primary": "totalPayoutBeforeTax",
    "breakdown": [
      "profit",

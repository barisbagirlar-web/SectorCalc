        "es": "Unidades totales producidas",
        "ar": "إجمالي الوحدات المنتجة"
      }
    }
  ],
  "formulas": {
    "totalDirectCost": "materialCost + laborCost + machineCost",
    "overheadAmount": "totalDirectCost * (overheadPercent / 100)",
    "totalCostBeforeMarkup": "totalDirectCost + overheadAmount",
    "totalCost": "totalCostBeforeMarkup * (1 + markupPercent / 100)",
    "costPerUnit": "totalCost / units"
  },
  "outputs": {
    "primary": "costPerUnit",
    "breakdown": [
      "totalDirectCost",
      "overheadAmount",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerUnit",

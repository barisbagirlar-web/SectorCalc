        "ar": "Markup %"
      },
      "businessContext_i18n": {
        "en": "Profit markup percentage on total cost",
        "tr": "Toplam maliyet üzerinden kar marjı yüzdesi",
        "de": "Gewinnaufschlag in Prozent der Gesamtkosten"
      }
    },
    {
      "id": "units",
      "label": "Number of Units",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Total units produced",
      "label_i18n": {
        "en": "Number of Units",
        "tr": "Birim Sayısı",
        "de": "Anzahl der Einheiten",
        "fr": "Number of Units",
        "es": "Number of Units",
        "ar": "Number of Units"
      },
      "businessContext_i18n": {
        "en": "Total units produced",
        "tr": "Üretilen toplam birim",
        "de": "Insgesamt produzierte Einheiten"
      }
    }
  ],
  "formulas": {
    "totalDirectCost": "materialCost + laborCost + machineCost",
    "overheadAmount": "totalDirectCost * (overheadPercent / 100)",
    "totalCostBeforeMarkup": "totalDirectCost + overheadAmount",
    "totalCost": "totalCostBeforeMarkup * (1 + markupPercent / 100)",
    "costPerUnit": "totalCost / units"
  },
  "outputs": {
    "primary": "costPerUnit",
    "breakdown": [
      "totalDirectCost",
      "overheadAmount",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerUnit",

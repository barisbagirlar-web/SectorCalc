    },
    {
      "id": "markupPercent",
      "label": "Markup %",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Profit markup percentage on total cost",
      "label_i18n": {
        "en": "Markup %",
        "tr": "Kar Marjı %",
        "de": "Aufschlag %",
        "fr": "Markup %",

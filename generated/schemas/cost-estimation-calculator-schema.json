    {
      "id": "units",
      "label": "Number of Units",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Total units produced",
      "label_i18n": {
        "en": "Number of Units",
        "tr": "Birim Sayısı",
        "de": "Anzahl der Einheiten",

{
  "toolName": "twilight-calculator",
  "inputs": [
    {
      "id": "full_power",
      "label": "Full Power Consumption",
      "type": "number",
      "unit": "W",
      "default": 100,
      "businessContext": "Nominal güç tüketimi (Watt)",
      "label_i18n": {
        "en": "Full Power Consumption",
        "tr": "Full Power Consumption",
        "de": "Full Power Consumption",
        "fr": "Full Power Consumption",
        "es": "Full Power Consumption",
        "ar": "Full Power Consumption"
      }
    },
    {
      "id": "dimming_percent",
      "label": "Dimming Percentage",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Karartma yüzdesi",
      "label_i18n": {
        "en": "Dimming Percentage",
        "tr": "Dimming Percentage",
        "de": "Dimming Percentage",
        "fr": "Dimming Percentage",
        "es": "Dimming Percentage",
        "ar": "Dimming Percentage"
      }
    },
    {
      "id": "exponent",
      "label": "Dimming Curve Exponent",
      "type": "number",
      "unit": "unit",
      "default": 2.2,
      "businessContext": "LED sönümlendirme eğrisi üssü",
      "label_i18n": {
        "en": "Dimming Curve Exponent",
        "tr": "Dimming Curve Exponent",
        "de": "Dimming Curve Exponent",
        "fr": "Dimming Curve Exponent",
        "es": "Dimming Curve Exponent",
        "ar": "Dimming Curve Exponent"
      }
    },
    {
      "id": "operating_hours",
      "label": "Daily Operating Hours",
      "type": "number",
      "unit": "h",
      "default": 12,
      "businessContext": "Günlük çalışma saati",
      "label_i18n": {
        "en": "Daily Operating Hours",
        "tr": "Daily Operating Hours",
        "de": "Daily Operating Hours",
        "fr": "Daily Operating Hours",
        "es": "Daily Operating Hours",
        "ar": "Daily Operating Hours"
      }
    },
    {
      "id": "cost_per_kwh",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "₺/kWh",
      "default": 0.15,
      "businessContext": "Elektrik birim fiyatı",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Electricity Cost",
        "de": "Electricity Cost",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      }
    }
  ],
  "formulas": {
    "dimming_factor": "(dimming_percent / 100) ** exponent",
    "actual_power": "full_power * dimming_factor",
    "daily_energy_saved_wh": "(full_power - actual_power) * operating_hours",
    "daily_cost_savings": "daily_energy_saved_wh * cost_per_kwh / 1000"
  },
  "outputs": {
    "primary": "daily_cost_savings",
    "breakdown": [
      "actual_power",
      "daily_energy_saved_wh",
      "dimming_factor"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "date-time",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems"
}

  "formulas": {
    "dimming_factor": "(dimming_percent / 100) ** exponent",
    "actual_power": "full_power * dimming_factor",
    "daily_energy_saved_wh": "(full_power - actual_power) * operating_hours",
    "daily_cost_savings": "daily_energy_saved_wh * cost_per_kwh / 1000"
  },

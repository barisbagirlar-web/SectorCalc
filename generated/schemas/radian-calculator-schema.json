      }
    },
    {
      "id": "time",
      "label": "Time",
      "type": "number",
      "unit": "s",
      "default": 1,
      "businessContext": "Time interval for angular displacement",
      "label_i18n": {
        "en": "Time",
        "tr": "Time",
        "de": "Time",
        "fr": "Time",
        "es": "Time",
        "ar": "Time"
      }
    },
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Radius of circular path",
      "label_i18n": {
        "en": "Radius",
        "tr": "Radius",
        "de": "Radius",
        "fr": "Radius",
        "es": "Radius",
        "ar": "Radius"
      }
    }
  ],
  "formulas": {
    "angularDisplacementRad": "(finalAngleDeg - initialAngleDeg) * Math.PI / 180",
    "angularVelocityRadPerSec": "angularDisplacementRad / time",
    "linearVelocity": "angularVelocityRadPerSec * radius",
    "arcLength": "angularDisplacementRad * radius"
  },
  "outputs": {
    "primary": "angularDisplacementRad",
    "breakdown": [
      "angularVelocityRadPerSec",
      "linearVelocity",
      "arcLength"
    ]
  },

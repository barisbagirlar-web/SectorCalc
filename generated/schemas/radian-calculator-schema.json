      "id": "finalAngleDeg",
      "label": "Final Angle (Degrees)",
      "type": "number",
      "unit": "°",
      "default": 0,
      "businessContext": "Ending angular position in degrees",
      "label_i18n": {
        "en": "Final Angle (Degrees)",
        "tr": "Final Angle (Degrees)",
        "de": "Final Angle (Degrees)",
        "fr": "Final Angle (Degrees)",

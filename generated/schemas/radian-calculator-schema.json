{
  "toolName": "radian-calculator",
  "inputs": [
    {
      "id": "initialAngleDeg",
      "label": "Initial Angle (Degrees)",
      "type": "number",
      "unit": "°",
      "default": 0,
      "businessContext": "Starting angular position in degrees"
    },
    {
      "id": "finalAngleDeg",
      "label": "Final Angle (Degrees)",
      "type": "number",
      "unit": "°",
      "default": 0,
      "businessContext": "Ending angular position in degrees"
    },
    {
      "id": "time",
      "label": "Time",
      "type": "number",
      "unit": "s",
      "default": 1,
      "businessContext": "Time interval for angular displacement"
    },
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Radius of circular path"
    }
  ],
  "formulas": {
    "angularDisplacementRad": "(finalAngleDeg - initialAngleDeg) * Math.PI / 180",
    "angularVelocityRadPerSec": "angularDisplacementRad / time",
    "linearVelocity": "angularVelocityRadPerSec * radius",
    "arcLength": "angularDisplacementRad * radius"
  },
  "outputs": {
    "primary": "angularDisplacementRad",
    "breakdown": [
      "angularVelocityRadPerSec",
      "linearVelocity",
      "arcLength"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

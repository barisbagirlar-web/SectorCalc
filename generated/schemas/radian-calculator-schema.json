  "formulas": {
    "angularDisplacementRad": "(finalAngleDeg - initialAngleDeg) * Math.PI / 180",
    "angularVelocityRadPerSec": "angularDisplacementRad / time",
    "linearVelocity": "angularVelocityRadPerSec * radius",
    "arcLength": "angularDisplacementRad * radius"
  },

{
  "toolName": "serving-size-calculator",
  "inputs": [
    {
      "id": "totalWeight",
      "label": "Total Batch Weight",
      "type": "number",
      "unit": "g",
      "default": 1000,
      "businessContext": "Total weight of the entire batch or recipe in grams."
    },
    {
      "id": "numberOfServings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 10,
      "businessContext": "Number of servings the batch yields."
    },
    {
      "id": "desiredServings",
      "label": "Desired Servings",
      "type": "number",
      "unit": "servings",
      "default": 20,
      "businessContext": "Target number of servings for scaling."
    },
    {
      "id": "batchCost",
      "label": "Total Batch Cost",
      "type": "number",
      "unit": "currency",
      "default": 50,
      "businessContext": "Total cost of ingredients for the batch."
    }
  ],
  "formulas": {
    "servingWeight": "totalWeight / numberOfServings",
    "scaledWeight": "(totalWeight / numberOfServings) * desiredServings",
    "costPerServing": "batchCost / numberOfServings"
  },
  "outputs": {
    "primary": "servingWeight",
    "breakdown": [
      "scaledWeight",
      "costPerServing"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "finance-sales-working-capital"
}

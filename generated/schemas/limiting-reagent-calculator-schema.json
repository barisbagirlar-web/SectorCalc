  "formulas": {
    "moles1": "reactant1Mass / reactant1MolarMass",
    "moles2": "reactant2Mass / reactant2MolarMass",
    "ratio1": "moles1 / reactant1Coefficient",
    "ratio2": "moles2 / reactant2Coefficient",
    "limitingReagent": "ratio1 <= ratio2 ? 'Reactant 1' : 'Reactant 2'",
    "theoreticalYield": "Math.min(ratio1, ratio2) * productCoefficient * productMolarMass"
  },
  "outputs": {
    "primary": "limitingReagent",
    "breakdown": [
      "moles1",
      "moles2",
      "theoreticalYield"
    ]

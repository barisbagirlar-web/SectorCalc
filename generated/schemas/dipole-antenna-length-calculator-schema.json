{
  "toolName": "dipole-antenna-length-calculator",
  "inputs": [
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "number",
      "unit": "MHz",
      "default": 100,
      "businessContext": "Operating frequency in megahertz",
      "label_i18n": {
        "en": "Frequency",
        "tr": "Frekans",
        "de": "Frequency",
        "fr": "Frequency",
        "es": "Frequency",
        "ar": "Frequency"
      },
      "businessContext_i18n": {
        "en": "Operating frequency in megahertz",
        "tr": "Megahertz cinsinden çalışma frekansı"
      }
    },
    {
      "id": "velocityFactor",
      "label": "Velocity Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.95,
      "businessContext": "Velocity factor of wire or cable. 0.95 for bare copper, 0.66 for insulated wire",
      "label_i18n": {
        "en": "Velocity Factor",
        "tr": "Hız Faktörü",
        "de": "Velocity Factor",
        "fr": "Velocity Factor",
        "es": "Velocity Factor",
        "ar": "Velocity Factor"
      },
      "businessContext_i18n": {
        "en": "Velocity factor of wire or cable. 0.95 for bare copper, 0.66 for insulated wire",
        "tr": "Tel veya kablonun hız faktörü. Çıplak bakır için 0.95, yalıtımlı tel için 0.66."
      }
    },
    {
      "id": "wavelengthFraction",
      "label": "Wavelength Fraction",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Fraction of wavelength. Use 0.5 for half-wave dipole, 1.0 for full-wave",
      "label_i18n": {
        "en": "Wavelength Fraction",
        "tr": "Dalga Boyu Kesri",
        "de": "Wavelength Fraction",
        "fr": "Wavelength Fraction",
        "es": "Wavelength Fraction",
        "ar": "Wavelength Fraction"
      },
      "businessContext_i18n": {
        "en": "Fraction of wavelength. Use 0.5 for half-wave dipole, 1.0 for full-wave",
        "tr": "Dalga boyunun kesri. Yarım dalga dipol için 0.5, tam dalga için 1.0 kullanın."
      }
    },
    {
      "id": "unitSelection",
      "label": "Unit Selection",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 for feet, 1 for meters",
      "label_i18n": {
        "en": "Unit Selection",
        "tr": "Birim Seçimi",
        "de": "Unit Selection",
        "fr": "Unit Selection",
        "es": "Unit Selection",
        "ar": "Unit Selection"
      },
      "businessContext_i18n": {
        "en": "0 for feet, 1 for meters",
        "tr": "Fit için 0, metre için 1."
      }
    },
    {
      "id": "endEffectCorrection",
      "label": "End Effect Correction",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Adjustment factor for end effect. Use 0.95-0.98 for practical shortening",
      "label_i18n": {
        "en": "End Effect Correction",
        "tr": "Uç Etkisi Düzeltmesi",
        "de": "End Effect Correction",
        "fr": "End Effect Correction",
        "es": "End Effect Correction",
        "ar": "End Effect Correction"
      },
      "businessContext_i18n": {
        "en": "Adjustment factor for end effect. Use 0.95-0.98 for practical shortening",
        "tr": "Uç etkisi için ayar faktörü. Pratik kısaltma için 0.95-0.98 kullanın."
      }
    }
  ],
  "formulas": {
    "lengthFeet": "492 * velocityFactor * wavelengthFraction * endEffectCorrection / frequency",
    "lengthMeters": "300 * velocityFactor * wavelengthFraction * endEffectCorrection / frequency",
    "lengthInSelectedUnit": "unitSelection === 0 ? 492 * velocityFactor * wavelengthFraction * endEffectCorrection / frequency : 300 * velocityFactor * wavelengthFraction * endEffectCorrection / frequency"
  },
  "outputs": {
    "primary": "lengthInSelectedUnit",
    "breakdown": [
      "lengthFeet",
      "lengthMeters"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "lengthInSelectedUnit",
    "unit": "MHz",
    "breakdownUnits": {
      "lengthMeters": "m"
    }
  },
  "category": "Dönüşüm & Ölçüm",

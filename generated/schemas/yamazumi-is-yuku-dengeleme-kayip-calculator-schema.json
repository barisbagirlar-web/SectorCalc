{
  "toolName": "yamazumi-is-yuku-dengeleme-kayip-calculator",
  "inputs": [
    {
      "id": "cycleTimes",
      "label": "Cycle Times (s)",
      "type": "number",
      "unit": "seconds",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Her istasyon için çevrim süreleri. Yamazumi analizinde kullanılır. Kaynak: Lean üretim, Maynard Endüstri Mühendisliği El Kitabı."
    },
    {
      "id": "taktTime",
      "label": "Takt Time (s)",
      "type": "number",
      "unit": "seconds",
      "default": 60,
      "min": 0.1,
      "max": null,
      "options": null,
      "businessContext": "Müşteri talebine göre hesaplanan ideal çevrim süresi. Kaynak: Lean üretim, JIT."
    },
    {
      "id": "numberOfStations",
      "label": "Number of Stations",
      "type": "number",
      "unit": "stations",
      "default": 1,
      "min": 1,
      "max": null,
      "options": null,
      "businessContext": "Hat üzerindeki istasyon sayısı. Kaynak: Endüstri mühendisliği."
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour ($)",
      "type": "number",
      "unit": "$/hour",
      "default": 20,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "İşçilik saatlik maliyeti. Kaynak: Finansal analiz."
    },
    {
      "id": "workingHoursPerDay",
      "label": "Working Hours per Day",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "min": 0,
      "max": 24,
      "options": null,
      "businessContext": "Günlük çalışma saati. Kaynak: İş etüdü."
    },
    {
      "id": "workingDaysPerYear",
      "label": "Working Days per Year",
      "type": "number",
      "unit": "days",
      "default": 250,
      "min": 1,
      "max": 365,
      "options": null,
      "businessContext": "Yıllık çalışma günü sayısı. Kaynak: Takvim."
    },
    {
      "id": "defectRate",
      "label": "Defect Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Kusur oranı. Kaynak: Six Sigma, ISO 9001."
    },
    {
      "id": "reworkCostPerUnit",
      "label": "Rework Cost per Unit ($)",
      "type": "number",
      "unit": "$",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Birim başına yeniden işleme maliyeti. Kaynak: Kalite maliyetleri."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence (0-1)",
      "type": "number",
      "unit": "ratio",
      "default": 1,
      "min": 0,
      "max": 1,
      "options": null,
      "businessContext": "Veri güvenilirliği katsayısı. Kaynak: Risk analizi."
    }
  ],
  "validation": {
    "rules": [
      "taktTime > 0",
      "numberOfStations >= 1",
      "laborCostPerHour >= 0",
      "workingHoursPerDay > 0 && workingHoursPerDay <= 24",
      "workingDaysPerYear > 0 && workingDaysPerYear <= 365",
      "defectRate >= 0 && defectRate <= 100",
      "reworkCostPerUnit >= 0",
      "dataConfidence >= 0 && dataConfidence <= 1",
      "cycleTimes array length must equal numberOfStations"
    ],
    "thresholds": {
      "defectRate": "defectRate > 5 ? 'Kritik: Kusur oranı %5 üzerinde' : ''",
      "balanceEfficiency": "balanceEfficiency < 0.8 ? 'Uyarı: Denge verimliliği %80 altında' : ''"
    }
  },
  "formulas": {
    "totalCycleTime": "sum(cycleTimes)",
    "maxCycleTime": "max(cycleTimes)",
    "balanceEfficiency": "totalCycleTime / (maxCycleTime * numberOfStations)",
    "totalLaborCostPerYear": "laborCostPerHour * workingHoursPerDay * workingDaysPerYear * numberOfStations",
    "defectCostPerYear": "defectRate / 100 * (totalCycleTime / taktTime) * workingHoursPerDay * workingDaysPerYear * reworkCostPerUnit",
    "totalLoss": "totalLaborCostPerYear * (1 - balanceEfficiency) + defectCostPerYear",
    "dataConfidenceAdjustedLoss": "totalLoss * (1 + (1 - dataConfidence))"
  },
  "outputs": {
    "primary": "totalLoss",
    "breakdown": {
      "balanceEfficiency": "balanceEfficiency",
      "totalCycleTime": "totalCycleTime",
      "maxCycleTime": "maxCycleTime",
      "totalLaborCostPerYear": "totalLaborCostPerYear",
      "defectCostPerYear": "defectCostPerYear"
    },
    "hiddenLossDrivers": [
      "defectRate > 5 ? 'Yüksek kusur oranı' : ''",
      "balanceEfficiency < 0.8 ? 'Düşük denge verimliliği' : ''"
    ],
    "suggestedActions": [
      "balanceEfficiency < 0.8 ? 'İstasyon sürelerini dengelemek için iş yükü yeniden dağıtın' : ''",
      "defectRate > 5 ? 'Kök neden analizi yaparak kusur oranını azaltın' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjustedLoss"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Benchmark Comparison",
    "Detailed Report with Charts"
  ],
  "premiumRequired": true
}

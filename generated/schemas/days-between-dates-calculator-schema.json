  "formulas": {
    "startDateISO": "`${startYear}-${String(startMonth).padStart(2, '0')}-${String(startDay).padStart(2, '0')}`",
    "endDateISO": "`${endYear}-${String(endMonth).padStart(2, '0')}-${String(endDay).padStart(2, '0')}`",
    "daysBetween": "(new Date(endYear, endMonth - 1, endDay) - new Date(startYear, startMonth - 1, startDay)) / (1000 * 60 * 60 * 24)"
  },
  "outputs": {
    "primary": "daysBetween",
    "breakdown": [
      "startDateISO",
      "endDateISO",
      "daysBetween"
    ]

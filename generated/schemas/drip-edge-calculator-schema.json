{
  "toolName": "drip-edge-calculator",
  "inputs": [
    {
      "id": "roofLength",
      "label": "Roof Length",
      "type": "number",
      "unit": "ft",
      "default": 40,
      "businessContext": "Horizontal length of the eave edge (building length), used to calculate total eave drip edge distance.",
      "label_i18n": {
        "en": "Roof Length",

      }
    },
    {
      "id": "roofWidth",
      "label": "Roof Width",
      "type": "number",
      "unit": "ft",
      "default": 30,
      "businessContext": "Horizontal span from eave to eave (building width), used to compute the horizontal run of the gable rake.",
      "label_i18n": {
        "en": "Roof Width",
        "tr": "Roof Width",
        "de": "Roof Width",
        "fr": "Roof Width",
        "es": "Roof Width",
        "ar": "Roof Width"
      }
    },
    {
      "id": "roofPitch",
      "label": "Roof Pitch",
      "type": "number",
      "unit": "in/12in",
      "default": 4,
      "businessContext": "Rise in inches per 12 inches of horizontal run, used to compute the slope length of the rake.",
      "label_i18n": {
        "en": "Roof Pitch",
        "tr": "Roof Pitch",
        "de": "Roof Pitch",
        "fr": "Roof Pitch",
        "es": "Roof Pitch",
        "ar": "Roof Pitch"
      }
    },
    {
      "id": "gableOverhang",
      "label": "Gable Overhang",
      "type": "number",
      "unit": "ft",
      "default": 1,
      "businessContext": "Horizontal projection of the rake beyond the gable wall, added to half of roof width to obtain the total run.",
      "label_i18n": {
        "en": "Gable Overhang",
        "tr": "Gable Overhang",
        "de": "Gable Overhang",
        "fr": "Gable Overhang",
        "es": "Gable Overhang",
        "ar": "Gable Overhang"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of extra material to allow for cutting, fitting, and installation errors.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "run": "roofWidth / 2 + gableOverhang",
    "rise": "run * (roofPitch / 12)",
    "eaveLength": "2 * roofLength"
  },

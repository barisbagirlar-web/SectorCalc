{
  "toolName": "hcg-calculator",
  "inputs": [
    {
      "id": "hcg_level",
      "label": "HCG Level (mIU/mL)",
      "type": "number",
      "unit": "mIU/mL",
      "default": 100,
      "businessContext": "Current HCG concentration in blood or urine sample",
      "label_i18n": {
        "en": "HCG Level (mIU/mL)",
        "tr": "HCG Level (mIU/mL)",
        "de": "HCG Level (mIU/mL)",
        "fr": "HCG Level (mIU/mL)",
        "es": "HCG Level (mIU/mL)",
        "ar": "HCG Level (mIU/mL)"
      }
    },
    {
      "id": "doubling_time_hours",
      "label": "Doubling Time (hours)",
      "type": "number",
      "unit": "hours",
      "default": 48,
      "businessContext": "Expected time for HCG level to double in early pregnancy",
      "label_i18n": {
        "en": "Doubling Time (hours)",
        "tr": "Doubling Time (hours)",
        "de": "Doubling Time (hours)",
        "fr": "Doubling Time (hours)",
        "es": "Doubling Time (hours)",
        "ar": "Doubling Time (hours)"
      }
    },
    {
      "id": "time_elapsed_hours",
      "label": "Time Elapsed (hours)",
      "type": "number",
      "unit": "hours",
      "default": 24,
      "businessContext": "Time interval since the last measurement",
      "label_i18n": {
        "en": "Time Elapsed (hours)",
        "tr": "Time Elapsed (hours)",
        "de": "Time Elapsed (hours)",
        "fr": "Time Elapsed (hours)",
        "es": "Time Elapsed (hours)",
        "ar": "Time Elapsed (hours)"
      }
    },
    {
      "id": "initial_hcg",
      "label": "Initial HCG Level (mIU/mL)",
      "type": "number",
      "unit": "mIU/mL",
      "default": 50,
      "businessContext": "Previous HCG measurement for comparison",
      "label_i18n": {
        "en": "Initial HCG Level (mIU/mL)",
        "tr": "Initial HCG Level (mIU/mL)",
        "de": "Initial HCG Level (mIU/mL)",
        "fr": "Initial HCG Level (mIU/mL)",
        "es": "Initial HCG Level (mIU/mL)",
        "ar": "Initial HCG Level (mIU/mL)"
      }
    }
  ],
  "formulas": {
    "projected_hcg": "hcg_level * Math.pow(2, time_elapsed_hours / doubling_time_hours)",
    "doubling_time_actual": "time_elapsed_hours * Math.log(2) / Math.log(hcg_level / initial_hcg)",
    "hcg_ratio": "hcg_level / initial_hcg",
    "percent_increase": "(hcg_level - initial_hcg) / initial_hcg * 100"
  },
  "outputs": {
    "primary": "projected_hcg",
    "breakdown": [
      "doubling_time_actual",
      "hcg_ratio",
      "percent_increase"
    ]
  },

      }
    },
    {
      "id": "toBase",
      "label": "To Base",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "The target logarithm base to convert to.",
      "label_i18n": {
        "en": "To Base",
        "tr": "To Base",
        "de": "To Base",
        "fr": "To Base",
        "es": "To Base",
        "ar": "To Base"

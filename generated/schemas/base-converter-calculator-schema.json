    },
    {
      "id": "fromBase",
      "label": "From Base",
      "type": "number",
      "unit": "unit",
      "default": 10,
      "businessContext": "The base of the logarithm you are converting from.",
      "label_i18n": {
        "en": "From Base",
        "tr": "From Base",
        "de": "From Base",
        "fr": "From Base",

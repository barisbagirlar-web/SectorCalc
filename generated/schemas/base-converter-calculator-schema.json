    },
    {
      "id": "roundDigits",
      "label": "Decimal Places",
      "type": "number",
      "unit": "digits",
      "default": 4,
      "businessContext": "Number of decimal places for rounding the result.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "primary": "Math.round((Math.log(inputNumber) / Math.log(toBase)) * Math.pow(10, roundDigits)) / Math.pow(10, roundDigits)",
    "logFromBase": "Math.round((Math.log(inputNumber) / Math.log(fromBase)) * Math.pow(10, roundDigits)) / Math.pow(10, roundDigits)",
    "naturalLog": "Math.round(Math.log(inputNumber) * Math.pow(10, roundDigits)) / Math.pow(10, roundDigits)",
    "log__fromBase__inputNumber_": "log_{fromBase}(inputNumber)",
    "ln_inputNumber_": "ln(inputNumber)",
    "result": "log_{toBase}(inputNumber)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "log_{fromBase}(inputNumber)",
      "ln(inputNumber)"
    ]
  },

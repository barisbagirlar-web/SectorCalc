  "formulas": {
    "netArea": "totalWallArea - doorWindowArea",
    "wasteFactor": "1 + (wastePercentage / 100)",
    "panelsNeeded": "(netArea * wasteFactor) / panelCoverage",
    "wasteArea": "netArea * (wastePercentage / 100)",
    "totalCost": "panelsNeeded * pricePerPanel"
  },

{
  "toolName": "vinyl-siding-calculator",
  "inputs": [
    {
      "id": "totalWallArea",
      "label": "Toplam Duvar Alanı",
      "type": "number",
      "unit": "sq ft",
      "default": 1000,
      "businessContext": "Tüm duvarların brüt alanı"
    },
    {
      "id": "doorWindowArea",
      "label": "Kapı ve Pencere Alanı",
      "type": "number",
      "unit": "sq ft",
      "default": 100,
      "businessContext": "Kaplama yapılmayacak alan"
    },
    {
      "id": "panelCoverage",
      "label": "Panel Kaplama Alanı",
      "type": "number",
      "unit": "sq ft",
      "default": 8,
      "businessContext": "Bir panelin kapladığı alan (genellikle 12 ft x 8 inç = 8 sq ft)"
    },
    {
      "id": "pricePerPanel",
      "label": "Panel Başına Fiyat",
      "type": "number",
      "unit": "USD",
      "default": 10,
      "businessContext": "Bir panelin satın alma maliyeti"
    },
    {
      "id": "wastePercentage",
      "label": "Fire Yüzdesi",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Kesme ve hatalardan kaynaklanan ilave malzeme yüzdesi"
    }
  ],
  "formulas": {
    "netArea": "totalWallArea - doorWindowArea",
    "wasteFactor": "1 + (wastePercentage / 100)",
    "panelsNeeded": "(netArea * wasteFactor) / panelCoverage",
    "wasteArea": "netArea * (wastePercentage / 100)",
    "totalCost": "panelsNeeded * pricePerPanel"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "netArea",
      "wasteFactor",
      "panelsNeeded",
      "wasteArea",
      "totalCost"
    ]
  },
  "category": "Çevre & Emisyon",
  "sector": "Sürdürülebilirlik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "sustainability-resource-esg"
}

    {
      "id": "wastePercentage",
      "label": "Fire Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional material percentage from cutting and errors",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Fire Yüzdesi",
        "de": "Prozessverlust in Prozent",
        "fr": "Pourcentage de rebut",
        "es": "Porcentaje de merma",
        "ar": "نسبة الهدر"
      },
      "businessContext_i18n": {
        "en": "Additional material percentage due to cutting and errors",
        "tr": "Kesme ve hatalardan kaynaklanan ilave malzeme yüzdesi",
        "de": "Zusätzlicher Materialanteil (%) durch Zuschnitt und Fehler",
        "fr": "Pourcentage de matériau supplémentaire pour les coupes et les défauts",
        "es": "Porcentaje adicional de material por cortes y errores",
        "ar": "نسبة المواد الإضافية الناتجة عن القص والأخطاء"
      }
    }
  ],
  "formulas": {
    "netArea": "totalWallArea - doorWindowArea",
    "wasteFactor": "1 + (wastePercentage / 100)",
    "panelsNeeded": "(netArea * wasteFactor) / panelCoverage",
    "wasteArea": "netArea * (wastePercentage / 100)",
    "totalCost": "panelsNeeded * pricePerPanel"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "netArea",
      "wasteFactor",
      "panelsNeeded",
      "wasteArea",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

      }
    },
    {
      "id": "endOdometer",
      "label": "End Odometer",
      "type": "number",
      "unit": "miles",
      "default": 0,
      "businessContext": "Final odometer reading after trip",
      "label_i18n": {
        "en": "End Odometer",
        "tr": "End Odometer",
        "de": "End Odometer",
        "fr": "End Odometer",
        "es": "End Odometer",
        "ar": "End Odometer"
      }
    },
    {
      "id": "fuelGallons",
      "label": "Fuel Used",
      "type": "number",
      "unit": "gallons",
      "default": 0,
      "businessContext": "Volume of fuel consumed during trip",
      "label_i18n": {
        "en": "Fuel Used",
        "tr": "Fuel Used",
        "de": "Fuel Used",
        "fr": "Fuel Used",
        "es": "Fuel Used",
        "ar": "Fuel Used"
      }
    },
    {
      "id": "fuelPricePerGallon",
      "label": "Fuel Price",
      "type": "number",
      "unit": "USD/gallon",
      "default": 0,
      "businessContext": "Price of fuel per gallon for cost calculation",
      "label_i18n": {
        "en": "Fuel Price",
        "tr": "Fuel Price",
        "de": "Fuel Price",
        "fr": "Fuel Price",
        "es": "Fuel Price",
        "ar": "Fuel Price"
      }
    }
  ],
  "formulas": {
    "mpg": "(endOdometer - startOdometer) / fuelGallons",
    "costPerMile": "(fuelGallons * fuelPricePerGallon) / (endOdometer - startOdometer)",
    "totalDistance": "endOdometer - startOdometer",
    "fuelCostTotal": "fuelGallons * fuelPricePerGallon"
  },
  "outputs": {
    "primary": "mpg",
    "breakdown": [
      "mpg",
      "costPerMile",
      "totalDistance",
      "fuelCostTotal"
    ],

{
  "toolName": "days-inventory-outstanding-calculator",
  "inputs": [
    {
      "id": "averageInventory",
      "label": "Average Inventory",
      "type": "number",
      "unit": "currency (e.g., USD)",
      "default": 0,
      "businessContext": "The average value of inventory held during the period. Typically (Beginning Inventory + Ending Inventory) / 2.",
      "label_i18n": {
        "en": "Average Inventory",
        "tr": "Average Inventory",
        "de": "Average Inventory",
        "fr": "Average Inventory",
        "es": "Average Inventory",
        "ar": "Average Inventory"
      }
    },
    {
      "id": "costOfGoodsSold",
      "label": "Cost of Goods Sold (COGS)",
      "type": "number",
      "unit": "currency (e.g., USD)",
      "default": 0,
      "businessContext": "The total cost of goods sold during the period.",
      "label_i18n": {
        "en": "Cost of Goods Sold (COGS)",
        "tr": "Cost of Goods Sold (COGS)",
        "de": "Cost of Goods Sold (COGS)",
        "fr": "Cost of Goods Sold (COGS)",
        "es": "Cost of Goods Sold (COGS)",
        "ar": "Cost of Goods Sold (COGS)"
      }
    },
    {
      "id": "periodDays",
      "label": "Period Length (Days)",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "Number of days in the measurement period. Standard is 365 for annual calculation.",
      "label_i18n": {
        "en": "Period Length (Days)",
        "tr": "Period Length (Days)",
        "de": "Period Length (Days)",
        "fr": "Period Length (Days)",
        "es": "Period Length (Days)",
        "ar": "Period Length (Days)"
      }
    },
    {
      "id": "inventoryTurnover",
      "label": "Inventory Turnover Ratio (Optional)",
      "type": "number",
      "unit": "ratio",
      "default": 0,
      "businessContext": "If known, enter the inventory turnover ratio (COGS / Average Inventory). If provided, DIO will be calculated as Period Days / Turnover Ratio. Leave 0 to calculate from Average Inventory and COGS.",
      "label_i18n": {
        "en": "Inventory Turnover Ratio (Optional)",
        "tr": "Inventory Turnover Ratio (Optional)",
        "de": "Inventory Turnover Ratio (Optional)",
        "fr": "Inventory Turnover Ratio (Optional)",
        "es": "Inventory Turnover Ratio (Optional)",
        "ar": "Inventory Turnover Ratio (Optional)"
      }
    }
  ],
  "formulas": {
    "daysInventoryOutstanding": "(inventoryTurnover > 0) ? (periodDays / inventoryTurnover) : ((averageInventory > 0 && costOfGoodsSold > 0) ? (periodDays * averageInventory / costOfGoodsSold) : 0)",
    "inventoryTurnoverRatio": "(inventoryTurnover > 0) ? inventoryTurnover : ((averageInventory > 0 && costOfGoodsSold > 0) ? (costOfGoodsSold / averageInventory) : 0)"
  },
  "outputs": {
    "primary": "daysInventoryOutstanding",
    "breakdown": [
      "inventoryTurnoverRatio",
      "daysInventoryOutstanding"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "inventoryTurnoverRatio"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Lojistik & Tedarik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "procurement-supply-chain",
  "sectorId": "lojistik",

{
  "toolName": "pps-calculator",
  "inputs": [
    {
      "id": "conveyorSpeed",
      "label": "Conveyor Speed",
      "type": "number",
      "unit": "m/s",
      "default": 1,
      "businessContext": "Speed of the conveyor belt",
      "label_i18n": {
        "en": "Conveyor Speed",
        "tr": "Conveyor Speed",
        "de": "Conveyor Speed",
        "fr": "Conveyor Speed",
        "es": "Conveyor Speed",
        "ar": "Conveyor Speed"
      }
    },
    {
      "id": "pieceSpacing",
      "label": "Piece Spacing",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "Distance between consecutive pieces on the conveyor",
      "label_i18n": {
        "en": "Piece Spacing",
        "tr": "Piece Spacing",
        "de": "Piece Spacing",
        "fr": "Piece Spacing",
        "es": "Piece Spacing",
        "ar": "Piece Spacing"
      }
    },
    {
      "id": "numLanes",
      "label": "Number of Lanes",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of parallel lanes on the conveyor",
      "label_i18n": {
        "en": "Number of Lanes",
        "tr": "Number of Lanes",
        "de": "Number of Lanes",
        "fr": "Number of Lanes",
        "es": "Number of Lanes",
        "ar": "Number of Lanes"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Overall line efficiency factor",
      "label_i18n": {
        "en": "Efficiency",
        "tr": "Efficiency",
        "de": "Efficiency",
        "fr": "Efficiency",
        "es": "Efficiency",
        "ar": "Efficiency"
      }
    },
    {
      "id": "shiftDuration",
      "label": "Shift Duration",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Duration of a standard production shift",
      "label_i18n": {
        "en": "Shift Duration",
        "tr": "Shift Duration",
        "de": "Shift Duration",
        "fr": "Shift Duration",
        "es": "Shift Duration",
        "ar": "Shift Duration"
      }
    }
  ],
  "formulas": {
    "productionRate_pps": "(conveyorSpeed / pieceSpacing) * numLanes * (efficiency / 100)",
    "productionRate_pcsPerMinute": "productionRate_pps * 60",
    "productionRate_pcsPerHour": "productionRate_pps * 3600",
    "productionRate_pcsPerShift": "productionRate_pps * 3600 * shiftDuration"
  },
  "outputs": {
    "primary": "productionRate_pps",
    "breakdown": [
      "Production Rate (pieces/minute): productionRate_pcsPerMinute pieces/minute",
      "Production Rate (pieces/hour): productionRate_pcsPerHour pieces/hour",
      "Production Rate (pieces/shift): productionRate_pcsPerShift pieces/shift (assuming ${shiftDuration}h shift)"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "productionRate_pcsPerShift"
  },
  "category": "Enerji & Sürdürülebilirlik",

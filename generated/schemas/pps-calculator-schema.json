        "ar": "Number of Lanes"
      },
      "businessContext_i18n": {
        "en": "Number of parallel lanes on the conveyor",
        "tr": "Konveyör üzerindeki paralel şerit sayısı"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Overall line efficiency factor",
      "label_i18n": {
        "en": "Efficiency",
        "tr": "Verim",
        "de": "Wirkungsgrad",
        "fr": "Efficiency",
        "es": "Efficiency",
        "ar": "Efficiency"
      },
      "businessContext_i18n": {
        "en": "Overall line efficiency factor",
        "tr": "Genel hat verimlilik faktörü"
      }
    },
    {
      "id": "shiftDuration",
      "label": "Shift Duration",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Duration of a standard production shift",
      "label_i18n": {
        "en": "Shift Duration",
        "tr": "Vardiya Süresi",
        "de": "Schichtdauer",
        "fr": "Shift Duration",
        "es": "Shift Duration",
        "ar": "Shift Duration"
      },
      "businessContext_i18n": {
        "en": "Duration of a standard production shift",
        "tr": "Standart bir üretim vardiyasının süresi"
      }
    }
  ],
  "formulas": {
    "productionRate_pps": "(conveyorSpeed / pieceSpacing) * numLanes * (efficiency / 100)",
    "productionRate_pcsPerMinute": "productionRate_pps * 60",
    "productionRate_pcsPerHour": "productionRate_pps * 3600",
    "productionRate_pcsPerShift": "productionRate_pps * 3600 * shiftDuration"
  },
  "outputs": {
    "primary": "productionRate_pps",
    "breakdown": [
      "Production Rate (pieces/minute): productionRate_pcsPerMinute pieces/minute",
      "Production Rate (pieces/hour): productionRate_pcsPerHour pieces/hour",
      "Production Rate (pieces/shift): productionRate_pcsPerShift pieces/shift (assuming ${shiftDuration}h shift)"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "productionRate_pcsPerShift",
    "unit": "m/s",
    "breakdownUnits": {
      "Production Rate (pieces/minute): productionRate_pcsPerMinute pieces/minute": "min",
      "Production Rate (pieces/hour): productionRate_pcsPerHour pieces/hour": "h",
      "Production Rate (pieces/shift): productionRate_pcsPerShift pieces/shift (assuming ${shiftDuration}h shift)": "%"
    }
  },

        "ar": "Piece Spacing"
      },
      "businessContext_i18n": {
        "en": "Distance between consecutive pieces on the conveyor",
        "tr": "Konveyör üzerindeki ardışık parçalar arasındaki mesafe"
      }
    },
    {
      "id": "numLanes",
      "label": "Number of Lanes",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of parallel lanes on the conveyor",
      "label_i18n": {
        "en": "Number of Lanes",
        "tr": "Şerit Sayısı",
        "de": "Number of Lanes",
        "fr": "Number of Lanes",

  "formulas": {
    "rainfallIntensity_m_per_s": "rainfallIntensity / 1000 / 3600",
    "flowRate": "rainfallIntensity_m_per_s * roofArea * runoffCoefficient",
    "gutterArea_m2": "gutterWidth * gutterDepth / 1e6",
    "wettedPerimeter_m": "(gutterWidth + 2 * gutterDepth) / 1000",
    "hydraulicRadius": "gutterArea_m2 / wettedPerimeter_m",
    "slope": "gutterSlope / 1000"
  },
  "outputs": {
    "primary": "slope",
    "breakdown": [

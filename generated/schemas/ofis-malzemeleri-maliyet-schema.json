  "formulas": {
    "ConsumptionRate": "TotalConsumed / EmployeeCount",
    "AnnualCost": "SUM(Item_i * UnitPrice_i * AnnualUsage_i)",
    "CarryingCost": "AverageInventory * HoldingRate",
    "StockoutCost": "EmergencyOrders * PremiumFreight",
    "EOQ_Office": "SQRT((2 * AnnualUsage * OrderCost) / HoldingCost)",
    "WastePct": "(Purchased - Consumed) / Purchased",
    "OptimizationSavings": "(CurrentCost - EOQ_Cost) + (WastePct * CurrentCost)"
  },
  "outputs": {
    "primary": "OptimizationSavings",

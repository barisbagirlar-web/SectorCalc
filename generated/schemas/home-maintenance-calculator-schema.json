{
  "toolName": "home-maintenance-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "House Area",
      "type": "number",
      "unit": "sq ft",
      "default": 1500,
      "businessContext": "Total livable area in square feet."
    },
    {
      "id": "age",
      "label": "House Age",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Years since construction."
    },
    {
      "id": "baseCostPerSqFt",
      "label": "Base Maintenance Cost",
      "type": "number",
      "unit": "$/sq ft/year",
      "default": 1.5,
      "businessContext": "Average annual maintenance cost per square foot for a new house."
    },
    {
      "id": "ageMultiplier",
      "label": "Age Factor",
      "type": "number",
      "unit": "factor",
      "default": 0.02,
      "businessContext": "Additional cost factor per year of age (e.g., 0.02 for 2% per year)."
    },
    {
      "id": "inflation",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "decimal",
      "default": 0.03,
      "businessContext": "Annual inflation rate as a decimal (e.g., 0.03 for 3%)."
    },
    {
      "id": "yearsToProject",
      "label": "Projection Years",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Number of years to project total maintenance cost."
    }
  ],
  "formulas": {
    "currentAnnualCost": "area * baseCostPerSqFt * (1 + age * ageMultiplier)",
    "perSqFtCost": "baseCostPerSqFt * (1 + age * ageMultiplier)",
    "projectedTotal": "currentAnnualCost * ((1+inflation)**yearsToProject - 1) / inflation"
  },
  "outputs": {
    "primary": "currentAnnualCost",
    "breakdown": [
      "perSqFtCost",
      "projectedTotal"
    ]
  },
  "category": "Bakım & Güvenilirlik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "maintenance-reliability",
  "sectorId": "insaat",
  "profession": "Proje Müdürü",
  "categoryId": "cost"
}

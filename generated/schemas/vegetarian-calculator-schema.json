{
  "toolName": "vegetarian-calculator",
  "inputs": [
    {
      "id": "dailyMeatConsumption",
      "label": "Daily meat consumption",
      "type": "number",
      "unit": "g/day",
      "default": 200,
      "businessContext": "Average amount of meat consumed per day in grams."
    },
    {
      "id": "vegetarianDaysPerWeek",
      "label": "Vegetarian days per week",
      "type": "number",
      "unit": "days",
      "default": 3,
      "businessContext": "Number of days per week on a vegetarian diet."
    },
    {
      "id": "beefRatio",
      "label": "Beef ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.3,
      "businessContext": "Proportion of meat that is beef (higher environmental impact)."
    },
    {
      "id": "porkRatio",
      "label": "Pork ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.3,
      "businessContext": "Proportion of meat that is pork."
    },
    {
      "id": "poultryRatio",
      "label": "Poultry ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.4,
      "businessContext": "Proportion of meat that is poultry."
    }
  ],
  "formulas": {
    "meat_reduction": "dailyMeatConsumption * (vegetarianDaysPerWeek / 7) * 365",
    "beef_reduction": "meat_reduction * beefRatio",
    "pork_reduction": "meat_reduction * porkRatio",
    "poultry_reduction": "meat_reduction * poultryRatio",
    "co2_saved": "beef_reduction * 27 + pork_reduction * 12 + poultry_reduction * 7",
    "water_saved": "beef_reduction * 15415 + pork_reduction * 6000 + poultry_reduction * 4300",
    "land_saved": "beef_reduction * 27 + pork_reduction * 9 + poultry_reduction * 5"
  },
  "outputs": {
    "primary": "co2_saved",
    "breakdown": [
      "water_saved",
      "land_saved"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma"
}

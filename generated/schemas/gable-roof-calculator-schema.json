  "formulas": {
    "ridgeLength": "(buildingWidth) * (buildingLength) * (roofPitch) * (overhang) * (rafterSpacing) * (wasteFactor)",
    "ridgeLength_aux": "(buildingWidth) * (buildingLength) * (roofPitch)"
  },
  "outputs": {
    "primary": "ridgeLength",
    "breakdown": [
      "rafterLength",
      "ridgeLength",
      "roofSurfaceArea",
      "totalRafters"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "ridgeLength_aux",
    "unit": "m"
  },
  "category": "Matematik & Analiz",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "matematik",
  "profession": "Matematikçi",
  "categoryId": "math",
  "validation": {
    "rules": [
      {
        "field": "buildingWidth",
        "condition": "> 0",
        "message": "Building width must be positive"
      },
      {
        "field": "buildingLength",
        "condition": "> 0",
        "message": "Building length must be positive"
      },
      {
        "field": "roofPitch",
        "condition": "between 0 and 90",
        "message": "Roof pitch must be between 0 and 90 degrees"
      },
      {
        "field": "overhang",
        "condition": ">= 0",
        "message": "Overhang must be non-negative"
      },
      {
        "field": "rafterSpacing",
        "condition": "> 0",
        "message": "Rafter spacing must be positive"
      },
      {
        "field": "wasteFactor",
        "condition": "between 0 and 100",
        "message": "Waste factor must be between 0 and 100"
      }
    ],
    "thresholds": {}
  },
  "premiumFeatures": [],
  "domainModel": "physical"
}

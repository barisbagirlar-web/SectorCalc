  "formulas": {
    "c": "Math.sqrt(a**2 + b**2)",
    "e": "c / a",
    "foci1_x": "orientation == 1 ? h : h - c",
    "foci1_y": "orientation == 1 ? k - c : k",
    "foci2_x": "orientation == 1 ? h : h + c",
    "foci2_y": "orientation == 1 ? k + c : k"
  },
  "outputs": {

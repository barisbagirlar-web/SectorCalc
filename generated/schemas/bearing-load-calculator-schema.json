      }
    },
    {
      "id": "speed",
      "label": "Rotational Speed (n)",
      "type": "number",
      "unit": "RPM",
      "default": 1500,
      "businessContext": "Rotational speed of the bearing in revolutions per minute",
      "label_i18n": {
        "en": "Rotational Speed (n)",
        "tr": "Rotational Speed (n)",
        "de": "Rotational Speed (n)",
        "fr": "Rotational Speed (n)",
        "es": "Rotational Speed (n)",
        "ar": "Rotational Speed (n)"
      }
    }
  ],
  "formulas": {
    "equivalentLoad": "Xfactor * radialLoad + Yfactor * axialLoad",
    "bearingLifeRevolutions": "(dynamicLoadRating / equivalentLoad) ** exponent",
    "bearingLifeHours": "bearingLifeRevolutions * 1000000 / (60 * speed)"
  },
  "outputs": {
    "primary": "bearingLifeHours",
    "breakdown": [
      "equivalentLoad",
      "bearingLifeRevolutions"

  "formulas": {
    "equivalentLoad": "Xfactor * radialLoad + Yfactor * axialLoad",
    "bearingLifeRevolutions": "(dynamicLoadRating / equivalentLoad) ** exponent",
    "bearingLifeHours": "bearingLifeRevolutions * 1000000 / (60 * speed)"
  },
  "outputs": {
    "primary": "bearingLifeHours",
    "breakdown": [
      "equivalentLoad",
      "bearingLifeRevolutions"

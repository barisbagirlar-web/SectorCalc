{
  "toolName": "centuries-to-millennia-calculator",
  "inputs": [
    {
      "id": "centuries",
      "label": "Centuries",
      "type": "number",
      "unit": "century",
      "default": 1,
      "businessContext": "Number of centuries to convert to millennia.",
      "label_i18n": {
        "en": "Centuries",
        "tr": "Centuries",
        "de": "Centuries",
        "fr": "Centuries",
        "es": "Centuries",
        "ar": "Centuries"
      }
    },
    {
      "id": "centuryYears",
      "label": "Years per Century",
      "type": "number",
      "unit": "years",
      "default": 100,
      "businessContext": "Definition of a century in years. Normally 100.",
      "label_i18n": {
        "en": "Years per Century",
        "tr": "Years per Century",
        "de": "Years per Century",
        "fr": "Years per Century",
        "es": "Years per Century",
        "ar": "Years per Century"
      }
    },
    {
      "id": "millenniumYears",
      "label": "Years per Millennium",
      "type": "number",
      "unit": "years",
      "default": 1000,
      "businessContext": "Definition of a millennium in years. Normally 1000.",
      "label_i18n": {
        "en": "Years per Millennium",
        "tr": "Years per Millennium",
        "de": "Years per Millennium",
        "fr": "Years per Millennium",
        "es": "Years per Millennium",
        "ar": "Years per Millennium"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "dp",
      "default": 2,
      "businessContext": "Number of decimal places for the result.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    }
  ],
  "formulas": {
    "rawMillennia": "inputs.centuries * inputs.centuryYears / inputs.millenniumYears",
    "millennia": "Math.round((inputs.centuries * inputs.centuryYears / inputs.millenniumYears) * Math.pow(10, inputs.precision)) / Math.pow(10, inputs.precision)"
  },
  "outputs": {
    "primary": "millennia",
    "breakdown": [
      "rawMillennia"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",

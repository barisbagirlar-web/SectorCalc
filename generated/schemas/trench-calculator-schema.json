{
  "toolName": "trench-calculator",
  "inputs": [
    {
      "id": "trenchLength",
      "label": "Trench Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Total length of the trench to be excavated",
      "label_i18n": {
        "en": "Trench Length",
        "tr": "Trench Length",
        "de": "Trench Length",
        "fr": "Trench Length",
        "es": "Trench Length",
        "ar": "Trench Length"
      }
    },
    {
      "id": "baseWidth",
      "label": "Base Width",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Width of the trench at the bottom",
      "label_i18n": {
        "en": "Base Width",
        "tr": "Base Width",
        "de": "Base Width",
        "fr": "Base Width",
        "es": "Base Width",
        "ar": "Base Width"
      }
    },
    {
      "id": "depth",
      "label": "Depth",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Vertical depth of excavation",
      "label_i18n": {
        "en": "Depth",
        "tr": "Depth",
        "de": "Depth",
        "fr": "Depth",
        "es": "Depth",
        "ar": "Depth"
      }
    },
    {
      "id": "sideSlope",
      "label": "Side Slope (H:V)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Horizontal distance per unit vertical (0 for vertical walls)",
      "label_i18n": {
        "en": "Side Slope (H:V)",
        "tr": "Side Slope (H:V)",
        "de": "Side Slope (H:V)",
        "fr": "Side Slope (H:V)",
        "es": "Side Slope (H:V)",
        "ar": "Side Slope (H:V)"
      }
    }
  ],
  "formulas": {
    "trenchVolume": "trenchLength * depth * (baseWidth + sideSlope * depth)",
    "crossSectionArea": "depth * (baseWidth + sideSlope * depth)",
    "topWidth": "baseWidth + 2 * sideSlope * depth"
  },
  "outputs": {
    "primary": "trenchVolume",
    "breakdown": [
      {
        "id": "crossSectionArea",
        "label": "Cross-Section Area",
        "unit": "m²"
      },
      {
        "id": "topWidth",
        "label": "Top Width",
        "unit": "m"
      }
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Madencilik & Doğal Kaynaklar",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "technology-ai-cloud-cyber",

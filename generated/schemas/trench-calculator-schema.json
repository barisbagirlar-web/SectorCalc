    {
      "id": "sideSlope",
      "label": "Side Slope (H:V)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Horizontal distance per unit vertical (0 for vertical walls)",
      "label_i18n": {
        "en": "Side Slope (H:V)",
        "tr": "Şev Eğimi (Y:D)",
        "de": "Side Slope (H:V)",
        "fr": "Side Slope (H:V)",
        "es": "Side Slope (H:V)",
        "ar": "Side Slope (H:V)"
      },
      "businessContext_i18n": {
        "en": "Horizontal distance per unit vertical (0 for vertical walls)",
        "tr": "Dikey birim başına yatay mesafe (dikey duvarlar için 0)."
      }
    }
  ],
  "formulas": {
    "trenchVolume": "trenchLength * depth * (baseWidth + sideSlope * depth)",
    "crossSectionArea": "depth * (baseWidth + sideSlope * depth)",
    "topWidth": "baseWidth + 2 * sideSlope * depth"
  },
  "outputs": {
    "primary": "trenchVolume",
    "breakdown": [

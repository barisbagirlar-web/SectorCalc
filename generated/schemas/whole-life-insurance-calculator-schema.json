      "id": "mortalityRate",
      "label": "Annual Mortality Rate",
      "type": "number",
      "unit": "decimal fraction",
      "default": 0.01,
      "businessContext": "The probability that the insured will die within the next year.",
      "label_i18n": {
        "en": "Annual Mortality Rate",
        "tr": "Yıllık Ölüm Oranı",
        "de": "Annual Mortality Rate",
        "fr": "Annual Mortality Rate",
        "es": "Annual Mortality Rate",
        "ar": "Annual Mortality Rate"
      },
      "businessContext_i18n": {
        "en": "The probability that the insured will die within the next year.",
        "tr": "Sigortalının önümüzdeki yıl içinde ölme olasılığı."
      }
    },
    {
      "id": "interestRate",
      "label": "Annual Discount Rate (i)",
      "type": "number",
      "unit": "decimal fraction",
      "default": 0.05,
      "businessContext": "The interest rate used for discounting future benefits.",
      "label_i18n": {
        "en": "Annual Discount Rate (i)",
        "tr": "Yıllık İskonto Oranı (i)",
        "de": "Annual Discount Rate (i)",
        "fr": "Annual Discount Rate (i)",
        "es": "Annual Discount Rate (i)",
        "ar": "Annual Discount Rate (i)"
      },
      "businessContext_i18n": {
        "en": "The interest rate used for discounting future benefits.",
        "tr": "Gelecekteki faydaların iskonto edilmesinde kullanılan faiz oranı."
      }
    },
    {
      "id": "expenseLoading",
      "label": "Expense Loading",
      "type": "number",
      "unit": "percentage",
      "default": 0.1,
      "businessContext": "Loading factor for expenses, as a decimal (e.g., 0.1 for 10%).",
      "label_i18n": {
        "en": "Expense Loading",
        "tr": "Gider Yüklemesi",
        "de": "Expense Loading",
        "fr": "Expense Loading",
        "es": "Expense Loading",
        "ar": "Expense Loading"
      },
      "businessContext_i18n": {
        "en": "Loading factor for expenses, as a decimal (e.g., 0.1 for 10%).",
        "tr": "Giderler için yükleme faktörü, ondalık olarak (ör. %10 için 0,1)."
      }
    }
  ],
  "formulas": {
    "Net Single Premium": "sumAssured * mortalityRate / (interestRate + mortalityRate)",
    "Annual Net Premium": "sumAssured * mortalityRate / (1 + interestRate)",
    "Gross Single Premium": "sumAssured * mortalityRate / (interestRate + mortalityRate) * (1 + expenseLoading)",
    "Gross Annual Premium": "sumAssured * mortalityRate / (1 + interestRate) * (1 + expenseLoading)"
  },
  "outputs": {
    "primary": "Gross Annual Premium",
    "breakdown": [
      "Net Single Premium",
      "Annual Net Premium",
      "Gross Single Premium"
    ],

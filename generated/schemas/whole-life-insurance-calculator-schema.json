      "label": "Sum Assured (Death Benefit)",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "The amount paid upon death of the insured.",
      "label_i18n": {
        "en": "Sum Assured (Death Benefit)",
        "tr": "Sigorta Tutarı (Ölüm Tazminatı)",
        "de": "Sum Assured (Death Benefit)",
        "fr": "Sum Assured (Death Benefit)",
        "es": "Sum Assured (Death Benefit)",
        "ar": "Sum Assured (Death Benefit)"
      },
      "businessContext_i18n": {
        "en": "The amount paid upon death of the insured.",

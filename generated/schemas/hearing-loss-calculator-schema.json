{
  "toolName": "hearing-loss-calculator",
  "inputs": [
    {
      "id": "noise_level",
      "label": "Noise Level",
      "type": "number",
      "unit": "dBA",
      "default": 85,
      "businessContext": "Average noise level during exposure in decibels A-weighted",
      "label_i18n": {
        "en": "Noise Level",
        "tr": "Noise Level",
        "de": "Noise Level",
        "fr": "Noise Level",
        "es": "Noise Level",
        "ar": "Noise Level"
      }
    },
    {
      "id": "exposure_hours",
      "label": "Daily Exposure Hours",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Number of hours per day exposed to noise",
      "label_i18n": {
        "en": "Daily Exposure Hours",
        "tr": "Daily Exposure Hours",
        "de": "Daily Exposure Hours",
        "fr": "Daily Exposure Hours",
        "es": "Daily Exposure Hours",
        "ar": "Daily Exposure Hours"
      }
    },
    {
      "id": "years_exposed",
      "label": "Years of Exposure",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Total years of occupational noise exposure",
      "label_i18n": {
        "en": "Years of Exposure",
        "tr": "Years of Exposure",
        "de": "Years of Exposure",
        "fr": "Years of Exposure",
        "es": "Years of Exposure",
        "ar": "Years of Exposure"
      }
    },
    {
      "id": "age",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the person for presbycusis estimation",
      "label_i18n": {
        "en": "Current Age",
        "tr": "Current Age",
        "de": "Current Age",
        "fr": "Current Age",
        "es": "Current Age",
        "ar": "Current Age"
      }
    }
  ],
  "formulas": {
    "twa": "(noise_level + 10 * (Math.log(exposure_hours / 8) / Math.LN10))",
    "nihl": "Math.max(0, (twa - 80) * years_exposed * 0.05)",
    "age_loss": "0.5 * Math.max(0, age - 18)",
    "total_hearing_loss": "nihl + age_loss"
  },
  "outputs": {
    "primary": "total_hearing_loss",
    "breakdown": [
      "nihl",
      "age_loss"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "electrical-power-systems",

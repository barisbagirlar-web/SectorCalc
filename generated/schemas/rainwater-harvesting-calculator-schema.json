{
  "toolName": "rainwater-harvesting-calculator",
  "inputs": [
    {
      "id": "roofArea",
      "label": "Roof Area",
      "type": "number",
      "unit": "m²",
      "default": 100,
      "businessContext": "Total catchment area of the roof surface available for rainwater collection.",
      "label_i18n": {
        "en": "Roof Area",
        "tr": "Roof Area",
        "de": "Roof Area",
        "fr": "Roof Area",
        "es": "Roof Area",
        "ar": "Roof Area"
      }
    },
    {
      "id": "runoffCoeff",
      "label": "Runoff Coefficient",
      "type": "number",
      "unit": "unit",
      "default": 0.85,
      "businessContext": "Ratio of rainfall that becomes runoff, accounting for roof material, slope, and evaporation losses.",
      "label_i18n": {
        "en": "Runoff Coefficient",
        "tr": "Runoff Coefficient",
        "de": "Runoff Coefficient",
        "fr": "Runoff Coefficient",
        "es": "Runoff Coefficient",
        "ar": "Runoff Coefficient"
      }
    },
    {
      "id": "annualRainfall",
      "label": "Average Annual Rainfall",
      "type": "number",
      "unit": "mm/year",
      "default": 800,
      "businessContext": "Long-term average precipitation depth per year at the location.",
      "label_i18n": {
        "en": "Average Annual Rainfall",
        "tr": "Average Annual Rainfall",
        "de": "Average Annual Rainfall",
        "fr": "Average Annual Rainfall",
        "es": "Average Annual Rainfall",
        "ar": "Average Annual Rainfall"
      }
    },
    {
      "id": "filterEfficiency",
      "label": "Filter Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Percentage of harvested water that passes through the filtration system without loss.",
      "label_i18n": {
        "en": "Filter Efficiency",
        "tr": "Filter Efficiency",
        "de": "Filter Efficiency",
        "fr": "Filter Efficiency",
        "es": "Filter Efficiency",
        "ar": "Filter Efficiency"
      }
    }
  ],
  "formulas": {
    "annualHarvest": "roofArea * annualRainfall * runoffCoeff * (filterEfficiency / 100)",
    "monthlyAverage": "(roofArea * annualRainfall * runoffCoeff * (filterEfficiency / 100)) / 12"
  },
  "outputs": {
    "primary": "annualHarvest",
    "breakdown": [
      "monthlyAverage"
    ],

{
  "toolName": "vacation-budget-calculator",
  "inputs": [
    {
      "id": "numberOfTravelers",
      "label": "Number of Travelers",
      "type": "number",
      "unit": "persons",
      "default": 1,
      "businessContext": "Number of people traveling; multiplies per-person costs.",
      "label_i18n": {
        "en": "Number of Travelers",
        "tr": "Number of Travelers",
        "de": "Number of Travelers",
        "fr": "Number of Travelers",
        "es": "Number of Travelers",
        "ar": "Number of Travelers"
      }
    },
    {
      "id": "numberOfNights",
      "label": "Number of Nights",
      "type": "number",
      "unit": "nights",
      "default": 7,
      "businessContext": "Duration of stay in nights; used for hotel and daily expenses.",
      "label_i18n": {
        "en": "Number of Nights",
        "tr": "Number of Nights",
        "de": "Number of Nights",
        "fr": "Number of Nights",
        "es": "Number of Nights",
        "ar": "Number of Nights"
      }
    },
    {
      "id": "flightCostPerPerson",
      "label": "Flight Cost per Person",
      "type": "number",
      "unit": "USD",
      "default": 500,
      "businessContext": "Round-trip flight cost per traveler.",
      "label_i18n": {
        "en": "Flight Cost per Person",
        "tr": "Flight Cost per Person",
        "de": "Flight Cost per Person",
        "fr": "Flight Cost per Person",
        "es": "Flight Cost per Person",
        "ar": "Flight Cost per Person"
      }
    },
    {
      "id": "hotelCostPerNight",
      "label": "Hotel Cost per Night (Total)",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Total accommodation cost per night for the group.",
      "label_i18n": {
        "en": "Hotel Cost per Night (Total)",
        "tr": "Hotel Cost per Night (Total)",
        "de": "Hotel Cost per Night (Total)",
        "fr": "Hotel Cost per Night (Total)",
        "es": "Hotel Cost per Night (Total)",
        "ar": "Hotel Cost per Night (Total)"
      }
    },
    {
      "id": "dailyFoodCostPerPerson",
      "label": "Daily Food Cost per Person",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Estimated daily meal and drink cost per person.",
      "label_i18n": {
        "en": "Daily Food Cost per Person",
        "tr": "Daily Food Cost per Person",
        "de": "Daily Food Cost per Person",
        "fr": "Daily Food Cost per Person",
        "es": "Daily Food Cost per Person",
        "ar": "Daily Food Cost per Person"
      }
    },
    {
      "id": "activitiesCostPerPerson",
      "label": "Activities Cost per Person",
      "type": "number",
      "unit": "USD",
      "default": 200,
      "businessContext": "Total cost of excursions and activities per person.",
      "label_i18n": {
        "en": "Activities Cost per Person",
        "tr": "Activities Cost per Person",
        "de": "Activities Cost per Person",
        "fr": "Activities Cost per Person",
        "es": "Activities Cost per Person",
        "ar": "Activities Cost per Person"
      }
    },
    {
      "id": "miscellaneousCost",
      "label": "Miscellaneous Cost",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Extra expenses such as souvenirs, tips, and transport.",
      "label_i18n": {
        "en": "Miscellaneous Cost",
        "tr": "Miscellaneous Cost",
        "de": "Miscellaneous Cost",
        "fr": "Miscellaneous Cost",
        "es": "Miscellaneous Cost",
        "ar": "Miscellaneous Cost"
      }
    }
  ],
  "formulas": {
    "flightsTotal": "numberOfTravelers * flightCostPerPerson",
    "hotelTotal": "numberOfNights * hotelCostPerNight",
    "foodTotal": "numberOfTravelers * dailyFoodCostPerPerson * numberOfNights",
    "activitiesTotal": "numberOfTravelers * activitiesCostPerPerson",
    "miscellaneousTotal": "miscellaneousCost",
    "totalBudget": "flightsTotal + hotelTotal + foodTotal + activitiesTotal + miscellaneousTotal",
    "dailyPerPerson": "totalBudget / (numberOfTravelers * numberOfNights)"
  },
  "outputs": {
    "primary": "totalBudget",
    "breakdown": [
      "flightsTotal",
      "hotelTotal",
      "foodTotal",
      "activitiesTotal",
      "miscellaneousTotal",
      "dailyPerPerson"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dailyPerPerson"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Turizm & Konaklama",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",

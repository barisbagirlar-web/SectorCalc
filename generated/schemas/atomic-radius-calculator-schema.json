  ],
  "formulas": {
    "avogadro": "6.02214076e+23",
    "volumePerAtom": "molarMass / (density * avogadro)",
    "packingFactorUsed": "structureType == 0 ? manualPackingFactor : (structureType == 1 ? 0.52 : structureType == 2 ? 0.68 : structureType == 3 ? 0.74 : 0.74)",
    "atomicVolume": "packingFactorUsed * volumePerAtom"
  },

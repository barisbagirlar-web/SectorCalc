        "de": "Frequency Point (f)",
        "fr": "Frequency Point (f)",
        "es": "Frequency Point (f)",
        "ar": "Frequency Point (f)"
      }
    }
  ],
  "formulas": {
    "normalizedFrequency": "frequencyPoint / cutoffFrequency",
    "besselPolynomial": "order === 1 ? 1 + normalizedFrequency : order === 2 ? 3 + 3*normalizedFrequency + normalizedFrequency**2 : order === 3 ? 15 + 15*normalizedFrequency + 6*normalizedFrequency**2 + normalizedFrequency**3 : 105 + 105*normalizedFrequency + 45*normalizedFrequency**2 + 10*normalizedFrequency**3 + normalizedFrequency**4"
  },
  "outputs": {
    "primary": "besselPolynomial",
    "breakdown": [

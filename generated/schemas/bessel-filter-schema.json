      }
    },
    {
      "id": "frequencyPoint",
      "label": "Frequency Point (f)",
      "type": "number",
      "unit": "Hz",
      "default": 500,
      "businessContext": "Frequency at which to evaluate the filter response.",
      "label_i18n": {
        "en": "Frequency Point (f)",

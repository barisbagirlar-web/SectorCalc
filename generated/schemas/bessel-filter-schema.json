      "label": "Cutoff Frequency (fc)",
      "type": "number",
      "unit": "Hz",
      "default": 1000,
      "businessContext": "The -3 dB cutoff frequency of the filter in Hz.",
      "label_i18n": {
        "en": "Cutoff Frequency (fc)",

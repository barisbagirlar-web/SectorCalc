{
  "toolName": "zumba-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms"
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "minutes",
      "default": 60,
      "businessContext": "Total duration of Zumba session in minutes"
    },
    {
      "id": "MET",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 7.5,
      "businessContext": "Metabolic Equivalent of Task for Zumba, typically 6-8"
    },
    {
      "id": "intensityFactor",
      "label": "Intensity Factor",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Multiplier to adjust for effort level (1.0 moderate, 1.2 high, 0.8 low)"
    }
  ],
  "formulas": {
    "caloriesBurned": "weight * MET * (duration / 60) * intensityFactor",
    "hours": "duration / 60"
  },
  "outputs": {
    "primary": "Calories Burned",
    "breakdown": [
      "Total Time (hours)",
      "MET Value",
      "Intensity Factor"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
{
  "toolName": "upload-time-calculator",
  "inputs": [
    {
      "id": "fileSize",
      "label": "File Size (MB)",
      "type": "number",
      "unit": "MB",
      "default": 100,
      "businessContext": "Size of the file to upload in megabytes (MB).",
      "label_i18n": {
        "en": "File Size (MB)",
        "tr": "File Size (MB)",
        "de": "File Size (MB)",
        "fr": "File Size (MB)",
        "es": "File Size (MB)",
        "ar": "File Size (MB)"
      }
    },
    {
      "id": "uploadSpeed",
      "label": "Upload Speed (Mbps)",
      "type": "number",
      "unit": "Mbps",
      "default": 10,
      "businessContext": "Upload bandwidth in megabits per second (Mbps).",
      "label_i18n": {
        "en": "Upload Speed (Mbps)",
        "tr": "Upload Speed (Mbps)",
        "de": "Upload Speed (Mbps)",
        "fr": "Upload Speed (Mbps)",
        "es": "Upload Speed (Mbps)",
        "ar": "Upload Speed (Mbps)"
      }
    },
    {
      "id": "overheadFactor",
      "label": "Overhead Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.1,
      "businessContext": "Multiplier accounting for protocol overhead (e.g., 1.1 for 10% overhead).",
      "label_i18n": {
        "en": "Overhead Factor",
        "tr": "Overhead Factor",
        "de": "Overhead Factor",
        "fr": "Overhead Factor",
        "es": "Overhead Factor",
        "ar": "Overhead Factor"
      }
    },
    {
      "id": "numConnections",
      "label": "Parallel Connections",
      "type": "number",
      "unit": "connections",
      "default": 1,
      "businessContext": "Number of parallel upload connections.",
      "label_i18n": {
        "en": "Parallel Connections",
        "tr": "Parallel Connections",
        "de": "Parallel Connections",
        "fr": "Parallel Connections",
        "es": "Parallel Connections",
        "ar": "Parallel Connections"
      }
    }
  ],
  "formulas": {
    "rawTimeSeconds": "(fileSize * 8) / uploadSpeed",
    "uploadTimeSeconds": "(fileSize * 8 * overheadFactor) / (uploadSpeed * numConnections)",
    "overheadTimeSeconds": "(fileSize * 8 * (overheadFactor - 1)) / (uploadSpeed * numConnections)",
    "effectiveSpeedMbps": "(uploadSpeed * numConnections) / overheadFactor"
  },
  "outputs": {
    "primary": "uploadTimeSeconds",
    "breakdown": [
      "formattedTime",
      "rawTimeSeconds",
      "overheadTimeSeconds",
      "effectiveSpeedMbps"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "formattedTime"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Bilişim & Yazılım",
  "premiumRequired": false,

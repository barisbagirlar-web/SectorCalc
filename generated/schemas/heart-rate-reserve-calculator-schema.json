{
  "toolName": "heart-rate-reserve-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the individual in years, used to estimate maximum heart rate if not explicitly provided",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "restingHeartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Resting heart rate measured in the morning before any activity, in beats per minute",
      "label_i18n": {
        "en": "Resting Heart Rate",
        "tr": "Resting Heart Rate",
        "de": "Resting Heart Rate",
        "fr": "Resting Heart Rate",
        "es": "Resting Heart Rate",
        "ar": "Resting Heart Rate"
      }
    },
    {
      "id": "maximumHeartRate",
      "label": "Maximum Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 0,
      "businessContext": "Maximum heart rate in beats per minute; if set to 0, it is estimated as 220 minus age",
      "label_i18n": {
        "en": "Maximum Heart Rate",
        "tr": "Maximum Heart Rate",
        "de": "Maximum Heart Rate",
        "fr": "Maximum Heart Rate",
        "es": "Maximum Heart Rate",
        "ar": "Maximum Heart Rate"
      }
    },
    {
      "id": "intensity",
      "label": "Training Intensity",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Desired training intensity as a percentage of heart rate reserve (Karvonen method)",
      "label_i18n": {
        "en": "Training Intensity",
        "tr": "Training Intensity",
        "de": "Training Intensity",
        "fr": "Training Intensity",
        "es": "Training Intensity",
        "ar": "Training Intensity"
      }
    }
  ],
  "formulas": {
    "maxHeartRate": "maximumHeartRate > 0 ? maximumHeartRate : 220 - age",
    "heartRateReserve": "maxHeartRate - restingHeartRate",
    "targetHeartRate": "heartRateReserve * (intensity / 100) + restingHeartRate"
  },
  "outputs": {
    "primary": "targetHeartRate",
    "breakdown": [
      "heartRateReserve",
      "maxHeartRate"
    ],

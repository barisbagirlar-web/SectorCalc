      }
    },
    {
      "id": "heatTransferCoeff",
      "label": "Heat Transfer Coefficient",
      "type": "number",
      "unit": "W/(m²·°C)",
      "default": 10,
      "businessContext": "Combined convection and radiation coefficient",
      "label_i18n": {
        "en": "Heat Transfer Coefficient",
        "tr": "Isı Transfer Katsayısı",
        "de": "Heat Transfer Coefficient",
        "fr": "Heat Transfer Coefficient",

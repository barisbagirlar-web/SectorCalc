        "tr": "Birleşik konveksiyon ve radyasyon katsayısı"
      }
    }
  ],
  "formulas": {
    "effectiveHeat": "heatInput * (efficiency / 100)",
    "temperatureRise": "effectiveHeat / (grillArea * heatTransferCoeff)",
    "grillTemperature": "ambientTemp + temperatureRise"
  },
  "outputs": {
    "primary": "grillTemperature",
    "breakdown": [
      "temperatureRise",

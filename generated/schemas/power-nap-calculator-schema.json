{
  "toolName": "power-nap-calculator",
  "inputs": [
    {
      "id": "currentTimeMinutes",
      "label": "Current Time (minutes past midnight)",
      "type": "number",
      "unit": "min",
      "default": 480,
      "businessContext": "Current time expressed in minutes since midnight (0-1439).",
      "label_i18n": {
        "en": "Current Time (minutes past midnight)",
        "tr": "Current Time (minutes past midnight)",
        "de": "Current Time (minutes past midnight)",
        "fr": "Current Time (minutes past midnight)",
        "es": "Current Time (minutes past midnight)",
        "ar": "Current Time (minutes past midnight)"
      }
    },
    {
      "id": "deadlineTimeMinutes",
      "label": "Deadline Wake-Up Time (minutes past midnight)",
      "type": "number",
      "unit": "min",
      "default": 720,
      "businessContext": "Latest time by which you must be awake, in minutes since midnight.",
      "label_i18n": {
        "en": "Deadline Wake-Up Time (minutes past midnight)",
        "tr": "Deadline Wake-Up Time (minutes past midnight)",
        "de": "Deadline Wake-Up Time (minutes past midnight)",
        "fr": "Deadline Wake-Up Time (minutes past midnight)",
        "es": "Deadline Wake-Up Time (minutes past midnight)",
        "ar": "Deadline Wake-Up Time (minutes past midnight)"
      }
    },
    {
      "id": "sleepLatencyMinutes",
      "label": "Time to Fall Asleep",
      "type": "number",
      "unit": "min",
      "default": 10,
      "businessContext": "Estimated minutes needed to fall asleep after lying down.",
      "label_i18n": {
        "en": "Time to Fall Asleep",
        "tr": "Time to Fall Asleep",
        "de": "Time to Fall Asleep",
        "fr": "Time to Fall Asleep",
        "es": "Time to Fall Asleep",
        "ar": "Time to Fall Asleep"
      }
    },
    {
      "id": "napQualityGoal",
      "label": "Desired Nap Quality (1-10)",
      "type": "number",
      "unit": "score",
      "default": 5,
      "businessContext": "Subjective goal for post-nap alertness; 10 = maximum revitalization.",
      "label_i18n": {
        "en": "Desired Nap Quality (1-10)",
        "tr": "Desired Nap Quality (1-10)",
        "de": "Desired Nap Quality (1-10)",
        "fr": "Desired Nap Quality (1-10)",
        "es": "Desired Nap Quality (1-10)",
        "ar": "Desired Nap Quality (1-10)"
      }
    }
  ],
  "formulas": {
    "availableTimeMinutes": "deadlineTimeMinutes - currentTimeMinutes",
    "powerNapFeasible": "(availableTimeMinutes >= (20 + sleepLatencyMinutes)) && (availableTimeMinutes > 0)",
    "fullCycleFeasible": "availableTimeMinutes >= (90 + sleepLatencyMinutes)",
    "recommendedNapDuration": "fullCycleFeasible && napQualityGoal >= 5 ? 90 : (powerNapFeasible ? 20 : 0)"
  },
  "outputs": {
    "primary": "recommendedNapDuration",
    "breakdown": [
      "powerNapFeasible",
      "fullCycleFeasible"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "recommendedNapDuration",
    "unit": "%"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",

{
  "toolName": "skiing-calculator",
  "inputs": [
    {
      "id": "verticalDrop",
      "label": "Vertical Drop",
      "type": "number",
      "unit": "m",
      "default": 300,
      "businessContext": "Height difference between start and end of ski slope in meters",
      "label_i18n": {
        "en": "Vertical Drop",
        "tr": "Vertical Drop",
        "de": "Vertical Drop",
        "fr": "Vertical Drop",
        "es": "Vertical Drop",
        "ar": "Vertical Drop"
      }
    },
    {
      "id": "horizontalDistance",
      "label": "Horizontal Distance",
      "type": "number",
      "unit": "m",
      "default": 1000,
      "businessContext": "Horizontal length of the ski slope in meters",
      "label_i18n": {
        "en": "Horizontal Distance",
        "tr": "Horizontal Distance",
        "de": "Horizontal Distance",
        "fr": "Horizontal Distance",
        "es": "Horizontal Distance",
        "ar": "Horizontal Distance"
      }
    },
    {
      "id": "frictionCoeff",
      "label": "Friction Coefficient",
      "type": "number",
      "unit": "unit",
      "default": 0.05,
      "businessContext": "Snow friction coefficient (0.02-0.1), depending on snow conditions",
      "label_i18n": {
        "en": "Friction Coefficient",
        "tr": "Friction Coefficient",
        "de": "Friction Coefficient",
        "fr": "Friction Coefficient",
        "es": "Friction Coefficient",
        "ar": "Friction Coefficient"
      }
    },
    {
      "id": "initialSpeed",
      "label": "Initial Speed",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "Initial speed at start of slope in meters per second",
      "label_i18n": {
        "en": "Initial Speed",
        "tr": "Initial Speed",
        "de": "Initial Speed",
        "fr": "Initial Speed",
        "es": "Initial Speed",
        "ar": "Initial Speed"
      }
    }
  ],
  "formulas": {
    "slopeAngle": "Math.atan(verticalDrop / horizontalDistance)",
    "slopeDistance": "Math.sqrt(verticalDrop**2 + horizontalDistance**2)",
    "acceleration": "9.81 * (Math.sin(slopeAngle) - frictionCoeff * Math.cos(slopeAngle))",
    "finalSpeed": "Math.sqrt(Math.max(0, initialSpeed**2 + 2 * acceleration * slopeDistance))",
    "time": "acceleration > 0 ? (finalSpeed - initialSpeed) / acceleration : Infinity"
  },
  "outputs": {
    "primary": "finalSpeed",
    "breakdown": [
      "acceleration",
      "slopeDistance",
      "time"
    ]
  },
  "category": "Dönüşüm & Ölçüm",

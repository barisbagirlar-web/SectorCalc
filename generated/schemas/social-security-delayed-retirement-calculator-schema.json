{
  "toolName": "social-security-delayed-retirement-calculator",
  "inputs": [
    {
      "id": "fullRetirementAge",
      "label": "Full Retirement Age",
      "type": "number",
      "unit": "years",
      "default": 67,
      "businessContext": "The age at which you can receive full Social Security retirement benefits.",
      "label_i18n": {
        "en": "Full Retirement Age",
        "tr": "Full Retirement Age",
        "de": "Full Retirement Age",
        "fr": "Full Retirement Age",
        "es": "Full Retirement Age",
        "ar": "Full Retirement Age"
      }
    },
    {
      "id": "plannedRetirementAge",
      "label": "Planned Retirement Age",
      "type": "number",
      "unit": "years",
      "default": 70,
      "businessContext": "The age at which you plan to start claiming benefits.",
      "label_i18n": {
        "en": "Planned Retirement Age",
        "tr": "Planned Retirement Age",
        "de": "Planned Retirement Age",
        "fr": "Planned Retirement Age",
        "es": "Planned Retirement Age",
        "ar": "Planned Retirement Age"
      }
    },
    {
      "id": "primaryInsuranceAmount",
      "label": "Primary Insurance Amount (PIA)",
      "type": "number",
      "unit": "USD/month",
      "default": 2000,
      "businessContext": "Your monthly benefit at full retirement age.",
      "label_i18n": {
        "en": "Primary Insurance Amount (PIA)",
        "tr": "Primary Insurance Amount (PIA)",
        "de": "Primary Insurance Amount (PIA)",
        "fr": "Primary Insurance Amount (PIA)",
        "es": "Primary Insurance Amount (PIA)",
        "ar": "Primary Insurance Amount (PIA)"
      }
    },
    {
      "id": "annualDelayCreditRate",
      "label": "Annual Delay Credit Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "The percentage increase in benefits for each year of delay past full retirement age.",
      "label_i18n": {
        "en": "Annual Delay Credit Rate",
        "tr": "Annual Delay Credit Rate",
        "de": "Annual Delay Credit Rate",
        "fr": "Annual Delay Credit Rate",
        "es": "Annual Delay Credit Rate",
        "ar": "Annual Delay Credit Rate"
      }
    }
  ],
  "formulas": {
    "delayYears": "plannedRetirementAge - fullRetirementAge",
    "benefitIncreaseFactor": "1 + (delayYears * annualDelayCreditRate / 100)",
    "newMonthlyBenefit": "primaryInsuranceAmount * benefitIncreaseFactor",
    "percentageIncrease": "(benefitIncreaseFactor - 1) * 100"
  },
  "outputs": {
    "primary": "newMonthlyBenefit",
    "breakdown": [
      "delayYears",
      "benefitIncreaseFactor",
      "percentageIncrease"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "percentageIncrease"
  },
  "category": "Otomotiv",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "maintenance-reliability",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",

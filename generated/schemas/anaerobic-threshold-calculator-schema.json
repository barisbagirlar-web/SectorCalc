{
  "toolName": "anaerobic-threshold-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the individual in years.",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "restingHeartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 60,
      "businessContext": "Resting heart rate, typically measured upon waking.",
      "label_i18n": {
        "en": "Resting Heart Rate",
        "tr": "Resting Heart Rate",
        "de": "Resting Heart Rate",
        "fr": "Resting Heart Rate",
        "es": "Resting Heart Rate",
        "ar": "Resting Heart Rate"
      }
    },
    {
      "id": "maxHeartRate",
      "label": "Maximum Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 0,
      "businessContext": "Maximum heart rate in beats per minute. Enter 0 to estimate from age (220 - age).",
      "label_i18n": {
        "en": "Maximum Heart Rate",
        "tr": "Maximum Heart Rate",
        "de": "Maximum Heart Rate",
        "fr": "Maximum Heart Rate",
        "es": "Maximum Heart Rate",
        "ar": "Maximum Heart Rate"
      }
    },
    {
      "id": "intensity",
      "label": "Intensity",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Percentage of heart rate reserve used for anaerobic threshold (commonly 80-90%).",
      "label_i18n": {
        "en": "Intensity",
        "tr": "Intensity",
        "de": "Intensity",
        "fr": "Intensity",
        "es": "Intensity",
        "ar": "Intensity"
      }
    }
  ],
  "formulas": {
    "maxHR": "inputs.maxHeartRate > 0 ? inputs.maxHeartRate : 220 - inputs.age",
    "heartRateReserve": "maxHR - inputs.restingHeartRate",
    "anaerobicThresholdHR": "inputs.restingHeartRate + (inputs.intensity / 100) * heartRateReserve"
  },
  "outputs": {
    "primary": "anaerobicThresholdHR",
    "breakdown": [
      "maxHR",
      "heartRateReserve"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

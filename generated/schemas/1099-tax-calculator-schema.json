{
  "toolName": "1099-tax-calculator",
  "inputs": [
    {
      "id": "grossIncome",
      "label": "Gross Income ($)",
      "type": "number",
      "unit": "$",
      "default": 50000,
      "businessContext": "Total income received from all 1099 contracts before any deductions.",
      "label_i18n": {
        "en": "Gross Income ($)",
        "tr": "Gross Income ($)",
        "de": "Gross Income ($)",
        "fr": "Gross Income ($)",
        "es": "Gross Income ($)",
        "ar": "Gross Income ($)"
      }
    },
    {
      "id": "businessExpenses",
      "label": "Business Expenses ($)",
      "type": "number",
      "unit": "$",
      "default": 5000,
      "businessContext": "Ordinary and necessary expenses directly related to the business (e.g., supplies, home office, mileage).",
      "label_i18n": {
        "en": "Business Expenses ($)",
        "tr": "Business Expenses ($)",
        "de": "Business Expenses ($)",
        "fr": "Business Expenses ($)",
        "es": "Business Expenses ($)",
        "ar": "Business Expenses ($)"
      }
    },
    {
      "id": "federalTaxRate",
      "label": "Federal Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 22,
      "businessContext": "Marginal federal income tax rate applied to taxable income after deductions.",
      "label_i18n": {
        "en": "Federal Tax Rate (%)",
        "tr": "Federal Tax Rate (%)",
        "de": "Federal Tax Rate (%)",
        "fr": "Federal Tax Rate (%)",
        "es": "Federal Tax Rate (%)",
        "ar": "Federal Tax Rate (%)"
      }
    },
    {
      "id": "stateTaxRate",
      "label": "State Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Combined state and local income tax rate, if applicable.",
      "label_i18n": {
        "en": "State Tax Rate (%)",
        "tr": "State Tax Rate (%)",
        "de": "State Tax Rate (%)",
        "fr": "State Tax Rate (%)",
        "es": "State Tax Rate (%)",
        "ar": "State Tax Rate (%)"
      }
    },
    {
      "id": "selfEmploymentTaxRate",
      "label": "Self-Employment Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 15.3,
      "businessContext": "Social Security and Medicare taxes for self-employed individuals (typically 15.3% on 92.35% of net profit).",
      "label_i18n": {
        "en": "Self-Employment Tax Rate (%)",
        "tr": "Self-Employment Tax Rate (%)",
        "de": "Self-Employment Tax Rate (%)",
        "fr": "Self-Employment Tax Rate (%)",
        "es": "Self-Employment Tax Rate (%)",
        "ar": "Self-Employment Tax Rate (%)"
      }
    }
  ],
  "formulas": {
    "netProfit": "grossIncome - businessExpenses",
    "seTax": "netProfit * 0.9235 * (selfEmploymentTaxRate / 100)",
    "adjustedNet": "netProfit - (seTax / 2)",
    "federalTax": "adjustedNet * (federalTaxRate / 100)",
    "stateTax": "adjustedNet * (stateTaxRate / 100)",
    "totalTax": "federalTax + stateTax + seTax"
  },
  "outputs": {
    "primary": "totalTax",
    "breakdown": [
      "federalTax",
      "stateTax",
      "seTax"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTax"
  },

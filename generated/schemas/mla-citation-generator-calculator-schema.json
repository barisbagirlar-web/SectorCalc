      }
    },
    {
      "id": "authorsPerCitation",
      "label": "Avg Authors per Citation",
      "type": "number",
      "unit": "count",
      "default": 2,
      "businessContext": "Average number of authors per citation",
      "label_i18n": {
        "en": "Avg Authors per Citation",
        "tr": "Atıf Başına Ortalama Yazar Sayısı",
        "de": "Durchschnittliche Autoren pro Zitation",
        "fr": "Moyenne d'auteurs par citation",
        "es": "Promedio de autores por cita",
        "ar": "متوسط عدد المؤلفين لكل اقتباس"
      },

        "ar": "متوسط عدد المصادر المميزة المذكورة لكل صفحة"
      }
    },
    {
      "id": "inTextFrequency",
      "label": "In-text Citation Frequency",
      "type": "number",
      "unit": "citations per page",
      "default": 2,
      "businessContext": "How many in-text citations appear per page",
      "label_i18n": {
        "en": "In-text Citation Frequency",
        "tr": "Metin içi atıf sıklığı",
        "de": "Zitierhäufigkeit im Text",
        "fr": "Fréquence des citations dans le texte",
        "es": "Frecuencia de citas en el texto",
        "ar": "تكرار الاقتباس داخل النص"
      },
      "businessContext_i18n": {
        "en": "How many in-text citations appear per page",
        "tr": "Sayfa başına kaç metin içi atıf görünüyor",
        "de": "Anzahl der In-Text-Zitate pro Seite",
        "fr": "Nombre de citations dans le texte par page",
        "es": "Número de citas en el texto que aparecen por página",
        "ar": "عدد الاقتباسات داخل النص التي تظهر لكل صفحة"
      }
    },
    {
      "id": "bibliographyEntries",
      "label": "Bibliography Entries",
      "type": "number",
      "unit": "count",
      "default": 10,
      "businessContext": "Total number of bibliography entries",
      "label_i18n": {
        "en": "Bibliography Entries",
        "tr": "Kaynakça girişleri",
        "de": "Bibliografie-Einträge",
        "fr": "Entrées bibliographiques",
        "es": "Entradas bibliográficas",
        "ar": "مدخلات قائمة المراجع"
      },
      "businessContext_i18n": {
        "en": "Total number of bibliography entries",
        "tr": "Toplam kaynakça girişi sayısı",
        "de": "Gesamtzahl der Bibliografie-Einträge",
        "fr": "Nombre total d'entrées bibliographiques",
        "es": "Número total de entradas bibliográficas",
        "ar": "إجمالي عدد مدخلات قائمة المراجع"
      }
    }
  ],
  "formulas": {
    "totalInText": "pages * inTextFrequency",
    "totalBibliographyWeight": "bibliographyEntries * (1 + authorsPerCitation * 0.1)",
    "wordsPerCitation": "wordCount / (pages * sourcesPerPage + 1)"
  },
  "outputs": {
    "primary": "totalInText",
    "breakdown": [
      "totalBibliographyWeight",
      "wordsPerCitation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "wordsPerCitation",
    "unit": "words"
  },

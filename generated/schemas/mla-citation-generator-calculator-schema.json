      "label_i18n": {
        "en": "Number of Pages",
        "tr": "Number of Pages",
        "de": "Number of Pages",
        "fr": "Number of Pages",
        "es": "Number of Pages",
        "ar": "Number of Pages"
      }
    },
    {
      "id": "authorsPerCitation",
      "label": "Avg Authors per Citation",
      "type": "number",
      "unit": "count",
      "default": 2,
      "businessContext": "Average number of authors per citation",
      "label_i18n": {
        "en": "Avg Authors per Citation",
        "tr": "Avg Authors per Citation",
        "de": "Avg Authors per Citation",
        "fr": "Avg Authors per Citation",
        "es": "Avg Authors per Citation",
        "ar": "Avg Authors per Citation"
      }
    },
    {
      "id": "sourcesPerPage",
      "label": "Sources per Page",
      "type": "number",
      "unit": "count",
      "default": 3,
      "businessContext": "Average number of distinct sources cited per page",
      "label_i18n": {
        "en": "Sources per Page",
        "tr": "Sources per Page",
        "de": "Sources per Page",
        "fr": "Sources per Page",
        "es": "Sources per Page",
        "ar": "Sources per Page"
      }
    },
    {
      "id": "inTextFrequency",
      "label": "In-text Citation Frequency",
      "type": "number",
      "unit": "citations per page",
      "default": 2,
      "businessContext": "How many in-text citations appear per page",
      "label_i18n": {
        "en": "In-text Citation Frequency",
        "tr": "In-text Citation Frequency",
        "de": "In-text Citation Frequency",
        "fr": "In-text Citation Frequency",
        "es": "In-text Citation Frequency",
        "ar": "In-text Citation Frequency"
      }
    },
    {
      "id": "bibliographyEntries",
      "label": "Bibliography Entries",
      "type": "number",
      "unit": "count",
      "default": 10,
      "businessContext": "Total number of bibliography entries",
      "label_i18n": {
        "en": "Bibliography Entries",
        "tr": "Bibliography Entries",
        "de": "Bibliography Entries",
        "fr": "Bibliography Entries",
        "es": "Bibliography Entries",
        "ar": "Bibliography Entries"
      }
    }
  ],
  "formulas": {
    "totalInText": "pages * inTextFrequency",
    "totalBibliographyWeight": "bibliographyEntries * (1 + authorsPerCitation * 0.1)",
    "wordsPerCitation": "wordCount / (pages * sourcesPerPage + 1)"
  },
  "outputs": {
    "primary": "totalInText",
    "breakdown": [
      "totalBibliographyWeight",
      "wordsPerCitation"
    ]
  },

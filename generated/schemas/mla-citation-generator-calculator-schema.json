{
  "toolName": "mla-citation-generator-calculator",
  "inputs": [
    {
      "id": "wordCount",
      "label": "Word Count",
      "type": "number",
      "unit": "words",
      "default": 1000,
      "businessContext": "Total word count of the document",
      "label_i18n": {
        "en": "Word Count",
        "tr": "Word Count",
        "de": "Word Count",
        "fr": "Word Count",
        "es": "Word Count",
        "ar": "Word Count"
      }
    },
    {
      "id": "pages",

      "label": "Sources per Page",
      "type": "number",
      "unit": "count",
      "default": 3,
      "businessContext": "Average number of distinct sources cited per page",
      "label_i18n": {
        "en": "Sources per Page",
        "tr": "Sayfa başına kaynak",
        "de": "Quellen pro Seite",
        "fr": "Sources par page",
        "es": "Fuentes por página",
        "ar": "المصادر لكل صفحة"
      },
      "businessContext_i18n": {
        "en": "Average number of distinct sources cited per page",
        "tr": "Sayfa başına atıf yapılan farklı kaynakların ortalama sayısı",

        "ar": "Number of Steps"
      }
    },
    {
      "id": "stepLength",
      "label": "Step Length",
      "type": "number",
      "unit": "m",
      "default": 0.762,
      "businessContext": "Length of one step in meters; average is 0.762 m (2.5 ft)",
      "label_i18n": {
        "en": "Step Length",
        "tr": "Step Length",
        "de": "Step Length",
        "fr": "Step Length",
        "es": "Step Length",
        "ar": "Step Length"
      }
    },
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "intensityFactor",
      "label": "Intensity Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier to adjust for walking intensity or individual metabolic rate",
      "label_i18n": {
        "en": "Intensity Factor",
        "tr": "Intensity Factor",
        "de": "Intensity Factor",
        "fr": "Intensity Factor",
        "es": "Intensity Factor",
        "ar": "Intensity Factor"
      }
    }
  ],
  "formulas": {
    "distanceKm": "steps * stepLength / 1000",
    "baseCalories": "distanceKm * weight * 0.53",
    "totalCalories": "baseCalories * intensityFactor"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [

  "formulas": {
    "ChargeableWeight": "MAX(GrossWeight, VolumetricWeight)",
    "BaseFreight": "ChargeableWeight * RatePerKg",
    "BunkerSurcharge": "BaseFreight * BAF_Pct",
    "SecurityFee": "ChargeableWeight * SecurityRate",
    "TerminalHandling": "Units * THC_Rate",
    "CustomsClearance": "FixedFee + (Value * DutyPct)",
    "TotalFreightCost": "BaseFreight + BunkerSurcharge + SecurityFee + TerminalHandling + CustomsClearance",
    "CostPerUnit": "TotalFreightCost / TotalUnits"
  },

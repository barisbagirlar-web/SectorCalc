      }
    },
    {
      "id": "t1",
      "label": "Known Time",
      "type": "number",
      "unit": "min",
      "default": 50,
      "businessContext": "Finishing time for the known distance in minutes",
      "label_i18n": {
        "en": "Known Time",
        "tr": "Known Time",
        "de": "Known Time",
        "fr": "Known Time",
        "es": "Known Time",
        "ar": "Known Time"
      }
    },
    {
      "id": "d2",
      "label": "Target Distance",
      "type": "number",
      "unit": "km",
      "default": 21.1,
      "businessContext": "Distance of the race to predict in kilometers",
      "label_i18n": {
        "en": "Target Distance",
        "tr": "Target Distance",
        "de": "Target Distance",
        "fr": "Target Distance",
        "es": "Target Distance",
        "ar": "Target Distance"
      }
    },
    {
      "id": "fatigue",
      "label": "Fatigue Exponent",
      "type": "number",
      "unit": "unit",
      "default": 1.06,
      "businessContext": "Fatigue factor per Riegel formula (default 1.06)",
      "label_i18n": {
        "en": "Fatigue Exponent",
        "tr": "Fatigue Exponent",
        "de": "Fatigue Exponent",
        "fr": "Fatigue Exponent",
        "es": "Fatigue Exponent",
        "ar": "Fatigue Exponent"
      }
    }
  ],
  "formulas": {
    "t2_min": "t1 * Math.pow(d2/d1, fatigue)",
    "pace_min": "t2_min / d2",
    "t2_formatted": "String(Math.floor(t2_min/60)).padStart(2,'0') + ':' + String(Math.floor(t2_min%60)).padStart(2,'0') + ':' + String(Math.round((t2_min%1)*60)).padStart(2,'0')",
    "pace_formatted": "String(Math.floor(pace_min)).padStart(2,'0') + ':' + String(Math.round((pace_min%1)*60)).padStart(2,'0')"
  },
  "outputs": {
    "primary": "t2_min",
    "breakdown": [
      "t2_formatted",
      "pace_formatted"
    ]
  },

{
  "toolName": "race-time-predictor-calculator",
  "inputs": [
    {
      "id": "d1",
      "label": "Known Distance",
      "type": "number",
      "unit": "km",
      "default": 10,
      "businessContext": "Distance of a previous race in kilometers"
    },
    {
      "id": "t1",
      "label": "Known Time",
      "type": "number",
      "unit": "min",
      "default": 50,
      "businessContext": "Finishing time for the known distance in minutes"
    },
    {
      "id": "d2",
      "label": "Target Distance",
      "type": "number",
      "unit": "km",
      "default": 21.1,
      "businessContext": "Distance of the race to predict in kilometers"
    },
    {
      "id": "fatigue",
      "label": "Fatigue Exponent",
      "type": "number",
      "unit": "",
      "default": 1.06,
      "businessContext": "Fatigue factor per Riegel formula (default 1.06)"
    }
  ],
  "formulas": {
    "t2_min": "t1 * Math.pow(d2/d1, fatigue)",
    "pace_min": "t2_min / d2",
    "t2_formatted": "String(Math.floor(t2_min/60)).padStart(2,'0') + ':' + String(Math.floor(t2_min%60)).padStart(2,'0') + ':' + String(Math.round((t2_min%1)*60)).padStart(2,'0')",
    "pace_formatted": "String(Math.floor(pace_min)).padStart(2,'0') + ':' + String(Math.round((pace_min%1)*60)).padStart(2,'0')"
  },
  "outputs": {
    "primary": "t2_min",
    "breakdown": [
      "t2_formatted",
      "pace_formatted"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

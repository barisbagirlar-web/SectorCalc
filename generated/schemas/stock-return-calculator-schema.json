{
  "toolName": "stock-return-calculator",
  "inputs": [
    {
      "id": "numberOfShares",
      "label": "Number of Shares",
      "type": "number",
      "unit": "shares",
      "default": 100,
      "businessContext": "The total number of shares purchased in the stock.",
      "label_i18n": {
        "en": "Number of Shares",
        "tr": "Hisse Sayısı",
        "de": "Anzahl der Aktien",
        "fr": "Number of Shares",
        "es": "Number of Shares",
        "ar": "Number of Shares"
      },
      "businessContext_i18n": {
        "en": "The total number of shares purchased in the stock.",
        "tr": "Hisse senedinde satın alınan toplam hisse sayısı."
      }
    },
    {
      "id": "purchasePrice",
      "label": "Purchase Price per Share",
      "type": "number",
      "unit": "currency",
      "default": 50,
      "businessContext": "The price at which each share was bought.",
      "label_i18n": {
        "en": "Purchase Price per Share",
        "tr": "Hisse Başına Alış Fiyatı",
        "de": "Purchase Price per Share",
        "fr": "Purchase Price per Share",
        "es": "Purchase Price per Share",
        "ar": "Purchase Price per Share"
      },
      "businessContext_i18n": {
        "en": "The price at which each share was bought.",
        "tr": "Her bir hissenin satın alındığı fiyat."
      }
    },
    {
      "id": "sellingPrice",
      "label": "Selling Price per Share",
      "type": "number",
      "unit": "currency",
      "default": 60,
      "businessContext": "The price at which each share was sold.",
      "label_i18n": {
        "en": "Selling Price per Share",
        "tr": "Hisse Başına Satış Fiyatı",
        "de": "Selling Price per Share",
        "fr": "Selling Price per Share",
        "es": "Selling Price per Share",
        "ar": "Selling Price per Share"
      },
      "businessContext_i18n": {
        "en": "The price at which each share was sold.",
        "tr": "Her bir hissenin satıldığı fiyat."
      }
    },
    {
      "id": "dividends",
      "label": "Total Dividends Received",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Sum of all dividends paid per share over the holding period.",
      "label_i18n": {
        "en": "Total Dividends Received",
        "tr": "Alınan Toplam Temettü",
        "de": "Total Dividends Received",
        "fr": "Total Dividends Received",
        "es": "Total Dividends Received",
        "ar": "Total Dividends Received"
      },
      "businessContext_i18n": {
        "en": "Sum of all dividends paid per share over the holding period.",
        "tr": "Elde tutma süresi boyunca hisse başına ödenen tüm temettülerin toplamı."
      }
    },
    {
      "id": "holdingPeriodYears",
      "label": "Holding Period",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "The length of time the stock was held, in years.",
      "label_i18n": {
        "en": "Holding Period",
        "tr": "Tutma Süresi",
        "de": "Holding Period",
        "fr": "Holding Period",
        "es": "Holding Period",
        "ar": "Holding Period"
      },
      "businessContext_i18n": {
        "en": "The length of time the stock was held, in years.",
        "tr": "Hisse senedinin elde tutulduğu süre (yıl cinsinden)."
      }
    }
  ],
  "formulas": {
    "totalInvestmentCost": "numberOfShares * purchasePrice",
    "totalReturnAmount": "numberOfShares * sellingPrice + dividends - numberOfShares * purchasePrice",
    "returnPercentage": "((numberOfShares * sellingPrice + dividends - numberOfShares * purchasePrice) / (numberOfShares * purchasePrice)) * 100",
    "annualizedReturnPercentage": "(((numberOfShares * sellingPrice + dividends) / (numberOfShares * purchasePrice)) ** (1 / holdingPeriodYears) - 1) * 100"
  },
  "outputs": {
    "primary": "returnPercentage",
    "breakdown": [
      "annualizedReturnPercentage",
      "totalReturnAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualizedReturnPercentage",
    "unit": "%",
    "breakdownUnits": {
      "annualizedReturnPercentage": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",

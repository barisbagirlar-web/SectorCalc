{
  "toolName": "korean-calendar-calculator",
  "inputs": [
    {
      "id": "birthYear",
      "label": "Doğum Yılı (Birth Year)",
      "type": "number",
      "unit": "year",
      "default": 1990,
      "businessContext": "User's birth year"
    },
    {
      "id": "birthMonth",
      "label": "Doğum Ayı (Birth Month)",
      "type": "number",
      "unit": "month",
      "default": 1,
      "businessContext": "User's birth month (1-12)"
    },
    {
      "id": "birthDay",
      "label": "Doğum Günü (Birth Day)",
      "type": "number",
      "unit": "day",
      "default": 1,
      "businessContext": "User's birth day (1-31)"
    },
    {
      "id": "currentYear",
      "label": "Mevcut Yıl (Current Year)",
      "type": "number",
      "unit": "year",
      "default": 2025,
      "businessContext": "Current year for calculation"
    },
    {
      "id": "currentMonth",
      "label": "Mevcut Ay (Current Month)",
      "type": "number",
      "unit": "month",
      "default": 6,
      "businessContext": "Current month (1-12)"
    },
    {
      "id": "currentDay",
      "label": "Mevcut Gün (Current Day)",
      "type": "number",
      "unit": "day",
      "default": 10,
      "businessContext": "Current day (1-31)"
    }
  ],
  "formulas": {
    "koreanAge": "currentYear - birthYear + 1",
    "internationalAge": "(currentYear - birthYear) - ( (currentMonth < birthMonth || (currentMonth == birthMonth && currentDay < birthDay)) ? 1 : 0 )",
    "dangiYear": "currentYear + 2333"
  },
  "outputs": {
    "primary": "koreanAge",
    "breakdown": [
      "internationalAge",
      "dangiYear"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

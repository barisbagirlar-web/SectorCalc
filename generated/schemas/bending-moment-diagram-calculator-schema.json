        "tr": "Yükün sol mesnetten uzaklığı (m)",
        "de": "Abstand der Last vom linken Auflager (m)",
        "fr": "Distance de la charge depuis l'appui gauche (m)",
        "es": "Distancia de la carga desde el apoyo izquierdo (m)",
        "ar": "بعد الحمولة عن المسند الأيسر (م)"
      }
    },
    {
      "id": "distanceX",
      "label": "Kesit Konumu",
      "type": "number",
      "unit": "m",
      "default": 2.5,
      "businessContext": "Distance of section for moment calculation from left support (m)",
      "label_i18n": {
        "en": "Kesit Konumu",
        "tr": "Cross-Section Location",
        "de": "Schnittposition",
        "fr": "Position de la section",
        "es": "Posición de la sección",
        "ar": "موقع المقطع"
      },
      "businessContext_i18n": {
        "en": "Distance of section from left support for moment calculation (m)",
        "tr": "Moment hesabı yapılan kesitin sol mesnetten uzaklığı (m)",
        "de": "Abstand des Schnitts vom linken Auflager (m)",
        "fr": "Distance de la section de calcul du moment depuis l'appui gauche (m)",
        "es": "Distancia desde el apoyo izquierdo hasta la sección de interés (m)",
        "ar": "بعد المقطع المحسوب عنه العزم عن المسند الأيسر (م)"
      }
    }
  ],
  "formulas": {
    "leftReaction": "loadMagnitude * (beamLength - loadPosition) / beamLength",
    "rightReaction": "loadMagnitude * loadPosition / beamLength",
    "bendingMomentAtX": "distanceX <= loadPosition ? (loadMagnitude * (beamLength - loadPosition) * distanceX / beamLength) : (loadMagnitude * loadPosition * (beamLength - distanceX) / beamLength)",
    "maxBendingMoment": "loadMagnitude * loadPosition * (beamLength - loadPosition) / beamLength",
    "maxMomentLocation": "loadPosition"
  },
  "outputs": {
    "primary": "bendingMomentAtX",
    "breakdown": [
      "leftReaction",
      "rightReaction",
      "maxBendingMoment",
      "maxMomentLocation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "maxMomentLocation",
    "unit": "m"
  },

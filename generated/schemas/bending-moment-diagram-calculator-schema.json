      }
    },
    {
      "id": "loadPosition",
      "label": "Load Position",
      "type": "number",
      "unit": "m",
      "default": 2.5,
      "businessContext": "Distance of load from left support (m)",
      "label_i18n": {
        "en": "Load Position",
        "tr": "Yük Konumu",
        "de": "Lastposition",
        "fr": "Position de la charge",
        "es": "Posición de la carga",

{
  "toolName": "bending-moment-diagram-calculator",
  "inputs": [
    {
      "id": "beamLength",
      "label": "Kiriş Uzunluğu",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Kirişin toplam uzunluğu (m)",
      "label_i18n": {
        "en": "Kiriş Uzunluğu",
        "tr": "Kiriş Uzunluğu",
        "de": "Kiriş Uzunluğu",
        "fr": "Kiriş Uzunluğu",
        "es": "Kiriş Uzunluğu",
        "ar": "Kiriş Uzunluğu"
      }
    },
    {
      "id": "loadMagnitude",
      "label": "Yük Büyüklüğü",
      "type": "number",
      "unit": "kN",
      "default": 10,
      "businessContext": "Tekil yükün büyüklüğü (kN)",
      "label_i18n": {
        "en": "Yük Büyüklüğü",
        "tr": "Yük Büyüklüğü",
        "de": "Yük Büyüklüğü",
        "fr": "Yük Büyüklüğü",
        "es": "Yük Büyüklüğü",
        "ar": "Yük Büyüklüğü"
      }
    },
    {
      "id": "loadPosition",
      "label": "Yük Konumu",
      "type": "number",
      "unit": "m",
      "default": 2.5,
      "businessContext": "Yükün sol mesnetten uzaklığı (m)",
      "label_i18n": {
        "en": "Yük Konumu",
        "tr": "Yük Konumu",
        "de": "Yük Konumu",
        "fr": "Yük Konumu",
        "es": "Yük Konumu",
        "ar": "Yük Konumu"
      }
    },
    {
      "id": "distanceX",
      "label": "Kesit Konumu",
      "type": "number",
      "unit": "m",
      "default": 2.5,
      "businessContext": "Moment hesabı yapılan kesitin sol mesnetten uzaklığı (m)",
      "label_i18n": {
        "en": "Kesit Konumu",
        "tr": "Kesit Konumu",
        "de": "Kesit Konumu",
        "fr": "Kesit Konumu",
        "es": "Kesit Konumu",
        "ar": "Kesit Konumu"
      }
    }
  ],
  "formulas": {
    "leftReaction": "loadMagnitude * (beamLength - loadPosition) / beamLength",
    "rightReaction": "loadMagnitude * loadPosition / beamLength",
    "bendingMomentAtX": "distanceX <= loadPosition ? (loadMagnitude * (beamLength - loadPosition) * distanceX / beamLength) : (loadMagnitude * loadPosition * (beamLength - distanceX) / beamLength)",
    "maxBendingMoment": "loadMagnitude * loadPosition * (beamLength - loadPosition) / beamLength",
    "maxMomentLocation": "loadPosition"
  },
  "outputs": {
    "primary": "bendingMomentAtX",
    "breakdown": [
      "leftReaction",
      "rightReaction",
      "maxBendingMoment",
      "maxMomentLocation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "maxMomentLocation"
  },

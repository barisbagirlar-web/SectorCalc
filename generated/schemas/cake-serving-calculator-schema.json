{
  "toolName": "cake-serving-calculator",
  "inputs": [
    {
      "id": "shape",
      "label": "Cake Shape",
      "type": "number",
      "unit": "none",
      "default": 0,
      "businessContext": "0 for round, 1 for rectangular",
      "label_i18n": {
        "en": "Cake Shape",
        "tr": "Cake Shape",
        "de": "Cake Shape",
        "fr": "Cake Shape",
        "es": "Cake Shape",
        "ar": "Cake Shape"
      }
    },
    {
      "id": "dim1",
      "label": "Diameter (round) / Length (rectangular)",
      "type": "number",
      "unit": "cm",
      "default": 20,
      "businessContext": "Primary dimension of the cake",
      "label_i18n": {
        "en": "Diameter (round) / Length (rectangular)",
        "tr": "Diameter (round) / Length (rectangular)",
        "de": "Diameter (round) / Length (rectangular)",
        "fr": "Diameter (round) / Length (rectangular)",
        "es": "Diameter (round) / Length (rectangular)",
        "ar": "Diameter (round) / Length (rectangular)"
      }
    },
    {
      "id": "dim2",
      "label": "Width (rectangular, enter 0 for round)",
      "type": "number",
      "unit": "cm",
      "default": 0,
      "businessContext": "Secondary dimension, only for rectangular cakes",
      "label_i18n": {
        "en": "Width (rectangular, enter 0 for round)",
        "tr": "Width (rectangular, enter 0 for round)",
        "de": "Width (rectangular, enter 0 for round)",
        "fr": "Width (rectangular, enter 0 for round)",
        "es": "Width (rectangular, enter 0 for round)",
        "ar": "Width (rectangular, enter 0 for round)"
      }
    },
    {
      "id": "servingArea",
      "label": "Area per Serving",
      "type": "number",
      "unit": "cm²",
      "default": 25,
      "businessContext": "Typical area per serving (e.g., 25 cm²)",
      "label_i18n": {
        "en": "Area per Serving",
        "tr": "Area per Serving",
        "de": "Area per Serving",
        "fr": "Area per Serving",
        "es": "Area per Serving",
        "ar": "Area per Serving"
      }
    }
  ],
  "formulas": {
    "cakeArea": "shape === 0 ? Math.PI * (dim1/2) ** 2 : dim1 * dim2",
    "totalServings": "cakeArea / servingArea"
  },
  "outputs": {
    "primary": "totalServings",
    "breakdown": [
      "cakeArea",
      "totalServings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalServings"
  },

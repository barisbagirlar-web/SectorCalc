{
  "toolName": "cake-serving-calculator",
  "inputs": [
    {
      "id": "shape",
      "label": "Cake Shape",
      "type": "number",
      "unit": "none",
      "default": 0,
      "businessContext": "0 for round, 1 for rectangular",
      "label_i18n": {
        "en": "Cake Shape",
        "tr": "Kek Şekli",
        "de": "Kuchenform",
        "fr": "Cake Shape",
        "es": "Cake Shape",
        "ar": "Cake Shape"
      },
      "businessContext_i18n": {
        "en": "0 for round, 1 for rectangular",
        "tr": "0 yuvarlak, 1 dikdörtgen",
        "de": "0 für rund, 1 für rechteckig"
      }
    },
    {
      "id": "dim1",
      "label": "Diameter (round) / Length (rectangular)",
      "type": "number",
      "unit": "cm",
      "default": 20,
      "businessContext": "Primary dimension of the cake",
      "label_i18n": {
        "en": "Diameter (round) / Length (rectangular)",
        "tr": "Çap (yuvarlak) / Uzunluk (dikdörtgen)",
        "de": "Durchmesser (rund) / Länge (rechteckig)",
        "fr": "Diameter (round) / Length (rectangular)",
        "es": "Diameter (round) / Length (rectangular)",
        "ar": "Diameter (round) / Length (rectangular)"
      },
      "businessContext_i18n": {
        "en": "Primary dimension of the cake",
        "tr": "Kekin ana boyutu",
        "de": "Primäre Abmessung des Kuchens"
      }
    },
    {
      "id": "dim2",
      "label": "Width (rectangular, enter 0 for round)",
      "type": "number",
      "unit": "cm",
      "default": 0,
      "businessContext": "Secondary dimension, only for rectangular cakes",
      "label_i18n": {
        "en": "Width (rectangular, enter 0 for round)",
        "tr": "Genişlik (dikdörtgen, yuvarlak için 0 girin)",
        "de": "Breite (rechteckig, bei rund 0 eingeben)",
        "fr": "Width (rectangular, enter 0 for round)",
        "es": "Width (rectangular, enter 0 for round)",
        "ar": "Width (rectangular, enter 0 for round)"
      },
      "businessContext_i18n": {
        "en": "Secondary dimension, only for rectangular cakes",
        "tr": "Sadece dikdörtgen kekler için ikincil boyut",
        "de": "Sekundäre Abmessung, nur bei rechteckigen Kuchen"
      }
    },
    {
      "id": "servingArea",
      "label": "Area per Serving",
      "type": "number",
      "unit": "cm²",
      "default": 25,
      "businessContext": "Typical area per serving (e.g., 25 cm²)",
      "label_i18n": {
        "en": "Area per Serving",
        "tr": "Porsiyon Başına Alan",
        "de": "Fläche pro Portion",
        "fr": "Area per Serving",
        "es": "Area per Serving",
        "ar": "Area per Serving"
      },
      "businessContext_i18n": {
        "en": "Typical area per serving (e.g., 25 cm²)",
        "tr": "Porsiyon başına tipik alan (örn. 25 cm²)",
        "de": "Typische Fläche pro Portion (z.B. 25 cm²)"
      }
    }
  ],
  "formulas": {
    "cakeArea": "shape === 0 ? Math.PI * (dim1/2) ** 2 : dim1 * dim2",
    "totalServings": "cakeArea / servingArea"
  },
  "outputs": {
    "primary": "totalServings",
    "breakdown": [
      "cakeArea",
      "totalServings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalServings",
    "unit": "none"
  },

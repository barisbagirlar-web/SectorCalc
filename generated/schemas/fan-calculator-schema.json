  "formulas": {
    "motorInputPowerKW": "(airflow * staticPressure) / (360 * fanEfficiency * motorEfficiency)",
    "fanShaftPowerKW": "(airflow * staticPressure) / (36000 * fanEfficiency)",
    "airPowerKW": "(airflow * staticPressure) / 3600000",
    "airflowM3s": "airflow / 3600",
    "massFlowRate": "(airflow / 3600) * airDensity"
  },

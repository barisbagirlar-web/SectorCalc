{
  "toolName": "l10-life-calculator",
  "inputs": [
    {
      "id": "dynamicLoadRating",
      "label": "Basic Dynamic Load Rating (C)",
      "type": "number",
      "unit": "kN",
      "default": 50,
      "businessContext": "Bearing dynamic load rating from manufacturer catalog",
      "label_i18n": {
        "en": "Basic Dynamic Load Rating (C)",
        "tr": "Basic Dynamic Load Rating (C)",
        "de": "Basic Dynamic Load Rating (C)",
        "fr": "Basic Dynamic Load Rating (C)",
        "es": "Basic Dynamic Load Rating (C)",
        "ar": "Basic Dynamic Load Rating (C)"
      }
    },
    {
      "id": "equivalentLoad",
      "label": "Equivalent Dynamic Load (P)",
      "type": "number",
      "unit": "kN",
      "default": 10,
      "businessContext": "Calculated equivalent radial/axial load on bearing",
      "label_i18n": {
        "en": "Equivalent Dynamic Load (P)",
        "tr": "Equivalent Dynamic Load (P)",
        "de": "Equivalent Dynamic Load (P)",
        "fr": "Equivalent Dynamic Load (P)",
        "es": "Equivalent Dynamic Load (P)",
        "ar": "Equivalent Dynamic Load (P)"
      }
    },
    {
      "id": "exponent",
      "label": "Life Exponent",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "p=3 for ball bearings, p=10/3 (≈3.333) for roller bearings",
      "label_i18n": {
        "en": "Life Exponent",
        "tr": "Life Exponent",
        "de": "Life Exponent",
        "fr": "Life Exponent",
        "es": "Life Exponent",
        "ar": "Life Exponent"
      }
    },
    {
      "id": "reliabilityFactor",
      "label": "Reliability Factor (a₁)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 for 90% reliability; e.g., 0.62 for 95%, 0.53 for 96% per ISO 281",
      "label_i18n": {
        "en": "Reliability Factor (a₁)",
        "tr": "Reliability Factor (a₁)",
        "de": "Reliability Factor (a₁)",
        "fr": "Reliability Factor (a₁)",
        "es": "Reliability Factor (a₁)",
        "ar": "Reliability Factor (a₁)"
      }
    },
    {
      "id": "speed",
      "label": "Rotational Speed",
      "type": "number",
      "unit": "rpm",
      "default": 1500,
      "businessContext": "Shaft speed; used to convert revolutions to hours",
      "label_i18n": {
        "en": "Rotational Speed",
        "tr": "Rotational Speed",
        "de": "Rotational Speed",
        "fr": "Rotational Speed",
        "es": "Rotational Speed",
        "ar": "Rotational Speed"
      }
    }
  ],
  "formulas": {
    "L10_rev": "(reliabilityFactor * Math.pow(dynamicLoadRating / equivalentLoad, exponent)) * 1e6",
    "L10_hours": "L10_rev / (60 * speed)"
  },
  "outputs": {
    "primary": "L10_hours",
    "breakdown": [
      "L10_rev",
      "L10_hours"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "cnc-additive-manufacturing",

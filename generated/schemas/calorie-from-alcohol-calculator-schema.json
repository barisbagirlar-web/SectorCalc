        "ar": "Energy per Gram of Alcohol (kcal/g)"
      }
    }
  ],
  "formulas": {
    "alcoholVolumeTotal": "volumePerDrink * numberOfDrinks",
    "alcoholGramsTotal": "alcoholVolumeTotal * abv * density / 100",
    "caloriesFromAlcohol": "alcoholGramsTotal * kcalPerGram"
  },
  "outputs": {
    "primary": "caloriesFromAlcohol",

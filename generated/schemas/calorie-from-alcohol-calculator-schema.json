      }
    },
    {
      "id": "kcalPerGram",
      "label": "Energy per Gram of Alcohol (kcal/g)",
      "type": "number",
      "unit": "kcal/g",
      "default": 7,
      "businessContext": "Metabolizable energy per gram of alcohol (7 kcal/g).",
      "label_i18n": {
        "en": "Energy per Gram of Alcohol (kcal/g)",
        "tr": "Energy per Gram of Alcohol (kcal/g)",

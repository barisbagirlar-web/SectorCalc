  "formulas": {
    "BaseEstimate": "SUM(DirectCosts) + Overhead",
    "Contingency": "BaseEstimate * RiskFactor",
    "ExpectedMargin": "(BidPrice - (BaseEstimate + Contingency)) / BidPrice",
    "WinProbability": "f(BidPrice, CompetitorIndex, HistoricalWinRate)",
    "ExpectedValue": "WinProbability * ExpectedMargin * BidPrice",
    "RiskAdjustedBid": "BaseEstimate / (1 - TargetMargin - RiskPremium)"
  },

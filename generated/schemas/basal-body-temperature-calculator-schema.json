  "formulas": {
    "averageTemperature": "(day1Temp + day2Temp + day3Temp) / 3",
    "daysAboveThreshold": "(day1Temp > baselineTemp + threshold ? 1 : 0) + (day2Temp > baselineTemp + threshold ? 1 : 0) + (day3Temp > baselineTemp + threshold ? 1 : 0)",
    "temperatureShiftScore": "((day1Temp > baselineTemp + threshold ? 1 : 0) + (day2Temp > baselineTemp + threshold ? 1 : 0) + (day3Temp > baselineTemp + threshold ? 1 : 0)) >= daysToConfirm ? 1 : 0"
  },

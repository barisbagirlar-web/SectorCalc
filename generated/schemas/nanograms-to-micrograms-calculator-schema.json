{
  "toolName": "nanograms-to-micrograms-calculator",
  "inputs": [
    {
      "id": "nanograms",
      "label": "Nanograms",
      "type": "number",
      "unit": "ng",
      "default": 0,
      "businessContext": "Per-item mass in nanograms (1 ng = 1e-9 g)",
      "label_i18n": {
        "en": "Nanograms",
        "tr": "Nanograms",
        "de": "Nanograms",
        "fr": "Nanograms",
        "es": "Nanograms",
        "ar": "Nanograms"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "ng/µg",
      "default": 1000,
      "businessContext": "Number of nanograms in one microgram (standard: 1000)",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Number of decimal places for the final result",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "batchSize",
      "label": "Batch Size",
      "type": "number",
      "unit": "items",
      "default": 1,
      "businessContext": "Number of items in the batch (total mass = per-item mass × batch size)",
      "label_i18n": {
        "en": "Batch Size",
        "tr": "Batch Size",
        "de": "Batch Size",
        "fr": "Batch Size",
        "es": "Batch Size",
        "ar": "Batch Size"
      }
    }
  ],
  "formulas": {
    "totalNanograms": "nanograms * batchSize",
    "rawMicrograms": "totalNanograms / conversionFactor",
    "micrograms": "Math.round(rawMicrograms * Math.pow(10, precision)) / Math.pow(10, precision)"
  },
  "outputs": {
    "primary": "micrograms",
    "breakdown": [
      "totalNanograms",
      "rawMicrograms"
    ]
  },
  "category": "Dönüşüm & Ölçüm",

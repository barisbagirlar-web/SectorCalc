    {
      "id": "otherDeductions",
      "label": "Other Deductions",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Additional deductions (e.g., union fees, advances)",
      "label_i18n": {
        "en": "Other Deductions",
        "tr": "Diğer Kesintiler",
        "de": "Sonstige Abzüge",
        "fr": "Autres déductions",
        "es": "Otras deducciones",
        "ar": "خصومات أخرى"
      },
      "businessContext_i18n": {
        "en": "Additional deductions (e.g., union fees, advances)",
        "tr": "Ek kesintiler (ör. sendika aidatı, avanslar)",
        "de": "Zusätzliche Abzüge (z.B. Gewerkschaftsbeiträge, Vorschüsse)",
        "fr": "Déductions supplémentaires (ex. frais syndicaux, avances)",
        "es": "Deducciones adicionales (ej. cuotas sindicales, anticipos)",
        "ar": "الخصومات الإضافية (مثل رسوم النقابة، السلف)"
      }
    }
  ],
  "formulas": {
    "grossPay": "hoursWorked * hourlyRate + overtimeHours * hourlyRate * overtimeMultiplier",
    "taxAmount": "grossPay * taxRate / 100",
    "insuranceAmount": "grossPay * insuranceRate / 100",
    "totalDeductions": "taxAmount + insuranceAmount + otherDeductions",
    "netPay": "grossPay - totalDeductions"
  },
  "outputs": {
    "primary": "netPay",
    "breakdown": [
      "grossPay",
      "totalDeductions",
      "taxAmount",
      "insuranceAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netPay",
    "unit": "hours"
  },

  "formulas": {
    "force": "(springConstant > 0 ? springConstant : (shearModulus * Math.pow(wireDiameter, 4)) / (8 * Math.pow(coilDiameter, 3) * activeCoils)) * displacement",
    "effectiveSpringConstant": "springConstant > 0 ? springConstant : (shearModulus * Math.pow(wireDiameter, 4)) / (8 * Math.pow(coilDiameter, 3) * activeCoils)",
    "displacement": "displacement"
  },
  "outputs": {
    "primary": "force",
    "breakdown": [
      "effectiveSpringConstant",
      "displacement"
    ]
  },

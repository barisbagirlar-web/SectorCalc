  "formulas": {
    "DriftRate": "(LastError - PrevError) / TimeBetween",
    "PredictedDrift": "DriftRate * TimeSinceLast",
    "CurrentUncertainty": "SQRT(BaseUncertainty^2 + PredictedDrift^2 + EnvFactor^2)",
    "RiskScore": "(CurrentUncertainty / Tolerance) * Criticality * UsageFreq",
    "OptimalInterval": "BaseInterval * (Tolerance / CurrentUncertainty)",
    "GuardBand": "ExpandedUncertainty * k"
  },

        "en": "Density of string material (e.g., steel: 7850 kg/m³)",
        "tr": "Tel malzemesinin yoğunluğu (örn., çelik: 7850 kg/m³)"
      }
    },
    {
      "id": "stringDiameter",
      "label": "String Diameter",
      "type": "number",
      "unit": "mm",
      "default": 1,
      "businessContext": "Diameter of the string in millimeters",
      "label_i18n": {
        "en": "String Diameter",
        "tr": "Tel Çapı",
        "de": "String Diameter",
        "fr": "String Diameter",
        "es": "String Diameter",
        "ar": "String Diameter"
      },
      "businessContext_i18n": {
        "en": "Diameter of the string in millimeters",
        "tr": "Telin milimetre cinsinden çapı"
      }
    },
    {
      "id": "stringLength",
      "label": "String Length",
      "type": "number",
      "unit": "cm",
      "default": 65,
      "businessContext": "Vibrating length of the string in centimeters",
      "label_i18n": {
        "en": "String Length",
        "tr": "Tel Uzunluğu",
        "de": "String Length",
        "fr": "String Length",
        "es": "String Length",
        "ar": "String Length"
      },
      "businessContext_i18n": {
        "en": "Vibrating length of the string in centimeters",
        "tr": "Telin santimetre cinsinden titreşim uzunluğu"
      }
    },
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 440,
      "businessContext": "Fundamental frequency of vibration (e.g., A4 = 440 Hz)",
      "label_i18n": {
        "en": "Frequency",
        "tr": "Frekans",
        "de": "Frequency",
        "fr": "Frequency",
        "es": "Frequency",
        "ar": "Frequency"
      },
      "businessContext_i18n": {
        "en": "Fundamental frequency of vibration (e.g., A4 = 440 Hz)",
        "tr": "Temel titreşim frekansı (örn., A4 = 440 Hz)"
      }
    }
  ],
  "formulas": {
    "linearDensity": "materialDensity * Math.PI * (stringDiameter / 1000) ** 2 / 4",
    "lengthM": "stringLength / 100",
    "tension": "linearDensity * (2 * lengthM * frequency) ** 2"
  },
  "outputs": {
    "primary": "tension",
    "breakdown": [
      "linearDensity",
      "tension"
    ],

{
  "toolName": "gcs-calculator",
  "inputs": [
    {
      "id": "materialCost",
      "label": "Material Cost",
      "type": "number",
      "unit": "EUR",
      "default": 100,
      "businessContext": "Direct material cost per unit"
    },
    {
      "id": "laborCost",
      "label": "Labor Cost",
      "type": "number",
      "unit": "EUR",
      "default": 50,
      "businessContext": "Direct labor cost per unit"
    },
    {
      "id": "overheadRate",
      "label": "Overhead Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Manufacturing overhead as percentage of direct cost"
    },
    {
      "id": "marginRate",
      "label": "Margin Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Desired profit margin on total cost"
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Number of units produced"
    }
  ],
  "formulas": {
    "totalCostPerUnit": "materialCost + laborCost + (materialCost + laborCost) * (overheadRate / 100)",
    "totalCost": "totalCostPerUnit * quantity",
    "sellingPricePerUnit": "totalCostPerUnit * (1 + marginRate / 100)",
    "totalRevenue": "sellingPricePerUnit * quantity",
    "totalProfit": "totalRevenue - totalCost"
  },
  "outputs": {
    "primary": "totalProfit",
    "breakdown": [
      "totalCostPerUnit",
      "sellingPricePerUnit",
      "totalRevenue"
    ]
  },
  "category": "Maliyet & Marj",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

      }
    },
    {
      "id": "laborCost",
      "label": "Labor Cost",
      "type": "number",
      "unit": "EUR",
      "default": 50,
      "businessContext": "Direct labor cost per unit",
      "label_i18n": {
        "en": "Labor Cost",
        "tr": "Labor Cost",
        "de": "Labor Cost",
        "fr": "Labor Cost",
        "es": "Labor Cost",
        "ar": "Labor Cost"
      }
    },
    {
      "id": "overheadRate",
      "label": "Overhead Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Manufacturing overhead as percentage of direct cost",
      "label_i18n": {
        "en": "Overhead Rate",
        "tr": "Overhead Rate",
        "de": "Overhead Rate",
        "fr": "Overhead Rate",
        "es": "Overhead Rate",
        "ar": "Overhead Rate"
      }
    },
    {
      "id": "marginRate",
      "label": "Margin Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Desired profit margin on total cost",
      "label_i18n": {
        "en": "Margin Rate",
        "tr": "Margin Rate",
        "de": "Margin Rate",
        "fr": "Margin Rate",
        "es": "Margin Rate",
        "ar": "Margin Rate"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Number of units produced",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Quantity",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      }
    }
  ],
  "formulas": {
    "totalCostPerUnit": "materialCost + laborCost + (materialCost + laborCost) * (overheadRate / 100)",
    "totalCost": "totalCostPerUnit * quantity",
    "sellingPricePerUnit": "totalCostPerUnit * (1 + marginRate / 100)",
    "totalRevenue": "sellingPricePerUnit * quantity",
    "totalProfit": "totalRevenue - totalCost"
  },
  "outputs": {
    "primary": "totalProfit",
    "breakdown": [
      "totalCostPerUnit",
      "sellingPricePerUnit",
      "totalRevenue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalProfit",
    "unit": "EUR"
  },

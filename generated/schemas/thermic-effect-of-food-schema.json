{
  "toolName": "thermic-effect-of-food",
  "inputs": [
    {
      "id": "protein",
      "label": "Daily Protein",
      "type": "number",
      "unit": "g",
      "default": 150,
      "businessContext": "Amount of protein consumed daily in grams."
    },
    {
      "id": "carbs",
      "label": "Daily Carbs",
      "type": "number",
      "unit": "g",
      "default": 250,
      "businessContext": "Amount of carbohydrates consumed daily in grams."
    },
    {
      "id": "fat",
      "label": "Daily Fat",
      "type": "number",
      "unit": "g",
      "default": 70,
      "businessContext": "Amount of fat consumed daily in grams."
    },
    {
      "id": "proteinTEF",
      "label": "Protein TEF Rate",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Thermic effect percentage for protein (typically 20-30%)."
    },
    {
      "id": "carbsTEF",
      "label": "Carbs TEF Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Thermic effect percentage for carbohydrates (typically 5-10%)."
    },
    {
      "id": "fatTEF",
      "label": "Fat TEF Rate",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Thermic effect percentage for fats (typically 0-3%)."
    }
  ],
  "formulas": {
    "totalCalories": "protein * 4 + carbs * 4 + fat * 9",
    "tefProtein": "protein * 4 * (proteinTEF / 100)",
    "tefCarbs": "carbs * 4 * (carbsTEF / 100)",
    "tefFat": "fat * 9 * (fatTEF / 100)",
    "tefTotal": "tefProtein + tefCarbs + tefFat",
    "tefPercent": "totalCalories !== 0 ? (tefTotal / totalCalories) * 100 : 0",
    "tefSummary": "`Thermic Effect: ${tefTotal.toFixed(0)} kcal (${tefPercent.toFixed(1)}% of total calories)`"
  },
  "outputs": {
    "primary": "tefSummary",
    "breakdown": [
      "totalCalories",
      "tefProtein",
      "tefCarbs",
      "tefFat",
      "tefTotal",
      "tefPercent"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

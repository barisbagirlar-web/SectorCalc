  "formulas": {
    "innerLength": "objectLength + 2 * clearance",
    "innerWidth": "objectWidth + 2 * clearance",
    "innerHeight": "objectHeight + 2 * clearance",
    "outerLength": "innerLength + 2 * wallThickness",
    "outerWidth": "innerWidth + 2 * wallThickness",
    "outerHeight": "innerHeight + 2 * wallThickness",
    "innerVolume": "innerLength * innerWidth * innerHeight",
    "outerVolume": "outerLength * outerWidth * outerHeight",
    "innerDimensions": "innerLength + ' x ' + innerWidth + ' x ' + innerHeight + ' cm'",
    "outerDimensions": "outerLength + ' x ' + outerWidth + ' x ' + outerHeight + ' cm'"

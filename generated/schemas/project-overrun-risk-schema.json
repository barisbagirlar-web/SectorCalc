  "formulas": {
    "SPI": "EarnedValue / PlannedValue",
    "CPI": "EarnedValue / ActualCost",
    "EAC": "BudgetAtCompletion / CPI",
    "ExpectedOverrun": "EAC - BudgetAtCompletion",
    "ScheduleDelay": "(ActualDuration - PlannedDuration) / PlannedDuration",
    "RiskExposure": "ProbabilityOfDelay * (DelayDays * DailyPenalty) + ProbabilityOfCostOverrun * ExpectedOverrun",
    "MitigationCost": "CrashingCost + FastTrackingCost",
    "NetRisk": "RiskExposure - MitigationCost"
  },

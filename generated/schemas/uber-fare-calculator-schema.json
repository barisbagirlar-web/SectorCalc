  "formulas": {
    "subtotal": "baseFare + costPerMinute * durationMinutes + costPerMile * distanceMiles",
    "surgeAmount": "subtotal * (surgeMultiplier - 1)",
    "bookingFeeAmount": "bookingFee",
    "totalFare": "subtotal * surgeMultiplier + bookingFee"
  },
  "outputs": {
    "primary": "totalFare",
    "breakdown": [
      "subtotal",
      "surgeAmount",
      "bookingFeeAmount",
      "totalFare"
    ],

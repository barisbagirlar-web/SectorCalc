  "formulas": {
    "toScientific": "if (value !== 0) { let exp = Math.floor(Math.log10(Math.abs(value))); let coeff = value / Math.pow(10, exp); return { coefficient: parseFloat(coeff.toFixed(precision)), exponent: exp }; } else { return { coefficient: 0, exponent: 0 }; }",
    "fromScientific": "coefficient * Math.pow(10, exponent)",
    "_coefficient_": "{coefficient}",
    "_exponent_": "{exponent}",
    "_value_": "{value}",
    "result": "Scientific Notation: {coefficient} × 10^{exponent}"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Coefficient: {coefficient}",
      "Exponent: {exponent}",
      "Standard Form: {value}"
    ]
  },

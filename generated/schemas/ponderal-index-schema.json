{
  "toolName": "ponderal-index",
  "inputs": [
    {
      "id": "massKg",
      "label": "Weight (kg)",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Patient's body mass."
    },
    {
      "id": "heightCm",
      "label": "Height (cm)",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Patient's height."
    },
    {
      "id": "refMassKg",
      "label": "Reference Weight (kg)",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Standard reference weight for comparison, typically average."
    },
    {
      "id": "refHeightCm",
      "label": "Reference Height (cm)",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Standard reference height for comparison, typically average."
    }
  ],
  "formulas": {
    "piPatient": "massKg / ((heightCm / 100) ** 3)",
    "piReference": "refMassKg / ((refHeightCm / 100) ** 3)",
    "piDifference": "piPatient - piReference"
  },
  "outputs": {
    "primary": "piPatient",
    "breakdown": [
      "piPatient",
      "piReference",
      "piDifference"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

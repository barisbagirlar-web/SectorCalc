        "tr": "Food 3 Servings",
        "de": "Food 3 Servings",
        "fr": "Food 3 Servings",
        "es": "Food 3 Servings",
        "ar": "Food 3 Servings"
      }
    },
    {
      "id": "food3VitPerServing",
      "label": "Vitamin per Serving (Food 3)",
      "type": "number",
      "unit": "mg",
      "default": 10,
      "businessContext": "Vitamin content per serving for food 3.",
      "label_i18n": {
        "en": "Vitamin per Serving (Food 3)",
        "tr": "Vitamin per Serving (Food 3)",
        "de": "Vitamin per Serving (Food 3)",
        "fr": "Vitamin per Serving (Food 3)",
        "es": "Vitamin per Serving (Food 3)",
        "ar": "Vitamin per Serving (Food 3)"
      }
    }
  ],
  "formulas": {
    "totalVitaminIntake": "food1Servings * food1VitPerServing + food2Servings * food2VitPerServing + food3Servings * food3VitPerServing",
    "percentRDA": "(totalVitaminIntake / rda) * 100",
    "shortfallValue": "rda - totalVitaminIntake"
  },
  "outputs": {
    "primary": "totalVitaminIntake",
    "breakdown": [
      "percentRDA",
      "shortfallValue"
    ],

    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "BTU/therm",
      "default": 100000,
      "businessContext": "Standard conversion factor from therms to BTU (1 therm = 100,000 BTU).",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "energyContentAdjustment",
      "label": "Energy Content Adjustment",
      "type": "number",
      "unit": "BTU/therm",
      "default": 0,
      "businessContext": "Adjustment to the conversion factor for fuel-specific energy content variations, if any.",
      "label_i18n": {
        "en": "Energy Content Adjustment",
        "tr": "Energy Content Adjustment",
        "de": "Energy Content Adjustment",
        "fr": "Energy Content Adjustment",
        "es": "Energy Content Adjustment",
        "ar": "Energy Content Adjustment"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "decimal places",
      "default": 0,
      "businessContext": "Number of decimal places to round the output.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "outputUnitFactor",
      "label": "Output Unit Scale Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Factor to convert BTU to desired output unit (e.g., 1 for BTU, 1e-6 for MMBTU).",
      "label_i18n": {
        "en": "Output Unit Scale Factor",
        "tr": "Output Unit Scale Factor",
        "de": "Output Unit Scale Factor",
        "fr": "Output Unit Scale Factor",
        "es": "Output Unit Scale Factor",
        "ar": "Output Unit Scale Factor"
      }
    }
  ],
  "formulas": {
    "adjustedFactor": "conversionFactor + energyContentAdjustment",
    "rawBtu": "quantity * (conversionFactor + energyContentAdjustment)",
    "scaledOutput": "rawBtu * outputUnitFactor"
  },
  "outputs": {
    "primary": "scaledOutput",
    "breakdown": [

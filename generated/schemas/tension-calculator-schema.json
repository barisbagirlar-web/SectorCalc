{
  "toolName": "tension-calculator",
  "inputs": [
    {
      "id": "mass",
      "label": "Load Mass",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Mass of the load to be supported"
    },
    {
      "id": "gravity",
      "label": "Gravity",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Gravitational acceleration (standard 9.81 m/s²)"
    },
    {
      "id": "angle",
      "label": "Angle from Horizontal",
      "type": "number",
      "unit": "°",
      "default": 45,
      "businessContext": "Angle of ropes/cables from horizontal"
    },
    {
      "id": "numberOfRopes",
      "label": "Number of Ropes",
      "type": "number",
      "unit": "",
      "default": 2,
      "businessContext": "Number of supporting ropes or cables"
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "",
      "default": 1.5,
      "businessContext": "Engineering safety factor per relevant standards"
    }
  ],
  "formulas": {
    "tensionPerRope": "(mass * gravity) / (numberOfRopes * Math.sin(angle * Math.PI / 180))",
    "tensionWithSafety": "tensionPerRope * safetyFactor"
  },
  "outputs": {
    "primary": "tensionWithSafety",
    "breakdown": [
      "tensionPerRope",
      "tensionWithSafety"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

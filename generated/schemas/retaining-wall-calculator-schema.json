  "formulas": {
    "W1": "wallHeight * wallThickness * concreteDensity",
    "W2": "baseWidth * baseThickness * concreteDensity",
    "heel_length": "baseWidth - wallThickness",
    "W3": "soilDensity * wallHeight * heel_length",
    "R": "W1 + W2 + W3",
    "Mr": "W1 * (wallThickness / 2) + W2 * (baseWidth / 2) + W3 * ((baseWidth + wallThickness) / 2)"
  },

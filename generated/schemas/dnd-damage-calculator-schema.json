  "formulas": {
    "baseDamage": "weaponDamage + abilityModifier + magicBonus + extraDamageDice",
    "criticalDamage": "baseDamage * 2",
    "averageDamagePerHit": "baseDamage * (1 - criticalHitChance / 100) + criticalDamage * (criticalHitChance / 100)",
    "finalDamage": "averageDamagePerHit * damageMultiplier"
  },
  "outputs": {
    "primary": "finalDamage",
    "breakdown": [

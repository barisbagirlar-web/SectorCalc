        "de": "Time Until Weigh-in",
        "fr": "Time Until Weigh-in",
        "es": "Time Until Weigh-in",
        "ar": "Time Until Weigh-in"
      }
    },
    {
      "id": "bodyFatPercentage",
      "label": "Body Fat Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Estimated body fat percentage",
      "label_i18n": {
        "en": "Body Fat Percentage",
        "tr": "Body Fat Percentage",
        "de": "Body Fat Percentage",
        "fr": "Body Fat Percentage",
        "es": "Body Fat Percentage",
        "ar": "Body Fat Percentage"
      }
    },
    {
      "id": "maxDehydrationPercentage",
      "label": "Safe Dehydration Limit",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Maximum safe water loss as % of body weight (typically 2-5%)",
      "label_i18n": {
        "en": "Safe Dehydration Limit",
        "tr": "Safe Dehydration Limit",
        "de": "Safe Dehydration Limit",
        "fr": "Safe Dehydration Limit",
        "es": "Safe Dehydration Limit",
        "ar": "Safe Dehydration Limit"
      }
    }
  ],
  "formulas": {
    "requiredWeightLoss": "currentWeight - targetWeight",
    "maxSafeWaterLoss": "currentWeight * maxDehydrationPercentage / 100",
    "cutRatePerHour": "requiredWeightLoss / hoursUntilWeighIn"
  },
  "outputs": {
    "primary": "requiredWeightLoss",
    "breakdown": [
      "maxSafeWaterLoss",
      "excessWeight",
      "cutRatePerHour"
    ],

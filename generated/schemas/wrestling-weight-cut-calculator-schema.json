      "label_i18n": {
        "en": "Safe Dehydration Limit",
        "tr": "Güvenli Dehidrasyon Limiti",
        "de": "Sichere Dehydrationsgrenze",
        "fr": "Limite de déshydratation sécuritaire",
        "es": "Safe Dehydration Limit",
        "ar": "Safe Dehydration Limit"
      },
      "businessContext_i18n": {
        "en": "Maximum safe water loss as % of body weight (typically 2-5%)",
        "tr": "Vücut ağırlığının yüzdesi olarak maksimum güvenli su kaybı (tipik olarak %2-5)",

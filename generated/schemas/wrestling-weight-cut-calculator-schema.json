        "fr": "Perte d'eau maximale sécuritaire en % du poids corporel (généralement 2-5%)"
      }
    }
  ],
  "formulas": {
    "requiredWeightLoss": "currentWeight - targetWeight",
    "maxSafeWaterLoss": "currentWeight * maxDehydrationPercentage / 100",
    "cutRatePerHour": "requiredWeightLoss / hoursUntilWeighIn"
  },
  "outputs": {
    "primary": "requiredWeightLoss",
    "breakdown": [
      "maxSafeWaterLoss",

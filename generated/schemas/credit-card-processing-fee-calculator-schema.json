{
  "toolName": "credit-card-processing-fee-calculator",
  "inputs": [
    {
      "id": "transactionAmount",
      "label": "Transaction Amount",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Total amount charged to the customer for the transaction.",
      "label_i18n": {
        "en": "Transaction Amount",
        "tr": "Transaction Amount",
        "de": "Transaction Amount",
        "fr": "Transaction Amount",
        "es": "Transaction Amount",
        "ar": "Transaction Amount"
      }
    },
    {
      "id": "processingRate",
      "label": "Processing Rate",
      "type": "number",
      "unit": "%",
      "default": 2.9,
      "businessContext": "Percentage fee charged by the processor on the transaction amount.",
      "label_i18n": {
        "en": "Processing Rate",
        "tr": "Processing Rate",
        "de": "Processing Rate",
        "fr": "Processing Rate",
        "es": "Processing Rate",
        "ar": "Processing Rate"
      }
    },
    {
      "id": "perTransactionFee",
      "label": "Per-Transaction Fee",
      "type": "number",
      "unit": "USD",
      "default": 0.3,
      "businessContext": "Fixed fee charged per transaction by the processor.",
      "label_i18n": {
        "en": "Per-Transaction Fee",
        "tr": "Per-Transaction Fee",
        "de": "Per-Transaction Fee",
        "fr": "Per-Transaction Fee",
        "es": "Per-Transaction Fee",
        "ar": "Per-Transaction Fee"
      }
    },
    {
      "id": "monthlyStatementFee",
      "label": "Monthly Statement Fee",
      "type": "number",
      "unit": "USD",
      "default": 10,
      "businessContext": "Fixed monthly fee for account maintenance, distributed across transactions.",
      "label_i18n": {
        "en": "Monthly Statement Fee",
        "tr": "Monthly Statement Fee",
        "de": "Monthly Statement Fee",
        "fr": "Monthly Statement Fee",
        "es": "Monthly Statement Fee",
        "ar": "Monthly Statement Fee"
      }
    },
    {
      "id": "numberOfTransactions",
      "label": "Number of Monthly Transactions",
      "type": "number",
      "unit": "transactions",
      "default": 100,
      "businessContext": "Total number of transactions processed per month.",
      "label_i18n": {
        "en": "Number of Monthly Transactions",
        "tr": "Number of Monthly Transactions",
        "de": "Number of Monthly Transactions",
        "fr": "Number of Monthly Transactions",
        "es": "Number of Monthly Transactions",
        "ar": "Number of Monthly Transactions"
      }
    }
  ],
  "formulas": {
    "totalFee": "transactionAmount * processingRate / 100 + perTransactionFee + monthlyStatementFee / numberOfTransactions",
    "netAmount": "transactionAmount - totalFee",
    "effectiveRate": "(totalFee / transactionAmount) * 100",
    "monthlyTotalFee": "totalFee * numberOfTransactions"
  },
  "outputs": {
    "primary": "netAmount",
    "breakdown": [
      "totalFee",
      "effectiveRate",
      "monthlyTotalFee"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "monthlyTotalFee"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "finance",

{
  "toolName": "mohrs-circle-calculator",
  "inputs": [
    {
      "id": "sigma_x",
      "label": "Normal Stress σx",
      "type": "number",
      "unit": "MPa",
      "default": 0,
      "businessContext": "Normal stress in x-direction",
      "label_i18n": {
        "en": "Normal Stress σx",

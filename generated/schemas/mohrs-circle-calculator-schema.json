      }
    },
    {
      "id": "sigma_y",
      "label": "Normal Stress σy",
      "type": "number",
      "unit": "MPa",
      "default": 0,
      "businessContext": "Normal stress in y-direction",
      "label_i18n": {
        "en": "Normal Stress σy",
        "tr": "Normal Stress σy",
        "de": "Normal Stress σy",
        "fr": "Normal Stress σy",
        "es": "Normal Stress σy",
        "ar": "Normal Stress σy"
      }
    },
    {
      "id": "tau_xy",
      "label": "Shear Stress τxy",
      "type": "number",
      "unit": "MPa",
      "default": 0,
      "businessContext": "Shear stress on x-face in y-direction",
      "label_i18n": {
        "en": "Shear Stress τxy",
        "tr": "Shear Stress τxy",
        "de": "Shear Stress τxy",
        "fr": "Shear Stress τxy",
        "es": "Shear Stress τxy",
        "ar": "Shear Stress τxy"
      }
    }
  ],
  "formulas": {
    "sigma_avg": "(sigma_x + sigma_y) / 2",
    "R": "Math.sqrt(((sigma_x - sigma_y) / 2) ** 2 + tau_xy ** 2)",
    "sigma_1": "sigma_avg + R",
    "sigma_2": "sigma_avg - R",
    "tau_max": "R",
    "theta_p": "0.5 * Math.atan2(tau_xy, (sigma_x - sigma_y) / 2) * 180 / Math.PI",
    "theta_s": "theta_p + 45",
    "Average_Stress___avg____sigma_avg__MPa": "Average Stress σ_avg = {sigma_avg} MPa",
    "Radius_R____R__MPa": "Radius R = {R} MPa",
    "Principal_Angle___p____theta_p__": "Principal Angle θ_p = {theta_p}°",
    "Shear_Angle___s____theta_s__": "Shear Angle θ_s = {theta_s}°"
  },
  "outputs": {
    "primary": "sigma_avg",
    "breakdown": [
      "Average Stress σ_avg = {sigma_avg} MPa",
      "Radius R = {R} MPa",
      "Principal Angle θ_p = {theta_p}°",
      "Shear Angle θ_s = {theta_s}°"
    ]
  },

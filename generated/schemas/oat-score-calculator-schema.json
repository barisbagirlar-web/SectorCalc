      "id": "torqueReading",
      "label": "Torque Reading",
      "type": "number",
      "unit": "Nm",
      "default": 50,
      "businessContext": "Measured torque in Newton-meters",
      "label_i18n": {
        "en": "Torque Reading",
        "tr": "Torque Reading",
        "de": "Torque Reading",
        "fr": "Torque Reading",
        "es": "Torque Reading",
        "ar": "Torque Reading"
      }
    },
    {
      "id": "angleReading",
      "label": "Angle Reading",
      "type": "number",
      "unit": "degrees",
      "default": 5,
      "businessContext": "Off-axis angle in degrees",
      "label_i18n": {
        "en": "Angle Reading",
        "tr": "Angle Reading",
        "de": "Angle Reading",
        "fr": "Angle Reading",
        "es": "Angle Reading",
        "ar": "Angle Reading"
      }
    },
    {
      "id": "vibrationLevel",
      "label": "Vibration Level",
      "type": "number",
      "unit": "mm/s",
      "default": 0.5,
      "businessContext": "Vibration RMS velocity",
      "label_i18n": {
        "en": "Vibration Level",
        "tr": "Vibration Level",
        "de": "Vibration Level",
        "fr": "Vibration Level",
        "es": "Vibration Level",
        "ar": "Vibration Level"
      }
    },
    {
      "id": "defectCount",
      "label": "Defect Count",
      "type": "number",
      "unit": "pieces",
      "default": 2,
      "businessContext": "Number of quality defects detected",
      "label_i18n": {
        "en": "Defect Count",
        "tr": "Defect Count",
        "de": "Defect Count",
        "fr": "Defect Count",
        "es": "Defect Count",
        "ar": "Defect Count"
      }
    },
    {
      "id": "calibrationFactor",
      "label": "Calibration Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Equipment calibration multiplier",
      "label_i18n": {
        "en": "Calibration Factor",
        "tr": "Calibration Factor",
        "de": "Calibration Factor",
        "fr": "Calibration Factor",
        "es": "Calibration Factor",
        "ar": "Calibration Factor"
      }
    }
  ],
  "formulas": {
    "torqueScore": "torqueReading * Math.cos(angleReading * 0.01745329252)",
    "vibrationImpact": "Math.log(vibrationLevel + 1) * 10",
    "defectPenalty": "defectCount * 5",
    "rawScore": "calibrationFactor * (torqueScore * 0.6 + (100 - vibrationImpact) * 0.3 + (100 - defectPenalty) * 0.1)",
    "oatScore": "rawScore"
  },
  "outputs": {
    "primary": "oatScore",
    "breakdown": [
      "torqueScore",
      "vibrationImpact",
      "defectPenalty",
      "rawScore"
    ]
  },

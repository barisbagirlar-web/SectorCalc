  "formulas": {
    "lastTerm": "(() => { let seq = []; if (termCount > 0) seq.push(firstTerm); if (termCount > 1) seq.push(secondTerm); for (let i = 2; i < termCount; i++) { seq.push(multiplierA * seq[i-1] + multiplierB * seq[i-2]); } if (decimalPlaces >= 0) { seq = seq.map(v => parseFloat(v.toFixed(decimalPlaces))); } return seq[seq.length - 1]; })()",
    "sequence": "(() => { let seq = []; if (termCount > 0) seq.push(firstTerm); if (termCount > 1) seq.push(secondTerm); for (let i = 2; i < termCount; i++) { seq.push(multiplierA * seq[i-1] + multiplierB * seq[i-2]); } if (decimalPlaces >= 0) { seq = seq.map(v => parseFloat(v.toFixed(decimalPlaces))); } return JSON.stringify(seq); })()"
  },

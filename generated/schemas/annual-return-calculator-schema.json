{
  "toolName": "annual-return-calculator",
  "inputs": [
    {
      "id": "initialInvestment",
      "label": "Initial Investment",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "The amount of money initially invested.",
      "label_i18n": {
        "en": "Initial Investment",
        "tr": "Initial Investment",
        "de": "Initial Investment",
        "fr": "Initial Investment",
        "es": "Initial Investment",
        "ar": "Initial Investment"
      }
    },
    {
      "id": "finalValue",
      "label": "Final Value",
      "type": "number",
      "unit": "currency",
      "default": 15000,
      "businessContext": "The total value of the investment at the end of the period.",
      "label_i18n": {
        "en": "Final Value",
        "tr": "Final Value",
        "de": "Final Value",
        "fr": "Final Value",
        "es": "Final Value",
        "ar": "Final Value"
      }
    },
    {
      "id": "years",
      "label": "Investment Period",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "The duration of the investment in years.",
      "label_i18n": {
        "en": "Investment Period",
        "tr": "Investment Period",
        "de": "Investment Period",
        "fr": "Investment Period",
        "es": "Investment Period",
        "ar": "Investment Period"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The annual inflation rate to adjust for real return.",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Inflation Rate",
        "de": "Inflation Rate",
        "fr": "Inflation Rate",
        "es": "Inflation Rate",
        "ar": "Inflation Rate"
      }
    }
  ],
  "formulas": {
    "nominalAnnualReturn": "(finalValue / initialInvestment) ** (1 / years) - 1",
    "realAnnualReturn": "(1 + ((finalValue / initialInvestment) ** (1 / years) - 1)) / (1 + inflationRate / 100) - 1",
    "totalReturnMultiple": "finalValue / initialInvestment"
  },
  "outputs": {
    "primary": "nominalAnnualReturn",
    "breakdown": [
      "realAnnualReturn",
      "totalReturnMultiple"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalReturnMultiple"
  },

      }
    },
    {
      "id": "finalValue",
      "label": "Final Value",
      "type": "number",
      "unit": "currency",
      "default": 15000,
      "businessContext": "The total value of the investment at the end of the period.",
      "label_i18n": {
        "en": "Final Value",
        "tr": "Nihai Değer",
        "de": "Endwert",
        "fr": "Final Value",
        "es": "Final Value",
        "ar": "Final Value"
      },
      "businessContext_i18n": {
        "en": "The total value of the investment at the end of the period.",
        "tr": "Dönem sonunda yatırımın toplam değeri.",
        "de": "Der Gesamtwert der Investition am Ende des Zeitraums."
      }
    },
    {
      "id": "years",
      "label": "Investment Period",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "The duration of the investment in years.",
      "label_i18n": {
        "en": "Investment Period",
        "tr": "Yatırım Süresi",
        "de": "Anlagedauer",
        "fr": "Investment Period",
        "es": "Investment Period",
        "ar": "Investment Period"
      },
      "businessContext_i18n": {
        "en": "The duration of the investment in years.",
        "tr": "Yatırımın yıl cinsinden süresi.",
        "de": "Die Dauer der Investition in Jahren."
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The annual inflation rate to adjust for real return.",
      "label_i18n": {
        "en": "Inflation Rate",
        "tr": "Enflasyon Oranı",
        "de": "Inflationsrate",
        "fr": "Inflation Rate",
        "es": "Inflation Rate",
        "ar": "Inflation Rate"
      },
      "businessContext_i18n": {
        "en": "The annual inflation rate to adjust for real return.",
        "tr": "Reel getiriyi hesaplamak için yıllık enflasyon oranı.",
        "de": "Die jährliche Inflationsrate zur Berechnung der realen Rendite."
      }
    }
  ],
  "formulas": {
    "nominalAnnualReturn": "(finalValue / initialInvestment) ** (1 / years) - 1",
    "realAnnualReturn": "(1 + ((finalValue / initialInvestment) ** (1 / years) - 1)) / (1 + inflationRate / 100) - 1",
    "totalReturnMultiple": "finalValue / initialInvestment"
  },
  "outputs": {
    "primary": "nominalAnnualReturn",
    "breakdown": [
      "realAnnualReturn",
      "totalReturnMultiple"
    ],

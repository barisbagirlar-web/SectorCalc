  "formulas": {
    "dotProduct": "x1 * x2 + y1 * y2",
    "magnitude1": "Math.sqrt(x1*x1 + y1*y1)",
    "magnitude2": "Math.sqrt(x2*x2 + y2*y2)",
    "angleRad": "Math.acos((x1 * x2 + y1 * y2) / (Math.sqrt(x1*x1 + y1*y1) * Math.sqrt(x2*x2 + y2*y2)))",
    "angleDeg": "Math.acos((x1 * x2 + y1 * y2) / (Math.sqrt(x1*x1 + y1*y1) * Math.sqrt(x2*x2 + y2*y2))) * (180 / Math.PI)"
  },

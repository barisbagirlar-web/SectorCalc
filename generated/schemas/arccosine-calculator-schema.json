      "label": "Hypotenuse",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the hypotenuse. Must be greater than zero and greater than or equal to the adjacent side to ensure a valid arccosine input (ratio ≤ 1).",
      "label_i18n": {
        "en": "Hypotenuse",
        "tr": "Hypotenuse",
        "de": "Hypotenuse",
        "fr": "Hypotenuse",
        "es": "Hypotenuse",
        "ar": "Hypotenuse"
      }
    },
    {
      "id": "outputUnit",
      "label": "Output Unit",
      "type": "number",
      "unit": "mode",

  "formulas": {
    "primary": "parseFloat((inputs.outputUnit == 1 ? (Math.acos(inputs.adjacent / inputs.hypotenuse) * (180 / Math.PI)) : Math.acos(inputs.adjacent / inputs.hypotenuse)).toFixed(inputs.precision))",

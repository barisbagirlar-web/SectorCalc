{
  "toolName": "capacity-factor-calculator",
  "inputs": [
    {
      "id": "actualEnergy",
      "label": "Actual Energy Produced",
      "type": "number",
      "unit": "MWh",
      "default": 0,
      "businessContext": "Total energy generated in the period (megawatt-hours).",
      "label_i18n": {
        "en": "Actual Energy Produced",
        "tr": "Gerçek Üretilen Enerji",
        "de": "Tatsächlich erzeugte Energie",
        "fr": "Actual Energy Produced",
        "es": "Actual Energy Produced",
        "ar": "Actual Energy Produced"
      },
      "businessContext_i18n": {
        "en": "Total energy generated in the period (megawatt-hours).",
        "tr": "Dönemde üretilen toplam enerji (megawatt-saat).",
        "de": "Gesamte im Zeitraum erzeugte Energie (Megawattstunden)."
      }
    },
    {
      "id": "installedCapacity",
      "label": "Installed Capacity",
      "type": "number",
      "unit": "MW",
      "default": 0,
      "businessContext": "Rated maximum power output (megawatts).",
      "label_i18n": {
        "en": "Installed Capacity",
        "tr": "Kurulu Güç",
        "de": "Installierte Kapazität",
        "fr": "Installed Capacity",
        "es": "Installed Capacity",
        "ar": "Installed Capacity"
      },
      "businessContext_i18n": {
        "en": "Rated maximum power output (megawatts).",
        "tr": "Nominal maksimum güç çıkışı (megawatt).",
        "de": "Nennleistung (Megawatt)."
      }
    },
    {
      "id": "hoursPeriod",
      "label": "Period Hours",
      "type": "number",
      "unit": "h",
      "default": 8760,
      "businessContext": "Total hours in the evaluation period (e.g., 8760 for a year).",
      "label_i18n": {
        "en": "Period Hours",
        "tr": "Dönem Saati",
        "de": "Betriebsstunden",
        "fr": "Period Hours",
        "es": "Period Hours",
        "ar": "Period Hours"
      },
      "businessContext_i18n": {
        "en": "Total hours in the evaluation period (e.g., 8760 for a year).",
        "tr": "Değerlendirme dönemindeki toplam saat (örneğin bir yıl için 8760).",
        "de": "Gesamtstunden im Bewertungszeitraum (z. B. 8760 für ein Jahr)."
      }
    },
    {
      "id": "availabilityFactor",
      "label": "Availability Factor",
      "type": "number",
      "unit": "(fraction)",
      "default": 1,
      "businessContext": "Fraction of time the plant was available (0-1). Use 1 if ignoring outages.",
      "label_i18n": {
        "en": "Availability Factor",
        "tr": "Kullanılabilirlik Faktörü",
        "de": "Verfügbarkeitsfaktor",
        "fr": "Availability Factor",
        "es": "Availability Factor",
        "ar": "Availability Factor"
      },
      "businessContext_i18n": {
        "en": "Fraction of time the plant was available (0-1). Use 1 if ignoring outages.",
        "tr": "Tesisin kullanılabilir olduğu zamanın oranı (0-1). Kesintiler yok sayılıyorsa 1 kullanın.",
        "de": "Anteil der Zeit, in der die Anlage verfügbar war (0-1). Verwenden Sie 1, wenn Ausfälle ignoriert werden."
      }
    },
    {
      "id": "targetCapacityFactor",
      "label": "Target Capacity Factor",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Target capacity factor for comparison (percentage).",
      "label_i18n": {
        "en": "Target Capacity Factor",
        "tr": "Hedef Kapasite Faktörü",
        "de": "Ziel-Kapazitätsfaktor",
        "fr": "Target Capacity Factor",
        "es": "Target Capacity Factor",
        "ar": "Target Capacity Factor"
      },
      "businessContext_i18n": {
        "en": "Target capacity factor for comparison (percentage).",
        "tr": "Karşılaştırma için hedef kapasite faktörü (yüzde).",
        "de": "Zielkapazitätsfaktor für den Vergleich (Prozentsatz)."
      }
    }
  ],
  "formulas": {
    "maxPossibleEnergy": "installedCapacity * hoursPeriod * availabilityFactor",
    "capacityFactor": "(actualEnergy / (installedCapacity * hoursPeriod * availabilityFactor)) * 100",
    "deviation": "((actualEnergy / (installedCapacity * hoursPeriod * availabilityFactor)) * 100) - targetCapacityFactor"
  },
  "outputs": {
    "primary": "capacityFactor",
    "breakdown": [
      "maxPossibleEnergy",
      "deviation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "deviation",
    "unit": "MWh"
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "ecology-environment",
  "sectorSlug": "energy-carbon",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "energy",

      "max": 100,
      "options": null,
      "businessContext": "İç ortam ile dış ortam arasındaki sıcaklık farkı. Isı transferi hesaplamalarında kullanılır. Kaynak: ASHRAE."
    },
    {
      "id": "isiGecirgenlikKatsayisi",
      "label": "Isı Geçirgenlik Katsayısı (W/m²K)",
      "type": "number",
      "unit": "W/m²K",
      "default": 1.5,
      "min": 0.1,
      "max": 10,

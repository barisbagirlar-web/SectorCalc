  "formulas": {
    "plantSpacingM": "plantSpacing / 100",
    "rowSpacingM": "rowSpacing / 100",
    "edgeOffsetM": "edgeOffset / 100",
    "effectiveLength": "length - 2 * edgeOffsetM",
    "effectiveWidth": "width - 2 * edgeOffsetM",
    "columns": "effectiveLength / plantSpacingM",
    "rows": "effectiveWidth / rowSpacingM",
    "totalPlants": "columns * rows",
    "totalArea": "length * width"
  },
  "outputs": {
    "primary": "totalPlants",

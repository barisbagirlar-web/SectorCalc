{
  "toolName": "sum-of-years-digits-depreciation-calculator",
  "inputs": [
    {
      "id": "cost",
      "label": "Asset Cost",
      "type": "number",
      "unit": "$",
      "default": 10000,
      "businessContext": "Initial purchase price of the asset",
      "label_i18n": {
        "en": "Asset Cost",
        "tr": "Asset Cost",
        "de": "Asset Cost",
        "fr": "Asset Cost",
        "es": "Asset Cost",
        "ar": "Asset Cost"
      }
    },
    {
      "id": "salvageValue",
      "label": "Salvage Value",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "Estimated residual value at end of useful life",
      "label_i18n": {
        "en": "Salvage Value",
        "tr": "Salvage Value",
        "de": "Salvage Value",
        "fr": "Salvage Value",
        "es": "Salvage Value",
        "ar": "Salvage Value"
      }
    },
    {
      "id": "usefulLife",
      "label": "Useful Life",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Total expected lifespan of the asset in years",
      "label_i18n": {
        "en": "Useful Life",
        "tr": "Useful Life",
        "de": "Useful Life",
        "fr": "Useful Life",
        "es": "Useful Life",
        "ar": "Useful Life"
      }
    },
    {
      "id": "year",
      "label": "Year of Depreciation",
      "type": "number",
      "unit": "year number",
      "default": 1,
      "businessContext": "The specific year for which depreciation expense is calculated (1-indexed)",
      "label_i18n": {
        "en": "Year of Depreciation",
        "tr": "Year of Depreciation",
        "de": "Year of Depreciation",
        "fr": "Year of Depreciation",
        "es": "Year of Depreciation",
        "ar": "Year of Depreciation"
      }
    }
  ],
  "formulas": {
    "depreciation": "(cost - salvageValue) * (usefulLife - year + 1) / (usefulLife * (usefulLife + 1) / 2)",
    "bookValueEnd": "cost - (cost - salvageValue) * (year * (2 * usefulLife - year + 1) / 2) / (usefulLife * (usefulLife + 1) / 2)"
  },
  "outputs": {
    "primary": "depreciation",
    "breakdown": [
      "depreciation",
      "bookValueEnd"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bookValueEnd"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

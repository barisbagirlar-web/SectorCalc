        "ar": "Pole 2 - Imaginary Part"
      }
    },
    {
      "id": "zero1_real",
      "label": "Zero 1 - Real Part",
      "type": "number",
      "unit": "Hz",
      "default": 100,
      "businessContext": "Real part of the first zero location in the s-plane.",
      "label_i18n": {
        "en": "Zero 1 - Real Part",
        "tr": "Zero 1 - Real Part",
        "de": "Zero 1 - Real Part",
        "fr": "Zero 1 - Real Part",
        "es": "Zero 1 - Real Part",
        "ar": "Zero 1 - Real Part"
      }
    },
    {
      "id": "zero1_imag",
      "label": "Zero 1 - Imaginary Part",
      "type": "number",
      "unit": "Hz",
      "default": 0,
      "businessContext": "Imaginary part of the first zero location in the s-plane.",
      "label_i18n": {
        "en": "Zero 1 - Imaginary Part",
        "tr": "Zero 1 - Imaginary Part",
        "de": "Zero 1 - Imaginary Part",
        "fr": "Zero 1 - Imaginary Part",
        "es": "Zero 1 - Imaginary Part",
        "ar": "Zero 1 - Imaginary Part"
      }
    }
  ],
  "formulas": {
    "w": "2 * Math.PI * frequency",
    "num_mag": "Math.sqrt(zero1_real ** 2 + (w - zero1_imag) ** 2)",
    "den1_mag": "Math.sqrt(pole1_real ** 2 + (w - pole1_imag) ** 2)",
    "den2_mag": "Math.sqrt(pole2_real ** 2 + (w - pole2_imag) ** 2)",
    "mag_linear": "num_mag / (den1_mag * den2_mag)",
    "mag_dB": "20 * (Math.log(mag_linear) / Math.log(10))"
  },
  "outputs": {
    "primary": "mag_dB",
    "breakdown": [
      "mag_linear"
    ]
  },
  "category": "Üretim & İmalat",

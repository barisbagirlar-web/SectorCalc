{
  "toolName": "pole-zero-calculator",
  "inputs": [
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1,
      "businessContext": "Frequency at which the transfer function magnitude is evaluated.",

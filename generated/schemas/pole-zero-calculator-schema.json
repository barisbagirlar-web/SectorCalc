      }
    },
    {
      "id": "pole1_imag",
      "label": "Pole 1 - Imaginary Part",
      "type": "number",
      "unit": "Hz",
      "default": 0,
      "businessContext": "Imaginary part of the first pole location in the s-plane.",
      "label_i18n": {
        "en": "Pole 1 - Imaginary Part",
        "tr": "Pole 1 - Imaginary Part",
        "de": "Pole 1 - Imaginary Part",

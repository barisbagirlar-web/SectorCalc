        "ar": "Pole 2 - Real Part"
      }
    },
    {
      "id": "pole2_imag",
      "label": "Pole 2 - Imaginary Part",
      "type": "number",
      "unit": "Hz",
      "default": 0,
      "businessContext": "Imaginary part of the second pole location in the s-plane.",
      "label_i18n": {
        "en": "Pole 2 - Imaginary Part",
        "tr": "Pole 2 - Imaginary Part",

      }
    },
    {
      "id": "pole2_real",
      "label": "Pole 2 - Real Part",
      "type": "number",
      "unit": "Hz",
      "default": 10,
      "businessContext": "Real part of the second pole location in the s-plane.",
      "label_i18n": {
        "en": "Pole 2 - Real Part",
        "tr": "Pole 2 - Real Part",
        "de": "Pole 2 - Real Part",
        "fr": "Pole 2 - Real Part",

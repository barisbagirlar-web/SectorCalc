{
  "toolName": "flood-routing-calculator",
  "inputs": [
    {
      "id": "inflow_prev",
      "label": "Previous Inflow",
      "type": "number",
      "unit": "m³/s",
      "default": 0,
      "businessContext": "Muskingum routing - upstream inflow at previous time step",
      "label_i18n": {
        "en": "Previous Inflow",
        "tr": "Previous Inflow",
        "de": "Previous Inflow",
        "fr": "Previous Inflow",
        "es": "Previous Inflow",
        "ar": "Previous Inflow"
      }
    },
    {
      "id": "inflow_curr",
      "label": "Current Inflow",
      "type": "number",
      "unit": "m³/s",
      "default": 10,
      "businessContext": "Muskingum routing - upstream inflow at current time step",
      "label_i18n": {
        "en": "Current Inflow",
        "tr": "Current Inflow",
        "de": "Current Inflow",
        "fr": "Current Inflow",
        "es": "Current Inflow",
        "ar": "Current Inflow"
      }
    },
    {
      "id": "outflow_prev",
      "label": "Previous Outflow",
      "type": "number",
      "unit": "m³/s",
      "default": 0,
      "businessContext": "Muskingum routing - downstream outflow at previous time step",
      "label_i18n": {
        "en": "Previous Outflow",
        "tr": "Previous Outflow",
        "de": "Previous Outflow",
        "fr": "Previous Outflow",
        "es": "Previous Outflow",
        "ar": "Previous Outflow"
      }
    },
    {
      "id": "dt",
      "label": "Time Step",
      "type": "number",
      "unit": "hours",
      "default": 1,
      "businessContext": "Routing time step Δt, must be less than K",
      "label_i18n": {
        "en": "Time Step",
        "tr": "Time Step",
        "de": "Time Step",
        "fr": "Time Step",
        "es": "Time Step",
        "ar": "Time Step"
      }
    },
    {
      "id": "K",
      "label": "Storage Constant K",
      "type": "number",
      "unit": "hours",
      "default": 2,
      "businessContext": "Muskingum parameter K, travel time of flood wave through reach",
      "label_i18n": {
        "en": "Storage Constant K",
        "tr": "Storage Constant K",
        "de": "Storage Constant K",
        "fr": "Storage Constant K",
        "es": "Storage Constant K",
        "ar": "Storage Constant K"
      }
    },
    {
      "id": "x",
      "label": "Weighting Factor x",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.2,
      "businessContext": "Muskingum parameter x, 0 ≤ x ≤ 0.5, typical 0.1-0.3 for natural streams",
      "label_i18n": {
        "en": "Weighting Factor x",
        "tr": "Weighting Factor x",
        "de": "Weighting Factor x",
        "fr": "Weighting Factor x",
        "es": "Weighting Factor x",
        "ar": "Weighting Factor x"
      }
    }
  ],
  "formulas": {
    "outflow_current": "((inflow_curr * (dt - 2*K*x) + inflow_prev * (dt + 2*K*x) + outflow_prev * (2*K*(1-x) - dt)) / (2*K*(1-x) + dt))",
    "coeff_C1": "(dt - 2*K*x) / (2*K*(1-x) + dt)",
    "coeff_C2": "(dt + 2*K*x) / (2*K*(1-x) + dt)",
    "coeff_C3": "(2*K*(1-x) - dt) / (2*K*(1-x) + dt)"
  },
  "outputs": {
    "primary": "outflow_current",
    "breakdown": [
      "coeff_C1",
      "coeff_C2",
      "coeff_C3"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "coeff_C3"
  },

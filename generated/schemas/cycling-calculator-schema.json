{
  "toolName": "cycling-calculator",
  "inputs": [
    {
      "id": "wheelDiameter",
      "label": "Tekerlek Çapı",
      "type": "number",
      "unit": "mm",
      "default": 622,
      "businessContext": "ISO 5775'te tanımlı standart jant çapı (ETRTO 622 - 700C)"
    },
    {
      "id": "cadence",
      "label": "Kadans",
      "type": "number",
      "unit": "RPM",
      "default": 90,
      "businessContext": "Pedal çevirme sıklığı (dakikadaki devir sayısı)"
    },
    {
      "id": "chainringTeeth",
      "label": "Ayna Dişli",
      "type": "number",
      "unit": "diş",
      "default": 50,
      "businessContext": "Ön aynakol dişli sayısı"
    },
    {
      "id": "cogTeeth",
      "label": "Rubik Dişli",
      "type": "number",
      "unit": "diş",
      "default": 17,
      "businessContext": "Arka rubik dişli sayısı"
    },
    {
      "id": "timeMinutes",
      "label": "Süre",
      "type": "number",
      "unit": "dk",
      "default": 60,
      "businessContext": "Hesaplama süresi (dakika)"
    }
  ],
  "formulas": {
    "gearRatio": "chainringTeeth / cogTeeth",
    "speed": "(Math.PI * wheelDiameter * cadence * gearRatio * 60) / 1000000",
    "distance": "speed * (timeMinutes / 60)"
  },
  "outputs": {
    "primary": "speed",
    "breakdown": [
      "speed",
      "distance"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

{
  "toolName": "vat-moss-calculator",
  "inputs": [
    {
      "id": "netAmount",
      "label": "Net Amount (€)",
      "type": "number",
      "unit": "€",
      "default": 100,
      "businessContext": "The price of the digital service excluding VAT.",
      "label_i18n": {
        "en": "Net Amount (€)",
        "tr": "Net Amount (€)",
        "de": "Net Amount (€)",
        "fr": "Net Amount (€)",
        "es": "Net Amount (€)",
        "ar": "Net Amount (€)"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "The VAT rate applicable in the consumer's EU member state.",
      "label_i18n": {
        "en": "VAT Rate (%)",
        "tr": "VAT Rate (%)",
        "de": "VAT Rate (%)",
        "fr": "VAT Rate (%)",
        "es": "VAT Rate (%)",
        "ar": "VAT Rate (%)"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of units or services sold.",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Quantity",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Discount percentage applied before VAT calculation.",
      "label_i18n": {
        "en": "Discount (%)",
        "tr": "Discount (%)",
        "de": "Discount (%)",
        "fr": "Discount (%)",
        "es": "Discount (%)",
        "ar": "Discount (%)"
      }
    },
    {
      "id": "additionalCosts",
      "label": "Additional Costs (€)",
      "type": "number",
      "unit": "€",
      "default": 0,
      "businessContext": "Any additional charges (e.g., processing fees) included in the taxable amount.",
      "label_i18n": {
        "en": "Additional Costs (€)",
        "tr": "Additional Costs (€)",
        "de": "Additional Costs (€)",
        "fr": "Additional Costs (€)",
        "es": "Additional Costs (€)",
        "ar": "Additional Costs (€)"
      }
    }
  ],
  "formulas": {
    "taxableAmount": "(netAmount * quantity) * (1 - discountPercent/100) + additionalCosts",
    "vatAmount": "taxableAmount * (vatRate/100)",
    "grossAmount": "taxableAmount + vatAmount"
  },
  "outputs": {
    "primary": "vatAmount",
    "breakdown": [
      "taxableAmount",
      "grossAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "grossAmount",
    "unit": "€"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

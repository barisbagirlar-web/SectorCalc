  "formulas": {
    "materialCost": "maltQuantity * maltCostPerKg + hopsQuantity * (hopsCostPer100g / 100) + yeastCost",
    "energyUsage": "batchVolume * 0.3",
    "energyTotalCost": "energyUsage * energyCost",
    "totalCost": "materialCost + energyTotalCost + overheadCost",
    "costPerLiter": "totalCost / batchVolume"
  },

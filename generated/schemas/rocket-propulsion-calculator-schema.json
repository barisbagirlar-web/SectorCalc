{
  "toolName": "rocket-propulsion-calculator",
  "inputs": [
    {
      "id": "initialMass",
      "label": "Initial Mass",
      "type": "number",
      "unit": "kg",
      "default": 50000,
      "businessContext": "Total initial mass of the rocket including propellant."
    },
    {
      "id": "finalMass",
      "label": "Final Mass",
      "type": "number",
      "unit": "kg",
      "default": 10000,
      "businessContext": "Final mass after propellant burnout (dry mass)."
    },
    {
      "id": "specificImpulse",
      "label": "Specific Impulse (Isp)",
      "type": "number",
      "unit": "s",
      "default": 300,
      "businessContext": "Specific impulse of the rocket engine, a measure of efficiency."
    },
    {
      "id": "gravitationalAcceleration",
      "label": "Gravitational Acceleration",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Standard gravitational acceleration at Earth's surface."
    },
    {
      "id": "massFlowRate",
      "label": "Mass Flow Rate",
      "type": "number",
      "unit": "kg/s",
      "default": 500,
      "businessContext": "Propellant mass flow rate through the engine."
    }
  ],
  "formulas": {
    "propellantMass": "initialMass - finalMass",
    "massRatio": "initialMass / finalMass",
    "exhaustVelocity": "specificImpulse * gravitationalAcceleration",
    "deltaV": "exhaustVelocity * Math.log(massRatio)",
    "thrust": "massFlowRate * exhaustVelocity",
    "burnTime": "propellantMass / massFlowRate"
  },
  "outputs": {
    "primary": "deltaV",
    "breakdown": [
      "exhaustVelocity",
      "massRatio",
      "thrust",
      "burnTime",
      "propellantMass"
    ]
  },
  "category": "Verimlilik & OEE",
  "sector": "Otomotiv & Taşıt",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "process-chemical",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "efficiency"
}

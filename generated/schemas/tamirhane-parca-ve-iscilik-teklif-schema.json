  "formulas": {
    "PartCost": "SUM(Quantity_i * DealerPrice_i)",
    "PartMargin": "PartCost * PartMarkupPct",
    "LaborCost": "FlatRateHours * ShopHourlyRate",
    "SubletCost": "SUM(SubletInvoices)",
    "TotalQuote": "PartCost + PartMargin + LaborCost + SubletCost + ShopSuppliesFee + EnvironmentalFee",
    "EffectiveLaborRate": "(LaborCost + PartMargin) / ActualHours",
    "GrossProfitPct": "(TotalQuote - PartCost - ActualLaborCost) / TotalQuote"
  },

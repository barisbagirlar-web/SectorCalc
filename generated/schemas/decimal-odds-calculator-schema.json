{
  "toolName": "decimal-odds-calculator",
  "inputs": [
    {
      "id": "decimalOdds",
      "label": "Decimal Odds",
      "type": "number",
      "unit": "x",
      "default": 2,
      "businessContext": "Decimal odds represent the total payout per unit stake, including original stake. E.g., 2.0 means double your money.",
      "label_i18n": {
        "en": "Decimal Odds",
        "tr": "Decimal Odds",
        "de": "Decimal Odds",
        "fr": "Decimal Odds",
        "es": "Decimal Odds",
        "ar": "Decimal Odds"
      }
    },
    {
      "id": "stake",
      "label": "Stake Amount",
      "type": "number",
      "unit": "€",
      "default": 100,
      "businessContext": "The amount of money placed as a bet.",
      "label_i18n": {
        "en": "Stake Amount",
        "tr": "Stake Amount",
        "de": "Stake Amount",
        "fr": "Stake Amount",
        "es": "Stake Amount",
        "ar": "Stake Amount"
      }
    },
    {
      "id": "margin",
      "label": "Bookmaker Margin",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Bookmaker's profit margin applied to odds, expressed as a percentage. E.g., 5% margin reduces true probability.",
      "label_i18n": {
        "en": "Bookmaker Margin",
        "tr": "Bookmaker Margin",
        "de": "Bookmaker Margin",
        "fr": "Bookmaker Margin",
        "es": "Bookmaker Margin",
        "ar": "Bookmaker Margin"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate on Winnings",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Applicable tax rate on net winnings (profit), if any. E.g., 10% for 10% tax.",
      "label_i18n": {
        "en": "Tax Rate on Winnings",
        "tr": "Tax Rate on Winnings",
        "de": "Tax Rate on Winnings",
        "fr": "Tax Rate on Winnings",
        "es": "Tax Rate on Winnings",
        "ar": "Tax Rate on Winnings"
      }
    }
  ],
  "formulas": {
    "totalReturn": "stake * decimalOdds",
    "profitBeforeTax": "stake * decimalOdds - stake",
    "profitAfterTax": "(stake * decimalOdds - stake) * (1 - taxRate / 100)",
    "impliedProbability": "1 / decimalOdds",
    "fairDecimalOdds": "1 / ((1 / decimalOdds) / (1 + margin / 100))"
  },
  "outputs": {
    "primary": "totalReturn",
    "breakdown": [
      "profitBeforeTax",
      "profitAfterTax",
      "impliedProbability",
      "fairDecimalOdds"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "fairDecimalOdds",
    "unit": "x"
  },
  "category": "Maliyet & Bütçeleme",

{
  "toolName": "fat-intake-calculator",
  "inputs": [
    {
      "id": "dailyCalories",
      "label": "Daily Calorie Intake",
      "type": "number",
      "unit": "kcal",
      "default": 2000,
      "businessContext": "Typical total daily energy intake as basis for fat calculation",
      "label_i18n": {
        "en": "Daily Calorie Intake",
        "tr": "Daily Calorie Intake",
        "de": "Daily Calorie Intake",
        "fr": "Daily Calorie Intake",
        "es": "Daily Calorie Intake",
        "ar": "Daily Calorie Intake"
      }
    },
    {
      "id": "fatPercentage",
      "label": "Fat Percentage",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Target percentage of daily calories from fat, typically 20–35%",
      "label_i18n": {
        "en": "Fat Percentage",
        "tr": "Fat Percentage",
        "de": "Fat Percentage",
        "fr": "Fat Percentage",
        "es": "Fat Percentage",
        "ar": "Fat Percentage"
      }
    },
    {
      "id": "mealsPerDay",
      "label": "Meals per Day",
      "type": "number",
      "unit": "meals",
      "default": 3,
      "businessContext": "Number of daily meals for per-meal fat distribution",
      "label_i18n": {
        "en": "Meals per Day",
        "tr": "Meals per Day",
        "de": "Meals per Day",
        "fr": "Meals per Day",
        "es": "Meals per Day",
        "ar": "Meals per Day"
      }
    },
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Individual body weight used to normalize fat intake per kilogram",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    }
  ],
  "formulas": {
    "gramsFatPerDay": "dailyCalories * fatPercentage / 100 / 9",
    "caloriesFromFat": "dailyCalories * fatPercentage / 100",
    "gramsFatPerKg": "(dailyCalories * fatPercentage / 100 / 9) / bodyWeight",
    "gramsFatPerMeal": "(dailyCalories * fatPercentage / 100 / 9) / mealsPerDay"
  },
  "outputs": {
    "primary": "gramsFatPerDay",
    "breakdown": [
      "caloriesFromFat",
      "gramsFatPerKg",
      "gramsFatPerMeal"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "gramsFatPerMeal"
  },

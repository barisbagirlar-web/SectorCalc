  "formulas": {
    "SL_Annual": "(Cost - SalvageValue) / UsefulLife",
    "DB_Rate": "2 / UsefulLife",
    "DB_Year_t": "BookValue_(t-1) * DB_Rate",
    "MACRS_Year_t": "Cost * MACRS_Table(AssetClass, Year)",
    "UoP_PerUnit": "(Cost - SalvageValue) / TotalExpectedUnits",
    "TCO": "AcquisitionCost + SUM((OpCost_t + MaintCost_t - Salvage_t) / (1 + DiscountRate)^t)",
    "TaxShield": "Depreciation * TaxRate"

{
  "toolName": "swimming-lap-calculator",
  "inputs": [
    {
      "id": "poolLength",
      "label": "Pool Length",
      "type": "number",
      "unit": "m",
      "default": 25,
      "businessContext": "Length of the swimming pool in meters.",
      "label_i18n": {
        "en": "Pool Length",
        "tr": "Pool Length",
        "de": "Pool Length",
        "fr": "Pool Length",
        "es": "Pool Length",
        "ar": "Pool Length"
      }
    },
    {
      "id": "numLaps",
      "label": "Number of Laps",
      "type": "number",
      "unit": "laps",
      "default": 10,
      "businessContext": "Total number of laps to be swum.",
      "label_i18n": {
        "en": "Number of Laps",
        "tr": "Number of Laps",
        "de": "Number of Laps",
        "fr": "Number of Laps",
        "es": "Number of Laps",
        "ar": "Number of Laps"
      }
    },
    {
      "id": "pacePer100m",
      "label": "Pace per 100m",
      "type": "number",
      "unit": "s",
      "default": 120,
      "businessContext": "Swimmer's pace in seconds per 100 meters.",
      "label_i18n": {
        "en": "Pace per 100m",
        "tr": "Pace per 100m",
        "de": "Pace per 100m",
        "fr": "Pace per 100m",
        "es": "Pace per 100m",
        "ar": "Pace per 100m"
      }
    },
    {
      "id": "restBetweenLaps",
      "label": "Rest Between Laps",
      "type": "number",
      "unit": "s",
      "default": 15,
      "businessContext": "Rest time in seconds taken after each lap (except the last).",
      "label_i18n": {
        "en": "Rest Between Laps",
        "tr": "Rest Between Laps",
        "de": "Rest Between Laps",
        "fr": "Rest Between Laps",
        "es": "Rest Between Laps",
        "ar": "Rest Between Laps"
      }
    }
  ],
  "formulas": {
    "totalDistance": "poolLength * numLaps",
    "totalSwimTime": "(pacePer100m / 100) * poolLength * numLaps",
    "totalRestTime": "(numLaps - 1) * restBetweenLaps",
    "effectivePacePer100m": "((pacePer100m / 100) * poolLength * numLaps + (numLaps - 1) * restBetweenLaps) * 100 / (poolLength * numLaps)",
    "totalTime": "(pacePer100m / 100) * poolLength * numLaps + (numLaps - 1) * restBetweenLaps"
  },
  "outputs": {
    "primary": "totalTime",
    "breakdown": [
      "totalDistance",
      "totalSwimTime",
      "totalRestTime",
      "effectivePacePer100m"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTime"
  },
  "category": "Diğer",
  "sector": "Fitness & Spor",

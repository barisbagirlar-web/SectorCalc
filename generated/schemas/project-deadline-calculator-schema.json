      }
    },
    {
      "id": "contingencyPercent",
      "label": "Yedek Süre Oranı",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Öngörülemeyen gecikmeler için ayrılan tampon süre yüzdesi",
      "label_i18n": {
        "en": "Yedek Süre Oranı",
        "tr": "Yedek Süre Oranı",

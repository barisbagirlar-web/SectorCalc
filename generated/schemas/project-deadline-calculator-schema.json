        "fr": "Yedek Süre Oranı",
        "es": "Yedek Süre Oranı",
        "ar": "Yedek Süre Oranı"
      }
    }
  ],
  "formulas": {
    "baseDays": "(totalTasks / (tasksPerDay * teamSize)) * complexityFactor",
    "totalDays": "baseDays * (1 + contingencyPercent / 100)",
    "contingencyDays": "totalDays - baseDays"
  },
  "outputs": {
    "primary": "totalDays",
    "breakdown": [
      "baseDays",
      "contingencyDays"

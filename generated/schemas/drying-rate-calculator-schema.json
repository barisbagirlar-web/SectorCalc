{
  "toolName": "drying-rate-calculator",
  "inputs": [
    {
      "id": "initial_moisture",
      "label": "Initial Moisture Content",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Wet basis moisture content of the material before drying",
      "label_i18n": {
        "en": "Initial Moisture Content",
        "tr": "Başlangıç Nem İçeriği",
        "de": "Initial Moisture Content",
        "fr": "Initial Moisture Content",
        "es": "Initial Moisture Content",
        "ar": "Initial Moisture Content"
      },
      "businessContext_i18n": {
        "en": "Wet basis moisture content of the material before drying",
        "tr": "Kurutma öncesi malzemenin yaş bazda nem içeriği"
      }
    },
    {
      "id": "final_moisture",
      "label": "Final Moisture Content",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Target moisture content after drying (wet basis)",
      "label_i18n": {
        "en": "Final Moisture Content",
        "tr": "Son Nem İçeriği",
        "de": "Final Moisture Content",
        "fr": "Final Moisture Content",
        "es": "Final Moisture Content",
        "ar": "Final Moisture Content"
      },
      "businessContext_i18n": {
        "en": "Target moisture content after drying (wet basis)",
        "tr": "Kurutma sonrası hedef nem içeriği (yaş baz)"
      }
    },
    {
      "id": "solid_mass",
      "label": "Wet Material Mass",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Total mass of wet material to be dried",
      "label_i18n": {
        "en": "Wet Material Mass",
        "tr": "Islak Malzeme Kütlesi",
        "de": "Wet Material Mass",
        "fr": "Wet Material Mass",
        "es": "Wet Material Mass",
        "ar": "Wet Material Mass"
      },
      "businessContext_i18n": {
        "en": "Total mass of wet material to be dried",
        "tr": "Kurutulacak ıslak malzemenin toplam kütlesi"
      }
    },
    {
      "id": "drying_rate",
      "label": "Drying Rate",
      "type": "number",
      "unit": "kg/h",
      "default": 50,
      "businessContext": "Moisture removal capacity of the dryer",
      "label_i18n": {
        "en": "Drying Rate",
        "tr": "Kurutma Hızı",
        "de": "Drying Rate",
        "fr": "Drying Rate",
        "es": "Drying Rate",
        "ar": "Drying Rate"
      },
      "businessContext_i18n": {
        "en": "Moisture removal capacity of the dryer",
        "tr": "Kurutucunun nem giderme kapasitesi"
      }
    },
    {
      "id": "specific_energy",
      "label": "Specific Energy Consumption",
      "type": "number",
      "unit": "kWh/kg",
      "default": 1.2,
      "businessContext": "Energy required to evaporate 1 kg of water",
      "label_i18n": {
        "en": "Specific Energy Consumption",
        "tr": "Özgül Enerji Tüketimi",
        "de": "Specific Energy Consumption",
        "fr": "Specific Energy Consumption",
        "es": "Specific Energy Consumption",
        "ar": "Specific Energy Consumption"
      },
      "businessContext_i18n": {
        "en": "Energy required to evaporate 1 kg of water",
        "tr": "1 kg suyu buharlaştırmak için gereken enerji"
      }
    }
  ],
  "formulas": {
    "water_removed_kg": "solid_mass * (initial_moisture - final_moisture) / 100",
    "drying_time_h": "water_removed_kg / drying_rate",
    "energy_consumption_kWh": "water_removed_kg * specific_energy"
  },
  "outputs": {
    "primary": "water_removed_kg",
    "breakdown": [
      "drying_time_h",
      "energy_consumption_kWh"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "energy_consumption_kWh",
    "unit": "kg",
    "breakdownUnits": {
      "drying_time_h": "h",
      "energy_consumption_kWh": "kWh"
    }
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,

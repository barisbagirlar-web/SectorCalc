      "type": "number",
      "unit": "adet/saat",
      "default": 10,
      "businessContext": "Referans olarak kabul edilen saatlik üretim miktarı",
      "label_i18n": {
        "en": "Standart Verimlilik",
        "tr": "Standart Verimlilik",

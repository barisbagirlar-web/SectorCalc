{
  "toolName": "productivity-calculator",
  "inputs": [
    {
      "id": "total_units_produced",
      "label": "Toplam Üretilen Birim",
      "type": "number",
      "unit": "adet",
      "default": 1000,
      "businessContext": "Üretim hattından çıkan toplam ürün miktarı"
    },
    {
      "id": "total_labor_hours",
      "label": "Toplam İşçilik Saati",
      "type": "number",
      "unit": "saat",
      "default": 100,
      "businessContext": "Üretim için harcanan toplam insan gücü süresi"
    },
    {
      "id": "defect_rate",
      "label": "Hata Oranı",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Üretilen ürünler içindeki hatalı oranı"
    },
    {
      "id": "standard_productivity",
      "label": "Standart Verimlilik",
      "type": "number",
      "unit": "adet/saat",
      "default": 10,
      "businessContext": "Referans olarak kabul edilen saatlik üretim miktarı"
    }
  ],
  "formulas": {
    "good_units": "total_units_produced * (1 - defect_rate / 100)",
    "effective_productivity": "(total_units_produced * (1 - defect_rate / 100)) / total_labor_hours",
    "efficiency": "((total_units_produced * (1 - defect_rate / 100)) / total_labor_hours / standard_productivity) * 100"
  },
  "outputs": {
    "primary": "effective_productivity",
    "breakdown": [
      "good_units",
      "efficiency"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

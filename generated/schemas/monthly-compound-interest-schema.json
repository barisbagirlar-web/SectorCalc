{
  "toolName": "monthly-compound-interest",
  "inputs": [
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "businessContext": "Initial investment or loan amount"
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual nominal interest rate"
    },
    {
      "id": "years",
      "label": "Time Period",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "Number of years money is invested or borrowed"
    },
    {
      "id": "compoundingsPerYear",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "times/year",
      "default": 12,
      "businessContext": "Number of times interest is compounded per year (monthly = 12)"
    }
  ],
  "formulas": {
    "finalAmount": "principal * Math.pow(1 + annualRate/100/compoundingsPerYear, compoundingsPerYear*years)",
    "interestEarned": "finalAmount - principal"
  },
  "outputs": {
    "primary": "finalAmount",
    "breakdown": [
      "interestEarned"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

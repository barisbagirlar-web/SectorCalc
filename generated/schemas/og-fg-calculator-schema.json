{
  "toolName": "og-fg-calculator",
  "inputs": [
    {
      "id": "ogReading",
      "label": "OG Reading",
      "type": "number",
      "unit": "gravity",
      "default": 1.05,
      "businessContext": "Original gravity reading from hydrometer (unadjusted for temperature)"
    },
    {
      "id": "fgReading",
      "label": "FG Reading",
      "type": "number",
      "unit": "gravity",
      "default": 1.01,
      "businessContext": "Final gravity reading from hydrometer (unadjusted for temperature)"
    },
    {
      "id": "ogTemp",
      "label": "Temperature at OG Reading",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature of the liquid when OG reading was taken"
    },
    {
      "id": "fgTemp",
      "label": "Temperature at FG Reading",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature of the liquid when FG reading was taken"
    },
    {
      "id": "calibTemp",
      "label": "Hydrometer Calibration Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature at which the hydrometer is calibrated (usually 20°C)"
    }
  ],
  "formulas": {
    "correctedOg": "ogReading * (1.00130346 - 0.000134722124 * ogTemp + 0.00000204052596 * ogTemp**2 - 0.00000000232820948 * ogTemp**3) / (1.00130346 - 0.000134722124 * calibTemp + 0.00000204052596 * calibTemp**2 - 0.00000000232820948 * calibTemp**3)",
    "correctedFg": "fgReading * (1.00130346 - 0.000134722124 * fgTemp + 0.00000204052596 * fgTemp**2 - 0.00000000232820948 * fgTemp**3) / (1.00130346 - 0.000134722124 * calibTemp + 0.00000204052596 * calibTemp**2 - 0.00000000232820948 * calibTemp**3)",
    "abv": "(correctedOg - correctedFg) * 131.25"
  },
  "outputs": {
    "primary": "correctedOg",
    "breakdown": [
      "correctedOg",
      "correctedFg",
      "abv"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

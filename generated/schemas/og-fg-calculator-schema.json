  "formulas": {
    "correctedOg": "ogReading * (1.00130346 - 0.000134722124 * ogTemp + 0.00000204052596 * ogTemp**2 - 0.00000000232820948 * ogTemp**3) / (1.00130346 - 0.000134722124 * calibTemp + 0.00000204052596 * calibTemp**2 - 0.00000000232820948 * calibTemp**3)",
    "correctedFg": "fgReading * (1.00130346 - 0.000134722124 * fgTemp + 0.00000204052596 * fgTemp**2 - 0.00000000232820948 * fgTemp**3) / (1.00130346 - 0.000134722124 * calibTemp + 0.00000204052596 * calibTemp**2 - 0.00000000232820948 * calibTemp**3)",
    "abv": "(correctedOg - correctedFg) * 131.25"
  },
  "outputs": {
    "primary": "correctedOg",
    "breakdown": [
      "correctedOg",
      "correctedFg",
      "abv"
    ],

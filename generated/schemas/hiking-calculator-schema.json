      }
    },
    {
      "id": "backpackWeight",
      "label": "Çanta Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Sırt çantasının ağırlığı",
      "label_i18n": {
        "en": "Bag weight",
        "tr": "Çanta Ağırlığı",
        "de": "Rucksackgewicht",
        "fr": "Poids du sac",
        "es": "Peso de la mochila",
        "ar": "وزن الحقيبة"
      },
      "businessContext_i18n": {
        "en": "Backpack weight",
        "tr": "Sırt çantasının ağırlığı",
        "de": "Gewicht des Rucksacks",
        "fr": "Poids du sac à dos",
        "es": "Peso de la mochila",
        "ar": "وزن حقيبة الظهر"
      }
    }
  ],
  "formulas": {
    "adjustedSpeed": "averageSpeed * (1 - 0.005 * backpackWeight)",
    "baseTime": "distance / adjustedSpeed",
    "ascentTime": "elevationGain / 600",
    "totalTime": "baseTime + ascentTime"
  },
  "outputs": {
    "primary": "adjustedSpeed",
    "breakdown": [
      {
        "id": "baseTime",
        "label": "Düz Yürüyüş Süresi",
        "unit": "saat",
        "formula": "baseTime"
      },
      {
        "id": "ascentTime",
        "label": "Tırmanış Süresi",
        "unit": "saat",
        "formula": "ascentTime"
      }
    ],

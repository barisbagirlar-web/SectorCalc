{
  "toolName": "hiking-calculator",
  "inputs": [
    {
      "id": "distance",
      "label": "Mesafe",
      "type": "number",
      "unit": "km",
      "default": 10,
      "businessContext": "Planlanan yürüyüş mesafesi",
      "label_i18n": {
        "en": "Mesafe",
        "tr": "Mesafe",
        "de": "Mesafe",
        "fr": "Mesafe",
        "es": "Mesafe",
        "ar": "Mesafe"
      }
    },
    {
      "id": "elevationGain",
      "label": "İrtifa Kazancı",
      "type": "number",
      "unit": "m",
      "default": 500,
      "businessContext": "Toplam tırmanılan yükseklik",
      "label_i18n": {
        "en": "İrtifa Kazancı",
        "tr": "İrtifa Kazancı",
        "de": "İrtifa Kazancı",
        "fr": "İrtifa Kazancı",
        "es": "İrtifa Kazancı",
        "ar": "İrtifa Kazancı"
      }
    },
    {
      "id": "averageSpeed",
      "label": "Ortalama Hız",
      "type": "number",
      "unit": "km/h",
      "default": 5,
      "businessContext": "Düz zeminde yürüyüş hızı",
      "label_i18n": {
        "en": "Ortalama Hız",
        "tr": "Ortalama Hız",
        "de": "Ortalama Hız",
        "fr": "Ortalama Hız",
        "es": "Ortalama Hız",
        "ar": "Ortalama Hız"
      }
    },
    {
      "id": "backpackWeight",
      "label": "Çanta Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Sırt çantasının ağırlığı",
      "label_i18n": {
        "en": "Çanta Ağırlığı",
        "tr": "Çanta Ağırlığı",
        "de": "Çanta Ağırlığı",
        "fr": "Çanta Ağırlığı",
        "es": "Çanta Ağırlığı",
        "ar": "Çanta Ağırlığı"
      }
    }
  ],
  "formulas": {
    "adjustedSpeed": "averageSpeed * (1 - 0.005 * backpackWeight)",
    "baseTime": "distance / adjustedSpeed",
    "ascentTime": "elevationGain / 600",
    "totalTime": "baseTime + ascentTime"
  },
  "outputs": {
    "primary": "adjustedSpeed",
    "breakdown": [
      {
        "id": "baseTime",
        "label": "Düz Yürüyüş Süresi",
        "unit": "saat",
        "formula": "baseTime"
      },
      {
        "id": "ascentTime",
        "label": "Tırmanış Süresi",
        "unit": "saat",
        "formula": "ascentTime"
      }
    ],
    "hiddenLossDrivers": [],

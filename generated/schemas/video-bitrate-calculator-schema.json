    {
      "id": "compressionRatio",
      "label": "Compression Ratio",
      "type": "number",
      "unit": "unit",
      "default": 0.1,
      "businessContext": "Typical values: 0.1 for H.264, 0.05 for H.265. Determines the compression factor applied to the uncompressed bitrate.",
      "label_i18n": {
        "en": "Compression Ratio",

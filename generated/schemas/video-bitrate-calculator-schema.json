    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "s",
      "default": 60,
      "businessContext": "Length of the video in seconds, used to calculate total file size",
      "label_i18n": {
        "en": "Duration",
        "tr": "Duration",
        "de": "Duration",
        "fr": "Duration",
        "es": "Duration",
        "ar": "Duration"
      }
    }
  ],
  "formulas": {
    "uncompressedBitrateBps": "width * height * frameRate * colorDepth",
    "uncompressedBitrateMbps": "uncompressedBitrateBps / 1000000",
    "compressedBitrateBps": "uncompressedBitrateBps * compressionRatio",
    "compressedBitrateMbps": "compressedBitrateBps / 1000000",
    "fileSizeMB": "compressedBitrateBps * duration / (8 * 1048576)",
    "fileSizeGB": "fileSizeMB / 1024"
  },
  "outputs": {
    "primary": "uncompressedBitrateBps",
    "breakdown": [

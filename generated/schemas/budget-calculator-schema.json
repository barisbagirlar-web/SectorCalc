      "id": "utilities",
      "label": "Faturalar",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "businessContext": "Elektrik, su, doğalgaz, internet vb. faturalar"
    },
    {
      "id": "grocery",
      "label": "Mutfak Masrafları",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "businessContext": "Aylık gıda ve market harcamaları"
    },
    {
      "id": "transportation",
      "label": "Ulaşım",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "businessContext": "Yakıt, toplu taşıma, araç bakım vb. ulaşım giderleri"
    },
    {
      "id": "savings",
      "label": "Tasarruf",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "businessContext": "Aylık düzenli tasarruf miktarı"
    },
    {

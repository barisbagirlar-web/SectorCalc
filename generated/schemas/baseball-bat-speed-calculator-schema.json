{
  "toolName": "baseball-bat-speed-calculator",
  "inputs": [
    {
      "id": "angularVelocity",
      "label": "Angular Velocity",
      "type": "number",
      "unit": "deg/s",
      "default": 1000,
      "businessContext": "Measured swing rotational speed (high-speed camera), typical range 800–1200 deg/s.",
      "label_i18n": {
        "en": "Angular Velocity",
        "tr": "Angular Velocity",
        "de": "Angular Velocity",
        "fr": "Angular Velocity",
        "es": "Angular Velocity",
        "ar": "Angular Velocity"
      }
    },
    {
      "id": "batLength",
      "label": "Bat Length",
      "type": "number",
      "unit": "cm",
      "default": 84,
      "businessContext": "Total bat length from knob to barrel end, standard 84 cm (33 inches).",
      "label_i18n": {
        "en": "Bat Length",
        "tr": "Bat Length",
        "de": "Bat Length",
        "fr": "Bat Length",
        "es": "Bat Length",
        "ar": "Bat Length"
      }
    },
    {
      "id": "pivotDistance",
      "label": "Pivot Point Distance",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Distance from the knob end to the effective axis of rotation (hands), typically 10 cm.",
      "label_i18n": {
        "en": "Pivot Point Distance",
        "tr": "Pivot Point Distance",
        "de": "Pivot Point Distance",
        "fr": "Pivot Point Distance",
        "es": "Pivot Point Distance",
        "ar": "Pivot Point Distance"
      }
    },
    {
      "id": "sweetSpotOffset",
      "label": "Sweet Spot Offset",
      "type": "number",
      "unit": "cm",
      "default": 15,
      "businessContext": "Distance from the barrel end to the sweet spot, commonly 15 cm.",
      "label_i18n": {
        "en": "Sweet Spot Offset",
        "tr": "Sweet Spot Offset",
        "de": "Sweet Spot Offset",
        "fr": "Sweet Spot Offset",
        "es": "Sweet Spot Offset",
        "ar": "Sweet Spot Offset"
      }
    },
    {
      "id": "batMass",
      "label": "Bat Mass",
      "type": "number",
      "unit": "g",
      "default": 900,
      "businessContext": "Mass of the bat in grams, typical wood bat mass ≈ 900 g.",
      "label_i18n": {
        "en": "Bat Mass",
        "tr": "Bat Mass",
        "de": "Bat Mass",
        "fr": "Bat Mass",
        "es": "Bat Mass",
        "ar": "Bat Mass"
      }
    }
  ],
  "formulas": {
    "angularVelocityRadPerS": "angularVelocity * Math.PI / 180",
    "effectiveRadiusM": "(batLength - sweetSpotOffset - pivotDistance) / 100",
    "batSpeed": "angularVelocity * Math.PI / 180 * (batLength - sweetSpotOffset - pivotDistance) / 100",
    "kineticEnergy": "0.5 * (batMass / 1000) * Math.pow(angularVelocity * Math.PI / 180 * (batLength - sweetSpotOffset - pivotDistance) / 100, 2)"
  },
  "outputs": {
    "primary": "batSpeed",
    "breakdown": [
      "angularVelocityRadPerS",
      "effectiveRadiusM",
      "kineticEnergy"
    ]
  },

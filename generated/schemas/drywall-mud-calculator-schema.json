{
  "toolName": "drywall-mud-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Drywall Area",
      "type": "number",
      "unit": "sq ft",
      "default": 500,
      "businessContext": "Total square footage of drywall to be finished",
      "label_i18n": {
        "en": "Drywall Area",
        "tr": "Drywall Area",
        "de": "Drywall Area",
        "fr": "Drywall Area",
        "es": "Drywall Area",
        "ar": "Drywall Area"
      }
    },
    {
      "id": "coats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of coats of joint compound applied (e.g., tape, fill, finish)",
      "label_i18n": {
        "en": "Number of Coats",
        "tr": "Number of Coats",
        "de": "Number of Coats",
        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    },
    {
      "id": "coverage",
      "label": "Coverage Rate",
      "type": "number",
      "unit": "sq ft per gallon",
      "default": 150,
      "businessContext": "Estimated coverage per gallon of ready-mix joint compound",
      "label_i18n": {
        "en": "Coverage Rate",
        "tr": "Coverage Rate",
        "de": "Coverage Rate",
        "fr": "Coverage Rate",
        "es": "Coverage Rate",
        "ar": "Coverage Rate"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional percentage to account for spillage, over-application, and joint waste",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "totalMudGallons": "area * coats / coverage * (1 + wasteFactor / 100)",
    "buckets": "Math.ceil(area * coats / coverage * (1 + wasteFactor / 100) / 4.5)"
  },
  "outputs": {
    "primary": "totalMudGallons",
    "breakdown": [
      "buckets"
    ]
  },
  "category": "Çevre & Emisyon",
  "sector": "Sürdürülebilirlik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "sustainability-resource-esg"
}

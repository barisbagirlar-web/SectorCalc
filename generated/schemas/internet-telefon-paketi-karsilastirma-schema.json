{
  "toolName": "internet-telefon-paketi-karsilastirma",
  "inputs": [
    {
      "id": "paketAdi",
      "label": "Paket Adı",
      "type": "select",
      "unit": "",
      "default": "Paket A",
      "min": null,
      "max": null,
      "options": [
        "Paket A",
        "Paket B",
        "Paket C"
      ],
      "businessContext": "Karşılaştırılacak internet-telefon paketlerinin adı. Kullanıcı tarafından tanımlanır."
    },
    {
      "id": "aylikUcret",
      "label": "Aylık Ücret",
      "type": "number",
      "unit": "TL/ay",
      "default": 100,
      "min": 0,
      "max": 10000,
      "businessContext": "Paketin aylık sabit ücreti. Fatura bazlı."
    },
    {
      "id": "internetHizi",
      "label": "İnternet Hızı (Mbps)",
      "type": "number",
      "unit": "Mbps",
      "default": 100,
      "min": 1,
      "max": 10000,
      "businessContext": "İndirme hızı. Mbps cinsinden."
    },
    {
      "id": "internetKotasi",
      "label": "İnternet Kotası (GB)",
      "type": "number",
      "unit": "GB",
      "default": 100,
      "min": 0,
      "max": 10000,
      "businessContext": "Aylık internet kullanım kotası. 0 sınırsız anlamına gelir."
    },
    {
      "id": "telefonDakikasi",
      "label": "Telefon Dakikası (dk/ay)",
      "type": "number",
      "unit": "dk/ay",
      "default": 500,
      "min": 0,
      "max": 100000,
      "businessContext": "Pakete dahil aylık konuşma dakikası."
    },
    {
      "id": "ekstraInternetUcreti",
      "label": "Ekstra İnternet Ücreti (TL/GB)",
      "type": "number",
      "unit": "TL/GB",
      "default": 10,
      "min": 0,
      "max": 1000,
      "businessContext": "Kota aşımı durumunda GB başına ek ücret."
    },
    {
      "id": "ekstraTelefonUcreti",
      "label": "Ekstra Telefon Ücreti (TL/dk)",
      "type": "number",
      "unit": "TL/dk",
      "default": 0.5,
      "min": 0,
      "max": 100,
      "businessContext": "Dakika aşımı durumunda dk başına ek ücret."
    },
    {
      "id": "tahminiInternetKullanim",
      "label": "Tahmini İnternet Kullanımı (GB/ay)",
      "type": "number",
      "unit": "GB/ay",
      "default": 80,
      "min": 0,
      "max": 10000,
      "businessContext": "Kullanıcının aylık ortalama internet tüketimi."
    },
    {
      "id": "tahminiTelefonKullanim",
      "label": "Tahmini Telefon Kullanımı (dk/ay)",
      "type": "number",
      "unit": "dk/ay",
      "default": 400,
      "min": 0,
      "max": 100000,
      "businessContext": "Kullanıcının aylık ortalama konuşma süresi."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "number",
      "unit": "",
      "default": 1,
      "min": 0,
      "max": 1,
      "businessContext": "Kullanıcının tahmini kullanım verilerine güven düzeyi (0-1). 1 tam güven."
    }
  ],
  "validation": {
    "rules": [
      "aylikUcret >= 0",
      "internetHizi > 0",
      "internetKotasi >= 0",
      "telefonDakikasi >= 0",
      "ekstraInternetUcreti >= 0",
      "ekstraTelefonUcreti >= 0",
      "tahminiInternetKullanim >= 0",
      "tahminiTelefonKullanim >= 0",
      "dataConfidence >= 0 and dataConfidence <= 1"
    ],
    "thresholds": {
      "tahminiInternetKullanim > internetKotasi && internetKotasi > 0": "Uyarı: Tahmini kullanım kotayı aşıyor, ek ücret oluşabilir.",
      "tahminiTelefonKullanim > telefonDakikasi": "Uyarı: Tahmini konuşma süresi paket dakikasını aşıyor, ek ücret oluşabilir."
    }
  },
  "formulas": {
    "ekstraInternet": "max(0, tahminiInternetKullanim - internetKotasi) * ekstraInternetUcreti",
    "ekstraTelefon": "max(0, tahminiTelefonKullanim - telefonDakikasi) * ekstraTelefonUcreti",
    "toplamMaliyet": "aylikUcret + ekstraInternet + ekstraTelefon",
    "birimMaliyet": "toplamMaliyet / (tahminiInternetKullanim + tahminiTelefonKullanim / 60)",
    "dataConfidenceAdjusted": "toplamMaliyet * (1 + (1 - dataConfidence) * 0.1)"
  },
  "outputs": {
    "primary": "toplamMaliyet",
    "breakdown": {
      "aylikUcret": "aylikUcret",
      "ekstraInternet": "ekstraInternet",
      "ekstraTelefon": "ekstraTelefon"
    },
    "hiddenLossDrivers": [
      "ekstraInternet > 0 ? 'Kota aşımı nedeniyle ek internet ücreti' : ''",
      "ekstraTelefon > 0 ? 'Dakika aşımı nedeniyle ek telefon ücreti' : ''"
    ],
    "suggestedActions": [
      "ekstraInternet > 0 ? 'Daha yüksek kotalı bir paket düşünün.' : ''",
      "ekstraTelefon > 0 ? 'Daha fazla dakika içeren bir paket düşünün.' : ''",
      "toplamMaliyet > 200 ? 'Maliyeti azaltmak için alternatif paketleri değerlendirin.' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

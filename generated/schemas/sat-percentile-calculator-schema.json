{
  "toolName": "sat-percentile-calculator",
  "inputs": [
    {
      "id": "mathScore",
      "label": "Math Score",
      "type": "number",
      "unit": "points",
      "default": 530,
      "businessContext": "SAT Math section score (200-800)."
    },
    {
      "id": "readingWritingScore",
      "label": "Evidence-Based Reading and Writing Score",
      "type": "number",
      "unit": "points",
      "default": 530,
      "businessContext": "SAT Evidence-Based Reading and Writing section score (200-800)."
    },
    {
      "id": "meanTotal",
      "label": "Mean Total Score",
      "type": "number",
      "unit": "points",
      "default": 1060,
      "businessContext": "Mean of total SAT score for the population."
    },
    {
      "id": "stdDev",
      "label": "Standard Deviation",
      "type": "number",
      "unit": "points",
      "default": 210,
      "businessContext": "Standard deviation of total SAT score."
    }
  ],
  "formulas": {
    "totalScore": "mathScore + readingWritingScore",
    "zScore": "(totalScore - meanTotal) / ((Math.sqrt(3) * stdDev) / 3.1415926535)",
    "percentile": "100 / (1 + Math.exp(-zScore))"
  },
  "outputs": {
    "primary": "percentile",
    "breakdown": [
      "totalScore",
      "zScore"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "education-academic",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma"
}

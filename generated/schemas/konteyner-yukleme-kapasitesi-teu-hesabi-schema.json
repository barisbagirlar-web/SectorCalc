{
  "toolName": "konteyner-yukleme-kapasitesi-teu-hesabi",
  "inputs": [
    {
      "id": "containerLength",
      "label": "Konteyner İç Uzunluğu",
      "type": "number",
      "unit": "m",
      "default": 12.032,
      "min": 0,
      "max": 20,
      "options": null,
      "businessContext": "ISO 668 standardına göre 20 ft konteyner iç uzunluğu 5.898 m, 40 ft konteyner iç uzunluğu 12.032 m'dir. Kullanıcı kendi konteyner ölçüsünü girebilir."
    },
    {
      "id": "containerWidth",
      "label": "Konteyner İç Genişliği",
      "type": "number",
      "unit": "m",
      "default": 2.352,
      "min": 0,
      "max": 3,
      "options": null,
      "businessContext": "ISO 668 standardına göre standart konteyner iç genişliği 2.352 m'dir."
    },
    {
      "id": "containerHeight",
      "label": "Konteyner İç Yüksekliği",
      "type": "number",
      "unit": "m",
      "default": 2.393,
      "min": 0,
      "max": 3,
      "options": null,
      "businessContext": "ISO 668 standardına göre standart konteyner iç yüksekliği 2.393 m'dir."
    },
    {
      "id": "cargoLength",
      "label": "Kargo Birim Uzunluğu",
      "type": "number",
      "unit": "m",
      "default": 1.2,
      "min": 0.01,
      "max": 12,
      "options": null,
      "businessContext": "Yüklenecek kargonun birim uzunluğu. Palet veya koli boyutu."
    },
    {
      "id": "cargoWidth",
      "label": "Kargo Birim Genişliği",
      "type": "number",
      "unit": "m",
      "default": 0.8,
      "min": 0.01,
      "max": 2.4,
      "options": null,
      "businessContext": "Yüklenecek kargonun birim genişliği."
    },
    {
      "id": "cargoHeight",
      "label": "Kargo Birim Yüksekliği",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0.01,
      "max": 2.4,
      "options": null,
      "businessContext": "Yüklenecek kargonun birim yüksekliği."
    },
    {
      "id": "stackingFactor",
      "label": "İstifleme Faktörü",
      "type": "number",
      "unit": "",
      "default": 0.9,
      "min": 0.5,
      "max": 1,
      "options": null,
      "businessContext": "Kargonun istiflenebilirliğini ve boşluk kaybını temsil eden faktör. Genellikle 0.8-0.95 arası. Endüstriyel deneyimlere dayanır."
    },
    {
      "id": "containerType",
      "label": "Konteyner Tipi",
      "type": "select",
      "unit": "",
      "default": "standard",
      "min": null,
      "max": null,
      "options": [
        "standard",
        "highCube",
        "openTop",
        "flatRack"
      ],
      "businessContext": "ISO 668 konteyner tipleri. HighCube: yükseklik 2.896 m, OpenTop: üstü açık, FlatRack: yanları açık."
    }
  ],
  "validation": {
    "rules": [
      "cargoLength <= containerLength",
      "cargoWidth <= containerWidth",
      "cargoHeight <= containerHeight",
      "stackingFactor between 0.5 and 1",
      "if containerType == 'highCube' then containerHeight = 2.896"
    ],
    "thresholds": {
      "stackingFactor < 0.7": "Düşük istifleme faktörü, kapasite kaybı yüksek",
      "cargoHeight > containerHeight * 0.9": "Kargo yüksekliği konteyner yüksekliğine yakın, dikkatli yükleme gerekli"
    }
  },
  "formulas": {
    "maxUnitsLength": "Math.floor(containerLength / cargoLength)",
    "maxUnitsWidth": "Math.floor(containerWidth / cargoWidth)",
    "maxUnitsHeight": "Math.floor(containerHeight / cargoHeight)",
    "maxUnitsPerContainer": "maxUnitsLength * maxUnitsWidth * maxUnitsHeight * stackingFactor",
    "totalTEU": "maxUnitsPerContainer / 1"
  },
  "outputs": {
    "primary": "maxUnitsPerContainer",
    "breakdown": {
      "maxUnitsLength": "maxUnitsLength",
      "maxUnitsWidth": "maxUnitsWidth",
      "maxUnitsHeight": "maxUnitsHeight",
      "containerVolume": "containerLength * containerWidth * containerHeight",
      "cargoVolume": "cargoLength * cargoWidth * cargoHeight",
      "volumeUtilization": "(maxUnitsPerContainer * cargoVolume) / containerVolume"
    },
    "hiddenLossDrivers": [
      "stackingFactor < 0.7 ? 'Düşük istifleme faktörü' : ''",
      "cargoHeight > containerHeight * 0.9 ? 'Kargo yüksekliği kritik' : ''"
    ],
    "suggestedActions": [
      "stackingFactor < 0.8 ? 'İstifleme düzenini iyileştirin' : ''",
      "volumeUtilization < 0.6 ? 'Kargo boyutlarını optimize edin' : ''"
    ],
    "dataConfidenceAdjusted": "maxUnitsPerContainer * (dataConfidence || 1)"
  },
  "premiumFeatures": [
    "PDF raporu",
    "CSV export",
    "Trend analizi",
    "Karşılaştırma (farklı konteyner tipleri)",
    "Detaylı hacim kullanım raporu"
  ],
  "premiumRequired": true
}

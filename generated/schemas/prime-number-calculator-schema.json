  "formulas": {
    "estimatedPrimes": "(upperBound / Math.log(upperBound)) - (lowerBound / Math.log(lowerBound))",
    "errorMargin": "(tolerance / 100) * ((upperBound / Math.log(upperBound)) - (lowerBound / Math.log(lowerBound)))",
    "estimatedPrimes____upperBound___Math_log": "estimatedPrimes = (upperBound / Math.log(upperBound)) - (lowerBound / Math.log(lowerBound))",
    "errorMargin___tolerance__of_the_estimate": "errorMargin = tolerance% of the estimate, i.e., (tolerance / 100) * estimatedPrimes"
  },
  "outputs": {

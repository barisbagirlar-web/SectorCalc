        "ar": "Yaş"
      }
    },
    {
      "id": "weight",
      "label": "Kilo",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Kullanıcının vücut ağırlığı (kilogram)",
      "label_i18n": {
        "en": "Kilo",
        "tr": "Kilo",
        "de": "Kilo",
        "fr": "Kilo",
        "es": "Kilo",
        "ar": "Kilo"
      }
    },
    {
      "id": "height",
      "label": "Boy",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Kullanıcının boyu (santimetre)",
      "label_i18n": {
        "en": "Boy",
        "tr": "Boy",
        "de": "Boy",
        "fr": "Boy",
        "es": "Boy",
        "ar": "Boy"
      }
    }
  ],
  "formulas": {
    "tbwMale": "2.447 - (0.09156 * age) + (0.1074 * height) + (0.3362 * weight)",
    "tbwFemale": "-2.097 + (0.1069 * height) + (0.2466 * weight)",
    "totalBodyWater": "sex === 1 ? tbwMale : tbwFemale",
    "waterPercentage": "((sex === 1 ? tbwMale : tbwFemale) / weight) * 100",
    "___waterPercentage_toFixed_2__": "%${waterPercentage.toFixed(2)}",
    "result": "toplam vücut suyu: ${totalBodyWater.toFixed(2)} litre"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Vücut su yüzdesi: %${waterPercentage.toFixed(2)}"
    ]
  },

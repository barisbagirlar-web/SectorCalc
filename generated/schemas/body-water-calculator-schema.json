  "formulas": {
    "tbwMale": "2.447 - (0.09156 * age) + (0.1074 * height) + (0.3362 * weight)",
    "tbwFemale": "-2.097 + (0.1069 * height) + (0.2466 * weight)",
    "totalBodyWater": "sex === 1 ? tbwMale : tbwFemale",
    "waterPercentage": "((sex === 1 ? tbwMale : tbwFemale) / weight) * 100"
  },
  "outputs": {
    "primary": "waterPercentage",

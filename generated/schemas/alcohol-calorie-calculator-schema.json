  "formulas": {
    "alcoholCalories": "volume * (abv / 100) * 0.789 * 7",
    "otherCalories": "carbs * 4 + protein * 4 + fat * 9",
    "totalCalories": "(alcoholCalories + otherCalories) * quantity"
  },

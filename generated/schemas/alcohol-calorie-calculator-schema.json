    },
    {
      "id": "quantity",
      "label": "Number of Drinks",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "The number of drinks consumed.",
      "label_i18n": {
        "en": "Number of Drinks",
        "tr": "Number of Drinks",
        "de": "Number of Drinks",
        "fr": "Number of Drinks",
        "es": "Number of Drinks",
        "ar": "Number of Drinks"
      }
    }
  ],
  "formulas": {
    "alcoholCalories": "volume * (abv / 100) * 0.789 * 7",
    "otherCalories": "carbs * 4 + protein * 4 + fat * 9",
    "totalCalories": "(alcoholCalories + otherCalories) * quantity"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [
      "alcoholCalories",
      "otherCalories"
    ]
  },

      }
    },
    {
      "id": "expectedAnnualReturn",
      "label": "Expected Annual Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Average annual return on investments.",
      "label_i18n": {
        "en": "Expected Annual Return",
        "tr": "Beklenen Yıllık Getiri",
        "de": "Erwartete jährliche Rendite",
        "fr": "Rendement annuel attendu",
        "es": "Rendimiento anual esperado",
        "ar": "العائد السنوي المتوقع"
      },
      "businessContext_i18n": {
        "en": "Average annual return on investments.",
        "tr": "Yatırımların ortalama yıllık getirisi.",
        "de": "Durchschnittliche jährliche Kapitalrendite.",
        "fr": "Rendement annuel moyen des investissements.",
        "es": "Rendimiento anual promedio de las inversiones.",
        "ar": "متوسط العائد السنوي على الاستثمارات."
      }
    },
    {
      "id": "yearsUntilRetirement",
      "label": "Years Until Retirement",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Years until retirement.",
      "label_i18n": {
        "en": "Years Until Retirement",
        "tr": "Emekliliğe kalan yıl",
        "de": "Jahre bis zur Rente",
        "fr": "Années avant la retraite",
        "es": "Años hasta la jubilación",
        "ar": "السنوات حتى التقاعد"
      },
      "businessContext_i18n": {
        "en": "Years until retirement.",
        "tr": "Emekliliğe kalan yıl.",
        "de": "Jahre bis zur Rente.",
        "fr": "Années avant la retraite.",
        "es": "Años hasta la jubilación.",
        "ar": "السنوات حتى التقاعد."
      }
    }
  ],
  "formulas": {
    "rothValue": "annualContribution * ((1 + expectedAnnualReturn/100) ^ yearsUntilRetirement)",
    "tradValue": "annualContribution * (1 - currentTaxRate/100) * ((1 + expectedAnnualReturn/100) ^ yearsUntilRetirement) / (1 - expectedRetirementTaxRate/100)",
    "rothMinusTrad": "rothValue - tradValue"
  },
  "outputs": {
    "primary": "rothMinusTrad",
    "breakdown": [
      "rothValue",
      "tradValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rothMinusTrad",
    "unit": "USD"
  },

      }
    }
  ],
  "formulas": {
    "transferTimestamp": "new Date(transferYear, transferMonth - 1, transferDay).getTime()",
    "daysToAdd": "266 - embryoAge",
    "dueDateTimestamp": "new Date(transferYear, transferMonth - 1, transferDay).getTime() + ((266 - embryoAge) * 86400000)"
  },
  "outputs": {
    "primary": "dueDateTimestamp",
    "breakdown": [
      "transferTimestamp",
      "daysToAdd"
    ]
  },

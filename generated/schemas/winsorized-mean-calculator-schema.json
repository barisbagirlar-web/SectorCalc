      }
    }
  ],
  "formulas": {
    "sorted": "[x1, x2, x3, x4, x5, x6].sort((a,b)=>a-b)",
    "n": "sorted.length",
    "k": "Math.floor(n * winPercent / 100)",
    "winsorizedMean": "sorted.reduce((sum, val, i) => i < k ? sum + sorted[k] : (i >= n - k ? sum + sorted[n - k - 1] : sum + val), 0) / n",
    "originalMean": "sorted.reduce((a,b)=>a+b,0)/n"
  },
  "outputs": {
    "primary": "winsorizedMean",
    "breakdown": [
      "originalMean",
      "k"
    ]
  },

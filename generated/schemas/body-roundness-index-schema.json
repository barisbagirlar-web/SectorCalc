{
  "toolName": "body-roundness-index",
  "inputs": [
    {
      "id": "waistCircumference",
      "label": "Waist Circumference",
      "type": "number",
      "unit": "cm",
      "default": 80,
      "businessContext": "Waist measurement at the narrowest point or at navel level."
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Standing height without shoes."
    }
  ],
  "formulas": {
    "waistM": "waistCircumference / 100",
    "heightM": "height / 100",
    "waistRadius": "waistM / (2 * Math.PI)",
    "halfHeight": "heightM / 2",
    "innerTerm": "1 - Math.pow(waistRadius / halfHeight, 2)",
    "sqrtTerm": "Math.sqrt(Math.max(0, innerTerm))",
    "bri": "364.2 - 365.5 * sqrtTerm"
  },
  "outputs": {
    "primary": "bri",
    "breakdown": [
      "waistM",
      "heightM",
      "waistRadius",
      "halfHeight",
      "innerTerm",
      "sqrtTerm"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

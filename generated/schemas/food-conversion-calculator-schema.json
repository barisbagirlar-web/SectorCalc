      }
    },
    {
      "id": "densityGml",
      "label": "Density (g/ml)",
      "type": "number",
      "unit": "g/ml",
      "default": 1,
      "businessContext": "Density of the ingredient. Water: 1 g/ml.",
      "label_i18n": {
        "en": "Density (g/ml)",
        "tr": "Density (g/ml)",
        "de": "Density (g/ml)",
        "fr": "Density (g/ml)",
        "es": "Density (g/ml)",
        "ar": "Density (g/ml)"
      }
    },
    {
      "id": "numberOfServings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "Number of servings the volume is divided into.",
      "label_i18n": {
        "en": "Number of Servings",
        "tr": "Number of Servings",
        "de": "Number of Servings",
        "fr": "Number of Servings",
        "es": "Number of Servings",
        "ar": "Number of Servings"
      }
    },
    {
      "id": "caloriesPerGram",
      "label": "Calories per gram",
      "type": "number",
      "unit": "cal/g",
      "default": 0.04,
      "businessContext": "Caloric content per gram of ingredient.",
      "label_i18n": {
        "en": "Calories per gram",
        "tr": "Calories per gram",
        "de": "Calories per gram",
        "fr": "Calories per gram",
        "es": "Calories per gram",
        "ar": "Calories per gram"
      }
    },
    {
      "id": "cupFactor",
      "label": "Cup Conversion Factor (ml/cup)",
      "type": "number",
      "unit": "ml/cup",
      "default": 236.588,
      "businessContext": "Number of milliliters in one standard cup.",
      "label_i18n": {
        "en": "Cup Conversion Factor (ml/cup)",
        "tr": "Cup Conversion Factor (ml/cup)",
        "de": "Cup Conversion Factor (ml/cup)",
        "fr": "Cup Conversion Factor (ml/cup)",
        "es": "Cup Conversion Factor (ml/cup)",
        "ar": "Cup Conversion Factor (ml/cup)"
      }
    }
  ],
  "formulas": {
    "totalWeightGrams": "volumeMl * densityGml",
    "weightPerServingGrams": "totalWeightGrams / numberOfServings",
    "totalCalories": "totalWeightGrams * caloriesPerGram",
    "caloriesPerServing": "totalCalories / numberOfServings",
    "totalCups": "volumeMl / cupFactor"
  },
  "outputs": {
    "primary": "totalWeightGrams",
    "breakdown": [
      "weightPerServingGrams",
      "totalCalories",
      "caloriesPerServing",
      "totalCups"
    ],

{
  "toolName": "food-conversion-calculator",
  "inputs": [
    {
      "id": "volumeMl",
      "label": "Volume (ml)",
      "type": "number",
      "unit": "ml",
      "default": 250,
      "businessContext": "Total volume of ingredient in milliliters.",
      "label_i18n": {
        "en": "Volume (ml)",
        "tr": "Volume (ml)",
        "de": "Volume (ml)",
        "fr": "Volume (ml)",
        "es": "Volume (ml)",

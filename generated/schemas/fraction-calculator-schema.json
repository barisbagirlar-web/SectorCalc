{
  "toolName": "fraction-calculator",
  "inputs": [
    {
      "id": "numerator1",
      "label": "Numerator 1",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "First fraction numerator"
    },
    {
      "id": "denominator1",
      "label": "Denominator 1",
      "type": "number",
      "unit": "",
      "default": 2,
      "businessContext": "First fraction denominator (non-zero)"
    },
    {
      "id": "numerator2",
      "label": "Numerator 2",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Second fraction numerator"
    },
    {
      "id": "denominator2",
      "label": "Denominator 2",
      "type": "number",
      "unit": "",
      "default": 3,
      "businessContext": "Second fraction denominator (non-zero)"
    },
    {
      "id": "operation",
      "label": "Operation",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "0=add, 1=subtract, 2=multiply, 3=divide"
    }
  ],
  "formulas": {
    "resultNumerator": "operation === 0 ? numerator1*denominator2 + numerator2*denominator1 : operation === 1 ? numerator1*denominator2 - numerator2*denominator1 : operation === 2 ? numerator1*numerator2 : numerator1*denominator2",
    "resultDenominator": "operation === 2 ? denominator1*denominator2 : operation === 3 ? denominator1*numerator2 : denominator1*denominator2",
    "gcd": "function gcd(a,b){return b===0?Math.abs(a):gcd(b,a%b)}; gcd(resultNumerator, resultDenominator)",
    "simplifiedNumerator": "resultNumerator / gcd",
    "simplifiedDenominator": "resultDenominator / gcd",
    "decimal": "resultNumerator / resultDenominator"
  },
  "outputs": {
    "primary": "simplifiedNumerator / simplifiedDenominator",
    "breakdown": [
      "Result numerator: resultNumerator",
      "Result denominator: resultDenominator",
      "GCD: gcd",
      "Simplified: simplifiedNumerator / simplifiedDenominator",
      "Decimal: decimal"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

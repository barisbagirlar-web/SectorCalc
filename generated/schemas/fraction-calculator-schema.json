  "formulas": {
    "resultNumerator": "operation === 0 ? numerator1*denominator2 + numerator2*denominator1 : operation === 1 ? numerator1*denominator2 - numerator2*denominator1 : operation === 2 ? numerator1*numerator2 : numerator1*denominator2",
    "resultDenominator": "operation === 2 ? denominator1*denominator2 : operation === 3 ? denominator1*numerator2 : denominator1*denominator2",
    "decimal": "resultNumerator / resultDenominator"
  },

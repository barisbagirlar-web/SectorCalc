    {
      "id": "batchSize",
      "label": "Batch Size",
      "type": "number",
      "unit": "adet",
      "default": 1000,
      "businessContext": "Hesaplanacak kart adedi",
      "label_i18n": {
        "en": "Batch Size",
        "tr": "Parti Büyüklüğü",
        "de": "Losgröße",
        "fr": "Taille de lot",
        "es": "Tamaño de lote",
        "ar": "حجم الدفعة"
      },
      "businessContext_i18n": {
        "en": "Hesaplanacak kart adedi",
        "tr": "Number of cards to calculate",
        "de": "Anzahl der zu berechnenden Karten",
        "fr": "Nombre de cartes à calculer",
        "es": "Cantidad de tarjetas a calcular",
        "ar": "عدد البطاقات المراد حسابها"
      }
    }
  ],
  "formulas": {
    "areaCm2": "(cardLength * cardWidth) / 100",
    "volumeCm3": "areaCm2 * (cardThickness / 10)",
    "massKg": "(volumeCm3 * materialDensity) / 1000",
    "materialCostPerCard": "massKg * materialCostPerKg",
    "effectiveCostPerCard": "materialCostPerCard * (1 + (wasteFactor / 100))",
    "wasteCost": "effectiveCostPerCard - materialCostPerCard",
    "totalCost": "effectiveCostPerCard * batchSize"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "materialCostPerCard",
      "wasteCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "mm"
  },

      "unit": "%",
      "default": 5,
      "businessContext": "Üretim firesi yüzdesi",
      "label_i18n": {
        "en": "Fire Oranı",
        "tr": "Fire Oranı",
        "de": "Fire Oranı",
        "fr": "Fire Oranı",
        "es": "Fire Oranı",
        "ar": "Fire Oranı"
      }
    },
    {
      "id": "batchSize",
      "label": "Parti Büyüklüğü",
      "type": "number",
      "unit": "adet",
      "default": 1000,
      "businessContext": "Hesaplanacak kart adedi",
      "label_i18n": {
        "en": "Parti Büyüklüğü",
        "tr": "Parti Büyüklüğü",
        "de": "Parti Büyüklüğü",
        "fr": "Parti Büyüklüğü",
        "es": "Parti Büyüklüğü",
        "ar": "Parti Büyüklüğü"
      }
    }
  ],
  "formulas": {
    "areaCm2": "(cardLength * cardWidth) / 100",
    "volumeCm3": "areaCm2 * (cardThickness / 10)",
    "massKg": "(volumeCm3 * materialDensity) / 1000",
    "materialCostPerCard": "massKg * materialCostPerKg",
    "effectiveCostPerCard": "materialCostPerCard * (1 + (wasteFactor / 100))",
    "wasteCost": "effectiveCostPerCard - materialCostPerCard",
    "totalCost": "effectiveCostPerCard * batchSize"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "materialCostPerCard",
      "wasteCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

{
  "toolName": "ses-yalitimi-desibel-azaltimi-hesabi",
  "inputs": [
    {
      "id": "kaynakSesSeviyesi",
      "label": "Kaynak Ses Seviyesi (dB)",
      "type": "number",
      "unit": "dB",
      "default": 100,
      "min": 0,
      "max": 200,
      "options": null,
      "businessContext": "Gürültü kaynağının ses basınç seviyesi. ISO 3740 serisi standartlarına göre ölçülür."
    },
    {
      "id": "malzemeTipi",
      "label": "Yalıtım Malzemesi Türü",
      "type": "select",
      "unit": "",
      "default": "mineralYun",
      "min": null,
      "max": null,
      "options": [
        "mineralYun",
        "poliuretanKopuk",
        "akustikPanel",
        "kauçuk",
        "camYunu"
      ],
      "businessContext": "Farklı malzemelerin ses yalıtım katsayıları (STC) ASTM E413 standardına göre belirlenir."
    },
    {
      "id": "malzemeKalınlık",
      "label": "Malzeme Kalınlığı (mm)",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "min": 10,
      "max": 500,
      "options": null,
      "businessContext": "Yalıtım malzemesinin kalınlığı, ses iletim kaybını doğrudan etkiler. ISO 717-1 standardı referans alınır."
    },
    {
      "id": "duvarTipi",
      "label": "Duvar Tipi",
      "type": "select",
      "unit": "",
      "default": "tekKat",
      "min": null,
      "max": null,
      "options": [
        "tekKat",
        "ciftKat",
        "kompozit"
      ],
      "businessContext": "Duvar yapısı, ses yalıtım performansını belirler. ASTM E90 test yöntemi kullanılır."
    },
    {
      "id": "ortamSıcaklık",
      "label": "Ortam Sıcaklığı (°C)",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "min": -20,
      "max": 60,
      "options": null,
      "businessContext": "Sıcaklık, malzeme yoğunluğunu ve ses hızını etkiler. ISO 9613-2 standardı referans alınır."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni (0-1)",
      "type": "number",
      "unit": "",
      "default": 0.9,
      "min": 0,
      "max": 1,
      "options": null,
      "businessContext": "Girdi verilerinin güvenilirliği. Düşük değerler sonucu daha muhafazakar yapar."
    }
  ],
  "validation": {
    "rules": [
      "kaynakSesSeviyesi >= 0 && kaynakSesSeviyesi <= 200",
      "malzemeKalınlık >= 10 && malzemeKalınlık <= 500",
      "ortamSıcaklık >= -20 && ortamSıcaklık <= 60",
      "dataConfidence >= 0 && dataConfidence <= 1"
    ],
    "thresholds": {
      "kaynakSesSeviyesi > 120": "Yüksek gürültü seviyesi, işitme koruma önlemleri gerekli.",
      "malzemeKalınlık < 25": "Yalıtım kalınlığı çok düşük, etkinlik azalabilir.",
      "dataConfidence < 0.5": "Veri güveni düşük, sonuçlar dikkatle yorumlanmalı."
    }
  },
  "formulas": {
    "stcKatsayisi": "stcKatsayisi = (malzemeTipi === 'mineralYun' ? 0.8 : malzemeTipi === 'poliuretanKopuk' ? 0.7 : malzemeTipi === 'akustikPanel' ? 0.9 : malzemeTipi === 'kauçuk' ? 0.6 : 0.75)",
    "duvarFaktoru": "duvarFaktoru = (duvarTipi === 'tekKat' ? 1.0 : duvarTipi === 'ciftKat' ? 1.3 : 1.5)",
    "sicaklikDuzeltme": "sicaklikDuzeltme = 1 + (ortamSıcaklık - 20) * 0.002",
    "desibelAzaltma": "desibelAzaltma = 20 * Math.log10(malzemeKalınlık) * stcKatsayisi * duvarFaktoru * sicaklikDuzeltme",
    "sonucSesSeviyesi": "sonucSesSeviyesi = kaynakSesSeviyesi - desibelAzaltma",
    "dataConfidenceAdjusted": "dataConfidenceAdjusted = sonucSesSeviyesi * (1 + (1 - dataConfidence) * 0.1)"
  },
  "outputs": {
    "primary": "sonucSesSeviyesi",
    "breakdown": {
      "desibelAzaltma": "desibelAzaltma",
      "stcKatsayisi": "stcKatsayisi",
      "duvarFaktoru": "duvarFaktoru",
      "sicaklikDuzeltme": "sicaklikDuzeltme"
    },
    "hiddenLossDrivers": [
      "kaynakSesSeviyesi > 120 ? 'Yüksek gürültü' : ''",
      "malzemeKalınlık < 25 ? 'Düşük kalınlık' : ''",
      "dataConfidence < 0.5 ? 'Düşük veri güveni' : ''"
    ],
    "suggestedActions": [
      "sonucSesSeviyesi > 85 ? 'İşitme koruyucu ekipman kullanın.' : ''",
      "malzemeKalınlık < 50 ? 'Daha kalın yalıtım malzemesi tercih edin.' : ''",
      "dataConfidence < 0.7 ? 'Veri kaynaklarını doğrulayın.' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF raporu",
    "CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

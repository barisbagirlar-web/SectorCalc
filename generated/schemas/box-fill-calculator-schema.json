        "de": "Setzen Sie 1, wenn Schutzleiter vorhanden sind (sie zählen als 1 des größten Volumens), sonst 0"
      }
    }
  ],
  "formulas": {
    "volumeLargest": "(number10AWG > 0 ? 2.5 : (number12AWG > 0 ? 2.25 : (number14AWG > 0 ? 2.0 : 0)))",
    "conductorVolume": "number14AWG * 2.0 + number12AWG * 2.25 + number10AWG * 2.5",
    "deviceVolume": "numberOfDevices * 2 * volumeLargest",
    "clampVolume": "numberOfClamps * volumeLargest",
    "groundVolume": "equipmentGroundPresent * volumeLargest",
    "totalVolume": "conductorVolume + deviceVolume + clampVolume + groundVolume"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "conductorVolume",
      "deviceVolume",
      "clampVolume",
      "groundVolume"
    ],

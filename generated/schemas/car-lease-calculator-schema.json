      "businessContext_i18n": {
        "en": "Net price of the vehicle",
        "tr": "Aracın net fiyatı",
        "de": "Nettopreis des Fahrzeugs"
      }
    },
    {
      "id": "residualValue",
      "label": "Residual Value",
      "type": "number",
      "unit": "€",
      "default": 15000,
      "businessContext": "Estimated value at lease end",
      "label_i18n": {
        "en": "Residual Value",
        "tr": "Kalıntı Değer",
        "de": "Restwert",
        "fr": "Residual Value",
        "es": "Residual Value",
        "ar": "Residual Value"
      },
      "businessContext_i18n": {
        "en": "Estimated value at lease end",
        "tr": "Kira sonunda tahmini değer",
        "de": "Geschätzter Restwert bei Leasingende"
      }
    },
    {
      "id": "moneyFactor",
      "label": "Money Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.0025,
      "businessContext": "Interest rate factor (money factor = APR / 2400)",
      "label_i18n": {
        "en": "Money Factor",
        "tr": "Para Faktörü",
        "de": "Geldfaktor",
        "fr": "Money Factor",
        "es": "Money Factor",
        "ar": "Money Factor"
      },
      "businessContext_i18n": {
        "en": "Interest rate factor (money factor = APR / 2400)",
        "tr": "Faiz oranı faktörü (para faktörü = APR / 2400)",
        "de": "Zinsfaktor (Geldfaktor = effektiver Jahreszins / 2400)"
      }
    },
    {
      "id": "leaseTerm",
      "label": "Lease Term",
      "type": "number",
      "unit": "months",
      "default": 36,
      "businessContext": "Duration of the lease",
      "label_i18n": {
        "en": "Lease Term",
        "tr": "Kira Süresi",
        "de": "Leasinglaufzeit",
        "fr": "Lease Term",
        "es": "Lease Term",
        "ar": "Lease Term"
      },
      "businessContext_i18n": {
        "en": "Duration of the lease",
        "tr": "Kira süresi",
        "de": "Laufzeit des Leasings"
      }
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "number",
      "unit": "€",
      "default": 2000,
      "businessContext": "Initial payment",
      "label_i18n": {
        "en": "Down Payment",
        "tr": "Peşinat",
        "de": "Anzahlung",
        "fr": "Down Payment",
        "es": "Down Payment",
        "ar": "Down Payment"
      },
      "businessContext_i18n": {
        "en": "Initial payment",
        "tr": "İlk ödeme",
        "de": "Anzahlung"
      }
    },
    {
      "id": "salesTaxRate",
      "label": "Sales Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Tax rate applied to monthly payment",
      "label_i18n": {
        "en": "Sales Tax Rate",
        "tr": "Satış Vergisi Oranı",
        "de": "Umsatzsteuersatz",
        "fr": "Sales Tax Rate",
        "es": "Sales Tax Rate",
        "ar": "Sales Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Tax rate applied to monthly payment",
        "tr": "Aylık ödemeye uygulanan vergi oranı",
        "de": "Steuersatz auf die monatliche Zahlung"
      }
    },
    {
      "id": "acquisitionFee",
      "label": "Acquisition Fee",
      "type": "number",
      "unit": "€",
      "default": 500,
      "businessContext": "One-time fee at lease start",
      "label_i18n": {
        "en": "Acquisition Fee",
        "tr": "Edinim Ücreti",
        "de": "Bearbeitungsgebühr",
        "fr": "Acquisition Fee",
        "es": "Acquisition Fee",
        "ar": "Acquisition Fee"
      },
      "businessContext_i18n": {
        "en": "One-time fee at lease start",
        "tr": "Kira başlangıcında tek seferlik ücret",
        "de": "Einmalige Gebühr bei Leasingbeginn"
      }
    }
  ],
  "formulas": {
    "netCapCost": "carPrice - downPayment + acquisitionFee",
    "depreciationFee": "(netCapCost - residualValue) / leaseTerm",
    "financeFee": "(netCapCost + residualValue) * moneyFactor",
    "monthlyPaymentBeforeTax": "depreciationFee + financeFee",
    "monthlyPayment": "monthlyPaymentBeforeTax * (1 + salesTaxRate / 100)",
    "totalLeaseCost": "monthlyPayment * leaseTerm + downPayment + acquisitionFee"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "totalLeaseCost",
      "depreciationFee",
      "financeFee"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalLeaseCost",
    "unit": "€"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",

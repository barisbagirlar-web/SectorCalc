{
  "toolName": "car-lease-calculator",
  "inputs": [
    {
      "id": "carPrice",
      "label": "Car Price",
      "type": "number",
      "unit": "€",
      "default": 30000,
      "businessContext": "Net price of the vehicle",
      "label_i18n": {
        "en": "Car Price",
        "tr": "Car Price",
        "de": "Car Price",
        "fr": "Car Price",
        "es": "Car Price",
        "ar": "Car Price"
      }
    },
    {
      "id": "residualValue",
      "label": "Residual Value",
      "type": "number",
      "unit": "€",
      "default": 15000,
      "businessContext": "Estimated value at lease end",
      "label_i18n": {
        "en": "Residual Value",
        "tr": "Residual Value",
        "de": "Residual Value",
        "fr": "Residual Value",
        "es": "Residual Value",
        "ar": "Residual Value"
      }
    },
    {
      "id": "moneyFactor",
      "label": "Money Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.0025,
      "businessContext": "Interest rate factor (money factor = APR / 2400)",
      "label_i18n": {
        "en": "Money Factor",
        "tr": "Money Factor",
        "de": "Money Factor",
        "fr": "Money Factor",
        "es": "Money Factor",
        "ar": "Money Factor"
      }
    },
    {
      "id": "leaseTerm",
      "label": "Lease Term",
      "type": "number",
      "unit": "months",
      "default": 36,
      "businessContext": "Duration of the lease",
      "label_i18n": {
        "en": "Lease Term",
        "tr": "Lease Term",
        "de": "Lease Term",
        "fr": "Lease Term",
        "es": "Lease Term",
        "ar": "Lease Term"
      }
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "number",
      "unit": "€",
      "default": 2000,
      "businessContext": "Initial payment",
      "label_i18n": {
        "en": "Down Payment",
        "tr": "Down Payment",
        "de": "Down Payment",
        "fr": "Down Payment",
        "es": "Down Payment",
        "ar": "Down Payment"
      }
    },
    {
      "id": "salesTaxRate",
      "label": "Sales Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Tax rate applied to monthly payment",
      "label_i18n": {
        "en": "Sales Tax Rate",
        "tr": "Sales Tax Rate",
        "de": "Sales Tax Rate",
        "fr": "Sales Tax Rate",
        "es": "Sales Tax Rate",
        "ar": "Sales Tax Rate"
      }
    },
    {
      "id": "acquisitionFee",
      "label": "Acquisition Fee",
      "type": "number",
      "unit": "€",
      "default": 500,
      "businessContext": "One-time fee at lease start",
      "label_i18n": {
        "en": "Acquisition Fee",
        "tr": "Acquisition Fee",
        "de": "Acquisition Fee",
        "fr": "Acquisition Fee",
        "es": "Acquisition Fee",
        "ar": "Acquisition Fee"
      }
    }
  ],
  "formulas": {
    "netCapCost": "carPrice - downPayment + acquisitionFee",
    "depreciationFee": "(netCapCost - residualValue) / leaseTerm",
    "financeFee": "(netCapCost + residualValue) * moneyFactor",
    "monthlyPaymentBeforeTax": "depreciationFee + financeFee",
    "monthlyPayment": "monthlyPaymentBeforeTax * (1 + salesTaxRate / 100)",
    "totalLeaseCost": "monthlyPayment * leaseTerm + downPayment + acquisitionFee"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "totalLeaseCost",
      "depreciationFee",
      "financeFee"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Otomotiv & Taşıt",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "maintenance-reliability",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "cost"
}

    },
    {
      "id": "course2Grade",
      "label": "Course 2 Grade (4.0 scale)",
      "type": "number",
      "unit": "points",
      "default": 0,
      "businessContext": "Grade point for course 2 on a 4.0 scale"
    },
    {
      "id": "course3Credit",
      "label": "Course 3 Credit Hours",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "businessContext": "Credit hours for course 3"
    },
    {
      "id": "course3Grade",
      "label": "Course 3 Grade (4.0 scale)",
      "type": "number",
      "unit": "points",
      "default": 0,
      "businessContext": "Grade point for course 3 on a 4.0 scale"
    },
    {
      "id": "course4Credit",
      "label": "Course 4 Credit Hours",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "businessContext": "Credit hours for course 4"
    },
    {
      "id": "course4Grade",
      "label": "Course 4 Grade (4.0 scale)",
      "type": "number",
      "unit": "points",
      "default": 0,
      "businessContext": "Grade point for course 4 on a 4.0 scale"
    }
  ],
  "formulas": {
    "totalGradePoints": "course1Credit * course1Grade + course2Credit * course2Grade + course3Credit * course3Grade + course4Credit * course4Grade",
    "totalCredits": "course1Credit + course2Credit + course3Credit + course4Credit",
    "gpa": "totalGradePoints / totalCredits"
  },
  "outputs": {
    "primary": "gpa",
    "breakdown": [
      "totalGradePoints",
      "totalCredits"
    ]
  },

{
  "toolName": "golf-distance-calculator",
  "inputs": [
    {
      "id": "clubSpeed",
      "label": "Club Speed",
      "type": "number",
      "unit": "mph",
      "default": 100,
      "businessContext": "Club head speed at impact, typically 70-130 mph for amateur golfers",
      "label_i18n": {
        "en": "Club Speed",
        "tr": "Club Speed",
        "de": "Club Speed",
        "fr": "Club Speed",
        "es": "Club Speed",
        "ar": "Club Speed"
      }
    },
    {
      "id": "smashFactor",
      "label": "Smash Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.48,
      "businessContext": "Ball speed divided by club speed, typically 1.35-1.5 for drivers",
      "label_i18n": {
        "en": "Smash Factor",
        "tr": "Smash Factor",
        "de": "Smash Factor",
        "fr": "Smash Factor",
        "es": "Smash Factor",
        "ar": "Smash Factor"
      }
    },
    {
      "id": "launchAngle",
      "label": "Launch Angle",
      "type": "number",
      "unit": "degrees",
      "default": 12,
      "businessContext": "Initial vertical angle of ball flight, optimal around 10-15 degrees",
      "label_i18n": {
        "en": "Launch Angle",
        "tr": "Launch Angle",
        "de": "Launch Angle",
        "fr": "Launch Angle",
        "es": "Launch Angle",
        "ar": "Launch Angle"
      }
    },
    {
      "id": "spinRate",
      "label": "Spin Rate",
      "type": "number",
      "unit": "rpm",
      "default": 2500,
      "businessContext": "Backspin rate, typical driver spin 2000-3000 rpm",
      "label_i18n": {
        "en": "Spin Rate",
        "tr": "Spin Rate",
        "de": "Spin Rate",
        "fr": "Spin Rate",
        "es": "Spin Rate",
        "ar": "Spin Rate"
      }
    },
    {
      "id": "windSpeed",
      "label": "Wind Speed",
      "type": "number",
      "unit": "mph",
      "default": 0,
      "businessContext": "Positive for tailwind, negative for headwind",
      "label_i18n": {
        "en": "Wind Speed",
        "tr": "Wind Speed",
        "de": "Wind Speed",
        "fr": "Wind Speed",
        "es": "Wind Speed",
        "ar": "Wind Speed"
      }
    },
    {
      "id": "altitude",
      "label": "Altitude",
      "type": "number",
      "unit": "feet",
      "default": 0,
      "businessContext": "Elevation above sea level, higher altitude reduces air density",
      "label_i18n": {
        "en": "Altitude",
        "tr": "Altitude",
        "de": "Altitude",
        "fr": "Altitude",
        "es": "Altitude",
        "ar": "Altitude"
      }
    }
  ],
  "formulas": {
    "ballSpeed": "clubSpeed * smashFactor",
    "carryDistance": "(ballSpeed * 1.75) - 40 + (launchAngle - 12) * 3 - (spinRate - 2500) * 0.03 + (windSpeed * 2) + (altitude * 0.001)",
    "totalDistance": "carryDistance * 1.08"
  },
  "outputs": {
    "primary": "totalDistance",
    "breakdown": [
      "ballSpeed",
      "carryDistance"
    ]
  },

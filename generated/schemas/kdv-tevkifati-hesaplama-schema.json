{
  "toolName": "kdv-tevkifati-hesaplama",
  "inputs": [
    {
      "id": "brutTutar",
      "label": "Brüt Tutar (KDV Dahil)",
      "type": "number",
      "unit": "TRY",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "KDV dahil fatura tutarı. Kaynak: 3065 sayılı KDV Kanunu."
    },
    {
      "id": "kdvOrani",
      "label": "KDV Oranı",
      "type": "select",
      "unit": "%",
      "default": "0.18",
      "min": null,
      "max": null,
      "options": [
        "0.01",
        "0.08",
        "0.18"
      ],
      "businessContext": "Türkiye'de uygulanan KDV oranları: %1, %8, %18. Kaynak: 3065 sayılı KDV Kanunu."
    },
    {
      "id": "tevkifatOrani",
      "label": "Tevkifat Oranı",
      "type": "select",
      "unit": "%",
      "default": "0.5",
      "min": null,
      "max": null,
      "options": [
        "0.3",
        "0.4",
        "0.5",
        "0.7",
        "0.9"
      ],
      "businessContext": "KDV tevkifat oranı; hizmet türüne göre değişir. Kaynak: KDV Genel Uygulama Tebliği."
    },
    {
      "id": "tevkifatKapsami",
      "label": "Tevkifat Kapsamı",
      "type": "select",
      "unit": "",
      "default": "kismi",
      "min": null,
      "max": null,
      "options": [
        "kismi",
        "tam"
      ],
      "businessContext": "Kısmi tevkifat: belirli oranda; tam tevkifat: %100. Kaynak: KDV Genel Uygulama Tebliği."
    }
  ],
  "validation": {
    "rules": [
      "brutTutar > 0",
      "kdvOrani in [0.01, 0.08, 0.18]",
      "tevkifatOrani in [0.3, 0.4, 0.5, 0.7, 0.9]",
      "if tevkifatKapsami == 'tam' then tevkifatOrani == 1.0"
    ],
    "thresholds": {
      "tevkifatTutari": "> 1000000 -> 'Yüksek tevkifat tutarı, vergi dairesine bildirim gerekebilir.'"
    }
  },
  "formulas": {
    "kdvMatrahi": "brutTutar / (1 + kdvOrani)",
    "kdvTutari": "kdvMatrahi * kdvOrani",
    "tevkifatTutari": "kdvTutari * tevkifatOrani",
    "odenmesiGerekenKDV": "kdvTutari - tevkifatTutari",
    "netTutar": "kdvMatrahi + odenmesiGerekenKDV"
  },
  "outputs": {
    "primary": "odenmesiGerekenKDV",
    "breakdown": {
      "kdvMatrahi": "kdvMatrahi",
      "kdvTutari": "kdvTutari",
      "tevkifatTutari": "tevkifatTutari",
      "netTutar": "netTutar"
    },
    "hiddenLossDrivers": [
      "if tevkifatTutari > 1000000 then 'Yüksek tevkifat tutarı'"
    ],
    "suggestedActions": [
      "Tevkifat oranını ve kapsamını doğrulayın.",
      "Yüksek tevkifat tutarları için vergi dairesine bildirim yapın."
    ],
    "dataConfidenceAdjusted": "odenmesiGerekenKDV"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

{
  "toolName": "dac-calculator",
  "inputs": [
    {
      "id": "airFlow",
      "label": "Air Flow Rate",
      "type": "number",
      "unit": "m³/h",
      "default": 1000,
      "businessContext": "The volumetric flow rate of air processed by the DAC system per hour.",
      "label_i18n": {
        "en": "Air Flow Rate",
        "tr": "Air Flow Rate",
        "de": "Air Flow Rate",
        "fr": "Air Flow Rate",
        "es": "Air Flow Rate",
        "ar": "Air Flow Rate"
      }
    },
    {
      "id": "co2Concentration",
      "label": "CO₂ Concentration",
      "type": "number",
      "unit": "ppm",
      "default": 415,
      "businessContext": "The atmospheric CO₂ concentration at the intake, typically around 415 ppm.",
      "label_i18n": {
        "en": "CO₂ Concentration",
        "tr": "CO₂ Concentration",
        "de": "CO₂ Concentration",
        "fr": "CO₂ Concentration",
        "es": "CO₂ Concentration",
        "ar": "CO₂ Concentration"
      }
    },
    {
      "id": "captureEfficiency",
      "label": "Capture Efficiency",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "The percentage of CO₂ removed from the processed air stream.",
      "label_i18n": {
        "en": "Capture Efficiency",
        "tr": "Capture Efficiency",
        "de": "Capture Efficiency",
        "fr": "Capture Efficiency",
        "es": "Capture Efficiency",
        "ar": "Capture Efficiency"
      }
    },
    {
      "id": "operatingHours",
      "label": "Operating Hours per Year",
      "type": "number",
      "unit": "h",
      "default": 8000,
      "businessContext": "The total number of hours the DAC plant operates annually.",
      "label_i18n": {
        "en": "Operating Hours per Year",
        "tr": "Operating Hours per Year",
        "de": "Operating Hours per Year",
        "fr": "Operating Hours per Year",
        "es": "Operating Hours per Year",
        "ar": "Operating Hours per Year"
      }
    },
    {
      "id": "energyPerTon",
      "label": "Energy Consumption per Ton CO₂",
      "type": "number",
      "unit": "kWh/ton",
      "default": 2000,
      "businessContext": "The electrical energy required to capture one metric ton of CO₂.",
      "label_i18n": {
        "en": "Energy Consumption per Ton CO₂",
        "tr": "Energy Consumption per Ton CO₂",
        "de": "Energy Consumption per Ton CO₂",
        "fr": "Energy Consumption per Ton CO₂",
        "es": "Energy Consumption per Ton CO₂",
        "ar": "Energy Consumption per Ton CO₂"
      }
    },
    {
      "id": "electricityPrice",
      "label": "Electricity Price",
      "type": "number",
      "unit": "$/kWh",
      "default": 0.1,
      "businessContext": "The cost of electricity per kilowatt-hour.",
      "label_i18n": {
        "en": "Electricity Price",
        "tr": "Electricity Price",
        "de": "Electricity Price",
        "fr": "Electricity Price",
        "es": "Electricity Price",
        "ar": "Electricity Price"
      }
    }
  ],
  "formulas": {
    "annualCO2Captured": "airFlow * co2Concentration * captureEfficiency * operatingHours * 1.964e-11",
    "annualEnergyConsumption": "airFlow * co2Concentration * captureEfficiency * operatingHours * 1.964e-11 * energyPerTon",
    "annualElectricityCost": "airFlow * co2Concentration * captureEfficiency * operatingHours * 1.964e-11 * energyPerTon * electricityPrice"
  },
  "outputs": {
    "primary": "annualCO2Captured",
    "breakdown": [
      "annualEnergyConsumption",
      "annualElectricityCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualElectricityCost",
    "unit": "m³/h"
  },

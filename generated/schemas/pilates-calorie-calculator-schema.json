        "tr": "Soğuma esneme hareketlerinin dakika cinsinden süresi"
      }
    },
    {
      "id": "difficultyFactor",
      "label": "Difficulty Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for overall intensity (e.g. 1.0 = normal, 1.2 = advanced)",
      "label_i18n": {
        "en": "Difficulty Factor",
        "tr": "Zorluk Faktörü",
        "de": "Difficulty Factor",
        "fr": "Difficulty Factor",
        "es": "Difficulty Factor",
        "ar": "Difficulty Factor"
      },
      "businessContext_i18n": {
        "en": "Multiplier for overall intensity (e.g. 1.0 = normal, 1.2 = advanced)",
        "tr": "Genel yoğunluk için çarpan (örn. 1.0 = normal, 1.2 = ileri seviye)"
      }
    }
  ],
  "formulas": {
    "caloriesBurned": "weight * (2.5 * warmupDuration / 60 + 3.5 * mainDuration / 60 + 2.0 * cooldownDuration / 60) * difficultyFactor",
    "caloriesPerMinute": "caloriesBurned / (warmupDuration + mainDuration + cooldownDuration)",
    "totalDuration": "warmupDuration + mainDuration + cooldownDuration"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "caloriesPerMinute",
      "totalDuration"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalDuration",
    "unit": "kg",
    "breakdownUnits": {
      "caloriesPerMinute": "min",
      "totalDuration": "%"
    }
  },

      "id": "cooldownDuration",
      "label": "Cool-down Duration",
      "type": "number",
      "unit": "min",
      "default": 5,
      "businessContext": "Duration of cool-down stretching in minutes",
      "label_i18n": {
        "en": "Cool-down Duration",
        "tr": "Soğuma Süresi",
        "de": "Cool-down Duration",

{
  "toolName": "energy-savings-calculator",
  "inputs": [
    {
      "id": "currentEnergyUsage",
      "label": "Current Energy Usage (kWh)",
      "type": "number",
      "unit": "kWh",
      "default": 1000,
      "businessContext": "Total energy consumption in the baseline period (e.g., monthly).",
      "label_i18n": {
        "en": "Current Energy Usage (kWh)",
        "tr": "Current Energy Usage (kWh)",
        "de": "Current Energy Usage (kWh)",
        "fr": "Current Energy Usage (kWh)",
        "es": "Current Energy Usage (kWh)",
        "ar": "Current Energy Usage (kWh)"
      }
    },
    {
      "id": "energyCostPerUnit",
      "label": "Energy Cost per kWh ($)",
      "type": "number",
      "unit": "$/kWh",
      "default": 0.12,
      "businessContext": "Cost per kilowatt-hour from the utility bill or energy contract.",
      "label_i18n": {
        "en": "Energy Cost per kWh ($)",
        "tr": "Energy Cost per kWh ($)",
        "de": "Energy Cost per kWh ($)",
        "fr": "Energy Cost per kWh ($)",
        "es": "Energy Cost per kWh ($)",
        "ar": "Energy Cost per kWh ($)"
      }
    },
    {
      "id": "efficiencyGain",
      "label": "Efficiency Improvement (%)",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Expected percentage reduction in energy usage due to conservation measures.",
      "label_i18n": {
        "en": "Efficiency Improvement (%)",
        "tr": "Efficiency Improvement (%)",
        "de": "Efficiency Improvement (%)",
        "fr": "Efficiency Improvement (%)",
        "es": "Efficiency Improvement (%)",
        "ar": "Efficiency Improvement (%)"
      }
    },
    {
      "id": "operatingHours",
      "label": "Operating Hours per Period",
      "type": "number",
      "unit": "hours",
      "default": 720,
      "businessContext": "Total operating hours in the analysis period (e.g., 720 hours per month).",
      "label_i18n": {
        "en": "Operating Hours per Period",
        "tr": "Operating Hours per Period",
        "de": "Operating Hours per Period",
        "fr": "Operating Hours per Period",
        "es": "Operating Hours per Period",
        "ar": "Operating Hours per Period"
      }
    },
    {
      "id": "emissionFactor",
      "label": "CO₂ Emission Factor (kg/kWh)",
      "type": "number",
      "unit": "kg/kWh",
      "default": 0.5,
      "businessContext": "Carbon dioxide emission per kWh for the energy source (e.g., grid average).",
      "label_i18n": {
        "en": "CO₂ Emission Factor (kg/kWh)",
        "tr": "CO₂ Emission Factor (kg/kWh)",
        "de": "CO₂ Emission Factor (kg/kWh)",
        "fr": "CO₂ Emission Factor (kg/kWh)",
        "es": "CO₂ Emission Factor (kg/kWh)",
        "ar": "CO₂ Emission Factor (kg/kWh)"
      }
    }
  ],
  "formulas": {
    "energySaved": "currentEnergyUsage * (efficiencyGain / 100)",
    "costSavings": "energySaved * energyCostPerUnit",
    "co2Reduction": "energySaved * emissionFactor"
  },
  "outputs": {
    "primary": "costSavings",
    "breakdown": [

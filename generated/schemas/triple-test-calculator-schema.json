  "formulas": {
    "mean": "(s1 + s2 + s3) / 3",
    "std_dev": "Math.sqrt((Math.pow(s1 - (s1 + s2 + s3) / 3, 2) + Math.pow(s2 - (s1 + s2 + s3) / 3, 2) + Math.pow(s3 - (s1 + s2 + s3) / 3, 2)) / 3)",
    "cv": "((Math.sqrt((Math.pow(s1 - (s1 + s2 + s3) / 3, 2) + Math.pow(s2 - (s1 + s2 + s3) / 3, 2) + Math.pow(s3 - (s1 + s2 + s3) / 3, 2)) / 3) / ((s1 + s2 + s3) / 3)) * 100",
    "mean_ok": "((s1 + s2 + s3) / 3) >= target",
    "cv_ok": "((Math.sqrt((Math.pow(s1 - (s1 + s2 + s3) / 3, 2) + Math.pow(s2 - (s1 + s2 + s3) / 3, 2) + Math.pow(s3 - (s1 + s2 + s3) / 3, 2)) / 3) / ((s1 + s2 + s3) / 3)) * 100 <= cv_limit",
    "min_ok": "s1 >= min_individual && s2 >= min_individual && s3 >= min_individual",
    "max_ok": "s1 <= max_individual && s2 <= max_individual && s3 <= max_individual",
    "acceptance": "(((s1 + s2 + s3) / 3) >= target) && (((Math.sqrt((Math.pow(s1 - (s1 + s2 + s3) / 3, 2) + Math.pow(s2 - (s1 + s2 + s3) / 3, 2) + Math.pow(s3 - (s1 + s2 + s3) / 3, 2)) / 3) / ((s1 + s2 + s3) / 3)) * 100 <= cv_limit) && (s1 >= min_individual && s2 >= min_individual && s3 >= min_individual) && (s1 <= max_individual && s2 <= max_individual && s3 <= max_individual)"
  },
  "outputs": {
    "primary": "acceptance",
    "breakdown": [
      "mean",
      "std_dev",
      "cv",
      "mean_ok",
      "cv_ok",
      "min_ok",
      "max_ok"
    ]
  },

  "formulas": {
    "OrificeFlow": "C_d * A * SQRT(2 * DeltaP * Density)",
    "SteamLoss_kg_h": "OrificeFlow * 3600",
    "EnergyLoss_kW": "SteamLoss_kg_h * Enthalpy_Steam / 3600",
    "AnnualCost": "EnergyLoss_kW * OperatingHours * SteamCost_per_kWh",
    "TrapFailureRate": "FailedTraps / TotalTraps",
    "TotalSystemLoss": "SUM(AnnualCost_i)",
    "RepairROI": "TotalSystemLoss / (TrapCost + LaborCost)"
  },

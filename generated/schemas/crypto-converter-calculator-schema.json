{
  "toolName": "crypto-converter-calculator",
  "inputs": [
    {
      "id": "amount",
      "label": "Amount",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "businessContext": "Amount to convert",
      "label_i18n": {
        "en": "Amount",
        "tr": "Miktar",
        "de": "Betrag",
        "fr": "Montant",
        "es": "Cantidad",
        "ar": "Amount"
      },
      "businessContext_i18n": {
        "en": "Amount to convert",
        "tr": "Dönüştürülecek miktar",
        "de": "Umzurechnender Betrag",
        "fr": "Montant à convertir",
        "es": "Cantidad a convertir"
      }
    },
    {
      "id": "exchangeRate",
      "label": "Exchange Rate",
      "type": "number",
      "unit": "BTC/USD",
      "default": 0.000025,
      "businessContext": "Current exchange rate",
      "label_i18n": {
        "en": "Exchange Rate",
        "tr": "Döviz Kuru",
        "de": "Wechselkurs",
        "fr": "Taux de change",
        "es": "Tipo de cambio",
        "ar": "Exchange Rate"
      },
      "businessContext_i18n": {
        "en": "Current exchange rate",
        "tr": "Güncel döviz kuru",
        "de": "Aktueller Wechselkurs",
        "fr": "Taux de change actuel",
        "es": "Tipo de cambio actual"
      }
    },
    {
      "id": "feePercent",
      "label": "Conversion Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 1.5,
      "businessContext": "Percentage fee for conversion",
      "label_i18n": {
        "en": "Conversion Fee (%)",
        "tr": "Dönüşüm Ücreti (%)",
        "de": "Umrechnungsgebühr (%)",
        "fr": "Frais de conversion (%)",
        "es": "Comisión de conversión (%)",
        "ar": "Conversion Fee (%)"
      },
      "businessContext_i18n": {
        "en": "Percentage fee for conversion",
        "tr": "Dönüşüm için yüzde ücret",
        "de": "Prozentsatz der Gebühr für die Umrechnung",
        "fr": "Pourcentage de frais pour la conversion",
        "es": "Porcentaje de comisión por la conversión"
      }
    },
    {
      "id": "spread",
      "label": "Spread (%)",
      "type": "number",
      "unit": "%",
      "default": 0.1,
      "businessContext": "Spread added to exchange rate",
      "label_i18n": {
        "en": "Spread (%)",
        "tr": "Spread (%)",
        "de": "Spread (%)",
        "fr": "Spread (%)",
        "es": "Diferencial (%)",
        "ar": "Spread (%)"
      },
      "businessContext_i18n": {
        "en": "Spread added to exchange rate",
        "tr": "Döviz kuruna eklenen spread",
        "de": "Aufschlag auf den Wechselkurs",
        "fr": "Spread ajouté au taux de change",
        "es": "Diferencial añadido al tipo de cambio"
      }
    }
  ],
  "formulas": {
    "rateAfterSpread": "exchangeRate * (1 + spread/100)",
    "convertedAmount": "amount * rateAfterSpread",
    "feeAmount": "convertedAmount * (feePercent/100)",
    "finalAmount": "convertedAmount - feeAmount"
  },
  "outputs": {
    "primary": "finalAmount",
    "breakdown": [
      "Entered amount: ${amount} USD",
      "Rate after spread: ${rateAfterSpread.toFixed(8)} BTC/USD",
      "Fee deducted: ${feeAmount.toFixed(8)} BTC",
      "Final amount: ${finalAmount.toFixed(8)} BTC"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalAmount",
    "unit": "USD",
    "breakdownUnits": {
      "Entered amount: ${amount} USD": "USD",
      "Rate after spread: ${rateAfterSpread.toFixed(8)} BTC/USD": "USD"
    }
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Birim & Dönüşüm",

{
  "toolName": "dropshipping-profit-calculator",
  "inputs": [
    {
      "id": "sellingPrice",
      "label": "Selling Price per Unit",
      "type": "number",
      "unit": "currency",
      "default": 50,
      "businessContext": "The price at which the product is sold to customers",
      "label_i18n": {
        "en": "Selling Price per Unit",
        "tr": "Selling Price per Unit",
        "de": "Selling Price per Unit",
        "fr": "Selling Price per Unit",
        "es": "Selling Price per Unit",
        "ar": "Selling Price per Unit"
      }
    },
    {
      "id": "costPrice",
      "label": "Cost Price per Unit",
      "type": "number",
      "unit": "currency",
      "default": 30,
      "businessContext": "The price paid to the supplier per unit",
      "label_i18n": {
        "en": "Cost Price per Unit",
        "tr": "Cost Price per Unit",
        "de": "Cost Price per Unit",
        "fr": "Cost Price per Unit",
        "es": "Cost Price per Unit",
        "ar": "Cost Price per Unit"
      }
    },
    {
      "id": "shippingCost",
      "label": "Shipping Cost per Unit",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "The shipping cost incurred per unit delivered",
      "label_i18n": {
        "en": "Shipping Cost per Unit",
        "tr": "Shipping Cost per Unit",
        "de": "Shipping Cost per Unit",
        "fr": "Shipping Cost per Unit",
        "es": "Shipping Cost per Unit",
        "ar": "Shipping Cost per Unit"
      }
    },
    {
      "id": "orderVolume",
      "label": "Monthly Order Volume",
      "type": "number",
      "unit": "orders/month",
      "default": 100,
      "businessContext": "Number of orders processed per month",
      "label_i18n": {
        "en": "Monthly Order Volume",
        "tr": "Monthly Order Volume",
        "de": "Monthly Order Volume",
        "fr": "Monthly Order Volume",
        "es": "Monthly Order Volume",
        "ar": "Monthly Order Volume"
      }
    },
    {
      "id": "fixedCosts",
      "label": "Monthly Fixed Costs",
      "type": "number",
      "unit": "currency/month",
      "default": 200,
      "businessContext": "Fixed operational costs per month (e.g., store subscriptions, marketing)",
      "label_i18n": {
        "en": "Monthly Fixed Costs",
        "tr": "Monthly Fixed Costs",
        "de": "Monthly Fixed Costs",
        "fr": "Monthly Fixed Costs",
        "es": "Monthly Fixed Costs",
        "ar": "Monthly Fixed Costs"
      }
    },
    {
      "id": "feePercentage",
      "label": "Payment Gateway Fee",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Transaction fee as a percentage of the selling price",
      "label_i18n": {
        "en": "Payment Gateway Fee",
        "tr": "Payment Gateway Fee",
        "de": "Payment Gateway Fee",
        "fr": "Payment Gateway Fee",
        "es": "Payment Gateway Fee",
        "ar": "Payment Gateway Fee"
      }
    }
  ],
  "formulas": {
    "revenue": "sellingPrice * orderVolume",
    "totalCOGS": "(costPrice + shippingCost) * orderVolume",
    "totalFees": "sellingPrice * (feePercentage / 100) * orderVolume",
    "grossProfit": "revenue - totalCOGS",
    "netProfit": "grossProfit - totalFees - fixedCosts",
    "netProfitMargin": "(netProfit / revenue) * 100"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "grossProfit",
      "totalFees",
      "netProfitMargin"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netProfitMargin",
    "unit": "currency",
    "breakdownUnits": {
      "netProfitMargin": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "finance-business",

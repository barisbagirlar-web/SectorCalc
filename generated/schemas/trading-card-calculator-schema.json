{
  "toolName": "trading-card-calculator",
  "inputs": [
    {
      "id": "cardPrice",
      "label": "Card Market Price (Ungraded)",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "Current market value of the ungraded card",
      "label_i18n": {
        "en": "Card Market Price (Ungraded)",
        "tr": "Card Market Price (Ungraded)",
        "de": "Card Market Price (Ungraded)",
        "fr": "Card Market Price (Ungraded)",
        "es": "Card Market Price (Ungraded)",
        "ar": "Card Market Price (Ungraded)"
      }
    },
    {
      "id": "gradingCost",
      "label": "Grading Cost",
      "type": "number",
      "unit": "currency",
      "default": 20,
      "businessContext": "Total cost to submit card for professional grading",
      "label_i18n": {
        "en": "Grading Cost",
        "tr": "Grading Cost",
        "de": "Grading Cost",
        "fr": "Grading Cost",
        "es": "Grading Cost",
        "ar": "Grading Cost"
      }
    },
    {
      "id": "gradeMultiplier",
      "label": "Expected Grade Multiplier",
      "type": "number",
      "unit": "ratio",
      "default": 2.5,
      "businessContext": "Factor by which card value multiplies upon achieving the expected grade",
      "label_i18n": {
        "en": "Expected Grade Multiplier",
        "tr": "Expected Grade Multiplier",
        "de": "Expected Grade Multiplier",
        "fr": "Expected Grade Multiplier",
        "es": "Expected Grade Multiplier",
        "ar": "Expected Grade Multiplier"
      }
    },
    {
      "id": "shippingCost",
      "label": "Shipping & Insurance",
      "type": "number",
      "unit": "currency",
      "default": 10,
      "businessContext": "Combined shipping and insurance cost for round-trip",
      "label_i18n": {
        "en": "Shipping & Insurance",
        "tr": "Shipping & Insurance",
        "de": "Shipping & Insurance",
        "fr": "Shipping & Insurance",
        "es": "Shipping & Insurance",
        "ar": "Shipping & Insurance"
      }
    },
    {
      "id": "sellingFee",
      "label": "Selling Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Platform or auction house fee as a percentage of the final sale price",
      "label_i18n": {
        "en": "Selling Fee (%)",
        "tr": "Selling Fee (%)",
        "de": "Selling Fee (%)",
        "fr": "Selling Fee (%)",
        "es": "Selling Fee (%)",
        "ar": "Selling Fee (%)"
      }
    }
  ],
  "formulas": {
    "totalCost": "gradingCost + shippingCost",
    "gradedValue": "cardPrice * gradeMultiplier",
    "feeAmount": "gradedValue * sellingFee / 100",
    "netProfit": "gradedValue - totalCost - feeAmount",
    "roi": "(netProfit / totalCost) * 100"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "totalCost",
      "gradedValue",
      "feeAmount",
      "roi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roi",
    "unit": "currency"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "procurement-supply-chain",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

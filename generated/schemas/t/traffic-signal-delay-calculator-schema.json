  "inputs": [
    {
      "id": "donguSuresi",
      "label": "Cycle Length (s)",
      "type": "number",
      "unit": "s",
      "default": 90,
      "min": 0,
      "businessContext": "Signal cycle length."
    },
    {
      "id": "yesilSure",
      "label": "Green Time (s)",
      "type": "number",
      "unit": "s",
      "default": 30,
      "min": 0,
      "businessContext": "Green signal duration."
    },
    {
      "id": "akisHizi",
      "label": "Traffic Flow (veh/s)",
      "type": "number",
      "unit": "veh/s",
      "default": 0.3,
      "min": 0,
      "businessContext": "Arrival flow rate."
    },
    {
      "id": "doygunAkis",
      "label": "Saturation Flow (veh/s)",
      "type": "number",
      "unit": "veh/s",
      "default": 0.5,
      "min": 0,
      "businessContext": "Maximum discharge rate."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(donguSuresi * Math.pow((1 - yesilSure/Math.max(1,donguSuresi)), 2)) / Math.max(0.0001, (2 * (1 - (akisHizi/Math.max(0.0001, doygunAkis)))))"
  },

      "id": "afterRepairValue",
      "label": "After Repair Value (ARV)",
      "type": "number",
      "unit": "USD",
      "default": 150000,
      "businessContext": "Estimated market value of the property after rehabilitation is complete.",
      "label_i18n": {
        "en": "After Repair Value (ARV)",
        "tr": "After Repair Value (ARV)",
        "de": "After Repair Value (ARV)",
        "fr": "After Repair Value (ARV)",

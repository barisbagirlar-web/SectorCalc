      }
    },
    {
      "id": "downPaymentPercent",
      "label": "Down Payment (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage of purchase price paid upfront as down payment.",
      "label_i18n": {
        "en": "Down Payment (%)",
        "tr": "Down Payment (%)",
        "de": "Down Payment (%)",
        "fr": "Down Payment (%)",
        "es": "Down Payment (%)",
        "ar": "Down Payment (%)"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Annual interest rate on the mortgage used for purchase.",
      "label_i18n": {
        "en": "Interest Rate (%)",
        "tr": "Interest Rate (%)",
        "de": "Interest Rate (%)",
        "fr": "Interest Rate (%)",
        "es": "Interest Rate (%)",
        "ar": "Interest Rate (%)"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term (Years)",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Duration of the mortgage loan in years.",
      "label_i18n": {
        "en": "Loan Term (Years)",
        "tr": "Loan Term (Years)",
        "de": "Loan Term (Years)",
        "fr": "Loan Term (Years)",
        "es": "Loan Term (Years)",
        "ar": "Loan Term (Years)"
      }
    },
    {
      "id": "monthlyExpenses",
      "label": "Monthly Expenses",
      "type": "number",
      "unit": "USD",
      "default": 500,
      "businessContext": "Total monthly operating expenses including taxes, insurance, management, maintenance, and vacancy allowance.",
      "label_i18n": {
        "en": "Monthly Expenses",
        "tr": "Monthly Expenses",
        "de": "Monthly Expenses",
        "fr": "Monthly Expenses",
        "es": "Monthly Expenses",
        "ar": "Monthly Expenses"
      }
    }
  ],
  "formulas": {
    "downPayment": "purchasePrice * (downPaymentPercent / 100)",
    "loanAmount": "purchasePrice - downPayment",
    "monthlyInterestRate": "interestRate / 100 / 12",
    "numberOfPayments": "loanTermYears * 12",
    "totalInvestment": "downPayment + rehabCost"
  },
  "outputs": {
    "primary": "totalInvestment",
    "breakdown": [
      "monthlyCashFlow",
      "totalInvestment",
      "monthlyMortgagePayment"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "cashOnCashReturn"
  },

  "formulas": {
    "total_load": "load_per_area * deck_width * span_length",
    "max_moment": "total_load * span_length / 8",
    "section_modulus_required": "max_moment * 1000 / (steel_yield_strength / safety_factor)",
    "beam_width_estimate": "section_modulus_required * 6 / (beam_depth ** 2) / 1000"
  },
  "outputs": {
    "primary": "beam_width_estimate",
    "breakdown": [
      "Total Load (kN): total_load",
      "Max Moment (kN·m): max_moment",
      "Required Section Modulus (cm³): section_modulus_required",
      "Estimated Beam Width (mm): beam_width_estimate"

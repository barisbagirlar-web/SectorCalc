        "es": "¿El cónyuge es beneficiario?",
        "ar": "هل المستحق زوج؟"
      },
      "businessContext_i18n": {
        "en": "Whether the beneficiary is a spouse (1: Yes, 0: No)",
        "tr": "Hak sahibinin eş olup olmadığı (1: Evet, 0: Hayır)",
        "de": "Gibt an, ob der Anspruchsberechtigte der Ehepartner ist (1: Ja, 0: Nein)",
        "fr": "Le conjoint est-il le bénéficiaire (1: Oui, 0: Non)",
        "es": "Indica si el beneficiario es el cónyuge (1: Sí, 0: No)",
        "ar": "هل المستحق زوج (1: نعم، 0: لا)"
      }
    }
  ],
  "formulas": {
    "baseBenefit": "averageMonthlyEarnings * 0.5",
    "childBenefit": "numberOfChildren * averageMonthlyEarnings * 0.1",
    "spouseExtra": "isSpouse * (survivorAge > 50 ? averageMonthlyEarnings * 0.2 : 0)",
    "totalMonthlyBenefit": "baseBenefit + childBenefit + spouseExtra"
  },
  "outputs": {
    "primary": "totalMonthlyBenefit",
    "breakdown": [
      "baseBenefit",
      "childBenefit",
      "spouseExtra"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMonthlyBenefit",
    "unit": "TL"
  },

  "formulas": {
    "baseBenefit": "averageMonthlyEarnings * 0.5",
    "childBenefit": "numberOfChildren * averageMonthlyEarnings * 0.1",
    "spouseExtra": "isSpouse * (survivorAge > 50 ? averageMonthlyEarnings * 0.2 : 0)",
    "totalMonthlyBenefit": "baseBenefit + childBenefit + spouseExtra"
  },

        "tr": "Bir standart içkinin saf alkol cinsinden tanımı (gram)"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity (units)",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of identical drinks consumed",
      "label_i18n": {
        "en": "Quantity (units)",
        "tr": "Miktar (birim)",

  "formulas": {
    "TaktTime": "AvailableTime / CustomerDemand",
    "CycleTimeFlexibility": "MAX(CycleTime_i) - MIN(CycleTime_i)",
    "BalanceLoss": "SUM(TaktTime - CycleTime_i) * LaborRate",
    "CrossTrainingCost": "Operators * TrainingHours * TrainerRate",
    "FlexibilityPremium": "CrossTrainingCost / AnnualProduction",
    "VolumeVariationCost": "IF(Demand > Capacity, (Demand - Capacity) * OvertimeRate, (Capacity - Demand) * IdleLaborCost)"
  },

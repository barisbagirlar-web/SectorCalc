{
  "toolName": "maintenance-cost-calculator",
  "inputs": [
    {
      "id": "laborRate",
      "label": "Hourly Labor Rate",
      "type": "number",
      "unit": "€/hour",
      "default": 50,
      "businessContext": "Cost of one technician per hour including wages and benefits.",
      "label_i18n": {
        "en": "Hourly Labor Rate",
        "tr": "Hourly Labor Rate",
        "de": "Hourly Labor Rate",
        "fr": "Hourly Labor Rate",
        "es": "Hourly Labor Rate",
        "ar": "Hourly Labor Rate"
      }
    },
    {
      "id": "technicians",
      "label": "Number of Technicians",
      "type": "number",
      "unit": "people",
      "default": 2,
      "businessContext": "Number of maintenance personnel assigned per task.",
      "label_i18n": {
        "en": "Number of Technicians",
        "tr": "Number of Technicians",
        "de": "Number of Technicians",
        "fr": "Number of Technicians",
        "es": "Number of Technicians",
        "ar": "Number of Technicians"
      }
    },
    {
      "id": "hoursPerMaintenance",
      "label": "Hours per Maintenance",
      "type": "number",
      "unit": "hours",
      "default": 4,
      "businessContext": "Average time to complete one maintenance task.",
      "label_i18n": {
        "en": "Hours per Maintenance",
        "tr": "Hours per Maintenance",
        "de": "Hours per Maintenance",
        "fr": "Hours per Maintenance",
        "es": "Hours per Maintenance",
        "ar": "Hours per Maintenance"
      }
    },
    {
      "id": "maintenanceFrequency",
      "label": "Maintenance Frequency",
      "type": "number",
      "unit": "events/year",
      "default": 12,
      "businessContext": "Number of maintenance tasks per year.",
      "label_i18n": {
        "en": "Maintenance Frequency",
        "tr": "Maintenance Frequency",
        "de": "Maintenance Frequency",
        "fr": "Maintenance Frequency",
        "es": "Maintenance Frequency",
        "ar": "Maintenance Frequency"
      }
    },
    {
      "id": "partsCostPerMaintenance",
      "label": "Parts Cost per Maintenance",
      "type": "number",
      "unit": "€",
      "default": 200,
      "businessContext": "Cost of spare parts and consumables per maintenance event.",
      "label_i18n": {
        "en": "Parts Cost per Maintenance",
        "tr": "Parts Cost per Maintenance",
        "de": "Parts Cost per Maintenance",
        "fr": "Parts Cost per Maintenance",
        "es": "Parts Cost per Maintenance",
        "ar": "Parts Cost per Maintenance"
      }
    },
    {
      "id": "overheadCostPerMaintenance",
      "label": "Overhead Cost per Maintenance",
      "type": "number",
      "unit": "€",
      "default": 100,
      "businessContext": "Additional costs such as tools, facilities, and indirect expenses per event.",
      "label_i18n": {
        "en": "Overhead Cost per Maintenance",
        "tr": "Overhead Cost per Maintenance",
        "de": "Overhead Cost per Maintenance",
        "fr": "Overhead Cost per Maintenance",
        "es": "Overhead Cost per Maintenance",
        "ar": "Overhead Cost per Maintenance"
      }
    }
  ],
  "formulas": {
    "laborCostPerEvent": "laborRate * technicians * hoursPerMaintenance",
    "totalCostPerEvent": "laborCostPerEvent + partsCostPerMaintenance + overheadCostPerMaintenance",
    "partsCostPerEvent": "partsCostPerMaintenance",
    "overheadCostPerEvent": "overheadCostPerMaintenance",
    "annualMaintenanceCost": "totalCostPerEvent * maintenanceFrequency"
  },
  "outputs": {
    "primary": "annualMaintenanceCost",
    "breakdown": [
      "laborCostPerEvent",
      "partsCostPerEvent",
      "overheadCostPerEvent",
      "totalCostPerEvent"
    ],

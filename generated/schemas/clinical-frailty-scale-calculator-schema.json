      }
    },
    {
      "id": "adl",
      "label": "Günlük Yaşam Aktiviteleri Skoru (0-7)",
      "type": "number",
      "unit": "puan",
      "default": 5,
      "businessContext": "Barthel İndeksi benzeri fonksiyonel bağımsızlık ölçümü (7: tam bağımsız, 0: tam bağımlı)",
      "label_i18n": {
        "en": "Günlük Yaşam Aktiviteleri Skoru (0-7)",
        "tr": "Günlük Yaşam Aktiviteleri Skoru (0-7)",
        "de": "Günlük Yaşam Aktiviteleri Skoru (0-7)",
        "fr": "Günlük Yaşam Aktiviteleri Skoru (0-7)",
        "es": "Günlük Yaşam Aktiviteleri Skoru (0-7)",
        "ar": "Günlük Yaşam Aktiviteleri Skoru (0-7)"
      }
    }
  ],
  "formulas": {
    "cfs": "Math.min(9, Math.max(1, Math.round(1 + Math.max(0, age - 65)/10 * 0.5 + comorbidities * 0.3 + Math.max(0, 7 - adl) * 0.4)))",
    "rawScore": "1 + Math.max(0, age - 65)/10 * 0.5 + comorbidities * 0.3 + Math.max(0, 7 - adl) * 0.4",
    "ageEffect": "Math.max(0, age - 65)/10 * 0.5",
    "comorbidityEffect": "comorbidities * 0.3",
    "adlEffect": "Math.max(0, 7 - adl) * 0.4"
  },
  "outputs": {
    "primary": "cfs",
    "breakdown": [
      "rawScore",
      "ageEffect",
      "comorbidityEffect",
      "adlEffect"
    ]
  },
  "category": "Üretim & İmalat",

{
  "toolName": "loan-affordability-calculator",
  "inputs": [
    {
      "id": "monthlyIncome",
      "label": "Monthly Net Income",
      "type": "number",
      "unit": "EUR",
      "default": 5000,
      "businessContext": "Total monthly net income of the borrower after taxes.",
      "label_i18n": {
        "en": "Monthly Net Income",
        "tr": "Monthly Net Income",
        "de": "Monthly Net Income",
        "fr": "Monthly Net Income",
        "es": "Monthly Net Income",
        "ar": "Monthly Net Income"
      }
    },
    {
      "id": "monthlyExpenses",
      "label": "Monthly Expenses",
      "type": "number",
      "unit": "EUR",
      "default": 2000,
      "businessContext": "Total monthly living expenses excluding any loan payments.",
      "label_i18n": {
        "en": "Monthly Expenses",
        "tr": "Monthly Expenses",
        "de": "Monthly Expenses",
        "fr": "Monthly Expenses",
        "es": "Monthly Expenses",
        "ar": "Monthly Expenses"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual nominal interest rate for the loan.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "The repayment period in years.",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    },
    {
      "id": "loanAmount",
      "label": "Desired Loan Amount",
      "type": "number",
      "unit": "EUR",
      "default": 200000,
      "businessContext": "The total loan amount the borrower wishes to take.",
      "label_i18n": {
        "en": "Desired Loan Amount",
        "tr": "Desired Loan Amount",
        "de": "Desired Loan Amount",
        "fr": "Desired Loan Amount",
        "es": "Desired Loan Amount",
        "ar": "Desired Loan Amount"
      }
    }
  ],
  "formulas": {
    "monthlyInterestRate": "annualInterestRate / 100 / 12",
    "numberOfPayments": "loanTermYears * 12",
    "netIncome": "monthlyIncome - monthlyExpenses"
  },
  "outputs": {
    "primary": "netIncome",
    "breakdown": [
      "netIncome",
      "monthlyPayment",
      "maxAffordableLoan"
    ],

      }
    },
    {
      "id": "assets",
      "label": "Total Assets",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "businessContext": "Book value of total tangible and intangible assets.",
      "label_i18n": {
        "en": "Total Assets",
        "tr": "Total Assets",
        "de": "Total Assets",
        "fr": "Total Assets",
        "es": "Total Assets",
        "ar": "Total Assets"
      }
    },
    {
      "id": "liabilities",
      "label": "Total Liabilities",
      "type": "number",
      "unit": "USD",
      "default": 200000,
      "businessContext": "Book value of total outstanding debt and other obligations.",
      "label_i18n": {
        "en": "Total Liabilities",
        "tr": "Total Liabilities",
        "de": "Total Liabilities",
        "fr": "Total Liabilities",
        "es": "Total Liabilities",
        "ar": "Total Liabilities"
      }
    }
  ],
  "formulas": {
    "netProfit": "revenue - expenses",
    "dcfValuation": "netProfit / (discountRate/100 - growthRate/100)",
    "assetBasedValuation": "assets - liabilities",
    "businessValuation": "(dcfValuation + assetBasedValuation) / 2"
  },
  "outputs": {
    "primary": "businessValuation",
    "breakdown": [
      "dcfValuation",
      "assetBasedValuation"

  "formulas": {
    "EV": "Range_Avg * d2_star",
    "AV": "SQRT((Range_Ops / d2_star)^2 - (EV^2 / (n * r)))",
    "GRR": "SQRT(EV^2 + AV^2)",
    "PV": "Range_Parts / d2_star",
    "TV": "SQRT(GRR^2 + PV^2)",
    "PctGRR": "(GRR / TV) * 100",
    "CostError": "(FalseAcc * EscapeCost) + (FalseRej * ScrapCost)",
    "OptTol": "GRR * 6",
    "FinImpact": "PctGRR * TotalQualCost"
  },
  "outputs": {
    "primary": "FinImpact",
    "unit": "USD",
    "breakdown": {
      "EV": "EV",

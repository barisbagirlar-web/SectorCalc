{
  "toolName": "swimming-turn-calculator",
  "inputs": [
    {
      "id": "approachDistance",
      "label": "Approach Distance",
      "type": "number",
      "unit": "m",
      "default": 1.5,
      "businessContext": "Distance from wall where the swimmer initiates the turn",
      "label_i18n": {
        "en": "Approach Distance",
        "tr": "Approach Distance",
        "de": "Approach Distance",
        "fr": "Approach Distance",
        "es": "Approach Distance",
        "ar": "Approach Distance"
      }
    },
    {
      "id": "approachVelocity",
      "label": "Approach Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 2,
      "businessContext": "Velocity of the swimmer during the approach",
      "label_i18n": {
        "en": "Approach Velocity",
        "tr": "Approach Velocity",
        "de": "Approach Velocity",
        "fr": "Approach Velocity",
        "es": "Approach Velocity",
        "ar": "Approach Velocity"
      }
    },
    {
      "id": "turnTime",
      "label": "Turn Execution Time",
      "type": "number",
      "unit": "s",
      "default": 1.2,
      "businessContext": "Time taken to execute the turn on the wall",
      "label_i18n": {
        "en": "Turn Execution Time",
        "tr": "Turn Execution Time",
        "de": "Turn Execution Time",
        "fr": "Turn Execution Time",
        "es": "Turn Execution Time",
        "ar": "Turn Execution Time"
      }
    },
    {
      "id": "pushOffVelocity",
      "label": "Push-off Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 2.5,
      "businessContext": "Velocity of the swimmer after push-off from the wall",

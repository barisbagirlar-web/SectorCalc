        "en": "Push-off Velocity",
        "tr": "Push-off Velocity",
        "de": "Push-off Velocity",
        "fr": "Push-off Velocity",
        "es": "Push-off Velocity",
        "ar": "Push-off Velocity"
      }
    },
    {
      "id": "breakOutDistance",
      "label": "Breakout Distance",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Distance from wall to the point of breakout (first stroke)",
      "label_i18n": {
        "en": "Breakout Distance",
        "tr": "Breakout Distance",
        "de": "Breakout Distance",
        "fr": "Breakout Distance",
        "es": "Breakout Distance",
        "ar": "Breakout Distance"
      }
    }
  ],
  "formulas": {
    "totalTurnTime": "(approachDistance / approachVelocity) + turnTime + (breakOutDistance / pushOffVelocity)",
    "approachTime": "approachDistance / approachVelocity",
    "turnExecutionTime": "turnTime",
    "pushOffTime": "breakOutDistance / pushOffVelocity"
  },
  "outputs": {
    "primary": "totalTurnTime",

{
  "toolName": "mbps-to-gbps-calculator",
  "inputs": [
    {
      "id": "mbpsValue",
      "label": "Speed in Mbps",
      "type": "number",
      "unit": "Mbps",
      "default": 1000,
      "businessContext": "Measured or nominal data rate in megabits per second.",
      "label_i18n": {
        "en": "Speed in Mbps",
        "tr": "Speed in Mbps",
        "de": "Speed in Mbps",
        "fr": "Speed in Mbps",
        "es": "Speed in Mbps",
        "ar": "Speed in Mbps"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "Mbps per Gbps",
      "default": 1000,
      "businessContext": "Standard conversion: 1 Gbps = 1000 Mbps. Adjust for non-standard units.",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "decimalPrecision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "places",
      "default": 2,
      "businessContext": "Output precision in decimal places for reporting consistency.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "calibrationOffset",
      "label": "Calibration Offset (Mbps)",
      "type": "number",
      "unit": "Mbps",
      "default": 0,
      "businessContext": "Calibration correction value added to the input. Typically 0 for uncalibrated readings.",
      "label_i18n": {
        "en": "Calibration Offset (Mbps)",
        "tr": "Calibration Offset (Mbps)",
        "de": "Calibration Offset (Mbps)",
        "fr": "Calibration Offset (Mbps)",
        "es": "Calibration Offset (Mbps)",
        "ar": "Calibration Offset (Mbps)"
      }
    },
    {
      "id": "measurementId",
      "label": "Measurement ID",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "For traceability to measurement records, set to 0 if not applicable.",
      "label_i18n": {
        "en": "Measurement ID",
        "tr": "Measurement ID",
        "de": "Measurement ID",
        "fr": "Measurement ID",
        "es": "Measurement ID",
        "ar": "Measurement ID"
      }
    }
  ],
  "formulas": {
    "adjustedMbps": "mbpsValue + calibrationOffset",
    "rawGbps": "(mbpsValue + calibrationOffset) / conversionFactor",
    "primaryGbps": "Math.round(((mbpsValue + calibrationOffset) / conversionFactor) * Math.pow(10, decimalPrecision)) / Math.pow(10, decimalPrecision)"
  },
  "outputs": {
    "primary": "primaryGbps",
    "breakdown": [
      "adjustedMbps",
      "rawGbps"
    ]
  },

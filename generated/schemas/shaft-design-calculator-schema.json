{
  "toolName": "shaft-design-calculator",
  "inputs": [
    {
      "id": "torque",
      "label": "Torque",
      "type": "number",
      "unit": "Nm",
      "default": 100,
      "businessContext": "Applied torsional moment on shaft.",
      "label_i18n": {
        "en": "Torque",
        "tr": "Torque",
        "de": "Torque",
        "fr": "Torque",
        "es": "Torque",
        "ar": "Torque"
      }
    },
    {
      "id": "bendingMoment",
      "label": "Bending Moment",
      "type": "number",
      "unit": "Nm",
      "default": 50,
      "businessContext": "Maximum bending moment on shaft.",
      "label_i18n": {
        "en": "Bending Moment",
        "tr": "Bending Moment",
        "de": "Bending Moment",
        "fr": "Bending Moment",
        "es": "Bending Moment",
        "ar": "Bending Moment"
      }
    },
    {
      "id": "diameter",
      "label": "Shaft Diameter",
      "type": "number",
      "unit": "mm",
      "default": 30,
      "businessContext": "Diameter of the shaft at the critical section.",
      "label_i18n": {
        "en": "Shaft Diameter",
        "tr": "Shaft Diameter",
        "de": "Shaft Diameter",
        "fr": "Shaft Diameter",
        "es": "Shaft Diameter",
        "ar": "Shaft Diameter"
      }
    },
    {
      "id": "yieldStrength",
      "label": "Material Yield Strength",
      "type": "number",
      "unit": "MPa",
      "default": 250,
      "businessContext": "Yield strength of shaft material.",
      "label_i18n": {
        "en": "Material Yield Strength",
        "tr": "Material Yield Strength",
        "de": "Material Yield Strength",
        "fr": "Material Yield Strength",
        "es": "Material Yield Strength",
        "ar": "Material Yield Strength"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Required safety factor against yielding.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "bendingStress": "(bendingMoment * 1000 * 32) / (Math.PI * Math.pow(diameter, 3))",
    "torsionalShear": "(torque * 1000 * 16) / (Math.PI * Math.pow(diameter, 3))",
    "vonMises": "Math.sqrt(Math.pow(bendingStress, 2) + 3 * Math.pow(torsionalShear, 2))",
    "allowable": "yieldStrength / safetyFactor",
    "margin": "((allowable - vonMises) / allowable) * 100"
  },
  "outputs": {
    "primary": "margin",
    "breakdown": [
      "bendingStress",
      "torsionalShear",
      "vonMises",
      "allowable"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Diğer",
  "premiumRequired": false,

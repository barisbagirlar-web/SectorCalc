{
  "toolName": "pace-per-kilometer-calculator",
  "inputs": [
    {
      "id": "totalMinutes",
      "label": "Total Time (minutes)",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Total running or walking time in minutes."
    },
    {
      "id": "totalSeconds",
      "label": "Total Time (seconds)",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Additional seconds beyond total minutes."
    },
    {
      "id": "distanceKm",
      "label": "Distance (kilometers)",
      "type": "number",
      "unit": "km",
      "default": 5,
      "businessContext": "Total distance covered in kilometers."
    }
  ],
  "formulas": {
    "totalTimeSeconds": "totalMinutes * 60 + totalSeconds",
    "paceSecondsPerKm": "totalTimeSeconds / distanceKm",
    "paceMinutes": "Math.floor(paceSecondsPerKm / 60)",
    "paceSeconds": "Math.round(paceSecondsPerKm % 60)",
    "paceFormatted": "paceMinutes + ':' + (paceSeconds < 10 ? '0' : '') + paceSeconds"
  },
  "outputs": {
    "primary": "paceFormatted",
    "breakdown": [
      "paceMinutes + ' min ' + paceSeconds + ' sec per km'",
      "paceSecondsPerKm + ' seconds per km'"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

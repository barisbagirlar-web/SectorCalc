  "formulas": {
    "circular_input": "recycled_input + reused_input",
    "circular_output": "recycled_waste + reused_waste",
    "linear_output": "total_waste_generated - circular_output",
    "total_throughput": "total_material_input + total_waste_generated",
    "circularity_index": "((circular_input + circular_output) / total_throughput) * 100",
    "reuse_rate": "((reused_input + reused_waste) / total_throughput) * 100",
    "recycling_rate": "((recycled_input + recycled_waste) / total_throughput) * 100",
    "landfill_rate": "((total_waste_generated - circular_output) / total_throughput) * 100"
  },
  "outputs": {
    "primary": "circularity_index",
    "breakdown": [

{
  "toolName": "compressible-flow-properties-calculator",
  "inputs": [
    {
      "id": "machNumber",
      "label": "Mach Number",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.5,
      "businessContext": "Mach number of the flow",
      "label_i18n": {
        "en": "Mach Number",
        "tr": "Mach Number",
        "de": "Mach Number",
        "fr": "Mach Number",
        "es": "Mach Number",
        "ar": "Mach Number"
      }
    },
    {
      "id": "gamma",
      "label": "Specific Heat Ratio",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.4,
      "businessContext": "Specific heat ratio (Cp/Cv)",
      "label_i18n": {
        "en": "Specific Heat Ratio",
        "tr": "Specific Heat Ratio",
        "de": "Specific Heat Ratio",
        "fr": "Specific Heat Ratio",
        "es": "Specific Heat Ratio",
        "ar": "Specific Heat Ratio"
      }
    },
    {
      "id": "staticTemperature",
      "label": "Static Temperature",
      "type": "number",
      "unit": "K",
      "default": 300,
      "businessContext": "Static temperature of the fluid",
      "label_i18n": {
        "en": "Static Temperature",
        "tr": "Static Temperature",
        "de": "Static Temperature",
        "fr": "Static Temperature",
        "es": "Static Temperature",
        "ar": "Static Temperature"
      }
    },
    {
      "id": "staticPressure",
      "label": "Static Pressure",
      "type": "number",
      "unit": "Pa",
      "default": 101325,
      "businessContext": "Static pressure of the fluid",
      "label_i18n": {
        "en": "Static Pressure",
        "tr": "Static Pressure",
        "de": "Static Pressure",
        "fr": "Static Pressure",
        "es": "Static Pressure",
        "ar": "Static Pressure"
      }
    },
    {
      "id": "gasConstant",
      "label": "Specific Gas Constant",
      "type": "number",
      "unit": "J/(kg·K)",
      "default": 287,
      "businessContext": "Specific gas constant of the fluid",
      "label_i18n": {
        "en": "Specific Gas Constant",
        "tr": "Specific Gas Constant",
        "de": "Specific Gas Constant",
        "fr": "Specific Gas Constant",
        "es": "Specific Gas Constant",
        "ar": "Specific Gas Constant"
      }
    }
  ],
  "formulas": {
    "stagnationTemperature": "staticTemperature * (1 + ((gamma - 1) / 2) * machNumber ** 2)",
    "stagnationPressure": "staticPressure * (1 + ((gamma - 1) / 2) * machNumber ** 2) ** (gamma / (gamma - 1))",
    "density": "staticPressure / (gasConstant * staticTemperature)"
  },
  "outputs": {
    "primary": "stagnationPressure",
    "breakdown": [
      "stagnationTemperature",
      "speedOfSound",
      "velocity",
      "density"
    ],
    "hiddenLossDrivers": [],

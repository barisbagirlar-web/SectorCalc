{
  "toolName": "butterworth-filter-calculator",
  "inputs": [
    {
      "id": "order",
      "label": "Filter Order (n)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Order of the Butterworth filter (positive integer). Higher order gives steeper roll-off.",
      "label_i18n": {
        "en": "Filter Order (n)",
        "tr": "Filter Order (n)",
        "de": "Filter Order (n)",
        "fr": "Filter Order (n)",
        "es": "Filter Order (n)",
        "ar": "Filter Order (n)"
      }
    },
    {
      "id": "cutoffHz",
      "label": "Cutoff Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1000,
      "businessContext": "Cutoff frequency at -3 dB point.",
      "label_i18n": {
        "en": "Cutoff Frequency",
        "tr": "Cutoff Frequency",
        "de": "Cutoff Frequency",
        "fr": "Cutoff Frequency",
        "es": "Cutoff Frequency",
        "ar": "Cutoff Frequency"
      }
    },
    {
      "id": "frequencyHz",
      "label": "Frequency of Interest",
      "type": "number",
      "unit": "Hz",
      "default": 2000,
      "businessContext": "Frequency at which to evaluate the filter response.",
      "label_i18n": {
        "en": "Frequency of Interest",
        "tr": "Frequency of Interest",
        "de": "Frequency of Interest",
        "fr": "Frequency of Interest",
        "es": "Frequency of Interest",
        "ar": "Frequency of Interest"
      }
    },
    {
      "id": "gain",
      "label": "Passband Gain",
      "type": "number",
      "unit": "V/V",
      "default": 1,
      "businessContext": "Linear gain in the passband (for active filters). Typically 1 for unity-gain Sallen-Key.",
      "label_i18n": {
        "en": "Passband Gain",
        "tr": "Passband Gain",
        "de": "Passband Gain",
        "fr": "Passband Gain",
        "es": "Passband Gain",
        "ar": "Passband Gain"
      }
    }
  ],
  "formulas": {
    "attenuationFactor": "1 / Math.sqrt(1 + Math.pow(frequencyHz / cutoffHz, 2 * order))",
    "magnitude": "gain * attenuationFactor",
    "attenuation_dB": "20 * Math.log10(magnitude)"
  },
  "outputs": {
    "primary": "attenuation_dB",
    "breakdown": [
      "attenuationFactor",
      "magnitude"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Telekomünikasyon",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "telekom",
  "profession": "Ağ Mühendisi",
  "categoryId": "conversion"
}

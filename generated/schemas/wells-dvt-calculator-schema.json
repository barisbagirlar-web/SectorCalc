{
  "toolName": "wells-dvt-calculator",
  "inputs": [
    {
      "id": "totalDepth",
      "label": "Total Depth",
      "type": "number",
      "unit": "m",
      "default": 2000,
      "businessContext": "The total measured depth of the wellbore from surface to bottom.",
      "label_i18n": {
        "en": "Total Depth",
        "tr": "Total Depth",
        "de": "Total Depth",
        "fr": "Total Depth",
        "es": "Total Depth",
        "ar": "Total Depth"
      }
    },
    {
      "id": "shoeDepth",
      "label": "Casing Shoe Depth",
      "type": "number",
      "unit": "m",
      "default": 1500,
      "businessContext": "The measured depth of the casing shoe.",
      "label_i18n": {
        "en": "Casing Shoe Depth",
        "tr": "Casing Shoe Depth",
        "de": "Casing Shoe Depth",
        "fr": "Casing Shoe Depth",
        "es": "Casing Shoe Depth",
        "ar": "Casing Shoe Depth"
      }
    },
    {
      "id": "casingDiameter",
      "label": "Casing Inner Diameter",
      "type": "number",
      "unit": "mm",
      "default": 177.8,
      "businessContext": "Inner diameter of the casing section.",
      "label_i18n": {
        "en": "Casing Inner Diameter",
        "tr": "Casing Inner Diameter",
        "de": "Casing Inner Diameter",
        "fr": "Casing Inner Diameter",
        "es": "Casing Inner Diameter",
        "ar": "Casing Inner Diameter"
      }
    },
    {
      "id": "openHoleDiameter",
      "label": "Open Hole Diameter",
      "type": "number",
      "unit": "mm",
      "default": 215.9,
      "businessContext": "Diameter of the open hole section below the shoe.",
      "label_i18n": {
        "en": "Open Hole Diameter",
        "tr": "Open Hole Diameter",
        "de": "Open Hole Diameter",
        "fr": "Open Hole Diameter",
        "es": "Open Hole Diameter",
        "ar": "Open Hole Diameter"
      }
    },
    {
      "id": "fluidDensity",
      "label": "Fluid Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1200,
      "businessContext": "Density of the wellbore fluid.",
      "label_i18n": {
        "en": "Fluid Density",
        "tr": "Fluid Density",
        "de": "Fluid Density",
        "fr": "Fluid Density",
        "es": "Fluid Density",
        "ar": "Fluid Density"
      }
    }
  ],
  "formulas": {
    "totalVolume": "Math.PI * ((casingDiameter/2000) ** 2 * shoeDepth + (openHoleDiameter/2000) ** 2 * (totalDepth - shoeDepth))",
    "volumeCasing": "Math.PI * (casingDiameter/2000) ** 2 * shoeDepth",
    "pressureShoe": "fluidDensity * 9.81 * shoeDepth / 1e5"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "volumeCasing",
      "pressureShoe"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pressureShoe"
  },

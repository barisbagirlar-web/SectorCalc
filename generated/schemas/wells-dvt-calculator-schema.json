{
  "toolName": "wells-dvt-calculator",
  "inputs": [
    {
      "id": "totalDepth",
      "label": "Total Depth",
      "type": "number",
      "unit": "m",
      "default": 2000,
      "businessContext": "The total measured depth of the wellbore from surface to bottom."
    },
    {
      "id": "shoeDepth",
      "label": "Casing Shoe Depth",
      "type": "number",
      "unit": "m",
      "default": 1500,
      "businessContext": "The measured depth of the casing shoe."
    },
    {
      "id": "casingDiameter",
      "label": "Casing Inner Diameter",
      "type": "number",
      "unit": "mm",
      "default": 177.8,
      "businessContext": "Inner diameter of the casing section."
    },
    {
      "id": "openHoleDiameter",
      "label": "Open Hole Diameter",
      "type": "number",
      "unit": "mm",
      "default": 215.9,
      "businessContext": "Diameter of the open hole section below the shoe."
    },
    {
      "id": "fluidDensity",
      "label": "Fluid Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1200,
      "businessContext": "Density of the wellbore fluid."
    }
  ],
  "formulas": {
    "totalVolume": "Math.PI * ((casingDiameter/2000) ** 2 * shoeDepth + (openHoleDiameter/2000) ** 2 * (totalDepth - shoeDepth))",
    "volumeCasing": "Math.PI * (casingDiameter/2000) ** 2 * shoeDepth",
    "pressureShoe": "fluidDensity * 9.81 * shoeDepth / 1e5"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "volumeCasing",
      "pressureShoe"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

  "formulas": {
    "transportTotal": "flightCostPerPerson * travelers",
    "accommodationTotal": "hotelCostPerNight * days",
    "foodTotal": "dailyFoodBudgetPerPerson * travelers * days",
    "activitiesTotal": "dailyActivityBudgetPerPerson * travelers * days",
    "grandTotal": "transportTotal + accommodationTotal + foodTotal + activitiesTotal"
  },
  "outputs": {
    "primary": "grandTotal",
    "breakdown": [
      "transportTotal",
      "accommodationTotal",
      "foodTotal",
      "activitiesTotal"

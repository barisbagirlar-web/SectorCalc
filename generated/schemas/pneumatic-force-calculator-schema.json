  "formulas": {
    "normalized_product": "systemPressure * boreDiameter * rodDiameter * cylinderCount",
    "result": "systemPressure * boreDiameter * rodDiameter * cylinderCount * (safetyFactor * (efficiency / 100))",
    "adjustment_factor": "safetyFactor * (efficiency / 100)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "normalized_product",
      "adjustment_factor"
    ],

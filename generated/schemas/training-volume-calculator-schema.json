{
  "toolName": "training-volume-calculator",
  "inputs": [
    {
      "id": "sets",
      "label": "Sets",
      "type": "number",
      "unit": "sets",
      "default": 3,
      "businessContext": "Number of sets performed"
    },
    {
      "id": "reps",
      "label": "Repetitions",
      "type": "number",
      "unit": "reps",
      "default": 10,
      "businessContext": "Number of repetitions per set"
    },
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 50,
      "businessContext": "Weight lifted per repetition in kilograms"
    },
    {
      "id": "intensityFactor",
      "label": "Intensity Factor",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Intensity factor accounting for exercise difficulty (1.0 = standard)"
    }
  ],
  "formulas": {
    "totalReps": "sets * reps",
    "totalWeightLifted": "sets * reps * weight",
    "trainingVolume": "sets * reps * weight * intensityFactor"
  },
  "outputs": {
    "primary": "trainingVolume",
    "breakdown": [
      "totalReps",
      "totalWeightLifted"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
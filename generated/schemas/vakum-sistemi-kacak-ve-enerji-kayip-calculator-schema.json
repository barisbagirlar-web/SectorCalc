{
  "toolName": "vakum-sistemi-kacak-ve-enerji-kayip-calculator",
  "inputs": [
    {
      "id": "systemVolume",
      "label": "Sistem Hacmi",
      "type": "number",
      "unit": "m³",
      "default": 10,
      "min": 0.1,
      "max": 10000,
      "options": null,
      "businessContext": "Vakum sisteminin toplam hacmi. ISO 21360-1:2020 standardına göre vakum sistemlerinin sınıflandırılmasında kullanılır."
    },
    {
      "id": "operatingPressure",
      "label": "İşletme Basıncı",
      "type": "number",
      "unit": "mbar",
      "default": 100,
      "min": 0.001,
      "max": 1000,
      "options": null,
      "businessContext": "Sistemin normal çalışma basıncı. Vakum teknolojisinde temel parametre."
    },
    {
      "id": "leakRate",
      "label": "Kaçak Oranı",
      "type": "number",
      "unit": "mbar·L/s",
      "default": 0.1,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Sistemdeki toplam kaçak miktarı. ISO 21360-2:2020'ye göre kaçak testi ile belirlenir."
    },
    {
      "id": "pumpPower",
      "label": "Pompa Gücü",
      "type": "number",
      "unit": "kW",
      "default": 5,
      "min": 0.1,
      "max": 500,
      "options": null,
      "businessContext": "Vakum pompasının nominal gücü. Enerji tüketiminin ana belirleyicisi."
    },
    {
      "id": "electricityCost",
      "label": "Elektrik Birim Maliyeti",
      "type": "number",
      "unit": "USD/kWh",
      "default": 0.12,
      "min": 0.01,
      "max": 1,
      "options": null,
      "businessContext": "Bölgesel elektrik fiyatı. Enerji maliyeti hesaplamalarında kullanılır."
    },
    {
      "id": "operatingHoursPerDay",
      "label": "Günlük Çalışma Saati",
      "type": "number",
      "unit": "saat/gün",
      "default": 24,
      "min": 0,
      "max": 24,
      "options": null,
      "businessContext": "Sistemin günlük çalışma süresi. Enerji tüketimi hesaplamasında zaman faktörü."
    },
    {
      "id": "operatingDaysPerYear",
      "label": "Yıllık Çalışma Günü",
      "type": "number",
      "unit": "gün/yıl",
      "default": 365,
      "min": 1,
      "max": 365,
      "options": null,
      "businessContext": "Sistemin yıllık çalışma günü sayısı. Yıllık maliyet hesaplaması için."
    },
    {
      "id": "pumpEfficiency",
      "label": "Pompa Verimi",
      "type": "number",
      "unit": "%",
      "default": 80,
      "min": 10,
      "max": 100,
      "options": null,
      "businessContext": "Pompanın enerji dönüşüm verimi. ISO 50001 enerji yönetimi standardı kapsamında değerlendirilir."
    },
    {
      "id": "leakReductionPotential",
      "label": "Kaçak Azaltma Potansiyeli",
      "type": "number",
      "unit": "%",
      "default": 50,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Kaçakların onarım ile ne kadar azaltılabileceği. Endüstriyel deneyimlere dayanır."
    },
    {
      "id": "repairCost",
      "label": "Onarım Maliyeti",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "min": 0,
      "max": 100000,
      "options": null,
      "businessContext": "Kaçakların onarımı için tahmini maliyet. Yatırım geri dönüş hesaplamasında kullanılır."
    }
  ],
  "validation": {
    "rules": [
      "operatingPressure > 0",
      "leakRate >= 0",
      "pumpPower > 0",
      "electricityCost > 0",
      "operatingHoursPerDay >= 0 && operatingHoursPerDay <= 24",
      "operatingDaysPerYear >= 1 && operatingDaysPerYear <= 365",
      "pumpEfficiency >= 10 && pumpEfficiency <= 100",
      "leakReductionPotential >= 0 && leakReductionPotential <= 100",
      "repairCost >= 0"
    ],
    "thresholds": {
      "leakRate": "leakRate > 1 ? 'Kritik kaçak seviyesi' : (leakRate > 0.5 ? 'Yüksek kaçak' : 'Normal')",
      "pumpEfficiency": "pumpEfficiency < 60 ? 'Düşük verim' : 'Verimli'"
    }
  },
  "formulas": {
    "annualEnergyConsumption": "pumpPower * operatingHoursPerDay * operatingDaysPerYear / pumpEfficiency * 100",
    "annualEnergyCost": "annualEnergyConsumption * electricityCost",
    "leakPowerLoss": "leakRate * operatingPressure * 0.001 * 1000 / 3600",
    "annualLeakEnergyLoss": "leakPowerLoss * operatingHoursPerDay * operatingDaysPerYear",
    "annualLeakCost": "annualLeakEnergyLoss * electricityCost",
    "potentialSavings": "annualLeakCost * leakReductionPotential / 100",
    "paybackPeriod": "repairCost / potentialSavings",
    "totalAnnualLoss": "annualEnergyCost + annualLeakCost"
  },
  "outputs": {
    "primary": "totalAnnualLoss",
    "breakdown": {
      "annualEnergyCost": "annualEnergyCost",
      "annualLeakCost": "annualLeakCost",
      "potentialSavings": "potentialSavings",
      "paybackPeriod": "paybackPeriod"
    },
    "hiddenLossDrivers": [
      "leakRate > 1 ? 'Kritik kaçak seviyesi' : ''",
      "pumpEfficiency < 60 ? 'Düşük pompa verimi' : ''"
    ],
    "suggestedActions": [
      "leakRate > 0.5 ? 'Kaçak tespit ve onarım programı başlatın' : ''",
      "pumpEfficiency < 60 ? 'Pompa bakımı veya değişimi değerlendirin' : ''",
      "paybackPeriod < 2 ? 'Onarım yatırımı önerilir' : ''"
    ],
    "dataConfidenceAdjusted": "totalAnnualLoss * (1 - 0.1)"
  },
  "premiumFeatures": [
    "PDF raporu",
    "CSV veri dışa aktarımı",
    "Trend analizi (zaman serisi)",
    "Karşılaştırmalı senaryo analizi",
    "Detaylı enerji kaybı raporu"
  ],
  "premiumRequired": true
}

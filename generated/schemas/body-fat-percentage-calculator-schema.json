      }
    },
    {
      "id": "hip",
      "label": "Hip Circumference",
      "type": "number",
      "unit": "cm",
      "default": 90,
      "businessContext": "Hip circumference at the widest point (only for females, set 0 for males)",
      "label_i18n": {
        "en": "Hip Circumference",
        "tr": "Hip Circumference",
        "de": "Hip Circumference",
        "fr": "Hip Circumference",
        "es": "Hip Circumference",
        "ar": "Hip Circumference"
      }
    }
  ],
  "formulas": {
    "bodyFatPercentage": "(gender === 0) ? (86.010 * Math.log(waist - neck) / Math.log(10) - 70.041 * Math.log(height) / Math.log(10) + 36.76) : (163.205 * Math.log(waist + hip - neck) / Math.log(10) - 97.684 * Math.log(height) / Math.log(10) - 78.387)",
    "bmi": "weight / Math.pow(height / 100, 2)",
    "fatMass": "(bodyFatPercentage / 100) * weight"
  },
  "outputs": {
    "primary": "bodyFatPercentage",
    "breakdown": [
      "bmi",
      "fatMass"
    ]
  },

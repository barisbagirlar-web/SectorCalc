      "label": "Waist Circumference",
      "type": "number",
      "unit": "cm",
      "default": 85,
      "businessContext": "Waist circumference measured at the level of the navel",
      "label_i18n": {
        "en": "Waist Circumference",
        "tr": "Waist Circumference",
        "de": "Waist Circumference",
        "fr": "Waist Circumference",
        "es": "Waist Circumference",

        "es": "Tasa de crecimiento anual proyectada del EPS"
      }
    },
    {
      "id": "dividendPerShare",
      "label": "Annual Dividend per Share",
      "type": "number",
      "unit": "currency",
      "default": 2,
      "businessContext": "Dividends paid per share per year",
      "label_i18n": {
        "en": "Annual Dividend per Share",
        "tr": "Hisse Başına Yıllık Temettü",
        "de": "Jährliche Dividende pro Aktie",
        "fr": "Dividende annuel par action",
        "es": "Dividendo anual por acción",
        "ar": "Annual Dividend per Share"
      },
      "businessContext_i18n": {
        "en": "Dividends paid per share per year",
        "tr": "Yıllık ödenen temettü (hisse başına)",
        "de": "Dividenden pro Aktie pro Jahr",
        "fr": "Dividendes versés par action par an",
        "es": "Dividendos pagados por acción por año"
      }
    }
  ],
  "formulas": {
    "peRatio": "marketPrice / earningsPerShare",
    "pegRatio": "growthRate !== 0 ? (marketPrice / earningsPerShare) / growthRate : null",
    "dividendYield": "(dividendPerShare / marketPrice) * 100"
  },
  "outputs": {
    "primary": "peRatio",
    "breakdown": [
      "pegRatio",
      "dividendYield"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dividendYield",
    "unit": "%",

        "es": "EPS diluido de los últimos doce meses (TTM)"
      }
    },
    {
      "id": "growthRate",
      "label": "Expected Growth Rate",
      "type": "number",
      "unit": "percentage",
      "default": 10,
      "businessContext": "Projected annual EPS growth rate",
      "label_i18n": {
        "en": "Expected Growth Rate",
        "tr": "Beklenen Büyüme Oranı",
        "de": "Erwartete Wachstumsrate",

        "fr": "Cours actuel de l'action dans la devise du marché",
        "es": "Precio actual de la acción en moneda de mercado"
      }
    },
    {
      "id": "earningsPerShare",
      "label": "Earnings per Share (EPS)",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "Trailing twelve months (TTM) diluted EPS",
      "label_i18n": {

        "es": "Tasa de crecimiento esperada",
        "ar": "Expected Growth Rate"
      },
      "businessContext_i18n": {
        "en": "Projected annual EPS growth rate",
        "tr": "Projeksiyonlu yıllık EPS büyüme oranı",
        "de": "Prognostizierte jährliche EPS-Wachstumsrate",

      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Weight of raw hides to be tanned.",
      "label_i18n": {
        "en": "Hide Weight",
        "tr": "Hide Weight",
        "de": "Hide Weight",
        "fr": "Hide Weight",
        "es": "Hide Weight",
        "ar": "Hide Weight"
      }
    },
    {
      "id": "desiredCr2O3Offer",
      "label": "Desired Cr₂O₃ Offer",
      "type": "number",
      "unit": "%",
      "default": 6,
      "businessContext": "Percentage of Cr₂O₃ on hide weight, typically 6-8% for chrome tanning.",
      "label_i18n": {
        "en": "Desired Cr₂O₃ Offer",
        "tr": "Desired Cr₂O₃ Offer",
        "de": "Desired Cr₂O₃ Offer",
        "fr": "Desired Cr₂O₃ Offer",
        "es": "Desired Cr₂O₃ Offer",
        "ar": "Desired Cr₂O₃ Offer"
      }
    },
    {
      "id": "bcsCr2O3Content",
      "label": "BCS Cr₂O₃ Content",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Chromium oxide content in basic chromium sulfate powder, typically 25-26%.",
      "label_i18n": {
        "en": "BCS Cr₂O₃ Content",
        "tr": "BCS Cr₂O₃ Content",
        "de": "BCS Cr₂O₃ Content",
        "fr": "BCS Cr₂O₃ Content",
        "es": "BCS Cr₂O₃ Content",
        "ar": "BCS Cr₂O₃ Content"
      }
    },
    {
      "id": "floatVolume",
      "label": "Float Volume",
      "type": "number",
      "unit": "L",
      "default": 2000,
      "businessContext": "Volume of float (water) used for tanning, often 200-300% on hide weight.",
      "label_i18n": {
        "en": "Float Volume",
        "tr": "Float Volume",
        "de": "Float Volume",
        "fr": "Float Volume",
        "es": "Float Volume",
        "ar": "Float Volume"
      }
    }
  ],
  "formulas": {
    "pureCr2O3Weight": "hideWeight * desiredCr2O3Offer / 100",
    "bcsWeight": "pureCr2O3Weight / (bcsCr2O3Content / 100)",
    "concentrationInFloat": "bcsWeight * 1000 / floatVolume"
  },
  "outputs": {
    "primary": "bcsWeight",
    "breakdown": [
      "pureCr2O3Weight",
      "concentrationInFloat"
    ]
  },

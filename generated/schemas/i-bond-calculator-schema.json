{
  "toolName": "i-bond-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Investment Amount",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "businessContext": "The amount you invest in I Bonds",
      "label_i18n": {
        "en": "Investment Amount",
        "tr": "Yatırım Tutarı",
        "de": "Investitionsbetrag",
        "fr": "Investment Amount",
        "es": "Investment Amount",
        "ar": "Investment Amount"
      },
      "businessContext_i18n": {
        "en": "The amount you invest in I Bonds",
        "tr": "I Bond'larına yatırdığınız miktar"
      }
    },
    {
      "id": "fixedRate",
      "label": "Fixed Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 0.4,
      "businessContext": "The fixed rate set by the Treasury for the bond",
      "label_i18n": {
        "en": "Fixed Rate (%)",
        "tr": "Sabit Oran (%)",
        "de": "Fixed Rate (%)",
        "fr": "Fixed Rate (%)",
        "es": "Fixed Rate (%)",
        "ar": "Fixed Rate (%)"
      },
      "businessContext_i18n": {
        "en": "The fixed rate set by the Treasury for the bond",
        "tr": "Hazine tarafından tahvil için belirlenen sabit oran"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 3.24,
      "businessContext": "The annual inflation rate based on CPI-U",
      "label_i18n": {
        "en": "Inflation Rate (%)",
        "tr": "Enflasyon Oranı (%)",
        "de": "Inflation Rate (%)",
        "fr": "Inflation Rate (%)",
        "es": "Inflation Rate (%)",
        "ar": "Inflation Rate (%)"
      },
      "businessContext_i18n": {
        "en": "The annual inflation rate based on CPI-U",
        "tr": "TÜFE-FE'ye dayalı yıllık enflasyon oranı"
      }
    },
    {
      "id": "years",
      "label": "Years Held",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Number of years the bond is held (1-30)",
      "label_i18n": {
        "en": "Years Held",
        "tr": "Tutulan Yıl Sayısı",
        "de": "Years Held",
        "fr": "Years Held",
        "es": "Years Held",
        "ar": "Years Held"
      },
      "businessContext_i18n": {
        "en": "Number of years the bond is held (1-30)",
        "tr": "Tahvilin tutulduğu yıl sayısı (1-30)"
      }
    }
  ],
  "formulas": {
    "compositeRateDecimal": "(fixedRate/100) + 2*(inflationRate/100) + (fixedRate/100)*(inflationRate/100)",
    "compositeRatePercent": "compositeRateDecimal * 100"
  },
  "outputs": {
    "primary": "compositeRatePercent",
    "breakdown": [
      "compositeRatePercent",
      "totalInterest",
      "effectiveAnnualRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

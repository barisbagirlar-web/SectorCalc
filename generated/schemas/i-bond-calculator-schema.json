{
  "toolName": "i-bond-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Investment Amount",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "businessContext": "The amount you invest in I Bonds",
      "label_i18n": {
        "en": "Investment Amount",
        "tr": "Investment Amount",
        "de": "Investment Amount",
        "fr": "Investment Amount",
        "es": "Investment Amount",
        "ar": "Investment Amount"
      }
    },
    {
      "id": "fixedRate",
      "label": "Fixed Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 0.4,
      "businessContext": "The fixed rate set by the Treasury for the bond",
      "label_i18n": {
        "en": "Fixed Rate (%)",
        "tr": "Fixed Rate (%)",
        "de": "Fixed Rate (%)",
        "fr": "Fixed Rate (%)",
        "es": "Fixed Rate (%)",
        "ar": "Fixed Rate (%)"
      }
    },
    {
      "id": "inflationRate",
      "label": "Inflation Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 3.24,
      "businessContext": "The annual inflation rate based on CPI-U",
      "label_i18n": {
        "en": "Inflation Rate (%)",
        "tr": "Inflation Rate (%)",
        "de": "Inflation Rate (%)",
        "fr": "Inflation Rate (%)",
        "es": "Inflation Rate (%)",
        "ar": "Inflation Rate (%)"
      }
    },
    {
      "id": "years",
      "label": "Years Held",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Number of years the bond is held (1-30)",
      "label_i18n": {
        "en": "Years Held",
        "tr": "Years Held",
        "de": "Years Held",
        "fr": "Years Held",
        "es": "Years Held",
        "ar": "Years Held"
      }
    }
  ],
  "formulas": {
    "compositeRateDecimal": "(fixedRate/100) + 2*(inflationRate/100) + (fixedRate/100)*(inflationRate/100)",
    "compositeRatePercent": "compositeRateDecimal * 100"
  },
  "outputs": {
    "primary": "compositeRatePercent",
    "breakdown": [
      "compositeRatePercent",
      "totalInterest",
      "effectiveAnnualRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveAnnualRate"
  },

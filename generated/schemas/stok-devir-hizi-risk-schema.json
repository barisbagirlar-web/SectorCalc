  "formulas": {
    "InventoryTurnover": "COGS / AverageInventory",
    "DaysSalesInventory": "365 / InventoryTurnover",
    "ObsolescenceRisk": "SUM(AgingBracket_i * ObsolescenceRate_i * InventoryValue_i)",
    "CarryingCost": "AverageInventory * (WACC + Storage + Insurance + Obsolescence)",
    "OptimalTurnover": "IndustryBenchmark * AdjustmentFactor",
    "StockoutRisk": "IF(Turnover > MaxThreshold, High, Low)",
    "LiquidationLoss": "SlowMovingInventory * (1 - SalvageValuePct)"
  },
  "outputs": {
    "primary": "LiquidationLoss",
    "unit": "USD",
    "breakdown": {

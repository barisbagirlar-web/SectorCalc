      "unit": "passengers",
      "default": 0,
      "businessContext": "Number of children aged 5-12. They get a discount.",
      "label_i18n": {
        "en": "Number of Children (5-12)",
        "tr": "Çocuk Sayısı (5-12)",
        "de": "Number of Children (5-12)",
        "fr": "Number of Children (5-12)",
        "es": "Number of Children (5-12)",
        "ar": "Number of Children (5-12)"
      },
      "businessContext_i18n": {
        "en": "Number of children aged 5-12. They get a discount.",
        "tr": "5-12 yaş arası çocuk sayısı. İndirim uygulanır."
      }
    },
    {
      "id": "distance",
      "label": "Distance",
      "type": "number",
      "unit": "km",
      "default": 100,
      "businessContext": "Total travel distance in kilometers.",
      "label_i18n": {
        "en": "Distance",
        "tr": "Mesafe",
        "de": "Entfernung",
        "fr": "Distance",
        "es": "Distance",
        "ar": "Distance"
      },
      "businessContext_i18n": {
        "en": "Total travel distance in kilometers.",
        "tr": "Kilometre cinsinden toplam seyahat mesafesi.",
        "de": "Gesamte Fahrstrecke in Kilometern."
      }
    },
    {
      "id": "baseFarePerKm",
      "label": "Base Fare per km",
      "type": "number",
      "unit": "currency/km",
      "default": 0.5,
      "businessContext": "Standard fare per kilometer per passenger.",
      "label_i18n": {
        "en": "Base Fare per km",
        "tr": "Km Başına Taban Ücret",
        "de": "Base Fare per km",
        "fr": "Base Fare per km",
        "es": "Base Fare per km",
        "ar": "Base Fare per km"
      },
      "businessContext_i18n": {
        "en": "Standard fare per kilometer per passenger.",
        "tr": "Yolcu başına kilometre başına standart ücret."
      }
    },
    {
      "id": "childDiscount",
      "label": "Child Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Discount percentage applied to child tickets (0-100).",
      "label_i18n": {
        "en": "Child Discount Rate",
        "tr": "Çocuk İndirim Oranı",
        "de": "Child Discount Rate",
        "fr": "Child Discount Rate",
        "es": "Child Discount Rate",
        "ar": "Child Discount Rate"
      },
      "businessContext_i18n": {
        "en": "Discount percentage applied to child tickets (0-100).",
        "tr": "Çocuk biletlerine uygulanan indirim yüzdesi (0-100)."
      }
    },
    {
      "id": "groupDiscount",
      "label": "Group Discount Rate (for 5+ passengers)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional discount rate for groups of 5 or more total passengers.",
      "label_i18n": {
        "en": "Group Discount Rate (for 5+ passengers)",
        "tr": "Grup İndirim Oranı (5+ yolcu)",
        "de": "Group Discount Rate (for 5+ passengers)",
        "fr": "Group Discount Rate (for 5+ passengers)",
        "es": "Group Discount Rate (for 5+ passengers)",
        "ar": "Group Discount Rate (for 5+ passengers)"
      },
      "businessContext_i18n": {
        "en": "Additional discount rate for groups of 5 or more total passengers.",
        "tr": "5 veya daha fazla toplam yolcu için grup indirim oranı."
      }
    },
    {
      "id": "serviceFee",
      "label": "Service Fee per Ticket",
      "type": "number",
      "unit": "currency",
      "default": 2,
      "businessContext": "Fixed service fee applied per ticket (per passenger).",
      "label_i18n": {
        "en": "Service Fee per Ticket",
        "tr": "Bilet Başına Hizmet Ücreti",
        "de": "Service Fee per Ticket",
        "fr": "Service Fee per Ticket",
        "es": "Service Fee per Ticket",
        "ar": "Service Fee per Ticket"
      },
      "businessContext_i18n": {
        "en": "Fixed service fee applied per ticket (per passenger).",
        "tr": "Bilet başına (yolcu başına) uygulanan sabit hizmet ücreti."
      }
    }
  ],
  "formulas": {
    "adultsFare": "adults * distance * baseFarePerKm",
    "childrenFare": "children * distance * baseFarePerKm * (1 - childDiscount/100)",
    "subtotal": "adultsFare + childrenFare",
    "totalPassengers": "adults + children",
    "groupDiscountAmount": "totalPassengers >= 5 ? subtotal * groupDiscount / 100 : 0",
    "subtotalAfterDiscount": "subtotal - groupDiscountAmount",
    "serviceFeeTotal": "totalPassengers * serviceFee",
    "totalCost": "subtotalAfterDiscount + serviceFeeTotal"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "subtotalAfterDiscount",
      "groupDiscountAmount",
      "childrenFare",
      "serviceFeeTotal"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "passengers"
  },
  "category": "Diğer",
  "sector": "Demiryolu & Raylı",
  "premiumRequired": false,

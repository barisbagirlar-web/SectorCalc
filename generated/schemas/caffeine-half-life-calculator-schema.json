      "label_i18n": {
        "en": "Initial Caffeine Dose",
        "tr": "Initial Caffeine Dose",
        "de": "Initial Caffeine Dose",
        "fr": "Initial Caffeine Dose",
        "es": "Initial Caffeine Dose",
        "ar": "Initial Caffeine Dose"
      }
    },
    {
      "id": "halfLife",
      "label": "Caffeine Half-Life",
      "type": "number",
      "unit": "hours",
      "default": 5,
      "businessContext": "Average half-life of caffeine in healthy adults: 3-7 hours, 5 hours typical. Smokers may have a half-life of 3 hours, pregnant women up to 15 hours.",
      "label_i18n": {
        "en": "Caffeine Half-Life",
        "tr": "Caffeine Half-Life",
        "de": "Caffeine Half-Life",
        "fr": "Caffeine Half-Life",
        "es": "Caffeine Half-Life",
        "ar": "Caffeine Half-Life"
      }
    },
    {
      "id": "elapsedTime",
      "label": "Time Elapsed",
      "type": "number",
      "unit": "hours",
      "default": 4,
      "businessContext": "Hours since caffeine intake. For bedtime planning, consider elapsed time until sleep.",
      "label_i18n": {
        "en": "Time Elapsed",
        "tr": "Time Elapsed",
        "de": "Time Elapsed",
        "fr": "Time Elapsed",
        "es": "Time Elapsed",
        "ar": "Time Elapsed"
      }
    },
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight helps in assessing dose per kg, which relates to sensitivity. Average adult: 60-80 kg.",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    }
  ],
  "formulas": {
    "primary": "initialDose * Math.pow(0.5, elapsedTime / halfLife)",

        "de": "Yarn per Stitch",
        "fr": "Yarn per Stitch",
        "es": "Yarn per Stitch",
        "ar": "Yarn per Stitch"
      }
    },
    {
      "id": "yarnDensity",
      "label": "Yarn Linear Density",
      "type": "number",
      "unit": "tex",
      "default": 50,
      "businessContext": "Enter the yarn linear density in tex (grams per 1000 meters).",
      "label_i18n": {
        "en": "Yarn Linear Density",
        "tr": "Yarn Linear Density",
        "de": "Yarn Linear Density",
        "fr": "Yarn Linear Density",
        "es": "Yarn Linear Density",
        "ar": "Yarn Linear Density"
      }
    }
  ],
  "formulas": {
    "totalStitches": "fabricWidth * stitchGauge * fabricLength * rowGauge",
    "totalYarnLength": "(totalStitches * yarnPerStitch) / 100",
    "totalYarnWeight": "totalYarnLength * (yarnDensity / 1000)"
  },
  "outputs": {
    "primary": "totalYarnLength",
    "breakdown": [
      "totalStitches",
      "totalYarnWeight"
    ],

{
  "toolName": "electricity-cost-calculator",
  "inputs": [
    {
      "id": "powerConsumption",
      "label": "Power Consumption",
      "type": "number",
      "unit": "kW",
      "default": 10,
      "businessContext": "Average power draw of the equipment or facility in kilowatts.",
      "label_i18n": {
        "en": "Power Consumption",
        "tr": "Power Consumption",
        "de": "Power Consumption",
        "fr": "Power Consumption",
        "es": "Power Consumption",
        "ar": "Power Consumption"
      }
    },
    {
      "id": "operatingHoursPerDay",
      "label": "Operating Hours per Day",
      "type": "number",
      "unit": "h",
      "default": 8,
      "businessContext": "Number of hours the equipment operates each day.",
      "label_i18n": {
        "en": "Operating Hours per Day",
        "tr": "Operating Hours per Day",
        "de": "Operating Hours per Day",
        "fr": "Operating Hours per Day",
        "es": "Operating Hours per Day",
        "ar": "Operating Hours per Day"
      }
    },
    {
      "id": "operatingDaysPerMonth",
      "label": "Operating Days per Month",
      "type": "number",
      "unit": "days",
      "default": 22,
      "businessContext": "Typical number of operating days in a month.",
      "label_i18n": {
        "en": "Operating Days per Month",
        "tr": "Operating Days per Month",
        "de": "Operating Days per Month",
        "fr": "Operating Days per Month",
        "es": "Operating Days per Month",
        "ar": "Operating Days per Month"
      }
    },
    {
      "id": "electricityRate",
      "label": "Electricity Rate",
      "type": "number",
      "unit": "$/kWh",
      "default": 0.12,
      "businessContext": "Cost per kilowatt-hour of energy consumed.",
      "label_i18n": {
        "en": "Electricity Rate",
        "tr": "Electricity Rate",
        "de": "Electricity Rate",
        "fr": "Electricity Rate",
        "es": "Electricity Rate",
        "ar": "Electricity Rate"
      }
    },
    {
      "id": "peakDemand",
      "label": "Peak Demand",
      "type": "number",
      "unit": "kW",
      "default": 0,
      "businessContext": "Highest average demand in kW during a 15-minute interval in the billing period. Set to 0 if no demand charge.",
      "label_i18n": {
        "en": "Peak Demand",
        "tr": "Peak Demand",
        "de": "Peak Demand",
        "fr": "Peak Demand",
        "es": "Peak Demand",
        "ar": "Peak Demand"
      }
    },
    {
      "id": "demandChargeRate",
      "label": "Demand Charge Rate",
      "type": "number",
      "unit": "$/kW",
      "default": 0,
      "businessContext": "Cost per kW of peak demand. Set to 0 if no demand charge.",
      "label_i18n": {
        "en": "Demand Charge Rate",
        "tr": "Demand Charge Rate",
        "de": "Demand Charge Rate",
        "fr": "Demand Charge Rate",
        "es": "Demand Charge Rate",
        "ar": "Demand Charge Rate"
      }
    }
  ],
  "formulas": {
    "energyCost": "powerConsumption * operatingHoursPerDay * operatingDaysPerMonth * electricityRate",
    "demandCost": "peakDemand * demandChargeRate",
    "totalMonthlyCost": "(powerConsumption * operatingHoursPerDay * operatingDaysPerMonth * electricityRate) + (peakDemand * demandChargeRate)"
  },
  "outputs": {
    "primary": "totalMonthlyCost",
    "breakdown": [
      "energyCost",
      "demandCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMonthlyCost"
  },

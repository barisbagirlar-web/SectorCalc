        "de": "Der aktuelle Ladezustand in Prozent der Batteriekapazität."
      }
    },
    {
      "id": "desiredCharge",
      "label": "Desired Charge",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "The target state of charge after charging session.",
      "label_i18n": {
        "en": "Desired Charge",
        "tr": "Hedef Şarj",
        "de": "Gewünschter Ladezustand",
        "fr": "Desired Charge",
        "es": "Desired Charge",
        "ar": "Desired Charge"
      },
      "businessContext_i18n": {
        "en": "The target state of charge after charging session.",
        "tr": "Şarj seansı sonrası hedeflenen şarj durumu.",

{
  "toolName": "ev-charging-calculator",
  "inputs": [
    {
      "id": "batteryCapacity",
      "label": "Battery Capacity",
      "type": "number",
      "unit": "kWh",
      "default": 75,
      "businessContext": "The total usable battery capacity of the electric vehicle.",
      "label_i18n": {
        "en": "Battery Capacity",
        "tr": "Pil Kapasitesi",
        "de": "Batteriekapazität",
        "fr": "Battery Capacity",
        "es": "Battery Capacity",
        "ar": "Battery Capacity"
      },
      "businessContext_i18n": {
        "en": "The total usable battery capacity of the electric vehicle.",
        "tr": "Elektrikli aracın toplam kullanılabilir batarya kapasitesi.",
        "de": "Die gesamte nutzbare Batteriekapazität des Elektrofahrzeugs."
      }
    },
    {
      "id": "currentCharge",
      "label": "Current Charge",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "The current state of charge as a percentage of battery capacity.",
      "label_i18n": {
        "en": "Current Charge",
        "tr": "Mevcut Şarj",

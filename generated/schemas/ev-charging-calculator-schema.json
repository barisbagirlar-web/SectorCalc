    },
    {
      "id": "chargingPower",
      "label": "Charging Power",
      "type": "number",
      "unit": "kW",
      "default": 50,
      "businessContext": "The charging power of the charging station.",
      "label_i18n": {
        "en": "Charging Power",
        "tr": "Şarj Gücü",
        "de": "Ladeleistung",
        "fr": "Charging Power",
        "es": "Charging Power",
        "ar": "Charging Power"
      },
      "businessContext_i18n": {
        "en": "The charging power of the charging station.",
        "tr": "Şarj istasyonunun şarj gücü.",
        "de": "Die Ladeleistung der Ladestation."
      }
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost of electricity per kWh.",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Elektrik Maliyeti",
        "de": "Stromkosten",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      },
      "businessContext_i18n": {
        "en": "Cost of electricity per kWh.",
        "tr": "kWh başına elektrik maliyeti.",
        "de": "Stromkosten pro kWh."
      }
    },
    {
      "id": "efficiency",
      "label": "Charging Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Charging efficiency, including conversion losses.",
      "label_i18n": {
        "en": "Charging Efficiency",
        "tr": "Şarj Verimliliği",
        "de": "Ladeeffizienz",
        "fr": "Charging Efficiency",
        "es": "Charging Efficiency",
        "ar": "Charging Efficiency"
      },
      "businessContext_i18n": {
        "en": "Charging efficiency, including conversion losses.",
        "tr": "Dönüşüm kayıpları dahil şarj verimliliği.",
        "de": "Ladeeffizienz inklusive Umwandlungsverluste."
      }
    }
  ],
  "formulas": {
    "charging-time": "(((batteryCapacity * (desiredCharge - currentCharge) / 100) * (100 / efficiency)) / chargingPower)",
    "energy-required": "((batteryCapacity * (desiredCharge - currentCharge) / 100) * (100 / efficiency))",
    "total-cost": "(((batteryCapacity * (desiredCharge - currentCharge) / 100) * (100 / efficiency)) * electricityCost)"
  },
  "outputs": {
    "primary": "charging-time",
    "breakdown": [
      "energy-required",
      "total-cost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "total-cost",
    "unit": "kWh"
  },
  "category": "Enerji & Karbon",

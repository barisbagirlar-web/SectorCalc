{
  "toolName": "umbrella-insurance-calculator",
  "inputs": [
    {
      "id": "totalAssets",
      "label": "Total Assets",
      "type": "number",
      "unit": "$",
      "default": 500000,
      "businessContext": "Total value of all owned assets (home, cars, investments, etc.)",
      "label_i18n": {
        "en": "Total Assets",
        "tr": "Total Assets",
        "de": "Total Assets",
        "fr": "Total Assets",
        "es": "Total Assets",
        "ar": "Total Assets"
      }
    },
    {
      "id": "totalLiabilities",
      "label": "Total Liabilities",
      "type": "number",
      "unit": "$",
      "default": 200000,
      "businessContext": "Outstanding debts (mortgage, loans, etc.)",
      "label_i18n": {
        "en": "Total Liabilities",
        "tr": "Total Liabilities",
        "de": "Total Liabilities",
        "fr": "Total Liabilities",
        "es": "Total Liabilities",
        "ar": "Total Liabilities"
      }
    },
    {
      "id": "underlyingCoverage",
      "label": "Underlying Liability Coverage",
      "type": "number",
      "unit": "$",
      "default": 300000,
      "businessContext": "Combined liability limits from auto, home, and other primary insurance policies",
      "label_i18n": {
        "en": "Underlying Liability Coverage",
        "tr": "Underlying Liability Coverage",
        "de": "Underlying Liability Coverage",
        "fr": "Underlying Liability Coverage",
        "es": "Underlying Liability Coverage",
        "ar": "Underlying Liability Coverage"
      }
    },
    {
      "id": "riskFactor",
      "label": "Risk Factor",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Multiplier based on occupation, lifestyle, and property risks (100% = standard)",
      "label_i18n": {
        "en": "Risk Factor",
        "tr": "Risk Factor",
        "de": "Risk Factor",
        "fr": "Risk Factor",
        "es": "Risk Factor",
        "ar": "Risk Factor"
      }
    }
  ],
  "formulas": {
    "netWorth": "totalAssets - totalLiabilities",
    "riskAdjustedNetWorth": "netWorth * (riskFactor / 100)",
    "coverageGap": "riskAdjustedNetWorth - underlyingCoverage"
  },
  "outputs": {
    "primary": "coverageGap",
    "breakdown": [
      "netWorth",
      "riskAdjustedNetWorth",
      "coverageGap"
    ],

{
  "toolName": "rankine-cycle-calculator",
  "inputs": [
    {
      "id": "turbineInletEnthalpy",
      "label": "Turbine Inlet Enthalpy (h₁)",
      "type": "number",
      "unit": "kJ/kg",
      "default": 2800,
      "businessContext": "Specific enthalpy of steam at turbine inlet (superheated conditions)",
      "label_i18n": {

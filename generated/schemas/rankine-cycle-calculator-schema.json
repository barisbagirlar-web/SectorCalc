      }
    },
    {
      "id": "pumpExitIsentropicEnthalpy",
      "label": "Isentropic Pump Exit Enthalpy (h₄ₛ)",
      "type": "number",
      "unit": "kJ/kg",
      "default": 210,
      "businessContext": "Specific enthalpy at pump exit assuming isentropic compression",
      "label_i18n": {
        "en": "Isentropic Pump Exit Enthalpy (h₄ₛ)",
        "tr": "Isentropic Pump Exit Enthalpy (h₄ₛ)",
        "de": "Isentropic Pump Exit Enthalpy (h₄ₛ)",
        "fr": "Isentropic Pump Exit Enthalpy (h₄ₛ)",
        "es": "Isentropic Pump Exit Enthalpy (h₄ₛ)",
        "ar": "Isentropic Pump Exit Enthalpy (h₄ₛ)"
      }
    },
    {
      "id": "turbineEfficiency",
      "label": "Turbine Isentropic Efficiency (ηₜ)",
      "type": "number",
      "unit": "unit",
      "default": 0.9,
      "businessContext": "Ratio of actual turbine work to isentropic work (0–1)",
      "label_i18n": {
        "en": "Turbine Isentropic Efficiency (ηₜ)",
        "tr": "Turbine Isentropic Efficiency (ηₜ)",
        "de": "Turbine Isentropic Efficiency (ηₜ)",
        "fr": "Turbine Isentropic Efficiency (ηₜ)",
        "es": "Turbine Isentropic Efficiency (ηₜ)",
        "ar": "Turbine Isentropic Efficiency (ηₜ)"
      }
    },
    {
      "id": "pumpEfficiency",
      "label": "Pump Isentropic Efficiency (ηₚ)",
      "type": "number",
      "unit": "unit",
      "default": 0.85,
      "businessContext": "Ratio of isentropic pump work to actual pump work (0–1)",
      "label_i18n": {
        "en": "Pump Isentropic Efficiency (ηₚ)",
        "tr": "Pump Isentropic Efficiency (ηₚ)",
        "de": "Pump Isentropic Efficiency (ηₚ)",
        "fr": "Pump Isentropic Efficiency (ηₚ)",
        "es": "Pump Isentropic Efficiency (ηₚ)",
        "ar": "Pump Isentropic Efficiency (ηₚ)"
      }
    }
  ],
  "formulas": {
    "turbineWork": "(turbineInletEnthalpy - turbineExitIsentropicEnthalpy) * turbineEfficiency",
    "pumpWork": "(pumpExitIsentropicEnthalpy - condenserOutletEnthalpy) / pumpEfficiency",
    "netWork": "(turbineInletEnthalpy - turbineExitIsentropicEnthalpy) * turbineEfficiency - (pumpExitIsentropicEnthalpy - condenserOutletEnthalpy) / pumpEfficiency",
    "heatAdded": "(turbineInletEnthalpy - condenserOutletEnthalpy) - (pumpExitIsentropicEnthalpy - condenserOutletEnthalpy) / pumpEfficiency",
    "thermalEfficiency": "((turbineInletEnthalpy - turbineExitIsentropicEnthalpy) * turbineEfficiency - (pumpExitIsentropicEnthalpy - condenserOutletEnthalpy) / pumpEfficiency) / ((turbineInletEnthalpy - condenserOutletEnthalpy) - (pumpExitIsentropicEnthalpy - condenserOutletEnthalpy) / pumpEfficiency)"
  },
  "outputs": {
    "primary": "thermalEfficiency",
    "breakdown": [
      "turbineWork",
      "pumpWork",
      "netWork",
      "heatAdded"
    ]
  },
  "category": "Akışkanlar & Termodinamik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,

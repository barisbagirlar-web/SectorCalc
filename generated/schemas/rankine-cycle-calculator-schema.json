      }
    },
    {
      "id": "condenserOutletEnthalpy",
      "label": "Condenser Outlet Enthalpy (h₃)",
      "type": "number",
      "unit": "kJ/kg",
      "default": 200,
      "businessContext": "Specific enthalpy of saturated liquid leaving the condenser",
      "label_i18n": {
        "en": "Condenser Outlet Enthalpy (h₃)",
        "tr": "Condenser Outlet Enthalpy (h₃)",

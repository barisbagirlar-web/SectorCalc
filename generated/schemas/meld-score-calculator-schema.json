{
  "toolName": "meld-score-calculator",
  "inputs": [
    {
      "id": "materialWasteRate",
      "label": "Material Waste Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of material wasted in production"
    },
    {
      "id": "energyConsumption",
      "label": "Energy Consumption",
      "type": "number",
      "unit": "kWh/unit",
      "default": 10,
      "businessContext": "Energy consumed per unit produced"
    },
    {
      "id": "laborProductivity",
      "label": "Labor Productivity",
      "type": "number",
      "unit": "units/hour",
      "default": 50,
      "businessContext": "Units produced per labor hour"
    },
    {
      "id": "defectRate",
      "label": "Defect Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Percentage of defective products"
    },
    {
      "id": "machineUtilization",
      "label": "Machine Utilization",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Percentage of available time machines are running"
    }
  ],
  "formulas": {
    "scoreMaterial": "Math.max(0, Math.min(100, 100 - materialWasteRate * 10))",
    "scoreEnergy": "Math.max(0, Math.min(100, 100 - (energyConsumption - 5) * (100 / 15)))",
    "scoreLabor": "Math.max(0, Math.min(100, laborProductivity))",
    "scoreDefect": "Math.max(0, Math.min(100, 100 - defectRate * 10))",
    "scoreUtilization": "Math.max(0, Math.min(100, machineUtilization))",
    "meldScore": "Math.round((0.2 * scoreMaterial + 0.25 * scoreEnergy + 0.2 * scoreLabor + 0.25 * scoreDefect + 0.1 * scoreUtilization) * 10) / 10"
  },
  "outputs": {
    "primary": "meldScore",
    "breakdown": [
      "scoreMaterial",
      "scoreEnergy",
      "scoreLabor",
      "scoreDefect",
      "scoreUtilization"
    ]
  },
  "category": "Verimlilik & OEE",
  "sector": "Makine & Ekipman",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "efficiency"
}

  "formulas": {
    "totalCurrent": "numberOfDevices * currentPerDevice * safetyFactor",
    "totalApparentPower": "voltage * totalCurrent",
    "totalRealPower": "totalApparentPower * powerFactor",
    "loadPercentage": "breakerRating > 0 ? (totalCurrent / breakerRating * 100) : null"
  },
  "outputs": {
    "primary": "totalRealPower",
    "breakdown": [
      "totalCurrent",
      "totalApparentPower",
      "loadPercentage"
    ]

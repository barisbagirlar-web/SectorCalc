{
  "toolName": "circuit-training-calculator",
  "inputs": [
    {
      "id": "voltage",
      "label": "Supply Voltage",
      "type": "number",
      "unit": "V",
      "default": 12,
      "businessContext": "Voltage supplied to the circuit"
    },
    {
      "id": "resistance1",
      "label": "Resistance R1",
      "type": "number",
      "unit": "Ω",
      "default": 1000,
      "businessContext": "Resistance of the first resistor"
    },
    {
      "id": "resistance2",
      "label": "Resistance R2",
      "type": "number",
      "unit": "Ω",
      "default": 2200,
      "businessContext": "Resistance of the second resistor"
    }
  ],
  "formulas": {
    "totalResistance": "resistance1 + resistance2",
    "current": "voltage / totalResistance",
    "powerTotal": "voltage * current",
    "powerR1": "current * current * resistance1",
    "powerR2": "current * current * resistance2"
  },
  "outputs": {
    "primary": "current",
    "breakdown": [
      "totalResistance",
      "powerTotal",
      "powerR1",
      "powerR2"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "categorySlug": "electrical-power-systems",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "sectorId": "otomotiv-tedarik",
  "profession": "Tedarik Zinciri Yöneticisi",
  "categoryId": "diger"
}

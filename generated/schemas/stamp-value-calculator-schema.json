{
  "toolName": "stamp-value-calculator",
  "inputs": [
    {
      "id": "documentValue",
      "label": "Document Value",
      "type": "number",
      "unit": "EUR",
      "default": 1000,
      "businessContext": "The monetary value of the contract or transaction document.",
      "label_i18n": {
        "en": "Document Value",
        "tr": "Document Value",
        "de": "Document Value",
        "fr": "Document Value",
        "es": "Document Value",
        "ar": "Document Value"
      }
    },
    {
      "id": "stampDutyRate",
      "label": "Stamp Duty Rate",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "Applicable stamp duty percentage based on jurisdiction and document type.",
      "label_i18n": {
        "en": "Stamp Duty Rate",
        "tr": "Stamp Duty Rate",
        "de": "Stamp Duty Rate",
        "fr": "Stamp Duty Rate",
        "es": "Stamp Duty Rate",
        "ar": "Stamp Duty Rate"
      }
    },
    {
      "id": "fixedFee",
      "label": "Fixed Fee",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Fixed administrative fee for stamping, if any.",
      "label_i18n": {
        "en": "Fixed Fee",
        "tr": "Fixed Fee",
        "de": "Fixed Fee",
        "fr": "Fixed Fee",
        "es": "Fixed Fee",
        "ar": "Fixed Fee"
      }
    },
    {
      "id": "exemptionThreshold",
      "label": "Exemption Threshold",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Minimum document value below which no stamp duty applies.",
      "label_i18n": {
        "en": "Exemption Threshold",
        "tr": "Exemption Threshold",
        "de": "Exemption Threshold",
        "fr": "Exemption Threshold",
        "es": "Exemption Threshold",
        "ar": "Exemption Threshold"
      }
    },
    {
      "id": "quantity",
      "label": "Number of Stamps",
      "type": "number",
      "unit": "pieces",
      "default": 1,
      "businessContext": "Number of stamping instances for bulk calculations.",
      "label_i18n": {
        "en": "Number of Stamps",
        "tr": "Number of Stamps",
        "de": "Number of Stamps",
        "fr": "Number of Stamps",
        "es": "Number of Stamps",
        "ar": "Number of Stamps"
      }
    }
  ],
  "formulas": {
    "dutyPerUnit": "documentValue > exemptionThreshold ? ((documentValue - exemptionThreshold) * stampDutyRate / 100 + fixedFee) : 0",
    "totalCost": "dutyPerUnit * quantity"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "dutyPerUnit"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "category": "Diğer",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "diger",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "cut-calculator",
  "inputs": [
    {
      "id": "cuttingSpeed",
      "label": "Kesme Hızı (Vc)",
      "type": "number",
      "unit": "m/dk",
      "default": 150,
      "businessContext": "Kesme hızı, malzeme ve takım özelliklerine bağlıdır."
    },
    {
      "id": "feedPerTooth",
      "label": "Diş Başı İlerleme (fz)",
      "type": "number",
      "unit": "mm/diş",
      "default": 0.15,
      "businessContext": "Takım kataloğundan seçilen değer."
    },
    {
      "id": "numberOfTeeth",
      "label": "Diş Sayısı (z)",
      "type": "number",
      "unit": "adet",
      "default": 4,
      "businessContext": "Kesici takımın diş sayısı."
    },
    {
      "id": "toolDiameter",
      "label": "Takım Çapı (D)",
      "type": "number",
      "unit": "mm",
      "default": 12,
      "businessContext": "Kesici takımın çapı."
    },
    {
      "id": "depthOfCut",
      "label": "Kesme Derinliği (ap)",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Eksenel kesme derinliği."
    },
    {
      "id": "widthOfCut",
      "label": "Kesme Genişliği (ae)",
      "type": "number",
      "unit": "mm",
      "default": 8,
      "businessContext": "Radyal kesme genişliği."
    }
  ],
  "formulas": {
    "spindleSpeed": "(cuttingSpeed * 1000) / (Math.PI * toolDiameter)",
    "feedRate": "feedPerTooth * numberOfTeeth * spindleSpeed",
    "materialRemovalRate": "(depthOfCut * widthOfCut * feedRate) / 1000"
  },
  "outputs": {
    "primary": "materialRemovalRate",
    "breakdown": [
      "spindleSpeed",
      "feedRate"
    ]
  },
  "category": "İmalat & Üretim",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "categorySlug": "cnc-additive-manufacturing",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

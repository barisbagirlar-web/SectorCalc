  "formulas": {
    "power_kW": "(torque * engineSpeed) / 9549",
    "power_HP": "power_kW / 0.7457",
    "fuelMassFlow_kgPerH": "fuelConsumption * fuelDensity",
    "fuelEnergyInput_kW": "(fuelMassFlow_kgPerH * heatingValue) / 3.6",
    "brakeThermalEfficiency_percent": "power_kW > 0 ? (power_kW / fuelEnergyInput_kW) * 100 : 0",
    "specificFuelConsumption_gPerkWh": "power_kW > 0 ? (fuelMassFlow_kgPerH * 1000) / power_kW : 0"
  },
  "outputs": {
    "primary": "power_kW",
    "breakdown": [
      "power_HP",
      "brakeThermalEfficiency_percent",
      "specificFuelConsumption_gPerkWh",
      "fuelEnergyInput_kW"
    ],

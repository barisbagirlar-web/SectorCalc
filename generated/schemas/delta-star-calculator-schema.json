{
  "toolName": "delta-star-calculator",
  "inputs": [
    {
      "id": "mode",
      "label": "Conversion Mode (0: Δ→Y, 1: Y→Δ)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "0 for Delta to Star, 1 for Star to Delta"
    },
    {
      "id": "R1",
      "label": "Resistance 1 (Ω) - R12 if Delta, R1 if Star",
      "type": "number",
      "unit": "Ω",
      "default": 10,
      "businessContext": "In Delta mode, this is R12; in Star mode, this is R1"
    },
    {
      "id": "R2",
      "label": "Resistance 2 (Ω) - R23 if Delta, R2 if Star",
      "type": "number",
      "unit": "Ω",
      "default": 20,
      "businessContext": "In Delta mode, this is R23; in Star mode, this is R2"
    },
    {
      "id": "R3",
      "label": "Resistance 3 (Ω) - R31 if Delta, R3 if Star",
      "type": "number",
      "unit": "Ω",
      "default": 30,
      "businessContext": "In Delta mode, this is R31; in Star mode, this is R3"
    }
  ],
  "formulas": {
    "equivalentSummary": "mode === 0 ? `Star: R1=${((R1*R3)/(R1+R2+R3)).toFixed(2)} Ω, R2=${((R1*R2)/(R1+R2+R3)).toFixed(2)} Ω, R3=${((R2*R3)/(R1+R2+R3)).toFixed(2)} Ω` : `Delta: R12=${(R1+R2+(R1*R2)/R3).toFixed(2)} Ω, R23=${(R2+R3+(R2*R3)/R1).toFixed(2)} Ω, R31=${(R3+R1+(R3*R1)/R2).toFixed(2)} Ω`",
    "R_eq1": "mode === 0 ? (R1 * R3) / (R1 + R2 + R3) : (R1 + R2 + (R1 * R2) / R3)",
    "R_eq2": "mode === 0 ? (R1 * R2) / (R1 + R2 + R3) : (R2 + R3 + (R2 * R3) / R1)",
    "R_eq3": "mode === 0 ? (R2 * R3) / (R1 + R2 + R3) : (R3 + R1 + (R3 * R1) / R2)"
  },
  "outputs": {
    "primary": {
      "id": "equivalentSummary",
      "label": "Equivalent Resistances",
      "unit": ""
    },
    "breakdown": [
      {
        "id": "R_eq1",
        "label": "Equivalent R1 (Ω) or R12 (Ω)",
        "unit": "Ω"
      },
      {
        "id": "R_eq2",
        "label": "Equivalent R2 (Ω) or R23 (Ω)",
        "unit": "Ω"
      },
      {
        "id": "R_eq3",
        "label": "Equivalent R3 (Ω) or R31 (Ω)",
        "unit": "Ω"
      }
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",

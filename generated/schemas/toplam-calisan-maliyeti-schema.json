    "AbsenteeismCost": "AbsentHours * FullyBurdenedRate",
    "TurnoverCost": "(Recruitment + Training) * TurnoverRate",
    "TotalEmployeeCost": "GrossSalary + StatutoryCosts + Benefits + AbsenteeismCost + TurnoverCost",
    "CostPerHour": "TotalEmployeeCost / ProductiveHours"
  },

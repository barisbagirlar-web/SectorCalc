  "formulas": {
    "swimTime": "return (inputs.swimDistance / 100) * inputs.swimPace;",
    "bikeTime": "return (inputs.bikeDistance / inputs.bikeSpeed) * 60;",
    "runTime": "return inputs.runDistance * inputs.runPace;",
    "totalTime": "var swim = (inputs.swimDistance / 100) * inputs.swimPace; var bike = (inputs.bikeDistance / inputs.bikeSpeed) * 60; var run = inputs.runDistance * inputs.runPace; var totalMin = swim + bike + run; var h = Math.floor(totalMin / 60); var m = Math.floor(totalMin % 60); var s = Math.round(totalMin % 1 * 60); if (s === 60) { m++; s = 0; } if (m === 60) { h++; m = 0; } return h + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');"
  },
  "outputs": {
    "primary": "totalTime",
    "breakdown": [
      "swimTime",
      "bikeTime",
      "runTime"
    ]
  },

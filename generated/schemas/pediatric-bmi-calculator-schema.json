    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "businessContext": "Standing height in centimeters."
    }
  ],
  "formulas": {
    "bmi": "weight / Math.pow(height/100, 2)"
  },

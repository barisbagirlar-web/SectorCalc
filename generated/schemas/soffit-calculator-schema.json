{
  "toolName": "soffit-calculator",
  "inputs": [
    {
      "id": "runLength",
      "label": "Length of Eaves",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Total linear length of eaves where soffit will be installed",
      "label_i18n": {
        "en": "Length of Eaves",
        "tr": "Length of Eaves",
        "de": "Length of Eaves",
        "fr": "Length of Eaves",
        "es": "Length of Eaves",
        "ar": "Length of Eaves"
      }
    },
    {
      "id": "overhangWidth",
      "label": "Overhang Width",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "Depth from fascia to wall (soffit width)",
      "label_i18n": {
        "en": "Overhang Width",
        "tr": "Overhang Width",
        "de": "Overhang Width",
        "fr": "Overhang Width",
        "es": "Overhang Width",
        "ar": "Overhang Width"
      }
    },
    {
      "id": "panelLength",
      "label": "Panel Length",
      "type": "number",
      "unit": "m",
      "default": 2.44,
      "businessContext": "Length of a single soffit panel",
      "label_i18n": {
        "en": "Panel Length",
        "tr": "Panel Length",
        "de": "Panel Length",
        "fr": "Panel Length",
        "es": "Panel Length",
        "ar": "Panel Length"
      }
    },
    {
      "id": "panelWidth",
      "label": "Panel Width",
      "type": "number",
      "unit": "m",
      "default": 0.3,
      "businessContext": "Width of a single soffit panel (visible face)",
      "label_i18n": {
        "en": "Panel Width",
        "tr": "Panel Width",
        "de": "Panel Width",
        "fr": "Panel Width",
        "es": "Panel Width",
        "ar": "Panel Width"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage for cuts and material waste",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "total_area": "runLength * overhangWidth",
    "area_with_waste": "runLength * overhangWidth * (1 + wasteFactor / 100)",
    "panels_exact": "(runLength * overhangWidth * (1 + wasteFactor / 100)) / (panelLength * panelWidth)"
  },
  "outputs": {
    "primary": "panels_exact",
    "breakdown": [
      "total_area",
      "area_with_waste",
      "panels_exact",
      "panels_rounded_up"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

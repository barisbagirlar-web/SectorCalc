{
  "toolName": "how-much-house-can-i-afford",
  "inputs": [
    {
      "id": "annualIncome",
      "label": "Annual Gross Income",
      "type": "number",
      "unit": "USD",
      "default": 80000,
      "businessContext": "Total pre-tax annual income of all borrowers"
    },
    {
      "id": "monthlyDebt",
      "label": "Monthly Debt Payments",
      "type": "number",
      "unit": "USD",
      "default": 500,
      "businessContext": "Total monthly payments for other recurring debt (car loans, credit cards, student loans, etc.)"
    },
    {
      "id": "downPayment",
      "label": "Down Payment",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "businessContext": "Cash amount available for upfront home purchase payment"
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 6.5,
      "businessContext": "Annual fixed mortgage interest rate"
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Duration of the mortgage loan in years"
    },
    {
      "id": "propertyTaxRate",
      "label": "Property Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 1.2,
      "businessContext": "Annual property tax rate as a percentage of the home's assessed value"
    },
    {
      "id": "insuranceAnnual",
      "label": "Annual Homeowner's Insurance",
      "type": "number",
      "unit": "USD",
      "default": 1200,
      "businessContext": "Yearly premium for homeowner's insurance"
    },
    {
      "id": "hoaMonthly",
      "label": "Monthly HOA Fees",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Monthly homeowners association dues, if applicable"
    }
  ],
  "formulas": {
    "monthlyIncome": "annualIncome / 12",
    "monthlyRate": "interestRate / 100 / 12",
    "numPayments": "loanTerm * 12",
    "maxHousingPayment": "Math.min(0.28 * monthlyIncome, 0.36 * monthlyIncome - monthlyDebt)",
    "PI": "(maxHousingPayment - (propertyTaxRate/100/12)*downPayment - insuranceAnnual/12 - hoaMonthly) / (1 + (propertyTaxRate/100/12) * (1 - Math.pow(1 + monthlyRate, -numPayments)) / monthlyRate)",
    "loanAmount": "PI * (1 - Math.pow(1 + monthlyRate, -numPayments)) / monthlyRate",
    "maxHomePrice": "loanAmount + downPayment",
    "monthlyPropertyTax": "(maxHomePrice * propertyTaxRate / 100) / 12",
    "monthlyInsurance": "insuranceAnnual / 12",
    "monthlyPI": "PI",
    "maxLoanAmount": "loanAmount",
    "monthlyHOA": "hoaMonthly"
  },
  "outputs": {
    "primary": "maxHomePrice",
    "breakdown": [
      "maxMonthlyPayment",
      "maxLoanAmount",
      "monthlyPI",
      "monthlyPropertyTax",
      "monthlyInsurance",
      "monthlyHOA"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

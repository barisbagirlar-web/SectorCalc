{
  "toolName": "coupon-calculator",
  "inputs": [
    {
      "id": "faceValue",
      "label": "Face Value",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "The par or principal amount of the bond",
      "label_i18n": {
        "en": "Face Value",
        "tr": "Face Value",
        "de": "Face Value",
        "fr": "Face Value",
        "es": "Face Value",
        "ar": "Face Value"
      }
    },
    {
      "id": "couponRate",
      "label": "Coupon Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual coupon rate as a percentage of face value",
      "label_i18n": {
        "en": "Coupon Rate (%)",
        "tr": "Coupon Rate (%)",
        "de": "Coupon Rate (%)",
        "fr": "Coupon Rate (%)",
        "es": "Coupon Rate (%)",
        "ar": "Coupon Rate (%)"
      }
    },
    {
      "id": "frequency",
      "label": "Payment Frequency",
      "type": "number",
      "unit": "times/year",
      "default": 2,
      "businessContext": "Number of coupon payments per year (e.g., 2 for semi-annual)",
      "label_i18n": {
        "en": "Payment Frequency",
        "tr": "Payment Frequency",
        "de": "Payment Frequency",
        "fr": "Payment Frequency",
        "es": "Payment Frequency",
        "ar": "Payment Frequency"
      }
    },
    {
      "id": "yearsToMaturity",
      "label": "Years to Maturity",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Remaining time until bond matures",
      "label_i18n": {
        "en": "Years to Maturity",
        "tr": "Years to Maturity",
        "de": "Years to Maturity",
        "fr": "Years to Maturity",
        "es": "Years to Maturity",
        "ar": "Years to Maturity"
      }
    }
  ],
  "formulas": {
    "periodicCoupon": "(faceValue * (couponRate / 100)) / frequency",
    "annualCoupon": "faceValue * (couponRate / 100)",
    "totalCoupons": "faceValue * (couponRate / 100) * yearsToMaturity"
  },
  "outputs": {
    "primary": "periodicCoupon",
    "breakdown": [
      "annualCoupon",
      "totalCoupons"
    ]
  },

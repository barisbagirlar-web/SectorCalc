{
  "toolName": "coupon-calculator",
  "inputs": [
    {
      "id": "faceValue",
      "label": "Face Value",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "The par or principal amount of the bond",
      "label_i18n": {
        "en": "Face Value",
        "tr": "Nominal Değer",
        "de": "Face Value",
        "fr": "Face Value",
        "es": "Face Value",
        "ar": "Face Value"
      },
      "businessContext_i18n": {
        "en": "The par or principal amount of the bond",
        "tr": "Tahvilin nominal veya anapara tutarı"
      }
    },
    {
      "id": "couponRate",
      "label": "Coupon Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual coupon rate as a percentage of face value",
      "label_i18n": {
        "en": "Coupon Rate (%)",
        "tr": "Kupon Oranı (%)",
        "de": "Coupon Rate (%)",
        "fr": "Coupon Rate (%)",
        "es": "Coupon Rate (%)",
        "ar": "Coupon Rate (%)"
      },
      "businessContext_i18n": {
        "en": "Annual coupon rate as a percentage of face value",
        "tr": "Nominal değerin yüzdesi olarak yıllık kupon oranı"
      }
    },
    {
      "id": "frequency",
      "label": "Payment Frequency",
      "type": "number",
      "unit": "times/year",
      "default": 2,
      "businessContext": "Number of coupon payments per year (e.g., 2 for semi-annual)",
      "label_i18n": {
        "en": "Payment Frequency",
        "tr": "Ödeme Sıklığı",
        "de": "Payment Frequency",
        "fr": "Payment Frequency",
        "es": "Payment Frequency",
        "ar": "Payment Frequency"
      },
      "businessContext_i18n": {
        "en": "Number of coupon payments per year (e.g., 2 for semi-annual)",
        "tr": "Yıllık kupon ödemesi sayısı (örn. altı aylık için 2)"
      }
    },
    {
      "id": "yearsToMaturity",
      "label": "Years to Maturity",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Remaining time until bond matures",
      "label_i18n": {
        "en": "Years to Maturity",
        "tr": "Vadeye Kalan Yıl",
        "de": "Years to Maturity",
        "fr": "Years to Maturity",
        "es": "Years to Maturity",
        "ar": "Years to Maturity"
      },
      "businessContext_i18n": {
        "en": "Remaining time until bond matures",
        "tr": "Tahvilin vadesine kalan süre"
      }
    }
  ],
  "formulas": {
    "periodicCoupon": "(faceValue * (couponRate / 100)) / frequency",
    "annualCoupon": "faceValue * (couponRate / 100)",
    "totalCoupons": "faceValue * (couponRate / 100) * yearsToMaturity"
  },
  "outputs": {
    "primary": "periodicCoupon",
    "breakdown": [
      "annualCoupon",
      "totalCoupons"
    ],

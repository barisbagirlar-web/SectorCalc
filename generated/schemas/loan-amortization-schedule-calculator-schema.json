      "label": "Loan Amount",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "Principal amount borrowed",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Loan Amount",
        "de": "Loan Amount",
        "fr": "Loan Amount",
        "es": "Loan Amount",

    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Nominal annual interest rate",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term (Years)",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Total duration of the loan in years",
      "label_i18n": {
        "en": "Loan Term (Years)",
        "tr": "Loan Term (Years)",
        "de": "Loan Term (Years)",
        "fr": "Loan Term (Years)",
        "es": "Loan Term (Years)",
        "ar": "Loan Term (Years)"
      }
    },
    {
      "id": "paymentsPerYear",
      "label": "Payments Per Year",
      "type": "number",
      "unit": "count",
      "default": 12,
      "businessContext": "Number of payment periods per year (e.g., 12 for monthly, 4 for quarterly)",
      "label_i18n": {
        "en": "Payments Per Year",
        "tr": "Payments Per Year",
        "de": "Payments Per Year",
        "fr": "Payments Per Year",
        "es": "Payments Per Year",
        "ar": "Payments Per Year"
      }
    }
  ],
  "formulas": {
    "periodicInterestRate": "(annualInterestRate / 100) / paymentsPerYear",
    "totalPayments": "loanTermYears * paymentsPerYear"
  },
  "outputs": {

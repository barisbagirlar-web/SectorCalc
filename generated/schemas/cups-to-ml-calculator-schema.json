{
  "toolName": "cups-to-ml-calculator",
  "inputs": [
    {
      "id": "cups",
      "label": "Volume in cups",
      "type": "number",
      "unit": "cups",
      "default": 1,
      "businessContext": "Input volume in US customary cups",
      "label_i18n": {
        "en": "Volume in cups",
        "tr": "Volume in cups",
        "de": "Volume in cups",
        "fr": "Volume in cups",
        "es": "Volume in cups",
        "ar": "Volume in cups"
      }
    },

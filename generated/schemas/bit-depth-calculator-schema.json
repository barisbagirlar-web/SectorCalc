  "formulas": {
    "dynamicRange": "20 * Math.log(Math.pow(2, bitDepth)) / Math.LN10",
    "numberOfLevels": "Math.pow(2, bitDepth)",
    "bitRate": "bitDepth * sampleRate * numChannels",
    "fileSize": "bitDepth * sampleRate * numChannels * duration / 8"
  },

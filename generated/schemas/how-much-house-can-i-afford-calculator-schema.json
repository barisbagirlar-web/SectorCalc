  "formulas": {
    "monthlyIncome": "annualIncome / 12",
    "maxTotalMonthlyDebt": "monthlyIncome * 0.36",
    "maxHousingExpense": "monthlyIncome * 0.28",
    "r": "interestRate / 100 / 12",
    "n": "loanTerm * 12",
    "monthlyPaymentFactor": "(r * (1 + r) ** n) / ((1 + r) ** n - 1)",
    "monthlyTaxInsuranceRate": "(propertyTaxRate / 100 + insuranceRate / 100) / 12"
  },

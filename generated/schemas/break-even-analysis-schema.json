{
  "toolName": "break-even-analysis",
  "inputs": [
    {
      "id": "fixedCosts",
      "label": "Fixed Costs (TL)",
      "type": "number",
      "unit": "TL",
      "default": 100000,
      "businessContext": "Total fixed costs (rent, salaries, insurance, etc.)",
      "label_i18n": {
        "en": "Fixed Costs (TL)",
        "tr": "Fixed Costs (TL)",
        "de": "Fixed Costs (TL)",
        "fr": "Fixed Costs (TL)",
        "es": "Fixed Costs (TL)",
        "ar": "Fixed Costs (TL)"
      }
    },
    {
      "id": "variableCostPerUnit",
      "label": "Variable Cost per Unit (TL)",
      "type": "number",
      "unit": "TL",
      "default": 50,
      "businessContext": "Cost per unit that varies with production volume",
      "label_i18n": {
        "en": "Variable Cost per Unit (TL)",
        "tr": "Variable Cost per Unit (TL)",
        "de": "Variable Cost per Unit (TL)",
        "fr": "Variable Cost per Unit (TL)",
        "es": "Variable Cost per Unit (TL)",
        "ar": "Variable Cost per Unit (TL)"
      }
    },
    {
      "id": "sellingPricePerUnit",
      "label": "Selling Price per Unit (TL)",
      "type": "number",
      "unit": "TL",
      "default": 100,
      "businessContext": "Price at which each unit is sold",
      "label_i18n": {
        "en": "Selling Price per Unit (TL)",
        "tr": "Selling Price per Unit (TL)",
        "de": "Selling Price per Unit (TL)",
        "fr": "Selling Price per Unit (TL)",
        "es": "Selling Price per Unit (TL)",
        "ar": "Selling Price per Unit (TL)"
      }
    },
    {
      "id": "expectedSalesVolume",
      "label": "Expected Sales Volume (units)",
      "type": "number",
      "unit": "units",
      "default": 3000,
      "businessContext": "Projected number of units to be sold",
      "label_i18n": {
        "en": "Expected Sales Volume (units)",
        "tr": "Expected Sales Volume (units)",
        "de": "Expected Sales Volume (units)",
        "fr": "Expected Sales Volume (units)",
        "es": "Expected Sales Volume (units)",
        "ar": "Expected Sales Volume (units)"
      }
    }
  ],
  "formulas": {
    "breakEvenUnits": "fixedCosts / (sellingPricePerUnit - variableCostPerUnit)",
    "breakEvenRevenue": "breakEvenUnits * sellingPricePerUnit",
    "profit": "(sellingPricePerUnit - variableCostPerUnit) * expectedSalesVolume - fixedCosts",
    "contributionMargin": "sellingPricePerUnit - variableCostPerUnit",
    "marginRatio": "contributionMargin / sellingPricePerUnit"
  },
  "outputs": {
    "primary": "breakEvenUnits",
    "breakdown": [
      "breakEvenRevenue",
      "profit",
      "contributionMargin",
      "marginRatio"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "marginRatio"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "İstatistik & Olasılık",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "istatistik",
  "profession": "İstatistikçi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

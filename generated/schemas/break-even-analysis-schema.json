        "de": "Prognostizierte Anzahl der zu verkaufenden Einheiten"
      }
    }
  ],
  "formulas": {
    "breakEvenUnits": "fixedCosts / (sellingPricePerUnit - variableCostPerUnit)",
    "breakEvenRevenue": "breakEvenUnits * sellingPricePerUnit",
    "profit": "(sellingPricePerUnit - variableCostPerUnit) * expectedSalesVolume - fixedCosts",
    "contributionMargin": "sellingPricePerUnit - variableCostPerUnit",
    "marginRatio": "contributionMargin / sellingPricePerUnit"
  },
  "outputs": {
    "primary": "breakEvenUnits",
    "breakdown": [
      "breakEvenRevenue",
      "profit",
      "contributionMargin",
      "marginRatio"

      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Tax rate applied after discount",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Vergi Oranı",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      },
      "businessContext_i18n": {

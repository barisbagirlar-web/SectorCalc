        "en": "Extra fees like lab, technology, etc.",
        "tr": "Laboratuvar, teknoloji vb. ek ücretler"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage discount on subtotal",
      "label_i18n": {

  "formulas": {
    "subtotal": "tuitionPerCredit * numberOfCredits + additionalFees",
    "discountAmount": "subtotal * (discountPercent / 100)",
    "subtotalAfterDiscount": "subtotal - discountAmount",
    "taxAmount": "subtotalAfterDiscount * (taxRate / 100)",
    "totalBeforeScholarship": "subtotalAfterDiscount + taxAmount",
    "totalTuition": "totalBeforeScholarship - scholarship"
  },
  "outputs": {
    "primary": "totalTuition",
    "breakdown": [
      "subtotal",
      "discountAmount",
      "subtotalAfterDiscount",
      "taxAmount",
      "totalBeforeScholarship",
      "scholarship",
      "totalTuition"

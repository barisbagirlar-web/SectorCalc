{
  "toolName": "buhar-kapani-steam-trap-kacak-ve-enerji-kayip-calculator",
  "inputs": [
    {
      "id": "steamPressure",
      "label": "Buhar Basıncı",
      "type": "number",
      "unit": "bar",
      "default": 7,
      "min": 0.5,
      "max": 30,
      "options": null,
      "businessContext": "Buhar kapanı girişindeki buhar basıncı. ISO 50001 enerji yönetimi standardına göre enerji kaybı hesaplamalarında temel parametre."
    },
    {
      "id": "orificeDiameter",
      "label": "Orifis Çapı",
      "type": "number",
      "unit": "mm",
      "default": 3,
      "min": 0.5,
      "max": 25,
      "options": null,
      "businessContext": "Kaçak orifisinin tahmini çapı. Endüstriyel buhar sistemlerinde kaçak debisi hesaplamak için kullanılır."
    },
    {
      "id": "steamCost",
      "label": "Buhar Maliyeti",
      "type": "number",
      "unit": "USD/ton",
      "default": 30,
      "min": 0,
      "max": 200,
      "options": null,
      "businessContext": "Ton buhar başına maliyet. Enerji maliyet analizi için gereklidir."
    },
    {
      "id": "operatingHours",
      "label": "Yıllık Çalışma Saati",
      "type": "number",
      "unit": "saat/yıl",
      "default": 8000,
      "min": 0,
      "max": 8760,
      "options": null,
      "businessContext": "Sistemin yıllık çalışma süresi. Enerji kaybının yıllık maliyete dönüştürülmesinde kullanılır."
    },
    {
      "id": "steamType",
      "label": "Buhar Türü",
      "type": "select",
      "unit": "",
      "default": "doymus",
      "min": null,
      "max": null,
      "options": [
        "doymus",
        "kizgin"
      ],
      "businessContext": "Doymuş veya kızgın buhar. Buharın termodinamik özelliklerini belirler; kızgın buhar için düzeltme faktörü uygulanır."
    },
    {
      "id": "dischargeCoefficient",
      "label": "Deşarj Katsayısı",
      "type": "number",
      "unit": "",
      "default": 0.65,
      "min": 0.5,
      "max": 0.9,
      "options": null,
      "businessContext": "Orifis geometrisine bağlı akış katsayısı. Standart değer 0.65 olup, keskin kenarlı orifisler için geçerlidir."
    }
  ],
  "validation": {
    "rules": [
      "steamPressure >= 0.5 ve <= 30",
      "orificeDiameter >= 0.5 ve <= 25",
      "steamCost >= 0",
      "operatingHours >= 0 ve <= 8760",
      "dischargeCoefficient >= 0.5 ve <= 0.9"
    ],
    "thresholds": {
      "leakRate": "leakRate > 50 ? 'Yüksek kaçak debisi' : null",
      "annualCost": "annualCost > 10000 ? 'Kritik enerji kaybı maliyeti' : null"
    }
  },
  "formulas": {
    "leakRate": "0.0001 * dischargeCoefficient * orificeDiameter^2 * sqrt(steamPressure * 10) * (steamType === 'kizgin' ? 1.2 : 1.0)",
    "annualSteamLoss": "leakRate * operatingHours",
    "annualCost": "annualSteamLoss * steamCost"
  },
  "outputs": {
    "primary": "annualCost",
    "breakdown": {
      "leakRate": "leakRate",
      "annualSteamLoss": "annualSteamLoss"
    },
    "hiddenLossDrivers": [
      "leakRate > 50 ? 'Yüksek kaçak debisi' : ''",
      "annualCost > 10000 ? 'Kritik enerji kaybı maliyeti' : ''"
    ],
    "suggestedActions": [
      "Kaçak tespiti ve onarımı yapılmalı",
      "Buhar kapanı periyodik bakım programı oluşturulmalı",
      "Enerji verimliliği iyileştirme fırsatları değerlendirilmeli"
    ],
    "dataConfidenceAdjusted": "annualCost * 0.9"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

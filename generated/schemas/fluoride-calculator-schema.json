{
  "toolName": "fluoride-calculator",
  "inputs": [
    {
      "id": "waterFlowRate",
      "label": "Water Flow Rate",
      "type": "number",
      "unit": "m³/day",
      "default": 1000,
      "businessContext": "Daily volume of water to be fluoridated",
      "label_i18n": {
        "en": "Water Flow Rate",
        "tr": "Water Flow Rate",
        "de": "Water Flow Rate",
        "fr": "Water Flow Rate",
        "es": "Water Flow Rate",
        "ar": "Water Flow Rate"
      }
    },
    {
      "id": "targetFluorideConc",
      "label": "Target Fluoride Concentration",
      "type": "number",
      "unit": "mg/L",
      "default": 1,
      "businessContext": "Desired fluoride level in treated water",
      "label_i18n": {
        "en": "Target Fluoride Concentration",
        "tr": "Target Fluoride Concentration",
        "de": "Target Fluoride Concentration",
        "fr": "Target Fluoride Concentration",
        "es": "Target Fluoride Concentration",
        "ar": "Target Fluoride Concentration"
      }
    },
    {
      "id": "rawFluorideConc",
      "label": "Raw Water Fluoride Concentration",
      "type": "number",
      "unit": "mg/L",
      "default": 0.2,
      "businessContext": "Natural fluoride level in source water",
      "label_i18n": {
        "en": "Raw Water Fluoride Concentration",
        "tr": "Raw Water Fluoride Concentration",
        "de": "Raw Water Fluoride Concentration",
        "fr": "Raw Water Fluoride Concentration",
        "es": "Raw Water Fluoride Concentration",
        "ar": "Raw Water Fluoride Concentration"
      }
    },
    {
      "id": "compoundPurity",
      "label": "Compound Purity",
      "type": "number",
      "unit": "%",
      "default": 98,
      "businessContext": "Purity of the fluoride chemical",
      "label_i18n": {
        "en": "Compound Purity",
        "tr": "Compound Purity",
        "de": "Compound Purity",
        "fr": "Compound Purity",
        "es": "Compound Purity",
        "ar": "Compound Purity"
      }
    },
    {
      "id": "fluorideIonPercent",
      "label": "Available Fluoride Ion",
      "type": "number",
      "unit": "%",
      "default": 45,
      "businessContext": "Percentage of fluoride ion in the compound by weight",
      "label_i18n": {
        "en": "Available Fluoride Ion",
        "tr": "Available Fluoride Ion",
        "de": "Available Fluoride Ion",
        "fr": "Available Fluoride Ion",
        "es": "Available Fluoride Ion",
        "ar": "Available Fluoride Ion"
      }
    }
  ],
  "formulas": {
    "fluorideDemand_g_per_day": "waterFlowRate * (targetFluorideConc - rawFluorideConc)",
    "compoundMass_g_per_day": "fluorideDemand_g_per_day / ((compoundPurity / 100) * (fluorideIonPercent / 100))",
    "compoundFeedRate_kg_per_day": "compoundMass_g_per_day / 1000"
  },
  "outputs": {
    "primary": "fluorideDemand_g_per_day",
    "breakdown": [
      {
        "id": "fluorideDemand_g_per_day",
        "label": "Fluoride Demand",
        "unit": "g/day"
      },
      {
        "id": "compoundMass_g_per_day",
        "label": "Pure Compound Mass",
        "unit": "g/day"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "compoundFeedRate_kg_per_day",
    "unit": "m³/day"
  },

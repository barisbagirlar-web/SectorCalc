    },
    {
      "id": "compoundPurity",
      "label": "Compound Purity",
      "type": "number",
      "unit": "%",
      "default": 98,
      "businessContext": "Purity of the fluoride chemical",
      "label_i18n": {
        "en": "Compound Purity",
        "tr": "Bileşik Saflığı",
        "de": "Reinheit der Verbindung",
        "fr": "Pureté du composé",
        "es": "Pureza del compuesto",
        "ar": "نقاء المركب"
      },
      "businessContext_i18n": {
        "en": "Purity of the fluoride chemical",
        "tr": "Florür kimyasalının saflığı",
        "de": "Reinheit der Fluoridchemikalie",
        "fr": "Pureté du composé chimique fluoré",
        "es": "Pureza del químico de fluoruro",
        "ar": "نقاء المادة الكيميائية الفلوريدية"
      }
    },
    {
      "id": "fluorideIonPercent",
      "label": "Available Fluoride Ion",
      "type": "number",
      "unit": "%",
      "default": 45,
      "businessContext": "Percentage of fluoride ion in the compound by weight",
      "label_i18n": {
        "en": "Available Fluoride Ion",
        "tr": "Mevcut Florür İyonu",
        "de": "Verfügbares Fluoridion",
        "fr": "Ion fluorure disponible",
        "es": "Ión fluoruro disponible",
        "ar": "أيون الفلوريد المتاح"
      },
      "businessContext_i18n": {
        "en": "Percentage of fluoride ion in the compound by weight",
        "tr": "Bileşikte ağırlıkça florür iyonu yüzdesi",
        "de": "Gewichtsprozent Fluoridion in der Verbindung",
        "fr": "Pourcentage massique d'ion fluorure dans le composé",
        "es": "Porcentaje de ión fluoruro en el compuesto en peso",
        "ar": "نسبة أيون الفلوريد في المركب بالوزن"
      }
    }
  ],
  "formulas": {
    "fluorideDemand_g_per_day": "waterFlowRate * (targetFluorideConc - rawFluorideConc)",
    "compoundMass_g_per_day": "fluorideDemand_g_per_day / ((compoundPurity / 100) * (fluorideIonPercent / 100))",
    "compoundFeedRate_kg_per_day": "compoundMass_g_per_day / 1000"
  },
  "outputs": {
    "primary": "fluorideDemand_g_per_day",
    "breakdown": [
      {
        "id": "fluorideDemand_g_per_day",
        "label": "Fluoride Demand",
        "unit": "g/day"
      },
      {
        "id": "compoundMass_g_per_day",
        "label": "Pure Compound Mass",
        "unit": "g/day"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "compoundFeedRate_kg_per_day",
    "unit": "m³/day"
  },

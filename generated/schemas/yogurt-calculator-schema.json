{
  "toolName": "yogurt-calculator",
  "inputs": [
    {
      "id": "milkCostPerLiter",
      "label": "Süt Maliyeti (Litre)",
      "type": "number",
      "unit": "₺/L",
      "default": 5,
      "businessContext": "Maliyet"
    },
    {
      "id": "milkYieldPerLiter",
      "label": "Süt Verimi (kg/L)",
      "type": "number",
      "unit": "kg/L",
      "default": 0.95,
      "businessContext": "Verim"
    },
    {
      "id": "starterCultureCostPerBatch",
      "label": "Starter Kültür Maliyeti (Parti Başına)",
      "type": "number",
      "unit": "₺",
      "default": 10,
      "businessContext": "Katkı Maliyeti"
    },
    {
      "id": "batchSizeLiters",
      "label": "Parti Büyüklüğü (Litre)",
      "type": "number",
      "unit": "L",
      "default": 100,
      "businessContext": "Parti Büyüklüğü"
    },
    {
      "id": "packagingCostPerKg",
      "label": "Ambalaj Maliyeti (kg Başına)",
      "type": "number",
      "unit": "₺/kg",
      "default": 2,
      "businessContext": "Ambalaj"
    },
    {
      "id": "overheadCostPerBatch",
      "label": "Genel Giderler (Parti Başına)",
      "type": "number",
      "unit": "₺",
      "default": 50,
      "businessContext": "Genel Giderler"
    }
  ],
  "formulas": {
    "totalYogurt": "milkYieldPerLiter * batchSizeLiters",
    "milkCostTotal": "milkCostPerLiter * batchSizeLiters",
    "totalCost": "milkCostTotal + starterCultureCostPerBatch + (packagingCostPerKg * totalYogurt) + overheadCostPerBatch",
    "costPerKg": "totalCost / totalYogurt"
  },
  "outputs": {
    "primary": "costPerKg",
    "breakdown": [
      "totalYogurt",
      "milkCostTotal",
      "totalCost"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "finance-sales-working-capital"
}

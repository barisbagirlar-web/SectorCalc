  "formulas": {
    "X_Bar_Bar": "AVERAGE(Means)",
    "R_Bar": "AVERAGE(Ranges)",
    "S_Bar": "AVERAGE(StdDevs)",
    "UCL_X": "X_Bar_Bar + (A2 * R_Bar)",
    "LCL_X": "X_Bar_Bar - (A2 * R_Bar)",
    "UCL_R": "D4 * R_Bar",
    "LCL_R": "D3 * R_Bar",
    "Sigma": "R_Bar / d2",
    "Cp": "(USL - LSL) / (6 * Sigma)"
  },

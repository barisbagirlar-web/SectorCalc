        "es": "Duración promedio del ciclo menstrual en días (típicamente 28)",
        "ar": "متوسط طول الدورة الشهرية بالأيام (عادة 28)"
      }
    }
  ],
  "formulas": {
    "currentDateDays": "(currentYear - 1) * 365.25 + (currentMonth - 1) * 30.4375 + currentDay",
    "lmpDateDays": "(lmpYear - 1) * 365.25 + (lmpMonth - 1) * 30.4375 + lmpDay",
    "cycleAdjustment": "cycleLength - 28",
    "totalDaysPregnant": "currentDateDays - lmpDateDays + cycleAdjustment",
    "weeksPregnant": "totalDaysPregnant / 7"
  },
  "outputs": {
    "primary": "weeksPregnant",
    "breakdown": [
      "totalDaysPregnant",
      "cycleAdjustment"
    ],

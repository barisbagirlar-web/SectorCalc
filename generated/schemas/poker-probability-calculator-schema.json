{
  "toolName": "poker-probability-calculator",
  "inputs": [
    {
      "id": "knownCards",
      "label": "Known Cards",
      "type": "number",
      "unit": "cards",
      "default": 2,
      "businessContext": "Number of cards you have seen, including your hole cards and any community cards.",
      "label_i18n": {
        "en": "Known Cards",
        "tr": "Known Cards",

      }
    },
    {
      "id": "deckSize",
      "label": "Deck Size",
      "type": "number",
      "unit": "cards",
      "default": 52,
      "businessContext": "Total number of cards in the deck.",
      "label_i18n": {
        "en": "Deck Size",
        "tr": "Deck Size",
        "de": "Deck Size",
        "fr": "Deck Size",
        "es": "Deck Size",
        "ar": "Deck Size"
      }
    },
    {
      "id": "outs",
      "label": "Outs",
      "type": "number",
      "unit": "cards",
      "default": 4,
      "businessContext": "Number of cards in the remaining deck that will improve your hand to a winner.",
      "label_i18n": {
        "en": "Outs",
        "tr": "Outs",
        "de": "Outs",
        "fr": "Outs",
        "es": "Outs",
        "ar": "Outs"
      }
    },
    {
      "id": "draws",
      "label": "Cards to Draw",
      "type": "number",
      "unit": "cards",
      "default": 1,
      "businessContext": "Number of upcoming community cards to be dealt (e.g., 1 for turn only, 2 for turn and river).",
      "label_i18n": {
        "en": "Cards to Draw",
        "tr": "Cards to Draw",
        "de": "Cards to Draw",
        "fr": "Cards to Draw",
        "es": "Cards to Draw",
        "ar": "Cards to Draw"
      }
    }
  ],
  "formulas": {
    "remaining": "deckSize - knownCards",
    "missProb": "((remaining - outs) / remaining) ** draws",
    "winProbability": "(1 - missProb) * 100",
    "lossProbability": "missProb * 100",
    "oddsAgainst": "missProb / (1 - missProb)"
  },
  "outputs": {
    "primary": "winProbability",
    "breakdown": [
      "lossProbability",
      "oddsAgainst"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "oddsAgainst",
    "unit": "cards"
  },

      "label_i18n": {
        "en": "Overlap Distance",
        "tr": "Overlap Distance",
        "de": "Overlap Distance",
        "fr": "Overlap Distance",
        "es": "Overlap Distance",
        "ar": "Overlap Distance"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage extra material for cutting waste and errors (e.g., 5)",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "effectiveWidth": "rollWidth - overlapDistance",
    "effectiveCoverage": "effectiveWidth * rollLength",
    "requiredArea": "surfaceArea * (1 + wasteFactor / 100)"
  },
  "outputs": {
    "primary": "requiredArea",
    "breakdown": [
      "effectiveCoverage",

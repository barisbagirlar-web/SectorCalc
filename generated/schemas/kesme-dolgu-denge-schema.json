  "formulas": {
    "Volume_Cut": "SUM(Area_Cut_i * Distance_i)",
    "Volume_Fill": "SUM(Area_Fill_i * Distance_i)",
    "ShrinkageFactor": "1 - (CompactedVolume / LooseVolume)",
    "SwellFactor": "LooseVolume / BankVolume",
    "NetBalance": "Volume_Cut - (Volume_Fill * ShrinkageFactor)",
    "BorrowRequired": "MAX(0, (Volume_Fill * ShrinkageFactor) - Volume_Cut)",
    "WasteRequired": "MAX(0, Volume_Cut - (Volume_Fill * ShrinkageFactor))",
    "HaulCost": "SUM(Volume_i * Distance_i * UnitHaulCost)"
  },

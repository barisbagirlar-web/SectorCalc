  ],
  "formulas": {
    "totalCapitalCost": "capitalCostPerKW * plantCapacity",
    "discountRateDec": "discountRate / 100",
    "annualFixedOandM": "fixedOandM * plantCapacity",
    "capacityFactorDec": "capacityFactor / 100",
    "annualEnergyOutput": "plantCapacity * capacityFactorDec * 8760 / 1000",
    "annualVariableOandM": "variableOandM * annualEnergyOutput",
    "annualFuelCost": "fuelCost * annualEnergyOutput"
  },
  "outputs": {
    "primary": "annualFuelCost",
    "breakdown": [
      "annualCapitalCost",
      "annualFixedOandM",
      "annualVariableOandM",
      "annualFuelCost",
      "annualEnergyOutput"
    ],

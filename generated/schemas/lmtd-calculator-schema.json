        "es": "Cold Outlet Temperature",
        "ar": "Cold Outlet Temperature"
      }
    },
    {
      "id": "flowType",
      "label": "Flow Arrangement (1=Counterflow, 2=Parallel)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Heat exchanger flow configuration. Use 1 for counterflow, 2 for parallel flow.",
      "label_i18n": {
        "en": "Flow Arrangement (1=Counterflow, 2=Parallel)",
        "tr": "Flow Arrangement (1=Counterflow, 2=Parallel)",
        "de": "Flow Arrangement (1=Counterflow, 2=Parallel)",
        "fr": "Flow Arrangement (1=Counterflow, 2=Parallel)",
        "es": "Flow Arrangement (1=Counterflow, 2=Parallel)",
        "ar": "Flow Arrangement (1=Counterflow, 2=Parallel)"
      }
    }
  ],
  "formulas": {
    "deltaT1": "flowType === 1 ? (thIn - tcOut) : (thIn - tcIn)",
    "deltaT2": "flowType === 1 ? (thOut - tcIn) : (thOut - tcOut)"
  },
  "outputs": {
    "primary": "deltaT2",
    "breakdown": [

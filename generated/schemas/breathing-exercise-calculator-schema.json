      "label": "Ambient Pressure",
      "type": "number",
      "unit": "atm",
      "default": 1,
      "businessContext": "Atmospheric pressure at the working location (1 atm at sea level)",
      "label_i18n": {
        "en": "Ambient Pressure",
        "tr": "Ortam basıncı",
        "de": "Ambient Pressure",
        "fr": "Ambient Pressure",

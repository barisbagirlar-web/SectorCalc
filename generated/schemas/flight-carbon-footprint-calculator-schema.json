{
  "toolName": "flight-carbon-footprint-calculator",
  "inputs": [
    {
      "id": "distance_km",
      "label": "Uçuş Mesafesi",
      "type": "number",
      "unit": "km",
      "default": 1000,
      "businessContext": "Kalkış ve varış noktaları arasındaki büyük daire mesafesi",
      "label_i18n": {
        "en": "Uçuş Mesafesi",
        "tr": "Uçuş Mesafesi",

        "fr": "Uçuş Mesafesi",
        "es": "Uçuş Mesafesi",
        "ar": "Uçuş Mesafesi"
      }
    },
    {
      "id": "fuel_burn_per_100_pkm",
      "label": "Yakıt Tüketimi",
      "type": "number",
      "unit": "L/100 pkm",
      "default": 3.5,
      "businessContext": "100 yolcu-kilometre başına litre cinsinden ortalama yakıt tüketimi (uçak tipine göre değişir)",
      "label_i18n": {
        "en": "Yakıt Tüketimi",
        "tr": "Yakıt Tüketimi",
        "de": "Yakıt Tüketimi",
        "fr": "Yakıt Tüketimi",
        "es": "Yakıt Tüketimi",
        "ar": "Yakıt Tüketimi"
      }
    },
    {
      "id": "emission_factor_kg_per_liter",
      "label": "Emisyon Faktörü",
      "type": "number",
      "unit": "kg CO₂/L",
      "default": 2.52,
      "businessContext": "Jet yakıtının yanması sonucu litre başına salınan CO₂ miktarı",
      "label_i18n": {
        "en": "Emisyon Faktörü",
        "tr": "Emisyon Faktörü",
        "de": "Emisyon Faktörü",
        "fr": "Emisyon Faktörü",
        "es": "Emisyon Faktörü",
        "ar": "Emisyon Faktörü"
      }
    },
    {
      "id": "class_multiplier",
      "label": "Sınıf Çarpanı",
      "type": "number",
      "unit": "çarpan",
      "default": 1,
      "businessContext": "Ekonomi=1, Business=2, First=3 gibi koltuk sınıfının kapladığı alan oranına göre düzeltme faktörü",
      "label_i18n": {
        "en": "Sınıf Çarpanı",
        "tr": "Sınıf Çarpanı",
        "de": "Sınıf Çarpanı",
        "fr": "Sınıf Çarpanı",
        "es": "Sınıf Çarpanı",
        "ar": "Sınıf Çarpanı"
      }
    },
    {
      "id": "radiative_forcing_index",
      "label": "Işınımsal Zorlama İndisi",
      "type": "number",
      "unit": "çarpan",
      "default": 1.9,
      "businessContext": "Yüksek irtifada salınan emisyonların ek iklim etkisini hesaba katan çarpan (IPCC önerisi: 1.9)",
      "label_i18n": {
        "en": "Işınımsal Zorlama İndisi",
        "tr": "Işınımsal Zorlama İndisi",
        "de": "Işınımsal Zorlama İndisi",
        "fr": "Işınımsal Zorlama İndisi",
        "es": "Işınımsal Zorlama İndisi",
        "ar": "Işınımsal Zorlama İndisi"
      }
    }
  ],
  "formulas": {
    "total_kg_CO2e": "distance_km * fuel_burn_per_100_pkm / 100 * emission_factor_kg_per_liter * class_multiplier * radiative_forcing_index",
    "base_kg_CO2": "distance_km * fuel_burn_per_100_pkm / 100 * emission_factor_kg_per_liter * class_multiplier",
    "radiative_forcing_contribution_kg_CO2e": "total_kg_CO2e - base_kg_CO2"
  },
  "outputs": {
    "primary": "total_kg_CO2e",
    "breakdown": [
      "base_kg_CO2",
      "radiative_forcing_contribution_kg_CO2e"
    ],

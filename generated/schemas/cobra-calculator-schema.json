  "formulas": {
    "totalPremium": "monthlyPremium * beneficiaries * coverageMonths",
    "adminFeeAmount": "totalPremium * adminFeeRate / 100",
    "totalCostWithoutContribution": "totalPremium + adminFeeAmount",
    "employerContributionAmount": "totalCostWithoutContribution * employerContributionRate / 100",
    "totalEmployeeCost": "totalCostWithoutContribution - employerContributionAmount"
  },
  "outputs": {
    "primary": "totalEmployeeCost",
    "breakdown": [
      "totalPremium",
      "adminFeeAmount",

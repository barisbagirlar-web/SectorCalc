{
  "toolName": "rir-calculator",
  "inputs": [
    {
      "id": "recordableCases",
      "label": "Number of Recordable Cases",
      "type": "number",
      "unit": "cases",
      "default": 5,
      "businessContext": "OSHA recordable work-related injuries and illnesses in the period.",
      "label_i18n": {
        "en": "Number of Recordable Cases",
        "tr": "Number of Recordable Cases",
        "de": "Number of Recordable Cases",
        "fr": "Number of Recordable Cases",
        "es": "Number of Recordable Cases",
        "ar": "Number of Recordable Cases"
      }
    },
    {
      "id": "employeeCount",
      "label": "Number of Employees",
      "type": "number",
      "unit": "FTE",
      "default": 100,
      "businessContext": "Full-time equivalent employees during the period.",
      "label_i18n": {
        "en": "Number of Employees",
        "tr": "Number of Employees",
        "de": "Number of Employees",
        "fr": "Number of Employees",
        "es": "Number of Employees",
        "ar": "Number of Employees"
      }
    },
    {
      "id": "hoursPerWeek",
      "label": "Hours Worked per Week",
      "type": "number",
      "unit": "hours",
      "default": 40,
      "businessContext": "Standard work hours per employee per week.",
      "label_i18n": {
        "en": "Hours Worked per Week",
        "tr": "Hours Worked per Week",
        "de": "Hours Worked per Week",
        "fr": "Hours Worked per Week",
        "es": "Hours Worked per Week",
        "ar": "Hours Worked per Week"
      }
    },
    {
      "id": "weeksPerYear",
      "label": "Weeks Worked per Year",
      "type": "number",
      "unit": "weeks",
      "default": 50,
      "businessContext": "Weeks per year the employees actually work (excluding holidays, vacations).",
      "label_i18n": {
        "en": "Weeks Worked per Year",
        "tr": "Weeks Worked per Year",
        "de": "Weeks Worked per Year",
        "fr": "Weeks Worked per Year",
        "es": "Weeks Worked per Year",
        "ar": "Weeks Worked per Year"
      }
    }
  ],
  "formulas": {
    "recordableIncidentRate": "(recordableCases * 200000) / (employeeCount * hoursPerWeek * weeksPerYear)",
    "totalHoursWorked": "employeeCount * hoursPerWeek * weeksPerYear",
    "numberOfRecordableCases": "recordableCases"
  },
  "outputs": {
    "primary": "recordableIncidentRate",
    "breakdown": [
      "totalHoursWorked",
      "numberOfRecordableCases"
    ],

{
  "toolName": "bond-calculator",
  "inputs": [
    {
      "id": "faceValue",
      "label": "Face Value",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "Par value of the bond paid at maturity",
      "label_i18n": {
        "en": "Face Value",
        "tr": "Face Value",
        "de": "Face Value",
        "fr": "Face Value",
        "es": "Face Value",
        "ar": "Face Value"
      }
    },
    {
      "id": "couponRate",
      "label": "Coupon Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual coupon payment as a percentage of face value",
      "label_i18n": {
        "en": "Coupon Rate",
        "tr": "Coupon Rate",
        "de": "Coupon Rate",
        "fr": "Coupon Rate",
        "es": "Coupon Rate",
        "ar": "Coupon Rate"
      }
    },
    {
      "id": "marketRate",
      "label": "Market Interest Rate (YTM)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Yield to maturity required by investors",
      "label_i18n": {
        "en": "Market Interest Rate (YTM)",
        "tr": "Market Interest Rate (YTM)",
        "de": "Market Interest Rate (YTM)",
        "fr": "Market Interest Rate (YTM)",
        "es": "Market Interest Rate (YTM)",
        "ar": "Market Interest Rate (YTM)"
      }
    },
    {
      "id": "yearsToMaturity",
      "label": "Years to Maturity",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time until bond matures",
      "label_i18n": {
        "en": "Years to Maturity",
        "tr": "Years to Maturity",
        "de": "Years to Maturity",
        "fr": "Years to Maturity",
        "es": "Years to Maturity",
        "ar": "Years to Maturity"
      }
    },
    {
      "id": "frequency",
      "label": "Coupon Frequency",
      "type": "number",
      "unit": "per year",
      "default": 2,
      "businessContext": "Number of coupon payments per year (e.g., 2 for semi-annual)",
      "label_i18n": {
        "en": "Coupon Frequency",
        "tr": "Coupon Frequency",
        "de": "Coupon Frequency",
        "fr": "Coupon Frequency",
        "es": "Coupon Frequency",
        "ar": "Coupon Frequency"
      }
    }
  ],
  "formulas": {
    "couponPayment": "faceValue * couponRate / 100 / frequency",
    "discountRate": "marketRate / 100 / frequency",
    "totalPeriods": "yearsToMaturity * frequency",
    "pvCoupons": "couponPayment * (1 - (1 + discountRate) ** (-totalPeriods)) / discountRate",
    "pvFace": "faceValue * (1 + discountRate) ** (-totalPeriods)",
    "bondPrice": "discountRate === 0 ? faceValue + couponPayment * totalPeriods : pvCoupons + pvFace"
  },
  "outputs": {
    "primary": "couponPayment",
    "breakdown": [
      "Coupon Payment",
      "Discount Rate per Period",
      "Total Periods",
      "Present Value of Coupons",
      "Present Value of Face Value",
      "Bond Price"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bondPrice"
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "quality",

        "ar": "Aperture (f-stop)"
      }
    },
    {
      "id": "shutterSpeed",
      "label": "Shutter Speed",
      "type": "number",
      "unit": "s",
      "default": 0.008,
      "businessContext": "Exposure time in seconds.",
      "label_i18n": {
        "en": "Shutter Speed",
        "tr": "Shutter Speed",
        "de": "Shutter Speed",
        "fr": "Shutter Speed",
        "es": "Shutter Speed",
        "ar": "Shutter Speed"
      }
    },
    {
      "id": "iso",
      "label": "ISO",
      "type": "number",
      "unit": "unit",
      "default": 100,
      "businessContext": "Sensor sensitivity rating.",
      "label_i18n": {
        "en": "ISO",
        "tr": "ISO",
        "de": "ISO",
        "fr": "ISO",
        "es": "ISO",
        "ar": "ISO"
      }
    },
    {
      "id": "measuredEV",
      "label": "Measured EV",
      "type": "number",
      "unit": "EV",
      "default": 12,
      "businessContext": "Exposure value from light meter.",
      "label_i18n": {
        "en": "Measured EV",
        "tr": "Measured EV",
        "de": "Measured EV",
        "fr": "Measured EV",
        "es": "Measured EV",
        "ar": "Measured EV"
      }
    }
  ],
  "formulas": {
    "calculatedEV": "Math.log2((aperture * aperture) / shutterSpeed) + Math.log2(iso / 100)",
    "difference": "measuredEV - calculatedEV"
  },
  "outputs": {
    "primary": "calculatedEV",
    "breakdown": [
      "calculatedEV",
      "difference"
    ]
  },

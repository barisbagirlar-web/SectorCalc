{
  "toolName": "excise-tax-calculator",
  "inputs": [
    {
      "id": "unitPrice",
      "label": "Birim Fiyat",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "Ürünün vergi hariç birim fiyatı",
      "label_i18n": {
        "en": "Birim Fiyat",
        "tr": "Unit Price",
        "de": "Stückpreis",
        "fr": "Prix unitaire",
        "es": "Precio unitario",
        "ar": "سعر الوحدة"
      },
      "businessContext_i18n": {
        "en": "Unit price excluding tax (USD)",
        "tr": "Ürünün vergi hariç birim fiyatı",
        "de": "Stückpreis des Produkts ohne Steuern",
        "fr": "Prix unitaire du produit hors taxes",
        "es": "Precio unitario del producto sin impuestos",
        "ar": "سعر الوحدة للمنتج باستثناء الضريبة"
      }
    },
    {
      "id": "quantity",
      "label": "Miktar",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Satılan veya üretilen birim sayısı",
      "label_i18n": {
        "en": "Miktar",
        "tr": "Quantity",
        "de": "Menge",
        "fr": "Quantité",
        "es": "Cantidad",
        "ar": "الكمية"
      },
      "businessContext_i18n": {
        "en": "Number of units sold or produced",
        "tr": "Satılan veya üretilen birim sayısı",
        "de": "Anzahl der verkauften oder produzierten Einheiten",
        "fr": "Nombre d'unités vendues ou produites",
        "es": "Número de unidades vendidas o producidas",
        "ar": "عدد الوحدات المباعة أو المنتجة"
      }
    },
    {
      "id": "adValoremRate",
      "label": "Ad Valorem Oranı",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Vergi matrahına uygulanan yüzdesel oran",
      "label_i18n": {
        "en": "Ad Valorem rate (%)",
        "tr": "Ad Valorem Oranı",
        "de": "Ad-Valorem-Satz",
        "fr": "Taux ad valorem",
        "es": "Tasa ad valorem",
        "ar": "نسبة القيمة المضافة"
      },
      "businessContext_i18n": {
        "en": "Percentage rate applied to tax base (%)",
        "tr": "Vergi matrahına uygulanan yüzdesel oran",
        "de": "Prozentsatz, der auf die Steuerbemessungsgrundlage angewendet wird",
        "fr": "Taux en pourcentage appliqué à la base d'imposition",
        "es": "Porcentaje aplicado a la base imponible",
        "ar": "النسبة المئوية المطبقة على الوعاء الضريبي"
      }
    },
    {
      "id": "specificTaxPerUnit",
      "label": "Birim Spesifik Vergi",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "Her birim başına uygulanan sabit vergi tutarı",
      "label_i18n": {
        "en": "Birim Spesifik Vergi",
        "tr": "Specific Tax per Unit",
        "de": "Spezifische Steuer pro Einheit",
        "fr": "Taxe spécifique par unité",
        "es": "Impuesto específico por unidad",
        "ar": "ضريبة محددة لكل وحدة"
      },
      "businessContext_i18n": {
        "en": "Fixed tax amount per unit (USD)",
        "tr": "Her birim başına uygulanan sabit vergi tutarı",
        "de": "Fester Steuerbetrag pro Einheit",
        "fr": "Montant de taxe fixe appliqué par unité",
        "es": "Monto fijo de impuesto aplicado por cada unidad",
        "ar": "مبلغ الضريبة الثابت المطبق على كل وحدة"
      }
    }
  ],
  "formulas": {
    "totalExciseTax": "quantity * specificTaxPerUnit + unitPrice * quantity * (adValoremRate / 100)",
    "specificTaxAmount": "quantity * specificTaxPerUnit",
    "adValoremTaxAmount": "unitPrice * quantity * (adValoremRate / 100)"
  },
  "outputs": {
    "primary": "totalExciseTax",
    "breakdown": [
      "specificTaxAmount",
      "adValoremTaxAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "adValoremTaxAmount",
    "unit": "currency"
  },

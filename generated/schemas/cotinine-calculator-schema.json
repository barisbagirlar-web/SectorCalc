{
  "toolName": "cotinine-calculator",
  "inputs": [
    {
      "id": "cotininePlasma",
      "label": "Plasma Cotinine",
      "type": "number",
      "unit": "ng/mL",
      "default": 200,
      "businessContext": "Measured concentration of cotinine in plasma.",
      "label_i18n": {
        "en": "Plasma Cotinine",
        "tr": "Plasma Cotinine",
        "de": "Plasma Cotinine",
        "fr": "Plasma Cotinine",
        "es": "Plasma Cotinine",
        "ar": "Plasma Cotinine"
      }
    },
    {
      "id": "slope",
      "label": "Calibration Slope",
      "type": "number",
      "unit": "ng/mL per cigarette/day",
      "default": 12.5,
      "businessContext": "Slope of the cotinine vs cigarettes per day linear model.",
      "label_i18n": {
        "en": "Calibration Slope",
        "tr": "Calibration Slope",
        "de": "Calibration Slope",
        "fr": "Calibration Slope",
        "es": "Calibration Slope",
        "ar": "Calibration Slope"
      }
    },
    {
      "id": "intercept",
      "label": "Calibration Intercept",
      "type": "number",
      "unit": "ng/mL",
      "default": 0,
      "businessContext": "Intercept of the linear model.",
      "label_i18n": {
        "en": "Calibration Intercept",
        "tr": "Calibration Intercept",
        "de": "Calibration Intercept",
        "fr": "Calibration Intercept",
        "es": "Calibration Intercept",
        "ar": "Calibration Intercept"
      }
    },
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Subject's body weight for dose normalization.",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "nicotinePerCig",
      "label": "Nicotine per Cigarette",
      "type": "number",
      "unit": "mg",
      "default": 1,
      "businessContext": "Average nicotine delivered per cigarette.",
      "label_i18n": {
        "en": "Nicotine per Cigarette",
        "tr": "Nicotine per Cigarette",
        "de": "Nicotine per Cigarette",
        "fr": "Nicotine per Cigarette",
        "es": "Nicotine per Cigarette",
        "ar": "Nicotine per Cigarette"
      }
    }
  ],
  "formulas": {
    "estimatedCigarettesPerDay": "Math.max(0, (cotininePlasma - intercept) / slope)",
    "nicotineIntakeMg": "Math.max(0, (cotininePlasma - intercept) / slope) * nicotinePerCig",
    "nicotineIntakeMgPerKg": "Math.max(0, (cotininePlasma - intercept) / slope) * nicotinePerCig / bodyWeight",
    "Nicotine_Intake__mg_day_": "Nicotine Intake (mg/day)",
    "Nicotine_Intake__mg_kg_day_": "Nicotine Intake (mg/kg/day)"
  },
  "outputs": {
    "primary": "estimatedCigarettesPerDay",
    "breakdown": [
      "Nicotine Intake (mg/day)",
      "Nicotine Intake (mg/kg/day)"
    ]
  },

      }
    },
    {
      "id": "x1",
      "label": "x1",
      "type": "number",
      "unit": "unit",
      "default": -1,
      "businessContext": "Left endpoint of interval",
      "label_i18n": {
        "en": "x1",
        "tr": "x1",
        "de": "x1",
        "fr": "x1",
        "es": "x1",
        "ar": "x1"
      }
    },
    {
      "id": "x2",
      "label": "x2",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Right endpoint of interval",
      "label_i18n": {
        "en": "x2",
        "tr": "x2",
        "de": "x2",
        "fr": "x2",
        "es": "x2",
        "ar": "x2"
      }
    }
  ],
  "formulas": {
    "f_x1": "a*x1*x1 + bCoef*x1 + cConst",
    "f_x2": "a*x2*x2 + bCoef*x2 + cConst",
    "conditionMet": "Math.abs(f_x1 - f_x2) < 1e-9",
    "c": "conditionMet ? -bCoef / (2*a) : null"
  },
  "outputs": {
    "primary": "c",
    "breakdown": [
      "f_x1",
      "f_x2",
      "conditionMet"
    ]
  },

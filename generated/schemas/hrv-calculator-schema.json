    },
    {
      "id": "operatingHours",
      "label": "Annual Operating Hours",
      "type": "number",
      "unit": "h/year",
      "default": 4000,
      "businessContext": "Hours per year the HRV operates",
      "label_i18n": {
        "en": "Annual Operating Hours",
        "tr": "Annual Operating Hours",

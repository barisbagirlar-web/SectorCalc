  "formulas": {
    "effectiveness": "(supplyTemp - outdoorTemp) / (indoorTemp - outdoorTemp)",
    "heatRate": "(airFlowRate * airDensity * specificHeat * (supplyTemp - outdoorTemp)) / 3600",
    "annualEnergySaved": "heatRate * operatingHours"
  },
  "outputs": {
    "primary": "effectiveness",
    "breakdown": [
      "heatRate",
      "annualEnergySaved"
    ],

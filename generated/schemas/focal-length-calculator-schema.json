{
  "toolName": "focal-length-calculator",
  "inputs": [
    {
      "id": "n",
      "label": "Refractive Index (n)",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Refractive index of the lens material (e.g., 1.5 for typical glass)",
      "label_i18n": {
        "en": "Refractive Index (n)",
        "tr": "Refractive Index (n)",
        "de": "Refractive Index (n)",
        "fr": "Refractive Index (n)",
        "es": "Refractive Index (n)",
        "ar": "Refractive Index (n)"
      }
    },
    {
      "id": "R1",
      "label": "Radius of Curvature 1 (R1)",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Radius of curvature of the first lens surface; positive if center of curvature is to the right",
      "label_i18n": {
        "en": "Radius of Curvature 1 (R1)",
        "tr": "Radius of Curvature 1 (R1)",
        "de": "Radius of Curvature 1 (R1)",
        "fr": "Radius of Curvature 1 (R1)",
        "es": "Radius of Curvature 1 (R1)",
        "ar": "Radius of Curvature 1 (R1)"
      }
    },
    {
      "id": "R2",
      "label": "Radius of Curvature 2 (R2)",
      "type": "number",
      "unit": "mm",
      "default": -100,
      "businessContext": "Radius of curvature of the second lens surface; positive if center of curvature is to the right",
      "label_i18n": {
        "en": "Radius of Curvature 2 (R2)",
        "tr": "Radius of Curvature 2 (R2)",
        "de": "Radius of Curvature 2 (R2)",
        "fr": "Radius of Curvature 2 (R2)",
        "es": "Radius of Curvature 2 (R2)",
        "ar": "Radius of Curvature 2 (R2)"
      }
    },
    {
      "id": "d",
      "label": "Center Thickness (d)",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Thickness of the lens at its optical center",
      "label_i18n": {
        "en": "Center Thickness (d)",
        "tr": "Center Thickness (d)",
        "de": "Center Thickness (d)",
        "fr": "Center Thickness (d)",
        "es": "Center Thickness (d)",
        "ar": "Center Thickness (d)"
      }
    }
  ],
  "formulas": {
    "focalLength": "1 / ((n - 1) * (1 / R1 - 1 / R2 + (n - 1) * d / (n * R1 * R2)))",
    "frontFocalLength": "focalLength * (1 - (n - 1) * d / (n * R1))",
    "backFocalLength": "focalLength * (1 - (n - 1) * d / (n * R2))"
  },
  "outputs": {
    "primary": "focalLength",
    "breakdown": [
      "frontFocalLength",
      "backFocalLength"
    ]
  },

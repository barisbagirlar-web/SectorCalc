  "formulas": {
    "Active": "SUM(kWh)",
    "Reactive": "SUM(kVArh)",
    "PF": "Active / SQRT(Active^2 + Reactive^2)",
    "ReactivePenalty": "IF(PF < Thresh, (Reactive - Active * TAN(ACOS(Thresh))) * Tariff, 0)",
    "DemandCharge": "Peak_kW * DemandRate",
    "TOU": "SUM(kWh * TOU_Rate)",
    "Total": "Base + TOU + Demand + Penalty + Tax",
    "Carbon": "Active * EmisFactor * CarbonPrice"
  },

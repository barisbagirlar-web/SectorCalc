{
  "toolName": "snowboarding-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight directly influences energy expenditure; heavier individuals burn more calories.",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "minutes",
      "default": 60,
      "businessContext": "Time spent actively snowboarding; longer duration increases total calorie burn.",
      "label_i18n": {
        "en": "Duration",
        "tr": "Duration",
        "de": "Duration",
        "fr": "Duration",
        "es": "Duration",
        "ar": "Duration"
      }
    },
    {
      "id": "intensity",
      "label": "Intensity Level",
      "type": "number",
      "unit": "scale 1-10",
      "default": 5,
      "businessContext": "Perceived exertion from 1 (very light, like easy cruising) to 10 (extreme, like aggressive carving or backcountry); used to derive metabolic equivalent (MET).",
      "label_i18n": {
        "en": "Intensity Level",
        "tr": "Intensity Level",
        "de": "Intensity Level",
        "fr": "Intensity Level",
        "es": "Intensity Level",
        "ar": "Intensity Level"
      }
    },
    {
      "id": "altitude",
      "label": "Altitude",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Above sea level altitude of the snowboarding location; higher altitude increases metabolic rate due to reduced oxygen availability.",
      "label_i18n": {
        "en": "Altitude",
        "tr": "Altitude",
        "de": "Altitude",
        "fr": "Altitude",
        "es": "Altitude",
        "ar": "Altitude"
      }
    },
    {
      "id": "correctionFactor",
      "label": "Correction Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Personal adjustment factor to account for individual metabolic variations (e.g., fitness level, genetics); typical range 0.8–1.2.",
      "label_i18n": {
        "en": "Correction Factor",
        "tr": "Correction Factor",
        "de": "Correction Factor",
        "fr": "Correction Factor",
        "es": "Correction Factor",
        "ar": "Correction Factor"
      }
    }
  ],
  "formulas": {
    "met": "4.0 + intensity * 0.4",
    "altFactor": "1 + altitude * 0.00002",
    "baseCalories": "weight * met * (duration / 60)",
    "caloriesBurned": "baseCalories * altFactor * correctionFactor"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "met",
      "altFactor",
      "baseCalories"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "caloriesBurned"
  },

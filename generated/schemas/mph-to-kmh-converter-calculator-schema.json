{
  "toolName": "mph-to-kmh-converter-calculator",
  "inputs": [
    {
      "id": "mphValue",
      "label": "Speed (mph)",
      "type": "number",
      "unit": "mph",
      "default": 60,
      "businessContext": "The speed in miles per hour to be converted.",
      "label_i18n": {
        "en": "Speed (mph)",
        "tr": "Speed (mph)",
        "de": "Speed (mph)",
        "fr": "Speed (mph)",
        "es": "Speed (mph)",
        "ar": "Speed (mph)"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the result.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "outputUnit",
      "label": "Target Unit",
      "type": "number",
      "unit": "code",
      "default": 0,
      "businessContext": "0: km/h, 1: m/s, 2: knots",
      "label_i18n": {
        "en": "Target Unit",
        "tr": "Target Unit",
        "de": "Target Unit",
        "fr": "Target Unit",
        "es": "Target Unit",
        "ar": "Target Unit"
      }
    },
    {
      "id": "roundingMode",
      "label": "Rounding Mode",
      "type": "number",
      "unit": "code",
      "default": 0,
      "businessContext": "0: standard rounding, 1: floor, 2: ceil",
      "label_i18n": {
        "en": "Rounding Mode",
        "tr": "Rounding Mode",
        "de": "Rounding Mode",
        "fr": "Rounding Mode",
        "es": "Rounding Mode",
        "ar": "Rounding Mode"
      }
    }
  ],
  "formulas": {
    "rawValue": "mphValue * (outputUnit === 0 ? 1.609344 : outputUnit === 1 ? 0.44704 : 0.868976)",
    "conversionFactorUsed": "outputUnit === 0 ? 1.609344 : outputUnit === 1 ? 0.44704 : 0.868976",
    "convertedSpeed": "(roundingMode === 0 ? Math.round : roundingMode === 1 ? Math.floor : Math.ceil)(rawValue * Math.pow(10, precision)) / Math.pow(10, precision)",
    "formattedResult": "convertedSpeed + ' ' + (outputUnit === 0 ? 'km/h' : outputUnit === 1 ? 'm/s' : 'knots')"
  },
  "outputs": {
    "primary": "convertedSpeed",
    "breakdown": [
      "rawValue",
      "conversionFactorUsed",
      "formattedResult"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "conversion"
}

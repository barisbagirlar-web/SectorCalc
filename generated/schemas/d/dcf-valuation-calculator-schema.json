  "formulas": {
    "fcfbd1": "fcf1 / Math.pow(1 + WACC / 100, 1)",
    "fcfbd2": "fcf2 / Math.pow(1 + WACC / 100, 2)",
    "fcfbd3": "fcf3 / Math.pow(1 + WACC / 100, 3)",
    "fcfbd4": "fcf4 / Math.pow(1 + WACC / 100, 4)",
    "fcfbd5": "fcf5 / Math.pow(1 + WACC / 100, 5)",
    "tv": "fcf5 * (1 + terminalBuyume / 100) / Math.max(0.0001, (WACC / 100 - terminalBuyume / 100))",
    "tvbd": "fcf5 * (1 + terminalBuyume / 100) / Math.max(0.0001, (WACC / 100 - terminalBuyume / 100)) / Math.pow(1 + WACC / 100, 5)",
    "result": "fcf1 / Math.pow(1 + WACC/100, 1) + fcf2 / Math.pow(1 + WACC/100, 2) + fcf3 / Math.pow(1 + WACC/100, 3) + fcf4 / Math.pow(1 + WACC/100, 4) + fcf5 / Math.pow(1 + WACC/100, 5) + (fcf5 * (1 + terminalBuyume/100) / Math.max(0.0001, (WACC/100 - terminalBuyume/100))) / Math.pow(1 + WACC/100, 5)"
  },

{
  "toolName": "dupont-roi-calculator",
  "catalogCategory": "finance-business",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finance",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "netKar",
      "label": "Net Income (USD)",
      "type": "number",
      "unit": "USD",
      "default": 150000,
      "min": 0,
      "businessContext": "Net income for the period."
    },
    {
      "id": "satislar",
      "label": "Sales (USD)",
      "type": "number",
      "unit": "USD",
      "default": 2000000,
      "min": 0,
      "businessContext": "Total sales revenue."
    },
    {
      "id": "varliklar",
      "label": "Total Assets (USD)",
      "type": "number",
      "unit": "USD",
      "default": 3000000,
      "min": 0,
      "businessContext": "Total assets."
    },
    {
      "id": "ozsermaye",
      "label": "Equity (USD)",
      "type": "number",
      "unit": "USD",
      "default": 1500000,
      "min": 0,
      "businessContext": "Total shareholders equity."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "profitMarji": "netKar / Math.max(1, satislar)",
    "varlikDevri": "satislar / Math.max(1, varliklar)",
    "kaldirac": "varliklar / Math.max(1, ozsermaye)",
    "result": "(netKar / Math.max(1, satislar)) * (satislar / Math.max(1, varliklar)) * (varliklar / Math.max(1, ozsermaye)) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "DuPont ROE"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate DuPont ROE decomposition — profitability, efficiency, leverage.",
      "long": "Calculate DuPont ROE decomposition — profitability, efficiency, leverage."
    }
  },
  "sectorSlug": "ecommerce"
}

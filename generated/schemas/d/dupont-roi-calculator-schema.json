  "formulas": {
    "profitMarji": "netKar / Math.max(1, satislar)",
    "varlikDevri": "satislar / Math.max(1, varliklar)",
    "kaldirac": "varliklar / Math.max(1, ozsermaye)",
    "result": "(netKar / Math.max(1, satislar)) * (satislar / Math.max(1, varliklar)) * (varliklar / Math.max(1, ozsermaye)) * 100"
  },

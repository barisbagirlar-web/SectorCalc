{
  "toolName": "draft-angle-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "parcaDerinlik",
      "label": "Part Depth (mm)",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "min": 0,
      "businessContext": "Part depth in mold direction."
    },
    {
      "id": "buzulmeOrani",
      "label": "Shrinkage Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 1.5,
      "min": 0,
      "businessContext": "Polymer shrinkage rate."
    },
    {
      "id": "yanYuzeyUzunluk",
      "label": "Side Wall Length (mm)",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "min": 0,
      "businessContext": "Mold side wall length."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.atan((parcaDerinlik * (buzulmeOrani / 100)) / Math.max(0.0001, yanYuzeyUzunluk)) * (180 / Math.PI)"
  },
  "outputs": {
    "primary": "result",
    "unit": "degrees",
    "breakdown": {
      "result": "Gerekli Draft Acisi"
    },
    "breakdownUnits": {
      "result": "degrees"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling process for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate minimum draft angle for part ejection from mold.",
      "long": "Calculate minimum draft angle for part ejection from mold."
    }
  },
  "sectorSlug": "daily-renovation"
}

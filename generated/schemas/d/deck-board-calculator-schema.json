{
  "toolName": "deck-board-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Deck Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 30,
      "min": 0,
      "businessContext": "Area to cover."
    },
    {
      "id": "tahtaEn",
      "label": "Board Width (m)",
      "type": "number",
      "unit": "m",
      "default": 0.14,
      "min": 0,
      "businessContext": "Board width."
    },
    {
      "id": "tahtaBoy",
      "label": "Board Length (m)",
      "type": "number",
      "unit": "m",
      "default": 3,
      "min": 0,
      "businessContext": "Board length."
    },
    {
      "id": "scrap",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Cutting waste."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.ceil((area / Math.max(0.0001, (tahtaEn * tahtaBoy))) * (1 + scrap / 100))"
  },
  "outputs": {
    "primary": "result",
    "unit": "boards",
    "breakdown": {
      "result": "Gerekli Deck Tahtasi"
    },
    "breakdownUnits": {
      "result": "boards"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate number of deck boards needed including waste factor.",
      "long": "Calculate number of deck boards needed including waste factor."
    }
  },
  "sectorSlug": "daily-renovation"
}

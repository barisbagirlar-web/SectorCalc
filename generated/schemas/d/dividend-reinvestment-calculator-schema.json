{
  "toolName": "dividend-reinvestment-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "share",
      "label": "Shares Held",
      "type": "number",
      "unit": "shares",
      "default": 100,
      "min": 0,
      "businessContext": "Number of shares owned."
    },
    {
      "id": "temettu",
      "label": "Dividend Per Share (USD)",
      "type": "number",
      "unit": "USD",
      "default": 2,
      "min": 0,
      "businessContext": "Annual dividend per share."
    },
    {
      "id": "price",
      "label": "Share Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "min": 0,
      "businessContext": "Current share price."
    },
    {
      "id": "year",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "min": 0,
      "businessContext": "DRIP strategy duration."
    },
    {
      "id": "getiri",
      "label": "Expected Annual Return (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Expected annual price appreciation."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "newShare": "share + ((temettu * share) / Math.max(1, price))",
    "result": "(share + ((temettu * share) / Math.max(1, price))) * Math.pow(1 + getiri / 100, year) * price"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "DRIP Portfoy Valuei"
    },
    "breakdownUnits": {
      "result": "USD"
    },

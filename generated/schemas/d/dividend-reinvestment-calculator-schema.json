      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate the compound growth effect of dividend reinvestment (DRIP).",
      "long": "Calculate the compound growth effect of dividend reinvestment (DRIP)."

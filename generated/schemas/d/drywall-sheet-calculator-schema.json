{
  "toolName": "drywall-sheet-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Wall Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 80,
      "min": 0,
      "businessContext": "Wall area."
    },
    {
      "id": "levhaEn",
      "label": "Sheet Width (m)",
      "type": "number",
      "unit": "m",
      "default": 1.2,
      "min": 0,
      "businessContext": "Drywall sheet width."
    },
    {
      "id": "levhaBoy",
      "label": "Sheet Length (m)",
      "type": "number",
      "unit": "m",
      "default": 2.5,
      "min": 0,
      "businessContext": "Drywall sheet length."
    },
    {
      "id": "scrap",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Cutting allowance."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.ceil((area * (1 + scrap / 100)) / Math.max(0.0001, (levhaEn * levhaBoy)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "sheets",
    "breakdown": {
      "result": "Required Drywall Sheets"
    },
    "breakdownUnits": {
      "result": "sheets"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate number of drywall sheets needed for walls.",
      "long": "Calculate number of drywall sheets needed for walls."
    }
  },
  "sectorSlug": "daily-renovation"
}

{
  "toolName": "drying-time-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "agriculture-food-beverage",
  "sector": "Agriculture, Maritime and Drilling",
  "sectorId": "agriculture-food-beverage",
  "inputs": [
    {
      "id": "urunKutlesi",
      "label": "Product Mass (kg)",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "min": 0,
      "businessContext": "Product to dry."
    },
    {
      "id": "baslangicNem",
      "label": "Initial Moisture (%)",
      "type": "number",
      "unit": "%",
      "default": 25,
      "min": 0,
      "businessContext": "Initial moisture content."
    },
    {
      "id": "hedefNem",
      "label": "Target Moisture (%)",
      "type": "number",
      "unit": "%",
      "default": 14,
      "min": 0,
      "businessContext": "Target moisture content."
    },
    {
      "id": "havaDebi",
      "label": "Air Flow Rate (kg/s)",
      "type": "number",
      "unit": "kg/s",
      "default": 5,
      "min": 0,
      "businessContext": "Drying air flow rate."
    },
    {
      "id": "nemFarki",
      "label": "Humidity Difference (kg/kg)",
      "type": "number",
      "unit": "scalar",
      "default": 0.01,
      "min": 0,
      "businessContext": "Air inlet-outlet humidity difference."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "buharlasanSu": "urunKutlesi * ((baslangicNem - hedefNem) / 100)",
    "result": "(urunKutlesi * ((baslangicNem - hedefNem) / 100)) / Math.max(0.0001, (havaDebi * nemFarki))"
  },
  "outputs": {
    "primary": "result",
    "unit": "s",
    "breakdown": {
      "result": "Drying Time"
    },
    "breakdownUnits": {
      "result": "s"
    },
    "hiddenLossDrivers": [
      "Low efficiency may indicate equipment or process issues."
    ],
    "suggestedActions": [
      "Calibrate all measuring equipment regularly.",
      "Use site-specific data when available."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate theoretical drying time to reach target moisture content.",
      "long": "Calculate theoretical drying time to reach target moisture content."
    }
  },
  "sectorSlug": "daily-renovation"

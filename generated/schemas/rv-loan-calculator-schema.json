    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "months",
      "default": 60,
      "businessContext": "Loan duration in months",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    },
    {
      "id": "salesTaxRate",
      "label": "Sales Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Applicable sales tax percentage",
      "label_i18n": {
        "en": "Sales Tax Rate",
        "tr": "Sales Tax Rate",
        "de": "Sales Tax Rate",
        "fr": "Sales Tax Rate",
        "es": "Sales Tax Rate",
        "ar": "Sales Tax Rate"
      }
    }
  ],
  "formulas": {
    "amountFinanced": "rvPrice * (1 + salesTaxRate/100) - downPayment - tradeInValue",
    "monthlyInterestRate": "annualInterestRate / 1200"
  },
  "outputs": {
    "primary": "monthlyInterestRate",
    "breakdown": [
      "amountFinanced",
      "totalInterest",
      "totalCost"

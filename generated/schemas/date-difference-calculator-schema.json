  "formulas": {
    "diffDays": "endYear * 365 + endMonth * 30 + endDay - (startYear * 365 + startMonth * 30 + startDay)",
    "diffYears": "(endYear * 365 + endMonth * 30 + endDay - (startYear * 365 + startMonth * 30 + startDay)) / 365",
    "diffMonths": "(endYear * 365 + endMonth * 30 + endDay - (startYear * 365 + startMonth * 30 + startDay)) / 30"
  },
  "outputs": {
    "primary": "diffDays",
    "breakdown": [

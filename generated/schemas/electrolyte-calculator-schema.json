{
  "toolName": "electrolyte-calculator",
  "inputs": [
    {
      "id": "desiredMolarity",
      "label": "Desired Molarity",
      "type": "number",
      "unit": "mol/L",
      "default": 1,
      "businessContext": "Target concentration of the electrolyte solution in moles per liter",
      "label_i18n": {
        "en": "Desired Molarity",
        "tr": "Desired Molarity",
        "de": "Desired Molarity",
        "fr": "Desired Molarity",
        "es": "Desired Molarity",
        "ar": "Desired Molarity"
      }
    },
    {
      "id": "solutionVolume",
      "label": "Solution Volume",
      "type": "number",
      "unit": "L",
      "default": 1,
      "businessContext": "Final volume of the solution to prepare",
      "label_i18n": {
        "en": "Solution Volume",
        "tr": "Solution Volume",
        "de": "Solution Volume",
        "fr": "Solution Volume",
        "es": "Solution Volume",
        "ar": "Solution Volume"
      }
    },
    {
      "id": "solutePurity",
      "label": "Solute Purity",
      "type": "number",
      "unit": "%",
      "default": 99.5,
      "businessContext": "Purity percentage of the solid solute (e.g., 99.5 means 99.5% pure)",
      "label_i18n": {
        "en": "Solute Purity",
        "tr": "Solute Purity",
        "de": "Solute Purity",
        "fr": "Solute Purity",
        "es": "Solute Purity",
        "ar": "Solute Purity"
      }
    },
    {
      "id": "molecularWeight",
      "label": "Molecular Weight (Anhydrous)",
      "type": "number",
      "unit": "g/mol",
      "default": 58.44,
      "businessContext": "Molar mass of the anhydrous solute",
      "label_i18n": {
        "en": "Molecular Weight (Anhydrous)",
        "tr": "Molecular Weight (Anhydrous)",
        "de": "Molecular Weight (Anhydrous)",
        "fr": "Molecular Weight (Anhydrous)",
        "es": "Molecular Weight (Anhydrous)",
        "ar": "Molecular Weight (Anhydrous)"
      }
    },
    {
      "id": "hydrationNumber",
      "label": "Water of Hydration",
      "type": "number",
      "unit": "mol/mol",
      "default": 0,
      "businessContext": "Number of water molecules per formula unit (e.g., 5 for CuSO4·5H2O; 0 for anhydrous)",
      "label_i18n": {
        "en": "Water of Hydration",
        "tr": "Water of Hydration",
        "de": "Water of Hydration",
        "fr": "Water of Hydration",
        "es": "Water of Hydration",
        "ar": "Water of Hydration"
      }
    }
  ],
  "formulas": {
    "effectiveMolecularWeight": "molecularWeight + hydrationNumber * 18.015",
    "pureMass": "desiredMolarity * solutionVolume * effectiveMolecularWeight",
    "rawMass": "pureMass / (solutePurity / 100)"
  },
  "outputs": {
    "primary": "rawMass",
    "breakdown": [
      "effectiveMolecularWeight",
      "pureMass"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rawMass"
  },

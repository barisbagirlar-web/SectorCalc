  "formulas": {
    "Cost_Air": "Weight * AirRate + Handling",
    "Cost_Sea": "Volume * SeaRate + PortFees + Customs",
    "Cost_Road": "Distance * RoadRate + Tolls",
    "TransitTimeCost": "TransitDays * InventoryCarryingCostPerDay",
    "RiskCost": "ProbabilityOfDamage * CargoValue + ProbabilityOfDelay * DelayPenalty",
    "TotalModeCost": "TransportCost + TransitTimeCost + RiskCost",
    "ModeSelection": "MIN(TotalModeCost_Air, TotalModeCost_Sea, TotalModeCost_Road)"
  },

{
  "toolName": "dividend-reinvestment-calculator",
  "inputs": [
    {
      "id": "initialInvestment",
      "label": "Initial Investment (USD)",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "businessContext": "Total amount initially invested in the stock.",
      "label_i18n": {
        "en": "Initial Investment (USD)",
        "tr": "Başlangıç Yatırımı (USD)",
        "de": "Initial Investment (USD)",
        "fr": "Initial Investment (USD)",
        "es": "Initial Investment (USD)",
        "ar": "Initial Investment (USD)"
      },
      "businessContext_i18n": {
        "en": "Total amount initially invested in the stock.",
        "tr": "Hisse senedine başlangıçta yatırılan toplam tutar."
      }
    },
    {
      "id": "annualDividendYield",
      "label": "Annual Dividend Yield (%)",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Annual dividend yield as a percentage of stock price.",
      "label_i18n": {
        "en": "Annual Dividend Yield (%)",
        "tr": "Yıllık Temettü Verimi (%)",
        "de": "Annual Dividend Yield (%)",
        "fr": "Annual Dividend Yield (%)",
        "es": "Annual Dividend Yield (%)",
        "ar": "Annual Dividend Yield (%)"
      },
      "businessContext_i18n": {
        "en": "Annual dividend yield as a percentage of stock price.",
        "tr": "Hisse senedi fiyatının yüzdesi olarak yıllık temettü verimi."
      }
    },
    {
      "id": "dividendGrowthRate",
      "label": "Dividend Growth Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected annual growth rate of dividends.",
      "label_i18n": {
        "en": "Dividend Growth Rate (%)",
        "tr": "Temettü Büyüme Oranı (%)",
        "de": "Dividend Growth Rate (%)",
        "fr": "Dividend Growth Rate (%)",
        "es": "Dividend Growth Rate (%)",
        "ar": "Dividend Growth Rate (%)"
      },
      "businessContext_i18n": {
        "en": "Expected annual growth rate of dividends.",
        "tr": "Temettülerin beklenen yıllık büyüme oranı."
      }
    },
    {
      "id": "stockPriceGrowthRate",
      "label": "Stock Price Growth Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual growth rate of stock price.",
      "label_i18n": {
        "en": "Stock Price Growth Rate (%)",
        "tr": "Hisse Senedi Fiyatı Büyüme Oranı (%)",
        "de": "Stock Price Growth Rate (%)",
        "fr": "Stock Price Growth Rate (%)",
        "es": "Stock Price Growth Rate (%)",
        "ar": "Stock Price Growth Rate (%)"
      },
      "businessContext_i18n": {
        "en": "Expected annual growth rate of stock price.",
        "tr": "Hisse senedi fiyatının beklenen yıllık büyüme oranı."
      }
    },
    {
      "id": "years",
      "label": "Investment Period (Years)",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Number of years the investment is held.",
      "label_i18n": {
        "en": "Investment Period (Years)",
        "tr": "Yatırım Süresi (Yıl)",
        "de": "Investment Period (Years)",
        "fr": "Investment Period (Years)",
        "es": "Investment Period (Years)",
        "ar": "Investment Period (Years)"
      },
      "businessContext_i18n": {
        "en": "Number of years the investment is held.",
        "tr": "Yatırımın elde tutulduğu yıl sayısı."
      }
    },
    {
      "id": "taxRate",
      "label": "Dividend Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tax rate applied to dividends.",
      "label_i18n": {
        "en": "Dividend Tax Rate (%)",
        "tr": "Temettü Vergi Oranı (%)",
        "de": "Dividend Tax Rate (%)",
        "fr": "Dividend Tax Rate (%)",
        "es": "Dividend Tax Rate (%)",
        "ar": "Dividend Tax Rate (%)"
      },
      "businessContext_i18n": {
        "en": "Tax rate applied to dividends.",
        "tr": "Temettülere uygulanan vergi oranı."
      }
    }
  ],
  "formulas": {
    "totalValue": "initialInvestment * (1 + stockPriceGrowthRate/100)**years + (initialInvestment * annualDividendYield/100 * (1 - taxRate/100) * ((1 + dividendGrowthRate/100)**years - 1) / (dividendGrowthRate/100))",
    "totalDividends": "initialInvestment * annualDividendYield/100 * (1 - taxRate/100) * ((1 + dividendGrowthRate/100)**years - 1) / (dividendGrowthRate/100)",
    "capitalGains": "initialInvestment * ((1 + stockPriceGrowthRate/100)**years - 1)",
    "effectiveYield": "((totalValue / initialInvestment)**(1/years) - 1) * 100"
  },
  "outputs": {
    "primary": "totalValue",
    "breakdown": [
      "totalDividends",
      "capitalGains",
      "effectiveYield"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveYield",
    "unit": "USD"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

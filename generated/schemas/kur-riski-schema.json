  "formulas": {
    "Exposure_FC": "TotalRevenue_FC - TotalCost_FC",
    "VaR_Historical": "Exposure_FC * StdDev_ExchangeRate * Z_Score",
    "VaR_Parametric": "Exposure_FC * Volatility * SQRT(TimeHorizon)",
    "HedgedExposure": "Exposure_FC * HedgeRatio",
    "UnhedgedVaR": "VaR_Historical * (1 - HedgeRatio)",
    "CostOfHedge": "Notional * ForwardPoints",
    "NetImpact": "(SpotRate - ForwardRate) * HedgedExposure"
  },
  "outputs": {
    "primary": "NetImpact",

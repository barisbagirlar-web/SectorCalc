{
  "toolName": "percent-difference-calculator",
  "inputs": [
    {
      "id": "value1",
      "label": "First Value",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "First measurement value for comparison",
      "label_i18n": {
        "en": "First Value",
        "tr": "First Value",
        "de": "First Value",
        "fr": "First Value",

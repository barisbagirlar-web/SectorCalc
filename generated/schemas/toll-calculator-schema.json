        "fr": "Ağırlık Faktörü",
        "es": "Ağırlık Faktörü",
        "ar": "Ağırlık Faktörü"
      }
    },
    {
      "id": "vat_rate",
      "label": "KDV Oranı (%)",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Uygulanan katma değer vergisi oranı",
      "label_i18n": {
        "en": "KDV Oranı (%)",
        "tr": "KDV Oranı (%)",
        "de": "KDV Oranı (%)",
        "fr": "KDV Oranı (%)",
        "es": "KDV Oranı (%)",
        "ar": "KDV Oranı (%)"
      }
    }
  ],
  "formulas": {
    "total_toll_excl_vat": "distance_km * base_toll_rate * (axle_multiplier + weight_factor) + fixed_toll_fee",
    "vat_amount": "total_toll_excl_vat * vat_rate / 100",
    "total_toll_incl_vat": "total_toll_excl_vat + vat_amount"
  },
  "outputs": {
    "primary": "total_toll_incl_vat",
    "breakdown": [
      "total_toll_excl_vat",
      "vat_amount"

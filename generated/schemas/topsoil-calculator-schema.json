{
  "toolName": "topsoil-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Length of the area to cover with topsoil",
      "label_i18n": {
        "en": "Length",
        "tr": "Length",
        "de": "Length",
        "fr": "Length",
        "es": "Length",
        "ar": "Length"
      }
    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Width of the area",
      "label_i18n": {
        "en": "Width",
        "tr": "Width",
        "de": "Width",
        "fr": "Width",
        "es": "Width",
        "ar": "Width"
      }
    },
    {
      "id": "depth",
      "label": "Depth",
      "type": "number",
      "unit": "cm",
      "default": 15,
      "businessContext": "Desired topsoil depth",
      "label_i18n": {
        "en": "Depth",
        "tr": "Depth",
        "de": "Depth",
        "fr": "Depth",
        "es": "Depth",
        "ar": "Depth"
      }
    },
    {
      "id": "bulkDensity",
      "label": "Bulk Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1500,
      "businessContext": "Bulk density of topsoil for weight estimation",
      "label_i18n": {
        "en": "Bulk Density",
        "tr": "Bulk Density",
        "de": "Bulk Density",
        "fr": "Bulk Density",
        "es": "Bulk Density",
        "ar": "Bulk Density"
      }
    },
    {
      "id": "costPerUnit",
      "label": "Cost per Unit Volume",
      "type": "number",
      "unit": "USD/m³",
      "default": 25,
      "businessContext": "Purchase price of topsoil per cubic meter",
      "label_i18n": {
        "en": "Cost per Unit Volume",
        "tr": "Cost per Unit Volume",
        "de": "Cost per Unit Volume",
        "fr": "Cost per Unit Volume",
        "es": "Cost per Unit Volume",
        "ar": "Cost per Unit Volume"
      }
    }
  ],
  "formulas": {
    "volume": "length * width * (depth / 100)",
    "weight": "volume * bulkDensity / 1000",
    "cost": "volume * costPerUnit"
  },
  "outputs": {
    "primary": "volume",
    "breakdown": [
      {
        "label": "Weight",
        "value": "weight"
      },
      {
        "label": "Estimated Cost",
        "value": "cost"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

        "de": "Average March Temperature",
        "fr": "Average March Temperature",
        "es": "Average March Temperature",
        "ar": "Average March Temperature"
      }
    },
    {
      "id": "proximityToWater",
      "label": "Proximity to Water",
      "type": "number",
      "unit": "index (0-1)",

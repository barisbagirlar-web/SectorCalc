        "en": "Proximity to Water",
        "tr": "Proximity to Water",
        "de": "Proximity to Water",
        "fr": "Proximity to Water",
        "es": "Proximity to Water",
        "ar": "Proximity to Water"
      }
    },
    {
      "id": "yearOffset",
      "label": "Year Offset from 2000",
      "type": "number",
      "unit": "years",
      "default": 25,
      "businessContext": "Number of years since 2000 to account for climate trends",
      "label_i18n": {
        "en": "Year Offset from 2000",
        "tr": "Year Offset from 2000",
        "de": "Year Offset from 2000",
        "fr": "Year Offset from 2000",
        "es": "Year Offset from 2000",
        "ar": "Year Offset from 2000"
      }
    }
  ],
  "formulas": {
    "latEffect": "latitude * 1.5",
    "elevEffect": "elevation * 0.005",
    "tempEffect": "(10 - avgMarchTemp) * 3",
    "waterEffect": "proximityToWater * -15",
    "yearEffect": "yearOffset * -0.5"
  },
  "outputs": {
    "primary": "yearEffect",
    "breakdown": [
      "latEffect",

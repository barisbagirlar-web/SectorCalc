  "formulas": {
    "aspectDecimal": "width / height",
    "targetDecimal": "targetRatioW / targetRatioH",
    "deviationPercent": "Math.sqrt((aspectDecimal - targetDecimal)**2) / targetDecimal * 100",
    "width": "width",
    "height": "height"
  },
  "outputs": {
    "primary": "aspectDecimal",
    "breakdown": [

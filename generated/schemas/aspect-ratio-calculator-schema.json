    {
      "id": "targetRatioH",
      "label": "Target Ratio Height",
      "type": "number",
      "unit": "unit",
      "default": 9,
      "businessContext": "The height component of a target aspect ratio (e.g., 9 for 16:9). Used to compare how close the current aspect ratio is to a standard.",

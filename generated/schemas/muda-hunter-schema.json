{
  "toolName": "7-waste-muda-hunter",
  "inputs": [
    {
      "id": "analysisPeriodDays",
      "label": "Analysis period length",
      "type": "number",
      "unit": "days",
      "default": 30,
      "min": 1,
      "max": 365,
      "businessContext": "Kullanıcının analiz yapmak istediği dönem. Atık hesaplamaları bu dönem için yapılır."
    },
    {
      "id": "productionUnits",
      "label": "Total production units",
      "type": "number",
      "unit": "units",
      "default": 10000,
      "min": 0,
      "max": null,
      "businessContext": "Analiz döneminde üretilen toplam birim sayısı."
    },
    {
      "id": "unitVariableCost",
      "label": "Unit variable cost",
      "type": "number",
      "unit": "currency",
      "default": 50,
      "min": 0,
      "max": null,
      "businessContext": "Birim başına değişken maliyet (malzeme, işçilik, enerji vb.)."
    },
    {
      "id": "unitSellingPrice",
      "label": "Unit selling price",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "min": 0,
      "max": null,
      "businessContext": "Birim satış fiyatı."
    },
    {
      "id": "revenue",
      "label": "Total revenue",
      "type": "number",
      "unit": "currency",
      "default": 1000000,
      "min": 0,
      "max": null,
      "businessContext": "Analiz dönemindeki toplam gelir."
    },
    {
      "id": "excessProductionUnits",
      "label": "Excess production units",
      "type": "number",
      "unit": "units",
      "default": 500,
      "min": 0,
      "max": null,
      "businessContext": "Talep fazlası üretilen birim sayısı (overproduction)."
    },
    {
      "id": "waitingHours",
      "label": "Total waiting hours",
      "type": "number",
      "unit": "hours",
      "default": 200,
      "min": 0,
      "max": null,
      "businessContext": "Bekleme nedeniyle kaybedilen toplam saat."
    },
    {
      "id": "waitingOpportunityCostMode",
      "label": "Waiting opportunity cost mode",
      "type": "select",
      "options": ["manual", "automatic"],
      "default": "automatic",
      "businessContext": "Bekleme fırsat maliyeti hesaplama yöntemi: manuel (kullanıcı tanımlı saatlik maliyet) veya otomatik (birim katkı payına göre)."
    },
    {
      "id": "hourlyOpportunityCost",
      "label": "Hourly opportunity cost",
      "type": "number",
      "unit": "currency/hour",
      "default": 100,
      "min": 0,
      "max": null,
      "businessContext": "Manuel modda kullanılan saatlik fırsat maliyeti."
    },
    {
      "id": "transportDistanceKm",
      "label": "Total transport distance",
      "type": "number",
      "unit": "km",
      "default": 5000,
      "min": 0,
      "max": null,
      "businessContext": "Malzeme taşıma için kat edilen toplam mesafe."
    },
    {
      "id": "transportCostPerKm",
      "label": "Transport cost per km",
      "type": "number",
      "unit": "currency/km",
      "default": 2,
      "min": 0,
      "max": null,
      "businessContext": "Kilometre başına taşıma maliyeti (yakıt, bakım, işçilik)."
    },
    {
      "id": "excessInventoryValue",
      "label": "Excess inventory value",
      "type": "number",
      "unit": "currency",
      "default": 50000,
      "min": 0,
      "max": null,
      "businessContext": "Fazla stokun parasal değeri."
    },
    {
      "id": "inventoryCarryingRate",
      "label": "Inventory carrying rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "min": 0,
      "max": 100,
      "businessContext": "Stok taşıma maliyeti oranı (yıllık % olarak)."
    },
    {
      "id": "motionWasteHours",
      "label": "Motion waste hours",
      "type": "number",
      "unit": "hours",
      "default": 100,
      "min": 0,
      "max": null,
      "businessContext": "Gereksiz hareketler (arama, yürüme vb.) nedeniyle kaybedilen toplam saat."
    },
    {
      "id": "averageLaborRate",
      "label": "Average labor rate",
      "type": "number",
      "unit": "currency/hour",
      "default": 30,
      "min": 0,
      "max": null,
      "businessContext": "Ortalama işçilik saat ücreti."
    },
    {
      "id": "defectUnits",
      "label": "Defect units",
      "type": "number",
      "unit": "units",
      "default": 200,
      "min": 0,
      "max": null,
      "businessContext": "Hatalı üretilen birim sayısı."
    },
    {
      "id": "reworkCostPerUnit",
      "label": "Rework cost per unit",
      "type": "number",
      "unit": "currency",
      "default": 20,
      "min": 0,
      "max": null,
      "businessContext": "Hatalı birimi düzeltme maliyeti."
    },
    {
      "id": "scrapValuePerUnit",
      "label": "Scrap value per unit",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "min": 0,
      "max": null,
      "businessContext": "Hurda birimin geri kazanım değeri."
    },
    {
      "id": "overprocessingHours",
      "label": "Overprocessing hours",
      "type": "number",
      "unit": "hours",
      "default": 150,
      "min": 0,
      "max": null,
      "businessContext": "Gereksiz işlemler (fazla kalite, ekstra adımlar) için harcanan saat."
    },
    {
      "id": "overprocessingCostPerHour",
      "label": "Overprocessing cost per hour",
      "type": "number",
      "unit": "currency/hour",
      "default": 40,
      "min": 0,
      "max": null,
      "businessContext": "Gereksiz işlemlerin saatlik maliyeti."
    },
    {
      "id": "dataConfidence",
      "label": "Data confidence",
      "type": "number",
      "unit": "%",
      "default": 80,
      "min": 0,
      "max": 100,
      "businessContext": "Girilen verilerin güvenilirlik yüzdesi."
    },
    {
      "id": "implementationDifficulty",
      "label": "Implementation difficulty",
      "type": "number",
      "unit": "scale 1-5",
      "default": 3,
      "min": 1,
      "max": 5,
      "businessContext": "İyileştirme önlemlerinin uygulama zorluğu (1: kolay, 5: çok zor)."
    }
  ],
  "validation": {
    "rules": [
      "Eğer Waiting opportunity cost mode 'manual' ise Hourly opportunity cost > 0 olmalı",
      "Data confidence 0-100 arasında",
      "Implementation difficulty 1-5 arasında tamsayı"
    ],
    "thresholds": {
      "defectRate": "defectUnits / productionUnits > 0.05 → 'KRITIK' uyarısı",
      "inventoryCarryingCost": "excessInventoryValue * (inventoryCarryingRate/100) > revenue*0.1 → yüksek stok maliyeti"
    }
  },
  "formulas": {
    "totalWasteCost": "excessProductionWaste + waitingWaste + transportWaste + inventoryWaste + motionWaste + defectWaste + overprocessingWaste",
    "excessProductionWaste": "excessProductionUnits * unitVariableCost",
    "waitingWaste": "waitingOpportunityCostMode === 'manual' ? waitingHours * hourlyOpportunityCost : waitingHours * (unitSellingPrice - unitVariableCost)",
    "transportWaste": "transportDistanceKm * transportCostPerKm",
    "inventoryWaste": "excessInventoryValue * (inventoryCarryingRate/100) * (analysisPeriodDays/365)",
    "motionWaste": "motionWasteHours * averageLaborRate",
    "defectWaste": "defectUnits * (reworkCostPerUnit + unitVariableCost - scrapValuePerUnit)",
    "overprocessingWaste": "overprocessingHours * overprocessingCostPerHour"
  },
  "outputs": {
    "primary": "totalWasteCost (currency, format: currency)",
    "breakdown": {
      "overproduction": "number",
      "waiting": "number",
      "transport": "number",
      "inventory": "number",
      "motion": "number",
      "defects": "number",
      "overprocessing": "number"
    },
    "hiddenLossDrivers": ["string"],
    "suggestedActions": ["string"],
    "dataConfidenceAdjusted": "totalWasteCost * (dataConfidence/100)"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Historical trend analysis (paid plans)",
    "Benchmarking against industry averages"
  ],
  "premiumRequired": true
}
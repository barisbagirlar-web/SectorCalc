      "label": "S (Coefficient of variation)",
      "type": "number",
      "unit": "unit",
      "default": 0.04,
      "businessContext": "Coefficient of variation from WHO growth standards",
      "label_i18n": {
        "en": "S (Coefficient of variation)",
        "tr": "S (Coefficient of variation)",
        "de": "S (Coefficient of variation)",
        "fr": "S (Coefficient of variation)",
        "es": "S (Coefficient of variation)",
        "ar": "S (Coefficient of variation)"
      }
    }
  ],
  "formulas": {
    "zScore": "(Math.pow(heightCm / M, L) - 1) / (L * S)",
    "erf": "(zScore > 0 ? 1 : -1) * Math.sqrt(1 - Math.exp(-zScore * zScore * (4 / Math.PI + 0.147 * zScore * zScore) / (1 + 0.147 * zScore * zScore)))",
    "percentile": "0.5 * (1 + erf / Math.sqrt(2)) * 100"
  },
  "outputs": {
    "primary": "percentile",
    "breakdown": [
      "zScore"
    ]
  },

    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "digits",
      "default": 0,
      "businessContext": "Number of decimal places for the result (applies to division). 0 for integer.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    }
  ],
  "formulas": {
    "decimalResult": "operation === 1 ? operandA + operandB : operation === 2 ? operandA - operandB : operation === 3 ? operandA * operandB : operation === 4 ? (operandB !== 0 ? operandA / operandB : 'Error: Division by zero') : 'Error: Invalid operation'",
    "roundedResult": "typeof decimalResult === 'number' ? parseFloat(decimalResult.toFixed(precision)) : decimalResult",
    "hexResult": "typeof roundedResult === 'number' ? roundedResult.toString(16).toUpperCase() : roundedResult",
    "operationName": "operation === 1 ? 'Addition' : operation === 2 ? 'Subtraction' : operation === 3 ? 'Multiplication' : operation === 4 ? 'Division' : 'Unknown'"
  },
  "outputs": {
    "primary": "hexResult",
    "breakdown": [
      "roundedResult",
      "operationName"
    ]
  },

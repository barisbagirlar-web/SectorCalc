    },
    {
      "id": "operation",
      "label": "Operation Code",
      "type": "number",
      "unit": "code",
      "default": 1,
      "businessContext": "1: Addition (+), 2: Subtraction (-), 3: Multiplication (*), 4: Division (/).",
      "label_i18n": {
        "en": "Operation Code",
        "tr": "Operation Code",
        "de": "Operation Code",

      },
      "businessContext_i18n": {
        "en": "Number of pumpkins to carve",
        "tr": "Oymak için balkabağı sayısı",
        "de": "Anzahl der zu schnitzenden Kürbisse",
        "fr": "Nombre de citrouilles à sculpter",
        "es": "Número de calabazas para tallar",
        "ar": "عدد القرع المراد نحته"
      }
    },
    {
      "id": "pumpkin_cost",
      "label": "Cost per Pumpkin",
      "type": "number",
      "unit": "USD",
      "default": 10,
      "businessContext": "Unit cost of each pumpkin",
      "label_i18n": {
        "en": "Cost per Pumpkin",
        "tr": "Balkabağı Başına Maliyet",
        "de": "Kosten pro Kürbis",
        "fr": "Coût par citrouille",
        "es": "Costo por calabaza",
        "ar": "تكلفة القرعة الواحدة"
      },
      "businessContext_i18n": {
        "en": "Unit cost of each pumpkin",
        "tr": "Her bir balkabağının birim maliyeti",
        "de": "Stückkosten jedes Kürbisses",
        "fr": "Coût unitaire de chaque citrouille",
        "es": "Costo unitario de cada calabaza",
        "ar": "تكلفة الوحدة لكل قرعة"
      }
    }
  ],
  "formulas": {
    "total_candy_needed": "num_children * candy_per_child",
    "candy_cost": "total_candy_needed * cost_per_candy",
    "pumpkin_total_cost": "pumpkin_count * pumpkin_cost",
    "total_cost": "candy_cost + decor_budget + pumpkin_total_cost",
    "cost_per_child": "total_cost / num_children"
  },
  "outputs": {
    "primary": "total_cost",
    "breakdown": [
      "total_candy_needed",
      "candy_cost",
      "pumpkin_total_cost",
      "cost_per_child"
    ],

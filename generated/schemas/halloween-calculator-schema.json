    {
      "id": "pumpkin_count",
      "label": "Number of Pumpkins",
      "type": "number",
      "unit": "pieces",
      "default": 3,
      "businessContext": "Number of pumpkins to carve",
      "label_i18n": {
        "en": "Number of Pumpkins",
        "tr": "Balkabağı Sayısı",

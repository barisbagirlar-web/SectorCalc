      }
    },
    {
      "id": "decor_budget",
      "label": "Decoration Budget",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Budget allocated for Halloween decorations",
      "label_i18n": {
        "en": "Decoration Budget",
        "tr": "Dekorasyon Bütçesi",

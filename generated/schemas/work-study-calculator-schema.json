        "en": "Precision",
        "tr": "Precision",
        "de": "Precision",
        "fr": "Precision",
        "es": "Precision",
        "ar": "Precision"
      }
    },
    {
      "id": "zScore",
      "label": "Z-score for Confidence Level",
      "type": "number",
      "unit": "unit",

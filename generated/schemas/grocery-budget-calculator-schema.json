{
  "toolName": "grocery-budget-calculator",
  "inputs": [
    {
      "id": "monthlyIncome",
      "label": "Monthly Income",
      "type": "number",
      "unit": "TL",
      "default": 5000,
      "businessContext": "Total monthly household income after taxes"
    },
    {
      "id": "groceryPercentage",
      "label": "Grocery Budget Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Recommended percentage of income allocated to groceries"
    },
    {
      "id": "numberOfPeople",
      "label": "Number of Household Members",
      "type": "number",
      "unit": "people",
      "default": 1,
      "businessContext": "Number of individuals consuming groceries"
    },
    {
      "id": "extraExpenses",
      "label": "Additional Grocery Expenses",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "businessContext": "Extra fixed grocery spending (e.g., eating out, special diets)"
    }
  ],
  "formulas": {
    "baseGroceryFromIncome": "monthlyIncome * groceryPercentage / 100",
    "totalGroceyBudget": "baseGroceryFromIncome + extraExpenses",
    "perPersonBudget": "totalGroceyBudget / numberOfPeople"
  },
  "outputs": {
    "primary": "totalGroceyBudget",
    "breakdown": [
      "baseGroceryFromIncome",
      "extraExpenses",
      "perPersonBudget"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "cost"
}

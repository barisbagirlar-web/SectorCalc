{
  "toolName": "grocery-budget-calculator",
  "inputs": [
    {
      "id": "adults",
      "label": "Number of Adults",
      "type": "number",
      "unit": "persons",
      "default": 2,
      "businessContext": "Count of adult household members"
    },
    {
      "id": "children",
      "label": "Number of Children",
      "type": "number",
      "unit": "persons",
      "default": 1,
      "businessContext": "Count of child household members"
    },
    {
      "id": "tripsPerMonth",
      "label": "Grocery Trips per Month",
      "type": "number",
      "unit": "trips/month",
      "default": 4,
      "businessContext": "Average number of grocery shopping trips each month"
    },
    {
      "id": "avgSpendPerTrip",
      "label": "Average Spend per Trip",
      "type": "number",
      "unit": "currency",
      "default": 150,
      "businessContext": "Average amount spent on each grocery trip"
    },
    {
      "id": "coefficientChild",
      "label": "Child Consumption Factor",
      "type": "number",
      "unit": "ratio",
      "default": 0.7,
      "businessContext": "Factor to adjust child consumption relative to an adult"
    },
    {
      "id": "bufferPercent",
      "label": "Buffer for Unexpected Items",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Extra percentage to cover occasional or unexpected purchases"
    }
  ],
  "formulas": {
    "totalMonthlyBudget": "tripsPerMonth * avgSpendPerTrip * (1 + bufferPercent / 100)",
    "weeklyBudget": "tripsPerMonth * avgSpendPerTrip * (1 + bufferPercent / 100) / 4.33",
    "perPersonBudget": "(tripsPerMonth * avgSpendPerTrip * (1 + bufferPercent / 100)) / (adults + children * coefficientChild)"
  },
  "outputs": {
    "primary": "totalMonthlyBudget",
    "breakdown": [
      "weeklyBudget",
      "perPersonBudget"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

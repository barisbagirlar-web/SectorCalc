{
  "toolName": "grocery-budget-calculator",
  "inputs": [
    {
      "id": "monthlyIncome",
      "label": "Monthly Income",
      "type": "number",
      "unit": "TL",
      "default": 5000,
      "businessContext": "Total monthly household income after taxes",
      "label_i18n": {
        "en": "Monthly Income",
        "tr": "Aylık Gelir",
        "de": "Monatliches Einkommen",
        "fr": "Monthly Income",
        "es": "Monthly Income",
        "ar": "Monthly Income"
      },
      "businessContext_i18n": {
        "en": "Total monthly household income after taxes",
        "tr": "Vergi sonrası toplam aylık hane geliri",
        "de": "Gesamtes monatliches Haushaltseinkommen nach Steuern"
      }
    },
    {
      "id": "groceryPercentage",
      "label": "Grocery Budget Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Recommended percentage of income allocated to groceries",
      "label_i18n": {
        "en": "Grocery Budget Percentage",
        "tr": "Market Bütçesi Yüzdesi",
        "de": "Prozentsatz des Lebensmittelbudgets",
        "fr": "Grocery Budget Percentage",
        "es": "Grocery Budget Percentage",
        "ar": "Grocery Budget Percentage"
      },
      "businessContext_i18n": {
        "en": "Recommended percentage of income allocated to groceries",
        "tr": "Gelirin market alışverişine ayrılması önerilen yüzdesi",
        "de": "Empfohlener Prozentsatz des Einkommens für Lebensmittel"
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of Household Members",
      "type": "number",
      "unit": "people",
      "default": 1,
      "businessContext": "Number of individuals consuming groceries",
      "label_i18n": {
        "en": "Number of Household Members",
        "tr": "Hane Halkı Sayısı",
        "de": "Anzahl der Haushaltsmitglieder",
        "fr": "Number of Household Members",
        "es": "Number of Household Members",
        "ar": "Number of Household Members"
      },
      "businessContext_i18n": {
        "en": "Number of individuals consuming groceries",
        "tr": "Market alışverişi yapan birey sayısı",
        "de": "Anzahl der Personen, die Lebensmittel verbrauchen"
      }
    },
    {
      "id": "extraExpenses",
      "label": "Additional Grocery Expenses",
      "type": "number",
      "unit": "TL",
      "default": 0,
      "businessContext": "Extra fixed grocery spending (e.g., eating out, special diets)",
      "label_i18n": {
        "en": "Additional Grocery Expenses",
        "tr": "Ek Market Giderleri",
        "de": "Zusätzliche Lebensmittelausgaben",
        "fr": "Additional Grocery Expenses",
        "es": "Additional Grocery Expenses",
        "ar": "Additional Grocery Expenses"
      },
      "businessContext_i18n": {
        "en": "Extra fixed grocery spending (e.g., eating out, special diets)",
        "tr": "Sabit ek market harcamaları (örn. dışarıda yemek, özel diyetler)",
        "de": "Zusätzliche feste Lebensmittelausgaben (z. B. Essen gehen, spezielle Diäten)"
      }
    }
  ],
  "formulas": {
    "baseGroceryFromIncome": "monthlyIncome * groceryPercentage / 100",
    "totalGroceyBudget": "baseGroceryFromIncome + extraExpenses",
    "perPersonBudget": "totalGroceyBudget / numberOfPeople"
  },
  "outputs": {
    "primary": "totalGroceyBudget",
    "breakdown": [
      "baseGroceryFromIncome",
      "extraExpenses",
      "perPersonBudget"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "perPersonBudget",
    "unit": "TL"
  },

        "es": "Altura neta de agua aplicada por riego"
      }
    },
    {
      "id": "systemEfficiency",
      "label": "Sistem Verimi",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Sulama sisteminin su iletim ve dağıtım verimi (0-100)",
      "label_i18n": {
        "en": "Sistem Verimi",
        "tr": "Sistem Verimi",
        "de": "Systemwirkungsgrad",
        "fr": "Efficacité du système",
        "es": "Eficiencia del sistema",
        "ar": "Sistem Verimi"
      },
      "businessContext_i18n": {
        "en": "Sulama sisteminin su iletim ve dağıtım verimi (0-100)",
        "tr": "Sulama sisteminin su iletim ve dağıtım verimi (0-100)",
        "de": "Wasserförder- und Verteilungswirkungsgrad des Bewässerungssystems (0-100)",
        "fr": "Efficacité de transport et de distribution du système d'irrigation (0-100)",
        "es": "Eficiencia de conducción y distribución del sistema de riego (0-100)"
      }
    }
  ],
  "formulas": {
    "emittersPerSquareMeter": "1 / (emitterSpacing * lateralSpacing)",
    "totalEmitters": "area * emittersPerSquareMeter",
    "totalFlowRate": "totalEmitters * emitterFlowRate",
    "netVolume": "irrigationDepth * area",
    "grossVolume": "netVolume / (systemEfficiency / 100)",
    "irrigationTime": "grossVolume / totalFlowRate"
  },
  "outputs": {
    "primary": "irrigationTime",
    "breakdown": [
      "totalEmitters",
      "totalFlowRate",
      "netVolume",
      "grossVolume"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "irrigationTime",
    "unit": "m²"
  },

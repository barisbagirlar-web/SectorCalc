      "label": "Sulama Suyu Derinliği",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Her sulamada uygulanacak net su yüksekliği",
      "label_i18n": {
        "en": "Sulama Suyu Derinliği",
        "tr": "Sulama Suyu Derinliği",
        "de": "Bewässerungswassertiefe",

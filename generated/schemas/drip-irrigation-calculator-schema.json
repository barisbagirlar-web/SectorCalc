  "formulas": {
    "emittersPerSquareMeter": "1 / (emitterSpacing * lateralSpacing)",
    "totalEmitters": "area * emittersPerSquareMeter",
    "totalFlowRate": "totalEmitters * emitterFlowRate",
    "netVolume": "irrigationDepth * area",
    "grossVolume": "netVolume / (systemEfficiency / 100)",
    "irrigationTime": "grossVolume / totalFlowRate"
  },
  "outputs": {
    "primary": "irrigationTime",
    "breakdown": [

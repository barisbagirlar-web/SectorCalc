  "formulas": {
    "unroundedProduct": "inputA * inputB * multiplierAdjustment",
    "roundedProduct": "Math.round((inputA * inputB * multiplierAdjustment) * Math.pow(10, roundingPrecision)) / Math.pow(10, roundingPrecision)"
  },

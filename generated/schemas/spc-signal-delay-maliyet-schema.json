  "formulas": {
    "ARL_InControl": "1 / Alpha",
    "ARL_OutOfControl": "1 / (1 - Beta)",
    "DetectionDelay_Hours": "ARL_OutOfControl * SamplingInterval",
    "DefectsProduced": "DetectionDelay_Hours * ProductionRate * DefectRate_OOC",
    "Cost_Delay": "DefectsProduced * CostPerDefect",
    "InvestigationCost": "FalseAlarmRate * SamplingFrequency * LaborRate",
    "OptimalInterval": "SQRT((2 * SamplingCost * ProductionRate) / (Cost_Delay * ShiftMagnitude^2))"
  },

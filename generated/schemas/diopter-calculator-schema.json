        "es": "Lens 2 Power",
        "ar": "Lens 2 Power"
      }
    },
    {
      "id": "originalDiopter",
      "label": "Original Prescription",
      "type": "number",
      "unit": "D",
      "default": -3,
      "businessContext": "Lens power before vertex distance change (negative for myopia).",
      "label_i18n": {
        "en": "Original Prescription",
        "tr": "Original Prescription",
        "de": "Original Prescription",
        "fr": "Original Prescription",
        "es": "Original Prescription",
        "ar": "Original Prescription"
      }
    },
    {
      "id": "vertexDistanceMm",
      "label": "Vertex Distance Change",
      "type": "number",
      "unit": "mm",
      "default": 12,
      "businessContext": "Distance the lens is moved from the eye (in mm, positive if moved away).",
      "label_i18n": {
        "en": "Vertex Distance Change",
        "tr": "Vertex Distance Change",
        "de": "Vertex Distance Change",
        "fr": "Vertex Distance Change",
        "es": "Vertex Distance Change",
        "ar": "Vertex Distance Change"
      }
    }
  ],
  "formulas": {
    "diopter": "100 / focalLengthCm",
    "focalLengthM": "focalLengthCm / 100",
    "combinedDiopter": "diopter1 + diopter2",
    "combinedFocalLengthCm": "100 / combinedDiopter",
    "effectiveDiopter": "originalDiopter / (1 - (vertexDistanceMm / 1000) * originalDiopter)"
  },
  "outputs": {
    "primary": "diopter",
    "breakdown": [
      "focalLengthM",
      "combinedDiopter",
      "combinedFocalLengthCm",
      "effectiveDiopter"

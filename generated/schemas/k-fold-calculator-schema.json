{
  "toolName": "k-fold-calculator",
  "inputs": [
    {
      "id": "k",
      "label": "Number of Folds (k)",
      "type": "number",
      "unit": "folds",
      "default": 5,
      "businessContext": "Number of folds used in cross-validation",
      "label_i18n": {
        "en": "Number of Folds (k)",
        "tr": "Number of Folds (k)",
        "de": "Number of Folds (k)",
        "fr": "Number of Folds (k)",
        "es": "Number of Folds (k)",
        "ar": "Number of Folds (k)"
      }
    },
    {
      "id": "n",
      "label": "Sample Size (n)",
      "type": "number",
      "unit": "samples",
      "default": 1000,
      "businessContext": "Total number of observations in the dataset",
      "label_i18n": {
        "en": "Sample Size (n)",
        "tr": "Sample Size (n)",
        "de": "Sample Size (n)",
        "fr": "Sample Size (n)",
        "es": "Sample Size (n)",
        "ar": "Sample Size (n)"
      }
    },
    {
      "id": "meanAccuracy",
      "label": "Mean Accuracy",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Average accuracy across all folds",
      "label_i18n": {
        "en": "Mean Accuracy",
        "tr": "Mean Accuracy",
        "de": "Mean Accuracy",
        "fr": "Mean Accuracy",
        "es": "Mean Accuracy",
        "ar": "Mean Accuracy"
      }
    },
    {
      "id": "stdDevAccuracy",
      "label": "Standard Deviation of Accuracy",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Standard deviation of accuracy scores from each fold",
      "label_i18n": {
        "en": "Standard Deviation of Accuracy",
        "tr": "Standard Deviation of Accuracy",
        "de": "Standard Deviation of Accuracy",
        "fr": "Standard Deviation of Accuracy",
        "es": "Standard Deviation of Accuracy",
        "ar": "Standard Deviation of Accuracy"
      }
    },
    {
      "id": "zScore",
      "label": "Z-Score",
      "type": "number",
      "unit": "unit",
      "default": 1.96,
      "businessContext": "Z-score for desired confidence level (e.g., 1.96 for 95%)",
      "label_i18n": {
        "en": "Z-Score",
        "tr": "Z-Score",
        "de": "Z-Score",
        "fr": "Z-Score",
        "es": "Z-Score",
        "ar": "Z-Score"
      }
    }
  ],
  "formulas": {
    "standardError": "stdDevAccuracy / Math.sqrt(k)",
    "marginOfError": "zScore * (stdDevAccuracy / Math.sqrt(k))",
    "lowerBoundCI": "meanAccuracy - (zScore * (stdDevAccuracy / Math.sqrt(k)))",
    "upperBoundCI": "meanAccuracy + (zScore * (stdDevAccuracy / Math.sqrt(k)))"
  },
  "outputs": {
    "primary": "standardError",
    "breakdown": [
      "marginOfError",
      "lowerBoundCI",
      "upperBoundCI"
    ]
  },
  "category": "Dönüşüm & Ölçüm",

{
  "toolName": "cat-age-calculator",
  "inputs": [
    {
      "id": "cat_years",
      "label": "Cat Age (Years)",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "The whole number of years the cat has lived. Minimum 0.",
      "label_i18n": {
        "en": "Cat Age (Years)",
        "tr": "Cat Age (Years)",
        "de": "Cat Age (Years)",
        "fr": "Cat Age (Years)",
        "es": "Cat Age (Years)",
        "ar": "Cat Age (Years)"
      }
    },
    {
      "id": "cat_months",
      "label": "Cat Age (Additional Months)",
      "type": "number",
      "unit": "months",
      "default": 0,
      "businessContext": "Additional months beyond whole years, from 0 to 11. For cats under 1 year, use years=0 and enter months here.",
      "label_i18n": {
        "en": "Cat Age (Additional Months)",
        "tr": "Cat Age (Additional Months)",
        "de": "Cat Age (Additional Months)",
        "fr": "Cat Age (Additional Months)",
        "es": "Cat Age (Additional Months)",
        "ar": "Cat Age (Additional Months)"
      }
    },
    {
      "id": "lifestyle_factor",
      "label": "Lifestyle Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Adjustment for indoor/outdoor lifestyle: Indoor only = 1.0, Outdoor access = 0.9, Feral = 0.8. Lower factor means slower aging in human years.",
      "label_i18n": {
        "en": "Lifestyle Factor",
        "tr": "Lifestyle Factor",
        "de": "Lifestyle Factor",
        "fr": "Lifestyle Factor",
        "es": "Lifestyle Factor",
        "ar": "Lifestyle Factor"
      }
    },
    {
      "id": "diet_factor",
      "label": "Diet Quality Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Adjustment for diet quality: Premium diet = 0.95, Normal diet = 1.0, Poor diet = 1.1. Higher factor means faster aging.",
      "label_i18n": {
        "en": "Diet Quality Factor",
        "tr": "Diet Quality Factor",
        "de": "Diet Quality Factor",
        "fr": "Diet Quality Factor",
        "es": "Diet Quality Factor",
        "ar": "Diet Quality Factor"
      }
    },
    {
      "id": "neuter_factor",
      "label": "Neutered/Spayed Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Adjustment if neutered/spayed: Yes = 1.0, No = 1.05. Intact cats may age slightly faster due to stress.",
      "label_i18n": {
        "en": "Neutered/Spayed Factor",
        "tr": "Neutered/Spayed Factor",
        "de": "Neutered/Spayed Factor",
        "fr": "Neutered/Spayed Factor",
        "es": "Neutered/Spayed Factor",
        "ar": "Neutered/Spayed Factor"
      }
    }
  ],
  "formulas": {
    "total_months": "cat_years * 12 + cat_months",
    "base_human_age": "total_months <= 12 ? 15 * (total_months / 12) : total_months <= 24 ? 15 + 9 * (total_months / 12 - 1) : 24 + 4 * (total_months / 12 - 2)",
    "adjusted_human_age": "base_human_age * lifestyle_factor * diet_factor * neuter_factor"
  },
  "outputs": {
    "primary": "adjusted_human_age",
    "breakdown": [
      "Total months: total_months",
      "Base human age (before adjustments): base_human_age",
      "Applied lifestyle factor: lifestyle_factor",
      "Applied diet factor: diet_factor",
      "Applied neuter factor: neuter_factor",
      "Final adjusted human age: adjusted_human_age"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "adjusted_human_age",
    "unit": "years"
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "quality",
  "validation": {
    "rules": [],
    "thresholds": {}
  },

{
  "toolName": "vesting-calculator",
  "inputs": [
    {
      "id": "totalGrant",
      "label": "Total Grant Amount",
      "type": "number",
      "unit": "shares",
      "default": 1000,
      "businessContext": "Total number of stock options or shares granted under the vesting plan.",
      "label_i18n": {
        "en": "Total Grant Amount",
        "tr": "Total Grant Amount",
        "de": "Total Grant Amount",
        "fr": "Total Grant Amount",
        "es": "Total Grant Amount",
        "ar": "Total Grant Amount"
      }
    },
    {
      "id": "vestingStartMonth",
      "label": "Vesting Start Month",
      "type": "number",
      "unit": "months",
      "default": 0,
      "businessContext": "The month (relative to a reference) when the vesting period begins. Typically 0 means grant date.",
      "label_i18n": {
        "en": "Vesting Start Month",
        "tr": "Vesting Start Month",
        "de": "Vesting Start Month",
        "fr": "Vesting Start Month",
        "es": "Vesting Start Month",
        "ar": "Vesting Start Month"
      }
    },
    {
      "id": "currentMonth",
      "label": "Current Month",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "The current month number from the vesting start to calculate vested shares.",
      "label_i18n": {
        "en": "Current Month",
        "tr": "Current Month",
        "de": "Current Month",
        "fr": "Current Month",
        "es": "Current Month",
        "ar": "Current Month"
      }
    },
    {
      "id": "vestingPeriodMonths",
      "label": "Vesting Period (Full Term)",
      "type": "number",
      "unit": "months",
      "default": 48,
      "businessContext": "Total duration in months over which the grant fully vests.",
      "label_i18n": {
        "en": "Vesting Period (Full Term)",
        "tr": "Vesting Period (Full Term)",
        "de": "Vesting Period (Full Term)",
        "fr": "Vesting Period (Full Term)",
        "es": "Vesting Period (Full Term)",
        "ar": "Vesting Period (Full Term)"
      }
    },
    {
      "id": "cliffPeriodMonths",
      "label": "Cliff Period",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Initial period where no vesting occurs. After cliff, vesting may be accelerated or linear.",
      "label_i18n": {
        "en": "Cliff Period",
        "tr": "Cliff Period",
        "de": "Cliff Period",
        "fr": "Cliff Period",
        "es": "Cliff Period",
        "ar": "Cliff Period"
      }
    }
  ],
  "formulas": {
    "result": "totalGrant + vestingStartMonth + currentMonth",
    "result_copy": "totalGrant + vestingStartMonth + currentMonth"
  },
  "outputs": {

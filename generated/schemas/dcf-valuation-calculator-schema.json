  "formulas": {
    "fcf_bd1": "fcf1 / Math.pow(1 + WACC / 100, 1)",
    "fcf_bd2": "fcf2 / Math.pow(1 + WACC / 100, 2)",
    "fcf_bd3": "fcf3 / Math.pow(1 + WACC / 100, 3)",
    "fcf_bd4": "fcf4 / Math.pow(1 + WACC / 100, 4)",
    "fcf_bd5": "fcf5 / Math.pow(1 + WACC / 100, 5)",
    "tv": "fcf5 * (1 + terminalBuyume / 100) / Math.max(0.0001, (WACC / 100 - terminalBuyume / 100))",
    "tv_bd": "fcf5 * (1 + terminalBuyume / 100) / Math.max(0.0001, (WACC / 100 - terminalBuyume / 100)) / Math.pow(1 + WACC / 100, 5)",
    "sonuc": "fcf1 / Math.pow(1 + WACC/100, 1) + fcf2 / Math.pow(1 + WACC/100, 2) + fcf3 / Math.pow(1 + WACC/100, 3) + fcf4 / Math.pow(1 + WACC/100, 4) + fcf5 / Math.pow(1 + WACC/100, 5) + (fcf5 * (1 + terminalBuyume/100) / Math.max(0.0001, (WACC/100 - terminalBuyume/100))) / Math.pow(1 + WACC/100, 5)"
  },

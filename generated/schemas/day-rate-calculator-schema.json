    },
    {
      "id": "billableHoursPerDay",
      "label": "Billable Hours per Day",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Average billable hours per working day",
      "label_i18n": {
        "en": "Billable Hours per Day",
        "tr": "Günlük Faturalanabilir Saat",
        "de": "Billable Hours per Day",

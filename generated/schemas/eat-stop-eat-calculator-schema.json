{
  "toolName": "eat-stop-eat-calculator",
  "inputs": [
    {
      "id": "currentWeight",
      "label": "Current Weight",
      "type": "number",
      "unit": "kg",
      "default": 75,
      "businessContext": "Your current body weight in kilograms."
    },
    {
      "id": "goalWeight",
      "label": "Goal Weight",
      "type": "number",
      "unit": "kg",
      "default": 65,
      "businessContext": "Your target body weight in kilograms."
    },
    {
      "id": "dailyCaloriesNonFasting",
      "label": "Daily Calorie Intake (Non-Fasting Days)",
      "type": "number",
      "unit": "kcal",
      "default": 2000,
      "businessContext": "Average daily calorie consumption on days you eat normally."
    },
    {
      "id": "fastingDaysPerWeek",
      "label": "Fasting Days per Week",
      "type": "number",
      "unit": "days",
      "default": 2,
      "businessContext": "Number of days per week you perform a 24-hour fast (zero calories)."
    }
  ],
  "formulas": {
    "weeklyCaloricDeficit": "dailyCaloriesNonFasting * fastingDaysPerWeek",
    "weeklyWeightLossKg": "weeklyCaloricDeficit / 7700",
    "weeksToGoal": "(currentWeight - goalWeight) / weeklyWeightLossKg"
  },
  "outputs": {
    "primary": "weeksToGoal",
    "breakdown": [
      "weeklyCaloricDeficit",
      "weeklyWeightLossKg"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "electrical-power-systems",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

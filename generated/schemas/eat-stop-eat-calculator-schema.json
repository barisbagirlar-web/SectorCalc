        "ar": "Current Weight"
      }
    },
    {
      "id": "goalWeight",
      "label": "Goal Weight",
      "type": "number",
      "unit": "kg",
      "default": 65,
      "businessContext": "Your target body weight in kilograms.",
      "label_i18n": {
        "en": "Goal Weight",
        "tr": "Goal Weight",
        "de": "Goal Weight",
        "fr": "Goal Weight",
        "es": "Goal Weight",
        "ar": "Goal Weight"
      }
    },
    {
      "id": "dailyCaloriesNonFasting",
      "label": "Daily Calorie Intake (Non-Fasting Days)",
      "type": "number",
      "unit": "kcal",
      "default": 2000,
      "businessContext": "Average daily calorie consumption on days you eat normally.",
      "label_i18n": {
        "en": "Daily Calorie Intake (Non-Fasting Days)",
        "tr": "Daily Calorie Intake (Non-Fasting Days)",
        "de": "Daily Calorie Intake (Non-Fasting Days)",
        "fr": "Daily Calorie Intake (Non-Fasting Days)",
        "es": "Daily Calorie Intake (Non-Fasting Days)",
        "ar": "Daily Calorie Intake (Non-Fasting Days)"
      }
    },
    {
      "id": "fastingDaysPerWeek",
      "label": "Fasting Days per Week",
      "type": "number",
      "unit": "days",
      "default": 2,
      "businessContext": "Number of days per week you perform a 24-hour fast (zero calories).",
      "label_i18n": {
        "en": "Fasting Days per Week",
        "tr": "Fasting Days per Week",
        "de": "Fasting Days per Week",
        "fr": "Fasting Days per Week",
        "es": "Fasting Days per Week",
        "ar": "Fasting Days per Week"
      }
    }
  ],
  "formulas": {
    "weeklyCaloricDeficit": "dailyCaloriesNonFasting * fastingDaysPerWeek",
    "weeklyWeightLossKg": "weeklyCaloricDeficit / 7700",
    "weeksToGoal": "(currentWeight - goalWeight) / weeklyWeightLossKg"
  },
  "outputs": {
    "primary": "weeksToGoal",
    "breakdown": [
      "weeklyCaloricDeficit",
      "weeklyWeightLossKg"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "weeksToGoal"
  },

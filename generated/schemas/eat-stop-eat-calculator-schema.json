      "id": "currentWeight",
      "label": "Current Weight",
      "type": "number",
      "unit": "kg",
      "default": 75,
      "businessContext": "Your current body weight in kilograms.",
      "label_i18n": {
        "en": "Current Weight",
        "tr": "Current Weight",
        "de": "Current Weight",
        "fr": "Current Weight",

        "fr": "Temps d'arrêt dû à des pannes non planifiées",
        "es": "Tiempo de inactividad por fallas no planificadas"
      }
    },
    {
      "id": "plannedDowntime",
      "label": "Planned Downtime",
      "type": "number",
      "unit": "min",
      "default": 20,
      "businessContext": "Downtime for planned maintenance or setups",
      "label_i18n": {
        "en": "Planned Downtime",
        "tr": "Planlı Duruş",
        "de": "Geplante Stillstandszeit",

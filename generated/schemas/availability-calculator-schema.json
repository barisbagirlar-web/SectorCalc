        "fr": "Temps d'arrêt pour maintenance planifiée ou réglages",
        "es": "Tiempo de inactividad por mantenimiento planificado o cambios de formato"
      }
    },
    {
      "id": "numberOfFailures",
      "label": "Number of Failures",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of failure events during the period",
      "label_i18n": {
        "en": "Number of Failures",
        "tr": "Arıza Sayısı",
        "de": "Anzahl der Ausfälle",
        "fr": "Nombre de pannes",
        "es": "Número de fallas",
        "ar": "Number of Failures"
      },
      "businessContext_i18n": {
        "en": "Number of failure events during the period",
        "tr": "Dönem içindeki arıza olaylarının sayısı",
        "de": "Anzahl der Ausfallereignisse im Zeitraum",
        "fr": "Nombre d'événements de panne pendant la période",
        "es": "Número de eventos de falla durante el período"
      }
    },
    {
      "id": "meanTimeToRepair",
      "label": "Mean Time To Repair (MTTR)",
      "type": "number",
      "unit": "min",
      "default": 15,
      "businessContext": "Average repair time per failure",
      "label_i18n": {
        "en": "Mean Time To Repair (MTTR)",
        "tr": "Ortalama onarım süresi (MTTR)",
        "de": "Mittlere Reparaturdauer (MTTR)",
        "fr": "Temps moyen de réparation (MTTR)",
        "es": "Tiempo medio de reparación (MTTR)",
        "ar": "Mean Time To Repair (MTTR)"
      },
      "businessContext_i18n": {
        "en": "Average repair time per failure",
        "tr": "Arıza başına ortalama onarım süresi",
        "de": "Durchschnittliche Reparaturzeit pro Ausfall",
        "fr": "Temps moyen de réparation par panne",
        "es": "Tiempo promedio de reparación por falla"
      }
    }
  ],
  "formulas": {
    "totalDowntime": "unplannedDowntime + plannedDowntime",
    "uptime": "plannedAvailableTime - (unplannedDowntime + plannedDowntime)",
    "availability": "(plannedAvailableTime - unplannedDowntime - plannedDowntime) / plannedAvailableTime * 100",
    "mtbf": "(plannedAvailableTime - unplannedDowntime - plannedDowntime) / numberOfFailures",
    "mttr": "meanTimeToRepair"
  },
  "outputs": {
    "primary": "availability",
    "breakdown": [
      "uptime",
      "totalDowntime",
      "mtbf",
      "mttr"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "mttr",
    "unit": "%",
    "breakdownUnits": {
      "totalDowntime": "min"
    }
  },

{
  "toolName": "inductive-reactance-calculator",
  "inputs": [
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 50,
      "businessContext": "AC supply frequency or operating frequency",
      "label_i18n": {
        "en": "Frequency",
        "tr": "Frequency",
        "de": "Frequency",
        "fr": "Frequency",
        "es": "Frequency",
        "ar": "Frequency"
      }
    },
    {
      "id": "inductance",
      "label": "Inductance",
      "type": "number",
      "unit": "H",
      "default": 0.01,
      "businessContext": "Inductance of the coil or inductor",
      "label_i18n": {
        "en": "Inductance",
        "tr": "Inductance",
        "de": "Inductance",
        "fr": "Inductance",
        "es": "Inductance",
        "ar": "Inductance"
      }
    },
    {
      "id": "measuredVoltage",
      "label": "Measured Voltage",
      "type": "number",
      "unit": "V",
      "default": 0,
      "businessContext": "RMS voltage measured across the inductor (optional for experimental verification)",
      "label_i18n": {
        "en": "Measured Voltage",
        "tr": "Measured Voltage",
        "de": "Measured Voltage",
        "fr": "Measured Voltage",
        "es": "Measured Voltage",
        "ar": "Measured Voltage"
      }
    },
    {
      "id": "measuredCurrent",
      "label": "Measured Current",
      "type": "number",
      "unit": "A",
      "default": 0,
      "businessContext": "RMS current through the inductor (optional for experimental verification)",
      "label_i18n": {
        "en": "Measured Current",
        "tr": "Measured Current",
        "de": "Measured Current",
        "fr": "Measured Current",
        "es": "Measured Current",
        "ar": "Measured Current"
      }
    }
  ],
  "formulas": {
    "angularFrequency": "2 * Math.PI * frequency",
    "inductiveReactance": "2 * Math.PI * frequency * inductance",
    "measuredReactance": "measuredCurrent !== 0 ? measuredVoltage / measuredCurrent : null"
  },
  "outputs": {
    "primary": "inductiveReactance",
    "breakdown": [
      "Angular Frequency (ω): {angularFrequency} rad/s",
      "Theoretical Inductive Reactance (X_L): {inductiveReactance} Ω",
      "Measured Reactance (X_L_meas): {measuredReactance} Ω (if provided, otherwise N/A)"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "measuredReactance"
  },

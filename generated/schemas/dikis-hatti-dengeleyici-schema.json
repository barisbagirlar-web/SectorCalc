  "formulas": {
    "TaktTime": "AvailableTime / Demand",
    "CycleTotal": "SUM(SMV)",
    "TheoOperators": "CycleTotal / TaktTime",
    "ActOperators": "CEILING(TheoOperators)",
    "LineEff": "(CycleTotal / (ActOperators * TaktTime)) * 100",
    "BalanceDelay": "100 - LineEff",
    "Smoothness": "SQRT(SUM((MaxCycle - Cycle_i)^2) / ActOperators)",
    "WIP": "(Bottleneck - Takt) * Demand"
  },

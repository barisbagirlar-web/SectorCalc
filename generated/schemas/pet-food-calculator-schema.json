  "formulas": {
    "dailyCalories": "70 * Math.pow(inputs.weight, 0.75) * inputs.activityFactor",
    "dailyFoodGrams": "1000 * 70 * Math.pow(inputs.weight, 0.75) * inputs.activityFactor / inputs.caloricDensity",
    "foodPerMealGrams": "1000 * 70 * Math.pow(inputs.weight, 0.75) * inputs.activityFactor / inputs.caloricDensity / inputs.mealsPerDay"
  },
  "outputs": {
    "primary": "dailyFoodGrams",
    "breakdown": [

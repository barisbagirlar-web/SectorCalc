{
  "toolName": "dividend-yield-calculator",
  "inputs": [
    {
      "id": "annualDividendPerShare",
      "label": "Annual Dividend per Share",
      "type": "number",
      "unit": "USD",
      "default": 2,
      "businessContext": "The total dividends paid per share over a year.",
      "label_i18n": {
        "en": "Annual Dividend per Share",
        "tr": "Annual Dividend per Share",
        "de": "Annual Dividend per Share",
        "fr": "Annual Dividend per Share",
        "es": "Annual Dividend per Share",
        "ar": "Annual Dividend per Share"
      }
    },
    {
      "id": "marketPricePerShare",
      "label": "Market Price per Share",
      "type": "number",
      "unit": "USD",
      "default": 40,
      "businessContext": "Current market price of one share.",
      "label_i18n": {
        "en": "Market Price per Share",
        "tr": "Market Price per Share",
        "de": "Market Price per Share",
        "fr": "Market Price per Share",
        "es": "Market Price per Share",
        "ar": "Market Price per Share"
      }
    },
    {
      "id": "numberOfShares",
      "label": "Number of Shares",
      "type": "number",
      "unit": "shares",
      "default": 100,
      "businessContext": "Number of shares owned for total dividend calculation.",
      "label_i18n": {
        "en": "Number of Shares",
        "tr": "Number of Shares",
        "de": "Number of Shares",
        "fr": "Number of Shares",
        "es": "Number of Shares",
        "ar": "Number of Shares"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Tax rate on dividend income for after-tax yield calculation.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "dividendYield": "annualDividendPerShare / marketPricePerShare * 100",
    "totalDividend": "annualDividendPerShare * numberOfShares",
    "afterTaxYield": "dividendYield * (1 - taxRate / 100)"
  },
  "outputs": {
    "primary": "dividendYield",
    "breakdown": [
      "totalDividend",
      "afterTaxYield"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "afterTaxYield"
  },

        "en": "Water Used",
        "tr": "Water Used",
        "de": "Water Used",
        "fr": "Water Used",
        "es": "Water Used",
        "ar": "Water Used"
      }
    },
    {
      "id": "beanCostPerKg",
      "label": "Bean Cost",
      "type": "number",
      "unit": "currency/kg",
      "default": 20,
      "businessContext": "Cost of coffee beans per kilogram.",
      "label_i18n": {
        "en": "Bean Cost",
        "tr": "Bean Cost",
        "de": "Bean Cost",
        "fr": "Bean Cost",
        "es": "Bean Cost",

  "formulas": {
    "coffeeCost": "(coffeeBeans / 1000) * beanCostPerKg",
    "energyCost": "((machinePowerWatts * (brewTimeMinutes / 60)) / 1000) * electricityCostPerKwh",
    "laborCost": "(brewTimeMinutes / 60) * laborCostPerHour",
    "totalDirectCost": "coffeeCost + energyCost + laborCost",
    "totalCost": "totalDirectCost * (1 + (overheadFactor / 100))"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "coffeeCost",
      "energyCost",
      "laborCost"
    ],

        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      }
    },
    {
      "id": "machinePowerWatts",
      "label": "Machine Power",
      "type": "number",
      "unit": "watts",
      "default": 1000,
      "businessContext": "Power consumption of coffee machine.",
      "label_i18n": {
        "en": "Machine Power",
        "tr": "Machine Power",
        "de": "Machine Power",
        "fr": "Machine Power",
        "es": "Machine Power",
        "ar": "Machine Power"
      }
    },
    {
      "id": "brewTimeMinutes",
      "label": "Brew Time",
      "type": "number",
      "unit": "minutes",
      "default": 3,
      "businessContext": "Time to brew one cup.",
      "label_i18n": {
        "en": "Brew Time",
        "tr": "Brew Time",
        "de": "Brew Time",
        "fr": "Brew Time",
        "es": "Brew Time",
        "ar": "Brew Time"
      }
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost",
      "type": "number",
      "unit": "currency/hour",
      "default": 12,
      "businessContext": "Barista labor cost per hour.",
      "label_i18n": {
        "en": "Labor Cost",
        "tr": "Labor Cost",
        "de": "Labor Cost",
        "fr": "Labor Cost",
        "es": "Labor Cost",
        "ar": "Labor Cost"
      }
    },
    {
      "id": "overheadFactor",
      "label": "Overhead %",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Overhead costs as percentage of direct costs.",
      "label_i18n": {
        "en": "Overhead %",
        "tr": "Overhead %",
        "de": "Overhead %",
        "fr": "Overhead %",
        "es": "Overhead %",
        "ar": "Overhead %"
      }
    }
  ],
  "formulas": {
    "coffeeCost": "(coffeeBeans / 1000) * beanCostPerKg",
    "energyCost": "((machinePowerWatts * (brewTimeMinutes / 60)) / 1000) * electricityCostPerKwh",
    "laborCost": "(brewTimeMinutes / 60) * laborCostPerHour",
    "totalDirectCost": "coffeeCost + energyCost + laborCost",
    "totalCost": "totalDirectCost * (1 + (overheadFactor / 100))"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "coffeeCost",
      "energyCost",
      "laborCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

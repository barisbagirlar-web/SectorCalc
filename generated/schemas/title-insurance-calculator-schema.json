{
  "toolName": "title-insurance-calculator",
  "inputs": [
    {
      "id": "propertyValue",
      "label": "Property Value",
      "type": "number",
      "unit": "USD",
      "default": 300000,
      "businessContext": "The market value or purchase price of the property.",
      "label_i18n": {
        "en": "Property Value",
        "tr": "Property Value",
        "de": "Property Value",
        "fr": "Property Value",
        "es": "Property Value",
        "ar": "Property Value"
      }
    },
    {
      "id": "coverageAmount",
      "label": "Coverage Amount",
      "type": "number",
      "unit": "USD",
      "default": 300000,
      "businessContext": "The amount of title insurance coverage, typically equal to the property value. Can be higher if there is additional risk.",
      "label_i18n": {
        "en": "Coverage Amount",
        "tr": "Coverage Amount",
        "de": "Coverage Amount",
        "fr": "Coverage Amount",
        "es": "Coverage Amount",
        "ar": "Coverage Amount"
      }
    },
    {
      "id": "ratePerThousand",
      "label": "Rate per $1000",
      "type": "number",
      "unit": "USD/1000",
      "default": 5,
      "businessContext": "The title insurance premium rate per $1000 of coverage. Varies by state and insurer.",
      "label_i18n": {
        "en": "Rate per $1000",
        "tr": "Rate per $1000",
        "de": "Rate per $1000",
        "fr": "Rate per $1000",
        "es": "Rate per $1000",
        "ar": "Rate per $1000"
      }
    },
    {
      "id": "policyFee",
      "label": "Policy Fee",
      "type": "number",
      "unit": "USD",
      "default": 150,
      "businessContext": "Fixed administrative fee for issuing the title insurance policy.",
      "label_i18n": {
        "en": "Policy Fee",
        "tr": "Policy Fee",
        "de": "Policy Fee",
        "fr": "Policy Fee",
        "es": "Policy Fee",
        "ar": "Policy Fee"
      }
    },
    {
      "id": "stateTaxRate",
      "label": "State Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "State tax rate applied to the premium, expressed as a percentage.",
      "label_i18n": {
        "en": "State Tax Rate",
        "tr": "State Tax Rate",
        "de": "State Tax Rate",
        "fr": "State Tax Rate",
        "es": "State Tax Rate",
        "ar": "State Tax Rate"
      }
    }
  ],
  "formulas": {
    "basePremium": "coverageAmount * (ratePerThousand / 1000)",
    "stateTax": "basePremium * stateTaxRate / 100",
    "totalPremium": "basePremium + policyFee + stateTax"
  },
  "outputs": {
    "primary": "totalPremium",
    "breakdown": [
      "basePremium",
      "policyFee",
      "stateTax",
      "totalPremium"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPremium"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

  "formulas": {
    "generateSamples": "let samples = []; for(let i=0; i<numSamples; i++){ let u1 = Math.random(); let u2 = Math.random(); let z = Math.sqrt(-2*Math.log(u1))*Math.cos(2*Math.PI*u2); samples.push(mean + stdDev*z); } samples;",
    "defects": "let samples = generateSamples(); let count = 0; for(let s of samples){ if(s < lowerSpec || s > upperSpec) count++; } count;",
    "defectRate": "defects / numSamples",
    "yield": "1 - defectRate",
    "cp": "(upperSpec - lowerSpec) / (6 * stdDev)",
    "cpk": "Math.min((mean - lowerSpec)/(3*stdDev), (upperSpec - mean)/(3*stdDev))"
  },
  "outputs": {
    "primary": "defectRate",
    "breakdown": [
      "yield",
      "cp",
      "cpk"
    ]
  },

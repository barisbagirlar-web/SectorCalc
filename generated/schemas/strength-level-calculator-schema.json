{
  "toolName": "strength-level-calculator",
  "inputs": [
    {
      "id": "appliedForce",
      "label": "Uygulanan Kuvvet",
      "type": "number",
      "unit": "N",
      "default": 1000,
      "businessContext": "Parçaya uygulanan kuvvet"
    },
    {
      "id": "crossSectionArea",
      "label": "Kesit Alanı",
      "type": "number",
      "unit": "mm²",
      "default": 50,
      "businessContext": "Parçanın yükü taşıyan kesit alanı"
    },
    {
      "id": "yieldStrength",
      "label": "Akma Dayanımı",
      "type": "number",
      "unit": "MPa",
      "default": 250,
      "businessContext": "Malzemenin akma dayanımı"
    },
    {
      "id": "safetyFactor",
      "label": "Emniyet Katsayısı",
      "type": "number",
      "unit": "",
      "default": 1.5,
      "businessContext": "Tasarım emniyet katsayısı"
    }
  ],
  "formulas": {
    "strengthLevel": "(yieldStrength / ((appliedForce / crossSectionArea) * safetyFactor)) * 100",
    "workingStress": "appliedForce / crossSectionArea",
    "allowableStress": "yieldStrength / safetyFactor"
  },
  "outputs": {
    "primary": "strengthLevel",
    "breakdown": [
      "workingStress",
      "allowableStress"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
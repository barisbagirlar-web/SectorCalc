  "formulas": {
    "TargetPlantPopulation": "Area * DesiredPlantsPerSqm",
    "SeedRequirement": "TargetPlantPopulation / (GerminationRate * FieldEmergenceRate)",
    "SeedCost": "SeedRequirement * PricePerKg",
    "OptimalYield": "f(PlantPopulation, SoilFertility, Water)",
    "FinancialLoss_Under": "(TargetYield - ActualYield) * CropPrice",
    "FinancialLoss_Over": "(ActualSeed - OptimalSeed) * SeedCost",
    "ROI_Seed": "(OptimalYield * CropPrice - SeedCost) / SeedCost"
  },

{
  "toolName": "ebay-fee-calculator",
  "inputs": [
    {
      "id": "salePrice",
      "label": "Sale Price",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "The final price at which the item was sold, excluding shipping.",
      "label_i18n": {
        "en": "Sale Price",
        "tr": "Sale Price",
        "de": "Sale Price",
        "fr": "Sale Price",
        "es": "Sale Price",
        "ar": "Sale Price"
      }
    },
    {
      "id": "shippingCost",
      "label": "Shipping Cost",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "The shipping cost charged to the buyer.",
      "label_i18n": {
        "en": "Shipping Cost",
        "tr": "Shipping Cost",
        "de": "Shipping Cost",
        "fr": "Shipping Cost",
        "es": "Shipping Cost",
        "ar": "Shipping Cost"
      }
    },
    {
      "id": "finalValueFeeRate",
      "label": "Final Value Fee Rate",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "The percentage of the total sale amount (item price + shipping) charged as final value fee.",
      "label_i18n": {
        "en": "Final Value Fee Rate",
        "tr": "Final Value Fee Rate",
        "de": "Final Value Fee Rate",
        "fr": "Final Value Fee Rate",
        "es": "Final Value Fee Rate",
        "ar": "Final Value Fee Rate"
      }
    },
    {
      "id": "fixedFinalValueFee",
      "label": "Fixed Final Value Fee",
      "type": "number",
      "unit": "EUR",
      "default": 0.3,
      "businessContext": "A fixed fee per order charged on top of the percentage-based final value fee.",
      "label_i18n": {
        "en": "Fixed Final Value Fee",
        "tr": "Fixed Final Value Fee",
        "de": "Fixed Final Value Fee",
        "fr": "Fixed Final Value Fee",
        "es": "Fixed Final Value Fee",
        "ar": "Fixed Final Value Fee"
      }
    },
    {
      "id": "insertionFee",
      "label": "Insertion Fee",
      "type": "number",
      "unit": "EUR",
      "default": 0.35,
      "businessContext": "The fee charged for listing the item. First few listings may be free.",
      "label_i18n": {
        "en": "Insertion Fee",
        "tr": "Insertion Fee",
        "de": "Insertion Fee",
        "fr": "Insertion Fee",
        "es": "Insertion Fee",
        "ar": "Insertion Fee"
      }
    },
    {
      "id": "listingUpgradeFee",
      "label": "Listing Upgrade Fee",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Any additional fees for listing upgrades (e.g., bold title, subtitle, gallery plus).",
      "label_i18n": {
        "en": "Listing Upgrade Fee",
        "tr": "Listing Upgrade Fee",
        "de": "Listing Upgrade Fee",
        "fr": "Listing Upgrade Fee",
        "es": "Listing Upgrade Fee",
        "ar": "Listing Upgrade Fee"
      }
    }
  ],
  "formulas": {
    "totalSaleAmount": "salePrice + shippingCost",
    "finalValueFee": "totalSaleAmount * (finalValueFeeRate / 100) + fixedFinalValueFee",
    "totalEbayFees": "finalValueFee + insertionFee + listingUpgradeFee",
    "netPayout": "totalSaleAmount - totalEbayFees"
  },
  "outputs": {
    "primary": "netPayout",
    "breakdown": [
      "totalEbayFees",
      "finalValueFee",
      "insertionFee",
      "listingUpgradeFee"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netPayout"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "procurement-supply-chain",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

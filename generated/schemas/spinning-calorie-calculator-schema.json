{
  "toolName": "spinning-calorie-calculator",
  "inputs": [
    {
      "id": "duration_min",
      "label": "Süre (dk)",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Spinning seansının dakika cinsinden süresi"
    },
    {
      "id": "speed_kmh",
      "label": "Ortalama Hız",
      "type": "number",
      "unit": "km/h",
      "default": 20,
      "businessContext": "Seans boyunca ortalama pedal çevirme hızı"
    },
    {
      "id": "resistance_level",
      "label": "Direnç Seviyesi",
      "type": "number",
      "unit": "1-10",
      "default": 5,
      "businessContext": "Bisiklet direncinin 1 ile 10 arasındaki seviyesi"
    },
    {
      "id": "weight_kg",
      "label": "Ağırlık",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Kullanıcının vücut ağırlığı"
    },
    {
      "id": "age_years",
      "label": "Yaş",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Kullanıcının yaşı (opsiyonel, formülde doğrudan kullanılmaz)"
    }
  ],
  "formulas": {
    "met_value": "3.5 + (speed_kmh * 0.2) + (resistance_level * 0.5)",
    "total_calories": "met_value * weight_kg * (duration_min / 60)",
    "calories_per_minute": "total_calories / duration_min"
  },
  "outputs": {
    "primary": "total_calories",
    "breakdown": [
      "met_value",
      "calories_per_minute"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
        "es": "Metal Gram Fiyatı",
        "ar": "Metal Gram Fiyatı"
      }
    },
    {
      "id": "gemstoneCost",
      "label": "Taş Maliyeti",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Kullanılan değerli taşların toplam maliyeti",
      "label_i18n": {
        "en": "Taş Maliyeti",
        "tr": "Taş Maliyeti",
        "de": "Taş Maliyeti",
        "fr": "Taş Maliyeti",
        "es": "Taş Maliyeti",
        "ar": "Taş Maliyeti"
      }
    },
    {
      "id": "laborCost",
      "label": "İşçilik Maliyeti",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Üretim veya montaj için işçilik bedeli",
      "label_i18n": {
        "en": "İşçilik Maliyeti",
        "tr": "İşçilik Maliyeti",
        "de": "İşçilik Maliyeti",
        "fr": "İşçilik Maliyeti",
        "es": "İşçilik Maliyeti",
        "ar": "İşçilik Maliyeti"
      }
    },
    {
      "id": "markupPercent",
      "label": "Kâr Marjı Oranı",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Toplam maliyet üzerine eklenecek kâr marjı yüzdesi",
      "label_i18n": {
        "en": "Kâr Marjı Oranı",
        "tr": "Kâr Marjı Oranı",
        "de": "Kâr Marjı Oranı",
        "fr": "Kâr Marjı Oranı",
        "es": "Kâr Marjı Oranı",
        "ar": "Kâr Marjı Oranı"
      }
    }
  ],
  "formulas": {
    "metalCost": "metalWeight * (metalPurity / 24) * metalPricePerGram",
    "materialCost": "metalCost + gemstoneCost",
    "totalCost": "materialCost + laborCost",
    "markupAmount": "totalCost * (markupPercent / 100)",
    "finalPrice": "totalCost + markupAmount"
  },
  "outputs": {
    "primary": "finalPrice",
    "breakdown": [
      "metalCost",
      "materialCost",
      "totalCost",
      "markupAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalPrice",

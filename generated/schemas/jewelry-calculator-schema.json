        "es": "Metal Ağırlık",
        "ar": "Metal Ağırlık"
      }
    },
    {
      "id": "metalPurity",
      "label": "Ayar",
      "type": "number",
      "unit": "K",
      "default": 18,
      "businessContext": "Metalin saflığı (24 ayar saf, 18 ayar %75 vb.)",
      "label_i18n": {
        "en": "Ayar",
        "tr": "Ayar",
        "de": "Ayar",
        "fr": "Ayar",
        "es": "Ayar",
        "ar": "Ayar"
      }
    },
    {

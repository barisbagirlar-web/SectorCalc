{
  "toolName": "daire-alani-cevresi-hesaplama",
  "inputs": [
    {
      "id": "yaricap",
      "label": "Yarıçap",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Dairenin yarıçapı. Geometrik hesaplamalar için temel girdi. Kaynak: Temel geometri."
    },
    {
      "id": "birim",
      "label": "Birim",
      "type": "select",
      "unit": "",
      "default": "m",
      "min": null,
      "max": null,
      "options": [
        "mm",
        "cm",
        "m",
        "km",
        "in",
        "ft"
      ],
      "businessContext": "Uzunluk birimi. Sonuçların istenen birimde gösterilmesi için. Kaynak: SI ve emperyal birim sistemleri."
    }
  ],
  "validation": {
    "rules": [
      "yaricap > 0"
    ],
    "thresholds": {
      "yaricap": "yaricap <= 0 ? 'Yarıçap pozitif olmalıdır' : ''"
    }
  },
  "formulas": {
    "alan": "Math.PI * yaricap * yaricap",
    "cevre": "2 * Math.PI * yaricap"
  },
  "outputs": {
    "primary": "alan",
    "breakdown": {
      "cevre": "cevre"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [],
    "dataConfidenceAdjusted": ""
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "trend analizi",
    "karşılaştırma",
    "detaylı rapor"
  ],
  "premiumRequired": false
}

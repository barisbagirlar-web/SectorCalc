  "formulas": {
    "synchronousSpeed": "120 * frequency / poles",
    "rotorSpeed": "synchronousSpeed * (1 - slip / 100)",
    "torque": "(outputPower * 9550) / rotorSpeed",
    "inputPower": "voltage * current * powerFactor * Math.sqrt(3) / 1000",
    "efficiency": "(outputPower / inputPower) * 100"
  },
  "outputs": {
    "primary": "torque",
    "breakdown": [

{
  "toolName": "mass-percent-calculator",
  "inputs": [
    {
      "id": "componentMass",
      "label": "Mass of Component",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Mass of the component for which mass percent is calculated.",
      "label_i18n": {
        "en": "Mass of Component",
        "tr": "Mass of Component",
        "de": "Mass of Component",
        "fr": "Mass of Component",
        "es": "Mass of Component",
        "ar": "Mass of Component"
      }
    },
    {
      "id": "otherComponentMass",
      "label": "Mass of Other Component",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Mass of the other component in the mixture. If total mass is not provided, this is used with component mass to compute total.",
      "label_i18n": {
        "en": "Mass of Other Component",
        "tr": "Mass of Other Component",
        "de": "Mass of Other Component",
        "fr": "Mass of Other Component",
        "es": "Mass of Other Component",
        "ar": "Mass of Other Component"
      }
    },
    {
      "id": "totalMass",
      "label": "Total Mass of Mixture",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Total mass of the mixture. If provided, it overrides the sum of component and other component.",
      "label_i18n": {
        "en": "Total Mass of Mixture",
        "tr": "Total Mass of Mixture",
        "de": "Total Mass of Mixture",
        "fr": "Total Mass of Mixture",
        "es": "Total Mass of Mixture",
        "ar": "Total Mass of Mixture"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the mass percent output.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "totalMassCalc": "inputs.totalMass > 0 ? inputs.totalMass : inputs.componentMass + inputs.otherComponentMass",
    "massPercent": "(inputs.componentMass / totalMassCalc) * 100",
    "massPercentRounded": "parseFloat(massPercent.toFixed(inputs.precision))",
    "otherMassPercent": "inputs.totalMass > 0 ? ((inputs.totalMass - inputs.componentMass) / inputs.totalMass) * 100 : (inputs.otherComponentMass / totalMassCalc) * 100",
    "otherMassPercentRounded": "parseFloat(otherMassPercent.toFixed(inputs.precision))"
  },
  "outputs": {
    "primary": "massPercentRounded",
    "breakdown": [
      "otherMassPercentRounded",
      "totalMassCalc"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "chemistry-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

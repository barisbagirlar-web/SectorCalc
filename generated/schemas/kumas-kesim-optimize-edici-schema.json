    "Utilization_Gain": "(NewEfficiency - OldEfficiency) * FabricRequired * PricePerMeter",
    "SplicingLoss": "Splices * OverlapLength * FabricWidth",
    "TotalYardage": "MarkerLength + EndLoss + SplicingLoss"

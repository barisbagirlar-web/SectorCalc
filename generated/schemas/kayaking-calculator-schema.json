      }
    },
    {
      "id": "dragCoefficient",
      "label": "Drag Coefficient",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Typical drag coefficient for the kayak hull shape.",
      "label_i18n": {
        "en": "Drag Coefficient",
        "tr": "Sürükleme Katsayısı",

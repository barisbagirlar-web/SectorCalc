      "businessContext": "Frontal area of the kayak and paddler.",
      "label_i18n": {
        "en": "Cross-sectional Area",
        "tr": "Kesit Alanı",
        "de": "Cross-sectional Area",
        "fr": "Cross-sectional Area",

        "ar": "Cross-sectional Area"
      },
      "businessContext_i18n": {
        "en": "Frontal area of the kayak and paddler.",
        "tr": "Kano ve kürekçinin ön alanı."
      }
    },
    {
      "id": "waterDensity",
      "label": "Water Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Density of water (fresh water ~1000, salt water ~1025).",
      "label_i18n": {
        "en": "Water Density",
        "tr": "Su Yoğunluğu",
        "de": "Water Density",
        "fr": "Water Density",
        "es": "Water Density",
        "ar": "Water Density"
      },
      "businessContext_i18n": {
        "en": "Density of water (fresh water ~1000, salt water ~1025).",
        "tr": "Su yoğunluğu (tatlı su ~1000, tuzlu su ~1025)."
      }
    },
    {
      "id": "paddlingEfficiency",
      "label": "Paddling Efficiency",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Mechanical efficiency of converting human power to propulsion.",
      "label_i18n": {
        "en": "Paddling Efficiency",
        "tr": "Kürek Çekme Verimliliği",
        "de": "Paddling Efficiency",
        "fr": "Paddling Efficiency",
        "es": "Paddling Efficiency",
        "ar": "Paddling Efficiency"
      },
      "businessContext_i18n": {
        "en": "Mechanical efficiency of converting human power to propulsion.",
        "tr": "İnsan gücünü itişe dönüştüren mekanik verimlilik."
      }
    }
  ],
  "formulas": {
    "dragForce": "0.5 * waterDensity * dragCoefficient * crossSectionalArea * speed * speed",
    "effectivePower": "dragForce * speed",
    "powerRequired": "effectivePower / (paddlingEfficiency / 100)"
  },
  "outputs": {
    "primary": "powerRequired",
    "breakdown": [
      "dragForce",
      "effectivePower"
    ],

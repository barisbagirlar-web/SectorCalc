  "formulas": {
    "totalModules": "quietZoneLeft + quietZoneRight + 11 + 11 * dataLength + 11 + 13",
    "barcodeWidth": "totalModules * moduleWidth",
    "leftQuietWidth": "quietZoneLeft * moduleWidth",
    "rightQuietWidth": "quietZoneRight * moduleWidth",
    "dataWidth": "11 * dataLength * moduleWidth",
    "startWidth": "11 * moduleWidth",
    "checkWidth": "11 * moduleWidth",
    "stopWidth": "13 * moduleWidth"
  },

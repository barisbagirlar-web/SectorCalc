{
  "toolName": "funnel-analysis-calculator",
  "inputs": [
    {
      "id": "visitors",
      "label": "Visitors",
      "type": "number",
      "unit": "count",
      "default": 1000,
      "businessContext": "Top-of-funnel audience size (e.g., ad impressions, website visitors)",
      "label_i18n": {
        "en": "Visitors",
        "tr": "Visitors",
        "de": "Visitors",
        "fr": "Visitors",
        "es": "Visitors",
        "ar": "Visitors"
      }
    },
    {
      "id": "leads",
      "label": "Leads",
      "type": "number",
      "unit": "count",
      "default": 500,
      "businessContext": "Leads generated (e.g., form fills, sign-ups)",
      "label_i18n": {
        "en": "Leads",
        "tr": "Leads",
        "de": "Leads",
        "fr": "Leads",
        "es": "Leads",
        "ar": "Leads"
      }
    },
    {
      "id": "qualifiedLeads",
      "label": "Qualified Leads",
      "type": "number",
      "unit": "count",
      "default": 200,
      "businessContext": "Leads meeting marketing/sales qualification criteria",
      "label_i18n": {
        "en": "Qualified Leads",
        "tr": "Qualified Leads",
        "de": "Qualified Leads",
        "fr": "Qualified Leads",
        "es": "Qualified Leads",
        "ar": "Qualified Leads"
      }
    },
    {
      "id": "opportunities",
      "label": "Opportunities",
      "type": "number",
      "unit": "count",
      "default": 100,
      "businessContext": "Sales-qualified opportunities or trials",
      "label_i18n": {
        "en": "Opportunities",
        "tr": "Opportunities",
        "de": "Opportunities",
        "fr": "Opportunities",
        "es": "Opportunities",
        "ar": "Opportunities"
      }
    },
    {
      "id": "customers",
      "label": "Customers",
      "type": "number",
      "unit": "count",
      "default": 30,
      "businessContext": "Closed-won deals or paying customers",
      "label_i18n": {
        "en": "Customers",
        "tr": "Customers",
        "de": "Customers",
        "fr": "Customers",
        "es": "Customers",
        "ar": "Customers"
      }
    }
  ],
  "formulas": {
    "visitorToLeadRate": "visitors > 0 ? (leads / visitors) * 100 : 0",
    "leadToQualifiedRate": "leads > 0 ? (qualifiedLeads / leads) * 100 : 0",
    "qualifiedToOpportunityRate": "qualifiedLeads > 0 ? (opportunities / qualifiedLeads) * 100 : 0",
    "opportunityToCustomerRate": "opportunities > 0 ? (customers / opportunities) * 100 : 0",
    "overallConversion": "visitors > 0 ? (customers / visitors) * 100 : 0"
  },
  "outputs": {
    "primary": "overallConversion",
    "breakdown": [
      "visitorToLeadRate",
      "leadToQualifiedRate",
      "qualifiedToOpportunityRate",
      "opportunityToCustomerRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "overallConversion",
    "unit": "count"
  },

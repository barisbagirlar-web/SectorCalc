{
  "toolName": "heloc-calculator",
  "inputs": [
    {
      "id": "homeValue",
      "label": "Home Value",
      "type": "number",
      "unit": "USD",
      "default": 300000,
      "businessContext": "Current appraised market value of the property",
      "label_i18n": {
        "en": "Home Value",
        "tr": "Home Value",
        "de": "Home Value",
        "fr": "Home Value",
        "es": "Home Value",
        "ar": "Home Value"
      }
    },
    {
      "id": "mortgageBalance",
      "label": "Mortgage Balance",
      "type": "number",
      "unit": "USD",
      "default": 200000,
      "businessContext": "Outstanding balance on the first mortgage",
      "label_i18n": {
        "en": "Mortgage Balance",
        "tr": "Mortgage Balance",
        "de": "Mortgage Balance",
        "fr": "Mortgage Balance",
        "es": "Mortgage Balance",
        "ar": "Mortgage Balance"
      }
    },
    {
      "id": "ltvLimit",
      "label": "LTV Limit",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Maximum combined loan-to-value ratio allowed by lender",
      "label_i18n": {
        "en": "LTV Limit",
        "tr": "LTV Limit",
        "de": "LTV Limit",
        "fr": "LTV Limit",
        "es": "LTV Limit",
        "ar": "LTV Limit"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual interest rate on the HELOC",
      "label_i18n": {
        "en": "Interest Rate",
        "tr": "Interest Rate",
        "de": "Interest Rate",
        "fr": "Interest Rate",
        "es": "Interest Rate",
        "ar": "Interest Rate"
      }
    },
    {
      "id": "drawAmount",
      "label": "Draw Amount",
      "type": "number",
      "unit": "USD",
      "default": 50000,
      "businessContext": "Amount you plan to draw from the HELOC",
      "label_i18n": {
        "en": "Draw Amount",
        "tr": "Draw Amount",
        "de": "Draw Amount",
        "fr": "Draw Amount",
        "es": "Draw Amount",
        "ar": "Draw Amount"
      }
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Repayment period for the HELOC",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    }
  ],
  "formulas": {
    "maxHeloc": "homeValue * (ltvLimit / 100) - mortgageBalance",
    "availableEquity": "homeValue - mortgageBalance"
  },
  "outputs": {
    "primary": "maxHeloc",
    "breakdown": [
      "availableEquity",
      "monthlyPayment",
      "totalInterest"
    ],

      "businessContext": "Diameter of the string (e.g., 0.010 inch ≈ 0.254 mm)",
      "label_i18n": {
        "en": "String Diameter",
        "tr": "String Diameter",
        "de": "String Diameter",
        "fr": "String Diameter",
        "es": "String Diameter",
        "ar": "String Diameter"
      }
    },
    {
      "id": "materialDensity",
      "label": "Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "businessContext": "Density of string material (steel ≈ 7850 kg/m³, nickel ≈ 8900 kg/m³)",
      "label_i18n": {
        "en": "Material Density",
        "tr": "Material Density",
        "de": "Material Density",
        "fr": "Material Density",
        "es": "Material Density",
        "ar": "Material Density"
      }
    },
    {
      "id": "targetFrequency",
      "label": "Target Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 329.63,
      "businessContext": "Desired pitch frequency (e.g., E4 = 329.63 Hz for high E string)",
      "label_i18n": {
        "en": "Target Frequency",
        "tr": "Target Frequency",
        "de": "Target Frequency",
        "fr": "Target Frequency",
        "es": "Target Frequency",
        "ar": "Target Frequency"
      }
    }
  ],
  "formulas": {
    "mu": "materialDensity * Math.PI * (stringDiameter / 2000) ** 2",
    "tension": "4 * scaleLength ** 2 * targetFrequency ** 2 * mu"
  },

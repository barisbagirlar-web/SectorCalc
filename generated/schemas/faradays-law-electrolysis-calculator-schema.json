{
  "toolName": "faradays-law-electrolysis-calculator",
  "inputs": [
    {
      "id": "current",
      "label": "Current (I)",
      "type": "number",
      "unit": "A",
      "default": 1,
      "businessContext": "Elektrik akımı (amper)"
    },
    {
      "id": "time",
      "label": "Time (t)",
      "type": "number",
      "unit": "s",
      "default": 3600,
      "businessContext": "Elektroliz süresi (saniye)"
    },
    {
      "id": "molarMass",
      "label": "Molar Mass (M)",
      "type": "number",
      "unit": "g/mol",
      "default": 63.5,
      "businessContext": "Maddenin molar kütlesi (ör: Cu: 63.5 g/mol)"
    },
    {
      "id": "electrons",
      "label": "Electrons Transferred (z)",
      "type": "number",
      "unit": "",
      "default": 2,
      "businessContext": "Reaksiyonda aktarılan elektron sayısı"
    },
    {
      "id": "efficiency",
      "label": "Current Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Akım verimi (Faradayik verim, % olarak)"
    }
  ],
  "formulas": {
    "charge": "current * time",
    "moles": "(current * time * (efficiency / 100)) / (96485 * electrons)",
    "mass": "((current * time * (efficiency / 100)) / (96485 * electrons)) * molarMass"
  },
  "outputs": {
    "primary": "mass",
    "breakdown": [
      "charge",
      "moles"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

      }
    },
    {
      "id": "jointEfficiency",
      "label": "Joint Efficiency",
      "type": "number",
      "unit": "unit",
      "default": 0.85,
      "businessContext": "Weld joint efficiency factor per ASME UW-12",
      "label_i18n": {
        "en": "Joint Efficiency",
        "tr": "Birleştirme Verimi",
        "de": "Joint Efficiency",
        "fr": "Joint Efficiency",
        "es": "Joint Efficiency",
        "ar": "Joint Efficiency"
      },
      "businessContext_i18n": {
        "en": "Weld joint efficiency factor per ASME UW-12",
        "tr": "Kaynak bağlantı verimlilik faktörü, ASME UW-12'ye göre"
      }
    },
    {
      "id": "corrosionAllowance",
      "label": "Corrosion Allowance",
      "type": "number",
      "unit": "mm",
      "default": 3,
      "businessContext": "Corrosion allowance added to wall thickness",
      "label_i18n": {
        "en": "Corrosion Allowance",
        "tr": "Korozyon Payı",
        "de": "Corrosion Allowance",
        "fr": "Corrosion Allowance",
        "es": "Corrosion Allowance",
        "ar": "Corrosion Allowance"
      },
      "businessContext_i18n": {
        "en": "Corrosion allowance added to wall thickness",
        "tr": "Duvar kalınlığına eklenen korozyon payı"
      }
    }
  ],
  "formulas": {
    "requiredThickness": "((pressure * (diameter / 2)) / (allowableStress * jointEfficiency - 0.6 * pressure)) + corrosionAllowance",
    "hoopThickness": "((pressure * (diameter / 2)) / (allowableStress * jointEfficiency - 0.6 * pressure)) + corrosionAllowance",
    "longitudinalThickness": "((pressure * (diameter / 2)) / (2 * allowableStress * jointEfficiency + 0.4 * pressure)) + corrosionAllowance"
  },
  "outputs": {
    "primary": "requiredThickness",
    "breakdown": [
      "hoopThickness",
      "longitudinalThickness"
    ],

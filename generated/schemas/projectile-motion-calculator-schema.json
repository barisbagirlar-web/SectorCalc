{
  "toolName": "projectile-motion-calculator",
  "inputs": [
    {
      "id": "initialVelocity",
      "label": "Initial Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 10,
      "businessContext": "Muzzle velocity of projectile"
    },
    {
      "id": "launchAngle",
      "label": "Launch Angle",
      "type": "number",
      "unit": "degrees",
      "default": 45,
      "businessContext": "Launch angle relative to horizontal"
    },
    {
      "id": "initialHeight",
      "label": "Initial Height",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Initial height from ground"
    },
    {
      "id": "gravity",
      "label": "Gravity",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Acceleration due to gravity (typically 9.81 m/s²)"
    }
  ],
  "formulas": {
    "timeOfFlight": "(initialVelocity * Math.sin(launchAngle * Math.PI / 180) + Math.sqrt(Math.pow(initialVelocity * Math.sin(launchAngle * Math.PI / 180), 2) + 2 * gravity * initialHeight)) / gravity",
    "range": "initialVelocity * Math.cos(launchAngle * Math.PI / 180) * ((initialVelocity * Math.sin(launchAngle * Math.PI / 180) + Math.sqrt(Math.pow(initialVelocity * Math.sin(launchAngle * Math.PI / 180), 2) + 2 * gravity * initialHeight)) / gravity)",
    "maxHeight": "initialHeight + Math.pow(initialVelocity * Math.sin(launchAngle * Math.PI / 180), 2) / (2 * gravity)"
  },
  "outputs": {
    "primary": "range",
    "breakdown": [
      "maxHeight",
      "timeOfFlight"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

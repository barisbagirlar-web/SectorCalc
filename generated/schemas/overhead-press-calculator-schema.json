    {
      "id": "pressure",
      "label": "System Pressure",
      "type": "number",
      "unit": "bar",
      "default": 200,
      "businessContext": "Hidrolik sistem basıncı",
      "label_i18n": {
        "en": "System Pressure",
        "tr": "System Pressure",
        "de": "System Pressure",
        "fr": "System Pressure",
        "es": "System Pressure",
        "ar": "System Pressure"
      }
    },
    {
      "id": "efficiency",
      "label": "Mechanical Efficiency",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Mekanik verim (sürtünme kayıpları vb.)",
      "label_i18n": {
        "en": "Mechanical Efficiency",
        "tr": "Mechanical Efficiency",
        "de": "Mechanical Efficiency",
        "fr": "Mechanical Efficiency",
        "es": "Mechanical Efficiency",
        "ar": "Mechanical Efficiency"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Emniyet katsayısı (aşırı yüklemeye karşı)",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "cylinderArea_m2": "Math.PI * Math.pow(boreDiameter/1000, 2) / 4",
    "theoreticalForce_kN": "pressure * 100 * cylinderArea_m2",
    "actualForce_kN": "theoreticalForce_kN * (efficiency / 100)",
    "safeWorkingForce_kN": "actualForce_kN / safetyFactor"
  },
  "outputs": {
    "primary": "safeWorkingForce_kN",
    "breakdown": [
      "cylinderArea_m2",
      "theoreticalForce_kN",
      "actualForce_kN"
    ]
  },

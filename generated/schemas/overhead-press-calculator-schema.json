{
  "toolName": "overhead-press-calculator",
  "inputs": [
    {
      "id": "boreDiameter",
      "label": "Piston Diameter",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Hidrolik silindir piston çapı"
    },
    {
      "id": "pressure",
      "label": "System Pressure",
      "type": "number",
      "unit": "bar",
      "default": 200,
      "businessContext": "Hidrolik sistem basıncı"
    },
    {
      "id": "efficiency",
      "label": "Mechanical Efficiency",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Mekanik verim (sürtünme kayıpları vb.)"
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "",
      "default": 1.5,
      "businessContext": "Emniyet katsayısı (aşırı yüklemeye karşı)"
    }
  ],
  "formulas": {
    "cylinderArea_m2": "Math.PI * Math.pow(boreDiameter/1000, 2) / 4",
    "theoreticalForce_kN": "pressure * 100 * cylinderArea_m2",
    "actualForce_kN": "theoreticalForce_kN * (efficiency / 100)",
    "safeWorkingForce_kN": "actualForce_kN / safetyFactor"
  },
  "outputs": {
    "primary": "safeWorkingForce_kN",
    "breakdown": [
      "cylinderArea_m2",
      "theoreticalForce_kN",
      "actualForce_kN"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false
}
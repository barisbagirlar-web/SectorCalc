{
  "toolName": "overhead-press-calculator",
  "inputs": [
    {
      "id": "weightLifted",
      "label": "Weight Lifted",
      "type": "number",
      "unit": "kg",
      "default": 50,
      "businessContext": "The amount of weight lifted in the overhead press exercise."
    },
    {
      "id": "repetitions",
      "label": "Repetitions",
      "type": "number",
      "unit": "rep",
      "default": 10,
      "businessContext": "Number of repetitions performed."
    },
    {
      "id": "sets",
      "label": "Sets",
      "type": "number",
      "unit": "set",
      "default": 3,
      "businessContext": "Number of sets performed."
    },
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 80,
      "businessContext": "Lifter's body weight to compute relative strength."
    }
  ],
  "formulas": {
    "estimatedOneRepMax": "weightLifted * (1 + repetitions / 30)",
    "totalVolume": "weightLifted * repetitions * sets",
    "relativeStrength": "weightLifted / bodyWeight"
  },
  "outputs": {
    "primary": {
      "id": "estimatedOneRepMax",
      "label": "Estimated 1RM",
      "unit": "kg"
    },
    "breakdown": [
      {
        "id": "totalVolume",
        "label": "Total Volume",
        "unit": "kg"
      },
      {
        "id": "relativeStrength",
        "label": "Relative Strength",
        "unit": "kg/kg"
      }
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

      },
      "businessContext_i18n": {
        "en": "Temperature of fuel at measurement point for density correction.",
        "tr": "Yoğunluk düzeltmesi için ölçüm noktasındaki yakıt sıcaklığı.",
        "de": "Temperatur des Kraftstoffs am Messpunkt für die Dichtekorrektur."
      }
    },
    {
      "id": "fuelDensityRef",
      "label": "Reference Fuel Density",
      "type": "number",
      "unit": "kg/L",
      "default": 0.84,
      "businessContext": "Fuel density at reference temperature (e.g., 15°C).",
      "label_i18n": {
        "en": "Reference Fuel Density",
        "tr": "Referans Yakıt Yoğunluğu",

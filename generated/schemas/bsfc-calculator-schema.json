  "inputs": [
    {
      "id": "fuelVolumeFlow",
      "label": "Fuel Volume Flow",
      "type": "number",
      "unit": "L/h",
      "default": 0,
      "businessContext": "Volumetric fuel flow rate measured in liters per hour.",
      "label_i18n": {
        "en": "Fuel Volume Flow",
        "tr": "Yakıt Hacimsel Akışı",

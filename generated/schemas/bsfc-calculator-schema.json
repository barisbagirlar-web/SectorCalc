      },
      "businessContext_i18n": {
        "en": "Fuel density at reference temperature (e.g., 15°C).",
        "tr": "Referans sıcaklıkta (ör. 15°C) yakıt yoğunluğu.",
        "de": "Kraftstoffdichte bei Referenztemperatur (z. B. 15 °C)."
      }
    },
    {
      "id": "power",
      "label": "Brake Power",
      "type": "number",
      "unit": "kW",
      "default": 0,
      "businessContext": "Engine brake power output in kilowatts.",
      "label_i18n": {
        "en": "Brake Power",
        "tr": "Fren Gücü",
        "de": "Bremsleistung",
        "fr": "Brake Power",
        "es": "Brake Power",
        "ar": "Brake Power"
      },
      "businessContext_i18n": {
        "en": "Engine brake power output in kilowatts.",
        "tr": "Kilovat cinsinden motor fren gücü çıkışı.",
        "de": "Motorbremsleistung in Kilowatt."
      }
    },
    {
      "id": "thermalExpansionCoeff",
      "label": "Fuel Thermal Expansion Coefficient",
      "type": "number",
      "unit": "1/°C",
      "default": 0.00095,
      "businessContext": "Coefficient of thermal expansion for fuel (typically 0.00095/°C for diesel).",
      "label_i18n": {
        "en": "Fuel Thermal Expansion Coefficient",
        "tr": "Yakıt Termal Genleşme Katsayısı",
        "de": "Kraftstoff-Wärmeausdehnungskoeffizient",
        "fr": "Fuel Thermal Expansion Coefficient",
        "es": "Fuel Thermal Expansion Coefficient",
        "ar": "Fuel Thermal Expansion Coefficient"
      },
      "businessContext_i18n": {
        "en": "Coefficient of thermal expansion for fuel (typically 0.00095/°C for diesel).",
        "tr": "Yakıt için termal genleşme katsayısı (dizel için tipik olarak 0,00095/°C).",
        "de": "Wärmeausdehnungskoeffizient für Kraftstoff (typischerweise 0,00095/°C für Diesel)."
      }
    }
  ],
  "formulas": {
    "densityCorrected": "fuelDensityRef / (1 + thermalExpansionCoeff * (fuelTemperature - 15))",
    "massFlow": "fuelVolumeFlow * densityCorrected",
    "bsfc": "(massFlow * 1000) / power",
    "bsfc_lb_hph": "bsfc * 0.001644"
  },
  "outputs": {
    "primary": "bsfc",
    "breakdown": [
      "densityCorrected",
      "massFlow",
      "bsfc_lb_hph"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bsfc_lb_hph",
    "unit": "L/h"
  },

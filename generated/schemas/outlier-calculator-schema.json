        "ar": "IQR Multiplier"
      }
    }
  ],
  "formulas": {
    "iqr": "q3 - q1",
    "lowerBound": "q1 - multiplier * (q3 - q1)",
    "upperBound": "q3 + multiplier * (q3 - q1)",
    "outlierStatus": "(value < (q1 - multiplier * (q3 - q1)) || value > (q3 + multiplier * (q3 - q1))) ? 'Yes' : 'No'"
  },
  "outputs": {
    "primary": "outlierStatus",
    "breakdown": [
      "iqr",
      "lowerBound",
      "upperBound"
    ]

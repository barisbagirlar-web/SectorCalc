  "formulas": {
    "totalCaffeine": "(volume / 100) * caffeinePer100ml",
    "totalSugar": "(volume / 100) * sugarPer100ml",
    "totalCalories": "(volume / 100) * caloriesPer100ml",
    "costPerCan": "pricePerPack / cansPerPack",
    "costPer100ml": "(pricePerPack / cansPerPack / volume) * 100"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [
      "totalCaffeine",
      "totalSugar",

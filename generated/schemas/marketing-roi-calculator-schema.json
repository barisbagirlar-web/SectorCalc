  "formulas": {
    "revenue": "numberOfLeads * (conversionRate / 100) * averageSaleRevenue",
    "netProfit": "numberOfLeads * (conversionRate / 100) * averageSaleRevenue - marketingCost",
    "roi": "((numberOfLeads * (conversionRate / 100) * averageSaleRevenue - marketingCost) / marketingCost) * 100"
  },

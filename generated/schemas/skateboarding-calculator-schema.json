  "formulas": {
    "deckArea": "deckLength * deckWidth",
    "wheelPerformance": "wheelDiameter * (100 - wheelHardness) / 100",
    "bearingSpeed": "bearingRating * 10",
    "truckStability": "truckWidth / deckWidth",
    "weightFactor": "riderWeight / 150",
    "styleMultiplier": "skateStyle === 1 ? 1.2 : (skateStyle === 2 ? 1.0 : 0.8)",
    "overallScore": "(deckArea * 0.2 + wheelPerformance * 0.3 + bearingSpeed * 0.25 + truckStability * 0.15 + weightFactor * 0.1) * styleMultiplier"
  },
  "outputs": {
    "primary": "overallScore",
    "breakdown": [
      "deckArea",
      "wheelPerformance",
      "bearingSpeed",
      "truckStability",
      "weightFactor",
      "styleMultiplier"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "overallScore",
    "unit": "in"
  },

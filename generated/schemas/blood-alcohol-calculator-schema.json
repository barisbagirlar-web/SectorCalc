      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of alcohol in the beverage",
      "label_i18n": {
        "en": "Alcohol by Volume",
        "tr": "Alcohol by Volume",
        "de": "Alcohol by Volume",

        "ar": "Body Weight"
      }
    },
    {
      "id": "gender",
      "label": "Gender (1=Male, 0=Female)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Biological sex: 1 for male, 0 for female",
      "label_i18n": {
        "en": "Gender (1=Male, 0=Female)",
        "tr": "Gender (1=Male, 0=Female)",
        "de": "Gender (1=Male, 0=Female)",
        "fr": "Gender (1=Male, 0=Female)",
        "es": "Gender (1=Male, 0=Female)",
        "ar": "Gender (1=Male, 0=Female)"
      }
    },
    {
      "id": "hoursSinceFirstDrink",
      "label": "Time Since First Drink",
      "type": "number",
      "unit": "hours",
      "default": 2,
      "businessContext": "Time elapsed since the first drink was consumed",
      "label_i18n": {
        "en": "Time Since First Drink",
        "tr": "Time Since First Drink",
        "de": "Time Since First Drink",
        "fr": "Time Since First Drink",
        "es": "Time Since First Drink",
        "ar": "Time Since First Drink"
      }
    }
  ],
  "formulas": {
    "alcoholGrams": "drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789",
    "widmarkFactorR": "gender === 1 ? 0.68 : 0.55",
    "bacBeforeElimination": "(drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789 / (bodyWeight * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100",
    "eliminationEffect": "0.015 * hoursSinceFirstDrink",
    "bacPercent": "(drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789 / (bodyWeight * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100 - 0.015 * hoursSinceFirstDrink",
    "bacPromille": "((drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789 / (bodyWeight * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100 - 0.015 * hoursSinceFirstDrink) * 10"
  },
  "outputs": {
    "primary": "bacPercent",
    "breakdown": [
      "alcoholGrams",
      "widmarkFactorR",
      "bacBeforeElimination",
      "eliminationEffect",
      "bacPromille"
    ]
  },
  "category": "Dönüşüm & Ölçüm",

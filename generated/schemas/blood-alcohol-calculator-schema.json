  ],
  "formulas": {
    "alcoholGrams": "drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789",
    "widmarkFactorR": "gender === 1 ? 0.68 : 0.55",
    "bacBeforeElimination": "(drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789 / (bodyWeight * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100",
    "eliminationEffect": "0.015 * hoursSinceFirstDrink",
    "bacPercent": "(drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789 / (bodyWeight * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100 - 0.015 * hoursSinceFirstDrink",
    "bacPromille": "((drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789 / (bodyWeight * 1000 * (gender === 1 ? 0.68 : 0.55))) * 100 - 0.015 * hoursSinceFirstDrink) * 10"
  },
  "outputs": {
    "primary": "bacPercent",
    "breakdown": [
      "alcoholGrams",
      "widmarkFactorR",
      "bacBeforeElimination",
      "eliminationEffect",
      "bacPromille"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

{
  "toolName": "steam-move-calculator",
  "inputs": [
    {
      "id": "massFlow",
      "label": "Steam Mass Flow Rate",
      "type": "number",
      "unit": "kg/h",
      "default": 1000,
      "businessContext": "The mass of steam flowing through the pipe per hour. Used to determine the required pipe size and velocity.",
      "label_i18n": {
        "en": "Steam Mass Flow Rate",
        "tr": "Steam Mass Flow Rate",
        "de": "Steam Mass Flow Rate",
        "fr": "Steam Mass Flow Rate",
        "es": "Steam Mass Flow Rate",
        "ar": "Steam Mass Flow Rate"
      }
    },
    {
      "id": "diameter",
      "label": "Pipe Inner Diameter",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "The internal diameter of the steam pipe. Critical for cross-sectional area calculation.",
      "label_i18n": {
        "en": "Pipe Inner Diameter",
        "tr": "Pipe Inner Diameter",
        "de": "Pipe Inner Diameter",
        "fr": "Pipe Inner Diameter",
        "es": "Pipe Inner Diameter",
        "ar": "Pipe Inner Diameter"
      }
    },
    {
      "id": "pressure",
      "label": "Steam Pressure (absolute)",
      "type": "number",
      "unit": "bar",
      "default": 10,
      "businessContext": "Absolute pressure of the steam. Required to calculate steam density via ideal gas law.",
      "label_i18n": {
        "en": "Steam Pressure (absolute)",
        "tr": "Steam Pressure (absolute)",
        "de": "Steam Pressure (absolute)",
        "fr": "Steam Pressure (absolute)",
        "es": "Steam Pressure (absolute)",
        "ar": "Steam Pressure (absolute)"
      }
    },
    {
      "id": "temperature",
      "label": "Steam Temperature",
      "type": "number",
      "unit": "°C",
      "default": 200,
      "businessContext": "Temperature of the steam in degrees Celsius. Used with pressure to compute density.",
      "label_i18n": {
        "en": "Steam Temperature",
        "tr": "Steam Temperature",
        "de": "Steam Temperature",
        "fr": "Steam Temperature",
        "es": "Steam Temperature",
        "ar": "Steam Temperature"
      }
    }
  ],
  "formulas": {
    "steamDensity": "(pressure * 1e5) / (461.5 * (temperature + 273.15))",
    "volFlow": "(massFlow / 3600) / steamDensity"
  },
  "outputs": {
    "primary": "volFlow",
    "breakdown": [
      "steamDensity",
      "pipeArea",
      "volFlow"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "velocity"
  },

{
  "toolName": "margin-calculator",
  "inputs": [
    {
      "id": "cost",
      "label": "Birim Maliyet",
      "type": "number",
      "unit": "TRY",
      "default": 0,
      "businessContext": "Ürün veya hizmet başına maliyet"
    },
    {
      "id": "sellingPrice",
      "label": "Liste Satış Fiyatı",
      "type": "number",
      "unit": "TRY",
      "default": 0,
      "businessContext": "İndirim öncesi satış fiyatı"
    },
    {
      "id": "quantity",
      "label": "Miktar",
      "type": "number",
      "unit": "Adet",
      "default": 1,
      "businessContext": "Satılan ürün adedi"
    },
    {
      "id": "discount",
      "label": "İndirim Oranı",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Satış fiyatı üzerinden yüzde indirim"
    }
  ],
  "formulas": {
    "netPrice": "sellingPrice * (1 - discount / 100)",
    "profitAmount": "(netPrice - cost) * quantity",
    "totalRevenue": "netPrice * quantity",
    "totalCost": "cost * quantity",
    "profitMargin": "((netPrice - cost) / netPrice) * 100"
  },
  "outputs": {
    "primary": "profitMargin",
    "breakdown": [
      "profitAmount",
      "totalRevenue",
      "totalCost"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

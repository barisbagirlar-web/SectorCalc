      }
    },
    {
      "id": "resistivity",
      "label": "Resistivity",
      "type": "number",
      "unit": "Ω·m",
      "default": 0.00000145,
      "businessContext": "Electrical resistivity of the wire material (e.g., Kanthal A1: 1.45×10⁻⁶ Ω·m).",
      "label_i18n": {
        "en": "Resistivity",
        "tr": "Resistivity",
        "de": "Resistivity",
        "fr": "Resistivity",
        "es": "Resistivity",
        "ar": "Resistivity"
      }
    },
    {
      "id": "voltage",
      "label": "Applied Voltage",
      "type": "number",
      "unit": "V",
      "default": 4.2,
      "businessContext": "Output voltage of the battery or regulated mod.",
      "label_i18n": {
        "en": "Applied Voltage",
        "tr": "Applied Voltage",
        "de": "Applied Voltage",
        "fr": "Applied Voltage",
        "es": "Applied Voltage",
        "ar": "Applied Voltage"
      }
    }
  ],
  "formulas": {
    "resistance": "resistivity * ((numberOfWraps * Math.PI * (innerDiameter + wireDiameter) + 2 * legLength) / 1000) / (Math.PI * Math.pow(wireDiameter / 2, 2) * 0.000001)",
    "current": "voltage / resistance",
    "power": "voltage * voltage / resistance"
  },
  "outputs": {
    "primary": "resistance",
    "breakdown": [
      "current",
      "power"
    ]
  },

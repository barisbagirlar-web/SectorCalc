      }
    },
    {
      "id": "baseVolumeML",
      "label": "Base Liquid per Serving",
      "type": "number",
      "unit": "ml",
      "default": 200,
      "businessContext": "Volume of liquid base (milk, juice, etc.) per smoothie in milliliters",
      "label_i18n": {
        "en": "Base Liquid per Serving",
        "tr": "Base Liquid per Serving",
        "de": "Base Liquid per Serving",
        "fr": "Base Liquid per Serving",
        "es": "Base Liquid per Serving",
        "ar": "Base Liquid per Serving"
      }
    },
    {
      "id": "fruitGrams",
      "label": "Fruit per Serving",
      "type": "number",
      "unit": "g",
      "default": 150,
      "businessContext": "Weight of fruit per smoothie in grams",
      "label_i18n": {
        "en": "Fruit per Serving",
        "tr": "Fruit per Serving",
        "de": "Fruit per Serving",
        "fr": "Fruit per Serving",
        "es": "Fruit per Serving",
        "ar": "Fruit per Serving"
      }
    },
    {
      "id": "iceGrams",
      "label": "Ice per Serving",
      "type": "number",
      "unit": "g",
      "default": 80,
      "businessContext": "Weight of ice per smoothie in grams",
      "label_i18n": {
        "en": "Ice per Serving",
        "tr": "Ice per Serving",
        "de": "Ice per Serving",
        "fr": "Ice per Serving",
        "es": "Ice per Serving",
        "ar": "Ice per Serving"
      }
    },
    {
      "id": "baseCostPerLiter",
      "label": "Base Liquid Cost per Liter",
      "type": "number",
      "unit": "USD/L",
      "default": 1.5,
      "businessContext": "Cost of one liter of liquid base in USD",
      "label_i18n": {
        "en": "Base Liquid Cost per Liter",
        "tr": "Base Liquid Cost per Liter",
        "de": "Base Liquid Cost per Liter",
        "fr": "Base Liquid Cost per Liter",
        "es": "Base Liquid Cost per Liter",
        "ar": "Base Liquid Cost per Liter"
      }
    },
    {
      "id": "fruitCostPerKg",
      "label": "Fruit Cost per kg",
      "type": "number",
      "unit": "USD/kg",
      "default": 4,
      "businessContext": "Cost of one kilogram of fruit in USD",
      "label_i18n": {
        "en": "Fruit Cost per kg",
        "tr": "Fruit Cost per kg",
        "de": "Fruit Cost per kg",
        "fr": "Fruit Cost per kg",
        "es": "Fruit Cost per kg",
        "ar": "Fruit Cost per kg"
      }
    },
    {
      "id": "iceCostPerKg",
      "label": "Ice Cost per kg",
      "type": "number",
      "unit": "USD/kg",
      "default": 0.1,
      "businessContext": "Cost of one kilogram of ice in USD",
      "label_i18n": {
        "en": "Ice Cost per kg",
        "tr": "Ice Cost per kg",
        "de": "Ice Cost per kg",
        "fr": "Ice Cost per kg",
        "es": "Ice Cost per kg",
        "ar": "Ice Cost per kg"
      }
    }
  ],
  "formulas": {
    "totalVolumeML": "baseVolumeML * servings",
    "baseCost": "(baseVolumeML / 1000) * baseCostPerLiter * servings",
    "fruitCost": "(fruitGrams / 1000) * fruitCostPerKg * servings",
    "iceCost": "(iceGrams / 1000) * iceCostPerKg * servings",
    "totalCost": "baseCost + fruitCost + iceCost",
    "costPerSmoothie": "totalCost / servings"
  },
  "outputs": {
    "primary": "costPerSmoothie",
    "breakdown": [
      "totalVolumeML",
      "baseCost",
      "fruitCost",
      "iceCost",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerSmoothie"
  },

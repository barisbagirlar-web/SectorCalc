{
  "toolName": "smoothie-calculator",
  "inputs": [
    {
      "id": "servings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "Number of smoothie servings to prepare",
      "label_i18n": {
        "en": "Number of Servings",
        "tr": "Number of Servings",
        "de": "Number of Servings",

{
  "toolName": "wendler-531-calculator",
  "inputs": [
    {
      "id": "oneRepMax",
      "label": "1RM (kg)",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Maksimum tek tekrar kaldırabileceğiniz ağırlık"
    },
    {
      "id": "trainingMaxPercent",
      "label": "Training Max Yüzdesi (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Genellikle %90 kullanılır"
    },
    {
      "id": "week",
      "label": "Hafta (1-4)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1: 65/75/85, 2: 70/80/90, 3: 75/85/95, 4: 40/50/60"
    },
    {
      "id": "set1Percent",
      "label": "1. Set Yüzdesi (%)",
      "type": "number",
      "unit": "%",
      "default": 65,
      "businessContext": "İlk çalışma setinin training max'e göre yüzdesi"
    },
    {
      "id": "set2Percent",
      "label": "2. Set Yüzdesi (%)",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "İkinci çalışma setinin yüzdesi"
    },
    {
      "id": "set3Percent",
      "label": "3. Set Yüzdesi (%)",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Son çalışma setinin yüzdesi"
    }
  ],
  "formulas": {
    "trainingMax": "oneRepMax * trainingMaxPercent / 100",
    "set1Weight": "trainingMax * set1Percent / 100",
    "set2Weight": "trainingMax * set2Percent / 100",
    "set3Weight": "trainingMax * set3Percent / 100"
  },
  "outputs": {
    "primary": "set3Weight",
    "breakdown": [
      "trainingMax",
      "set1Weight",
      "set2Weight"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

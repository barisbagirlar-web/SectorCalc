{
  "toolName": "usd-loan-cost-calculator",
  "catalogCategory": "finance-business",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Credit and Debt",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "amount",
      "label": "Loan Amount (USD)",
      "type": "number",
      "unit": "USD",
      "default": 50000,
      "min": 0,
      "businessContext": "Loan principal in USD."
    },
    {
      "id": "interest",
      "label": "Annual Interest (%)",
      "type": "number",
      "unit": "%",
      "default": 8,
      "min": 0,
      "businessContext": "Loan interest rate."
    },
    {
      "id": "vade",
      "label": "Term (Months)",
      "type": "number",
      "unit": "months",
      "default": 36,
      "min": 1,
      "businessContext": "Loan term."
    },
    {
      "id": "kurBeklentisi",
      "label": "FX Expected Change (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "min": 0,
      "businessContext": "Expected annual FX rate increase."
    },
    {
      "id": "mevcutKur",
      "label": "Current FX Rate (USD/USD)",
      "type": "number",
      "unit": "USD",
      "default": 30,
      "min": 0,
      "businessContext": "Current USD/TRY rate."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "usdInstallment": "interest === 0 ? amount / Math.max(1, vade) : amount * ((interest / 1200) * Math.pow(1 + interest / 1200, vade)) / (Math.pow(1 + interest / 1200, vade) - 1)",
    "result": "(interest === 0 ? amount / Math.max(1, vade) : amount * ((interest / 1200) * Math.pow(1 + interest / 1200, vade)) / (Math.pow(1 + interest / 1200, vade) - 1)) * mevcutKur * Math.pow(1 + kurBeklentisi / 100, vade / 12)"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "Estimated TRY Monthly Installment"
    },
    "breakdownUnits": {
      "result": "USD"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Compare multiple loan offers before committing.",
      "Consider total cost including fees."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate estimated TRY cost of a USD loan with FX risk.",
      "long": "Calculate estimated TRY cost of a USD loan with FX risk."
    }
  },
  "sectorSlug": "ecommerce"
}

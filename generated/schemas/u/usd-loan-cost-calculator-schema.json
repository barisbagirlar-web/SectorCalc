  "formulas": {
    "usdTaksit": "faiz === 0 ? tutar / Math.max(1, vade) : tutar * ((faiz / 1200) * Math.pow(1 + faiz / 1200, vade)) / (Math.pow(1 + faiz / 1200, vade) - 1)",
    "sonuc": "(faiz === 0 ? tutar / Math.max(1, vade) : tutar * ((faiz / 1200) * Math.pow(1 + faiz / 1200, vade)) / (Math.pow(1 + faiz / 1200, vade) - 1)) * mevcutKur * Math.pow(1 + kurBeklentisi / 100, vade / 12)"
  },

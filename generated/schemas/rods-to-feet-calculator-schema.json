{
  "toolName": "rods-to-feet-calculator",
  "inputs": [
    {
      "id": "rods",
      "label": "Number of Rods",
      "type": "number",
      "unit": "rods",
      "default": 1,
      "businessContext": "The quantity to convert from rods to feet.",
      "label_i18n": {
        "en": "Number of Rods",
        "tr": "Number of Rods",
        "de": "Number of Rods",
        "fr": "Number of Rods",
        "es": "Number of Rods",
        "ar": "Number of Rods"
      }
    },
    {
      "id": "feetPerRod",
      "label": "Feet per Rod",
      "type": "number",
      "unit": "ft/rod",
      "default": 16.5,
      "businessContext": "Conversion factor. Standard US survey rod is 16.5 feet. Adjust if using a different definition.",
      "label_i18n": {
        "en": "Feet per Rod",
        "tr": "Feet per Rod",
        "de": "Feet per Rod",
        "fr": "Feet per Rod",
        "es": "Feet per Rod",
        "ar": "Feet per Rod"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the output.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional percentage to add for safety margin in engineering calculations.",
      "label_i18n": {
        "en": "Safety Factor (%)",
        "tr": "Safety Factor (%)",
        "de": "Safety Factor (%)",
        "fr": "Safety Factor (%)",
        "es": "Safety Factor (%)",
        "ar": "Safety Factor (%)"
      }
    },
    {
      "id": "tolerance",
      "label": "Tolerance (± ft)",
      "type": "number",
      "unit": "ft",
      "default": 0,
      "businessContext": "Tolerance band for the converted length.",
      "label_i18n": {
        "en": "Tolerance (± ft)",
        "tr": "Tolerance (± ft)",
        "de": "Tolerance (± ft)",
        "fr": "Tolerance (± ft)",
        "es": "Tolerance (± ft)",
        "ar": "Tolerance (± ft)"
      }
    }
  ],
  "formulas": {
    "baseFeet": "rods * feetPerRod",
    "safetyFeet": "baseFeet * (1 + safetyFactor / 100)",
    "totalFeet": "Math.round(safetyFeet * 10 ** decimalPlaces) / 10 ** decimalPlaces",
    "_rods__rods____feetPerRod__ft_rod____bas": "{rods} rods × {feetPerRod} ft/rod = {baseFeet} ft",
    "_safetyFeet__ft": "{safetyFeet} ft",
    "_totalFeet__ft": "{totalFeet} ft",
    "__tolerance__ft": "±{tolerance} ft"
  },
  "outputs": {
    "primary": "totalFeet",
    "breakdown": [
      "Base conversion: {rods} rods × {feetPerRod} ft/rod = {baseFeet} ft",
      "After safety margin {safetyFactor}%: {safetyFeet} ft",
      "Rounded to {decimalPlaces} decimals: {totalFeet} ft",
      "Tolerance: ±{tolerance} ft"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "hse-ergonomics"
}

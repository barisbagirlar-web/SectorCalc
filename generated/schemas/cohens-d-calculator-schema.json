  "formulas": {
    "pooledSD": "Math.sqrt(((n1-1)*sd1*sd1 + (n2-1)*sd2*sd2) / (n1+n2-2))",
    "cohensD": "(mean1 - mean2) / pooledSD",
    "effectSize": "Math.abs(cohensD)",
    "interpretation": "cohensD >= 0.8 ? 'Large' : (cohensD >= 0.5 ? 'Medium' : (cohensD >= 0.2 ? 'Small' : 'Negligible'))"
  },
  "outputs": {
    "primary": "cohensD",
    "breakdown": [
      "pooledSD",
      "effectSize",
      "interpretation"
    ]
  },

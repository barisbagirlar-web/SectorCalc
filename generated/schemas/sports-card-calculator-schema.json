{
  "toolName": "sports-card-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Purchase Price",
      "type": "number",
      "unit": "€",
      "default": 100,
      "businessContext": "The price you paid to acquire the sports card.",
      "label_i18n": {
        "en": "Purchase Price",
        "tr": "Purchase Price",
        "de": "Purchase Price",
        "fr": "Purchase Price",
        "es": "Purchase Price",
        "ar": "Purchase Price"
      }
    },
    {
      "id": "salePrice",
      "label": "Sale Price",
      "type": "number",
      "unit": "€",
      "default": 150,
      "businessContext": "The final selling price of the sports card.",
      "label_i18n": {
        "en": "Sale Price",
        "tr": "Sale Price",
        "de": "Sale Price",
        "fr": "Sale Price",
        "es": "Sale Price",
        "ar": "Sale Price"
      }
    },
    {
      "id": "gradingCost",
      "label": "Grading Cost",
      "type": "number",
      "unit": "€",
      "default": 20,
      "businessContext": "Cost of professional grading service for the card.",
      "label_i18n": {
        "en": "Grading Cost",
        "tr": "Grading Cost",
        "de": "Grading Cost",
        "fr": "Grading Cost",
        "es": "Grading Cost",
        "ar": "Grading Cost"
      }
    },
    {
      "id": "shippingCost",
      "label": "Shipping Cost",
      "type": "number",
      "unit": "€",
      "default": 10,
      "businessContext": "Total shipping and handling costs for the transaction.",
      "label_i18n": {
        "en": "Shipping Cost",
        "tr": "Shipping Cost",
        "de": "Shipping Cost",
        "fr": "Shipping Cost",
        "es": "Shipping Cost",
        "ar": "Shipping Cost"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Applicable sales tax rate as a percentage of the sale price.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "totalInvestment": "purchasePrice + gradingCost + shippingCost",
    "totalRevenue": "salePrice",
    "grossProfit": "salePrice - purchasePrice - gradingCost - shippingCost",
    "taxAmount": "salePrice * taxRate / 100",
    "netProfit": "grossProfit - taxAmount",
    "profitMargin": "salePrice !== 0 ? (netProfit / salePrice) * 100 : 0",
    "roi": "totalInvestment !== 0 ? (netProfit / totalInvestment) * 100 : 0"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "totalInvestment",
      "totalRevenue",
      "grossProfit",
      "taxAmount",
      "netProfit",
      "profitMargin",
      "roi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roi"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",

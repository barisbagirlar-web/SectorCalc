{
  "toolName": "drying-calculator",
  "inputs": [
    {
      "id": "initialMoisture",
      "label": "Initial Moisture Content (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Moisture percentage of material before drying",
      "label_i18n": {
        "en": "Initial Moisture Content (%)",
        "tr": "Başlangıç Nem İçeriği (%)",
        "de": "Anfänglicher Feuchtigkeitsgehalt (%)",
        "fr": "Initial Moisture Content (%)",
        "es": "Initial Moisture Content (%)",
        "ar": "Initial Moisture Content (%)"
      },
      "businessContext_i18n": {
        "en": "Moisture percentage of material before drying",
        "tr": "Kurutma öncesi malzemenin nem yüzdesi",
        "de": "Feuchtigkeitsprozentsatz des Materials vor dem Trocknen"
      }
    },
    {
      "id": "finalMoisture",
      "label": "Final Moisture Content (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Target moisture percentage after drying",
      "label_i18n": {
        "en": "Final Moisture Content (%)",
        "tr": "Son Nem İçeriği (%)",
        "de": "Endgültiger Feuchtigkeitsgehalt (%)",
        "fr": "Final Moisture Content (%)",
        "es": "Final Moisture Content (%)",
        "ar": "Final Moisture Content (%)"
      },
      "businessContext_i18n": {
        "en": "Target moisture percentage after drying",
        "tr": "Kurutma sonrası hedef nem yüzdesi",
        "de": "Ziel-Feuchtigkeitsprozentsatz nach dem Trocknen"
      }
    },
    {
      "id": "materialMass",
      "label": "Material Mass (kg)",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Total mass of wet material to be dried",
      "label_i18n": {
        "en": "Material Mass (kg)",
        "tr": "Malzeme Kütlesi (kg)",
        "de": "Materialmasse (kg)",
        "fr": "Material Mass (kg)",
        "es": "Material Mass (kg)",
        "ar": "Material Mass (kg)"
      },
      "businessContext_i18n": {
        "en": "Total mass of wet material to be dried",
        "tr": "Kurutulacak ıslak malzemenin toplam kütlesi",
        "de": "Gesamtmasse des zu trocknenden nassen Materials"
      }
    },
    {
      "id": "dryingTime",
      "label": "Drying Time (hours)",
      "type": "number",
      "unit": "h",
      "default": 8,
      "businessContext": "Total time available for drying process",
      "label_i18n": {
        "en": "Drying Time (hours)",
        "tr": "Kurutma Süresi (saat)",
        "de": "Trocknungszeit (Stunden)",
        "fr": "Drying Time (hours)",
        "es": "Drying Time (hours)",
        "ar": "Drying Time (hours)"
      },
      "businessContext_i18n": {
        "en": "Total time available for drying process",
        "tr": "Kurutma işlemi için mevcut toplam süre",
        "de": "Gesamtzeit, die für den Trocknungsprozess zur Verfügung steht"
      }
    },
    {
      "id": "energyConsumption",
      "label": "Energy Consumption (kWh/kg water)",
      "type": "number",
      "unit": "kWh/kg",
      "default": 1.5,
      "businessContext": "Energy required to remove 1 kg of water",
      "label_i18n": {
        "en": "Energy Consumption (kWh/kg water)",
        "tr": "Enerji Tüketimi (kWh/kg su)",
        "de": "Energieverbrauch (kWh/kg Wasser)",
        "fr": "Energy Consumption (kWh/kg water)",
        "es": "Energy Consumption (kWh/kg water)",
        "ar": "Energy Consumption (kWh/kg water)"
      },
      "businessContext_i18n": {
        "en": "Energy required to remove 1 kg of water",
        "tr": "1 kg suyu uzaklaştırmak için gereken enerji",
        "de": "Energie, die benötigt wird, um 1 kg Wasser zu entfernen"
      }
    },
    {
      "id": "energyCost",
      "label": "Energy Cost ($/kWh)",
      "type": "number",
      "unit": "$/kWh",
      "default": 0.12,
      "businessContext": "Cost per unit of energy",
      "label_i18n": {
        "en": "Energy Cost ($/kWh)",
        "tr": "Enerji Maliyeti ($/kWh)",
        "de": "Energiekosten ($/kWh)",
        "fr": "Energy Cost ($/kWh)",
        "es": "Energy Cost ($/kWh)",
        "ar": "Energy Cost ($/kWh)"
      },
      "businessContext_i18n": {
        "en": "Cost per unit of energy",
        "tr": "Birim enerji başına maliyet",
        "de": "Kosten pro Energieeinheit"
      }
    }
  ],
  "formulas": {
    "waterToRemove": "materialMass * (initialMoisture - finalMoisture) / 100",
    "totalEnergy": "waterToRemove * energyConsumption",
    "totalCost": "totalEnergy * energyCost",
    "dryingRate": "waterToRemove / dryingTime"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "Water to Remove: {waterToRemove} kg",
      "Total Energy: {totalEnergy} kWh",
      "Total Cost: ${totalCost}",
      "Drying Rate: {dryingRate} kg/h"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dryingRate",
    "unit": "%",
    "breakdownUnits": {
      "Water to Remove: {waterToRemove} kg": "kg",
      "Total Energy: {totalEnergy} kWh": "kWh"
    }
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",

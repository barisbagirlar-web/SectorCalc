      }
    },
    {
      "id": "gender",
      "label": "Cinsiyet (0=Erkek, 1=Kız)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Bebeğin cinsiyeti: 0 erkek, 1 kız",
      "label_i18n": {
        "en": "Cinsiyet (0=Erkek, 1=Kız)",
        "tr": "Cinsiyet (0=Erkek, 1=Kız)",
        "de": "Cinsiyet (0=Erkek, 1=Kız)",
        "fr": "Cinsiyet (0=Erkek, 1=Kız)",
        "es": "Cinsiyet (0=Erkek, 1=Kız)",
        "ar": "Cinsiyet (0=Erkek, 1=Kız)"
      }
    }
  ],
  "formulas": {
    "weightPercentile": "Math.round(100 * (1/(1+Math.exp(-((currentWeight - (birthWeight + 0.6 * ageMonths))/0.5)))))",
    "lengthPercentile": "Math.round(100 * (1/(1+Math.exp(-((length - (45 + 2.5 * ageMonths))/2)))))",
    "weightForLengthPercentile": "Math.round(100 * (1/(1+Math.exp(-((currentWeight - (length/100 * 10))/1.2)))))"
  },
  "outputs": {
    "primary": "weightPercentile",
    "breakdown": [
      "lengthPercentile",
      "weightForLengthPercentile"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,

  "formulas": {
    "defectScore": "100 - defectRate",
    "deliveryScore": "onTimeDelivery",
    "productivityScore": "(productivity / targetProductivity) * 100",
    "safetyScore": "100 - (safetyIncidents * 10)",
    "honorScore": "(defectScore + deliveryScore + productivityScore + safetyScore) / 4"
  },
  "outputs": {
    "primary": "honorScore",
    "breakdown": [
      "defectScore",
      "deliveryScore",
      "productivityScore",
      "safetyScore"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

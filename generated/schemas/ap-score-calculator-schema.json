  "formulas": {
    "compositePercentage": "((multipleChoiceCorrect / multipleChoiceTotal) * 0.5 + (freeResponsePoints / freeResponseMaxPoints) * 0.5) * 100",
    "apScore": "compositePercentage >= 85 ? 5 : compositePercentage >= 70 ? 4 : compositePercentage >= 50 ? 3 : compositePercentage >= 30 ? 2 : 1"
  },

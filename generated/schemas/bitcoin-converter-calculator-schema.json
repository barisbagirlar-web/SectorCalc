{
  "toolName": "bitcoin-converter-calculator",
  "inputs": [
    {
      "id": "btcAmount",
      "label": "Bitcoin Amount",
      "type": "number",
      "unit": "BTC",
      "default": 0,
      "businessContext": "Enter the amount of Bitcoin to convert to USD. Set to 0 if converting USD to BTC.",
      "label_i18n": {
        "en": "Bitcoin Amount",
        "tr": "Bitcoin Amount",
        "de": "Bitcoin Amount",
        "fr": "Bitcoin Amount",
        "es": "Bitcoin Amount",
        "ar": "Bitcoin Amount"
      }
    },
    {
      "id": "usdAmount",
      "label": "USD Amount",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Enter the amount of USD to convert to Bitcoin. Set to 0 if converting BTC to USD.",
      "label_i18n": {
        "en": "USD Amount",
        "tr": "USD Amount",
        "de": "USD Amount",
        "fr": "USD Amount",
        "es": "USD Amount",
        "ar": "USD Amount"
      }
    },
    {
      "id": "btcPrice",
      "label": "BTC Market Price",
      "type": "number",
      "unit": "USD/BTC",
      "default": 30000,
      "businessContext": "Current market price of 1 Bitcoin in USD.",
      "label_i18n": {
        "en": "BTC Market Price",
        "tr": "BTC Market Price",
        "de": "BTC Market Price",
        "fr": "BTC Market Price",
        "es": "BTC Market Price",
        "ar": "BTC Market Price"
      }
    },
    {
      "id": "feePercent",
      "label": "Transaction Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "Percentage fee charged per transaction (e.g., 0.5 for 0.5%).",
      "label_i18n": {
        "en": "Transaction Fee (%)",
        "tr": "Transaction Fee (%)",
        "de": "Transaction Fee (%)",
        "fr": "Transaction Fee (%)",
        "es": "Transaction Fee (%)",
        "ar": "Transaction Fee (%)"
      }
    },
    {
      "id": "fixedFee",
      "label": "Fixed Fee (USD)",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Fixed fee in USD added per transaction.",
      "label_i18n": {
        "en": "Fixed Fee (USD)",
        "tr": "Fixed Fee (USD)",
        "de": "Fixed Fee (USD)",
        "fr": "Fixed Fee (USD)",
        "es": "Fixed Fee (USD)",
        "ar": "Fixed Fee (USD)"
      }
    }
  ],
  "formulas": {
    "convertedAmount": "(btcAmount !== 0) ? (btcAmount * btcPrice * (1 - feePercent/100) - fixedFee) : ((usdAmount + fixedFee) / (btcPrice * (1 - feePercent/100)))",
    "grossValue": "btcAmount * btcPrice",
    "totalFees": "(btcAmount !== 0) ? (btcAmount * btcPrice * (feePercent/100) + fixedFee) : ((usdAmount + fixedFee) * (feePercent/100) + fixedFee)"
  },
  "outputs": {
    "primary": "convertedAmount",
    "breakdown": [
      "grossValue",
      "totalFees"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalFees"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Birim & Dönüşüm",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "birim-donusum",
  "profession": "Mühendis",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

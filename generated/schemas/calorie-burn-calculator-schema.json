{
  "toolName": "calorie-burn-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight of the person performing the activity"
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Duration of the physical activity in minutes"
    },
    {
      "id": "met",
      "label": "MET",
      "type": "number",
      "unit": "MET",
      "default": 8,
      "businessContext": "Metabolic Equivalent of Task, representing activity intensity"
    }
  ],
  "formulas": {
    "caloriesBurned": "met * weight * (duration / 60)",
    "metMinutes": "met * duration",
    "durationHours": "duration / 60"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "metMinutes",
      "durationHours"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

{
  "toolName": "calorie-burn-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "User's height in centimeters"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years"
    },
    {
      "id": "gender",
      "label": "Gender (1=Male, 0=Female)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Gender: 1 for male, 0 for female"
    },
    {
      "id": "duration",
      "label": "Activity Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Duration of the exercise in minutes"
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 7,
      "businessContext": "Metabolic Equivalent of Task for the activity"
    }
  ],
  "formulas": {
    "activityCal": "met * 3.5 * weight / 200 * duration",
    "bmrKcalPerDay": "10 * weight + 6.25 * height - 5 * age + (gender * 166 - 161)"
  },
  "outputs": {
    "primary": {
      "label": "Activity Calories Burned",
      "formula": "activityCal",
      "unit": "kcal"
    },
    "breakdown": [
      {
        "label": "Activity Calories",
        "formula": "activityCal",
        "unit": "kcal"
      },
      {
        "label": "BMR (daily)",
        "formula": "bmrKcalPerDay",
        "unit": "kcal/day"
      }
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

{
  "toolName": "fsa-calculator",
  "inputs": [
    {
      "id": "currentFuelConsumption",
      "label": "Current Fuel Consumption",
      "type": "number",
      "unit": "L/100km",
      "default": 10,
      "businessContext": "Average fuel consumption per 100 km under typical load conditions.",
      "label_i18n": {
        "en": "Current Fuel Consumption",
        "tr": "Current Fuel Consumption",
        "de": "Current Fuel Consumption",
        "fr": "Current Fuel Consumption",
        "es": "Current Fuel Consumption",
        "ar": "Current Fuel Consumption"
      }
    },
    {
      "id": "annualDistance",
      "label": "Annual Distance Traveled",
      "type": "number",
      "unit": "km",
      "default": 30000,
      "businessContext": "Total kilometers traveled by the vehicle per year.",
      "label_i18n": {
        "en": "Annual Distance Traveled",
        "tr": "Annual Distance Traveled",
        "de": "Annual Distance Traveled",
        "fr": "Annual Distance Traveled",
        "es": "Annual Distance Traveled",
        "ar": "Annual Distance Traveled"
      }
    },
    {
      "id": "fuelPrice",
      "label": "Fuel Price",
      "type": "number",
      "unit": "$/L",
      "default": 1.5,
      "businessContext": "Unit price of fuel (e.g., diesel, gasoline).",
      "label_i18n": {
        "en": "Fuel Price",
        "tr": "Fuel Price",
        "de": "Fuel Price",
        "fr": "Fuel Price",
        "es": "Fuel Price",
        "ar": "Fuel Price"
      }
    },
    {
      "id": "efficiencyImprovement",
      "label": "Efficiency Improvement",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected percentage reduction in fuel consumption due to improvements.",
      "label_i18n": {
        "en": "Efficiency Improvement",
        "tr": "Efficiency Improvement",
        "de": "Efficiency Improvement",
        "fr": "Efficiency Improvement",
        "es": "Efficiency Improvement",
        "ar": "Efficiency Improvement"
      }
    },
    {
      "id": "engineLoadFactor",
      "label": "Engine Load Factor",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Average engine load as a percentage, adjusting real-world consumption.",
      "label_i18n": {
        "en": "Engine Load Factor",
        "tr": "Engine Load Factor",
        "de": "Engine Load Factor",
        "fr": "Engine Load Factor",
        "es": "Engine Load Factor",
        "ar": "Engine Load Factor"
      }
    },
    {
      "id": "operatingYears",
      "label": "Operating Years",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "Number of years over which savings accumulate.",
      "label_i18n": {
        "en": "Operating Years",
        "tr": "Operating Years",
        "de": "Operating Years",
        "fr": "Operating Years",
        "es": "Operating Years",
        "ar": "Operating Years"
      }
    }
  ],
  "formulas": {
    "annualFuelUsed": "annualDistance * (currentFuelConsumption / 100) * (engineLoadFactor / 100)",
    "improvedFuelConsumption": "currentFuelConsumption * (1 - efficiencyImprovement / 100)",
    "annualFuelSaved": "annualDistance * ((currentFuelConsumption - improvedFuelConsumption) / 100) * (engineLoadFactor / 100)",
    "annualCostSavings": "annualFuelSaved * fuelPrice",
    "totalSavings": "annualCostSavings * operatingYears"
  },
  "outputs": {
    "primary": "totalSavings",
    "breakdown": [
      "annualFuelSaved",
      "annualCostSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalSavings",
    "unit": "L/100km"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Otomotiv & Taşıt",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

      "label_i18n": {
        "en": "Loan 1 Annual Interest Rate",
        "tr": "Loan 1 Annual Interest Rate",
        "de": "Loan 1 Annual Interest Rate",
        "fr": "Loan 1 Annual Interest Rate",
        "es": "Loan 1 Annual Interest Rate",

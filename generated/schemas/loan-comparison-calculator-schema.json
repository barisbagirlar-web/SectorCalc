      }
    },
    {
      "id": "loan1Term",
      "label": "Loan 1 Term",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "The loan term in years for Loan 1",
      "label_i18n": {
        "en": "Loan 1 Term",
        "tr": "Loan 1 Term",
        "de": "Loan 1 Term",
        "fr": "Loan 1 Term",
        "es": "Loan 1 Term",
        "ar": "Loan 1 Term"
      }
    },
    {
      "id": "loan2Amount",
      "label": "Loan 2 Principal",
      "type": "number",
      "unit": "currency",
      "default": 12000,
      "businessContext": "The amount borrowed for Loan 2",
      "label_i18n": {
        "en": "Loan 2 Principal",
        "tr": "Loan 2 Principal",
        "de": "Loan 2 Principal",
        "fr": "Loan 2 Principal",
        "es": "Loan 2 Principal",
        "ar": "Loan 2 Principal"
      }
    },
    {
      "id": "loan2Rate",
      "label": "Loan 2 Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 4.5,
      "businessContext": "The annual interest rate for Loan 2",
      "label_i18n": {
        "en": "Loan 2 Annual Interest Rate",
        "tr": "Loan 2 Annual Interest Rate",
        "de": "Loan 2 Annual Interest Rate",
        "fr": "Loan 2 Annual Interest Rate",
        "es": "Loan 2 Annual Interest Rate",
        "ar": "Loan 2 Annual Interest Rate"
      }
    },
    {
      "id": "loan2Term",
      "label": "Loan 2 Term",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "The loan term in years for Loan 2",
      "label_i18n": {
        "en": "Loan 2 Term",
        "tr": "Loan 2 Term",
        "de": "Loan 2 Term",
        "fr": "Loan 2 Term",
        "es": "Loan 2 Term",
        "ar": "Loan 2 Term"
      }
    }
  ],
  "formulas": {
    "monthlyPayment1": "loan1Amount * (loan1Rate/100/12) * (1 + loan1Rate/100/12) ** (loan1Term * 12) / ((1 + loan1Rate/100/12) ** (loan1Term * 12) - 1)",
    "monthlyPayment2": "loan2Amount * (loan2Rate/100/12) * (1 + loan2Rate/100/12) ** (loan2Term * 12) / ((1 + loan2Rate/100/12) ** (loan2Term * 12) - 1)",
    "totalPayment1": "monthlyPayment1 * loan1Term * 12",
    "totalPayment2": "monthlyPayment2 * loan2Term * 12",
    "totalInterest1": "totalPayment1 - loan1Amount",
    "totalInterest2": "totalPayment2 - loan2Amount",
    "totalCostDifference": "totalPayment1 - totalPayment2"
  },
  "outputs": {
    "primary": "totalCostDifference",
    "breakdown": [
      "monthlyPayment1",
      "monthlyPayment2",
      "totalPayment1",
      "totalPayment2",
      "totalInterest1",
      "totalInterest2"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCostDifference"
  },

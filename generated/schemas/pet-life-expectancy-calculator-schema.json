    {
      "id": "sterilized",
      "label": "Sterilized (0/1)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 if sterilized, 0 otherwise",
      "label_i18n": {
        "en": "Sterilized (0/1)",
        "tr": "Sterilized (0/1)",
        "de": "Sterilized (0/1)",
        "fr": "Sterilized (0/1)",
        "es": "Sterilized (0/1)",
        "ar": "Sterilized (0/1)"
      }
    }
  ],
  "formulas": {
    "weightMultiplier": "1 - 0.02 * Math.abs(weight - idealWeight)",
    "activityMultiplier": "0.8 + (activityLevel / 10) * 0.2",
    "dietMultiplier": "0.7 + (dietQuality / 10) * 0.3",
    "vetMultiplier": "Math.min(1, 0.9 + vetVisits * 0.025)",
    "sterilizationMultiplier": "1 + 0.1 * sterilized",
    "lifeExpectancy": "baseLifespan * weightMultiplier * activityMultiplier * dietMultiplier * vetMultiplier * sterilizationMultiplier"
  },
  "outputs": {
    "primary": "lifeExpectancy",
    "breakdown": [
      "weightMultiplier",
      "activityMultiplier",
      "dietMultiplier",
      "vetMultiplier",
      "sterilizationMultiplier"
    ]
  },
  "category": "Üretim & İmalat",

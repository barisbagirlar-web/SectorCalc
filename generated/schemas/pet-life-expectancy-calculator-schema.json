  "validation": {
    "rules": [
      {
        "field": "weight",
        "condition": "weight > 0",
        "message": "Weight must be positive"
      },
      {
        "field": "idealWeight",
        "condition": "idealWeight > 0",
        "message": "Ideal weight must be positive"
      },
      {
        "field": "activityLevel",
        "condition": "activityLevel >= 0 && activityLevel <= 10",
        "message": "Activity level must be between 0 and 10"
      },
      {
        "field": "dietQuality",
        "condition": "dietQuality >= 0 && dietQuality <= 10",
        "message": "Diet quality must be between 0 and 10"
      },
      {
        "field": "vetVisits",
        "condition": "vetVisits >= 0",
        "message": "Vet visits must be non-negative"
      },
      {
        "field": "sterilized",
        "condition": "sterilized === 0 || sterilized === 1",
        "message": "Sterilized must be 0 or 1"
      }
    ],
    "thresholds": {}
  },
  "premiumFeatures": []
}

  "formulas": {
    "activityMultiplier": "0.8 + (activityLevel / 10) * 0.2",
    "dietMultiplier": "0.7 + (dietQuality / 10) * 0.3",
    "vetMultiplier": "1 + 0.05 * vetVisits",
    "sterilizationMultiplier": "1 + 0.1 * sterilized"
  },

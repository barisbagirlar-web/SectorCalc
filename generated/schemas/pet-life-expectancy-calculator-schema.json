    "primary": "sterilizationMultiplier",
    "breakdown": [
      "weightMultiplier",
      "activityMultiplier",
      "dietMultiplier",
      "vetMultiplier",
      "sterilizationMultiplier"
    ],
    "hiddenLossDrivers": [],

  "formulas": {
    "totalEngagements": "likes + comments + shares",
    "engagementRateByImpressions": "totalImpressions > 0 ? (totalEngagements / totalImpressions) * 100 : 0",
    "engagementRateByFollowers": "totalFollowers > 0 ? (totalEngagements / totalFollowers) * 100 : 0"
  },

{
  "toolName": "arcsine-calculator",
  "inputs": [
    {
      "id": "sineValue",
      "label": "Sine Value",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.5,
      "businessContext": "The sine of the angle to compute the arcsine. Must be between -1 and 1. Typical use in engineering for angle determination from ratios."
    },
    {
      "id": "outputUnit",
      "label": "Output Unit (0:Degrees, 1:Radians)",
      "type": "number",
      "unit": "binary",
      "default": 1,
      "businessContext": "Select output angle unit: 0 for degrees (common in construction), 1 for radians (mathematical analysis)."
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "count",
      "default": 4,
      "businessContext": "Number of decimal places for rounding the result, ensuring measurement precision."
    },
    {
      "id": "angleSelection",
      "label": "Angle Selection (0:Principal, 1:Supplementary, 2:Both)",
      "type": "number",
      "unit": "code",
      "default": 0,
      "businessContext": "Principal value in [-90°,90°], supplementary is 180° - principal for specific applications like geometry."
    }
  ],
  "formulas": {
    "principalRad": "Math.asin(sineValue)",
    "principalDeg": "(principalRad * 180 / Math.PI)",
    "supplementaryRad": "(Math.PI - principalRad)",
    "supplementaryDeg": "(supplementaryRad * 180 / Math.PI)",
    "primaryOutput": "(outputUnit === 0 ? (angleSelection === 0 ? parseFloat(principalDeg.toFixed(decimalPlaces)) : (angleSelection === 1 ? parseFloat(supplementaryDeg.toFixed(decimalPlaces)) : (parseFloat(principalDeg.toFixed(decimalPlaces)) + ', ' + parseFloat(supplementaryDeg.toFixed(decimalPlaces))))) : (angleSelection === 0 ? parseFloat(principalRad.toFixed(decimalPlaces)) : (angleSelection === 1 ? parseFloat(supplementaryRad.toFixed(decimalPlaces)) : (parseFloat(principalRad.toFixed(decimalPlaces)) + ', ' + parseFloat(supplementaryRad.toFixed(decimalPlaces))))))",
    "breakdown1": "`Sine Input: ${sineValue}`",
    "breakdown2": "`Principal Angle (rad): ${parseFloat(principalRad.toFixed(decimalPlaces))} rad, (deg): ${parseFloat(principalDeg.toFixed(decimalPlaces))}°`",
    "breakdown3": "`Supplementary Angle (rad): ${parseFloat(supplementaryRad.toFixed(decimalPlaces))} rad, (deg): ${parseFloat(supplementaryDeg.toFixed(decimalPlaces))}°`"
  },
  "outputs": {
    "primary": "primaryOutput",
    "breakdown": [
      "breakdown1",
      "breakdown2",
      "breakdown3"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma"
}

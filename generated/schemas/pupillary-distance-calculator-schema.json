  "formulas": {
    "totalFarPd": "rightPd + leftPd",
    "workingDistMm": "workingDistance * 10",
    "effectiveDistance": "workingDistMm + vertexDistance + centerRotationDistance",
    "rightNearPd": "rightPd * workingDistMm / effectiveDistance",
    "leftNearPd": "leftPd * workingDistMm / effectiveDistance",
    "totalNearPd": "rightNearPd + leftNearPd"
  },

{
  "toolName": "break-even-safety-margin-calculator",
  "inputs": [
    {
      "id": "fixedCosts",
      "label": "Fixed Costs",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total fixed costs (e.g., rent, salaries) per period. Based on cost accounting standards."
    },
    {
      "id": "variableCostPerUnit",
      "label": "Variable Cost per Unit",
      "type": "number",
      "unit": "currency/unit",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Variable cost incurred per unit produced. Standard cost accounting."
    },
    {
      "id": "sellingPricePerUnit",
      "label": "Selling Price per Unit",
      "type": "number",
      "unit": "currency/unit",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Price at which each unit is sold. Market pricing analysis."
    },
    {
      "id": "actualSalesVolume",
      "label": "Actual Sales Volume",
      "type": "number",
      "unit": "units",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Actual number of units sold in the period. Sales data."
    },
    {
      "id": "timePeriod",
      "label": "Time Period",
      "type": "select",
      "unit": "",
      "default": "monthly",
      "min": null,
      "max": null,
      "options": [
        "daily",
        "weekly",
        "monthly",
        "quarterly",
        "yearly"
      ],
      "businessContext": "Period for which costs and sales are measured. Aligns with financial reporting periods."
    }
  ],
  "validation": {
    "rules": [
      "sellingPricePerUnit > variableCostPerUnit",
      "fixedCosts >= 0",
      "variableCostPerUnit >= 0",
      "sellingPricePerUnit > 0",
      "actualSalesVolume >= 0"
    ],
    "thresholds": {
      "safetyMargin": "safetyMargin < 0.1 -> 'Low safety margin, high risk'",
      "breakEvenUnits": "actualSalesVolume < breakEvenUnits -> 'Below break-even point'"
    }
  },
  "formulas": {
    "contributionMarginPerUnit": "sellingPricePerUnit - variableCostPerUnit",
    "contributionMarginRatio": "contributionMarginPerUnit / sellingPricePerUnit",
    "breakEvenUnits": "fixedCosts / contributionMarginPerUnit",
    "breakEvenRevenue": "fixedCosts / contributionMarginRatio",
    "safetyMarginUnits": "actualSalesVolume - breakEvenUnits",
    "safetyMarginRevenue": "(actualSalesVolume * sellingPricePerUnit) - breakEvenRevenue",
    "safetyMarginPercentage": "safetyMarginUnits / actualSalesVolume"
  },
  "outputs": {
    "primary": "safetyMarginPercentage",
    "breakdown": {
      "breakEvenUnits": "breakEvenUnits",
      "breakEvenRevenue": "breakEvenRevenue",
      "contributionMarginPerUnit": "contributionMarginPerUnit",
      "contributionMarginRatio": "contributionMarginRatio",
      "safetyMarginUnits": "safetyMarginUnits",
      "safetyMarginRevenue": "safetyMarginRevenue"
    },
    "hiddenLossDrivers": [
      "If safetyMarginPercentage < 0.1: 'Low safety margin'",
      "If actualSalesVolume < breakEvenUnits: 'Below break-even'"
    ],
    "suggestedActions": [
      "If safetyMargin low: Reduce fixed costs or increase selling price.",
      "If below break-even: Increase sales volume or reduce variable costs."
    ],
    "dataConfidenceAdjusted": "safetyMarginPercentage * dataConfidence (if dataConfidence input exists)"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis over periods",
    "Scenario comparison",
    "Detailed report with charts"
  ],
  "premiumRequired": true
}

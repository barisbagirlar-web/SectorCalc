{
  "toolName": "decimal-to-binary-calculator",
  "inputs": [
    {
      "id": "decimalValue",
      "label": "Decimal Number",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "The non-negative decimal integer to convert to binary.",
      "label_i18n": {
        "en": "Decimal Number",
        "tr": "Decimal Number",
        "de": "Decimal Number",
        "fr": "Decimal Number",
        "es": "Decimal Number",
        "ar": "Decimal Number"
      }
    },
    {
      "id": "minBits",
      "label": "Minimum Bits",
      "type": "number",
      "unit": "bits",
      "default": 8,
      "businessContext": "Minimum number of bits in the output binary string. Shorter results are padded with leading zeros.",
      "label_i18n": {
        "en": "Minimum Bits",
        "tr": "Minimum Bits",
        "de": "Minimum Bits",
        "fr": "Minimum Bits",
        "es": "Minimum Bits",
        "ar": "Minimum Bits"
      }
    },
    {
      "id": "groupSize",
      "label": "Group Size",
      "type": "number",
      "unit": "bits/group",
      "default": 0,
      "businessContext": "Number of bits per group separated by a space. 0 means no grouping.",
      "label_i18n": {
        "en": "Group Size",
        "tr": "Group Size",
        "de": "Group Size",
        "fr": "Group Size",
        "es": "Group Size",
        "ar": "Group Size"
      }
    },
    {
      "id": "includePrefix",
      "label": "Include 0b Prefix",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "1 to prepend '0b' prefix, 0 to omit. Only effective when output is a string.",
      "label_i18n": {
        "en": "Include 0b Prefix",
        "tr": "Include 0b Prefix",
        "de": "Include 0b Prefix",
        "fr": "Include 0b Prefix",
        "es": "Include 0b Prefix",
        "ar": "Include 0b Prefix"
      }
    },
    {
      "id": "outputNumberFormat",
      "label": "Output as Number",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "1 to output the binary value as a base-10 number (loosing leading zeros and formatting), 0 to output as a formatted string.",
      "label_i18n": {
        "en": "Output as Number",
        "tr": "Output as Number",
        "de": "Output as Number",
        "fr": "Output as Number",
        "es": "Output as Number",
        "ar": "Output as Number"
      }
    }
  ],
  "formulas": {
    "binaryUnpadded": "decimalValue < 0 ? 'Error: Negative input not supported' : decimalValue.toString(2)",
    "paddedBinary": "minBits > 0 ? binaryUnpadded.padStart(minBits, '0') : binaryUnpadded",
    "groupedBinary": "groupSize > 0 ? paddedBinary.match(new RegExp(`.{1,${groupSize}}`, 'g')).join(' ') : paddedBinary",
    "withPrefix": "includePrefix == 1 ? '0b' + groupedBinary : groupedBinary",
    "binaryAsNumber": "parseInt(paddedBinary, 2)",
    "primaryOutput": "outputNumberFormat == 1 ? binaryAsNumber : withPrefix"
  },
  "outputs": {
    "primary": "primaryOutput",
    "breakdown": [
      "binaryUnpadded",
      "paddedBinary",
      "groupedBinary",
      "withPrefix",
      "binaryAsNumber"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

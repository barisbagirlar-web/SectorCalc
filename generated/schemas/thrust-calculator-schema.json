  "formulas": {
    "momentumThrust": "massFlowRate * exhaustVelocity",
    "pressureThrust": "(exitPressure - ambientPressure) * exitArea",
    "totalThrust": "massFlowRate * exhaustVelocity + (exitPressure - ambientPressure) * exitArea"
  },

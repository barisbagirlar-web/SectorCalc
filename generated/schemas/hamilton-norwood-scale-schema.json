{
  "toolName": "hamilton-norwood-scale",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Patient age for risk assessment",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "frontal_recession_mm",
      "label": "Frontal Recession",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Measured from original hairline",
      "label_i18n": {
        "en": "Frontal Recession",
        "tr": "Frontal Recession",
        "de": "Frontal Recession",
        "fr": "Frontal Recession",
        "es": "Frontal Recession",
        "ar": "Frontal Recession"
      }
    },
    {
      "id": "vertex_thinning_percent",
      "label": "Vertex Thinning",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage of visible scalp on crown",
      "label_i18n": {
        "en": "Vertex Thinning",
        "tr": "Vertex Thinning",
        "de": "Vertex Thinning",
        "fr": "Vertex Thinning",
        "es": "Vertex Thinning",
        "ar": "Vertex Thinning"
      }
    },
    {
      "id": "temporal_thinning_percent",
      "label": "Temporal Thinning",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage thinning at temples",
      "label_i18n": {
        "en": "Temporal Thinning",
        "tr": "Temporal Thinning",
        "de": "Temporal Thinning",
        "fr": "Temporal Thinning",
        "es": "Temporal Thinning",
        "ar": "Temporal Thinning"
      }
    },
    {
      "id": "family_history_score",
      "label": "Family History Score",
      "type": "number",
      "unit": "0-3",
      "default": 1,
      "businessContext": "0=none, 1=mild, 2=moderate, 3=strong",
      "label_i18n": {
        "en": "Family History Score",
        "tr": "Family History Score",
        "de": "Family History Score",
        "fr": "Family History Score",
        "es": "Family History Score",
        "ar": "Family History Score"
      }
    },
    {
      "id": "duration_years",
      "label": "Duration of Hair Loss",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Years since onset",
      "label_i18n": {
        "en": "Duration of Hair Loss",
        "tr": "Duration of Hair Loss",
        "de": "Duration of Hair Loss",
        "fr": "Duration of Hair Loss",
        "es": "Duration of Hair Loss",
        "ar": "Duration of Hair Loss"
      }
    }
  ],
  "formulas": {
    "frontal_score": "Math.min(3, Math.floor(frontal_recession_mm / 10))",
    "vertex_score": "Math.min(3, Math.floor(vertex_thinning_percent / 25))",
    "temporal_score": "Math.min(2, Math.floor(temporal_thinning_percent / 20))",
    "family_score": "family_history_score",
    "duration_score": "Math.min(2, Math.floor(duration_years / 5))",
    "age_score": "Math.min(2, Math.floor((age - 20) / 10))",
    "raw_score": "frontal_score + vertex_score + temporal_score + family_score + duration_score + age_score",
    "norwood_stage": "Math.min(7, Math.max(1, Math.round(raw_score / 2)))",
    "progression_risk": "raw_score > 10 ? 'High' : (raw_score > 6 ? 'Moderate' : 'Low')",
    "_frontal_score_": "{frontal_score}",
    "_vertex_score_": "{vertex_score}",
    "_temporal_score_": "{temporal_score}",
    "_family_score_": "{family_score}",
    "_duration_score_": "{duration_score}",
    "_age_score_": "{age_score}",
    "_raw_score_": "{raw_score}",
    "_progression_risk_": "{progression_risk}"
  },
  "outputs": {
    "primary": "frontal_score",
    "breakdown": [
      "Frontal Score: {frontal_score}",
      "Vertex Score: {vertex_score}",
      "Temporal Score: {temporal_score}",
      "Family History Score: {family_score}",
      "Duration Score: {duration_score}",
      "Age Score: {age_score}",
      "Raw Score: {raw_score}",
      "Progression Risk: {progression_risk}"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma"
}

{
  "toolName": "a-level-calculator",
  "inputs": [
    {
      "id": "measured",
      "label": "Measured Value",
      "type": "number",
      "unit": "Pa",
      "default": 1,
      "businessContext": "The measured physical quantity (e.g., sound pressure in Pascals).",
      "label_i18n": {
        "en": "Measured Value",
        "tr": "Measured Value",
        "de": "Measured Value",
        "fr": "Measured Value",
        "es": "Measured Value",
        "ar": "Measured Value"
      }
    },
    {
      "id": "reference",
      "label": "Reference Value",
      "type": "number",
      "unit": "Pa",
      "default": 0.00002,
      "businessContext": "The reference quantity for the level calculation. Typical reference for sound pressure is 20 µPa.",
      "label_i18n": {
        "en": "Reference Value",
        "tr": "Reference Value",
        "de": "Reference Value",
        "fr": "Reference Value",
        "es": "Reference Value",
        "ar": "Reference Value"
      }
    },
    {
      "id": "dbMultiplier",
      "label": "dB Multiplier",
      "type": "number",
      "unit": "unit",
      "default": 20,
      "businessContext": "20 for amplitude quantities (pressure, voltage), 10 for power quantities.",
      "label_i18n": {
        "en": "dB Multiplier",
        "tr": "dB Multiplier",
        "de": "dB Multiplier",
        "fr": "dB Multiplier",
        "es": "dB Multiplier",
        "ar": "dB Multiplier"
      }
    },
    {
      "id": "systemGain",
      "label": "System Gain (dB)",
      "type": "number",
      "unit": "dB",
      "default": 0,
      "businessContext": "Additional gain or attenuation in the system, in decibels. Positive for amplification, negative for attenuation.",
      "label_i18n": {
        "en": "System Gain (dB)",
        "tr": "System Gain (dB)",
        "de": "System Gain (dB)",
        "fr": "System Gain (dB)",
        "es": "System Gain (dB)",
        "ar": "System Gain (dB)"
      }
    }
  ],
  "formulas": {
    "ratio": "measured / reference",
    "log10ratio": "Math.log(measured / reference) / Math.log(10)",
    "preGainLevel": "dbMultiplier * (Math.log(measured / reference) / Math.log(10))",
    "level": "dbMultiplier * (Math.log(measured / reference) / Math.log(10)) + systemGain"
  },
  "outputs": {
    "primary": "level",
    "breakdown": [
      "ratio",
      "log10ratio",
      "preGainLevel"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "education-academic",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

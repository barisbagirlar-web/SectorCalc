{
  "toolName": "container-calculator",
  "inputs": [
    {
      "id": "totalQuantity",
      "label": "Toplam Adet",
      "type": "number",
      "unit": "adet",
      "default": 1000,
      "businessContext": "Sevk edilecek toplam birim sayısı",
      "label_i18n": {
        "en": "Toplam Adet",
        "tr": "Toplam Adet",
        "de": "Toplam Adet",
        "fr": "Toplam Adet",
        "es": "Toplam Adet",
        "ar": "Toplam Adet"
      }
    },
    {
      "id": "itemsPerPallet",
      "label": "Palet Başına Adet",
      "type": "number",
      "unit": "adet/palet",
      "default": 50,
      "businessContext": "Bir palete sığan birim sayısı",
      "label_i18n": {
        "en": "Palet Başına Adet",
        "tr": "Palet Başına Adet",
        "de": "Palet Başına Adet",
        "fr": "Palet Başına Adet",
        "es": "Palet Başına Adet",
        "ar": "Palet Başına Adet"
      }
    },
    {
      "id": "palletsPerContainer",
      "label": "Konteyner Başına Palet",
      "type": "number",
      "unit": "palet/konteyner",
      "default": 20,
      "businessContext": "Bir konteynere yüklenebilen palet sayısı (ör: 20 palet = TEU)",
      "label_i18n": {
        "en": "Konteyner Başına Palet",
        "tr": "Konteyner Başına Palet",
        "de": "Konteyner Başına Palet",
        "fr": "Konteyner Başına Palet",
        "es": "Konteyner Başına Palet",
        "ar": "Konteyner Başına Palet"
      }
    },
    {
      "id": "reservePercent",
      "label": "Yedek Oranı (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Hasar, kayıp vb. için ek yedek yüzdesi",
      "label_i18n": {
        "en": "Yedek Oranı (%)",
        "tr": "Yedek Oranı (%)",
        "de": "Yedek Oranı (%)",
        "fr": "Yedek Oranı (%)",
        "es": "Yedek Oranı (%)",
        "ar": "Yedek Oranı (%)"
      }
    }
  ],
  "formulas": {
    "palletsNeeded": "Math.ceil(totalQuantity / itemsPerPallet)",
    "containersWithoutReserve": "Math.ceil(palletsNeeded / palletsPerContainer)",
    "containersWithReserve": "Math.ceil(containersWithoutReserve * (1 + reservePercent / 100))",
    "__palletsNeeded_": "${palletsNeeded}",
    "__containersWithoutReserve_": "${containersWithoutReserve}",
    "__containersWithReserve_": "${containersWithReserve}"
  },
  "outputs": {
    "primary": "palletsNeeded",
    "breakdown": [
      "İhtiyaç Duyulan Palet: ${palletsNeeded}",
      "Yedeksiz Konteyner: ${containersWithoutReserve}",
      "Yedekli Konteyner: ${containersWithReserve}"
    ]
  },
  "category": "Diğer",
  "sector": "Denizcilik & Gemi",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "quality-six-sigma",
  "sectorId": "denizcilik",
  "profession": "Gemi Mühendisi",
  "categoryId": "diger"
}

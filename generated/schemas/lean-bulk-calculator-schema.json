{
  "toolName": "lean-bulk-calculator",
  "inputs": [
    {
      "id": "dailyProduction",
      "label": "Daily Production Volume",
      "type": "number",
      "unit": "units/day",
      "default": 1000,
      "businessContext": "Number of units produced per day",
      "label_i18n": {
        "en": "Daily Production Volume",
        "tr": "Günlük Üretim Hacmi",
        "de": "Daily Production Volume",
        "fr": "Daily Production Volume",
        "es": "Daily Production Volume",
        "ar": "Daily Production Volume"
      },
      "businessContext_i18n": {
        "en": "Number of units produced per day",
        "tr": "Günde üretilen birim sayısı"
      }
    },
    {
      "id": "materialPerUnit",
      "label": "Material Per Unit",
      "type": "number",
      "unit": "kg",
      "default": 0.5,
      "businessContext": "Amount of raw material required per unit",
      "label_i18n": {
        "en": "Material Per Unit",
        "tr": "Birim Başına Malzeme",
        "de": "Material Per Unit",
        "fr": "Material Per Unit",
        "es": "Material Per Unit",
        "ar": "Material Per Unit"
      },
      "businessContext_i18n": {
        "en": "Amount of raw material required per unit",
        "tr": "Birim başına gereken hammadde miktarı"
      }
    },
    {
      "id": "containerCapacity",
      "label": "Container Capacity",
      "type": "number",
      "unit": "kg",
      "default": 25,
      "businessContext": "Capacity of each bulk container",
      "label_i18n": {
        "en": "Container Capacity",
        "tr": "Konteyner Kapasitesi",
        "de": "Behälterkapazität",
        "fr": "Container Capacity",
        "es": "Container Capacity",
        "ar": "Container Capacity"
      },
      "businessContext_i18n": {
        "en": "Capacity of each bulk container",
        "tr": "Her bir dökme konteynerin kapasitesi"
      }
    },
    {
      "id": "safetyStockDays",
      "label": "Safety Stock Days",
      "type": "number",
      "unit": "days",
      "default": 2,
      "businessContext": "Days of inventory kept as safety buffer",
      "label_i18n": {
        "en": "Safety Stock Days",
        "tr": "Emniyet Stoku Günleri",
        "de": "Safety Stock Days",
        "fr": "Safety Stock Days",
        "es": "Safety Stock Days",
        "ar": "Safety Stock Days"
      },
      "businessContext_i18n": {
        "en": "Days of inventory kept as safety buffer",
        "tr": "Güvenlik tamponu olarak tutulan envanter gün sayısı"
      }
    },
    {
      "id": "leadTimeDays",
      "label": "Lead Time Days",
      "type": "number",
      "unit": "days",
      "default": 5,
      "businessContext": "Supplier lead time in days",
      "label_i18n": {
        "en": "Lead Time Days",
        "tr": "Teslim Süresi Günleri",
        "de": "Lead Time Days",
        "fr": "Lead Time Days",
        "es": "Lead Time Days",
        "ar": "Lead Time Days"
      },
      "businessContext_i18n": {
        "en": "Supplier lead time in days",
        "tr": "Tedarikçi teslim süresi (gün)"
      }
    },
    {
      "id": "reorderPointMultiplier",
      "label": "Reorder Point Multiplier",
      "type": "number",
      "unit": "unit",
      "default": 1.2,
      "businessContext": "Multiplier to account for variability in demand during lead time",
      "label_i18n": {
        "en": "Reorder Point Multiplier",
        "tr": "Yeniden Sipariş Noktası Çarpanı",
        "de": "Reorder Point Multiplier",
        "fr": "Reorder Point Multiplier",
        "es": "Reorder Point Multiplier",
        "ar": "Reorder Point Multiplier"
      },
      "businessContext_i18n": {
        "en": "Multiplier to account for variability in demand during lead time",
        "tr": "Teslim süresi boyunca talep değişkenliğini hesaba katan çarpan"
      }
    }
  ],
  "formulas": {
    "totalDailyMaterial": "dailyProduction * materialPerUnit",
    "totalBulkRequired": "totalDailyMaterial * (leadTimeDays + safetyStockDays) * reorderPointMultiplier",
    "avgDailyContainers": "totalDailyMaterial / containerCapacity"
  },
  "outputs": {
    "primary": "totalDailyMaterial",
    "breakdown": [
      {
        "label": "Number of Containers",
        "value": "numberOfContainers",
        "unit": "containers"
      },
      {
        "label": "Average Daily Containers",
        "value": "avgDailyContainers",
        "unit": "containers/day"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "avgDailyContainers",
    "unit": "units/day"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Lojistik & Tedarik",
  "premiumRequired": false,
  "categorySlug": "lean-production",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",

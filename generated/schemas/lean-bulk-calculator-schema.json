{
  "toolName": "lean-bulk-calculator",
  "inputs": [
    {
      "id": "dailyProduction",
      "label": "Daily Production Volume",
      "type": "number",
      "unit": "units/day",
      "default": 1000,
      "businessContext": "Number of units produced per day"
    },
    {
      "id": "materialPerUnit",
      "label": "Material Per Unit",
      "type": "number",
      "unit": "kg",
      "default": 0.5,
      "businessContext": "Amount of raw material required per unit"
    },
    {
      "id": "containerCapacity",
      "label": "Container Capacity",
      "type": "number",
      "unit": "kg",
      "default": 25,
      "businessContext": "Capacity of each bulk container"
    },
    {
      "id": "safetyStockDays",
      "label": "Safety Stock Days",
      "type": "number",
      "unit": "days",
      "default": 2,
      "businessContext": "Days of inventory kept as safety buffer"
    },
    {
      "id": "leadTimeDays",
      "label": "Lead Time Days",
      "type": "number",
      "unit": "days",
      "default": 5,
      "businessContext": "Supplier lead time in days"
    },
    {
      "id": "reorderPointMultiplier",
      "label": "Reorder Point Multiplier",
      "type": "number",
      "unit": "",
      "default": 1.2,
      "businessContext": "Multiplier to account for variability in demand during lead time"
    }
  ],
  "formulas": {
    "totalDailyMaterial": "dailyProduction * materialPerUnit",
    "totalBulkRequired": "totalDailyMaterial * (leadTimeDays + safetyStockDays) * reorderPointMultiplier",
    "numberOfContainers": "Math.ceil(totalBulkRequired / containerCapacity)",
    "avgDailyContainers": "totalDailyMaterial / containerCapacity"
  },
  "outputs": {
    "primary": {
      "label": "Total Bulk Material Required",
      "value": "totalBulkRequired",
      "unit": "kg"
    },
    "breakdown": [
      {
        "label": "Number of Containers",
        "value": "numberOfContainers",
        "unit": "containers"
      },
      {
        "label": "Average Daily Containers",
        "value": "avgDailyContainers",
        "unit": "containers/day"
      }
    ]
  },
  "category": "Malzeme, Fire & OEE",
  "sector": "Üretim & İmalat",
  "premiumRequired": false
}
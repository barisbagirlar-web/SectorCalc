{
  "toolName": "tip-calculator",
  "inputs": [
    {
      "id": "billAmount",
      "label": "Bill Amount",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Total pre-tax bill amount"
    },
    {
      "id": "tipPercent",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tip percentage on pre-tax amount"
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "people",
      "default": 2,
      "businessContext": "Number of diners splitting the bill"
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Sales tax rate applied to bill"
    }
  ],
  "formulas": {
    "taxAmount": "billAmount * (taxRate / 100)",
    "totalWithTax": "billAmount + taxAmount",
    "tipAmount": "billAmount * (tipPercent / 100)",
    "totalAmount": "totalWithTax + tipAmount",
    "totalPerPerson": "totalAmount / numberOfPeople"
  },
  "outputs": {
    "primary": "totalPerPerson",
    "breakdown": [
      "tipAmount",
      "totalAmount",
      "totalPerPerson"
    ]
  },
  "category": "Finans & Yatırım",
  "sector": "Perakende & Tüketici",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "finance"
}

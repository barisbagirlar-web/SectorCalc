{
  "toolName": "tip-calculator",
  "inputs": [
    {
      "id": "billAmount",
      "label": "Bill Amount",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total bill amount before tip. Standard input for tip calculation."
    },
    {
      "id": "tipPercentage",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Percentage of bill to tip. Common range 10-20%."
    },
    {
      "id": "splitCount",
      "label": "Split Count",
      "type": "number",
      "unit": "people",
      "default": 1,
      "min": 1,
      "max": null,
      "options": null,
      "businessContext": "Number of people splitting the bill."
    },
    {
      "id": "roundUp",
      "label": "Round Up to Nearest Dollar",
      "type": "boolean",
      "unit": "",
      "default": false,
      "min": null,
      "max": null,
      "options": null,
      "businessContext": "Option to round total per person to nearest whole dollar."
    },
    {
      "id": "serviceQuality",
      "label": "Service Quality",
      "type": "select",
      "unit": "",
      "default": "average",
      "min": null,
      "max": null,
      "options": [
        "poor",
        "average",
        "excellent"
      ],
      "businessContext": "Adjusts tip percentage based on service quality. Common practice in hospitality."
    }
  ],
  "validation": {
    "rules": [
      "billAmount must be >= 0",
      "tipPercentage must be between 0 and 100",
      "splitCount must be >= 1",
      "if serviceQuality is 'poor', tipPercentage should be <= 10",
      "if serviceQuality is 'excellent', tipPercentage should be >= 18"
    ],
    "thresholds": {
      "tipPercentage": "if tipPercentage > 25 then 'High tip percentage'",
      "splitCount": "if splitCount > 10 then 'Large group'"
    }
  },
  "formulas": {
    "tipAmount": "billAmount * (tipPercentage / 100)",
    "totalAmount": "billAmount + tipAmount",
    "totalPerPerson": "totalAmount / splitCount",
    "roundedTotalPerPerson": "roundUp ? Math.ceil(totalPerPerson) : totalPerPerson"
  },
  "outputs": {
    "primary": "roundedTotalPerPerson",
    "breakdown": {
      "tipAmount": "tipAmount",
      "totalAmount": "totalAmount",
      "totalPerPerson": "totalPerPerson"
    },
    "hiddenLossDrivers": [
      "if tipPercentage > 25 then 'High tip percentage'",
      "if splitCount > 10 then 'Large group'"
    ],
    "suggestedActions": [
      "Consider standard tip percentages (15-20%)",
      "For large groups, verify split accuracy"
    ],
    "dataConfidenceAdjusted": "roundedTotalPerPerson"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Comparison with historical tips",
    "Detailed report with service quality breakdown"
  ],
  "premiumRequired": false
}

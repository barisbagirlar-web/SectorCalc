{
  "toolName": "tip-calculator",
  "inputs": [
    {
      "id": "billAmount",
      "label": "Bill Amount",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Total pre-tax bill amount",
      "label_i18n": {
        "en": "Bill Amount",
        "tr": "Fatura Tutarı",
        "de": "Rechnungsbetrag",
        "fr": "Montant de la facture",
        "es": "Monto de la cuenta",
        "ar": "مبلغ الفاتورة"
      },
      "businessContext_i18n": {
        "en": "Total pre-tax bill amount",
        "tr": "Vergi öncesi toplam fatura tutarı",
        "de": "Gesamtrechnungsbetrag vor Steuern",
        "fr": "Montant total de la facture avant impôt",
        "es": "Monto total de la factura antes de impuestos",
        "ar": "إجمالي مبلغ الفاتورة قبل الضريبة"
      }
    },
    {
      "id": "tipPercent",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tip percentage on pre-tax amount",
      "label_i18n": {
        "en": "Tip Percentage",
        "tr": "Bahşiş Yüzdesi",
        "de": "Trinkgeldprozentsatz",
        "fr": "Pourcentage de pourboire",
        "es": "Porcentaje de propina",
        "ar": "نسبة البقشيش"
      },
      "businessContext_i18n": {
        "en": "Tip percentage on pre-tax amount",
        "tr": "Vergi öncesi tutar üzerinden bahşiş yüzdesi",
        "de": "Trinkgeldprozentsatz auf den Nettobetrag",
        "fr": "Pourcentage de pourboire sur le montant avant impôt",
        "es": "Porcentaje de propina sobre el monto antes de impuestos",
        "ar": "نسبة الإكرامية على المبلغ قبل الضريبة"
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "people",
      "default": 2,
      "businessContext": "Number of diners splitting the bill",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Kişi Sayısı",
        "de": "Anzahl der Personen",
        "fr": "Nombre de personnes",
        "es": "Número de personas",
        "ar": "عدد الأشخاص"
      },
      "businessContext_i18n": {
        "en": "Number of diners splitting the bill",
        "tr": "Faturayı bölen kişi sayısı",
        "de": "Anzahl der Personen, die die Rechnung teilen",
        "fr": "Nombre de convives partageant la facture",
        "es": "Número de comensales que dividen la cuenta",
        "ar": "عدد الأشخاص المشاركين في تقسيم الفاتورة"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Sales tax rate applied to bill",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Vergi Oranı",
        "de": "Steuersatz",
        "fr": "Taux de taxe",
        "es": "Tasa de impuesto",
        "ar": "نسبة الضريبة"
      },
      "businessContext_i18n": {
        "en": "Sales tax rate applied to bill",
        "tr": "Faturaya uygulanan satış vergisi oranı",
        "de": "Umsatzsteuersatz auf die Rechnung",
        "fr": "Taux de taxe de vente appliqué à la facture",
        "es": "Tasa de impuesto a las ventas aplicada a la factura",
        "ar": "نسبة ضريبة المبيعات المطبقة على الفاتورة"
      }
    }
  ],
  "formulas": {
    "taxAmount": "billAmount * (taxRate / 100)",
    "totalWithTax": "billAmount + taxAmount",
    "tipAmount": "billAmount * (tipPercent / 100)",
    "totalAmount": "totalWithTax + tipAmount",
    "totalPerPerson": "totalAmount / numberOfPeople"
  },
  "outputs": {
    "primary": "totalPerPerson",
    "breakdown": [
      "tipAmount",
      "totalAmount",
      "totalPerPerson"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPerPerson",
    "unit": "USD"
  },

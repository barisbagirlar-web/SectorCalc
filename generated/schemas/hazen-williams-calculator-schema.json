      "label": "Hazen-Williams Coefficient",
      "type": "number",
      "unit": "dimensionless",
      "default": 130,
      "businessContext": "Roughness coefficient depending on pipe material (e.g., 130 for new steel, 140 for PVC).",
      "label_i18n": {
        "en": "Hazen-Williams Coefficient",

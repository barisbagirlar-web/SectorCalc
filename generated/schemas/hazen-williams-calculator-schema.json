      }
    }
  ],
  "formulas": {
    "velocity": "flowRate / (Math.PI * (pipeDiameter / 2) ** 2)",
    "headLoss": "(10.67 * pipeLength * flowRate ** 1.852) / (cFactor ** 1.852 * pipeDiameter ** 4.87)",
    "headLossPerUnitLength": "(10.67 * flowRate ** 1.852) / (cFactor ** 1.852 * pipeDiameter ** 4.87)"
  },
  "outputs": {
    "primary": "headLoss",
    "breakdown": [
      "velocity",
      "headLossPerUnitLength"
    ],

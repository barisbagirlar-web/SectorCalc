      }
    },
    {
      "id": "FootingWidth",
      "label": "Footing Width",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "The width of a single footing in meters.",
      "label_i18n": {
        "en": "Footing Width",
        "tr": "Footing Width",
        "de": "Footing Width",
        "fr": "Footing Width",
        "es": "Footing Width",
        "ar": "Footing Width"
      }
    },
    {
      "id": "FootingDepth",
      "label": "Footing Depth",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "The depth or thickness of the footing in meters.",
      "label_i18n": {
        "en": "Footing Depth",
        "tr": "Footing Depth",
        "de": "Footing Depth",
        "fr": "Footing Depth",
        "es": "Footing Depth",
        "ar": "Footing Depth"
      }
    },
    {
      "id": "NumberOfFootings",
      "label": "Number of Footings",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total number of identical footings to be poured.",
      "label_i18n": {
        "en": "Number of Footings",
        "tr": "Number of Footings",
        "de": "Number of Footings",
        "fr": "Number of Footings",
        "es": "Number of Footings",
        "ar": "Number of Footings"
      }
    },
    {
      "id": "WasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of extra concrete added to account for spillage, over‑excavation, and formwork irregularities.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "volumeWithoutWaste": "FootingLength * FootingWidth * FootingDepth * NumberOfFootings",
    "totalVolume": "FootingLength * FootingWidth * FootingDepth * NumberOfFootings * (1 + WasteFactor / 100)",
    "wasteAddition": "totalVolume - volumeWithoutWaste"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "volumeWithoutWaste",
      "wasteAddition"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "wasteAddition"
  },

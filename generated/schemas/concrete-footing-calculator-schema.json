{
  "toolName": "concrete-footing-calculator",
  "inputs": [
    {
      "id": "FootingLength",
      "label": "Footing Length",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "The length of a single footing in meters.",
      "label_i18n": {
        "en": "Footing Length",

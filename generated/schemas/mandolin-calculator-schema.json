      }
    },
    {
      "id": "labor_rate",
      "label": "Labor Rate",
      "type": "number",
      "unit": "USD/hour",
      "default": 25,
      "businessContext": "Hourly wage for luthier",
      "label_i18n": {
        "en": "Labor Rate",
        "tr": "İşçilik ücreti",
        "de": "Stundensatz",
        "fr": "Labor Rate",
        "es": "Labor Rate",
        "ar": "Labor Rate"
      },
      "businessContext_i18n": {
        "en": "Hourly wage for luthier",
        "tr": "Luthier için saatlik ücret"
      }
    },
    {
      "id": "overhead_percent",
      "label": "Overhead Percent",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Overhead cost as percentage of direct costs",
      "label_i18n": {
        "en": "Overhead Percent",
        "tr": "Genel Gider Yüzdesi",
        "de": "Overhead Percent",
        "fr": "Overhead Percent",
        "es": "Overhead Percent",
        "ar": "Overhead Percent"
      },
      "businessContext_i18n": {
        "en": "Overhead cost as percentage of direct costs",
        "tr": "Doğrudan maliyetlerin yüzdesi olarak genel gider maliyeti",
        "de": "Gemeinkosten als Prozentsatz der direkten Kosten"
      }
    },
    {
      "id": "profit_margin",
      "label": "Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Desired profit margin on total cost",
      "label_i18n": {
        "en": "Profit Margin",
        "tr": "Kâr Marjı",
        "de": "Gewinnmarge",
        "fr": "Profit Margin",
        "es": "Profit Margin",
        "ar": "Profit Margin"
      },
      "businessContext_i18n": {
        "en": "Desired profit margin on total cost",
        "tr": "Toplam maliyet üzerinden istenen kar marjı",
        "de": "Gewünschte Gewinnmarge auf die Gesamtkosten"
      }
    }
  ],
  "formulas": {
    "total_material_cost": "mandolin_count * (body_wood_cost + neck_wood_cost + hardware_cost)",
    "total_labor_cost": "mandolin_count * labor_hours * labor_rate",
    "direct_cost": "total_material_cost + total_labor_cost",
    "overhead_cost": "direct_cost * (overhead_percent / 100)",
    "total_cost": "direct_cost + overhead_cost",
    "selling_price": "total_cost * (1 + profit_margin / 100)",
    "cost_per_unit": "total_cost / mandolin_count",
    "price_per_unit": "selling_price / mandolin_count"
  },
  "outputs": {
    "primary": "price_per_unit",
    "breakdown": [
      "total_material_cost",
      "total_labor_cost",
      "overhead_cost",
      "total_cost",
      "selling_price",
      "cost_per_unit"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "price_per_unit",
    "unit": "pcs"
  },

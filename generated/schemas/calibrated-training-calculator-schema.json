{
  "toolName": "calibrated-training-calculator",
  "inputs": [
    {
      "id": "preScore",
      "label": "Pre-Training Assessment Score",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Average score of trainees before training, as percentage of maximum.",
      "label_i18n": {
        "en": "Pre-Training Assessment Score",
        "tr": "Pre-Training Assessment Score",
        "de": "Pre-Training Assessment Score",
        "fr": "Pre-Training Assessment Score",
        "es": "Pre-Training Assessment Score",
        "ar": "Pre-Training Assessment Score"
      }
    },
    {
      "id": "postScore",
      "label": "Post-Training Assessment Score",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Average score of trainees after training, as percentage of maximum.",
      "label_i18n": {
        "en": "Post-Training Assessment Score",
        "tr": "Post-Training Assessment Score",
        "de": "Post-Training Assessment Score",
        "fr": "Post-Training Assessment Score",
        "es": "Post-Training Assessment Score",
        "ar": "Post-Training Assessment Score"
      }
    },
    {
      "id": "trainingDuration",
      "label": "Training Duration",
      "type": "number",
      "unit": "hours",
      "default": 40,
      "businessContext": "Total hours of training delivered.",
      "label_i18n": {
        "en": "Training Duration",
        "tr": "Training Duration",
        "de": "Training Duration",
        "fr": "Training Duration",
        "es": "Training Duration",
        "ar": "Training Duration"
      }
    },
    {
      "id": "hourlyCost",
      "label": "Training Cost per Hour",
      "type": "number",
      "unit": "€",
      "default": 100,
      "businessContext": "Cost per hour including instructor, materials, overhead.",
      "label_i18n": {
        "en": "Training Cost per Hour",
        "tr": "Training Cost per Hour",
        "de": "Training Cost per Hour",
        "fr": "Training Cost per Hour",
        "es": "Training Cost per Hour",
        "ar": "Training Cost per Hour"
      }
    },
    {
      "id": "scrapRateBefore",
      "label": "Scrap Rate Before Training",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of defective output before training.",
      "label_i18n": {
        "en": "Scrap Rate Before Training",
        "tr": "Scrap Rate Before Training",
        "de": "Scrap Rate Before Training",
        "fr": "Scrap Rate Before Training",
        "es": "Scrap Rate Before Training",
        "ar": "Scrap Rate Before Training"
      }
    },
    {
      "id": "scrapRateAfter",
      "label": "Scrap Rate After Training",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Percentage of defective output after training.",
      "label_i18n": {
        "en": "Scrap Rate After Training",
        "tr": "Scrap Rate After Training",
        "de": "Scrap Rate After Training",
        "fr": "Scrap Rate After Training",
        "es": "Scrap Rate After Training",
        "ar": "Scrap Rate After Training"
      }
    }
  ],
  "formulas": {
    "skillGain": "((postScore - preScore) / (100 - preScore)) * 100",
    "qualityImprovement": "((scrapRateBefore - scrapRateAfter) / scrapRateBefore) * 100",
    "costEfficiency": "(((postScore - preScore) / (100 - preScore)) * 100) / (trainingDuration * hourlyCost)",
    "trainingEffectiveness": "0.6 * (((postScore - preScore) / (100 - preScore)) * 100) + 0.4 * (((scrapRateBefore - scrapRateAfter) / scrapRateBefore) * 100)"
  },
  "outputs": {
    "primary": "trainingEffectiveness",
    "breakdown": [
      "skillGain",
      "qualityImprovement",
      "costEfficiency"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "trainingEffectiveness",
    "unit": "%",
    "breakdownUnits": {
      "costEfficiency": "%"
    }
  },

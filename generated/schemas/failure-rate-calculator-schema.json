{
  "toolName": "failure-rate-calculator",
  "inputs": [
    {
      "id": "numFailures",
      "label": "Number of Failures",
      "type": "number",
      "unit": "failures",
      "default": 5,
      "businessContext": "Total observed failures during monitoring period",
      "label_i18n": {
        "en": "Number of Failures",
        "tr": "Number of Failures",
        "de": "Number of Failures",
        "fr": "Number of Failures",
        "es": "Number of Failures",
        "ar": "Number of Failures"
      }
    },
    {
      "id": "totalTime",
      "label": "Total Calendar Time",
      "type": "number",
      "unit": "hours",
      "default": 8760,
      "businessContext": "Total elapsed time in hours (e.g., 8760 h/year)",
      "label_i18n": {
        "en": "Total Calendar Time",
        "tr": "Total Calendar Time",
        "de": "Total Calendar Time",
        "fr": "Total Calendar Time",
        "es": "Total Calendar Time",
        "ar": "Total Calendar Time"
      }
    },
    {
      "id": "numUnits",
      "label": "Number of Units",
      "type": "number",
      "unit": "units",
      "default": 1,
      "businessContext": "Number of units under test or in operation",
      "label_i18n": {
        "en": "Number of Units",
        "tr": "Number of Units",
        "de": "Number of Units",
        "fr": "Number of Units",
        "es": "Number of Units",
        "ar": "Number of Units"
      }
    },
    {
      "id": "dutyCycle",
      "label": "Duty Cycle",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Percentage of time units are actually operating",
      "label_i18n": {
        "en": "Duty Cycle",
        "tr": "Duty Cycle",
        "de": "Duty Cycle",
        "fr": "Duty Cycle",
        "es": "Duty Cycle",
        "ar": "Duty Cycle"
      }
    }
  ],
  "formulas": {
    "effectiveOperatingHours": "totalTime * numUnits * (dutyCycle / 100)",
    "failureRatePerHour": "numFailures / effectiveOperatingHours",
    "mtbfHours": "effectiveOperatingHours / numFailures",
    "failureRateFPMH": "failureRatePerHour * 1000000",
    "failureRateFIT": "failureRatePerHour * 1000000000"
  },
  "outputs": {
    "primary": "failureRateFIT",
    "breakdown": [
      "Effective Operating Hours: ${effectiveOperatingHours.toFixed(2)} hours",
      "Failure Rate (λ): ${failureRatePerHour.toExponential(4)} per hour",
      "MTBF: ${mtbfHours.toFixed(2)} hours",
      "FIT Rate: ${failureRateFIT.toFixed(2)} failures per billion hours"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "failureRateFIT"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "maintenance-reliability",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "conversion",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

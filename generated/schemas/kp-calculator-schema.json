{
  "toolName": "kp-calculator",
  "inputs": [
    {
      "id": "processGain",
      "label": "Process Gain (K)",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Steady-state gain of the process, ratio of output change to input change.",
      "label_i18n": {
        "en": "Process Gain (K)",
        "tr": "Process Gain (K)",
        "de": "Process Gain (K)",
        "fr": "Process Gain (K)",
        "es": "Process Gain (K)",
        "ar": "Process Gain (K)"
      }
    },
    {
      "id": "timeConstant",
      "label": "Time Constant (T)",
      "type": "number",
      "unit": "s",
      "default": 10,
      "businessContext": "Time taken for the process response to reach 63.2% of its final value.",
      "label_i18n": {
        "en": "Time Constant (T)",
        "tr": "Time Constant (T)",
        "de": "Time Constant (T)",
        "fr": "Time Constant (T)",
        "es": "Time Constant (T)",
        "ar": "Time Constant (T)"
      }
    },
    {
      "id": "deadTime",
      "label": "Dead Time (L)",
      "type": "number",
      "unit": "s",
      "default": 1,
      "businessContext": "Delay between input change and process response.",
      "label_i18n": {
        "en": "Dead Time (L)",
        "tr": "Dead Time (L)",
        "de": "Dead Time (L)",
        "fr": "Dead Time (L)",
        "es": "Dead Time (L)",
        "ar": "Dead Time (L)"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Multiplier to derate the calculated gain for robustness.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    },
    {
      "id": "controllerType",
      "label": "Controller Type (1=P, 2=PI, 3=PID)",
      "type": "number",
      "unit": "option",
      "default": 2,
      "businessContext": "Selects the tuning rule: 1 for P-only, 2 for PI, 3 for PID based on Ziegler-Nichols open-loop method.",
      "label_i18n": {
        "en": "Controller Type (1=P, 2=PI, 3=PID)",
        "tr": "Controller Type (1=P, 2=PI, 3=PID)",
        "de": "Controller Type (1=P, 2=PI, 3=PID)",
        "fr": "Controller Type (1=P, 2=PI, 3=PID)",
        "es": "Controller Type (1=P, 2=PI, 3=PID)",
        "ar": "Controller Type (1=P, 2=PI, 3=PID)"
      }
    }
  ],
  "formulas": {
    "primary": "Kp_raw * safetyFactor",
    "Kp_raw": "(controllerType === 1 ? (timeConstant / (processGain * deadTime)) : (controllerType === 2 ? (0.9 * timeConstant / (processGain * deadTime)) : (1.2 * timeConstant / (processGain * deadTime))))",
    "Ki": "(controllerType === 1 ? 0 : (controllerType === 2 ? (0.3 * timeConstant / (processGain * Math.pow(deadTime, 2))) : (0.6 * timeConstant / (processGain * Math.pow(deadTime, 2)))))",
    "Kd": "(controllerType === 3 ? (0.6 * timeConstant / processGain) : 0)"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "Kp_raw",
      "Ki",
      "Kd"
    ]
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Gıda & İçecek",
  "premiumRequired": false,
  "catalogCategory": "chemistry-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "hse-ergonomics",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "quality"
}

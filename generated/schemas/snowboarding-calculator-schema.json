{
  "toolName": "snowboarding-calculator",
  "inputs": [
    {
      "id": "slopeAngle",
      "label": "Slope Angle",
      "type": "number",
      "unit": "degree",
      "default": "30",
      "businessContext": "Angle of the snowboarding slope relative to horizontal.",
      "label_i18n": {
        "en": "Slope Angle",
        "tr": "Slope Angle",
        "de": "Slope Angle",
        "fr": "Slope Angle",
        "es": "Slope Angle",
        "ar": "Slope Angle"
      }
    },
    {
      "id": "slopeLength",
      "label": "Slope Length",
      "type": "number",
      "unit": "m",
      "default": "100",
      "businessContext": "Length of the slope surface.",
      "label_i18n": {
        "en": "Slope Length",
        "tr": "Slope Length",
        "de": "Slope Length",
        "fr": "Slope Length",
        "es": "Slope Length",
        "ar": "Slope Length"
      }
    },
    {
      "id": "frictionCoeff",
      "label": "Friction Coefficient",
      "type": "number",
      "unit": "dimensionless",
      "default": "0.1",
      "businessContext": "Coefficient of kinetic friction between snowboard and snow.",
      "label_i18n": {
        "en": "Friction Coefficient",
        "tr": "Friction Coefficient",
        "de": "Friction Coefficient",
        "fr": "Friction Coefficient",
        "es": "Friction Coefficient",
        "ar": "Friction Coefficient"
      }
    },
    {
      "id": "mass",
      "label": "Rider + Board Mass",
      "type": "number",
      "unit": "kg",
      "default": "75",
      "businessContext": "Total mass of the snowboarder and equipment.",
      "label_i18n": {
        "en": "Rider + Board Mass",
        "tr": "Rider + Board Mass",
        "de": "Rider + Board Mass",
        "fr": "Rider + Board Mass",
        "es": "Rider + Board Mass",
        "ar": "Rider + Board Mass"
      }
    }
  ],
  "formulas": {
    "acceleration": "9.81 * (Math.sin(slopeAngle * Math.PI / 180) - frictionCoeff * Math.cos(slopeAngle * Math.PI / 180))",
    "finalVelocity": "Math.sqrt(2 * (9.81 * (Math.sin(slopeAngle * Math.PI / 180) - frictionCoeff * Math.cos(slopeAngle * Math.PI / 180))) * slopeLength)",
    "travelTime": "Math.sqrt(2 * slopeLength / (9.81 * (Math.sin(slopeAngle * Math.PI / 180) - frictionCoeff * Math.cos(slopeAngle * Math.PI / 180))))",
    "kineticEnergy": "0.5 * mass * (2 * (9.81 * (Math.sin(slopeAngle * Math.PI / 180) - frictionCoeff * Math.cos(slopeAngle * Math.PI / 180))) * slopeLength)"
  },
  "outputs": {
    "primary": "finalVelocity",
    "breakdown": [
      "acceleration",
      "travelTime",
      "kineticEnergy"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

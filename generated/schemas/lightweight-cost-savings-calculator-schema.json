  "validation": {
    "rules": [
      {
        "id": "weight_reduction_positive",
        "condition": "new_weight_kg < current_weight_kg",
        "message": "New weight must be less than current weight to achieve savings."
      },
      {
        "id": "volume_positive",
        "condition": "annual_volume_units > 0",
        "message": "Annual volume must be greater than zero."
      },
      {
        "id": "material_cost_positive",
        "condition": "material_cost_per_kg >= 0",
        "message": "Material cost cannot be negative."
      },
      {
        "id": "waste_rate_range",
        "condition": "waste_rate_percent >= 0 AND waste_rate_percent <= 100",
        "message": "Waste rate must be between 0% and 100%."
      }
    ],
    "thresholds": [
      {
        "id": "savings_alert_low",
        "condition": "total_annual_savings < 10000",
        "level": "warning",
        "message": "Annual savings are low; consider larger volume or greater weight reduction."
      },
      {
        "id": "savings_alert_high",
        "condition": "total_annual_savings > 1000000",
        "level": "success",
        "message": "Significant annual savings achieved; recommend further optimization."
      },
      {
        "id": "payback_alert",
        "condition": "payback_period_years > 3",
        "level": "warning",
        "message": "Payback period exceeds 3 years; evaluate investment risk."
      }
    ]
  },
  "formulas": {
    "result": "current_weight_kg + new_weight_kg + annual_volume_units",
    "result_copy": "current_weight_kg + new_weight_kg + annual_volume_units"
  },
  "outputs": {

  "formulas": {
    "CashInflow": "SUM(Receipts_t)",
    "CashOutflow": "SUM(Payments_t)",
    "NetCashFlow_t": "CashInflow_t - CashOutflow_t",
    "CumulativeCashFlow": "SUM(NetCashFlow_t)",
    "CashGap": "MAX(0, -MIN(CumulativeCashFlow))",
    "DSO": "(AccountsReceivable / TotalCreditSales) * Days",
    "DPO": "(AccountsPayable / TotalCreditPurchases) * Days",
    "DIO": "(Inventory / COGS) * Days",
    "CashConversionCycle": "DSO + DIO - DPO",
    "FinancingCost": "CashGap * DailyInterestRate"
  },

      }
    },
    {
      "id": "baseVG",
      "label": "Base VG%",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "VG percentage in nicotine base (rest is PG)",
      "label_i18n": {
        "en": "Base VG%",
        "tr": "Baz VG%",
        "de": "Base VG%",
        "fr": "Base VG%",
        "es": "Base VG%",
        "ar": "Base VG%"
      },
      "businessContext_i18n": {
        "en": "VG percentage in nicotine base (rest is PG)",
        "tr": "Nikotin bazındaki VG yüzdesi (geri kalanı PG'dir)"
      }
    },
    {
      "id": "desiredVG",
      "label": "Desired VG%",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Target VG percentage in the final mix",
      "label_i18n": {
        "en": "Desired VG%",
        "tr": "İstenen VG%",
        "de": "Desired VG%",
        "fr": "Desired VG%",
        "es": "Desired VG%",
        "ar": "Desired VG%"
      },
      "businessContext_i18n": {
        "en": "Target VG percentage in the final mix",
        "tr": "Nihai karışımdaki hedef VG yüzdesi"
      }
    }
  ],
  "formulas": {
    "requiredBaseVolume": "(targetNicotine * finalVolume) / baseNicotine",
    "additionalPG": "(finalVolume * (100 - desiredVG) / 100) - (((targetNicotine * finalVolume) / baseNicotine) * (100 - baseVG) / 100)",
    "additionalVG": "(finalVolume * desiredVG / 100) - (((targetNicotine * finalVolume) / baseNicotine) * baseVG / 100)"
  },
  "outputs": {
    "primary": "requiredBaseVolume",
    "breakdown": [
      "additionalPG",
      "additionalVG"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "additionalVG",
    "unit": "mg/ml"
  },

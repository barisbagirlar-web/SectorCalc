    },
    {
      "id": "baseNicotine",
      "label": "Nicotine Base Concentration",
      "type": "number",
      "unit": "mg/ml",
      "default": 100,
      "businessContext": "Nicotine concentration of the base liquid",
      "label_i18n": {
        "en": "Nicotine Base Concentration",
        "tr": "Nikotin baz konsantrasyonu",
        "de": "Nicotine Base Concentration",
        "fr": "Nicotine Base Concentration",

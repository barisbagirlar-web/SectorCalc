{
  "toolName": "meal-prep-calculator",
  "inputs": [
    {
      "id": "desiredServings",
      "label": "Number of Servings Needed",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "Total meals you intend to prepare"
    },
    {
      "id": "recipeServings",
      "label": "Servings per Recipe",
      "type": "number",
      "unit": "servings",
      "default": 4,
      "businessContext": "Servings yielded by one full recipe batch"
    },
    {
      "id": "recipeCost",
      "label": "Total Recipe Cost",
      "type": "number",
      "unit": "EUR",
      "default": 12.5,
      "businessContext": "Cost of all raw ingredients for one recipe batch"
    },
    {
      "id": "wastePercentage",
      "label": "Expected Waste",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of ingredients lost to trimming, spillage, or overcooking"
    },
    {
      "id": "packagingCostPerServing",
      "label": "Packaging Cost per Serving",
      "type": "number",
      "unit": "EUR",
      "default": 0.3,
      "businessContext": "Cost of disposable containers, foil, film per portion"
    },
    {
      "id": "fixedCost",
      "label": "Fixed Costs",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Equipment rental, utilities, or any one-time overhead"
    }
  ],
  "formulas": {
    "effectiveServingsPerBatch": "recipeServings * (1 - wastePercentage / 100)",
    "numberOfBatches": "Math.ceil(desiredServings / effectiveServingsPerBatch)",
    "totalIngredientCost": "numberOfBatches * recipeCost",
    "totalPackagingCost": "desiredServings * packagingCostPerServing",
    "totalVariableCost": "totalIngredientCost + totalPackagingCost",
    "totalCost": "totalVariableCost + fixedCost",
    "costPerServing": "totalCost / desiredServings",
    "wastedServings": "numberOfBatches * recipeServings - desiredServings"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "costPerServing",
      "numberOfBatches",
      "totalIngredientCost",
      "totalPackagingCost",
      "wastedServings"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "denizcilik",
  "profession": "Gemi Mühendisi",
  "categoryId": "cost"
}

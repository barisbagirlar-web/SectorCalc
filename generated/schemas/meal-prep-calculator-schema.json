{
  "toolName": "meal-prep-calculator",
  "inputs": [
    {
      "id": "desiredServings",
      "label": "Number of Servings Needed",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "Total meals you intend to prepare",
      "label_i18n": {
        "en": "Number of Servings Needed",
        "tr": "Number of Servings Needed",
        "de": "Number of Servings Needed",
        "fr": "Number of Servings Needed",
        "es": "Number of Servings Needed",
        "ar": "Number of Servings Needed"
      }
    },
    {
      "id": "recipeServings",
      "label": "Servings per Recipe",
      "type": "number",
      "unit": "servings",

        "de": "Servings per Recipe",
        "fr": "Servings per Recipe",
        "es": "Servings per Recipe",
        "ar": "Servings per Recipe"
      }
    },
    {
      "id": "recipeCost",
      "label": "Total Recipe Cost",
      "type": "number",
      "unit": "EUR",
      "default": 12.5,
      "businessContext": "Cost of all raw ingredients for one recipe batch",
      "label_i18n": {
        "en": "Total Recipe Cost",
        "tr": "Total Recipe Cost",
        "de": "Total Recipe Cost",
        "fr": "Total Recipe Cost",
        "es": "Total Recipe Cost",
        "ar": "Total Recipe Cost"
      }
    },
    {
      "id": "wastePercentage",
      "label": "Expected Waste",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of ingredients lost to trimming, spillage, or overcooking",
      "label_i18n": {
        "en": "Expected Waste",
        "tr": "Expected Waste",
        "de": "Expected Waste",
        "fr": "Expected Waste",
        "es": "Expected Waste",
        "ar": "Expected Waste"
      }
    },
    {
      "id": "packagingCostPerServing",
      "label": "Packaging Cost per Serving",
      "type": "number",
      "unit": "EUR",
      "default": 0.3,
      "businessContext": "Cost of disposable containers, foil, film per portion",
      "label_i18n": {
        "en": "Packaging Cost per Serving",
        "tr": "Packaging Cost per Serving",
        "de": "Packaging Cost per Serving",
        "fr": "Packaging Cost per Serving",
        "es": "Packaging Cost per Serving",
        "ar": "Packaging Cost per Serving"
      }
    },
    {
      "id": "fixedCost",
      "label": "Fixed Costs",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Equipment rental, utilities, or any one-time overhead",
      "label_i18n": {
        "en": "Fixed Costs",
        "tr": "Fixed Costs",
        "de": "Fixed Costs",
        "fr": "Fixed Costs",
        "es": "Fixed Costs",
        "ar": "Fixed Costs"
      }
    }
  ],
  "formulas": {
    "effectiveServingsPerBatch": "recipeServings * (1 - wastePercentage / 100)",
    "totalPackagingCost": "desiredServings * packagingCostPerServing"
  },
  "outputs": {
    "primary": "totalPackagingCost",
    "breakdown": [
      "costPerServing",
      "numberOfBatches",
      "totalIngredientCost",
      "totalPackagingCost",
      "wastedServings"
    ],

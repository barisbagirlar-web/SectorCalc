        "ar": "Titrant Volume (mL)"
      }
    },
    {
      "id": "titrantConcentration",
      "label": "Titrant Concentration (mol/L)",
      "type": "number",
      "unit": "mol/L",
      "default": 0.1,
      "businessContext": "Concentration of the standard titrant solution",
      "label_i18n": {
        "en": "Titrant Concentration (mol/L)",
        "tr": "Titrant Concentration (mol/L)",
        "de": "Titrant Concentration (mol/L)",
        "fr": "Titrant Concentration (mol/L)",
        "es": "Titrant Concentration (mol/L)",
        "ar": "Titrant Concentration (mol/L)"
      }
    },
    {
      "id": "titrantProticity",
      "label": "Titrant Proticity",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of reactive H+ or OH- per titrant molecule",
      "label_i18n": {
        "en": "Titrant Proticity",
        "tr": "Titrant Proticity",
        "de": "Titrant Proticity",
        "fr": "Titrant Proticity",
        "es": "Titrant Proticity",
        "ar": "Titrant Proticity"
      }
    },
    {
      "id": "analyteVolume",
      "label": "Analyte Volume (mL)",
      "type": "number",
      "unit": "mL",
      "default": 50,
      "businessContext": "Volume of the analyte sample taken for titration",
      "label_i18n": {
        "en": "Analyte Volume (mL)",
        "tr": "Analyte Volume (mL)",
        "de": "Analyte Volume (mL)",
        "fr": "Analyte Volume (mL)",
        "es": "Analyte Volume (mL)",
        "ar": "Analyte Volume (mL)"
      }
    },
    {
      "id": "analyteProticity",
      "label": "Analyte Proticity",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of reactive H+ or OH- per analyte molecule",
      "label_i18n": {
        "en": "Analyte Proticity",
        "tr": "Analyte Proticity",
        "de": "Analyte Proticity",
        "fr": "Analyte Proticity",
        "es": "Analyte Proticity",
        "ar": "Analyte Proticity"
      }
    }
  ],
  "formulas": {
    "analyteConcentration": "(titrantConcentration * titrantVolume * titrantProticity) / (analyteVolume * analyteProticity)",
    "molesTitrant": "(titrantVolume / 1000) * titrantConcentration * titrantProticity",
    "molesAnalyteEquivalent": "(titrantVolume / 1000) * titrantConcentration * titrantProticity"
  },
  "outputs": {
    "primary": "analyteConcentration",
    "breakdown": [
      "molesTitrant",
      "molesAnalyteEquivalent"
    ]
  },

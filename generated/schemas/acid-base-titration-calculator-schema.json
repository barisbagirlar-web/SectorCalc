{
  "toolName": "acid-base-titration-calculator",
  "inputs": [
    {
      "id": "titrantVolume",
      "label": "Titrant Volume (mL)",
      "type": "number",
      "unit": "mL",
      "default": 25,
      "businessContext": "Volume of titrant used to reach the equivalence point",
      "label_i18n": {
        "en": "Titrant Volume (mL)",
        "tr": "Titrant Volume (mL)",
        "de": "Titrant Volume (mL)",

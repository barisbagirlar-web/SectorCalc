      }
    },
    {
      "id": "frictionLoss",
      "label": "Friction Loss",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Estimated friction loss in piping and fittings.",
      "label_i18n": {
        "en": "Friction Loss",
        "tr": "Sürtünme Kaybı",
        "de": "Friction Loss",
        "fr": "Friction Loss",
        "es": "Friction Loss",
        "ar": "Friction Loss"
      },
      "businessContext_i18n": {
        "en": "Estimated friction loss in piping and fittings.",
        "tr": "Boru ve bağlantı elemanlarında tahmini sürtünme kaybı."
      }
    },
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "m³/h",
      "default": 10,
      "businessContext": "Desired volumetric flow rate.",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Debi",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      },
      "businessContext_i18n": {
        "en": "Desired volumetric flow rate.",
        "tr": "İstenen hacimsel debi."
      }
    },
    {
      "id": "pumpEfficiency",
      "label": "Pump Efficiency",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Pump efficiency (typically 50–85%).",
      "label_i18n": {
        "en": "Pump Efficiency",
        "tr": "Pompa Verimliliği",
        "de": "Pump Efficiency",
        "fr": "Pump Efficiency",
        "es": "Pump Efficiency",
        "ar": "Pump Efficiency"
      },
      "businessContext_i18n": {
        "en": "Pump efficiency (typically 50–85%).",
        "tr": "Pompa verimliliği (tipik olarak %50–85)."
      }
    }
  ],
  "formulas": {
    "totalDynamicHead": "staticWaterLevel + drawdown + dischargeHead + frictionLoss",
    "hydraulicPower": "(flowRate * totalDynamicHead * 9.81) / 3600",
    "pumpPower": "hydraulicPower / (pumpEfficiency / 100)"
  },
  "outputs": {
    "primary": "pumpPower",
    "breakdown": [
      "totalDynamicHead",
      "hydraulicPower"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pumpPower",
    "unit": "m"
  },

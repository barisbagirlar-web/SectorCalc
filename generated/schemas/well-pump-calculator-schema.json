{
  "toolName": "well-pump-calculator",
  "inputs": [
    {
      "id": "staticWaterLevel",
      "label": "Static Water Level",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Depth from ground surface to water level when not pumping.",
      "label_i18n": {
        "en": "Static Water Level",

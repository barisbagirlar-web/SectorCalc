        "fr": "Drawdown",
        "es": "Drawdown",
        "ar": "Drawdown"
      },
      "businessContext_i18n": {
        "en": "Additional drop in water level during pumping.",
        "tr": "Pompalama sırasında su seviyesindeki ek düşüş."
      }
    },
    {
      "id": "dischargeHead",
      "label": "Discharge Head",
      "type": "number",
      "unit": "m",
      "default": 20,
      "businessContext": "Pressure head required at discharge point (1 bar ≈ 10.2 m).",
      "label_i18n": {
        "en": "Discharge Head",

{
  "toolName": "belt-pulley-speed-length-calculator",
  "inputs": [
    {
      "id": "driverPulleyDiameter",
      "label": "Driver Pulley Diameter",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "min": 10,
      "max": 5000,
      "options": null,
      "businessContext": "Diameter of the driving pulley. Standard belt drive design per ISO 5293."
    },
    {
      "id": "drivenPulleyDiameter",
      "label": "Driven Pulley Diameter",
      "type": "number",
      "unit": "mm",
      "default": 200,
      "min": 10,
      "max": 5000,
      "options": null,
      "businessContext": "Diameter of the driven pulley. Standard belt drive design per ISO 5293."
    },
    {
      "id": "centerDistance",
      "label": "Center Distance",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "min": 50,
      "max": 10000,
      "options": null,
      "businessContext": "Distance between pulley centers. Affects belt length and tension."
    },
    {
      "id": "driverSpeed",
      "label": "Driver Speed",
      "type": "number",
      "unit": "RPM",
      "default": 1500,
      "min": 1,
      "max": 10000,
      "options": null,
      "businessContext": "Rotational speed of the driving pulley."
    },
    {
      "id": "beltType",
      "label": "Belt Type",
      "type": "select",
      "unit": "",
      "default": "V-belt",
      "min": null,
      "max": null,
      "options": [
        "V-belt",
        "Timing belt",
        "Flat belt"
      ],
      "businessContext": "Type of belt affects length calculation and speed ratio."
    }
  ],
  "validation": {
    "rules": [
      "driverPulleyDiameter > 0",
      "drivenPulleyDiameter > 0",
      "centerDistance > (driverPulleyDiameter + drivenPulleyDiameter)/2",
      "driverSpeed > 0"
    ],
    "thresholds": {
      "speedRatio": "If speedRatio > 5, warning: 'High speed ratio may require special belt'",
      "beltSpeed": "If beltSpeed > 30 m/s, warning: 'Belt speed exceeds typical limit'"
    }
  },
  "formulas": {
    "speedRatio": "driverSpeed / (drivenPulleyDiameter / driverPulleyDiameter)",
    "drivenSpeed": "driverSpeed * (driverPulleyDiameter / drivenPulleyDiameter)",
    "beltLength": "2 * centerDistance + (Math.PI * (driverPulleyDiameter + drivenPulleyDiameter) / 2) + (Math.pow(drivenPulleyDiameter - driverPulleyDiameter, 2) / (4 * centerDistance))",
    "beltSpeed": "Math.PI * driverPulleyDiameter * driverSpeed / 60000"
  },
  "outputs": {
    "primary": "drivenSpeed",
    "breakdown": {
      "speedRatio": "speedRatio",
      "beltLength": "beltLength",
      "beltSpeed": "beltSpeed"
    },
    "hiddenLossDrivers": [
      "speedRatio > 5 ? 'High speed ratio' : null",
      "beltSpeed > 30 ? 'Excessive belt speed' : null"
    ],
    "suggestedActions": [
      "If speedRatio > 5, consider using a two-stage drive",
      "If beltSpeed > 30 m/s, reduce driver speed or increase pulley diameter"
    ],
    "dataConfidenceAdjusted": "drivenSpeed * (1 - 0.05)"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Comparison with multiple configurations",
    "Detailed report with tension recommendations"
  ],
  "premiumRequired": true
}

{
  "toolName": "fitbit-calorie-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Yaş",
      "type": "number",
      "unit": "yıl",
      "default": 30,
      "businessContext": "Kullanıcının yıl cinsinden yaşı"
    },
    {
      "id": "gender",
      "label": "Cinsiyet (0: Kadın, 1: Erkek)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Cinsiyet: 0 kadın, 1 erkek"
    },
    {
      "id": "weight",
      "label": "Ağırlık",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Kullanıcının kilogram cinsinden vücut ağırlığı"
    },
    {
      "id": "height",
      "label": "Boy",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Kullanıcının santimetre cinsinden boyu"
    },
    {
      "id": "activityFactor",
      "label": "Aktivite Faktörü",
      "type": "number",
      "unit": "",
      "default": 1.2,
      "businessContext": "Sedanter:1.2, Hafif aktif:1.375, Orta aktif:1.55, Çok aktif:1.725, Ekstra aktif:1.9"
    }
  ],
  "formulas": {
    "bmr": "(gender === 1 ? (10*weight + 6.25*height - 5*age + 5) : (10*weight + 6.25*height - 5*age - 161))",
    "tdee": "bmr * activityFactor"
  },
  "outputs": {
    "primary": "tdee",
    "breakdown": [
      "bmr",
      "activityFactor"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false
}
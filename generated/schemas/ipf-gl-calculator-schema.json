{
  "toolName": "ipf-gl-calculator",
  "inputs": [
    {
      "id": "thermal_conductivity",
      "label": "Thermal Conductivity (k)",
      "type": "number",
      "unit": "W/(m·K)",
      "default": 0.04,
      "businessContext": "Material's thermal conductivity"
    },
    {
      "id": "thickness",
      "label": "Insulation Thickness",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Thickness of insulation layer"
    },
    {
      "id": "area",
      "label": "Surface Area",
      "type": "number",
      "unit": "m²",
      "default": 10,
      "businessContext": "Area of insulated surface"
    },
    {
      "id": "temp_hot",
      "label": "Hot Side Temperature",
      "type": "number",
      "unit": "°C",
      "default": 80,
      "businessContext": "Temperature on the hot side"
    },
    {
      "id": "temp_cold",
      "label": "Cold Side Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature on the cold side"
    },
    {
      "id": "u_target",
      "label": "Target U-value",
      "type": "number",
      "unit": "W/(m²·K)",
      "default": 0.5,
      "businessContext": "Required maximum U-value per GL guidelines"
    }
  ],
  "formulas": {
    "u_actual": "(thermal_conductivity * 1000) / thickness",
    "ipf": "u_target / ((thermal_conductivity * 1000) / thickness)",
    "heat_loss": "((thermal_conductivity * 1000) / thickness) * area * (temp_hot - temp_cold)"
  },
  "outputs": {
    "primary": "ipf",
    "breakdown": [
      "u_actual",
      "heat_loss"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "categorySlug": "metal-plastics-forming",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

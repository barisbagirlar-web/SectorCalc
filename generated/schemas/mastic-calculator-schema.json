    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage to account for material loss during application.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Atık Faktörü",
        "de": "Waste Factor",
        "fr": "Waste Factor",

{
  "toolName": "mastic-calculator",
  "inputs": [
    {
      "id": "jointLength",
      "label": "Joint Length",
      "type": "number",
      "unit": "mm",
      "default": 1000,
      "businessContext": "The linear length of one joint to be filled with mastic.",
      "label_i18n": {
        "en": "Joint Length",
        "tr": "Joint Length",
        "de": "Joint Length",
        "fr": "Joint Length",
        "es": "Joint Length",
        "ar": "Joint Length"
      }
    },
    {
      "id": "jointWidth",
      "label": "Joint Width",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "The width of the joint gap.",
      "label_i18n": {
        "en": "Joint Width",
        "tr": "Joint Width",
        "de": "Joint Width",
        "fr": "Joint Width",
        "es": "Joint Width",
        "ar": "Joint Width"
      }
    },
    {
      "id": "jointDepth",
      "label": "Joint Depth",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "The depth of the joint to be filled.",
      "label_i18n": {
        "en": "Joint Depth",
        "tr": "Joint Depth",
        "de": "Joint Depth",
        "fr": "Joint Depth",
        "es": "Joint Depth",
        "ar": "Joint Depth"
      }
    },
    {
      "id": "numberOfJoints",
      "label": "Number of Joints",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total number of joints of the same dimensions.",
      "label_i18n": {
        "en": "Number of Joints",
        "tr": "Number of Joints",
        "de": "Number of Joints",
        "fr": "Number of Joints",
        "es": "Number of Joints",
        "ar": "Number of Joints"
      }
    },
    {
      "id": "cartridgeVolume",
      "label": "Cartridge Volume",
      "type": "number",
      "unit": "ml",
      "default": 300,
      "businessContext": "Net volume of mastic in one standard cartridge.",
      "label_i18n": {
        "en": "Cartridge Volume",
        "tr": "Cartridge Volume",
        "de": "Cartridge Volume",
        "fr": "Cartridge Volume",
        "es": "Cartridge Volume",
        "ar": "Cartridge Volume"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage to account for material loss during application.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "totalVolumeMl": "jointLength * jointWidth * jointDepth * numberOfJoints / 1000",
    "totalVolumeWithWasteMl": "totalVolumeMl * (1 + wasteFactor / 100)",
    "cartridgesNeeded": "Math.ceil(totalVolumeWithWasteMl / cartridgeVolume)"
  },
  "outputs": {
    "primary": "cartridgesNeeded",
    "breakdown": [
      "totalVolumeMl",
      "totalVolumeWithWasteMl"
    ]
  },
  "category": "Çevre & Emisyon",
  "sector": "Sürdürülebilirlik",
  "premiumRequired": false,

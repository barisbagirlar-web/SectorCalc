  "formulas": {
    "totalVolumeMl": "jointLength * jointWidth * jointDepth * numberOfJoints / 1000",
    "totalVolumeWithWasteMl": "totalVolumeMl * (1 + wasteFactor / 100)"
  },
  "outputs": {
    "primary": "totalVolumeWithWasteMl",
    "breakdown": [
      "totalVolumeMl",
      "totalVolumeWithWasteMl"
    ],

{
  "toolName": "tankless-water-heater-calculator",
  "inputs": [
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "L/min",
      "default": 6,
      "businessContext": "Volumetric flow rate of water through the heater",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Flow Rate",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      }
    },
    {
      "id": "inletTemp",
      "label": "Inlet Temperature",
      "type": "number",
      "unit": "°C",
      "default": 10,
      "businessContext": "Temperature of incoming cold water",
      "label_i18n": {
        "en": "Inlet Temperature",
        "tr": "Inlet Temperature",
        "de": "Inlet Temperature",
        "fr": "Inlet Temperature",
        "es": "Inlet Temperature",
        "ar": "Inlet Temperature"
      }
    },
    {
      "id": "outletTemp",
      "label": "Outlet Temperature",
      "type": "number",
      "unit": "°C",
      "default": 40,
      "businessContext": "Desired temperature of hot water output",
      "label_i18n": {
        "en": "Outlet Temperature",
        "tr": "Outlet Temperature",
        "de": "Outlet Temperature",
        "fr": "Outlet Temperature",
        "es": "Outlet Temperature",
        "ar": "Outlet Temperature"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 98,
      "businessContext": "Heater thermal efficiency (0-100%)",
      "label_i18n": {
        "en": "Efficiency",
        "tr": "Efficiency",
        "de": "Efficiency",
        "fr": "Efficiency",
        "es": "Efficiency",
        "ar": "Efficiency"
      }
    },
    {
      "id": "energyCost",
      "label": "Energy Cost",
      "type": "number",
      "unit": "per kWh",
      "default": 0.15,
      "businessContext": "Cost of energy (electricity or gas) per kilowatt-hour",
      "label_i18n": {
        "en": "Energy Cost",
        "tr": "Energy Cost",
        "de": "Energy Cost",
        "fr": "Energy Cost",
        "es": "Energy Cost",
        "ar": "Energy Cost"
      }
    },
    {
      "id": "usageTime",
      "label": "Daily Usage",
      "type": "number",
      "unit": "hours",
      "default": 2,
      "businessContext": "Average daily duration of water heater operation",
      "label_i18n": {
        "en": "Daily Usage",
        "tr": "Daily Usage",
        "de": "Daily Usage",
        "fr": "Daily Usage",
        "es": "Daily Usage",
        "ar": "Daily Usage"
      }
    },
    {
      "id": "daysPerMonth",
      "label": "Days per Month",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of days per month for cost estimation",
      "label_i18n": {
        "en": "Days per Month",
        "tr": "Days per Month",
        "de": "Days per Month",
        "fr": "Days per Month",
        "es": "Days per Month",
        "ar": "Days per Month"
      }
    },
    {
      "id": "specificHeat",
      "label": "Specific Heat",
      "type": "number",
      "unit": "kJ/(kg·°C)",
      "default": 4.186,
      "businessContext": "Specific heat capacity of water (4.186 kJ/(kg·°C) for water)",
      "label_i18n": {
        "en": "Specific Heat",
        "tr": "Specific Heat",
        "de": "Specific Heat",
        "fr": "Specific Heat",
        "es": "Specific Heat",
        "ar": "Specific Heat"
      }
    }
  ],
  "formulas": {
    "requiredPower": "(flowRate / 60) * specificHeat * (outletTemp - inletTemp) / (efficiency / 100)",
    "dailyEnergy": "(flowRate / 60) * specificHeat * (outletTemp - inletTemp) / (efficiency / 100) * usageTime",
    "dailyCost": "(flowRate / 60) * specificHeat * (outletTemp - inletTemp) / (efficiency / 100) * usageTime * energyCost",
    "monthlyCost": "(flowRate / 60) * specificHeat * (outletTemp - inletTemp) / (efficiency / 100) * usageTime * energyCost * daysPerMonth",
    "annualCost": "(flowRate / 60) * specificHeat * (outletTemp - inletTemp) / (efficiency / 100) * usageTime * energyCost * 365"
  },
  "outputs": {
    "primary": "requiredPower",
    "breakdown": [
      "dailyEnergy",
      "dailyCost",
      "monthlyCost",
      "annualCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualCost"
  },
  "category": "Akışkanlar & Termodinamik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,

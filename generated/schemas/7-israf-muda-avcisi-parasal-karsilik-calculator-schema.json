{
  "toolName": "7-israf-muda-avcisi-parasal-karsilik-calculator",
  "inputs": [
    {
      "id": "wasteType",
      "label": "İsraf Türü",
      "type": "select",
      "unit": "",
      "default": "overproduction",
      "min": null,
      "max": null,
      "options": [
        "overproduction",
        "waiting",
        "transportation",
        "overprocessing",
        "inventory",
        "motion",
        "defects"
      ],
      "businessContext": "Lean üretimdeki 7 temel muda (israf) türü. Kaynak: Womack & Jones, Lean Thinking."
    },
    {
      "id": "wasteQuantity",
      "label": "İsraf Miktarı",
      "type": "number",
      "unit": "birim/gün",
      "default": 10,
      "min": 0,
      "max": 100000,
      "businessContext": "Günlük oluşan israf miktarı (adet, kg, saat vb.)."
    },
    {
      "id": "unitCost",
      "label": "Birim Maliyet",
      "type": "number",
      "unit": "TL/birim",
      "default": 50,
      "min": 0,
      "max": 100000,
      "businessContext": "İsraf edilen her birimin parasal değeri. Kaynak: ABC maliyetleme."
    },
    {
      "id": "frequency",
      "label": "Sıklık",
      "type": "select",
      "unit": "",
      "default": "daily",
      "min": null,
      "max": null,
      "options": [
        "hourly",
        "daily",
        "weekly",
        "monthly",
        "yearly"
      ],
      "businessContext": "İsrafın hangi periyotta ölçüldüğü."
    },
    {
      "id": "workingDaysPerYear",
      "label": "Yıllık Çalışma Günü",
      "type": "number",
      "unit": "gün/yıl",
      "default": 250,
      "min": 1,
      "max": 365,
      "businessContext": "Yıllık çalışma günü sayısı. Varsayılan: 250 (hafta sonları ve resmi tatil hariç)."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "select",
      "unit": "",
      "default": "medium",
      "min": null,
      "max": null,
      "options": [
        "low",
        "medium",
        "high"
      ],
      "businessContext": "Veri kaynağının güvenilirliği. Düşük güven durumunda sonuçlar daha muhafazakar hesaplanır."
    }
  ],
  "validation": {
    "rules": [
      "wasteQuantity >= 0",
      "unitCost >= 0",
      "workingDaysPerYear >= 1 && workingDaysPerYear <= 365",
      "if wasteType == 'defects' then unitCost > 0"
    ],
    "thresholds": {
      "annualLoss": {
        "critical": 1000000,
        "warning": 500000
      }
    }
  },
  "formulas": {
    "dailyLoss": "wasteQuantity * unitCost",
    "annualLoss": "dailyLoss * (frequency == 'hourly' ? 8 : frequency == 'daily' ? 1 : frequency == 'weekly' ? 1/5 : frequency == 'monthly' ? 1/20 : 1/250) * workingDaysPerYear",
    "dataConfidenceMultiplier": "dataConfidence == 'low' ? 0.8 : dataConfidence == 'medium' ? 1.0 : 1.2",
    "adjustedAnnualLoss": "annualLoss * dataConfidenceMultiplier"
  },
  "outputs": {
    "primary": "adjustedAnnualLoss",
    "breakdown": {
      "dailyLoss": "dailyLoss",
      "annualLoss": "annualLoss",
      "dataConfidenceMultiplier": "dataConfidenceMultiplier"
    },
    "hiddenLossDrivers": [
      "if annualLoss > 1000000 then 'Yıllık kayıp kritik seviyede (>1M TL)'",
      "if annualLoss > 500000 && annualLoss <= 1000000 then 'Yıllık kayıp uyarı seviyesinde (>500K TL)'"
    ],
    "suggestedActions": [
      "İsraf türüne göre kök neden analizi yapın (5 Neden, Balık Kılçığı).",
      "Kaizen etkinlikleri ile israfı azaltmaya yönelik aksiyon planı oluşturun.",
      "Yalın dönüşüm ekibi ile VSM (Değer Akışı Haritalama) çalışması yapın."
    ],
    "dataConfidenceAdjusted": "adjustedAnnualLoss"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi (zaman serisi grafiği)",
    "Karşılaştırma (farklı dönemler veya hatlar arası)",
    "Detaylı rapor (breakdown ve önerilerle)"
  ],
  "premiumRequired": true
}

        "fr": "Mil Alt Sapma",
        "es": "Mil Alt Sapma",
        "ar": "Mil Alt Sapma"
      }
    }
  ],
  "formulas": {
    "holeMax": "nominalDiameter + holeUpperDev",
    "holeMin": "nominalDiameter + holeLowerDev",
    "shaftMax": "nominalDiameter + shaftUpperDev",
    "shaftMin": "nominalDiameter + shaftLowerDev",
    "maxClearance": "holeMax - shaftMin",
    "minClearance": "holeMin - shaftMax",
    "fitTypeCode": "minClearance > 0 ? 1 : (maxClearance < 0 ? 3 : 2)"
  },
  "outputs": {
    "primary": "maxClearance",
    "breakdown": [
      "minClearance",
      "fitTypeCode"
    ],

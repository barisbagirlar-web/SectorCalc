{
  "toolName": "parabolic-dish-calculator",
  "inputs": [
    {
      "id": "cap",
      "label": "Çap (D)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Parabolik çanağın çapı (metre cinsinden)."
    },
    {
      "id": "derinlik",
      "label": "Derinlik (d)",
      "type": "number",
      "unit": "m",
      "default": 0.25,
      "businessContext": "Çanağın merkez derinliği."
    },
    {
      "id": "frekans",
      "label": "Frekans (f)",
      "type": "number",
      "unit": "MHz",
      "default": 3000,
      "businessContext": "İşletim frekansı (MHz)."
    },
    {
      "id": "verim",
      "label": "Verim (η)",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Açıklık verimliliği (yüzde olarak, örn. 60 → %60)."
    }
  ],
  "formulas": {
    "Odak Uzaklığı (m)": "cap ** 2 / (16 * derinlik)",
    "f/D Oranı": "cap / (16 * derinlik)",
    "Açıklık Alanı (m²)": "Math.PI * (cap / 2) ** 2",
    "Dalga Boyu (m)": "299792458 / (frekans * 1e6)",
    "Yarım Güç Hüzme Genişliği (°)": "70 * (299792458 / (frekans * 1e6)) / cap",
    "Kazanç (dBi)": "10 * Math.log10((Math.PI * cap / (299792458 / (frekans * 1e6))) ** 2 * (verim / 100))"
  },
  "outputs": {
    "primary": "Kazanç (dBi)",
    "breakdown": [
      "Odak Uzaklığı (m)",
      "f/D Oranı",
      "Açıklık Alanı (m²)",
      "Dalga Boyu (m)",
      "Yarım Güç Hüzme Genişliği (°)"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

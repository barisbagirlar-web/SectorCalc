{
  "toolName": "vineyard-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Vineyard Area",
      "type": "number",
      "unit": "hectares",
      "default": 5,
      "businessContext": "Total vineyard area in hectares.",
      "label_i18n": {
        "en": "Vineyard Area",
        "tr": "Bağ Alanı",
        "de": "Vineyard Area",
        "fr": "Vineyard Area",
        "es": "Vineyard Area",
        "ar": "Vineyard Area"
      },
      "businessContext_i18n": {
        "en": "Total vineyard area in hectares.",
        "tr": "Hektar cinsinden toplam bağ alanı."
      }
    },
    {
      "id": "vineDensity",
      "label": "Vine Density",
      "type": "number",
      "unit": "vines/ha",
      "default": 4000,
      "businessContext": "Number of vines per hectare.",
      "label_i18n": {
        "en": "Vine Density",
        "tr": "Asma Yoğunluğu",
        "de": "Vine Density",
        "fr": "Vine Density",
        "es": "Vine Density",
        "ar": "Vine Density"
      },
      "businessContext_i18n": {
        "en": "Number of vines per hectare.",
        "tr": "Hektar başına asma sayısı."
      }
    },
    {
      "id": "yieldPerVine",
      "label": "Grape Yield per Vine",
      "type": "number",
      "unit": "kg/vine",
      "default": 2.5,
      "businessContext": "Average grape yield per vine in kilograms.",
      "label_i18n": {
        "en": "Grape Yield per Vine",
        "tr": "Asma Başına Üzüm Verimi",
        "de": "Grape Yield per Vine",
        "fr": "Grape Yield per Vine",
        "es": "Grape Yield per Vine",
        "ar": "Grape Yield per Vine"
      },
      "businessContext_i18n": {
        "en": "Average grape yield per vine in kilograms.",
        "tr": "Asma başına kilogram cinsinden ortalama üzüm verimi."
      }
    },
    {
      "id": "grapePrice",
      "label": "Grape Price",
      "type": "number",
      "unit": "$/kg",
      "default": 1.2,
      "businessContext": "Selling price per kilogram of grapes.",
      "label_i18n": {
        "en": "Grape Price",
        "tr": "Üzüm Fiyatı",
        "de": "Grape Price",
        "fr": "Grape Price",
        "es": "Grape Price",
        "ar": "Grape Price"
      },
      "businessContext_i18n": {
        "en": "Selling price per kilogram of grapes.",
        "tr": "Kilogram başına üzüm satış fiyatı."
      }
    },
    {
      "id": "costPerHectare",
      "label": "Annual Cost per Hectare",
      "type": "number",
      "unit": "$/ha",
      "default": 5000,
      "businessContext": "Total annual maintenance cost per hectare including labor, water, and other expenses.",
      "label_i18n": {
        "en": "Annual Cost per Hectare",
        "tr": "Yıllık Hektar Başına Maliyet",
        "de": "Annual Cost per Hectare",
        "fr": "Annual Cost per Hectare",
        "es": "Annual Cost per Hectare",
        "ar": "Annual Cost per Hectare"
      },
      "businessContext_i18n": {
        "en": "Total annual maintenance cost per hectare including labor, water, and other expenses.",
        "tr": "İşçilik, su ve diğer giderler dahil olmak üzere hektar başına toplam yıllık bakım maliyeti."
      }
    },
    {
      "id": "wasteRate",
      "label": "Waste Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of grapes lost to waste or spoilage.",
      "label_i18n": {
        "en": "Waste Rate",
        "tr": "Fire Oranı",
        "de": "Waste Rate",
        "fr": "Waste Rate",
        "es": "Waste Rate",
        "ar": "Waste Rate"
      },
      "businessContext_i18n": {
        "en": "Percentage of grapes lost to waste or spoilage.",
        "tr": "Atık veya bozulma nedeniyle kaybedilen üzüm yüzdesi."
      }
    }
  ],
  "formulas": {
    "totalVines": "area * vineDensity",
    "totalGrapesGross": "totalVines * yieldPerVine",
    "wasteAmount": "totalGrapesGross * (wasteRate / 100)",
    "totalGrapesNet": "totalGrapesGross - wasteAmount",
    "totalRevenue": "totalGrapesNet * grapePrice",
    "totalCost": "area * costPerHectare",
    "netProfit": "totalRevenue - totalCost"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "totalGrapesNet",
      "totalRevenue",
      "totalCost",
      "wasteAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netProfit",
    "unit": "hectares"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Birim & Dönüşüm",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",

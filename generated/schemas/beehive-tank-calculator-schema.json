{
  "toolName": "beehive-tank-calculator",
  "inputs": [
    {
      "id": "diameter",
      "label": "Tank Çapı",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Beehive tank inner diameter",
      "label_i18n": {
        "en": "Tank Çapı",
        "tr": "Tank Çapı",
        "de": "Tank Çapı",
        "fr": "Tank Çapı",
        "es": "Tank Çapı",
        "ar": "Tank Çapı"
      }
    },
    {
      "id": "heightCylinder",
      "label": "Silindir Yüksekliği",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "Height of the cylindrical section",
      "label_i18n": {
        "en": "Silindir Yüksekliği",
        "tr": "Silindir Yüksekliği",
        "de": "Silindir Yüksekliği",
        "fr": "Silindir Yüksekliği",
        "es": "Silindir Yüksekliği",
        "ar": "Silindir Yüksekliği"
      }
    },
    {
      "id": "wallThickness",
      "label": "Et Kalınlığı",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Tank wall thickness for material calculation",
      "label_i18n": {
        "en": "Et Kalınlığı",
        "tr": "Et Kalınlığı",
        "de": "Et Kalınlığı",
        "fr": "Et Kalınlığı",
        "es": "Et Kalınlığı",
        "ar": "Et Kalınlığı"
      }
    },
    {
      "id": "materialDensity",
      "label": "Malzeme Yoğunluğu",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "businessContext": "Density of tank material (e.g., steel)",
      "label_i18n": {
        "en": "Malzeme Yoğunluğu",
        "tr": "Malzeme Yoğunluğu",
        "de": "Malzeme Yoğunluğu",
        "fr": "Malzeme Yoğunluğu",
        "es": "Malzeme Yoğunluğu",
        "ar": "Malzeme Yoğunluğu"
      }
    },
    {
      "id": "materialCost",
      "label": "Birim Malzeme Maliyeti",
      "type": "number",
      "unit": "TRY/kg",
      "default": 10,
      "businessContext": "Cost per kg of material",
      "label_i18n": {
        "en": "Birim Malzeme Maliyeti",
        "tr": "Birim Malzeme Maliyeti",
        "de": "Birim Malzeme Maliyeti",
        "fr": "Birim Malzeme Maliyeti",
        "es": "Birim Malzeme Maliyeti",
        "ar": "Birim Malzeme Maliyeti"
      }
    }
  ],
  "formulas": {
    "radius": "diameter / 2",
    "volumeCylinder": "Math.PI * (diameter/2)**2 * heightCylinder",
    "volumeHemisphere": "(2/3) * Math.PI * (diameter/2)**3",
    "totalVolume": "volumeCylinder + volumeHemisphere",
    "surfaceAreaCylinder": "2 * Math.PI * (diameter/2) * heightCylinder",
    "surfaceAreaHemisphere": "2 * Math.PI * (diameter/2)**2",
    "totalSurfaceArea": "surfaceAreaCylinder + surfaceAreaHemisphere",
    "materialVolume": "totalSurfaceArea * (wallThickness / 1000)",
    "materialWeight": "materialVolume * materialDensity",
    "materialCostTotal": "materialWeight * materialCost",
    "Silindir_Hacmi__m__": "Silindir Hacmi (m³)",
    "Kubbe_Hacmi__m__": "Kubbe Hacmi (m³)",
    "Y_zey_Alan___m__": "Yüzey Alanı (m²)",
    "Malzeme_A__rl_____kg_": "Malzeme Ağırlığı (kg)",
    "Malzeme_Maliyeti__TRY_": "Malzeme Maliyeti (TRY)",
    "result": "Toplam Hacim (m³)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Silindir Hacmi (m³)",
      "Kubbe Hacmi (m³)",
      "Yüzey Alanı (m²)",
      "Malzeme Ağırlığı (kg)",
      "Malzeme Maliyeti (TRY)"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "metal-plastics-forming"
}

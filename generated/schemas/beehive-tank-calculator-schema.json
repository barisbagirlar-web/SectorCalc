    },
    {
      "id": "materialCost",
      "label": "Birim Malzeme Maliyeti",
      "type": "number",
      "unit": "TRY/kg",
      "default": 10,
      "businessContext": "Cost per kg of material",
      "label_i18n": {
        "en": "Birim Malzeme Maliyeti",
        "tr": "Birim Malzeme Maliyeti",
        "de": "Materialkosten pro Einheit",
        "fr": "Birim Malzeme Maliyeti",
        "es": "Birim Malzeme Maliyeti",
        "ar": "Birim Malzeme Maliyeti"
      },
      "businessContext_i18n": {
        "en": "Cost per kg of material",
        "tr": "Malzemenin kg başına maliyeti",
        "de": "Kosten pro kg Material"
      }
    }
  ],
  "formulas": {
    "radius": "diameter / 2",
    "volumeCylinder": "Math.PI * (diameter/2)**2 * heightCylinder",
    "volumeHemisphere": "(2/3) * Math.PI * (diameter/2)**3",
    "totalVolume": "volumeCylinder + volumeHemisphere",
    "surfaceAreaCylinder": "2 * Math.PI * (diameter/2) * heightCylinder",
    "surfaceAreaHemisphere": "2 * Math.PI * (diameter/2)**2",
    "totalSurfaceArea": "surfaceAreaCylinder + surfaceAreaHemisphere",
    "materialVolume": "totalSurfaceArea * (wallThickness / 1000)",
    "materialWeight": "materialVolume * materialDensity",
    "materialCostTotal": "materialWeight * materialCost"
  },
  "outputs": {
    "primary": "materialCostTotal",
    "breakdown": [
      "Silindir Hacmi (m³)",
      "Kubbe Hacmi (m³)",
      "Yüzey Alanı (m²)",
      "Malzeme Ağırlığı (kg)",
      "Malzeme Maliyeti (TRY)"
    ],

  "formulas": {
    "radius": "diameter / 2",
    "volumeCylinder": "Math.PI * (diameter/2)**2 * heightCylinder",
    "volumeHemisphere": "(2/3) * Math.PI * (diameter/2)**3",
    "totalVolume": "volumeCylinder + volumeHemisphere",
    "surfaceAreaCylinder": "2 * Math.PI * (diameter/2) * heightCylinder",
    "surfaceAreaHemisphere": "2 * Math.PI * (diameter/2)**2",
    "totalSurfaceArea": "surfaceAreaCylinder + surfaceAreaHemisphere",
    "materialVolume": "totalSurfaceArea * (wallThickness / 1000)",
    "materialWeight": "materialVolume * materialDensity",
    "materialCostTotal": "materialWeight * materialCost"
  },
  "outputs": {
    "primary": "materialCostTotal",
    "breakdown": [
      "Silindir Hacmi (m³)",
      "Kubbe Hacmi (m³)",
      "Yüzey Alanı (m²)",
      "Malzeme Ağırlığı (kg)",
      "Malzeme Maliyeti (TRY)"
    ],

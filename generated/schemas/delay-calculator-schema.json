      "label": "Kuyrukta Bekleme Gecikmesi",
      "type": "number",
      "unit": "dakika",
      "default": 0,
      "businessContext": "Malzeme veya iş emri kuyruk bekleme süresi gecikmesi"
    },
    {
      "id": "processDelay",
      "label": "İşlem Gecikmesi",
      "type": "number",
      "unit": "dakika",
      "default": 0,
      "businessContext": "İşleme süresindeki gecikme"
    },
    {
      "id": "transportDelay",
      "label": "Taşıma Gecikmesi",
      "type": "number",
      "unit": "dakika",
      "default": 0,
      "businessContext": "Malzeme taşıma veya lojistik gecikmesi"

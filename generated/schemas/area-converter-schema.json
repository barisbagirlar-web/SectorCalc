{
  "toolName": "area-converter",
  "inputs": [
    {
      "id": "value",
      "label": "Value",
      "type": "number",
      "unit": "m²",
      "default": 1,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "The numeric value of the area to be converted. Based on SI unit standard (ISO 80000-3)."
    },
    {
      "id": "fromUnit",
      "label": "From Unit",
      "type": "select",
      "unit": "",
      "default": "m²",
      "min": null,
      "max": null,
      "options": [
        "m²",
        "km²",
        "ha",
        "acre",
        "ft²",
        "in²",
        "yd²",
        "mi²"
      ],
      "businessContext": "The unit of the input area. Common units based on international standards (ISO 80000-3) and US customary units."
    },
    {
      "id": "toUnit",
      "label": "To Unit",
      "type": "select",
      "unit": "",
      "default": "ft²",
      "min": null,
      "max": null,
      "options": [
        "m²",
        "km²",
        "ha",
        "acre",
        "ft²",
        "in²",
        "yd²",
        "mi²"
      ],
      "businessContext": "The target unit for conversion. Same standards as fromUnit."
    }
  ],
  "validation": {
    "rules": [
      "value must be >= 0",
      "fromUnit and toUnit must be different"
    ],
    "thresholds": {}
  },
  "formulas": {
    "conversionFactors": {
      "m²": 1,
      "km²": 1000000,
      "ha": 10000,
      "acre": 4046.8564224,
      "ft²": 0.09290304,
      "in²": 0.00064516,
      "yd²": 0.83612736,
      "mi²": 2589988.110336
    },
    "result": "value * conversionFactors[fromUnit] / conversionFactors[toUnit]"
  },
  "outputs": {
    "primary": "result",
    "breakdown": {
      "valueInSqm": "value * conversionFactors[fromUnit]",
      "conversionFactor": "conversionFactors[fromUnit] / conversionFactors[toUnit]"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [],
    "dataConfidenceAdjusted": "result"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Comparison",
    "Detailed report"
  ],
  "premiumRequired": false
}

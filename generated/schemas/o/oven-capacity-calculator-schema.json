{
  "toolName": "oven-capacity-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "tavaSayisi",
      "label": "Number of Trays",
      "type": "number",
      "unit": "trays",
      "default": 10,
      "min": 0,
      "businessContext": "Trays per batch."
    },
    {
      "id": "tavaKapasite",
      "label": "Tray Capacity (kg)",
      "type": "number",
      "unit": "kg",
      "default": 5,
      "min": 0,
      "businessContext": "Product per tray."
    },
    {
      "id": "pismeSure",
      "label": "Baking Time (min)",
      "type": "number",
      "unit": "min",
      "default": 20,
      "min": 0,
      "businessContext": "Baking time per batch."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(tavaSayisi * tavaKapasite * 60) / Math.max(0.0001, pismeSure)"
  },
  "outputs": {
    "primary": "result",
    "unit": "kg/h",
    "breakdown": {
      "result": "Oven Capacity"
    },
    "breakdownUnits": {
      "result": "kg/h"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling process for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate oven hourly baking capacity.",
      "long": "Calculate oven hourly baking capacity."
    }
  },
  "sectorSlug": "daily-renovation"
}

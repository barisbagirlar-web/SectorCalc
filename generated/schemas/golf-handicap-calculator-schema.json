  "formulas": {
    "differential": "(grossScore - courseRating) * 113 / slopeRating",
    "courseHandicap": "handicapIndex * (slopeRating / 113) + (courseRating - par)"
  },
  "outputs": {
    "primary": "differential",
    "breakdown": [
      "differential",
      "courseHandicap"
    ]
  },

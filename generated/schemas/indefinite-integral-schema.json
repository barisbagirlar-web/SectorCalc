        "de": "Constant (C)",
        "fr": "Constant (C)",
        "es": "Constant (C)",
        "ar": "Constant (C)"
      }
    }
  ],
  "formulas": {
    "integralResult": "functionType === 1 ? (coefficient * (x ** (exponent + 1)) / (exponent + 1)) + constant : functionType === 2 ? (coefficient * Math.exp(x)) + constant : functionType === 3 ? (-coefficient * Math.cos(x)) + constant : 0",
    "x": "1",
    "a____coefficient_": "a = {coefficient}",
    "n____exponent_": "n = {exponent}",
    "C____constant_": "C = {constant}",
    "_integralResult_": "{integralResult}",
    "result": "∫ f(x) dx = (a * x^(n+1))/(n+1) + C"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Coefficient: a = {coefficient}",
      "Exponent: n = {exponent}",
      "Constant: C = {constant}",
      "Result: {integralResult}"
    ]
  },

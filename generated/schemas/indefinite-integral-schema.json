    },
    {
      "id": "exponent",
      "label": "Exponent (n)",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Exponent for polynomial (n != -1)",
      "label_i18n": {
        "en": "Exponent (n)",
        "tr": "Exponent (n)",
        "de": "Exponent (n)",
        "fr": "Exponent (n)",
        "es": "Exponent (n)",

    {
      "id": "stopTime",
      "label": "Time per Stop",
      "type": "number",
      "unit": "minutes",
      "default": 15,
      "businessContext": "Average time spent per stop",
      "label_i18n": {
        "en": "Time per Stop",
        "tr": "Durak Başına Süre",
        "de": "Zeit pro Stopp",
        "fr": "Time per Stop",

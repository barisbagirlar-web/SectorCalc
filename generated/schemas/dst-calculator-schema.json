  "formulas": {
    "travelTime": "distance / averageSpeed",
    "totalTime": "travelTime + (numStops * stopTime / 60)",
    "fuelConsumed": "(distance / 100) * fuelConsumption",
    "fuelCost": "fuelConsumed * fuelPrice"
  },
  "outputs": {
    "primary": "totalTime",
    "breakdown": [
      "travelTime",
      "fuelCost",
      "fuelConsumed"
    ],

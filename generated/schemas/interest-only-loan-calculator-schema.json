{
  "toolName": "interest-only-loan-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Loan Amount (Principal)",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "The amount borrowed.",
      "label_i18n": {
        "en": "Loan Amount (Principal)",
        "tr": "Loan Amount (Principal)",
        "de": "Loan Amount (Principal)",
        "fr": "Loan Amount (Principal)",
        "es": "Loan Amount (Principal)",
        "ar": "Loan Amount (Principal)"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual nominal interest rate on loan.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Total duration of the loan in years.",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    },
    {
      "id": "paymentsPerYear",
      "label": "Payments Per Year",
      "type": "number",
      "unit": "periods/year",
      "default": 12,
      "businessContext": "Number of interest payments made per year (e.g., 12 for monthly).",
      "label_i18n": {
        "en": "Payments Per Year",
        "tr": "Payments Per Year",
        "de": "Payments Per Year",
        "fr": "Payments Per Year",
        "es": "Payments Per Year",
        "ar": "Payments Per Year"
      }
    }
  ],
  "formulas": {
    "periodicInterestPayment": "principal * (annualInterestRate / 100) / paymentsPerYear",
    "totalInterest": "periodicInterestPayment * loanTermYears * paymentsPerYear",
    "totalPayment": "totalInterest"
  },
  "outputs": {
    "primary": "periodicInterestPayment",
    "breakdown": [
      "totalInterest",
      "totalPayment"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPayment"
  },

        "ar": "Kabarma Faktörü"
      }
    },
    {
      "id": "wasteFactorPercent",
      "label": "Fire/Zayiat Faktörü",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Dökülme, sızıntı vb. kayıplar",
      "label_i18n": {
        "en": "Fire/Zayiat Faktörü",
        "tr": "Fire/Zayiat Faktörü",
        "de": "Fire/Zayiat Faktörü",
        "fr": "Fire/Zayiat Faktörü",
        "es": "Fire/Zayiat Faktörü",
        "ar": "Fire/Zayiat Faktörü"
      }
    },
    {
      "id": "truckCapacity",
      "label": "Kamyon Kapasitesi",
      "type": "number",
      "unit": "m³",
      "default": 10,
      "businessContext": "Bir kamyonun taşıma kapasitesi",
      "label_i18n": {
        "en": "Kamyon Kapasitesi",
        "tr": "Kamyon Kapasitesi",
        "de": "Kamyon Kapasitesi",
        "fr": "Kamyon Kapasitesi",
        "es": "Kamyon Kapasitesi",
        "ar": "Kamyon Kapasitesi"
      }
    }
  ],
  "formulas": {
    "totalLooseVolume": "bankVolume * (1 + swellFactorPercent/100) * (1 + wasteFactorPercent/100)",
    "swellRatio": "swellFactorPercent / 100",
    "volumeIncrease": "bankVolume * (swellFactorPercent / 100)",
    "adjustedVolumeIncrease": "(bankVolume * (1 + swellFactorPercent/100) * (1 + wasteFactorPercent/100)) - bankVolume",
    "loadsRequired": "(bankVolume * (1 + swellFactorPercent/100) * (1 + wasteFactorPercent/100)) / truckCapacity"
  },
  "outputs": {
    "primary": "totalLooseVolume",
    "breakdown": [
      "swellRatio",
      "volumeIncrease",
      "adjustedVolumeIncrease",
      "loadsRequired"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "loadsRequired",
    "unit": "m³",
    "breakdownUnits": {
      "swellRatio": "%"
    }
  },

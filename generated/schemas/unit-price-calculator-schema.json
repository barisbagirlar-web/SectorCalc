      "id": "totalCost",
      "label": "Total Cost",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "Total cost of goods or services before additional costs and discounts.",
      "label_i18n": {
        "en": "Total Cost",
        "tr": "Total Cost",
        "de": "Total Cost",
        "fr": "Total Cost",
        "es": "Total Cost",
        "ar": "Total Cost"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Number of units purchased.",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Quantity",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      }
    },
    {
      "id": "additionalCosts",
      "label": "Additional Costs",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Extra costs such as shipping, handling, or setup fees.",
      "label_i18n": {
        "en": "Additional Costs",
        "tr": "Additional Costs",
        "de": "Additional Costs",
        "fr": "Additional Costs",
        "es": "Additional Costs",
        "ar": "Additional Costs"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Discount percentage applied to the total cost.",
      "label_i18n": {
        "en": "Discount (%)",
        "tr": "Discount (%)",
        "de": "Discount (%)",
        "fr": "Discount (%)",
        "es": "Discount (%)",
        "ar": "Discount (%)"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Sales tax or VAT percentage applied after discount.",
      "label_i18n": {
        "en": "Tax Rate (%)",
        "tr": "Tax Rate (%)",
        "de": "Tax Rate (%)",
        "fr": "Tax Rate (%)",
        "es": "Tax Rate (%)",
        "ar": "Tax Rate (%)"
      }
    }
  ],
  "formulas": {
    "discountAmount": "totalCost * discountPercent / 100",
    "netUnitPrice": "(totalCost + additionalCosts - (totalCost * discountPercent / 100)) / quantity",
    "unitPrice": "((totalCost + additionalCosts - (totalCost * discountPercent / 100)) / quantity) * (1 + taxRate / 100)"
  },
  "outputs": {
    "primary": "unitPrice",
    "breakdown": [
      "netUnitPrice",
      "discountAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "unitPrice"
  },

        "de": "Körpergewicht in Kilogramm",
        "fr": "Poids corporel en kilogrammes",
        "es": "Peso corporal en kilogramos",
        "ar": "وزن الجسم بالكيلوجرام"
      }
    },
    {
      "id": "drinks",
      "label": "Number of Drinks",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Standard drinks (14g ethanol each)",
      "label_i18n": {
        "en": "Number of Drinks",
        "tr": "İçecek Sayısı",
        "de": "Anzahl der Getränke",
        "fr": "Nombre de verres",
        "es": "Número de bebidas",
        "ar": "عدد المشروبات"
      },
      "businessContext_i18n": {

      }
    },
    {
      "id": "hours",
      "label": "Hours Since First Drink",
      "type": "number",
      "unit": "hours",
      "default": 1,
      "businessContext": "Time elapsed since start of drinking",
      "label_i18n": {
        "en": "Hours Since First Drink",
        "tr": "İlk İçkiden Bu Yana Geçen Saat",
        "de": "Stunden seit dem ersten Getränk",
        "fr": "Heures depuis le premier verre",
        "es": "Horas desde la primera bebida",
        "ar": "الساعات منذ أول مشروب"
      },
      "businessContext_i18n": {
        "en": "Time elapsed since start of drinking",
        "tr": "İçmeye başladıktan sonra geçen süre",
        "de": "Verstrichene Zeit seit Beginn des Trinkens",
        "fr": "Temps écoulé depuis le début de la consommation",
        "es": "Tiempo transcurrido desde el inicio de la ingesta",
        "ar": "الوقت المنقضي منذ بدء الشرب"
      }
    },
    {
      "id": "alcoholPercentage",
      "label": "Alcohol Percentage per Drink",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Alcohol by volume (ABV) per drink",
      "label_i18n": {
        "en": "Alcohol Percentage per Drink",
        "tr": "İçki Başına Alkol Yüzdesi",
        "de": "Alkoholanteil pro Getränk",
        "fr": "Pourcentage d'alcool par verre",
        "es": "Porcentaje de alcohol por bebida",
        "ar": "نسبة الكحول لكل مشروب"
      },
      "businessContext_i18n": {
        "en": "Alcohol by volume (ABV) per drink",
        "tr": "İçki başına hacimce alkol oranı (ABV)",
        "de": "Alkoholvolumen (ABV) pro Getränk",
        "fr": "Taux d'alcool par volume (ABV) par verre",
        "es": "Graduación alcohólica (ABV) por bebida",
        "ar": "نسبة الكحول بالحجم لكل مشروب"
      }
    },
    {
      "id": "volumePerDrink",
      "label": "Volume per Drink",
      "type": "number",
      "unit": "ml",
      "default": 355,
      "businessContext": "Volume of one drink in milliliters",
      "label_i18n": {
        "en": "Volume per Drink",
        "tr": "İçki Başına Hacim",
        "de": "Volumen pro Getränk",
        "fr": "Volume par verre",
        "es": "Volumen por bebida",
        "ar": "حجم المشروب"
      },
      "businessContext_i18n": {
        "en": "Volume of one drink in milliliters",
        "tr": "Bir içkinin mililitre cinsinden hacmi",
        "de": "Volumen eines Getränks in Millilitern",
        "fr": "Volume d'un verre en millilitres",
        "es": "Volumen de una bebida en mililitros",
        "ar": "حجم المشروب الواحد بالمليلتر"
      }
    }
  ],
  "formulas": {
    "totalAlcoholGrams": "drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789",
    "bodyWaterConstant": "gender === 0 ? 0.68 : 0.55",
    "bacRaw": "totalAlcoholGrams / (weight * bodyWaterConstant * 10)",
    "bacMetabolized": "hours * 0.015"
  },
  "outputs": {
    "primary": "bacMetabolized",
    "breakdown": [
      "totalAlcoholGrams",
      "bacRaw",
      "bacMetabolized"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bac",
    "unit": "kg",
    "breakdownUnits": {
      "totalAlcoholGrams": "g"
    }
  },

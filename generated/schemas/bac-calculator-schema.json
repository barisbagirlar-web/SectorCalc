{
  "toolName": "bac-calculator",
  "inputs": [
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 for male, 1 for female",
      "label_i18n": {
        "en": "Gender",
        "tr": "Gender",
        "de": "Gender",
        "fr": "Gender",
        "es": "Gender",
        "ar": "Gender"
      }
    },
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight in kilograms",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "drinks",
      "label": "Number of Drinks",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Standard drinks (14g ethanol each)",
      "label_i18n": {
        "en": "Number of Drinks",
        "tr": "Number of Drinks",
        "de": "Number of Drinks",
        "fr": "Number of Drinks",
        "es": "Number of Drinks",
        "ar": "Number of Drinks"
      }
    },
    {
      "id": "hours",
      "label": "Hours Since First Drink",
      "type": "number",
      "unit": "hours",
      "default": 1,
      "businessContext": "Time elapsed since start of drinking",
      "label_i18n": {
        "en": "Hours Since First Drink",
        "tr": "Hours Since First Drink",
        "de": "Hours Since First Drink",
        "fr": "Hours Since First Drink",
        "es": "Hours Since First Drink",
        "ar": "Hours Since First Drink"
      }
    },
    {
      "id": "alcoholPercentage",
      "label": "Alcohol Percentage per Drink",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Alcohol by volume (ABV) per drink",
      "label_i18n": {
        "en": "Alcohol Percentage per Drink",
        "tr": "Alcohol Percentage per Drink",
        "de": "Alcohol Percentage per Drink",
        "fr": "Alcohol Percentage per Drink",
        "es": "Alcohol Percentage per Drink",
        "ar": "Alcohol Percentage per Drink"
      }
    },
    {
      "id": "volumePerDrink",
      "label": "Volume per Drink",
      "type": "number",
      "unit": "ml",
      "default": 355,
      "businessContext": "Volume of one drink in milliliters",
      "label_i18n": {
        "en": "Volume per Drink",
        "tr": "Volume per Drink",
        "de": "Volume per Drink",
        "fr": "Volume per Drink",
        "es": "Volume per Drink",
        "ar": "Volume per Drink"
      }
    }
  ],
  "formulas": {
    "totalAlcoholGrams": "drinks * volumePerDrink * (alcoholPercentage / 100) * 0.789",
    "bodyWaterConstant": "gender === 0 ? 0.68 : 0.55",
    "bacRaw": "totalAlcoholGrams / (weight * bodyWaterConstant * 10)",
    "bacMetabolized": "hours * 0.015",
    "bac": "Math.max(0, bacRaw - bacMetabolized)"
  },
  "outputs": {
    "primary": "bac",
    "breakdown": [
      "totalAlcoholGrams",
      "bacRaw",
      "bacMetabolized"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "quality-six-sigma"
}

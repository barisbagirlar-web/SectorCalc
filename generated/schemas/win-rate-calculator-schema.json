    },
    {
      "id": "targetWinRate",
      "label": "Target Win Rate",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Target win rate (%)",
      "label_i18n": {
        "en": "Target Win Rate",
        "tr": "Hedef Kazanma Oranı",
        "de": "Ziel-Gewinnrate",
        "fr": "Taux de gain cible",
        "es": "Tasa de éxito objetivo",
        "ar": "نسبة الفوز المستهدفة"
      },
      "businessContext_i18n": {
        "en": "Target win rate (%)",
        "tr": "Hedeflenen kazanma oranı (%)",
        "de": "Angestrebte Gewinnrate (%)",
        "fr": "Taux de gain cible (%)",
        "es": "Tasa de éxito objetivo (%)",
        "ar": "نسبة الفوز المستهدفة (%)"
      }
    }
  ],
  "formulas": {
    "winRate": "(wonOpportunities / (totalOpportunities - pendingOpportunities)) * 100",
    "winCount": "wonOpportunities",
    "lossCount": "totalOpportunities - pendingOpportunities - wonOpportunities",
    "gap": "winRate - targetWinRate"
  },
  "outputs": {
    "primary": "winRate",
    "breakdown": [
      "winCount",
      "lossCount",
      "gap"
    ],

      "label": "Total Opportunities",
      "type": "number",
      "unit": "count",
      "default": 100,
      "businessContext": "Toplam satış fırsatı sayısı (kazanılan, kaybedilen, beklemede)",
      "label_i18n": {
        "en": "Total Opportunities",
        "tr": "Total Opportunities",
        "de": "Total Opportunities",
        "fr": "Total Opportunities",
        "es": "Total Opportunities",
        "ar": "Total Opportunities"
      }
    },
    {
      "id": "wonOpportunities",
      "label": "Won Opportunities",
      "type": "number",
      "unit": "count",
      "default": 25,
      "businessContext": "Kazanılan fırsat sayısı",
      "label_i18n": {
        "en": "Won Opportunities",
        "tr": "Won Opportunities",
        "de": "Won Opportunities",
        "fr": "Won Opportunities",
        "es": "Won Opportunities",
        "ar": "Won Opportunities"
      }
    },
    {
      "id": "pendingOpportunities",
      "label": "Pending Opportunities",
      "type": "number",
      "unit": "count",
      "default": 20,
      "businessContext": "Beklemedeki fırsat sayısı",
      "label_i18n": {
        "en": "Pending Opportunities",
        "tr": "Pending Opportunities",
        "de": "Pending Opportunities",
        "fr": "Pending Opportunities",
        "es": "Pending Opportunities",
        "ar": "Pending Opportunities"
      }
    },
    {
      "id": "targetWinRate",
      "label": "Target Win Rate",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Hedeflenen kazanma oranı (%)",
      "label_i18n": {
        "en": "Target Win Rate",
        "tr": "Target Win Rate",
        "de": "Target Win Rate",
        "fr": "Target Win Rate",
        "es": "Target Win Rate",
        "ar": "Target Win Rate"
      }
    }
  ],
  "formulas": {
    "winRate": "(wonOpportunities / (totalOpportunities - pendingOpportunities)) * 100",
    "winCount": "wonOpportunities",
    "lossCount": "totalOpportunities - pendingOpportunities - wonOpportunities",
    "gap": "winRate - targetWinRate"
  },
  "outputs": {
    "primary": "winRate",
    "breakdown": [
      "winCount",
      "lossCount",
      "gap"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "gap",
    "unit": "count"
  },

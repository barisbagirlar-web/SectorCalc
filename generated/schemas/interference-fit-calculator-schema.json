      "unit": "unit",
      "default": 0.15,
      "businessContext": "Coefficient of friction between mating surfaces",
      "label_i18n": {
        "en": "Friction Coefficient",
        "tr": "Sürtünme Katsayısı",
        "de": "Reibungskoeffizient",
        "fr": "Coefficient de frottement",
        "es": "Coeficiente de fricción",
        "ar": "معامل الاحتكاك"
      },
      "businessContext_i18n": {
        "en": "Coefficient of friction between mating surfaces",
        "tr": "Birleşme yüzeyleri arasındaki sürtünme katsayısı",
        "de": "Reibungskoeffizient zwischen den Passflächen",
        "fr": "Coefficient de frottement entre les surfaces en contact",

{
  "toolName": "half-life-nuclear-calculator",
  "inputs": [
    {
      "id": "initialQuantity",
      "label": "Initial Quantity",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Initial mass of the radioactive substance.",
      "label_i18n": {
        "en": "Initial Quantity",
        "tr": "Initial Quantity",
        "de": "Initial Quantity",
        "fr": "Initial Quantity",
        "es": "Initial Quantity",
        "ar": "Initial Quantity"
      }
    },
    {
      "id": "halfLife",
      "label": "Half-Life",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time required for half of the substance to decay.",
      "label_i18n": {
        "en": "Half-Life",
        "tr": "Half-Life",
        "de": "Half-Life",
        "fr": "Half-Life",
        "es": "Half-Life",
        "ar": "Half-Life"
      }
    },
    {
      "id": "elapsedTime",
      "label": "Elapsed Time",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "Time duration over which decay is calculated.",
      "label_i18n": {
        "en": "Elapsed Time",
        "tr": "Elapsed Time",
        "de": "Elapsed Time",
        "fr": "Elapsed Time",
        "es": "Elapsed Time",
        "ar": "Elapsed Time"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for safety margin in criticality or radiological assessments.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "numberOfHalfLives": "elapsedTime / halfLife",
    "remainingQuantity": "initialQuantity * (0.5 ** (elapsedTime / halfLife))",
    "decayedAmount": "initialQuantity - remainingQuantity",
    "safeRemaining": "remainingQuantity * safetyFactor"
  },
  "outputs": {
    "primary": "remainingQuantity",
    "breakdown": [
      "decayedAmount",
      "numberOfHalfLives",
      "safeRemaining"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "safeRemaining"
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,

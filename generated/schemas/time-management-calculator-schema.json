        "es": "Efficiency",
        "ar": "Efficiency"
      }
    },
    {
      "id": "breakTimePerDay",
      "label": "Break time per day",
      "type": "number",
      "unit": "minutes",
      "default": 60,
      "businessContext": "Total break time per worker per day (minutes)",
      "label_i18n": {
        "en": "Break time per day",
        "tr": "Break time per day",
        "de": "Break time per day",
        "fr": "Break time per day",
        "es": "Break time per day",
        "ar": "Break time per day"
      }
    },
    {
      "id": "workingHoursPerDay",
      "label": "Working hours per day",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Standard working hours per day",
      "label_i18n": {
        "en": "Working hours per day",
        "tr": "Working hours per day",
        "de": "Working hours per day",
        "fr": "Working hours per day",
        "es": "Working hours per day",
        "ar": "Working hours per day"
      }
    }
  ],
  "formulas": {
    "totalWorkMinutes": "(totalTasks * timePerTask) / workers",
    "adjustedWorkMinutes": "(totalTasks * timePerTask) / (workers * (efficiency/100))",
    "effectiveMinutesPerDay": "workingHoursPerDay * 60 - breakTimePerDay",
    "totalDays": "(totalTasks * timePerTask) / (workers * (efficiency/100) * (workingHoursPerDay * 60 - breakTimePerDay))"
  },
  "outputs": {
    "primary": "totalDays",
    "breakdown": [
      "totalWorkMinutes",
      "adjustedWorkMinutes",
      "effectiveMinutesPerDay"

{
  "toolName": "original-price-calculator",
  "inputs": [
    {
      "id": "finalPrice",
      "label": "Final Price",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "Total price paid by customer including all surcharges and taxes.",
      "label_i18n": {
        "en": "Final Price",
        "tr": "Final Price",
        "de": "Final Price",
        "fr": "Final Price",
        "es": "Final Price",
        "ar": "Final Price"
      }
    },
    {
      "id": "rawMaterialSurcharge",
      "label": "Raw Material Surcharge",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "Additional cost per unit for raw materials.",
      "label_i18n": {
        "en": "Raw Material Surcharge",
        "tr": "Raw Material Surcharge",
        "de": "Raw Material Surcharge",
        "fr": "Raw Material Surcharge",
        "es": "Raw Material Surcharge",
        "ar": "Raw Material Surcharge"
      }
    },
    {
      "id": "laborSurcharge",
      "label": "Labor Surcharge",
      "type": "number",
      "unit": "currency",
      "default": 3,
      "businessContext": "Additional labor cost per unit.",
      "label_i18n": {
        "en": "Labor Surcharge",
        "tr": "Labor Surcharge",
        "de": "Labor Surcharge",
        "fr": "Labor Surcharge",
        "es": "Labor Surcharge",
        "ar": "Labor Surcharge"
      }
    },
    {
      "id": "overheadPercentage",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Factory overhead as percentage of base cost.",
      "label_i18n": {
        "en": "Overhead Percentage",
        "tr": "Overhead Percentage",
        "de": "Overhead Percentage",
        "fr": "Overhead Percentage",
        "es": "Overhead Percentage",
        "ar": "Overhead Percentage"
      }
    },
    {
      "id": "profitMarginPercentage",
      "label": "Profit Margin Percentage",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Profit margin applied after overhead.",
      "label_i18n": {
        "en": "Profit Margin Percentage",
        "tr": "Profit Margin Percentage",
        "de": "Profit Margin Percentage",
        "fr": "Profit Margin Percentage",
        "es": "Profit Margin Percentage",
        "ar": "Profit Margin Percentage"
      }
    },
    {
      "id": "vatPercentage",
      "label": "VAT Percentage",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Value Added Tax percentage.",
      "label_i18n": {
        "en": "VAT Percentage",
        "tr": "VAT Percentage",
        "de": "VAT Percentage",
        "fr": "VAT Percentage",
        "es": "VAT Percentage",
        "ar": "VAT Percentage"
      }
    }
  ],
  "formulas": {
    "basePriceBeforeOverhead": "finalPrice / ((1 + vatPercentage / 100) * (1 + profitMarginPercentage / 100))",
    "originalBaseCost": "basePriceBeforeOverhead / (1 + overheadPercentage / 100) - rawMaterialSurcharge - laborSurcharge"
  },
  "outputs": {
    "primary": "originalBaseCost",
    "breakdown": [
      "basePriceBeforeOverhead",
      "originalBaseCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "originalBaseCost"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",

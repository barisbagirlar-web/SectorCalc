      "label": "Fuel Efficiency",
      "type": "number",
      "unit": "km/L",
      "default": 5,
      "businessContext": "Average kilometers the transport vehicle travels per liter of fuel.",
      "label_i18n": {
        "en": "Fuel Efficiency",

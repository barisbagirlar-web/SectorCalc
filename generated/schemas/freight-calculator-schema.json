        "de": "Fuel Efficiency",
        "fr": "Fuel Efficiency",
        "es": "Fuel Efficiency",
        "ar": "Fuel Efficiency"
      }
    },
    {
      "id": "ratePerKg",
      "label": "Handling Rate per Kg",
      "type": "number",
      "unit": "$/kg",
      "default": 0.1,
      "businessContext": "Cost of handling, loading, and unloading per kilogram.",
      "label_i18n": {
        "en": "Handling Rate per Kg",
        "tr": "Handling Rate per Kg",
        "de": "Handling Rate per Kg",
        "fr": "Handling Rate per Kg",
        "es": "Handling Rate per Kg",
        "ar": "Handling Rate per Kg"
      }
    },
    {
      "id": "otherCharges",
      "label": "Additional Charges",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Any tolls, surcharges, or fixed costs not included elsewhere.",

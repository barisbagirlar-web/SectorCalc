        "en": "Additional Charges",
        "tr": "Additional Charges",
        "de": "Additional Charges",
        "fr": "Additional Charges",
        "es": "Additional Charges",
        "ar": "Additional Charges"
      }
    }
  ],
  "formulas": {
    "fuelCost": "distance / fuelEfficiency * fuelCostPerLiter",
    "weightCost": "weight * ratePerKg",
    "totalCost": "fuelCost + weightCost + otherCharges"

  "formulas": {
    "subtotal": "quantity * unitPrice",
    "discountAmount": "subtotal * discountPercent / 100",
    "taxAmount": "(subtotal - discountAmount) * taxPercent / 100",
    "finalTotal": "subtotal - discountAmount + taxAmount + shippingFee - couponValue"
  },

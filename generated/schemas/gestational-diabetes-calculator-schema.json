        "es": "Vücut Kitle İndeksi (BMI)",
        "ar": "Vücut Kitle İndeksi (BMI)"
      }
    },
    {
      "id": "previousGDM",
      "label": "Önceki Gebelikte GDM Öyküsü",
      "type": "number",
      "unit": "0=Hayır, 1=Evet",
      "default": 0,
      "businessContext": "Daha önce gestasyonel diyabet geçirmiş olmak, tekrarlama riskini artırır.",
      "label_i18n": {
        "en": "Önceki Gebelikte GDM Öyküsü",
        "tr": "Önceki Gebelikte GDM Öyküsü",
        "de": "Önceki Gebelikte GDM Öyküsü",
        "fr": "Önceki Gebelikte GDM Öyküsü",
        "es": "Önceki Gebelikte GDM Öyküsü",
        "ar": "Önceki Gebelikte GDM Öyküsü"
      }
    },
    {
      "id": "familyDiabetes",
      "label": "Ailede Diyabet Öyküsü",
      "type": "number",
      "unit": "0=Hayır, 1=Evet",
      "default": 0,
      "businessContext": "Birinci derece akrabalarda diyabet varlığı risk faktörüdür.",
      "label_i18n": {
        "en": "Ailede Diyabet Öyküsü",
        "tr": "Ailede Diyabet Öyküsü",
        "de": "Ailede Diyabet Öyküsü",
        "fr": "Ailede Diyabet Öyküsü",
        "es": "Ailede Diyabet Öyküsü",
        "ar": "Ailede Diyabet Öyküsü"
      }
    },
    {
      "id": "fastingGlucose",
      "label": "Açlık Kan Şekeri",
      "type": "number",
      "unit": "mg/dL",
      "default": 90,
      "businessContext": "Gebelikte açlık kan şekeri düzeyi, diyabet taramasında kullanılır.",
      "label_i18n": {
        "en": "Açlık Kan Şekeri",
        "tr": "Açlık Kan Şekeri",
        "de": "Açlık Kan Şekeri",
        "fr": "Açlık Kan Şekeri",
        "es": "Açlık Kan Şekeri",
        "ar": "Açlık Kan Şekeri"
      }
    },
    {
      "id": "ogtt1h",
      "label": "OGTT 1. Saat Kan Şekeri",
      "type": "number",
      "unit": "mg/dL",
      "default": 140,
      "businessContext": "Oral glukoz tolerans testi 1. saat değeri, tanı kriterlerinden biridir.",
      "label_i18n": {
        "en": "OGTT 1. Saat Kan Şekeri",
        "tr": "OGTT 1. Saat Kan Şekeri",
        "de": "OGTT 1. Saat Kan Şekeri",
        "fr": "OGTT 1. Saat Kan Şekeri",
        "es": "OGTT 1. Saat Kan Şekeri",
        "ar": "OGTT 1. Saat Kan Şekeri"
      }
    },
    {
      "id": "ogtt2h",
      "label": "OGTT 2. Saat Kan Şekeri",
      "type": "number",
      "unit": "mg/dL",
      "default": 120,
      "businessContext": "Oral glukoz tolerans testi 2. saat değeri, tanı kriterlerinden biridir.",
      "label_i18n": {
        "en": "OGTT 2. Saat Kan Şekeri",
        "tr": "OGTT 2. Saat Kan Şekeri",
        "de": "OGTT 2. Saat Kan Şekeri",
        "fr": "OGTT 2. Saat Kan Şekeri",
        "es": "OGTT 2. Saat Kan Şekeri",
        "ar": "OGTT 2. Saat Kan Şekeri"
      }
    },
    {
      "id": "gestationalWeek",
      "label": "Gebelik Haftası",
      "type": "number",
      "unit": "hafta",
      "default": 24,
      "businessContext": "Tarama genellikle 24-28. haftalar arasında yapılır.",
      "label_i18n": {
        "en": "Gebelik Haftası",
        "tr": "Gebelik Haftası",
        "de": "Gebelik Haftası",
        "fr": "Gebelik Haftası",
        "es": "Gebelik Haftası",
        "ar": "Gebelik Haftası"
      }
    }
  ],
  "formulas": {
    "riskScore": "((age - 25) * 0.1 + (bmi - 25) * 0.2 + previousGDM * 2 + familyDiabetes * 1.5 + (fastingGlucose - 92) * 0.05 + (ogtt1h - 180) * 0.02 + (ogtt2h - 153) * 0.02 + (gestationalWeek - 24) * 0.01)",
    "gdmProbability": "1 / (1 + Math.exp(-riskScore))",
    "diagnosis": "((fastingGlucose >= 92 || ogtt1h >= 180 || ogtt2h >= 153) ? 1 : 0)",
    "Risk_Skoru": "Risk Skoru",
    "Tan__Kriteri__0_Negatif__1_Pozitif_": "Tanı Kriteri (0=Negatif, 1=Pozitif)",
    "result": "GDM Olasılığı (%)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Risk Skoru",
      "Tanı Kriteri (0=Negatif, 1=Pozitif)"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",

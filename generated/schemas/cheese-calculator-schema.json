{
  "toolName": "cheese-calculator",
  "inputs": [
    {
      "id": "milkWeight",
      "label": "Milk Weight",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Total weight of milk input",
      "label_i18n": {
        "en": "Milk Weight",
        "tr": "Süt Ağırlığı",
        "de": "Milchgewicht",
        "fr": "Milk Weight",
        "es": "Milk Weight",
        "ar": "Milk Weight"
      },
      "businessContext_i18n": {
        "en": "Total weight of milk input",
        "tr": "Girdi sütün toplam ağırlığı",
        "de": "Gesamtgewicht der Milchzufuhr"
      }
    },
    {
      "id": "fatPercent",
      "label": "Milk Fat %",
      "type": "number",
      "unit": "%",
      "default": 3.5,
      "businessContext": "Percentage of fat in milk",
      "label_i18n": {
        "en": "Milk Fat %",
        "tr": "Süt Yağ %",
        "de": "Milchfett %",
        "fr": "Milk Fat %",
        "es": "Milk Fat %",
        "ar": "Milk Fat %"
      },
      "businessContext_i18n": {
        "en": "Percentage of fat in milk",
        "tr": "Sütteki yağ yüzdesi",
        "de": "Prozentsatz des Fetts in der Milch"
      }
    },
    {
      "id": "proteinPercent",
      "label": "Milk Protein %",
      "type": "number",
      "unit": "%",
      "default": 3.2,
      "businessContext": "Percentage of protein in milk",
      "label_i18n": {
        "en": "Milk Protein %",
        "tr": "Süt Proteini %",
        "de": "Milcheiweiß %",
        "fr": "Milk Protein %",
        "es": "Milk Protein %",
        "ar": "Milk Protein %"
      },
      "businessContext_i18n": {
        "en": "Percentage of protein in milk",
        "tr": "Sütteki protein yüzdesi",
        "de": "Prozentsatz des Proteins in der Milch"
      }
    },
    {
      "id": "moistureTarget",
      "label": "Target Moisture %",
      "type": "number",
      "unit": "%",
      "default": 40,
      "businessContext": "Target moisture content in cheese",
      "label_i18n": {
        "en": "Target Moisture %",
        "tr": "Hedef Nem %",
        "de": "Ziel-Feuchte %",
        "fr": "Target Moisture %",
        "es": "Target Moisture %",
        "ar": "Target Moisture %"
      },
      "businessContext_i18n": {
        "en": "Target moisture content in cheese",
        "tr": "Peynirde hedeflenen nem içeriği",
        "de": "Ziel-Feuchtegehalt im Käse"
      }
    },
    {
      "id": "yieldFactor",
      "label": "Yield Efficiency Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.9,
      "businessContext": "Efficiency factor accounting for losses during processing (0.8-0.95)",
      "label_i18n": {
        "en": "Yield Efficiency Factor",
        "tr": "Verim Verimlilik Faktörü",
        "de": "Ausbeute-Effizienzfaktor",
        "fr": "Yield Efficiency Factor",
        "es": "Yield Efficiency Factor",
        "ar": "Yield Efficiency Factor"
      },
      "businessContext_i18n": {
        "en": "Efficiency factor accounting for losses during processing (0.8-0.95)",
        "tr": "İşleme sırasındaki kayıpları hesaba katan verimlilik faktörü (0.8-0.95)",
        "de": "Effizienzfaktor zur Berücksichtigung von Verlusten während der Verarbeitung (0,8-0,95)"
      }
    }
  ],
  "formulas": {
    "cheeseWeight": "milkWeight * (fatPercent/100 + proteinPercent/100) * yieldFactor / (1 - moistureTarget/100)",
    "fatInCheese": "milkWeight * (fatPercent/100) * yieldFactor",
    "proteinInCheese": "milkWeight * (proteinPercent/100) * yieldFactor",
    "waterInCheese": "cheeseWeight * (moistureTarget/100)",
    "solidsInCheese": "cheeseWeight - waterInCheese"
  },
  "outputs": {
    "primary": "cheeseWeight",
    "breakdown": [
      "fatInCheese",
      "proteinInCheese",
      "waterInCheese",
      "solidsInCheese"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "solidsInCheese",
    "unit": "kg",
    "breakdownUnits": {
      "fatInCheese": "in",
      "proteinInCheese": "in",
      "waterInCheese": "in",
      "solidsInCheese": "in"
    }
  },
  "category": "Verimlilik & OEE",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",

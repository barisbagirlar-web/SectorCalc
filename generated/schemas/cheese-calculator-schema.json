{
  "toolName": "cheese-calculator",
  "inputs": [
    {
      "id": "milkWeight",
      "label": "Milk Weight",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Total weight of milk input",
      "label_i18n": {
        "en": "Milk Weight",
        "tr": "Süt Ağırlığı",
        "de": "Milchgewicht",

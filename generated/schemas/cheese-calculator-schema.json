        "fr": "Poids total du lait en entrée",
        "es": "Peso total de la leche de entrada",
        "ar": "الوزن الإجمالي للحليب المدخل"
      }
    },
    {
      "id": "fatPercent",
      "label": "Milk Fat %",
      "type": "number",
      "unit": "%",
      "default": 3.5,
      "businessContext": "Percentage of fat in milk",
      "label_i18n": {
        "en": "Milk Fat %",
        "tr": "Süt Yağ %",
        "de": "Milchfett %",
        "fr": "Taux de matière grasse du lait (%)",
        "es": "% de grasa en la leche",
        "ar": "نسبة دهن الحليب"
      },
      "businessContext_i18n": {
        "en": "Percentage of fat in milk",
        "tr": "Sütteki yağ yüzdesi",
        "de": "Prozentsatz des Fetts in der Milch",
        "fr": "Pourcentage de matière grasse dans le lait",
        "es": "Porcentaje de grasa en la leche",
        "ar": "نسبة الدهن في الحليب"
      }
    },
    {
      "id": "proteinPercent",
      "label": "Milk Protein %",
      "type": "number",
      "unit": "%",
      "default": 3.2,
      "businessContext": "Percentage of protein in milk",
      "label_i18n": {
        "en": "Milk Protein %",
        "tr": "Süt Proteini %",
        "de": "Milcheiweiß %",
        "fr": "Taux de protéines du lait (%)",
        "es": "% de proteína en la leche",
        "ar": "نسبة بروتين الحليب"
      },
      "businessContext_i18n": {
        "en": "Percentage of protein in milk",
        "tr": "Sütteki protein yüzdesi",
        "de": "Prozentsatz des Proteins in der Milch",
        "fr": "Pourcentage de protéines dans le lait",
        "es": "Porcentaje de proteína en la leche",
        "ar": "نسبة البروتين في الحليب"
      }
    },
    {
      "id": "moistureTarget",
      "label": "Target Moisture %",
      "type": "number",
      "unit": "%",
      "default": 40,
      "businessContext": "Target moisture content in cheese",
      "label_i18n": {
        "en": "Target Moisture %",
        "tr": "Hedef Nem %",
        "de": "Ziel-Feuchte %",
        "fr": "Taux d'humidité cible (%)",
        "es": "% de humedad objetivo",
        "ar": "نسبة الرطوبة المستهدفة"
      },
      "businessContext_i18n": {
        "en": "Target moisture content in cheese",
        "tr": "Peynirde hedeflenen nem içeriği",
        "de": "Ziel-Feuchtegehalt im Käse",
        "fr": "Taux d'humidité cible dans le fromage",
        "es": "Contenido de humedad objetivo en el queso",
        "ar": "نسبة الرطوبة المستهدفة في الجبن"
      }
    },
    {
      "id": "yieldFactor",
      "label": "Yield Efficiency Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.9,
      "businessContext": "Efficiency factor accounting for losses during processing (0.8-0.95)",
      "label_i18n": {
        "en": "Yield Efficiency Factor",
        "tr": "Verim Verimlilik Faktörü",
        "de": "Ausbeute-Effizienzfaktor",
        "fr": "Facteur d'efficacité du rendement",
        "es": "Factor de eficiencia de rendimiento",
        "ar": "عامل كفاءة الإنتاجية"
      },
      "businessContext_i18n": {
        "en": "Efficiency factor accounting for losses during processing (0.8-0.95)",
        "tr": "İşleme sırasındaki kayıpları hesaba katan verimlilik faktörü (0.8-0.95)",
        "de": "Effizienzfaktor zur Berücksichtigung von Verlusten während der Verarbeitung (0,8-0,95)",
        "fr": "Facteur d'efficacité tenant compte des pertes lors de la transformation (0,8-0,95)",
        "es": "Factor de eficiencia que contabiliza pérdidas durante el procesamiento (0.8-0.95)",
        "ar": "عامل الكفاءة الذي يأخذ في الاعتبار الخسائر أثناء المعالجة (0.8-0.95)"
      }
    }
  ],
  "formulas": {
    "cheeseWeight": "milkWeight * (fatPercent/100 + proteinPercent/100) * yieldFactor / (1 - moistureTarget/100)",
    "fatInCheese": "milkWeight * (fatPercent/100) * yieldFactor",
    "proteinInCheese": "milkWeight * (proteinPercent/100) * yieldFactor",
    "waterInCheese": "cheeseWeight * (moistureTarget/100)",
    "solidsInCheese": "cheeseWeight - waterInCheese"
  },
  "outputs": {
    "primary": "cheeseWeight",
    "breakdown": [
      "fatInCheese",
      "proteinInCheese",
      "waterInCheese",
      "solidsInCheese"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "solidsInCheese",
    "unit": "kg",
    "breakdownUnits": {
      "fatInCheese": "in",
      "proteinInCheese": "in",
      "waterInCheese": "in",
      "solidsInCheese": "in"
    }
  },
  "category": "Matematik & Analiz",
  "sector": "Gıda & Beslenme",

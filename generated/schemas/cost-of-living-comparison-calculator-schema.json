{
  "toolName": "cost-of-living-comparison-calculator",
  "inputs": [
    {
      "id": "baseRent",
      "label": "Base City Rent",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "businessContext": "Average monthly rent for a 1-bedroom apartment in the base city.",
      "label_i18n": {
        "en": "Base City Rent",
        "tr": "Base City Rent",
        "de": "Base City Rent",
        "fr": "Base City Rent",
        "es": "Base City Rent",
        "ar": "Base City Rent"
      }
    },
    {
      "id": "baseUtilities",
      "label": "Base City Utilities",
      "type": "number",
      "unit": "USD",
      "default": 200,
      "businessContext": "Monthly cost of basic utilities (electricity, water, heating, garbage) for a standard apartment.",
      "label_i18n": {
        "en": "Base City Utilities",
        "tr": "Base City Utilities",
        "de": "Base City Utilities",
        "fr": "Base City Utilities",
        "es": "Base City Utilities",
        "ar": "Base City Utilities"
      }
    },
    {
      "id": "baseGroceries",
      "label": "Base City Groceries",
      "type": "number",
      "unit": "USD",
      "default": 400,
      "businessContext": "Monthly grocery bill for a single person in the base city.",
      "label_i18n": {
        "en": "Base City Groceries",
        "tr": "Base City Groceries",
        "de": "Base City Groceries",
        "fr": "Base City Groceries",
        "es": "Base City Groceries",
        "ar": "Base City Groceries"
      }
    },
    {
      "id": "baseTransport",
      "label": "Base City Transportation",
      "type": "number",
      "unit": "USD",
      "default": 150,
      "businessContext": "Monthly public transport pass or equivalent fuel costs in the base city.",
      "label_i18n": {
        "en": "Base City Transportation",
        "tr": "Base City Transportation",
        "de": "Base City Transportation",
        "fr": "Base City Transportation",
        "es": "Base City Transportation",
        "ar": "Base City Transportation"
      }
    },
    {
      "id": "baseMisc",
      "label": "Base City Misc. Expenses",
      "type": "number",
      "unit": "USD",
      "default": 250,
      "businessContext": "Other monthly living expenses (entertainment, clothing, personal care) in the base city.",
      "label_i18n": {
        "en": "Base City Misc. Expenses",
        "tr": "Base City Misc. Expenses",
        "de": "Base City Misc. Expenses",
        "fr": "Base City Misc. Expenses",
        "es": "Base City Misc. Expenses",
        "ar": "Base City Misc. Expenses"
      }
    },
    {
      "id": "targetIndex",
      "label": "Target City Cost of Living Index",
      "type": "number",
      "unit": "index",
      "default": 120,
      "businessContext": "Cost of living index of the target city, relative to base city = 100. A value above 100 means it is more expensive.",
      "label_i18n": {
        "en": "Target City Cost of Living Index",
        "tr": "Target City Cost of Living Index",
        "de": "Target City Cost of Living Index",
        "fr": "Target City Cost of Living Index",
        "es": "Target City Cost of Living Index",
        "ar": "Target City Cost of Living Index"
      }
    }
  ],
  "formulas": {
    "totalBaseCost": "baseRent + baseUtilities + baseGroceries + baseTransport + baseMisc",
    "totalTargetCost": "totalBaseCost * targetIndex / 100"
  },
  "outputs": {
    "primary": "totalTargetCost",
    "breakdown": [
      "Total base city monthly cost: $${totalBaseCost.toFixed(2)}",
      "Target city index: ${targetIndex}",
      "Equivalent target city cost: $${totalTargetCost.toFixed(2)}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTargetCost",
    "unit": "USD"
  },
  "category": "Enerji & Karbon",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "energy",
  "validation": {

{
  "toolName": "dive-table-calculator",
  "inputs": [
    {
      "id": "diveDepth",
      "label": "Target Dive Depth",
      "type": "number",
      "unit": "m",
      "default": 30,
      "businessContext": "Planned maximum depth of the dive, affecting inert gas loading and decompression risk.",
      "label_i18n": {
        "en": "Target Dive Depth",
        "tr": "Target Dive Depth",
        "de": "Target Dive Depth",
        "fr": "Target Dive Depth",
        "es": "Target Dive Depth",
        "ar": "Target Dive Depth"
      }
    },
    {
      "id": "targetPPO2",
      "label": "Target Partial Pressure O₂",
      "type": "number",
      "unit": "atm",
      "default": 1.4,
      "businessContext": "Safe maximum partial pressure of oxygen to avoid CNS toxicity (1.4–1.6 atm).",
      "label_i18n": {
        "en": "Target Partial Pressure O₂",
        "tr": "Target Partial Pressure O₂",
        "de": "Target Partial Pressure O₂",
        "fr": "Target Partial Pressure O₂",
        "es": "Target Partial Pressure O₂",
        "ar": "Target Partial Pressure O₂"
      }
    },
    {
      "id": "o2Fraction",
      "label": "Nitrox O₂ Fraction",
      "type": "number",
      "unit": "%",
      "default": 32,
      "businessContext": "Oxygen percentage in the breathing gas mix, determines depth limits and decompression efficiency.",
      "label_i18n": {
        "en": "Nitrox O₂ Fraction",
        "tr": "Nitrox O₂ Fraction",
        "de": "Nitrox O₂ Fraction",
        "fr": "Nitrox O₂ Fraction",
        "es": "Nitrox O₂ Fraction",
        "ar": "Nitrox O₂ Fraction"
      }
    }
  ],
  "formulas": {
    "mod": "(targetPPO2 / (o2Fraction / 100) - 1) * 10",
    "bestMix": "(targetPPO2 / (diveDepth / 10 + 1)) * 100"
  },
  "outputs": {
    "primary": "mod",
    "breakdown": [
      "bestMix"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bestMix"
  },

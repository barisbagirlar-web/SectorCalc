      }
    },
    {
      "id": "unitCount",
      "label": "Number of Units",
      "type": "number",
      "unit": "pieces",
      "default": 1,
      "businessContext": "Number of identical units under observation",
      "label_i18n": {
        "en": "Number of Units",
        "tr": "Birim Sayısı",
        "de": "Anzahl der Einheiten",
        "fr": "Number of Units",
        "es": "Number of Units",
        "ar": "Number of Units"
      },
      "businessContext_i18n": {
        "en": "Number of identical units under observation",
        "tr": "Gözlem altındaki özdeş birim sayısı"
      }
    },
    {
      "id": "failureCount",
      "label": "Number of Failures",
      "type": "number",
      "unit": "count",
      "default": 5,
      "businessContext": "Total number of failures observed across all units",
      "label_i18n": {
        "en": "Number of Failures",
        "tr": "Arıza Sayısı",
        "de": "Anzahl der Ausfälle",
        "fr": "Number of Failures",
        "es": "Number of Failures",
        "ar": "Number of Failures"
      },
      "businessContext_i18n": {
        "en": "Total number of failures observed across all units",
        "tr": "Tüm birimlerde gözlemlenen toplam arıza sayısı"
      }
    },
    {
      "id": "repairHours",
      "label": "Total Repair Hours",
      "type": "number",
      "unit": "hours",
      "default": 50,
      "businessContext": "Total time spent on repairs for all failures",
      "label_i18n": {
        "en": "Total Repair Hours",
        "tr": "Toplam Onarım Saati",
        "de": "Total Repair Hours",
        "fr": "Total Repair Hours",
        "es": "Total Repair Hours",
        "ar": "Total Repair Hours"
      },
      "businessContext_i18n": {
        "en": "Total time spent on repairs for all failures",
        "tr": "Tüm arızalar için onarımlara harcanan toplam süre"
      }
    }
  ],
  "formulas": {
    "totalOperationalTime": "operatingHours * unitCount",
    "MTBF": "totalOperationalTime / failureCount",
    "MTTR": "repairHours / failureCount",
    "Availability": "MTBF / (MTBF + MTTR)"
  },
  "outputs": {
    "primary": "MTBF",
    "breakdown": [
      "MTTR",
      "Availability"
    ],

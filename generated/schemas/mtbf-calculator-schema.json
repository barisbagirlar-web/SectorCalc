{
  "toolName": "mtbf-calculator",
  "inputs": [
    {
      "id": "operatingHours",
      "label": "Operating Hours per Unit",
      "type": "number",
      "unit": "hours",
      "default": 8760,
      "businessContext": "Total operating hours for a single unit during the observation period",
      "label_i18n": {
        "en": "Operating Hours per Unit",
        "tr": "Birim Başına Çalışma Saati",

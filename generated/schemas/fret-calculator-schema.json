{
  "toolName": "fret-calculator",
  "inputs": [
    {
      "id": "scaleLength",
      "label": "Scale Length",
      "type": "number",
      "unit": "mm",
      "default": 648,
      "businessContext": "The distance from the nut to the bridge saddle, typically measured in millimeters.",
      "label_i18n": {
        "en": "Scale Length",
        "tr": "Scale Length",
        "de": "Scale Length",
        "fr": "Scale Length",
        "es": "Scale Length",
        "ar": "Scale Length"
      }
    },
    {
      "id": "fretNumber",
      "label": "Fret Number",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "The fret position to calculate (1-indexed).",
      "label_i18n": {
        "en": "Fret Number",
        "tr": "Fret Number",
        "de": "Fret Number",
        "fr": "Fret Number",
        "es": "Fret Number",
        "ar": "Fret Number"
      }
    },
    {
      "id": "totalFrets",
      "label": "Total Frets",
      "type": "number",
      "unit": "unit",
      "default": 24,
      "businessContext": "The total number of frets on the instrument fingerboard.",
      "label_i18n": {
        "en": "Total Frets",
        "tr": "Total Frets",
        "de": "Total Frets",
        "fr": "Total Frets",
        "es": "Total Frets",
        "ar": "Total Frets"
      }
    },
    {
      "id": "compensation",
      "label": "Compensation",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Additional length added to the scale length for intonation compensation at the bridge.",
      "label_i18n": {
        "en": "Compensation",
        "tr": "Compensation",
        "de": "Compensation",
        "fr": "Compensation",
        "es": "Compensation",
        "ar": "Compensation"
      }
    }
  ],
  "formulas": {
    "distanceToFret": "((scaleLength + compensation) - ((scaleLength + compensation) / Math.pow(2, fretNumber / 12)))",
    "distanceToNextFret": "fretNumber < totalFrets ? ((scaleLength + compensation) - ((scaleLength + compensation) / Math.pow(2, (fretNumber + 1) / 12))) : 0",
    "distanceTo12thFret": "(scaleLength + compensation) / 2",
    "fretSpacing": "fretNumber > 1 ? (((scaleLength + compensation) - ((scaleLength + compensation) / Math.pow(2, fretNumber / 12))) - ((scaleLength + compensation) - ((scaleLength + compensation) / Math.pow(2, (fretNumber - 1) / 12)))) : ((scaleLength + compensation) - ((scaleLength + compensation) / Math.pow(2, fretNumber / 12)))"
  },
  "outputs": {
    "primary": "distanceToFret",
    "breakdown": [
      "distanceToNextFret",
      "distanceTo12thFret",
      "fretSpacing"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "gaming-entertainment",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

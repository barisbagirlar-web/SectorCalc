{
  "toolName": "pond-calculator",
  "inputs": [
    {
      "id": "pondLength",
      "label": "Pond Length",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Pond dimensions for construction and liner sizing"
    },
    {
      "id": "pondWidth",
      "label": "Pond Width",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "Pond dimensions for construction and liner sizing"
    },
    {
      "id": "pondDepth",
      "label": "Average Depth",
      "type": "number",
      "unit": "m",
      "default": 1.5,
      "businessContext": "Pond dimensions for construction and liner sizing"
    },
    {
      "id": "linerOverlap",
      "label": "Liner Overlap",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "businessContext": "Overlap allowance for pond liner installation"
    }
  ],
  "formulas": {
    "volumeM3": "pondLength * pondWidth * pondDepth",
    "volumeLiters": "volumeM3 * 1000",
    "linerLength": "pondLength + 2 * pondDepth + 2 * linerOverlap",
    "linerWidth": "pondWidth + 2 * pondDepth + 2 * linerOverlap",
    "linerArea": "linerLength * linerWidth"
  },
  "outputs": {
    "primary": "volumeLiters",
    "breakdown": [
      "volumeM3",
      "linerArea",
      "linerLength",
      "linerWidth"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "technology-ai-cloud-cyber"
}

      }
    },
    {
      "id": "otherCost",
      "label": "Other Costs",
      "type": "number",
      "unit": "€",
      "default": 0.1,
      "businessContext": "Cost of garnishes, syrups, ice, etc. per drink",
      "label_i18n": {
        "en": "Other Costs",
        "tr": "Other Costs",
        "de": "Other Costs",
        "fr": "Other Costs",
        "es": "Other Costs",
        "ar": "Other Costs"
      }
    },
    {
      "id": "marginPercent",
      "label": "Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Target profit margin percentage on selling price",
      "label_i18n": {
        "en": "Profit Margin",
        "tr": "Profit Margin",
        "de": "Profit Margin",
        "fr": "Profit Margin",
        "es": "Profit Margin",
        "ar": "Profit Margin"
      }
    }
  ],
  "formulas": {
    "totalVolume": "spiritVol + mixerVol",
    "totalCost": "(spiritVol / 1000) * spiritCostPerL + (mixerVol / 1000) * mixerCostPerL + otherCost",
    "sellingPrice": "totalCost / (1 - marginPercent / 100)",
    "costPerMl": "totalCost / totalVolume"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "sellingPrice",
      "totalVolume",
      "costPerMl"
    ],

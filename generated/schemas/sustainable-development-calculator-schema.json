    },
    {
      "id": "production_units",
      "label": "Production Units",
      "type": "number",
      "unit": "units",
      "default": 100,
      "businessContext": "Number of units produced",
      "label_i18n": {
        "en": "Production Units",
        "tr": "Production Units",
        "de": "Production Units",
        "fr": "Production Units",
        "es": "Production Units",
        "ar": "Production Units"
      }
    }
  ],
  "formulas": {
    "energy_intensity": "energy_consumption / production_units",
    "renewable_energy_ratio": "renewable_energy_share / 100",
    "water_intensity": "water_usage / production_units",
    "waste_recycling_rate": "recycled_waste / waste_generated",
    "co2_intensity": "co2_emissions / production_units",
    "sustainability_score": "(renewable_energy_ratio * 25) + ((1 - water_intensity / 10) * 25) + (waste_recycling_rate * 25) + ((1 - co2_intensity / 100) * 25)"
  },
  "outputs": {
    "primary": "sustainability_score",
    "breakdown": [
      "energy_intensity",
      "water_intensity",
      "waste_recycling_rate",
      "co2_intensity"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

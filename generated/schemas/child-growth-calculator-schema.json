{
  "toolName": "child-growth-calculator",
  "inputs": [
    {
      "id": "parentQuantity",
      "label": "Parent Item Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Production order quantity for the parent item.",
      "label_i18n": {
        "en": "Parent Item Quantity",
        "tr": "Parent Item Quantity",
        "de": "Parent Item Quantity",
        "fr": "Parent Item Quantity",
        "es": "Parent Item Quantity",
        "ar": "Parent Item Quantity"
      }
    },
    {
      "id": "bomMultiplier",
      "label": "BOM Multiplier",
      "type": "number",
      "unit": "pcs/pcs",
      "default": 1,
      "businessContext": "Number of child items required per one parent item.",
      "label_i18n": {
        "en": "BOM Multiplier",
        "tr": "BOM Multiplier",
        "de": "BOM Multiplier",
        "fr": "BOM Multiplier",
        "es": "BOM Multiplier",
        "ar": "BOM Multiplier"
      }
    },
    {
      "id": "scrapRate",
      "label": "Scrap Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Expected percentage of child items scrapped during production.",
      "label_i18n": {
        "en": "Scrap Rate",
        "tr": "Scrap Rate",
        "de": "Scrap Rate",
        "fr": "Scrap Rate",
        "es": "Scrap Rate",
        "ar": "Scrap Rate"
      }
    },
    {
      "id": "safetyStockFactor",
      "label": "Safety Stock Factor",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional percentage for safety stock to cover uncertainties.",
      "label_i18n": {
        "en": "Safety Stock Factor",
        "tr": "Safety Stock Factor",
        "de": "Safety Stock Factor",
        "fr": "Safety Stock Factor",
        "es": "Safety Stock Factor",
        "ar": "Safety Stock Factor"
      }
    }
  ],
  "formulas": {
    "grossRequirement": "parentQuantity * bomMultiplier",
    "netRequirement": "grossRequirement / (1 - scrapRate / 100)",
    "finalRequirement": "netRequirement * (1 + safetyStockFactor / 100)"
  },
  "outputs": {
    "primary": "finalRequirement",
    "breakdown": [
      "grossRequirement",
      "netRequirement",
      "finalRequirement"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalRequirement"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Lojistik & Tedarik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "lojistik",
  "profession": "Lojistik Uzmanı",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

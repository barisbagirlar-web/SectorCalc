  "formulas": {
    "totalCost": "initialInvestment + (resourceHours * costPerHour * timeframe * 4.33)",
    "requiredMonthlyImprovement": "(targetValue - currentValue) / timeframe",
    "feasibilityScore": "expectedImprovementRate / ((targetValue - currentValue) / timeframe) * 100",
    "expectedMonthlyImprovementRate": "expectedImprovementRate"
  },
  "outputs": {
    "primary": "feasibilityScore",
    "breakdown": [
      "totalCost",
      "requiredMonthlyImprovement",
      "expectedMonthlyImprovementRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "expectedMonthlyImprovementRate",
    "unit": "months"
  },

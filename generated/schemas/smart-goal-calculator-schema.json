    },
    {
      "id": "expectedImprovementRate",
      "label": "Expected Improvement Rate",
      "type": "number",
      "unit": "% per month",
      "default": 5,
      "businessContext": "Expected improvement rate per month (%).",
      "label_i18n": {
        "en": "Expected Improvement Rate",

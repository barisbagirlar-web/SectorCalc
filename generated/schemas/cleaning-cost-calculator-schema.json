      }
    },
    {
      "id": "overheadMargin",
      "label": "Overhead Margin",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Overhead and profit margin percentage",
      "label_i18n": {
        "en": "Overhead Margin",
        "tr": "Genel Gider Marjı",
        "de": "Overhead Margin",
        "fr": "Overhead Margin",
        "es": "Overhead Margin",
        "ar": "Overhead Margin"
      },
      "businessContext_i18n": {
        "en": "Overhead and profit margin percentage",
        "tr": "Genel gider ve kar marjı yüzdesi"
      }
    }
  ],
  "formulas": {
    "laborCost": "area * frequency * laborTime * laborRate",
    "materialCost": "area * frequency * materialCost",
    "equipmentCost": "equipmentCost",
    "subtotal": "laborCost + materialCost + equipmentCost",
    "overheadAmount": "subtotal * (overheadMargin / 100)",
    "totalMonthlyCost": "subtotal + overheadAmount"
  },
  "outputs": {
    "primary": "totalMonthlyCost",
    "breakdown": [
      "laborCost",
      "materialCost",
      "equipmentCost",
      "overheadAmount"
    ],

{
  "toolName": "m-to-ft-calculator",
  "inputs": [
    {
      "id": "meters",
      "label": "Length (m)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Nominal length in meters as per engineering drawing or measurement.",
      "label_i18n": {
        "en": "Length (m)",
        "tr": "Length (m)",
        "de": "Length (m)",
        "fr": "Length (m)",
        "es": "Length (m)",
        "ar": "Length (m)"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (ft/m)",
      "type": "number",
      "unit": "ft/m",
      "default": 3.280839895,
      "businessContext": "Standard conversion factor from meters to feet per ISO 80000-3. Adjust if using US survey foot (3.280833333).",
      "label_i18n": {
        "en": "Conversion Factor (ft/m)",
        "tr": "Conversion Factor (ft/m)",
        "de": "Conversion Factor (ft/m)",
        "fr": "Conversion Factor (ft/m)",
        "es": "Conversion Factor (ft/m)",
        "ar": "Conversion Factor (ft/m)"
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty (± m)",
      "type": "number",
      "unit": "m",
      "default": 0.001,
      "businessContext": "Combined standard uncertainty of the length measurement per ISO/IEC 17025 calibration certificate.",
      "label_i18n": {
        "en": "Measurement Uncertainty (± m)",
        "tr": "Measurement Uncertainty (± m)",
        "de": "Measurement Uncertainty (± m)",
        "fr": "Measurement Uncertainty (± m)",
        "es": "Measurement Uncertainty (± m)",
        "ar": "Measurement Uncertainty (± m)"
      }
    },
    {
      "id": "temperatureOffset",
      "label": "Temperature Offset (K)",
      "type": "number",
      "unit": "K",
      "default": 0,
      "businessContext": "Temperature deviation from reference 20°C. For steel tapes, expansion coefficient ~0.0000116/K. Enter difference in K (e.g., if 25°C, enter 5).",
      "label_i18n": {
        "en": "Temperature Offset (K)",
        "tr": "Temperature Offset (K)",
        "de": "Temperature Offset (K)",
        "fr": "Temperature Offset (K)",
        "es": "Temperature Offset (K)",
        "ar": "Temperature Offset (K)"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places for Output",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Number of decimal places to round the output feet value as per project tolerance requirements.",
      "label_i18n": {
        "en": "Decimal Places for Output",
        "tr": "Decimal Places for Output",
        "de": "Decimal Places for Output",
        "fr": "Decimal Places for Output",
        "es": "Decimal Places for Output",
        "ar": "Decimal Places for Output"
      }
    },
    {
      "id": "applyCorrection",
      "label": "Apply Correction? (1=Yes, 0=No)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Toggle to apply temperature and uncertainty corrections. Set to 1 for calibrated results, 0 for nominal conversion only.",
      "label_i18n": {
        "en": "Apply Correction? (1=Yes, 0=No)",
        "tr": "Apply Correction? (1=Yes, 0=No)",
        "de": "Apply Correction? (1=Yes, 0=No)",
        "fr": "Apply Correction? (1=Yes, 0=No)",
        "es": "Apply Correction? (1=Yes, 0=No)",
        "ar": "Apply Correction? (1=Yes, 0=No)"
      }
    }
  ],
  "formulas": {
    "correctedMeters": "applyCorrection === 1 ? meters * (1 + temperatureOffset * 0.0000116) : meters",
    "rawFeet": "meters * conversionFactor",
    "uncertaintyFeet": "measurementUncertainty * conversionFactor",
    "applyCorrection": "applyCorrection",
    "feet": "Math.round(((applyCorrection === 1 ? meters * (1 + temperatureOffset * 0.0000116) : meters) * conversionFactor) * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)"
  },
  "outputs": {
    "primary": "feet",
    "breakdown": [
      "correctedMeters",
      "rawFeet",
      "uncertaintyFeet",
      "applyCorrection"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Otomotiv & Taşıt",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "conversion"
}

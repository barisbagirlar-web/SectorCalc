      "label_i18n": {
        "en": "Sample Standard Deviation",
        "tr": "Sample Standard Deviation",
        "de": "Sample Standard Deviation",
        "fr": "Sample Standard Deviation",
        "es": "Sample Standard Deviation",
        "ar": "Sample Standard Deviation"
      }
    },
    {
      "id": "sampleSize",
      "label": "Sample Size",
      "type": "number",
      "unit": "count",
      "default": 30,
      "businessContext": "Number of observations in the sample.",
      "label_i18n": {
        "en": "Sample Size",
        "tr": "Sample Size",
        "de": "Sample Size",
        "fr": "Sample Size",
        "es": "Sample Size",
        "ar": "Sample Size"
      }
    },
    {
      "id": "confidenceLevel",
      "label": "Confidence Level",
      "type": "number",
      "unit": "decimal",
      "default": 0.95,
      "businessContext": "Desired confidence level (e.g., 0.95 for 95%).",
      "label_i18n": {
        "en": "Confidence Level",
        "tr": "Confidence Level",
        "de": "Confidence Level",
        "fr": "Confidence Level",
        "es": "Confidence Level",
        "ar": "Confidence Level"
      }
    }
  ],
  "formulas": {
    "zScore": "if (confidenceLevel === 0.90) { 1.645 } else if (confidenceLevel === 0.95) { 1.96 } else if (confidenceLevel === 0.99) { 2.576 } else { 1.96 }",
    "marginOfError": "zScore * sampleStdDev / Math.sqrt(sampleSize)",
    "lowerBound": "sampleMean - marginOfError",
    "upperBound": "sampleMean + marginOfError"
  },
  "outputs": {
    "primary": "zScore",
    "breakdown": [
      "Margin of Error: marginOfError",
      "Z-Score: zScore"
    ]
  },

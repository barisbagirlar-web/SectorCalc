{
  "toolName": "crystallization-calculator",
  "inputs": [
    {
      "id": "massSolvent",
      "label": "Mass of Solvent",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Mass of solvent in the solution"
    },
    {
      "id": "solubilityInitial",
      "label": "Initial Solubility",
      "type": "number",
      "unit": "g/100g",
      "default": 50,
      "businessContext": "Solubility at initial temperature (g solute per 100g solvent)"
    },
    {
      "id": "solubilityFinal",
      "label": "Final Solubility",
      "type": "number",
      "unit": "g/100g",
      "default": 20,
      "businessContext": "Solubility at final temperature (g solute per 100g solvent)"
    },
    {
      "id": "temperatureInitial",
      "label": "Initial Temperature",
      "type": "number",
      "unit": "°C",
      "default": 80,
      "businessContext": "Starting temperature of the solution, for reference"
    },
    {
      "id": "temperatureFinal",
      "label": "Final Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Final temperature after cooling, for reference"
    }
  ],
  "formulas": {
    "massInitialSolute": "massSolvent * solubilityInitial / 100",
    "massCrystal": "massSolvent * (solubilityInitial - solubilityFinal) / 100",
    "yieldPercent": "(massCrystal / massInitialSolute) * 100"
  },
  "outputs": {
    "primary": "massInitialSolute",
    "breakdown": [
      {
        "id": "massCrystallized",
        "label": "Mass Crystallized",
        "unit": "kg",
        "formula": "massCrystal"
      },
      {
        "id": "massInitialSolute",
        "label": "Initial Solute Mass",
        "unit": "kg",
        "formula": "massInitialSolute"
      }
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

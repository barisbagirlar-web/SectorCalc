{
  "toolName": "crystallization-calculator",
  "inputs": [
    {
      "id": "massSolvent",
      "label": "Mass of Solvent",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Mass of solvent in the solution",
      "label_i18n": {
        "en": "Mass of Solvent",
        "tr": "Mass of Solvent",
        "de": "Mass of Solvent",
        "fr": "Mass of Solvent",
        "es": "Mass of Solvent",
        "ar": "Mass of Solvent"
      }
    },
    {
      "id": "solubilityInitial",
      "label": "Initial Solubility",
      "type": "number",
      "unit": "g/100g",
      "default": 50,
      "businessContext": "Solubility at initial temperature (g solute per 100g solvent)",
      "label_i18n": {
        "en": "Initial Solubility",
        "tr": "Initial Solubility",
        "de": "Initial Solubility",
        "fr": "Initial Solubility",
        "es": "Initial Solubility",
        "ar": "Initial Solubility"
      }
    },
    {
      "id": "solubilityFinal",
      "label": "Final Solubility",
      "type": "number",
      "unit": "g/100g",
      "default": 20,
      "businessContext": "Solubility at final temperature (g solute per 100g solvent)",
      "label_i18n": {
        "en": "Final Solubility",
        "tr": "Final Solubility",
        "de": "Final Solubility",
        "fr": "Final Solubility",
        "es": "Final Solubility",
        "ar": "Final Solubility"
      }
    },
    {
      "id": "temperatureInitial",
      "label": "Initial Temperature",
      "type": "number",
      "unit": "°C",
      "default": 80,
      "businessContext": "Starting temperature of the solution, for reference",
      "label_i18n": {
        "en": "Initial Temperature",
        "tr": "Initial Temperature",
        "de": "Initial Temperature",
        "fr": "Initial Temperature",
        "es": "Initial Temperature",
        "ar": "Initial Temperature"
      }
    },
    {
      "id": "temperatureFinal",
      "label": "Final Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Final temperature after cooling, for reference",
      "label_i18n": {
        "en": "Final Temperature",
        "tr": "Final Temperature",
        "de": "Final Temperature",
        "fr": "Final Temperature",
        "es": "Final Temperature",
        "ar": "Final Temperature"
      }
    }
  ],
  "formulas": {
    "massInitialSolute": "massSolvent * solubilityInitial / 100",
    "massCrystal": "massSolvent * (solubilityInitial - solubilityFinal) / 100",
    "yieldPercent": "(massCrystal / massInitialSolute) * 100"
  },
  "outputs": {
    "primary": "massInitialSolute",
    "breakdown": [
      {
        "id": "massCrystallized",
        "label": "Mass Crystallized",
        "unit": "kg",
        "formula": "massCrystal"
      },
      {
        "id": "massInitialSolute",
        "label": "Initial Solute Mass",
        "unit": "kg",
        "formula": "massInitialSolute"
      }
    ],

  "formulas": {
    "Cost_Virgin": "Price_V * (1 + Scrap_V) + Transp_V",
    "Cost_Recyc": "(Collect + Sort + Pellet) / Yield",
    "QualPenalty": "(Tensile_V - Tensile_R) * AppFactor",
    "EnergySav": "(Energy_V - Energy_R) * EnergyCost",
    "CarbonCred": "(CO2_V - CO2_R) * CarbonPrice",
    "Total_R": "Cost_Recyc + QualPenalty - EnergySav - CarbonCred",
    "ROI": "(Cost_V - Total_R) * Vol / Capex"

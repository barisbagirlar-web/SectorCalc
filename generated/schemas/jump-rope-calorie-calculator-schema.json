{
  "toolName": "jump-rope-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms. Used to compute energy expenditure.",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Total time spent jumping rope in minutes.",
      "label_i18n": {
        "en": "Duration",
        "tr": "Duration",
        "de": "Duration",
        "fr": "Duration",
        "es": "Duration",
        "ar": "Duration"
      }
    },
    {
      "id": "jumpsPerMinute",
      "label": "Jumps per Minute",
      "type": "number",
      "unit": "jpm",
      "default": 120,
      "businessContext": "Average number of rope skips per minute. Influences intensity (MET).",
      "label_i18n": {
        "en": "Jumps per Minute",
        "tr": "Jumps per Minute",
        "de": "Jumps per Minute",
        "fr": "Jumps per Minute",
        "es": "Jumps per Minute",
        "ar": "Jumps per Minute"
      }
    },
    {
      "id": "efficiencyFactor",
      "label": "Efficiency Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Individual fitness variation multiplier (1.0 = average, >1 = higher calorie burn).",
      "label_i18n": {
        "en": "Efficiency Factor",
        "tr": "Efficiency Factor",
        "de": "Efficiency Factor",
        "fr": "Efficiency Factor",
        "es": "Efficiency Factor",
        "ar": "Efficiency Factor"
      }
    }
  ],
  "formulas": {
    "met": "jumpsPerMinute / 13.636",
    "caloriesPerMinute": "met * weight * 3.5 / 200 * efficiencyFactor",
    "caloriesBurned": "caloriesPerMinute * duration"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "met",
      "caloriesPerMinute"
    ]
  },

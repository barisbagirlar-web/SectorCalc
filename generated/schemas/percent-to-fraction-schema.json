{
  "toolName": "percent-to-fraction",
  "inputs": [
    {
      "id": "percentValue",
      "label": "Yüzde Değeri",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Yüzde olarak girilen değer"
    },
    {
      "id": "simplify",
      "label": "Sadeleştir",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Kesiri sadeleştirme seçeneği (1: Evet, 0: Hayır) – not: bu sürümde sadeleştirme uygulanmamaktadır"
    },
    {
      "id": "mixedNumber",
      "label": "Tam Sayılı Kesir",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Kesir tam sayılı olarak gösterilsin mi? (1: Evet, 0: Hayır)"
    },
    {
      "id": "precision",
      "label": "Ondalık Basamak",
      "type": "number",
      "unit": "",
      "default": 2,
      "businessContext": "Yüzde değerinin ondalık basamak sayısı"
    }
  ],
  "formulas": {
    "decimal": "percentValue / 100",
    "pow10": "Math.pow(10, precision)",
    "numeratorRaw": "Math.round(percentValue * pow10)",
    "denominatorRaw": "100 * pow10",
    "whole": "mixedNumber ? Math.floor(numeratorRaw / denominatorRaw) : 0",
    "numeratorFrac": "mixedNumber ? (numeratorRaw - whole * denominatorRaw) : numeratorRaw",
    "denominatorFrac": "denominatorRaw"
  },
  "outputs": {
    "primary": "mixedNumber && whole > 0 ? `${whole} ${numeratorFrac}/${denominatorFrac}` : `${numeratorFrac}/${denominatorFrac}`",
    "breakdown": [
      "Yüzde değeri ondalık sayıya çevrildi: ${decimal}",
      "Kesir olarak yazıldı (${precision} ondalık basamak ile): ${numeratorRaw}/${denominatorRaw}",
      "Sadeleştirme: bu sürümde otomatik sadeleştirme yapılmadı",
      "Tam sayılı kesir gösterimi: ${mixedNumber ? (whole > 0 ? `${whole} tam ${numeratorFrac}/${denominatorFrac}` : `${numeratorFrac}/${denominatorFrac}`) : 'kapalı'}"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

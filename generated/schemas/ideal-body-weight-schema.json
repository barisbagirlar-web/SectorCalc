{
  "toolName": "ideal-body-weight",
  "inputs": [
    {
      "id": "gender_code",
      "label": "Gender (0: Female, 1: Male)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Biyolojik cinsiyet (0: Kadın, 1: Erkek)"
    },
    {
      "id": "height_cm",
      "label": "Height (cm)",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Boy uzunluğu santimetre cinsinden"
    }
  ],
  "formulas": {
    "ibw_kg": "gender_code === 1 ? 50.0 + 0.9 * (height_cm - 150) : 45.5 + 0.9 * (height_cm - 150)",
    "ibw_lbs": "ibw_kg * 2.20462"
  },
  "outputs": {
    "primary": "ibw_kg",
    "breakdown": [
      "ibw_lbs"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

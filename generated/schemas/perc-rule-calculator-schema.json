{
  "toolName": "perc-rule-calculator",
  "inputs": [
    {
      "id": "plannedTime",
      "label": "Planned Production Time",
      "type": "number",
      "unit": "min",
      "default": 480,
      "businessContext": "Total time planned for production including breaks and expected downtime.",
      "label_i18n": {
        "en": "Planned Production Time",
        "tr": "Planned Production Time",
        "de": "Planned Production Time",
        "fr": "Planned Production Time",
        "es": "Planned Production Time",
        "ar": "Planned Production Time"
      }
    },
    {
      "id": "operatingTime",
      "label": "Operating Time",
      "type": "number",
      "unit": "min",
      "default": 460,
      "businessContext": "Actual time the machine was running and producing.",
      "label_i18n": {
        "en": "Operating Time",
        "tr": "Operating Time",
        "de": "Operating Time",
        "fr": "Operating Time",
        "es": "Operating Time",
        "ar": "Operating Time"
      }
    },
    {
      "id": "idealCycleTime",
      "label": "Ideal Cycle Time",
      "type": "number",
      "unit": "sec/unit",
      "default": 30,
      "businessContext": "The theoretical fastest time to produce one unit.",
      "label_i18n": {
        "en": "Ideal Cycle Time",
        "tr": "Ideal Cycle Time",
        "de": "Ideal Cycle Time",
        "fr": "Ideal Cycle Time",
        "es": "Ideal Cycle Time",
        "ar": "Ideal Cycle Time"
      }
    },
    {
      "id": "totalUnits",
      "label": "Total Units Produced",
      "type": "number",
      "unit": "units",
      "default": 900,
      "businessContext": "Total number of units produced, including defective ones.",
      "label_i18n": {
        "en": "Total Units Produced",
        "tr": "Total Units Produced",
        "de": "Total Units Produced",
        "fr": "Total Units Produced",
        "es": "Total Units Produced",
        "ar": "Total Units Produced"
      }
    },
    {
      "id": "defects",
      "label": "Defective Units",
      "type": "number",
      "unit": "units",
      "default": 10,
      "businessContext": "Units that do not meet quality standards.",
      "label_i18n": {
        "en": "Defective Units",
        "tr": "Defective Units",
        "de": "Defective Units",
        "fr": "Defective Units",
        "es": "Defective Units",
        "ar": "Defective Units"
      }
    }
  ],
  "formulas": {
    "availability": "operatingTime / plannedTime",
    "performance": "(idealCycleTime * totalUnits) / (operatingTime * 60)",
    "quality": "(totalUnits - defects) / totalUnits",
    "oee": "availability * performance * quality"
  },
  "outputs": {
    "primary": "oee",
    "breakdown": [
      "availability",
      "performance",
      "quality"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "oee",
    "unit": "min",
    "breakdownUnits": {
      "availability": "%"
    }
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,

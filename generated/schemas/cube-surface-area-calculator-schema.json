  "outputs": {
    "primary": "result",
    "breakdown": [
      "faceArea = sideLength ** 2",
      "baseArea = quantity * exposedFaces * faceArea * unitConversionFactor",
      "totalSurfaceArea = baseArea * (1 + safetyMargin/100)"

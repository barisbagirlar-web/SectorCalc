{
  "toolName": "one-rep-max-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight Lifted",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The weight used for the lift, in kilograms."
    },
    {
      "id": "reps",
      "label": "Repetitions",
      "type": "number",
      "unit": "reps",
      "default": 10,
      "businessContext": "Number of repetitions performed to failure or near failure."
    }
  ],
  "formulas": {
    "oneRepMax": "weight * (1 + reps / 30)",
    "weight": "weight",
    "reps": "reps",
    "multiplier": "1 + reps / 30"
  },
  "outputs": {
    "primary": "oneRepMax",
    "breakdown": [
      "weight",
      "reps",
      "multiplier"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
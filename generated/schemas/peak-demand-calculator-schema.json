{
  "toolName": "peak-demand-calculator",
  "inputs": [
    {
      "id": "connectedLoad",
      "label": "Toplam Bağlı Yük",
      "type": "number",
      "unit": "kW",
      "default": 100,
      "businessContext": "Tesisteki tüm ekipmanların anma güçlerinin toplamı (kW cinsinden)",
      "label_i18n": {
        "en": "Toplam Bağlı Yük",
        "tr": "Toplam Bağlı Yük",
        "de": "Toplam Bağlı Yük",
        "fr": "Toplam Bağlı Yük",
        "es": "Toplam Bağlı Yük",
        "ar": "Toplam Bağlı Yük"
      }
    },
    {
      "id": "demandFactor",
      "label": "Talep Faktörü",
      "type": "number",
      "unit": "-",
      "default": 0.8,
      "businessContext": "Maksimum talebin toplam bağlı yüke oranı, tipik olarak 0-1 arasındadır",
      "label_i18n": {
        "en": "Talep Faktörü",
        "tr": "Talep Faktörü",
        "de": "Talep Faktörü",
        "fr": "Talep Faktörü",
        "es": "Talep Faktörü",
        "ar": "Talep Faktörü"
      }
    },
    {
      "id": "powerFactor",
      "label": "Güç Faktörü",
      "type": "number",
      "unit": "-",
      "default": 0.9,
      "businessContext": "Aktif gücün görünür güce oranı, tipik olarak 0-1 arasındadır",
      "label_i18n": {
        "en": "Güç Faktörü",
        "tr": "Güç Faktörü",
        "de": "Güç Faktörü",
        "fr": "Güç Faktörü",
        "es": "Güç Faktörü",
        "ar": "Güç Faktörü"
      }
    },
    {
      "id": "reserveMargin",
      "label": "Yedek Kapasite Marjı",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Gelecekteki büyüme veya belirsizlik için eklenen yüzde marj",
      "label_i18n": {
        "en": "Yedek Kapasite Marjı",
        "tr": "Yedek Kapasite Marjı",
        "de": "Yedek Kapasite Marjı",
        "fr": "Yedek Kapasite Marjı",
        "es": "Yedek Kapasite Marjı",
        "ar": "Yedek Kapasite Marjı"
      }
    }
  ],
  "formulas": {
    "peakDemand_kW": "connectedLoad * demandFactor * (1 + reserveMargin / 100)",
    "peakDemand_kVA": "peakDemand_kW / powerFactor",
    "demandPercentage": "(peakDemand_kW / connectedLoad) * 100"
  },
  "outputs": {
    "primary": "peakDemand_kW",
    "breakdown": [
      "peakDemand_kVA",
      "demandPercentage"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "demandPercentage"
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,

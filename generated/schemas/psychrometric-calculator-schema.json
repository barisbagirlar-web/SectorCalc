{
  "toolName": "psychrometric-calculator",
  "inputs": [
    {
      "id": "dryBulbTemp",
      "label": "Dry Bulb Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Ambient air temperature measured by a standard thermometer."
    },
    {
      "id": "relativeHumidity",
      "label": "Relative Humidity",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Percentage of water vapor in the air relative to saturation."
    },
    {
      "id": "atmosphericPressure",
      "label": "Atmospheric Pressure",
      "type": "number",
      "unit": "kPa",
      "default": 101.325,
      "businessContext": "Standard sea-level atmospheric pressure."
    }
  ],
  "formulas": {
    "saturationVaporPressure": "0.6108 * Math.exp((17.27 * dryBulbTemp) / (dryBulbTemp + 237.3))",
    "actualVaporPressure": "relativeHumidity / 100 * saturationVaporPressure",
    "humidityRatio": "0.622 * actualVaporPressure / (atmosphericPressure - actualVaporPressure)",
    "enthalpy": "1.006 * dryBulbTemp + humidityRatio * (2501 + 1.86 * dryBulbTemp)",
    "specificVolume": "0.2871 * (dryBulbTemp + 273.15) * (1 + 1.6078 * humidityRatio) / atmosphericPressure",
    "dewPoint": "237.3 * Math.log(actualVaporPressure / 0.6108) / (17.27 - Math.log(actualVaporPressure / 0.6108))"
  },
  "outputs": {
    "primary": "enthalpy",
    "breakdown": [
      "saturationVaporPressure",
      "actualVaporPressure",
      "humidityRatio",
      "specificVolume",
      "dewPoint"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

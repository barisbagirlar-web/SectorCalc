{
  "toolName": "sprinkler-calculator",
  "inputs": [
    {
      "id": "designArea",
      "label": "Design Area",
      "type": "number",
      "unit": "ft²",
      "default": 1500,
      "businessContext": "The design area of sprinkler operation per NFPA 13.",
      "label_i18n": {
        "en": "Design Area",
        "tr": "Kayma modülü (çelik için tipik)",
        "de": "Design Area",
        "fr": "Design Area",
        "es": "Design Area",
        "ar": "Design Area"
      },
      "businessContext_i18n": {
        "en": "The design area of sprinkler operation per NFPA 13.",
        "tr": "Tasarım Alanı"
      }
    },
    {
      "id": "density",
      "label": "Discharge Density",
      "type": "number",
      "unit": "gpm/ft²",
      "default": 0.1,
      "businessContext": "Water density required per square foot per minute.",
      "label_i18n": {
        "en": "Discharge Density",
        "tr": "NFPA 13'e göre sprinkler işletim tasarım alanı.",
        "de": "Discharge Density",
        "fr": "Discharge Density",
        "es": "Discharge Density",
        "ar": "Discharge Density"
      },
      "businessContext_i18n": {
        "en": "Water density required per square foot per minute.",
        "tr": "Boşaltma Yoğunluğu"
      }
    },
    {
      "id": "kFactor",
      "label": "Sprinkler K-Factor",
      "type": "number",
      "unit": "gpm/psi^0.5",
      "default": 5.6,
      "businessContext": "Discharge coefficient of the sprinkler head.",
      "label_i18n": {
        "en": "Sprinkler K-Factor",
        "tr": "Metrekare başına dakikada gerekli su yoğunluğu.",
        "de": "Sprinkler K-Factor",
        "fr": "Sprinkler K-Factor",
        "es": "Sprinkler K-Factor",
        "ar": "Sprinkler K-Factor"
      },
      "businessContext_i18n": {
        "en": "Discharge coefficient of the sprinkler head.",
        "tr": "Sprinkler K-Faktörü"
      }
    },
    {
      "id": "numSprinklers",
      "label": "Number of Sprinklers",
      "type": "number",
      "unit": "ea",
      "default": 12,
      "businessContext": "Number of sprinklers expected to operate in the design area.",
      "label_i18n": {
        "en": "Number of Sprinklers",
        "tr": "Sprinkler başlığının boşaltma katsayısı.",
        "de": "Number of Sprinklers",
        "fr": "Number of Sprinklers",
        "es": "Number of Sprinklers",
        "ar": "Number of Sprinklers"
      },
      "businessContext_i18n": {
        "en": "Number of sprinklers expected to operate in the design area.",
        "tr": "Sprinkler Sayısı"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.1,
      "businessContext": "Factor to account for system inefficiencies.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Güvenlik Faktörü",
        "de": "Sicherheitsfaktor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      },
      "businessContext_i18n": {
        "en": "Factor to account for system inefficiencies.",
        "tr": "Sistem verimsizliklerini hesaba katan faktör."
      }
    },
    {
      "id": "pipeFrictionLoss",
      "label": "Pipe Friction Loss",
      "type": "number",
      "unit": "psi",
      "default": 5,
      "businessContext": "Estimated friction loss in piping.",
      "label_i18n": {
        "en": "Pipe Friction Loss",
        "tr": "Boru Sürtünme Kaybı",
        "de": "Pipe Friction Loss",
        "fr": "Pipe Friction Loss",
        "es": "Pipe Friction Loss",
        "ar": "Pipe Friction Loss"
      },
      "businessContext_i18n": {
        "en": "Estimated friction loss in piping.",
        "tr": "Boru hattında tahmini sürtünme kaybı."
      }
    }
  ],
  "formulas": {
    "totalFlow": "designArea * density * safetyFactor",
    "flowPerSprinkler": "totalFlow / numSprinklers",
    "requiredPressure": "(flowPerSprinkler / kFactor) ** 2",
    "totalPressure": "requiredPressure + pipeFrictionLoss"
  },
  "outputs": {
    "primary": "totalFlow",
    "breakdown": [
      "flowPerSprinkler",
      "requiredPressure",
      "totalPressure"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPressure",
    "unit": "ft²"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,
  "catalogCategory": "ecology-environment",
  "sectorSlug": "energy-carbon",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "matematik",
  "profession": "Matematikçi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

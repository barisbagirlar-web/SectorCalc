  "formulas": {
    "MRR": "V_c * f * a_p",
    "Power": "MRR * SpecEnergy",
    "ToolLife": "C / (V_c^n * f^m)",
    "Cost": "MIN(Mach + Change + Tool)",
    "Opt_Vc": "(C / (T_opt)^n)^(1/n)",
    "T_opt": "((1/n - 1) * (ChangeTime + ToolCost/MachRate))",
    "Ra": "f^2 / (8 * NoseRad)",
    "Check": "Power < MaxPower AND Ra < Tol"
  },

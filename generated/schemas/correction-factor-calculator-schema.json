      },
      "businessContext_i18n": {
        "en": "Gas compressibility factor (1 for ideal gas)",
        "tr": "Gaz sıkıştırılabilirlik faktörü (ideal gaz için 1)",
        "de": "Gaskompressibilitätsfaktor (1 für ideales Gas)",

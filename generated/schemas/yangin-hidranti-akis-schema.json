  "formulas": {
    "FlowRate_Q": "29.83 * c_d * d^2 * SQRT(P_Pitot)",
    "ResidualPressure": "P_Static - (FlowRate_Q / Coefficient)^1.85",
    "AvailableFlow_At20psi": "FlowRate_Q * ((P_Static - 20) / (P_Static - P_Residual))^0.54",
    "FrictionLoss": "f * (Length / Diameter) * (Velocity^2 / 2g)",
    "RequiredPumpHead": "ElevationHead + FrictionLoss + NozzlePressure",
    "Compliance": "IF(AvailableFlow_At20psi > RequiredFlow, \"PASS\", \"FAIL\")"
  },

    {
      "id": "finePerCitation",
      "label": "Ceza Başına Para Cezası",
      "type": "number",
      "unit": "TL",
      "default": 500,
      "businessContext": "Her bir ceza için ödenmesi gereken temel para cezası tutarı",
      "label_i18n": {
        "en": "Ceza Başına Para Cezası",
        "tr": "Ceza Başına Para Cezası",

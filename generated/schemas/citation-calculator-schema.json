      "unit": "unit",
      "default": 1,
      "businessContext": "Ceza ciddiyetine göre çarpan (örn. tekerrür, yük hasarı vb.)",
      "label_i18n": {
        "en": "Ağırlaştırıcı Çarpan",
        "tr": "Ağırlaştırıcı Çarpan",
        "de": "Ağırlaştırıcı Çarpan",
        "fr": "Ağırlaştırıcı Çarpan",
        "es": "Ağırlaştırıcı Çarpan",
        "ar": "Ağırlaştırıcı Çarpan"
      }
    },
    {
      "id": "processingFeePerCitation",
      "label": "İşlem Ücreti (Ceza Başına)",
      "type": "number",
      "unit": "TL",
      "default": 50,
      "businessContext": "Her ceza için tahsil edilen idari işlem ücreti",
      "label_i18n": {
        "en": "İşlem Ücreti (Ceza Başına)",
        "tr": "İşlem Ücreti (Ceza Başına)",
        "de": "İşlem Ücreti (Ceza Başına)",
        "fr": "İşlem Ücreti (Ceza Başına)",
        "es": "İşlem Ücreti (Ceza Başına)",
        "ar": "İşlem Ücreti (Ceza Başına)"
      }
    },
    {
      "id": "earlyPaymentDiscount",
      "label": "Erken Ödeme İndirimi (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Erken ödeme durumunda uygulanacak yüzde indirim (0 ise indirim yok)",
      "label_i18n": {
        "en": "Erken Ödeme İndirimi (%)",
        "tr": "Erken Ödeme İndirimi (%)",
        "de": "Erken Ödeme İndirimi (%)",
        "fr": "Erken Ödeme İndirimi (%)",
        "es": "Erken Ödeme İndirimi (%)",
        "ar": "Erken Ödeme İndirimi (%)"
      }
    }
  ],
  "formulas": {
    "totalFine": "numCitations * finePerCitation * severityMultiplier",
    "totalProcessing": "numCitations * processingFeePerCitation",
    "grossTotal": "totalFine + totalProcessing",
    "discountAmount": "grossTotal * (earlyPaymentDiscount / 100)",
    "netTotal": "grossTotal - discountAmount"
  },
  "outputs": {
    "primary": "netTotal",
    "breakdown": [
      "totalFine",
      "totalProcessing",
      "discountAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netTotal"
  },

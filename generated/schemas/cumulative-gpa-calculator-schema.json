  "formulas": {
    "cumulativeGPA": "(previousGPA * previousCredits + newGPA * newCredits) / (previousCredits + newCredits)",
    "totalGradePoints": "previousGPA * previousCredits + newGPA * newCredits",
    "totalCredits": "previousCredits + newCredits"
  },
  "outputs": {
    "primary": "cumulativeGPA",
    "breakdown": [
      "totalGradePoints",
      "totalCredits"
    ]

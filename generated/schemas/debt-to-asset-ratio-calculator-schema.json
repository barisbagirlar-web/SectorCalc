        "en": "Current Assets",
        "tr": "Current Assets",
        "de": "Current Assets",
        "fr": "Current Assets",
        "es": "Current Assets",
        "ar": "Current Assets"
      }
    },
    {
      "id": "nonCurrentAssets",
      "label": "Non-Current Assets",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Long-term investments and property, plant, equipment",
      "label_i18n": {
        "en": "Non-Current Assets",
        "tr": "Non-Current Assets",
        "de": "Non-Current Assets",
        "fr": "Non-Current Assets",
        "es": "Non-Current Assets",
        "ar": "Non-Current Assets"
      }
    }
  ],
  "formulas": {
    "totalLiabilities": "shortTermLiabilities + longTermLiabilities",
    "totalAssets": "currentAssets + nonCurrentAssets",
    "debtToAssetRatio": "totalAssets !== 0 ? (totalLiabilities / totalAssets) * 100 : null"
  },
  "outputs": {
    "primary": "debtToAssetRatio",
    "breakdown": [
      "totalLiabilities",
      "totalAssets"
    ],

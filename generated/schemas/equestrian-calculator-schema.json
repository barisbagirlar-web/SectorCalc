  "formulas": {
    "normalized_product": "load_mass * (slope_percent / 100) * rolling_resistance * desired_speed",
    "result": "load_mass * (slope_percent / 100) * rolling_resistance * desired_speed * (horse_pull_force * (efficiency / 100))",
    "adjustment_factor": "horse_pull_force * (efficiency / 100)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "normalized_product",
      "adjustment_factor"
    ],

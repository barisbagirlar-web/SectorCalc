{
  "toolName": "filtration-calculator",
  "inputs": [
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "m³/s",
      "default": 0.001,
      "businessContext": "Target volumetric flow rate of the fluid to be filtered.",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Flow Rate",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      }
    },
    {
      "id": "viscosity",
      "label": "Dynamic Viscosity",
      "type": "number",
      "unit": "Pa·s",
      "default": 0.001,
      "businessContext": "Dynamic viscosity of the fluid.",
      "label_i18n": {
        "en": "Dynamic Viscosity",
        "tr": "Dynamic Viscosity",
        "de": "Dynamic Viscosity",
        "fr": "Dynamic Viscosity",
        "es": "Dynamic Viscosity",
        "ar": "Dynamic Viscosity"
      }
    },
    {
      "id": "pressureDrop",
      "label": "Pressure Drop",
      "type": "number",
      "unit": "Pa",
      "default": 100000,
      "businessContext": "Maximum allowable pressure drop across the filter.",
      "label_i18n": {
        "en": "Pressure Drop",
        "tr": "Pressure Drop",
        "de": "Pressure Drop",
        "fr": "Pressure Drop",
        "es": "Pressure Drop",
        "ar": "Pressure Drop"
      }
    },
    {
      "id": "membraneResistance",
      "label": "Membrane Resistance",
      "type": "number",
      "unit": "1/m",
      "default": 10000000000,
      "businessContext": "Resistance of the clean filter medium.",
      "label_i18n": {
        "en": "Membrane Resistance",
        "tr": "Membrane Resistance",
        "de": "Membrane Resistance",
        "fr": "Membrane Resistance",
        "es": "Membrane Resistance",
        "ar": "Membrane Resistance"
      }
    },
    {
      "id": "cakeResistance",
      "label": "Cake Resistance",
      "type": "number",
      "unit": "1/m",
      "default": 0,
      "businessContext": "Additional resistance from the filter cake (0 for clean filter).",
      "label_i18n": {
        "en": "Cake Resistance",
        "tr": "Cake Resistance",
        "de": "Cake Resistance",
        "fr": "Cake Resistance",
        "es": "Cake Resistance",
        "ar": "Cake Resistance"
      }
    }
  ],
  "formulas": {
    "totalResistance": "membraneResistance + cakeResistance",
    "requiredFilterArea": "(flowRate * viscosity * totalResistance) / pressureDrop",
    "flux": "flowRate / requiredFilterArea"
  },
  "outputs": {
    "primary": "requiredFilterArea",
    "breakdown": [
      "flux",
      "totalResistance"
    ],

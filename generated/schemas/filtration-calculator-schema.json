        "de": "Widerstand des sauberen Filtermediums"
      }
    },
    {
      "id": "cakeResistance",
      "label": "Cake Resistance",
      "type": "number",
      "unit": "1/m",
      "default": 0,
      "businessContext": "Additional resistance from the filter cake (0 for clean filter).",
      "label_i18n": {
        "en": "Cake Resistance",
        "tr": "Kek direnci",
        "de": "Kuchenwiderstand",
        "fr": "Cake Resistance",
        "es": "Cake Resistance",
        "ar": "Cake Resistance"
      },
      "businessContext_i18n": {
        "en": "Additional resistance from the filter cake (0 for clean filter).",

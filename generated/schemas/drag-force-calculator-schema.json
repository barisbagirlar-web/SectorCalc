{
  "toolName": "drag-force-calculator",
  "inputs": [
    {
      "id": "fluidDensity",
      "label": "Fluid Density (ρ)",
      "type": "number",
      "unit": "kg/m³",
      "default": 1.225,
      "businessContext": "The density of the fluid through which the object moves. For air at sea level and 15°C, use 1.225 kg/m³.",
      "label_i18n": {
        "en": "Fluid Density (ρ)",
        "tr": "Fluid Density (ρ)",
        "de": "Fluid Density (ρ)",
        "fr": "Fluid Density (ρ)",
        "es": "Fluid Density (ρ)",
        "ar": "Fluid Density (ρ)"
      }
    },
    {
      "id": "velocity",
      "label": "Flow Velocity (v)",
      "type": "number",
      "unit": "m/s",
      "default": 10,
      "businessContext": "Relative velocity between the object and the fluid.",
      "label_i18n": {
        "en": "Flow Velocity (v)",
        "tr": "Flow Velocity (v)",
        "de": "Flow Velocity (v)",
        "fr": "Flow Velocity (v)",
        "es": "Flow Velocity (v)",
        "ar": "Flow Velocity (v)"
      }
    },
    {
      "id": "dragCoefficient",
      "label": "Drag Coefficient (Cd)",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.5,
      "businessContext": "Empirical coefficient that depends on the shape of the object. Typical values: smooth sphere 0.47, streamlined body 0.04, cube 1.05.",
      "label_i18n": {
        "en": "Drag Coefficient (Cd)",
        "tr": "Drag Coefficient (Cd)",
        "de": "Drag Coefficient (Cd)",
        "fr": "Drag Coefficient (Cd)",
        "es": "Drag Coefficient (Cd)",
        "ar": "Drag Coefficient (Cd)"
      }
    },
    {
      "id": "referenceArea",
      "label": "Reference Area (A)",
      "type": "number",
      "unit": "m²",
      "default": 1,
      "businessContext": "The frontal area of the object perpendicular to the flow, or other appropriate reference area.",
      "label_i18n": {
        "en": "Reference Area (A)",
        "tr": "Reference Area (A)",
        "de": "Reference Area (A)",
        "fr": "Reference Area (A)",
        "es": "Reference Area (A)",
        "ar": "Reference Area (A)"
      }
    }
  ],
  "formulas": {
    "dynamicPressure": "0.5 * fluidDensity * velocity ** 2",
    "dragForce": "dynamicPressure * dragCoefficient * referenceArea"
  },
  "outputs": {
    "primary": "dragForce",
    "breakdown": [
      "dynamicPressure",
      "dragForce"
    ],

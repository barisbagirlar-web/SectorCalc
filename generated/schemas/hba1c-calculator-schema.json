        "tr": "Son 2-3 aydaki ortalama kan şekeri seviyesi."
      }
    },
    {
      "id": "unit",
      "label": "Glucose Unit",
      "type": "number",
      "unit": "0=mg/dL, 1=mmol/L",
      "default": 0,
      "businessContext": "Select the unit: 0 for mg/dL, 1 for mmol/L.",
      "label_i18n": {
        "en": "Glucose Unit",
        "tr": "Glikoz Birimi",
        "de": "Glucose Unit",
        "fr": "Glucose Unit",
        "es": "Glucose Unit",
        "ar": "Glucose Unit"
      },
      "businessContext_i18n": {
        "en": "Select the unit: 0 for mg/dL, 1 for mmol/L.",
        "tr": "Birimi seçin: mg/dL için 0, mmol/L için 1."
      }
    },
    {
      "id": "confidence",
      "label": "Confidence Level",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Confidence level for uncertainty range calculation.",
      "label_i18n": {
        "en": "Confidence Level",
        "tr": "Güven Düzeyi",
        "de": "Confidence Level",
        "fr": "Confidence Level",
        "es": "Confidence Level",
        "ar": "Confidence Level"
      },
      "businessContext_i18n": {
        "en": "Confidence level for uncertainty range calculation.",
        "tr": "Belirsizlik aralığı hesaplaması için güven düzeyi."
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Typical measurement uncertainty of HbA1c assay method.",
      "label_i18n": {
        "en": "Measurement Uncertainty",
        "tr": "Ölçüm Belirsizliği",
        "de": "Measurement Uncertainty",
        "fr": "Measurement Uncertainty",
        "es": "Measurement Uncertainty",
        "ar": "Measurement Uncertainty"
      },
      "businessContext_i18n": {
        "en": "Typical measurement uncertainty of HbA1c assay method.",
        "tr": "HbA1c test yönteminin tipik ölçüm belirsizliği."
      }
    }
  ],
  "formulas": {
    "eAG_mgdl": "unit == 0 ? glucose : glucose * 18.0182",
    "eAG_mmol": "unit == 0 ? glucose / 18.0182 : glucose",
    "hba1cPercent": "(eAG_mgdl + 46.7) / 28.7",
    "hba1cMmolMol": "10.93 * eAG_mmol - 23.5",
    "rangeLow": "hba1cPercent * (1 - measurementUncertainty / 100)",
    "rangeHigh": "hba1cPercent * (1 + measurementUncertainty / 100)"
  },
  "outputs": {
    "primary": "hba1cPercent",
    "breakdown": [
      "hba1cMmolMol",
      "eAG_mgdl",
      "eAG_mmol",
      "rangeLow",
      "rangeHigh"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rangeHigh",
    "unit": "%"
  },

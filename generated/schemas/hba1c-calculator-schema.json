{
  "toolName": "hba1c-calculator",
  "inputs": [
    {
      "id": "glucose",
      "label": "Average Blood Glucose",
      "type": "number",
      "unit": "mg/dL or mmol/L",
      "default": 120,
      "businessContext": "Average blood glucose level over the past 2-3 months.",
      "label_i18n": {
        "en": "Average Blood Glucose",
        "tr": "Average Blood Glucose",
        "de": "Average Blood Glucose",
        "fr": "Average Blood Glucose",
        "es": "Average Blood Glucose",
        "ar": "Average Blood Glucose"
      }
    },
    {
      "id": "unit",
      "label": "Glucose Unit",
      "type": "number",
      "unit": "0=mg/dL, 1=mmol/L",
      "default": 0,
      "businessContext": "Select the unit: 0 for mg/dL, 1 for mmol/L.",
      "label_i18n": {
        "en": "Glucose Unit",
        "tr": "Glucose Unit",
        "de": "Glucose Unit",
        "fr": "Glucose Unit",
        "es": "Glucose Unit",
        "ar": "Glucose Unit"
      }
    },
    {
      "id": "confidence",
      "label": "Confidence Level",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Confidence level for uncertainty range calculation.",
      "label_i18n": {
        "en": "Confidence Level",
        "tr": "Confidence Level",
        "de": "Confidence Level",
        "fr": "Confidence Level",
        "es": "Confidence Level",
        "ar": "Confidence Level"
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Typical measurement uncertainty of HbA1c assay method.",
      "label_i18n": {
        "en": "Measurement Uncertainty",
        "tr": "Measurement Uncertainty",
        "de": "Measurement Uncertainty",
        "fr": "Measurement Uncertainty",
        "es": "Measurement Uncertainty",
        "ar": "Measurement Uncertainty"
      }
    }
  ],
  "formulas": {
    "eAG_mgdl": "unit == 0 ? glucose : glucose * 18.0182",
    "eAG_mmol": "unit == 0 ? glucose / 18.0182 : glucose",
    "hba1cPercent": "(eAG_mgdl + 46.7) / 28.7",
    "hba1cMmolMol": "10.93 * eAG_mmol - 23.5",
    "rangeLow": "hba1cPercent * (1 - measurementUncertainty / 100)",
    "rangeHigh": "hba1cPercent * (1 + measurementUncertainty / 100)"
  },
  "outputs": {
    "primary": "hba1cPercent",
    "breakdown": [
      "hba1cMmolMol",
      "eAG_mgdl",
      "eAG_mmol",
      "rangeLow",
      "rangeHigh"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rangeHigh"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Sağlık & Tıp",
  "premiumRequired": false,

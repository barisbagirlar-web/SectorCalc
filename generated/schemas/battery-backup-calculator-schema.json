    },
    {
      "id": "temperatureDerating",
      "label": "Sıcaklık Düzeltme Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Düşük sıcaklıklarda kapasite kaybını telafi eden katsayı (≤1). 1: oda sıcaklığı",
      "label_i18n": {
        "en": "Sıcaklık Düzeltme Faktörü",
        "tr": "Sıcaklık Düzeltme Faktörü",

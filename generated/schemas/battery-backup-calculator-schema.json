        "es": "Sıcaklık Düzeltme Faktörü",
        "ar": "Sıcaklık Düzeltme Faktörü"
      }
    }
  ],
  "formulas": {
    "totalBatteryEnergyWh": "batteryCapacityAh * systemVoltage * safetyFactor * temperatureDerating",
    "usableEnergyWh": "totalBatteryEnergyWh * (depthOfDischarge / 100) * (inverterEfficiency / 100)",
    "estimatedBackupTimeHours": "usableEnergyWh / loadPower"
  },
  "outputs": {
    "primary": "estimatedBackupTimeHours",
    "breakdown": [
      "totalBatteryEnergyWh",
      "usableEnergyWh"
    ],

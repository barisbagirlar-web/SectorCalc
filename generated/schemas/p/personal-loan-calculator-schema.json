  "formulas": {
    "taksit": "faiz === 0 ? (tutar - masraf) / Math.max(1, vade) : (tutar - masraf) * ((faiz / 1200) * Math.pow(1 + faiz / 1200, vade)) / (Math.pow(1 + faiz / 1200, vade) - 1)",
    "sonuc": "((faiz === 0 ? (tutar - masraf) / Math.max(1, vade) : (tutar - masraf) * ((faiz / 1200) * Math.pow(1 + faiz / 1200, vade)) / (Math.pow(1 + faiz / 1200, vade) - 1)) * vade + masraf - tutar)"
  },

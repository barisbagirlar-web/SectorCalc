{
  "toolName": "paving-stone-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Paving Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 30,
      "min": 0,
      "businessContext": "Area to pave."
    },
    {
      "id": "tasEn",
      "label": "Stone Width (m)",
      "type": "number",
      "unit": "m",
      "default": 0.1,
      "min": 0,
      "businessContext": "Paver width."
    },
    {
      "id": "tasBoy",
      "label": "Stone Length (m)",
      "type": "number",
      "unit": "m",
      "default": 0.2,
      "min": 0,
      "businessContext": "Paver length."
    },
    {
      "id": "scrap",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "min": 0,
      "businessContext": "Cutting waste."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.ceil((area / Math.max(0.0001, (tasEn * tasBoy))) * (1 + scrap / 100))"
  },
  "outputs": {
    "primary": "result",
    "unit": "stones",
    "breakdown": {
      "result": "Gerekli Kilit Tasi"
    },
    "breakdownUnits": {
      "result": "stones"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate number of paving stones needed for a patio or driveway.",
      "long": "Calculate number of paving stones needed for a patio or driveway."
    }
  },
  "sectorSlug": "daily-renovation"
}

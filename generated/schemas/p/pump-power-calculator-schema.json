{
  "toolName": "pump-power-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "flow",
      "label": "Flow Rate (m³/h)",
      "type": "number",
      "unit": "m3/h",
      "default": 10,
      "min": 0,
      "businessContext": "Pumping flow rate."
    },
    {
      "id": "height",
      "label": "Total Head (m)",
      "type": "number",
      "unit": "m",
      "default": 50,
      "min": 0,
      "businessContext": "Suction + discharge head."
    },
    {
      "id": "efficiency",
      "label": "Pump Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 70,
      "min": 0,
      "businessContext": "Pump efficiency."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(flow * height * 9.81) / Math.max(0.0001, (3600 * (efficiency / 100)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "kW",
    "breakdown": {
      "result": "Min. Pump Power"
    },
    "breakdownUnits": {
      "result": "kW"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate minimum pump shaft power for water lifting.",
      "long": "Calculate minimum pump shaft power for water lifting."
    }
  },

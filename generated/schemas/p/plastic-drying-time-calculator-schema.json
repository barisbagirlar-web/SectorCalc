{
  "toolName": "plastic-drying-time-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "malzemeKutle",
      "label": "Material Mass (kg)",
      "type": "number",
      "unit": "kg",
      "default": 50,
      "min": 0,
      "businessContext": "Polymer to dry."
    },
    {
      "id": "nemOrani",
      "label": "Moisture Content (%)",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "min": 0,
      "businessContext": "Polymer moisture percentage."
    },
    {
      "id": "havaDebi",
      "label": "Air Flow (kg/s)",
      "type": "number",
      "unit": "kg/s",
      "default": 0.5,
      "min": 0,
      "businessContext": "Drying air flow."
    },
    {
      "id": "nemAlmaKapasite",
      "label": "Moisture Removal Capacity (kg/kg)",
      "type": "number",
      "unit": "scalar",
      "default": 0.005,
      "min": 0,
      "businessContext": "Air moisture removal capacity."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(malzemeKutle * (nemOrani / 100)) / Math.max(0.0001, (havaDebi * nemAlmaKapasite))"
  },
  "outputs": {
    "primary": "result",
    "unit": "s",
    "breakdown": {
      "result": "Drying Time"
    },
    "breakdownUnits": {
      "result": "s"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling parameters for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate drying time for hygroscopic polymer to reach processable moisture.",
      "long": "Calculate drying time for hygroscopic polymer to reach processable moisture."
    }
  },
  "sectorSlug": "daily-renovation"
}

{
  "toolName": "madrs-calculator",
  "inputs": [
    {
      "id": "axleDiameter",
      "label": "Axle Diameter",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "The diameter of the machine axle under analysis.",
      "label_i18n": {
        "en": "Axle Diameter",
        "tr": "Axle Diameter",
        "de": "Axle Diameter",
        "fr": "Axle Diameter",
        "es": "Axle Diameter",
        "ar": "Axle Diameter"
      }
    },
    {
      "id": "axleLength",
      "label": "Axle Length",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "businessContext": "The unsupported length of the axle between bearings.",
      "label_i18n": {
        "en": "Axle Length",
        "tr": "Axle Length",
        "de": "Axle Length",
        "fr": "Axle Length",
        "es": "Axle Length",
        "ar": "Axle Length"
      }
    },
    {
      "id": "load",
      "label": "Applied Load",
      "type": "number",
      "unit": "N",
      "default": 1000,
      "businessContext": "Central point load acting on the axle.",
      "label_i18n": {
        "en": "Applied Load",
        "tr": "Applied Load",
        "de": "Applied Load",
        "fr": "Applied Load",
        "es": "Applied Load",
        "ar": "Applied Load"
      }
    },
    {
      "id": "elasticModulus",
      "label": "Elastic Modulus",
      "type": "number",
      "unit": "GPa",
      "default": 210,
      "businessContext": "Material's modulus of elasticity (e.g., steel ≈ 210 GPa).",
      "label_i18n": {
        "en": "Elastic Modulus",
        "tr": "Elastic Modulus",
        "de": "Elastic Modulus",
        "fr": "Elastic Modulus",
        "es": "Elastic Modulus",
        "ar": "Elastic Modulus"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Design safety factor for allowable stress comparison.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "momentOfInertia": "Math.PI * Math.pow(axleDiameter, 4) / 64",
    "maxDeflection": "(load * Math.pow(axleLength, 3)) / (48 * elasticModulus * 1000 * momentOfInertia)",
    "maxBendingStress": "(load * axleLength * axleDiameter) / (8 * momentOfInertia)"
  },
  "outputs": {
    "primary": "maxDeflection",
    "breakdown": [
      "momentOfInertia",
      "maxBendingStress"
    ]
  },
  "category": "İSG & Risk Yönetimi",

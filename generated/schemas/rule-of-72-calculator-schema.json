{
  "toolName": "rule-of-72-calculator",
  "inputs": [
    {
      "id": "interestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "The nominal annual interest rate, before compounding effect.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "compoundingFrequency",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "times/year",
      "default": 1,
      "businessContext": "Number of compounding periods per year (e.g., 1 for annual, 12 for monthly).",
      "label_i18n": {
        "en": "Compounding Frequency",
        "tr": "Compounding Frequency",
        "de": "Compounding Frequency",
        "fr": "Compounding Frequency",
        "es": "Compounding Frequency",
        "ar": "Compounding Frequency"
      }
    },
    {
      "id": "ruleConstant",
      "label": "Rule Constant",
      "type": "number",
      "unit": "year·%",
      "default": 72,
      "businessContext": "The constant used in the rule of 72 (typically 72, but can be 70 or 69.3 for more precision).",
      "label_i18n": {
        "en": "Rule Constant",
        "tr": "Rule Constant",
        "de": "Rule Constant",
        "fr": "Rule Constant",
        "es": "Rule Constant",
        "ar": "Rule Constant"
      }
    },
    {
      "id": "initialInvestment",
      "label": "Initial Investment",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "The initial amount invested.",
      "label_i18n": {
        "en": "Initial Investment",
        "tr": "Initial Investment",
        "de": "Initial Investment",
        "fr": "Initial Investment",
        "es": "Initial Investment",
        "ar": "Initial Investment"
      }
    }
  ],
  "formulas": {
    "effectiveRate": "((1 + interestRate / 100 / compoundingFrequency) ** compoundingFrequency - 1)",
    "approxYears": "ruleConstant / interestRate",
    "finalApprox": "initialInvestment * (1 + effectiveRate) ** approxYears"
  },
  "outputs": {
    "primary": "approxYears",
    "breakdown": [
      "exactYears",
      "effectiveRate",
      "finalExact",
      "finalApprox"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalApprox"
  },
  "category": "Finans & Yatırım",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "matematik",
  "profession": "Matematikçi",
  "categoryId": "finance",

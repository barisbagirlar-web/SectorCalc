  "formulas": {
    "totalWallArea": "(2 * (roomLength + roomWidth)) * roomHeight",
    "totalOpenings": "numberOfDoors * 2 + numberOfWindows * 1.5",
    "netArea": "totalWallArea - totalOpenings",
    "totalAreaWithWaste": "netArea * (1 + wasteFactor / 100)",
    "compound_kg": "totalAreaWithWaste * 0.4",
    "tape_m": "totalAreaWithWaste * 1.5"
  },
  "outputs": {
    "primary": "tape_m",
    "breakdown": [
      "compound_kg",
      "tape_m",
      "screws"
    ],

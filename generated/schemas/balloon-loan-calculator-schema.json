        "fr": "Taux d'intérêt annuel nominal",
        "es": "Tasa de interés nominal anual",
        "ar": "معدل الفائدة السنوي الاسمي"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration until balloon payment",
      "label_i18n": {
        "en": "Loan Term (Years)",
        "tr": "Kredi Vadesi (Yıl)",
        "de": "Kreditlaufzeit (Jahre)",
        "fr": "Durée du prêt (années)",
        "es": "Plazo del préstamo (años)",
        "ar": "مدة القرض (بالسنوات)"
      },
      "businessContext_i18n": {
        "en": "Duration until balloon payment",
        "tr": "Balon ödemeye kadar geçen süre",

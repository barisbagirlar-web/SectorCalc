{
  "toolName": "balloon-loan-calculator",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "Total borrowed amount",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Loan Amount",
        "de": "Loan Amount",
        "fr": "Loan Amount",
        "es": "Loan Amount",
        "ar": "Loan Amount"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Nominal annual interest rate",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "loanTermYears",
      "label": "Loan Term (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration until balloon payment",
      "label_i18n": {
        "en": "Loan Term (Years)",
        "tr": "Loan Term (Years)",
        "de": "Loan Term (Years)",
        "fr": "Loan Term (Years)",
        "es": "Loan Term (Years)",
        "ar": "Loan Term (Years)"
      }
    },
    {
      "id": "balloonPercent",
      "label": "Balloon Payment (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Balloon payment amount as % of loan",
      "label_i18n": {
        "en": "Balloon Payment (%)",
        "tr": "Balloon Payment (%)",
        "de": "Balloon Payment (%)",
        "fr": "Balloon Payment (%)",
        "es": "Balloon Payment (%)",
        "ar": "Balloon Payment (%)"
      }
    },
    {
      "id": "paymentsPerYear",
      "label": "Payments per Year",
      "type": "number",
      "unit": "payments/year",
      "default": 12,
      "businessContext": "Compounding frequency",
      "label_i18n": {
        "en": "Payments per Year",
        "tr": "Payments per Year",
        "de": "Payments per Year",
        "fr": "Payments per Year",
        "es": "Payments per Year",
        "ar": "Payments per Year"
      }
    }
  ],
  "formulas": {
    "periodicRate": "(annualInterestRate/100) / paymentsPerYear",
    "n": "loanTermYears * paymentsPerYear",
    "balloonAmount": "loanAmount * (balloonPercent/100)",
    "monthlyPayment": "(loanAmount * periodicRate * (1+periodicRate)**n - balloonAmount * periodicRate) / ((1+periodicRate)**n - 1)",
    "totalPaymentWithoutBalloon": "monthlyPayment * n",
    "totalInterest": "(monthlyPayment * n + balloonAmount) - loanAmount",
    "totalCost": "monthlyPayment * n + balloonAmount"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "balloonAmount",
      "totalPaymentWithoutBalloon",
      "totalInterest",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

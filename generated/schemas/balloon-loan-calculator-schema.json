        "ar": "مبلغ القرض"
      },
      "businessContext_i18n": {
        "en": "Total borrowed amount",
        "tr": "Toplam borç miktarı",
        "de": "Gesamter geliehener Betrag",
        "fr": "Montant total emprunté",

        "fr": "Durée jusqu'au paiement forfaitaire",
        "es": "Duración hasta el pago global",
        "ar": "المدة حتى الدفعة الكبيرة"
      }
    },
    {
      "id": "balloonPercent",
      "label": "Balloon Payment (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Balloon payment amount as % of loan",
      "label_i18n": {
        "en": "Balloon Payment (%)",
        "tr": "Balon Ödeme (%)",
        "de": "Ballonzahlung (%)",
        "fr": "Paiement forfaitaire (%)",
        "es": "Pago global (%)",
        "ar": "الدفعة الكبيرة (%)"
      },
      "businessContext_i18n": {
        "en": "Balloon payment amount as % of loan",
        "tr": "Kredinin yüzdesi olarak balon ödeme tutarı",
        "de": "Ballonzahlungsbetrag als % des Darlehens",
        "fr": "Montant du paiement forfaitaire en % du prêt",
        "es": "Monto del pago global como % del préstamo",
        "ar": "مبلغ الدفعة الكبيرة كنسبة مئوية من القرض"
      }
    },
    {
      "id": "paymentsPerYear",
      "label": "Payments per Year",
      "type": "number",
      "unit": "payments/year",
      "default": 12,
      "businessContext": "Compounding frequency",
      "label_i18n": {
        "en": "Payments per Year",
        "tr": "Yıllık Ödeme Sayısı",
        "de": "Zahlungen pro Jahr",
        "fr": "Paiements par an",
        "es": "Pagos por año",
        "ar": "عدد الدفعات في السنة"
      },
      "businessContext_i18n": {
        "en": "Compounding frequency",
        "tr": "Bileşik faiz sıklığı",
        "de": "Aufzinsungshäufigkeit",
        "fr": "Fréquence de capitalisation",
        "es": "Frecuencia de capitalización",
        "ar": "تكرار المركبة"
      }
    }
  ],
  "formulas": {
    "periodicRate": "(annualInterestRate/100) / paymentsPerYear",
    "n": "loanTermYears * paymentsPerYear",
    "balloonAmount": "loanAmount * (balloonPercent/100)",
    "monthlyPayment": "(loanAmount * periodicRate * (1+periodicRate)**n - balloonAmount * periodicRate) / ((1+periodicRate)**n - 1)",
    "totalPaymentWithoutBalloon": "monthlyPayment * n",
    "totalInterest": "(monthlyPayment * n + balloonAmount) - loanAmount",
    "totalCost": "monthlyPayment * n + balloonAmount"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "balloonAmount",
      "totalPaymentWithoutBalloon",
      "totalInterest",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "currency"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

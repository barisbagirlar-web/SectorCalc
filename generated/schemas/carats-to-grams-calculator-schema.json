      }
    },
    {
      "id": "batchSize",
      "label": "Batch Size",
      "type": "number",
      "unit": "items",
      "default": 1,
      "businessContext": "Number of items being converted, if multiple items of the same carat weight.",
      "label_i18n": {
        "en": "Batch Size",
        "tr": "Batch Size",
        "de": "Batch Size",
        "fr": "Batch Size",
        "es": "Batch Size",
        "ar": "Batch Size"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "places",

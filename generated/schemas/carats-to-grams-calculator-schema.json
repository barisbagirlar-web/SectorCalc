      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "pricePerGram",
      "label": "Price per Gram",
      "type": "number",
      "unit": "currency/g",
      "default": 0,
      "businessContext": "Optional: price per gram to calculate total value. Leave as 0 to ignore.",
      "label_i18n": {
        "en": "Price per Gram",
        "tr": "Price per Gram",
        "de": "Price per Gram",
        "fr": "Price per Gram",
        "es": "Price per Gram",
        "ar": "Price per Gram"
      }
    }
  ],
  "formulas": {
    "totalCarats": "carats * batchSize",
    "gramsPerItem": "carats * conversionFactor",
    "totalGrams": "gramsPerItem * batchSize",
    "totalPrice": "totalGrams * pricePerGram"
  },
  "outputs": {
    "primary": "totalPrice",
    "breakdown": [

{
  "toolName": "pompa-gucu-basma-yuksekligi-hesabi",
  "inputs": [
    {
      "id": "debi",
      "label": "Debi (Q)",
      "type": "number",
      "unit": "m³/s",
      "default": 0.1,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Pompa debisi, birim zamanda taşınan akışkan hacmi. ISO 9906 standardına göre ölçülür."
    },
    {
      "id": "basmaYuksekligi",
      "label": "Basma Yüksekliği (H)",
      "type": "number",
      "unit": "m",
      "default": 20,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Pompanın akışkana sağladığı toplam yükseklik (statik + kayıplar). ISO 9906'ya göre hesaplanır."
    },
    {
      "id": "akiskanYogunlugu",
      "label": "Akışkan Yoğunluğu (ρ)",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Akışkanın yoğunluğu. Su için 1000 kg/m³, diğer akışkanlar için tablo değerleri kullanılır."
    },
    {
      "id": "verim",
      "label": "Pompa Verimi (η)",
      "type": "number",
      "unit": "%",
      "default": 75,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Pompanın mekanik verimi. Tipik değerler %50-90 arası. ISO 9906'da tanımlıdır."
    },
    {
      "id": "elektrikBirimFiyati",
      "label": "Elektrik Birim Fiyatı",
      "type": "number",
      "unit": "TL/kWh",
      "default": 1.5,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Enerji maliyeti hesaplaması için kullanılır. Güncel piyasa fiyatı."
    },
    {
      "id": "calismaSuresi",
      "label": "Günlük Çalışma Süresi",
      "type": "number",
      "unit": "saat/gün",
      "default": 8,
      "min": 0,
      "max": 24,
      "options": null,
      "businessContext": "Pompanın günlük ortalama çalışma süresi."
    },
    {
      "id": "calismaGunu",
      "label": "Yıllık Çalışma Günü",
      "type": "number",
      "unit": "gün/yıl",
      "default": 300,
      "min": 0,
      "max": 365,
      "options": null,
      "businessContext": "Pompanın yıllık çalışma günü sayısı."
    }
  ],
  "validation": {
    "rules": [
      "debi > 0",
      "basmaYuksekligi > 0",
      "akiskanYogunlugu > 0",
      "verim > 0 && verim <= 100",
      "elektrikBirimFiyati >= 0",
      "calismaSuresi >= 0 && calismaSuresi <= 24",
      "calismaGunu >= 0 && calismaGunu <= 365"
    ],
    "thresholds": {
      "verim < 50": "Düşük verim: pompa verimi %50'nin altında, bakım veya değişim gerekebilir.",
      "guc > 100": "Yüksek güç: pompa gücü 100 kW üzerinde, enerji maliyeti yüksek."
    }
  },
  "formulas": {
    "guc": "debi * basmaYuksekligi * akiskanYogunlugu * 9.81 / (verim / 100)",
    "enerjiTuketimiGunluk": "guc * calismaSuresi / 1000",
    "enerjiTuketimiYillik": "enerjiTuketimiGunluk * calismaGunu",
    "yillikEnerjiMaliyeti": "enerjiTuketimiYillik * elektrikBirimFiyati"
  },
  "outputs": {
    "primary": "guc",
    "breakdown": {
      "guc": "Pompa Gücü (kW)",
      "enerjiTuketimiGunluk": "Günlük Enerji Tüketimi (kWh)",
      "enerjiTuketimiYillik": "Yıllık Enerji Tüketimi (kWh)",
      "yillikEnerjiMaliyeti": "Yıllık Enerji Maliyeti (TL)"
    },
    "hiddenLossDrivers": [
      "verim < 50 ? 'Düşük verim' : ''",
      "guc > 100 ? 'Yüksek güç' : ''"
    ],
    "suggestedActions": [
      "verim < 50 ? 'Pompa bakımı veya değişimi değerlendirin.' : ''",
      "guc > 100 ? 'Enerji verimliliği analizi yapın.' : ''"
    ],
    "dataConfidenceAdjusted": "guc * (1 - 0.1)"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

{
  "toolName": "5-2-diet-calculator",
  "inputs": [
    {
      "id": "normalKcal",
      "label": "Normal Day Calories",
      "type": "number",
      "unit": "kcal/day",
      "default": 2000,
      "businessContext": "Daily calorie intake on normal eating days (5 days per week)"
    },
    {
      "id": "fastKcal",
      "label": "Fast Day Calories",
      "type": "number",
      "unit": "kcal/day",
      "default": 500,
      "businessContext": "Daily calorie intake on fasting days (2 days per week)"
    },
    {
      "id": "weeks",
      "label": "Number of Weeks",
      "type": "number",
      "unit": "weeks",
      "default": 4,
      "businessContext": "Duration of the diet plan"
    },
    {
      "id": "maintenanceKcal",
      "label": "Maintenance Calories",
      "type": "number",
      "unit": "kcal/day",
      "default": 2500,
      "businessContext": "Daily calorie intake to maintain current weight (based on TDEE)"
    }
  ],
  "formulas": {
    "totalWeeklyCalories": "5 * normalKcal + 2 * fastKcal",
    "averageDailyCalories": "totalWeeklyCalories / 7",
    "weeklyCalorieDeficit": "7 * maintenanceKcal - totalWeeklyCalories",
    "weeklyWeightLoss": "weeklyCalorieDeficit / 7700",
    "estimatedTotalWeightLoss": "weeklyWeightLoss * weeks"
  },
  "outputs": {
    "primary": "estimatedTotalWeightLoss",
    "breakdown": [
      "averageDailyCalories",
      "totalWeeklyCalories",
      "weeklyCalorieDeficit",
      "weeklyWeightLoss"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Temizlik & Hijyen",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "maintenance-reliability",
  "sectorId": "temizlik",
  "profession": "Hijyen Uzmanı",
  "categoryId": "conversion"
}

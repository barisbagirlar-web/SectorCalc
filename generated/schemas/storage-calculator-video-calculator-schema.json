{
  "toolName": "storage-calculator-video-calculator",
  "inputs": [
    {
      "id": "numCameras",
      "label": "Number of Cameras",
      "type": "number",
      "unit": "adet",
      "default": 4,
      "businessContext": "Total IP cameras in system",
      "label_i18n": {
        "en": "Number of Cameras",
        "tr": "Number of Cameras",
        "de": "Number of Cameras",
        "fr": "Number of Cameras",
        "es": "Number of Cameras",
        "ar": "Number of Cameras"
      }
    },
    {
      "id": "bitrate",
      "label": "Average Bitrate per Camera",
      "type": "number",
      "unit": "Mbps",
      "default": 4,
      "businessContext": "Estimated bitrate per camera (depends on resolution, fps, compression)",
      "label_i18n": {
        "en": "Average Bitrate per Camera",
        "tr": "Average Bitrate per Camera",
        "de": "Average Bitrate per Camera",
        "fr": "Average Bitrate per Camera",
        "es": "Average Bitrate per Camera",
        "ar": "Average Bitrate per Camera"
      }
    },
    {
      "id": "recordingHours",
      "label": "Recording Hours per Day",
      "type": "number",
      "unit": "saat/gün",
      "default": 24,
      "businessContext": "Daily recording duration per camera",
      "label_i18n": {
        "en": "Recording Hours per Day",
        "tr": "Recording Hours per Day",
        "de": "Recording Hours per Day",
        "fr": "Recording Hours per Day",
        "es": "Recording Hours per Day",
        "ar": "Recording Hours per Day"
      }
    },
    {
      "id": "retentionDays",
      "label": "Retention Period",
      "type": "number",
      "unit": "gün",
      "default": 30,
      "businessContext": "Number of days to keep footage",
      "label_i18n": {
        "en": "Retention Period",
        "tr": "Retention Period",
        "de": "Retention Period",
        "fr": "Retention Period",
        "es": "Retention Period",
        "ar": "Retention Period"
      }
    },
    {
      "id": "overheadPercent",
      "label": "Storage Overhead",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional capacity for RAID, formatting, and system",
      "label_i18n": {
        "en": "Storage Overhead",
        "tr": "Storage Overhead",
        "de": "Storage Overhead",
        "fr": "Storage Overhead",
        "es": "Storage Overhead",
        "ar": "Storage Overhead"
      }
    }
  ],
  "formulas": {
    "dailyGBPerCamera": "bitrate * recordingHours * 3600 / (8 * 1024)",
    "dailyGBTotal": "dailyGBPerCamera * numCameras",
    "totalGB": "numCameras * bitrate * recordingHours * 3600 * retentionDays / (8 * 1024)",
    "totalWithOverhead": "totalGB * (1 + overheadPercent / 100)",
    "totalTB": "totalWithOverhead / 1024"
  },
  "outputs": {
    "primary": "totalTB",
    "breakdown": [
      "totalWithOverhead",
      "dailyGBTotal",
      "dailyGBPerCamera"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTB",
    "unit": "adet"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Görsel & Medya",
  "premiumRequired": false,

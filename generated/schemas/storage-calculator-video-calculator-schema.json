        "de": "Tägliche Aufzeichnungsdauer pro Kamera",
        "fr": "Durée d'enregistrement quotidienne par caméra"
      }
    },
    {
      "id": "retentionDays",
      "label": "Retention Period",
      "type": "number",
      "unit": "gün",
      "default": 30,
      "businessContext": "Number of days to keep footage",
      "label_i18n": {
        "en": "Retention Period",
        "tr": "Saklama Süresi",
        "de": "Aufbewahrungszeitraum",
        "fr": "Période de conservation",
        "es": "Retention Period",
        "ar": "Retention Period"
      },
      "businessContext_i18n": {
        "en": "Number of days to keep footage",
        "tr": "Görüntülerin saklanacağı gün sayısı",
        "de": "Anzahl der Tage zur Aufbewahrung der Aufnahmen",
        "fr": "Nombre de jours de conservation des images"
      }
    },
    {
      "id": "overheadPercent",
      "label": "Storage Overhead",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional capacity for RAID, formatting, and system",
      "label_i18n": {
        "en": "Storage Overhead",
        "tr": "Depolama Yükü",
        "de": "Speicher-Overhead",
        "fr": "Surcharge de stockage",
        "es": "Storage Overhead",
        "ar": "Storage Overhead"
      },
      "businessContext_i18n": {
        "en": "Additional capacity for RAID, formatting, and system",
        "tr": "RAID, biçimlendirme ve sistem için ek kapasite",
        "de": "Zusätzliche Kapazität für RAID, Formatierung und System",
        "fr": "Capacité supplémentaire pour RAID, formatage et système"
      }
    }
  ],
  "formulas": {
    "dailyGBPerCamera": "bitrate * recordingHours * 3600 / (8 * 1024)",
    "dailyGBTotal": "dailyGBPerCamera * numCameras",
    "totalGB": "numCameras * bitrate * recordingHours * 3600 * retentionDays / (8 * 1024)",
    "totalWithOverhead": "totalGB * (1 + overheadPercent / 100)",
    "totalTB": "totalWithOverhead / 1024"
  },
  "outputs": {
    "primary": "totalTB",
    "breakdown": [
      "totalWithOverhead",
      "dailyGBTotal",
      "dailyGBPerCamera"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTB",

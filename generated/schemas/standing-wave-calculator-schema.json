{
  "toolName": "standing-wave-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length (L)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the vibrating string"
    },
    {
      "id": "tension",
      "label": "Tension (T)",
      "type": "number",
      "unit": "N",
      "default": 100,
      "businessContext": "Tension applied to the string"
    },
    {
      "id": "linearDensity",
      "label": "Linear Density (μ)",
      "type": "number",
      "unit": "kg/m",
      "default": 0.01,
      "businessContext": "Mass per unit length of the string"
    },
    {
      "id": "harmonic",
      "label": "Harmonic Number (n)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Harmonic mode: 1=fundamental, 2=2nd harmonic, etc."
    }
  ],
  "formulas": {
    "fundamentalFrequency": "1/(2*length) * Math.sqrt(tension / linearDensity)",
    "frequency": "harmonic * (1/(2*length) * Math.sqrt(tension / linearDensity))",
    "wavelength": "2 * length / harmonic",
    "waveSpeed": "Math.sqrt(tension / linearDensity)"
  },
  "outputs": {
    "primary": "frequency",
    "breakdown": [
      "wavelength",
      "waveSpeed"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

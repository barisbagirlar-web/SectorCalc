{
  "toolName": "kwh-calculator",
  "inputs": [
    {
      "id": "powerRating",
      "label": "Power Rating",
      "type": "number",
      "unit": "W",
      "default": 1000,
      "businessContext": "Rated power consumption of a single device in watts.",
      "label_i18n": {
        "en": "Power Rating",
        "tr": "Power Rating",
        "de": "Power Rating",
        "fr": "Power Rating",
        "es": "Power Rating",
        "ar": "Power Rating"
      }
    },
    {
      "id": "numberOfDevices",
      "label": "Number of Devices",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of identical devices operating concurrently.",
      "label_i18n": {
        "en": "Number of Devices",
        "tr": "Number of Devices",
        "de": "Number of Devices",
        "fr": "Number of Devices",
        "es": "Number of Devices",
        "ar": "Number of Devices"
      }
    },
    {
      "id": "usageHoursPerDay",
      "label": "Usage Hours per Day",
      "type": "number",
      "unit": "h/day",
      "default": 8,
      "businessContext": "Average daily operating hours of the device(s).",
      "label_i18n": {
        "en": "Usage Hours per Day",
        "tr": "Usage Hours per Day",
        "de": "Usage Hours per Day",
        "fr": "Usage Hours per Day",
        "es": "Usage Hours per Day",
        "ar": "Usage Hours per Day"
      }
    },
    {
      "id": "daysPerMonth",
      "label": "Days per Month",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of operating days per month, typically 30 for estimation.",
      "label_i18n": {
        "en": "Days per Month",
        "tr": "Days per Month",
        "de": "Days per Month",
        "fr": "Days per Month",
        "es": "Days per Month",
        "ar": "Days per Month"
      }
    },
    {
      "id": "electricityRate",
      "label": "Electricity Rate",
      "type": "number",
      "unit": "€/kWh",
      "default": 0.15,
      "businessContext": "Cost per kilowatt-hour in euros (adjust to local currency).",
      "label_i18n": {
        "en": "Electricity Rate",
        "tr": "Electricity Rate",
        "de": "Electricity Rate",
        "fr": "Electricity Rate",
        "es": "Electricity Rate",
        "ar": "Electricity Rate"
      }
    }
  ],
  "formulas": {
    "dailyEnergyKWh": "(powerRating * numberOfDevices * usageHoursPerDay) / 1000",
    "monthlyEnergyKWh": "dailyEnergyKWh * daysPerMonth",
    "yearlyEnergyKWh": "dailyEnergyKWh * 365",
    "monthlyCost": "monthlyEnergyKWh * electricityRate",
    "yearlyCost": "yearlyEnergyKWh * electricityRate"
  },
  "outputs": {
    "primary": "monthlyEnergyKWh",
    "breakdown": [
      "dailyEnergyKWh",
      "monthlyCost",
      "yearlyEnergyKWh",
      "yearlyCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "yearlyCost",
    "unit": "kWh",
    "breakdownUnits": {
      "dailyEnergyKWh": "kWh",
      "yearlyEnergyKWh": "kWh"
    }
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,

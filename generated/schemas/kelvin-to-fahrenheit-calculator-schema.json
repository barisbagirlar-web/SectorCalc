      "businessContext": "Number of decimal places for the output Fahrenheit value.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Ondalık Hassasiyet",
        "de": "Dezimalgenauigkeit",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      },
      "businessContext_i18n": {
        "en": "Number of decimal places for the output Fahrenheit value.",
        "tr": "Çıktı Fahrenheit değeri için ondalık basamak sayısı."

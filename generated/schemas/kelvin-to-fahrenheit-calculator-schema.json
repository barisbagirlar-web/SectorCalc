    },
    {
      "id": "calibrationOffset",
      "label": "Calibration Offset",
      "type": "number",
      "unit": "K",
      "default": 0,
      "businessContext": "An optional offset to apply to the Kelvin value for calibration purposes.",
      "label_i18n": {
        "en": "Calibration Offset",
        "tr": "Kalibrasyon Ofseti",
        "de": "Kalibrierungsversatz",
        "fr": "Calibration Offset",
        "es": "Calibration Offset",
        "ar": "Calibration Offset"
      },
      "businessContext_i18n": {
        "en": "An optional offset to apply to the Kelvin value for calibration purposes.",
        "tr": "Kalibrasyon amacıyla Kelvin değerine uygulanacak isteğe bağlı bir ofset."
      }
    },
    {
      "id": "expectedFahrenheit",
      "label": "Expected Fahrenheit (Verification)",
      "type": "number",
      "unit": "°F",
      "default": 32,
      "businessContext": "A known Fahrenheit value for cross-checking the conversion (not used in calculation).",
      "label_i18n": {
        "en": "Expected Fahrenheit (Verification)",
        "tr": "Beklenen Fahrenheit (Doğrulama)",
        "de": "Expected Fahrenheit (Verification)",
        "fr": "Expected Fahrenheit (Verification)",
        "es": "Expected Fahrenheit (Verification)",
        "ar": "Expected Fahrenheit (Verification)"
      },
      "businessContext_i18n": {
        "en": "A known Fahrenheit value for cross-checking the conversion (not used in calculation).",
        "tr": "Dönüşümü çapraz kontrol için bilinen bir Fahrenheit değeri (hesaplamada kullanılmaz)."
      }
    }
  ],
  "formulas": {
    "effectiveKelvin": "kelvin + calibrationOffset",
    "celsius": "effectiveKelvin - 273.15",
    "fahrenheitUnrounded": "celsius * 9/5 + 32"
  },
  "outputs": {
    "primary": "fahrenheitUnrounded",
    "breakdown": [
      "Effective Kelvin (with offset): ${effectiveKelvin} K",
      "Celsius: ${celsius} °C",
      "Fahrenheit (unrounded): ${fahrenheitUnrounded} °F",
      "Fahrenheit (rounded to ${precision} decimal places): ${fahrenheit} °F"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "fahrenheit",
    "unit": "°F",
    "breakdownUnits": {
      "Celsius: ${celsius} °C": "°C",
      "Fahrenheit (unrounded): ${fahrenheitUnrounded} °F": "°F",
      "Fahrenheit (rounded to ${precision} decimal places): ${fahrenheit} °F": "°F"
    }
  },

{
  "toolName": "markup-calculator",
  "inputs": [
    {
      "id": "costPrice",
      "label": "Cost Price",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "The unit cost of the product or service.",
      "label_i18n": {
        "en": "Cost Price",
        "tr": "Cost Price",
        "de": "Cost Price",
        "fr": "Cost Price",
        "es": "Cost Price",
        "ar": "Cost Price"
      }
    },
    {
      "id": "markupPercent",
      "label": "Markup Percentage",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "The percentage markup applied to the cost price.",
      "label_i18n": {
        "en": "Markup Percentage",
        "tr": "Markup Percentage",
        "de": "Markup Percentage",
        "fr": "Markup Percentage",
        "es": "Markup Percentage",
        "ar": "Markup Percentage"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of units to calculate totals for.",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Quantity",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      }
    },
    {
      "id": "additionalCostPerUnit",
      "label": "Additional Cost per Unit",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Extra cost per unit such as shipping, packaging, or handling.",
      "label_i18n": {
        "en": "Additional Cost per Unit",
        "tr": "Additional Cost per Unit",
        "de": "Additional Cost per Unit",
        "fr": "Additional Cost per Unit",
        "es": "Additional Cost per Unit",
        "ar": "Additional Cost per Unit"
      }
    }
  ],
  "formulas": {
    "sellingPrice": "costPrice + costPrice * markupPercent / 100 + additionalCostPerUnit",
    "totalRevenue": "(costPrice + costPrice * markupPercent / 100 + additionalCostPerUnit) * quantity",
    "totalProfit": "(costPrice + costPrice * markupPercent / 100 + additionalCostPerUnit) * quantity - (costPrice + additionalCostPerUnit) * quantity",
    "profitMargin": "(((costPrice + costPrice * markupPercent / 100 + additionalCostPerUnit) * quantity - (costPrice + additionalCostPerUnit) * quantity) / ((costPrice + costPrice * markupPercent / 100 + additionalCostPerUnit) * quantity)) * 100"
  },
  "outputs": {
    "primary": "sellingPrice",
    "breakdown": [
      "totalRevenue",
      "totalProfit",
      "profitMargin"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitMargin"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

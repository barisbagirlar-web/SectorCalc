{
  "toolName": "semi-annual-compound-interest-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "TL",
      "default": 10000,
      "businessContext": "Initial lump sum invested",
      "label_i18n": {
        "en": "Principal Amount",
        "tr": "Anapara Tutarı",
        "de": "Kapitalbetrag",
        "fr": "Montant principal",
        "es": "Monto principal",
        "ar": "Principal Amount"
      },
      "businessContext_i18n": {
        "en": "Initial lump sum invested",
        "tr": "Yatırılan başlangıç toplu miktarı",
        "de": "Anfängliche Einmalanlage",
        "fr": "Montant forfaitaire initial investi",
        "es": "Inversión inicial global"
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Nominal annual interest rate",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Yıllık Faiz Oranı",
        "de": "Jährlicher Zinssatz",
        "fr": "Taux d'intérêt annuel",
        "es": "Tasa de Interés Anual",
        "ar": "Annual Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Nominal annual interest rate",
        "tr": "Nominal yıllık faiz oranı",
        "de": "Nominaler jährlicher Zinssatz",
        "fr": "Taux d'intérêt annuel nominal",
        "es": "Tasa de interés nominal anual"
      }
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Investment duration in years",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Yıl Sayısı",
        "de": "Anzahl der Jahre",
        "fr": "Nombre d'années",
        "es": "Número de años",
        "ar": "Number of Years"
      },
      "businessContext_i18n": {
        "en": "Investment duration in years",
        "tr": "Yatırım süresi (yıl)",
        "de": "Anlagedauer in Jahren",
        "fr": "Durée d'investissement en années",
        "es": "Duración de la inversión en años"
      }
    },
    {
      "id": "compoundingPeriods",
      "label": "Compounding Periods per Year",
      "type": "number",
      "unit": "periods/year",
      "default": 2,
      "businessContext": "For semi-annual compounding, set to 2",
      "label_i18n": {
        "en": "Compounding Periods per Year",
        "tr": "Yıllık Bileşik Dönem Sayısı",
        "de": "Zinsperioden pro Jahr",
        "fr": "Périodes de capitalisation par an",
        "es": "Períodos de capitalización por año",
        "ar": "Compounding Periods per Year"
      },
      "businessContext_i18n": {
        "en": "For semi-annual compounding, set to 2",
        "tr": "Altı aylık bileşik faiz için 2 olarak ayarlayın",
        "de": "Für halbjährliche Aufzinsung auf 2 setzen",
        "fr": "Pour une capitalisation semestrielle, définir sur 2",
        "es": "Para capitalización semestral, establecer en 2"
      }
    }
  ],
  "formulas": {
    "futureValue": "principal * (1 + (annualRate/100) / compoundingPeriods) ** (compoundingPeriods * years)",
    "totalInterest": "futureValue - principal",
    "effectiveAnnualRate": "((1 + (annualRate/100) / compoundingPeriods) ** compoundingPeriods - 1) * 100"
  },
  "outputs": {
    "primary": "futureValue",
    "breakdown": [
      "totalInterest",
      "effectiveAnnualRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveAnnualRate",
    "unit": "TL"
  },

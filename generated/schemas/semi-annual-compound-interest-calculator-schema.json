{
  "toolName": "semi-annual-compound-interest-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "TL",
      "default": 10000,
      "businessContext": "Initial lump sum invested",
      "label_i18n": {
        "en": "Principal Amount",
        "tr": "Principal Amount",
        "de": "Principal Amount",
        "fr": "Principal Amount",
        "es": "Principal Amount",
        "ar": "Principal Amount"
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Nominal annual interest rate",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Investment duration in years",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Number of Years",
        "de": "Number of Years",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      }
    },
    {
      "id": "compoundingPeriods",
      "label": "Compounding Periods per Year",
      "type": "number",
      "unit": "periods/year",
      "default": 2,
      "businessContext": "For semi-annual compounding, set to 2",
      "label_i18n": {
        "en": "Compounding Periods per Year",
        "tr": "Compounding Periods per Year",
        "de": "Compounding Periods per Year",
        "fr": "Compounding Periods per Year",
        "es": "Compounding Periods per Year",
        "ar": "Compounding Periods per Year"
      }
    }
  ],
  "formulas": {
    "futureValue": "principal * (1 + (annualRate/100) / compoundingPeriods) ** (compoundingPeriods * years)",
    "totalInterest": "futureValue - principal",
    "effectiveAnnualRate": "((1 + (annualRate/100) / compoundingPeriods) ** compoundingPeriods - 1) * 100"
  },
  "outputs": {
    "primary": "futureValue",
    "breakdown": [
      "totalInterest",
      "effectiveAnnualRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveAnnualRate"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

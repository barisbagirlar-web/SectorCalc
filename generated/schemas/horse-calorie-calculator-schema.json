{
  "toolName": "horse-calorie-calculator",
  "inputs": [
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 500,
      "businessContext": "Horse body weight in kilograms"
    },
    {
      "id": "activityLevel",
      "label": "Activity Level",
      "type": "number",
      "unit": "factor",
      "default": 1.2,
      "businessContext": "Multiplier for activity: 1.0 idle, 1.2 light, 1.4 moderate, 1.6 heavy, 1.8 very heavy"
    },
    {
      "id": "pregnancyStage",
      "label": "Pregnancy Stage",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Pregnancy multiplier: 1.0 not pregnant, 1.1 early pregnancy, 1.2 late pregnancy"
    },
    {
      "id": "lactationStage",
      "label": "Lactation Stage",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Lactation multiplier: 1.0 not lactating, 1.3 lactating"
    },
    {
      "id": "ageFactor",
      "label": "Age Factor",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Age multiplier: 1.0 adult, 1.1 senior (>15 years), 1.2 growing (<3 years)"
    }
  ],
  "formulas": {
    "maintenanceDE": "1.4 + 0.03 * (bodyWeight * 2.20462)",
    "totalDailyDE": "maintenanceDE * activityLevel * pregnancyStage * lactationStage * ageFactor"
  },
  "outputs": {
    "primary": "totalDailyDE",
    "breakdown": [
      "maintenanceDE"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "hse-ergonomics"
}

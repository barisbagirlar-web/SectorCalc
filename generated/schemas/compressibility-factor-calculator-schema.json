{
  "toolName": "compressibility-factor-calculator",
  "inputs": [
    {
      "id": "pressure",
      "label": "Pressure",
      "type": "number",
      "unit": "Pa",
      "default": 101325,
      "businessContext": "Actual pressure of the gas"
    },
    {
      "id": "volume",
      "label": "Volume",
      "type": "number",
      "unit": "m³",
      "default": 0.0224,
      "businessContext": "Actual volume of the gas"
    },
    {
      "id": "moles",
      "label": "Moles",
      "type": "number",
      "unit": "mol",
      "default": 1,
      "businessContext": "Amount of gas in moles"
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "K",
      "default": 273.15,
      "businessContext": "Absolute temperature"
    },
    {
      "id": "gasConstant",
      "label": "Gas Constant",
      "type": "number",
      "unit": "J/(mol·K)",
      "default": 8.314,
      "businessContext": "Universal gas constant, adjust for units"
    }
  ],
  "formulas": {
    "Z": "(pressure * volume) / (moles * gasConstant * temperature)",
    "idealVolume": "(moles * gasConstant * temperature) / pressure",
    "percentDeviation": "((((pressure * volume) / (moles * gasConstant * temperature)) - 1) * 100)"
  },
  "outputs": {
    "primary": "Z",
    "breakdown": [
      "idealVolume",
      "percentDeviation"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",

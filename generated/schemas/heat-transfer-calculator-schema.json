  "formulas": {
    "heatTransferRate": "area * (tempInside - tempOutside) / (1/hInside + thickness/thermalConductivity + 1/hOutside)",
    "overallHeatTransferCoeff": "1 / (1/hInside + thickness/thermalConductivity + 1/hOutside)",
    "deltaTemp": "tempInside - tempOutside"
  },
  "outputs": {
    "primary": "heatTransferRate",
    "breakdown": [

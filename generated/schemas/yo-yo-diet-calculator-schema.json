{
  "toolName": "yo-yo-diet-calculator",
  "inputs": [
    {
      "id": "initialWeight",
      "label": "Initial Weight",
      "type": "number",
      "unit": "kg",
      "default": 80,
      "businessContext": "Body weight at the beginning of the first diet cycle",
      "label_i18n": {
        "en": "Initial Weight",
        "tr": "Initial Weight",
        "de": "Initial Weight",
        "fr": "Initial Weight",
        "es": "Initial Weight",
        "ar": "Initial Weight"
      }
    },
    {
      "id": "currentWeight",
      "label": "Current Weight",
      "type": "number",
      "unit": "kg",
      "default": 82,
      "businessContext": "Current body weight after all diet cycles",
      "label_i18n": {
        "en": "Current Weight",
        "tr": "Current Weight",
        "de": "Current Weight",
        "fr": "Current Weight",
        "es": "Current Weight",
        "ar": "Current Weight"
      }
    },
    {
      "id": "numberOfCycles",
      "label": "Number of Cycles",
      "type": "number",
      "unit": "count",
      "default": 3,
      "businessContext": "Total number of completed yo-yo diet cycles",
      "label_i18n": {
        "en": "Number of Cycles",
        "tr": "Number of Cycles",
        "de": "Number of Cycles",
        "fr": "Number of Cycles",
        "es": "Number of Cycles",
        "ar": "Number of Cycles"
      }
    },
    {
      "id": "weightLossPerCycle",
      "label": "Weight Loss per Cycle",
      "type": "number",
      "unit": "kg",
      "default": 5,
      "businessContext": "Average weight lost during the loss phase of one cycle",
      "label_i18n": {
        "en": "Weight Loss per Cycle",
        "tr": "Weight Loss per Cycle",
        "de": "Weight Loss per Cycle",
        "fr": "Weight Loss per Cycle",
        "es": "Weight Loss per Cycle",
        "ar": "Weight Loss per Cycle"
      }
    },
    {
      "id": "weightRegainPerCycle",
      "label": "Weight Regain per Cycle",
      "type": "number",
      "unit": "kg",
      "default": 4,
      "businessContext": "Average weight regained during the regain phase of one cycle",
      "label_i18n": {
        "en": "Weight Regain per Cycle",
        "tr": "Weight Regain per Cycle",
        "de": "Weight Regain per Cycle",
        "fr": "Weight Regain per Cycle",
        "es": "Weight Regain per Cycle",
        "ar": "Weight Regain per Cycle"
      }
    },
    {
      "id": "cycleDurationDays",
      "label": "Cycle Duration",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Average duration of one complete diet cycle (loss + regain)",
      "label_i18n": {
        "en": "Cycle Duration",
        "tr": "Cycle Duration",
        "de": "Cycle Duration",
        "fr": "Cycle Duration",
        "es": "Cycle Duration",
        "ar": "Cycle Duration"
      }
    }
  ],
  "formulas": {
    "netWeightChange": "currentWeight - initialWeight",
    "totalWeightLost": "numberOfCycles * weightLossPerCycle",
    "totalWeightRegained": "numberOfCycles * weightRegainPerCycle",
    "yoyoIndex": "totalWeightLost !== 0 ? totalWeightRegained / totalWeightLost : 0",
    "averageCycleFluctuation": "(weightLossPerCycle + weightRegainPerCycle) / 2"
  },
  "outputs": {
    "primary": "yoyoIndex",
    "breakdown": [
      "netWeightChange",
      "totalWeightLost",
      "totalWeightRegained",
      "averageCycleFluctuation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "averageCycleFluctuation",
    "unit": "kg"
  },
  "category": "Dönüşüm & Ölçüm",

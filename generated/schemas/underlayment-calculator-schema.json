{
  "toolName": "underlayment-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Total Floor Area",
      "type": "number",
      "unit": "sq ft",
      "default": 500,
      "businessContext": "The total area of the floor to be covered with underlayment, measured in square feet.",
      "label_i18n": {
        "en": "Total Floor Area",
        "tr": "Total Floor Area",
        "de": "Total Floor Area",
        "fr": "Total Floor Area",
        "es": "Total Floor Area",
        "ar": "Total Floor Area"
      }
    },
    {
      "id": "rollLength",
      "label": "Roll Length",
      "type": "number",
      "unit": "ft",
      "default": 50,
      "businessContext": "The length of a single roll of underlayment, in feet.",
      "label_i18n": {
        "en": "Roll Length",
        "tr": "Roll Length",
        "de": "Roll Length",
        "fr": "Roll Length",
        "es": "Roll Length",
        "ar": "Roll Length"
      }
    },
    {
      "id": "rollWidth",
      "label": "Roll Width",
      "type": "number",
      "unit": "ft",
      "default": 4,
      "businessContext": "The width of a single roll of underlayment, in feet.",
      "label_i18n": {
        "en": "Roll Width",
        "tr": "Roll Width",
        "de": "Roll Width",
        "fr": "Roll Width",
        "es": "Roll Width",
        "ar": "Roll Width"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "The percentage of additional material needed to account for cuts, fitting, and waste.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "pricePerRoll",
      "label": "Price per Roll",
      "type": "number",
      "unit": "USD",
      "default": 30,
      "businessContext": "The cost of one roll of underlayment in US dollars.",
      "label_i18n": {
        "en": "Price per Roll",
        "tr": "Price per Roll",
        "de": "Price per Roll",
        "fr": "Price per Roll",
        "es": "Price per Roll",
        "ar": "Price per Roll"
      }
    }
  ],
  "formulas": {
    "rollArea": "rollLength * rollWidth",
    "neededArea": "area * (1 + wasteFactor / 100)",
    "exactRolls": "neededArea / rollArea",
    "totalCost": "exactRolls * pricePerRoll"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "One roll covers ${rollArea} sq ft (${rollLength} ft × ${rollWidth} ft).",
      "Adjusted area with ${wasteFactor}% waste: ${neededArea} sq ft.",
      "Exact number of rolls required (before rounding up): ${exactRolls}.",
      "Total cost based on exact rolls: $${totalCost} (round up for purchase)."
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "matematik",
  "profession": "Matematikçi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

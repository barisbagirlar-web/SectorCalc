{
  "toolName": "true-airspeed-calculator",
  "inputs": [
    {
      "id": "indicatedAirSpeed",
      "label": "Gösterge Hava Hızı (IAS)",
      "type": "number",
      "unit": "knot",
      "default": 150,
      "businessContext": "Pitot-statik sistemden okunan hız (knot)."
    },
    {
      "id": "pressureAltitude",
      "label": "Basınç İrtifası",
      "type": "number",
      "unit": "feet",
      "default": 10000,
      "businessContext": "Standart basınç ayarı (29.92 inHg) ile ölçülen irtifa (feet)."
    },
    {
      "id": "outsideAirTemperature",
      "label": "Dış Hava Sıcaklığı (OAT)",
      "type": "number",
      "unit": "°C",
      "default": -5,
      "businessContext": "Serbest hava sıcaklığı (°C)."
    }
  ],
  "formulas": {
    "theta": "(outsideAirTemperature + 273.15) / 288.15",
    "delta": "Math.pow(1 - 0.00000687535 * pressureAltitude, 5.2561)",
    "sigma": "delta / theta",
    "trueAirSpeed": "indicatedAirSpeed / Math.sqrt(sigma)"
  },
  "outputs": {
    "primary": "trueAirSpeed",
    "breakdown": [
      "sigma",
      "delta",
      "theta"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

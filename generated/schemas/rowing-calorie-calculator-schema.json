{
  "toolName": "rowing-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Vücut Ağırlığı",
        "de": "Körpergewicht",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      },
      "businessContext_i18n": {
        "en": "User's body weight in kilograms",
        "tr": "Kullanıcının kilogram cinsinden vücut ağırlığı",
        "de": "Körpergewicht des Benutzers in Kilogramm"
      }
    },
    {
      "id": "active_duration",
      "label": "Active Duration",
      "type": "number",
      "unit": "minutes",
      "default": 30,
      "businessContext": "Duration of active rowing in minutes",
      "label_i18n": {
        "en": "Active Duration",
        "tr": "Aktif Süre",
        "de": "Active Duration",
        "fr": "Active Duration",
        "es": "Active Duration",
        "ar": "Active Duration"
      },
      "businessContext_i18n": {
        "en": "Duration of active rowing in minutes",
        "tr": "Dakika cinsinden aktif kürek çekme süresi"
      }
    },
    {
      "id": "rest_duration",
      "label": "Rest Duration",
      "type": "number",
      "unit": "minutes",
      "default": 5,
      "businessContext": "Duration of rest intervals in minutes",
      "label_i18n": {
        "en": "Rest Duration",
        "tr": "Dinlenme Süresi",
        "de": "Ruhedauer",
        "fr": "Rest Duration",
        "es": "Rest Duration",
        "ar": "Rest Duration"
      },
      "businessContext_i18n": {
        "en": "Duration of rest intervals in minutes",
        "tr": "Dakika cinsinden dinlenme aralıklarının süresi"
      }
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 7,
      "businessContext": "Metabolic Equivalent of Task for rowing intensity",
      "label_i18n": {
        "en": "MET Value",
        "tr": "MET Değeri",
        "de": "MET-Wert",
        "fr": "MET Value",
        "es": "MET Value",
        "ar": "MET Value"
      },
      "businessContext_i18n": {
        "en": "Metabolic Equivalent of Task for rowing intensity",
        "tr": "Kürek çekme yoğunluğu için metabolik eşdeğer"
      }
    }
  ],
  "formulas": {
    "active_hours": "active_duration / 60",
    "rest_hours": "rest_duration / 60",
    "calories_active": "met * weight * active_hours",
    "calories_rest": "1.0 * weight * rest_hours",
    "total_calories": "calories_active + calories_rest"
  },
  "outputs": {
    "primary": "total_calories",
    "breakdown": [
      "calories_active",
      "calories_rest"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "total_calories",
    "unit": "kg"
  },

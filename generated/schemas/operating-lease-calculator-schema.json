{
  "toolName": "operating-lease-calculator",
  "inputs": [
    {
      "id": "assetCost",
      "label": "Asset Cost",
      "type": "number",
      "unit": "EUR",
      "default": 50000,
      "businessContext": "Initial purchase price of the asset.",
      "label_i18n": {
        "en": "Asset Cost",
        "tr": "Varlık Maliyeti",
        "de": "Vermögenswertkosten",
        "fr": "Coût de l'actif",
        "es": "Costo del activo",
        "ar": "تكلفة الأصل"
      },
      "businessContext_i18n": {
        "en": "Initial purchase price of the asset.",
        "tr": "Varlığın ilk satın alma fiyatı",
        "de": "Anschaffungspreis des Vermögenswerts",
        "fr": "Prix d'achat initial de l'actif",
        "es": "Precio de compra inicial del activo",
        "ar": "سعر الشراء الأولي للأصل"
      }
    },
    {
      "id": "residualValue",
      "label": "Residual Value",
      "type": "number",
      "unit": "EUR",
      "default": 10000,
      "businessContext": "Estimated value of the asset at end of lease.",
      "label_i18n": {
        "en": "Residual Value",
        "tr": "Kalıntı Değer",
        "de": "Restwert",
        "fr": "Valeur résiduelle",
        "es": "Valor residual",
        "ar": "القيمة المتبقية"
      },
      "businessContext_i18n": {
        "en": "Estimated value of the asset at end of lease.",
        "tr": "Varlığın kiralama sonunda tahmini değeri",
        "de": "Geschätzter Restwert des Vermögenswerts am Ende des Leasingvertrags",
        "fr": "Valeur estimée de l'actif en fin de location",
        "es": "Valor estimado del activo al final del arrendamiento",
        "ar": "القيمة التقديرية للأصل في نهاية عقد الإيجار"
      }
    },
    {
      "id": "leaseTerm",
      "label": "Lease Term",
      "type": "number",
      "unit": "months",
      "default": 36,
      "businessContext": "Duration of the lease in months.",
      "label_i18n": {
        "en": "Lease Term",
        "tr": "Kira Süresi",
        "de": "Leasinglaufzeit",
        "fr": "Durée du bail",
        "es": "Plazo de arrendamiento",
        "ar": "مدة الإيجار"
      },
      "businessContext_i18n": {
        "en": "Duration of the lease in months.",
        "tr": "Kiralama süresi (ay)",
        "de": "Laufzeit des Leasingvertrags in Monaten",
        "fr": "Durée de la location en mois",
        "es": "Duración del arrendamiento en meses",
        "ar": "مدة عقد الإيجار بالأشهر"
      }
    },
    {
      "id": "interestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual interest rate for lease financing.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Yıllık Faiz Oranı",
        "de": "Jährlicher Zinssatz",
        "fr": "Taux d'intérêt annuel",
        "es": "Tasa de Interés Anual",
        "ar": "معدل الفائدة السنوي"
      },
      "businessContext_i18n": {
        "en": "Annual interest rate for lease financing.",
        "tr": "Kiralama finansmanı için yıllık faiz oranı",
        "de": "Jährlicher Zinssatz für die Leasingfinanzierung",
        "fr": "Taux d'intérêt annuel pour le financement de la location",
        "es": "Tasa de interés anual para el financiamiento del arrendamiento",
        "ar": "معدل الفائدة السنوي لتمويل الإيجار"
      }
    }
  ],
  "formulas": {
    "monthlyInterestRate": "interestRate / 100 / 12",
    "depreciableBase": "assetCost - residualValue",
    "monthlyDepreciation": "depreciableBase / leaseTerm",
    "monthlyLeasePayment": "monthlyDepreciation + (depreciableBase * monthlyInterestRate)",
    "totalLeaseCost": "monthlyLeasePayment * leaseTerm",
    "totalInterest": "totalLeaseCost - depreciableBase"
  },
  "outputs": {
    "primary": "monthlyLeasePayment",
    "breakdown": [
      "totalLeaseCost",
      "totalInterest"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalInterest",
    "unit": "EUR"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",
  "validation": {
    "rules": [
      {
        "field": "assetCost",
        "rule": "greaterThan",
        "value": 0,
        "message": "Asset cost must be positive."
      },
      {
        "field": "residualValue",
        "rule": "greaterThanOrEqual",
        "value": 0,
        "message": "Residual value must be non-negative."
      },
      {
        "field": "leaseTerm",
        "rule": "greaterThan",
        "value": 0,
        "message": "Lease term must be positive."
      },
      {
        "field": "interestRate",
        "rule": "greaterThanOrEqual",
        "value": 0,
        "message": "Interest rate must be non-negative."
      }
    ],
    "thresholds": {}
  },
  "premiumFeatures": []
}

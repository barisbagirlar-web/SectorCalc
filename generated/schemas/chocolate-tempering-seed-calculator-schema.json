{
  "toolName": "chocolate-tempering-seed-calculator",
  "inputs": [
    {
      "id": "meltedMass",
      "label": "Melted Chocolate Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of melted chocolate to be tempered.",
      "label_i18n": {
        "en": "Melted Chocolate Mass",
        "tr": "Melted Chocolate Mass",
        "de": "Melted Chocolate Mass",
        "fr": "Melted Chocolate Mass",
        "es": "Melted Chocolate Mass",
        "ar": "Melted Chocolate Mass"
      }
    },
    {
      "id": "meltedTemp",
      "label": "Melted Chocolate Temperature",
      "type": "number",
      "unit": "°C",
      "default": 45,
      "businessContext": "Temperature of the chocolate after melting.",
      "label_i18n": {
        "en": "Melted Chocolate Temperature",
        "tr": "Melted Chocolate Temperature",
        "de": "Melted Chocolate Temperature",
        "fr": "Melted Chocolate Temperature",
        "es": "Melted Chocolate Temperature",
        "ar": "Melted Chocolate Temperature"
      }
    },
    {
      "id": "targetTemp",
      "label": "Target Working Temperature",
      "type": "number",
      "unit": "°C",
      "default": 31,
      "businessContext": "Desired working temperature for tempered chocolate.",
      "label_i18n": {
        "en": "Target Working Temperature",
        "tr": "Target Working Temperature",
        "de": "Target Working Temperature",
        "fr": "Target Working Temperature",
        "es": "Target Working Temperature",
        "ar": "Target Working Temperature"
      }
    },
    {
      "id": "seedTemp",
      "label": "Seed Chocolate Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature of the seed chocolate (room temperature).",
      "label_i18n": {
        "en": "Seed Chocolate Temperature",
        "tr": "Seed Chocolate Temperature",
        "de": "Seed Chocolate Temperature",
        "fr": "Seed Chocolate Temperature",
        "es": "Seed Chocolate Temperature",
        "ar": "Seed Chocolate Temperature"
      }
    }
  ],
  "formulas": {
    "requiredSeedMass": "meltedMass * (meltedTemp - targetTemp) / (targetTemp - seedTemp)",
    "seedRatioPercent": "((meltedTemp - targetTemp) / (targetTemp - seedTemp)) * 100"
  },
  "outputs": {
    "primary": "requiredSeedMass",
    "breakdown": [
      {
        "id": "seedRatioPercent",
        "label": "Seed to Melt Ratio",
        "unit": "%"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "seedRatioPercent"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Metal & Kaynak",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",

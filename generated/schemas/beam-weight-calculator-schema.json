{
  "slug": "beam-weight-calculator",
  "title": "Beam Weight Calculator",
  "description": "Industrial-grade beam weight estimation tool compliant with ISO 9001, Lean Six Sigma, and WERC standards. Calculates theoretical weight, material cost, and hidden loss drivers for steel beams.",
  "premiumRequired": true,
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Multi-beam comparison",
    "Custom material database",
    "API integration"
  ],
  "inputs": [
    {
      "id": "beam_type",
      "label": "Beam Type",
      "type": "select",
      "unit": "unit",
      "default": "I-beam",
      "options": [
        "I-beam",
        "H-beam",
        "C-channel",
        "Angle",
        "T-beam"
      ],
      "businessContext": "Standard structural steel profiles per ASTM A6/A6M.",
      "label_i18n": {
        "en": "Beam Type"
      },
      "businessContext_i18n": {
        "en": "Standard structural steel profiles per ASTM A6/A6M."
      }
    },
    {
      "id": "material_density",
      "label": "Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "min": 7000,
      "max": 9000,
      "businessContext": "Typical steel density 7850 kg/m³; adjust for alloys (e.g., stainless ~8000).",
      "label_i18n": {
        "en": "Material Density"
      },
      "businessContext_i18n": {
        "en": "Typical steel density 7850 kg/m³; adjust for alloys (e.g., stainless ~8000)."
      }
    },
    {
      "id": "length",
      "label": "Beam Length",
      "type": "number",
      "unit": "m",
      "default": 6,
      "min": 0.5,
      "max": 30,
      "businessContext": "Standard stock lengths: 6m, 12m; custom up to 30m.",
      "label_i18n": {
        "en": "Beam Length"
      },
      "businessContext_i18n": {
        "en": "Standard stock lengths: 6m, 12m; custom up to 30m."
      }
    },
    {
      "id": "flange_width",
      "label": "Flange Width",
      "type": "number",
      "unit": "mm",
      "default": 200,
      "min": 50,
      "max": 1000,
      "businessContext": "Width of top/bottom flange for I/H-beams.",
      "label_i18n": {
        "en": "Flange Width"
      },
      "businessContext_i18n": {
        "en": "Width of top/bottom flange for I/H-beams."
      }
    },
    {
      "id": "flange_thickness",
      "label": "Flange Thickness",
      "type": "number",
      "unit": "mm",
      "default": 12,
      "min": 4,
      "max": 100,
      "businessContext": "Thickness of flange plates.",
      "label_i18n": {
        "en": "Flange Thickness"
      },
      "businessContext_i18n": {
        "en": "Thickness of flange plates."
      }
    },
    {
      "id": "web_height",
      "label": "Web Height",
      "type": "number",
      "unit": "mm",
      "default": 300,
      "min": 100,
      "max": 1200,
      "businessContext": "Clear height between flanges (web depth).",
      "label_i18n": {
        "en": "Web Height"
      },
      "businessContext_i18n": {
        "en": "Clear height between flanges (web depth)."
      }
    },
    {
      "id": "web_thickness",
      "label": "Web Thickness",
      "type": "number",
      "unit": "mm",
      "default": 8,
      "min": 3,
      "max": 50,
      "businessContext": "Thickness of the vertical web.",
      "label_i18n": {
        "en": "Web Thickness"
      },
      "businessContext_i18n": {
        "en": "Thickness of the vertical web."
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "min": 1,
      "max": 10000,
      "businessContext": "Number of identical beams.",
      "label_i18n": {
        "en": "Quantity"
      },
      "businessContext_i18n": {
        "en": "Number of identical beams."
      }
    }
  ],
  "validation": {
    "rules": [
      {
        "id": "flange_web_ratio",
        "condition": "flange_width / web_height > 2.0",
        "message": "Flange width exceeds 2x web height – unusual geometry, verify dimensions."
      },
      {
        "id": "web_slenderness",
        "condition": "web_height / web_thickness > 100",
        "message": "Web slenderness > 100 – potential buckling risk per AISC 360."
      },
      {
        "id": "flange_thickness_ratio",
        "condition": "flange_width / flange_thickness > 30",
        "message": "Flange width/thickness > 30 – check local buckling limits."
      },
      {
        "id": "length_restriction",
        "condition": "length > 12.0",
        "message": "Length > 12m – special transport and handling required."
      }
    ],
    "thresholds": [
      {
        "id": "weight_alert",
        "condition": "total_weight > 5000",
        "message": "Total weight exceeds 5,000 kg – crane capacity may be insufficient."
      },
      {
        "id": "cost_alert",
        "condition": "total_material_cost > 10000",
        "message": "Material cost > $10,000 – consider bulk discount or alternative material."
      },
      {
        "id": "cutting_loss_alert",
        "condition": "cutting_loss_factor > 5.0",
        "message": "Cutting loss > 5% – review nesting and cutting process (Lean Six Sigma waste reduction)."
      }
    ]
  },
  "formulas": {
    "result": "beam_type + material_density + length",
    "result_copy": "beam_type + material_density + length"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result",
    "unit": "kg/m³"
  },

      "label_i18n": {
        "en": "Additional Ounces",
        "tr": "Additional Ounces",
        "de": "Additional Ounces",
        "fr": "Additional Ounces",
        "es": "Additional Ounces",
        "ar": "Additional Ounces"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for rounded output",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    }
  ],
  "formulas": {
    "roundedPounds": "Math.round((stones * adjustmentFactor + additionalWeight - subtractWeight + ounces / 16) * (10 ** precision)) / (10 ** precision)",
    "rawPounds": "stones * adjustmentFactor + additionalWeight - subtractWeight + ounces / 16",
    "stonesToPounds": "stones * adjustmentFactor"
  },
  "outputs": {
    "primary": "roundedPounds",
    "breakdown": [
      "rawPounds",
      "stonesToPounds"
    ]
  },

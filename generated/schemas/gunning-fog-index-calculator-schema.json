  "formulas": {
    "avgSentenceLength": "totalWords / totalSentences",
    "pctComplexWords": "((complexWords - exemptWords) / totalWords) * 100",
    "gunningFogIndex": "0.4 * ((totalWords / totalSentences) + (((complexWords - exemptWords) / totalWords) * 100))"
  },

    },
    {
      "id": "base2",
      "label": "Base 2",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Length of the second parallel side of the trapezoid",
      "label_i18n": {
        "en": "Base 2",
        "tr": "Base 2",
        "de": "Base 2",
        "fr": "Base 2",
        "es": "Base 2",
        "ar": "Base 2"
      }
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Perpendicular distance between the two bases",
      "label_i18n": {
        "en": "Height",
        "tr": "Height",
        "de": "Height",
        "fr": "Height",
        "es": "Height",
        "ar": "Height"
      }
    },
    {
      "id": "outputUnitSelection",
      "label": "Output Unit",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 for mm², 2 for cm², 3 for m²",
      "label_i18n": {
        "en": "Output Unit",
        "tr": "Output Unit",
        "de": "Output Unit",
        "fr": "Output Unit",
        "es": "Output Unit",
        "ar": "Output Unit"
      }
    }
  ],
  "formulas": {
    "sumOfBases": "base1 + base2",
    "halfSumOfBases": "sumOfBases / 2",
    "area": "halfSumOfBases * height",
    "conversionFactor": "outputUnitSelection === 1 ? 1 : (outputUnitSelection === 2 ? 0.01 : (outputUnitSelection === 3 ? 0.000001 : 1))",
    "finalArea": "area * conversionFactor"
  },
  "outputs": {
    "primary": "finalArea",
    "breakdown": [
      "sumOfBases",
      "halfSumOfBases",
      "area",
      "conversionFactor",
      "finalArea"
    ]
  },

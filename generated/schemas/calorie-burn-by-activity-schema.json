{
  "toolName": "calorie-burn-by-activity",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms"
    },
    {
      "id": "duration",
      "label": "Activity Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Total time spent on the activity in minutes"
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 5,
      "businessContext": "Metabolic Equivalent of Task for the specific activity"
    },
    {
      "id": "factor",
      "label": "Individual Adjustment Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Optional multiplier to account for individual metabolic differences"
    }
  ],
  "formulas": {
    "totalCalories": "{met} * {weight} * ({duration} / 60) * {factor}",
    "caloriesPerMinute": "{met} * {weight} / 60 * {factor}",
    "caloriesPerHour": "{met} * {weight} * {factor}"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [
      "caloriesPerMinute",
      "caloriesPerHour"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

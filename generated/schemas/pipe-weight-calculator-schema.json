{
  "toolName": "pipe-weight-calculator",
  "inputs": [
    {
      "id": "outerDiameter",
      "label": "Outer Diameter",
      "type": "number",
      "unit": "mm",
      "default": 219.1,
      "businessContext": "Pipe outer diameter in millimeters. Standard sizes: 21.3mm to 219.1mm.",
      "label_i18n": {
        "en": "Outer Diameter",
        "tr": "Outer Diameter",
        "de": "Outer Diameter",
        "fr": "Outer Diameter",
        "es": "Outer Diameter",
        "ar": "Outer Diameter"
      }
    },
    {
      "id": "wallThickness",
      "label": "Wall Thickness",
      "type": "number",
      "unit": "mm",
      "default": 8.18,
      "businessContext": "Wall thickness in millimeters. Varies by schedule.",
      "label_i18n": {
        "en": "Wall Thickness",
        "tr": "Wall Thickness",
        "de": "Wall Thickness",
        "fr": "Wall Thickness",
        "es": "Wall Thickness",
        "ar": "Wall Thickness"
      }
    },
    {
      "id": "length",
      "label": "Length",
      "type": "number",
      "unit": "m",
      "default": 6,
      "businessContext": "Pipe length in meters. Commonly 6m or 12m.",
      "label_i18n": {
        "en": "Length",
        "tr": "Length",
        "de": "Length",
        "fr": "Length",
        "es": "Length",
        "ar": "Length"
      }
    },
    {
      "id": "density",
      "label": "Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 7850,
      "businessContext": "Material density in kg/m³. Steel: 7850, aluminum: 2700, PVC: 1400.",
      "label_i18n": {
        "en": "Material Density",
        "tr": "Material Density",
        "de": "Material Density",
        "fr": "Material Density",
        "es": "Material Density",
        "ar": "Material Density"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of pipe pieces.",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Quantity",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      }
    }
  ],
  "formulas": {
    "crossSectionalArea": "Math.PI * wallThickness * (outerDiameter - wallThickness)",
    "linearMass": "Math.PI * wallThickness * (outerDiameter - wallThickness) * density / 1e6",
    "weight": "Math.PI * wallThickness * (outerDiameter - wallThickness) * density * length * quantity / 1e6"
  },
  "outputs": {
    "primary": "weight",
    "breakdown": [
      "linearMass",
      "crossSectionalArea"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "weight"
  },
  "premiumRequired": false,

        "en": "Cost per Yard",
        "tr": "Cost per Yard",
        "de": "Cost per Yard",
        "fr": "Cost per Yard",
        "es": "Cost per Yard",
        "ar": "Cost per Yard"
      }
    },
    {
      "id": "decimal_places",
      "label": "Decimal Places",
      "type": "number",
      "unit": "dp",
      "default": 2,
      "businessContext": "Number of decimal places for rounding the output values.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "raw_yards": "length_feet / 3",
    "waste_yards": "raw_yards * waste_percent / 100",
    "safety_yards": "raw_yards * safety_margin_percent / 100"
  },
  "outputs": {
    "primary": "safety_yards",

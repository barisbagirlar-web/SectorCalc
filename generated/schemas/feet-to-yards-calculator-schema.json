{
  "toolName": "feet-to-yards-calculator",
  "inputs": [
    {
      "id": "length_feet",
      "label": "Length in Feet",
      "type": "number",
      "unit": "ft",
      "default": 1,
      "businessContext": "The length measured in feet to be converted to yards.",
      "label_i18n": {

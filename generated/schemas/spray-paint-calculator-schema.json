{
  "toolName": "spray-paint-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Surface Area",
      "type": "number",
      "unit": "m²",
      "default": 10,
      "businessContext": "Boyanacak toplam yüzey alanı"
    },
    {
      "id": "coverage",
      "label": "Coverage Rate",
      "type": "number",
      "unit": "m²/L",
      "default": 10,
      "businessContext": "Boya kapsama oranı (üretici verisi)"
    },
    {
      "id": "coats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Uygulanacak kat sayısı"
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Yangın, aşırı püskürtme vb. kayıplar"
    },
    {
      "id": "canVolume",
      "label": "Can Volume",
      "type": "number",
      "unit": "L",
      "default": 0.4,
      "businessContext": "Bir sprey boya kutusunun hacmi"
    }
  ],
  "formulas": {
    "effectiveCoverage": "coverage * (1 - wasteFactor / 100)",
    "totalPaintVolume": "(area * coats) / effectiveCoverage",
    "cansRequired": "Math.ceil(totalPaintVolume / canVolume)"
  },
  "outputs": {
    "primary": "cansRequired",
    "breakdown": [
      "totalPaintVolume",
      "effectiveCoverage"
    ]
  },
  "category": "Malzeme, Fire & OEE",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management"
}

  "formulas": {
    "volumeTrunk": "formFactor * (Math.PI * (dbh/100)**2 / 4) * treeHeight",
    "biomassTrunk": "volumeTrunk * woodDensity",
    "biomassBranches": "biomassTrunk * branchFactor",
    "totalBiomass": "biomassTrunk + biomassBranches",
    "totalCarbon": "totalBiomass * carbonFraction"
  },
  "outputs": {
    "primary": "totalCarbon",
    "breakdown": [
      "volumeTrunk",
      "biomassTrunk",
      "biomassBranches",
      "totalBiomass"
    ],

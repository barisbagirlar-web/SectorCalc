        "ar": "Form Faktörü"
      }
    },
    {
      "id": "branchFactor",
      "label": "Dal Biyokütle Oranı",
      "type": "number",
      "unit": "oran",
      "default": 0.3,
      "businessContext": "Gövde biyokütlesine oranla dal miktarı.",
      "label_i18n": {
        "en": "Dal Biyokütle Oranı",
        "tr": "Dal Biyokütle Oranı",
        "de": "Dal Biyokütle Oranı",
        "fr": "Dal Biyokütle Oranı",
        "es": "Dal Biyokütle Oranı",
        "ar": "Dal Biyokütle Oranı"
      }
    }
  ],
  "formulas": {
    "volumeTrunk": "formFactor * (Math.PI * (dbh/100)**2 / 4) * treeHeight",
    "biomassTrunk": "volumeTrunk * woodDensity",
    "biomassBranches": "biomassTrunk * branchFactor",
    "totalBiomass": "biomassTrunk + biomassBranches",
    "totalCarbon": "totalBiomass * carbonFraction"
  },
  "outputs": {
    "primary": "totalCarbon",
    "breakdown": [
      "volumeTrunk",
      "biomassTrunk",
      "biomassBranches",
      "totalBiomass"
    ],

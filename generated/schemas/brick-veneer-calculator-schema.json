  "formulas": {
    "wallArea": "wallWidth * wallHeight",
    "brickAreaWithMortar": "(brickLength / 1000 + mortarJoint / 1000) * (brickHeight / 1000 + mortarJoint / 1000)",
    "bricksWithoutWaste": "wallArea / brickAreaWithMortar",
    "wasteBricks": "bricksWithoutWaste * wasteFactor / 100",
    "totalBricks": "bricksWithoutWaste + wasteBricks"
  },
  "outputs": {
    "primary": "totalBricks",
    "breakdown": [
      "wallArea",
      "brickAreaWithMortar",
      "bricksWithoutWaste",
      "wasteBricks"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "wasteBricks",
    "unit": "pieces"
  },

{
  "toolName": "retention-rate-calculator",
  "inputs": [
    {
      "id": "customersStart",
      "label": "Starting Customers",
      "type": "number",
      "unit": "customers",
      "default": 1000,
      "businessContext": "Number of customers at the beginning of the measurement period.",
      "label_i18n": {
        "en": "Starting Customers",
        "tr": "Starting Customers",
        "de": "Starting Customers",
        "fr": "Starting Customers",
        "es": "Starting Customers",
        "ar": "Starting Customers"
      }
    },
    {
      "id": "customersEnd",
      "label": "Ending Customers",
      "type": "number",
      "unit": "customers",
      "default": 900,
      "businessContext": "Number of customers at the end of the measurement period.",
      "label_i18n": {
        "en": "Ending Customers",
        "tr": "Ending Customers",
        "de": "Ending Customers",
        "fr": "Ending Customers",
        "es": "Ending Customers",
        "ar": "Ending Customers"
      }
    },
    {
      "id": "newCustomers",
      "label": "New Customers",
      "type": "number",
      "unit": "customers",
      "default": 200,
      "businessContext": "Number of new customers acquired during the measurement period.",
      "label_i18n": {
        "en": "New Customers",
        "tr": "New Customers",
        "de": "New Customers",
        "fr": "New Customers",
        "es": "New Customers",
        "ar": "New Customers"
      }
    },
    {
      "id": "periodDays",
      "label": "Period Length",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Length of the measurement period in days (optional, can be used for annualization).",
      "label_i18n": {
        "en": "Period Length",
        "tr": "Period Length",
        "de": "Period Length",
        "fr": "Period Length",
        "es": "Period Length",
        "ar": "Period Length"
      }
    }
  ],
  "formulas": {
    "retainedCustomers": "customersEnd - newCustomers",
    "retentionRate": "customersStart > 0 ? ((customersEnd - newCustomers) / customersStart) * 100 : 0",
    "churnRate": "customersStart > 0 ? 100 - ((customersEnd - newCustomers) / customersStart) * 100 : 0"
  },
  "outputs": {
    "primary": "retentionRate",
    "breakdown": [
      "retainedCustomers",
      "churnRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "churnRate"
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",

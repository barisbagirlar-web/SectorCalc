{
  "toolName": "short-term-rental-calculator",
  "inputs": [
    {
      "id": "nightlyRate",
      "label": "Nightly Rate",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Daily rental price of the property",
      "label_i18n": {
        "en": "Nightly Rate",
        "tr": "Nightly Rate",
        "de": "Nightly Rate",
        "fr": "Nightly Rate",
        "es": "Nightly Rate",
        "ar": "Nightly Rate"
      }
    },
    {
      "id": "numberOfNights",
      "label": "Number of Nights",
      "type": "number",
      "unit": "nights",
      "default": 1,
      "businessContext": "Length of stay in nights",
      "label_i18n": {
        "en": "Number of Nights",
        "tr": "Number of Nights",
        "de": "Number of Nights",
        "fr": "Number of Nights",
        "es": "Number of Nights",
        "ar": "Number of Nights"
      }
    },
    {
      "id": "cleaningFee",
      "label": "Cleaning Fee",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "One-time fee for cleaning services",
      "label_i18n": {
        "en": "Cleaning Fee",
        "tr": "Cleaning Fee",
        "de": "Cleaning Fee",
        "fr": "Cleaning Fee",
        "es": "Cleaning Fee",
        "ar": "Cleaning Fee"
      }
    },
    {
      "id": "serviceFeePercent",
      "label": "Service Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of base amount charged as service fee",
      "label_i18n": {
        "en": "Service Fee (%)",
        "tr": "Service Fee (%)",
        "de": "Service Fee (%)",
        "fr": "Service Fee (%)",
        "es": "Service Fee (%)",
        "ar": "Service Fee (%)"
      }
    },
    {
      "id": "occupancyTaxPercent",
      "label": "Occupancy Tax (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Local tax percentage on rental subtotal",
      "label_i18n": {
        "en": "Occupancy Tax (%)",
        "tr": "Occupancy Tax (%)",
        "de": "Occupancy Tax (%)",
        "fr": "Occupancy Tax (%)",
        "es": "Occupancy Tax (%)",
        "ar": "Occupancy Tax (%)"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Discount percentage applied to base amount",
      "label_i18n": {
        "en": "Discount (%)",
        "tr": "Discount (%)",
        "de": "Discount (%)",
        "fr": "Discount (%)",
        "es": "Discount (%)",
        "ar": "Discount (%)"
      }
    }
  ],
  "formulas": {
    "baseAmount": "nightlyRate * numberOfNights",
    "serviceFee": "baseAmount * serviceFeePercent / 100",
    "discountAmount": "baseAmount * discountPercent / 100",
    "subtotal": "baseAmount + cleaningFee + serviceFee - discountAmount",
    "taxAmount": "subtotal * occupancyTaxPercent / 100",
    "totalAmount": "subtotal + taxAmount"
  },
  "outputs": {
    "primary": "totalAmount",
    "breakdown": [
      "baseAmount",
      "serviceFee",
      "cleaningFee",
      "discountAmount",
      "subtotal",
      "taxAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalAmount"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Emlak & Gayrimenkul",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

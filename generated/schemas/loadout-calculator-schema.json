        "ar": "Cargo Weight"
      }
    },
    {
      "id": "vehicleCapacity",
      "label": "Vehicle Capacity",
      "type": "number",
      "unit": "kg",
      "default": 10000,
      "businessContext": "Maximum payload capacity of the vehicle",
      "label_i18n": {
        "en": "Vehicle Capacity",
        "tr": "Vehicle Capacity",
        "de": "Vehicle Capacity",
        "fr": "Vehicle Capacity",
        "es": "Vehicle Capacity",
        "ar": "Vehicle Capacity"
      }
    },
    {
      "id": "palletCount",
      "label": "Number of Pallets",
      "type": "number",
      "unit": "pcs",
      "default": 0,
      "businessContext": "Total count of pallets in the load",
      "label_i18n": {
        "en": "Number of Pallets",
        "tr": "Number of Pallets",
        "de": "Number of Pallets",
        "fr": "Number of Pallets",
        "es": "Number of Pallets",
        "ar": "Number of Pallets"
      }
    },
    {
      "id": "palletWeight",
      "label": "Weight per Pallet",
      "type": "number",
      "unit": "kg",
      "default": 20,
      "businessContext": "Average weight of an empty pallet",
      "label_i18n": {
        "en": "Weight per Pallet",
        "tr": "Weight per Pallet",
        "de": "Weight per Pallet",
        "fr": "Weight per Pallet",
        "es": "Weight per Pallet",
        "ar": "Weight per Pallet"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.1,
      "businessContext": "Multiplier applied to total load for safety margin",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    },
    {
      "id": "axleLimit",
      "label": "Axle Load Limit",
      "type": "number",
      "unit": "kg",
      "default": 5000,
      "businessContext": "Maximum permissible load per axle",
      "label_i18n": {
        "en": "Axle Load Limit",
        "tr": "Axle Load Limit",
        "de": "Axle Load Limit",
        "fr": "Axle Load Limit",
        "es": "Axle Load Limit",
        "ar": "Axle Load Limit"
      }
    },
    {
      "id": "numberOfAxles",
      "label": "Number of Axles",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Total number of axles on the vehicle",
      "label_i18n": {
        "en": "Number of Axles",
        "tr": "Number of Axles",
        "de": "Number of Axles",
        "fr": "Number of Axles",
        "es": "Number of Axles",
        "ar": "Number of Axles"
      }
    }
  ],
  "formulas": {
    "totalLoad": "(cargoWeight + palletCount * palletWeight) * safetyFactor",
    "loadUtilization": "((cargoWeight + palletCount * palletWeight) * safetyFactor / vehicleCapacity) * 100",
    "remainingCapacity": "vehicleCapacity - (cargoWeight + palletCount * palletWeight) * safetyFactor",
    "axleLoadPerAxle": "((cargoWeight + palletCount * palletWeight) * safetyFactor) / numberOfAxles"
  },
  "outputs": {
    "primary": "loadUtilization",
    "breakdown": [
      "totalLoad",
      "remainingCapacity",
      "axleLoadPerAxle"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "axleLoadPerAxle"
  },

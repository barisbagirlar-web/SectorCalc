{
  "toolName": "loadout-calculator",
  "inputs": [
    {
      "id": "cargoWeight",
      "label": "Cargo Weight",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Total weight of cargo to be loaded (excluding pallets)",
      "label_i18n": {
        "en": "Cargo Weight",
        "tr": "Cargo Weight",

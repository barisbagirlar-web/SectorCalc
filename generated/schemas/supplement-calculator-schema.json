      }
    },
    {
      "id": "baseConc",
      "label": "Base Concentration",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Initial concentration of the target substance in the base material (%)",
      "label_i18n": {
        "en": "Base Concentration",
        "tr": "Base Concentration",
        "de": "Base Concentration",
        "fr": "Base Concentration",
        "es": "Base Concentration",
        "ar": "Base Concentration"
      }
    },
    {
      "id": "desiredConc",
      "label": "Desired Concentration",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Target final concentration of the mixture (%)",
      "label_i18n": {
        "en": "Desired Concentration",
        "tr": "Desired Concentration",
        "de": "Desired Concentration",
        "fr": "Desired Concentration",
        "es": "Desired Concentration",
        "ar": "Desired Concentration"
      }
    },
    {
      "id": "suppConc",
      "label": "Supplement Concentration",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Concentration of the target substance in the supplement (%)",
      "label_i18n": {
        "en": "Supplement Concentration",
        "tr": "Supplement Concentration",
        "de": "Supplement Concentration",
        "fr": "Supplement Concentration",
        "es": "Supplement Concentration",
        "ar": "Supplement Concentration"
      }
    }
  ],
  "formulas": {
    "supplementWeight": "baseWeight * (desiredConc - baseConc) / (suppConc - desiredConc)",
    "totalWeight": "baseWeight + supplementWeight",
    "finalConc": "(baseWeight * baseConc + supplementWeight * suppConc) / totalWeight"
  },
  "outputs": {
    "primary": "supplementWeight",
    "breakdown": [
      "totalWeight",
      "finalConc"
    ],

      }
    },
    {
      "id": "exerciseType",
      "label": "Exercise Type",
      "type": "number",
      "unit": "0=Walking,1=Running",
      "default": 0,
      "businessContext": "Type of exercise: 0 for walking, 1 for running",
      "label_i18n": {
        "en": "Exercise Type",
        "tr": "Egzersiz Türü",
        "de": "Übungsart",
        "fr": "Type d'exercice",
        "es": "Exercise Type",
        "ar": "Exercise Type"
      },
      "businessContext_i18n": {
        "en": "Type of exercise: 0 for walking, 1 for running",
        "tr": "Egzersiz türü: 0 yürüyüş, 1 koşu",
        "de": "Art der Übung: 0 für Gehen, 1 für Laufen",
        "fr": "Type d'exercice : 0 pour la marche, 1 pour la course"
      }
    }
  ],
  "formulas": {
    "speedMperMin": "speed * 1000 / 60",
    "grade": "incline / 100",
    "VO2walking": "3.5 + 0.1 * speedMperMin + 1.8 * speedMperMin * grade",
    "VO2running": "3.5 + 0.2 * speedMperMin + 0.9 * speedMperMin * grade",
    "MET_walking": "VO2walking / 3.5",
    "MET_running": "VO2running / 3.5",
    "MET": "(1 - exerciseType) * MET_walking + exerciseType * MET_running",
    "calories": "MET * weight * (duration / 60)",
    "distance": "speed * (duration / 60)"
  },
  "outputs": {
    "primary": "calories",
    "breakdown": [
      "distance",
      "MET"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "distance",
    "unit": "kg"
  },

        "ar": "Speed"
      }
    },
    {
      "id": "incline",
      "label": "Incline",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Incline percentage (e.g., 5 for 5%)",
      "label_i18n": {
        "en": "Incline",
        "tr": "Incline",
        "de": "Incline",
        "fr": "Incline",
        "es": "Incline",
        "ar": "Incline"
      }
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Exercise duration in minutes",
      "label_i18n": {
        "en": "Duration",
        "tr": "Duration",
        "de": "Duration",
        "fr": "Duration",
        "es": "Duration",
        "ar": "Duration"
      }
    },
    {
      "id": "exerciseType",
      "label": "Exercise Type",
      "type": "number",
      "unit": "0=Walking,1=Running",
      "default": 0,
      "businessContext": "Type of exercise: 0 for walking, 1 for running",
      "label_i18n": {
        "en": "Exercise Type",
        "tr": "Exercise Type",
        "de": "Exercise Type",
        "fr": "Exercise Type",
        "es": "Exercise Type",
        "ar": "Exercise Type"
      }
    }
  ],
  "formulas": {
    "speedMperMin": "speed * 1000 / 60",
    "grade": "incline / 100",
    "VO2walking": "3.5 + 0.1 * speedMperMin + 1.8 * speedMperMin * grade",
    "VO2running": "3.5 + 0.2 * speedMperMin + 0.9 * speedMperMin * grade",
    "MET_walking": "VO2walking / 3.5",
    "MET_running": "VO2running / 3.5",
    "MET": "(1 - exerciseType) * MET_walking + exerciseType * MET_running",
    "calories": "MET * weight * (duration / 60)",
    "distance": "speed * (duration / 60)"
  },
  "outputs": {
    "primary": "calories",
    "breakdown": [
      "distance",
      "MET"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "distance",
    "unit": "kg"
  },

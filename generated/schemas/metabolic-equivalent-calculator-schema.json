{
  "toolName": "metabolic-equivalent-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms"
    },
    {
      "id": "duration_hours",
      "label": "Duration (hours)",
      "type": "number",
      "unit": "h",
      "default": 0,
      "businessContext": "Activity duration hours component"
    },
    {
      "id": "duration_minutes",
      "label": "Duration (minutes)",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Activity duration minutes component"
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 5,
      "businessContext": "Metabolic equivalent for the activity"
    }
  ],
  "formulas": {
    "caloriesBurned": "met * weight * (duration_hours + duration_minutes/60)",
    "metMinutes": "met * (duration_hours*60 + duration_minutes)",
    "oxygenConsumed": "(met * 3.5 * weight * (duration_hours*60 + duration_minutes)) / 1000"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "metMinutes",
      "oxygenConsumed"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma"
}

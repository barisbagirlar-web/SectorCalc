{
  "toolName": "metabolic-equivalent-calculator",
  "inputs": [
    {
      "id": "heartRate",
      "label": "Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 120,
      "businessContext": "Measured heart rate during activity"
    },
    {
      "id": "restingHeartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Resting heart rate measured in the morning"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the person"
    },
    {
      "id": "vo2max",
      "label": "VO2max",
      "type": "number",
      "unit": "ml/kg/min",
      "default": 40,
      "businessContext": "Maximum oxygen uptake, either measured or estimated"
    },
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight of the person"
    },
    {
      "id": "gender",
      "label": "Gender (1=Male, 0=Female)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1 for male, 0 for female, used for maximum heart rate estimation"
    }
  ],
  "formulas": {
    "metabolicEquivalent": "(vo2max * ((heartRate - restingHeartRate) / (( (gender == 1 ? 220 - age : 226 - age) ) - restingHeartRate))) / 3.5",
    "relativeVO2": "vo2max * ((heartRate - restingHeartRate) / (( (gender == 1 ? 220 - age : 226 - age) ) - restingHeartRate))",
    "energyExpenditure": "((vo2max * ((heartRate - restingHeartRate) / (( (gender == 1 ? 220 - age : 226 - age) ) - restingHeartRate))) / 3.5) * bodyWeight"
  },
  "outputs": {
    "primary": {
      "id": "metabolicEquivalent",
      "label": "Metabolic Equivalent",
      "unit": "MET"
    },
    "breakdown": [
      {
        "id": "relativeVO2",
        "label": "Relative VO2",
        "unit": "ml/kg/min"
      },
      {
        "id": "energyExpenditure",
        "label": "Energy Expenditure",
        "unit": "kcal/hour"
      }
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

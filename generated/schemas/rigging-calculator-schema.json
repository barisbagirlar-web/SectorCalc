{
  "toolName": "rigging-calculator",
  "inputs": [
    {
      "id": "loadWeight",
      "label": "Yük Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Kaldırılacak yükün toplam ağırlığı",
      "label_i18n": {
        "en": "Yük Ağırlığı",
        "tr": "Yük Ağırlığı",
        "de": "Yük Ağırlığı",
        "fr": "Yük Ağırlığı",
        "es": "Yük Ağırlığı",
        "ar": "Yük Ağırlığı"
      }
    },
    {
      "id": "slingAngle",
      "label": "Askı Açısı (yataydan)",
      "type": "number",
      "unit": "°",
      "default": 60,
      "businessContext": "Askı açısı yatay düzlemden ölçülür (0° tam yatay, 90° dikey)",
      "label_i18n": {
        "en": "Askı Açısı (yataydan)",
        "tr": "Askı Açısı (yataydan)",
        "de": "Askı Açısı (yataydan)",
        "fr": "Askı Açısı (yataydan)",
        "es": "Askı Açısı (yataydan)",
        "ar": "Askı Açısı (yataydan)"
      }
    },
    {
      "id": "numberOfLegs",
      "label": "Askı Kolu Sayısı",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Yükü taşıyan askı kollarının sayısı (genellikle 2 veya 4)",
      "label_i18n": {
        "en": "Askı Kolu Sayısı",
        "tr": "Askı Kolu Sayısı",
        "de": "Askı Kolu Sayısı",
        "fr": "Askı Kolu Sayısı",
        "es": "Askı Kolu Sayısı",
        "ar": "Askı Kolu Sayısı"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Güvenlik Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 5,
      "businessContext": "Tasarımda kullanılan emniyet katsayısı (örn: 5:1)",
      "label_i18n": {
        "en": "Güvenlik Faktörü",
        "tr": "Güvenlik Faktörü",
        "de": "Güvenlik Faktörü",
        "fr": "Güvenlik Faktörü",
        "es": "Güvenlik Faktörü",
        "ar": "Güvenlik Faktörü"
      }
    }
  ],
  "formulas": {
    "sinAngle": "Math.sin(slingAngle * Math.PI / 180)",
    "tensionGross": "loadWeight / (numberOfLegs * sinAngle)",
    "tensionDesign": "tensionGross * safetyFactor",
    "__tensionGross_toFixed_2___kg": "${tensionGross.toFixed(2)} kg",
    "__safetyFactor_": "${safetyFactor}",
    "__slingAngle__": "${slingAngle}°",
    "__sinAngle_toFixed_4__": "${sinAngle.toFixed(4)}",
    "result": "Askı Başına Tasarım Yükü: ${tensionDesign.toFixed(2)} kg"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Brüt askı yükü: ${tensionGross.toFixed(2)} kg",
      "Güvenlik faktörü: ${safetyFactor}",
      "Açı (yataydan): ${slingAngle}°",
      "Sin(θ): ${sinAngle.toFixed(4)}"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "hse-ergonomics",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

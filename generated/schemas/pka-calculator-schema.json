{
  "toolName": "pka-calculator",
  "inputs": [
    {
      "id": "acidConcentration",
      "label": "Asit Konsantrasyonu",
      "type": "number",
      "unit": "mol/L",
      "default": 0.1,
      "businessContext": "Zayıf asidin başlangıç konsantrasyonu",
      "label_i18n": {
        "en": "Asit Konsantrasyonu",
        "tr": "Asit Konsantrasyonu",
        "de": "Asit Konsantrasyonu",
        "fr": "Asit Konsantrasyonu",
        "es": "Asit Konsantrasyonu",
        "ar": "Asit Konsantrasyonu"
      }
    },
    {
      "id": "measuredpH",
      "label": "Ölçülen pH",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Çözeltinin ölçülen pH değeri",
      "label_i18n": {
        "en": "Ölçülen pH",
        "tr": "Ölçülen pH",
        "de": "Ölçülen pH",
        "fr": "Ölçülen pH",
        "es": "Ölçülen pH",
        "ar": "Ölçülen pH"
      }
    },
    {
      "id": "knownKa",
      "label": "Bilinen Ka Değeri",
      "type": "number",
      "unit": "mol/L",
      "default": 0,
      "businessContext": "Asit ayrışma sabiti biliniyorsa, doğrudan hesaplama için girin (opsiyonel)",
      "label_i18n": {
        "en": "Bilinen Ka Değeri",
        "tr": "Bilinen Ka Değeri",
        "de": "Bilinen Ka Değeri",
        "fr": "Bilinen Ka Değeri",
        "es": "Bilinen Ka Değeri",
        "ar": "Bilinen Ka Değeri"
      }
    },
    {
      "id": "temperature",
      "label": "Sıcaklık",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Çözelti sıcaklığı (hesaplamayı etkilemez, kayıt amaçlı)",
      "label_i18n": {
        "en": "Sıcaklık",
        "tr": "Sıcaklık",
        "de": "Sıcaklık",
        "fr": "Sıcaklık",
        "es": "Sıcaklık",
        "ar": "Sıcaklık"
      }
    }
  ],
  "formulas": {
    "computedHplus": "Math.pow(10, -measuredpH)",
    "computedKa": "knownKa > 0 ? knownKa : Math.pow( Math.pow(10, -measuredpH), 2 ) / (acidConcentration - Math.pow(10, -measuredpH))",
    "computedPka": "knownKa > 0 ? -Math.log(knownKa)/Math.LN10 : -Math.log( Math.pow( Math.pow(10, -measuredpH), 2 ) / (acidConcentration - Math.pow(10, -measuredpH)) ) / Math.LN10"
  },
  "outputs": {
    "primary": "computedPka",
    "breakdown": [
      "computedHplus",
      "computedKa",
      "computedPka"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,

{
  "toolName": "construction-project-overrun",
  "inputs": [
    {
      "id": "originalBudget",
      "label": "Original Budget",
      "type": "number",
      "unit": "USD",
      "default": 1000000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Initial approved budget for the construction project. Based on PMBOK cost baseline."
    },
    {
      "id": "actualCost",
      "label": "Actual Cost to Date",
      "type": "number",
      "unit": "USD",
      "default": 1200000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total expenditure incurred so far. From project accounting."
    },
    {
      "id": "plannedProgress",
      "label": "Planned Progress (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Scheduled completion percentage at current date. Earned Value Management (EVM) metric."
    },
    {
      "id": "actualProgress",
      "label": "Actual Progress (%)",
      "type": "number",
      "unit": "%",
      "default": 40,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Physical percentage of work completed. Measured via site reports."
    },
    {
      "id": "projectDuration",
      "label": "Project Duration",
      "type": "number",
      "unit": "months",
      "default": 12,
      "min": 1,
      "max": null,
      "options": null,
      "businessContext": "Total planned duration from start to finish."
    },
    {
      "id": "elapsedTime",
      "label": "Elapsed Time",
      "type": "number",
      "unit": "months",
      "default": 6,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Time passed since project start."
    },
    {
      "id": "contingencyReserve",
      "label": "Contingency Reserve",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Budget set aside for unforeseen costs. PMBOK risk management."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence",
      "type": "select",
      "unit": "",
      "default": "medium",
      "min": null,
      "max": null,
      "options": [
        "low",
        "medium",
        "high"
      ],
      "businessContext": "Reliability of input data. Low = high uncertainty, high = audited data."
    }
  ],
  "validation": {
    "rules": [
      "actualCost >= 0",
      "originalBudget > 0",
      "plannedProgress between 0 and 100",
      "actualProgress between 0 and 100",
      "projectDuration > 0",
      "elapsedTime >= 0",
      "elapsedTime <= projectDuration",
      "contingencyReserve >= 0",
      "if actualProgress > 0 then actualCost > 0"
    ],
    "thresholds": {
      "costOverrunPercent > 10": "Warning: Cost overrun exceeds 10% of original budget.",
      "scheduleVariancePercent < -10": "Warning: Schedule delay exceeds 10%.",
      "costPerformanceIndex < 0.8": "Critical: CPI below 0.8 indicates severe cost inefficiency.",
      "schedulePerformanceIndex < 0.8": "Critical: SPI below 0.8 indicates severe schedule delay."
    }
  },
  "formulas": {
    "costVariance": "actualCost - originalBudget",
    "costOverrunPercent": "(actualCost - originalBudget) / originalBudget * 100",
    "scheduleVariancePercent": "(actualProgress - plannedProgress) / plannedProgress * 100",
    "costPerformanceIndex": "actualProgress / 100 * originalBudget / actualCost",
    "schedulePerformanceIndex": "actualProgress / plannedProgress",
    "estimateAtCompletion": "originalBudget + contingencyReserve + costVariance",
    "overrunRiskScore": "costOverrunPercent * 0.5 + Math.max(0, -scheduleVariancePercent) * 0.3 + (1 - costPerformanceIndex) * 100 * 0.2",
    "dataConfidenceAdjustedOverrun": "costOverrunPercent * (dataConfidence === 'high' ? 1 : dataConfidence === 'medium' ? 1.1 : 1.25)"
  },
  "outputs": {
    "primary": "costOverrunPercent",
    "breakdown": {
      "costVariance": "costVariance",
      "scheduleVariancePercent": "scheduleVariancePercent",
      "costPerformanceIndex": "costPerformanceIndex",
      "schedulePerformanceIndex": "schedulePerformanceIndex",
      "estimateAtCompletion": "estimateAtCompletion",
      "overrunRiskScore": "overrunRiskScore"
    },
    "hiddenLossDrivers": [
      "costOverrunPercent > 10 ? 'Cost overrun exceeds 10%' : ''",
      "scheduleVariancePercent < -10 ? 'Schedule delay exceeds 10%' : ''",
      "costPerformanceIndex < 0.8 ? 'CPI below 0.8' : ''",
      "schedulePerformanceIndex < 0.8 ? 'SPI below 0.8' : ''"
    ],
    "suggestedActions": [
      "costOverrunPercent > 10 ? 'Initiate cost control measures: review procurement and labor costs.' : ''",
      "scheduleVariancePercent < -10 ? 'Implement schedule compression techniques: fast tracking or crashing.' : ''",
      "costPerformanceIndex < 0.8 ? 'Conduct value engineering to reduce costs.' : ''",
      "schedulePerformanceIndex < 0.8 ? 'Increase workforce or overtime to catch up schedule.' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjustedOverrun"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Benchmark Comparison",
    "Detailed Report with Charts"
  ],
  "premiumRequired": true
}

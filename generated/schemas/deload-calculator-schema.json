        "ar": "Current Average Intensity"
      }
    },
    {
      "id": "currentVolume",
      "label": "Current Weekly Volume Load",
      "type": "number",
      "unit": "kg",
      "default": 5000,
      "businessContext": "Total weekly volume load in kilograms (sets x reps x weight).",
      "label_i18n": {
        "en": "Current Weekly Volume Load",

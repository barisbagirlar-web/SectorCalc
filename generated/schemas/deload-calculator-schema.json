      }
    },
    {
      "id": "deloadDuration",
      "label": "Deload Duration",
      "type": "number",
      "unit": "weeks",
      "default": 1,
      "businessContext": "Duration of the deload phase in weeks.",
      "label_i18n": {
        "en": "Deload Duration",
        "tr": "Deload Duration",
        "de": "Deload Duration",
        "fr": "Deload Duration",
        "es": "Deload Duration",
        "ar": "Deload Duration"
      }
    },
    {
      "id": "deloadIntensityReduction",
      "label": "Intensity Reduction",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Reduction in intensity percentage points during deload.",
      "label_i18n": {
        "en": "Intensity Reduction",
        "tr": "Intensity Reduction",
        "de": "Intensity Reduction",
        "fr": "Intensity Reduction",
        "es": "Intensity Reduction",
        "ar": "Intensity Reduction"
      }
    },
    {
      "id": "deloadVolumeReduction",
      "label": "Volume Reduction",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage reduction in volume load during deload.",
      "label_i18n": {
        "en": "Volume Reduction",
        "tr": "Volume Reduction",
        "de": "Volume Reduction",
        "fr": "Volume Reduction",
        "es": "Volume Reduction",
        "ar": "Volume Reduction"
      }
    }
  ],
  "formulas": {
    "deloadIntensity": "currentIntensity - deloadIntensityReduction",
    "deloadVolume": "currentVolume * (1 - deloadVolumeReduction / 100)",
    "deloadWorkingWeight": "currentTrainingMax * (deloadIntensity / 100)"
  },
  "outputs": {
    "primary": "deloadWorkingWeight",
    "breakdown": [
      "deloadIntensity",
      "deloadVolume"
    ],

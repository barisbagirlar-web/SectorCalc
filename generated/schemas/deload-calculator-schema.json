{
  "toolName": "deload-calculator",
  "inputs": [
    {
      "id": "currentTrainingMax",
      "label": "Current Training Max",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The lifter's current one-rep max for the exercise in kg.",
      "label_i18n": {
        "en": "Current Training Max",
        "tr": "Current Training Max",

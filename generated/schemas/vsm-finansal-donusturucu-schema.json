  "formulas": {
    "LeadTimeCost": "WIP_Inventory * DailyCarryingCost * TotalLeadTimeDays",
    "ValueAddedRatio": "ValueAddedTime / TotalLeadTime",
    "NonValueAddedCost": "(TotalLeadTime - ValueAddedTime) * CostPerMinute",
    "InventoryReductionSavings": "(OldWIP - NewWIP) * CarryingRate",
    "ProductivityGain": "(OldCycleTime - NewCycleTime) * AnnualVolume * LaborRate",
    "TotalFinancialImpact": "InventoryReductionSavings + ProductivityGain + QualityImprovementSavings"
  },

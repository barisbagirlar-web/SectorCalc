{
  "toolName": "sheet-pile-weight-cost-calculator",
  "inputs": [
    {
      "id": "pileWidth",
      "label": "Pile Width",
      "type": "number",
      "unit": "m",
      "default": 0.6,
      "businessContext": "Width of a single sheet pile",
      "label_i18n": {
        "en": "Pile Width",
        "tr": "Pile Width",
        "de": "Pile Width",
        "fr": "Pile Width",
        "es": "Pile Width",
        "ar": "Pile Width"
      }
    },
    {
      "id": "pileLength",
      "label": "Pile Length",
      "type": "number",
      "unit": "m",
      "default": 12,
      "businessContext": "Length of each pile",
      "label_i18n": {
        "en": "Pile Length",
        "tr": "Pile Length",
        "de": "Pile Length",
        "fr": "Pile Length",
        "es": "Pile Length",
        "ar": "Pile Length"
      }
    },
    {
      "id": "numberOfPiles",
      "label": "Number of Piles",
      "type": "number",
      "unit": "unit",
      "default": 100,
      "businessContext": "Total number of piles",
      "label_i18n": {
        "en": "Number of Piles",
        "tr": "Number of Piles",
        "de": "Number of Piles",
        "fr": "Number of Piles",
        "es": "Number of Piles",
        "ar": "Number of Piles"
      }
    },
    {
      "id": "weightPerArea",
      "label": "Unit Weight",
      "type": "number",
      "unit": "kg/m²",
      "default": 120,
      "businessContext": "Mass of sheet pile per square meter (e.g., from manufacturer)",
      "label_i18n": {
        "en": "Unit Weight",
        "tr": "Unit Weight",
        "de": "Unit Weight",
        "fr": "Unit Weight",
        "es": "Unit Weight",
        "ar": "Unit Weight"
      }
    },
    {
      "id": "costPerTon",
      "label": "Cost per Ton",
      "type": "number",
      "unit": "$/ton",
      "default": 900,
      "businessContext": "Cost of steel per metric ton",
      "label_i18n": {
        "en": "Cost per Ton",
        "tr": "Cost per Ton",
        "de": "Cost per Ton",
        "fr": "Cost per Ton",
        "es": "Cost per Ton",
        "ar": "Cost per Ton"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Waste factor for cutting and damage",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "totalArea": "pileWidth * pileLength * numberOfPiles * (1 + wasteFactor / 100)",
    "totalWeightTons": "totalArea * weightPerArea / 1000",
    "totalCost": "totalWeightTons * costPerTon"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalArea",
      "totalWeightTons"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

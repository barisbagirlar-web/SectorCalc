{
  "toolName": "sheet-pile-weight-cost-calculator",
  "inputs": [
    {
      "id": "pileWidth",
      "label": "Pile Width",
      "type": "number",
      "unit": "m",
      "default": 0.6,
      "businessContext": "Width of a single sheet pile",
      "label_i18n": {
        "en": "Pile Width",
        "tr": "Kazık Genişliği",
        "de": "Pile Width",
        "fr": "Pile Width",
        "es": "Pile Width",
        "ar": "Pile Width"
      },
      "businessContext_i18n": {
        "en": "Width of a single sheet pile",

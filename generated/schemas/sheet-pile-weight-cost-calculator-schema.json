  "formulas": {
    "totalArea": "pileWidth * pileLength * numberOfPiles * (1 + wasteFactor / 100)",
    "totalWeightTons": "totalArea * weightPerArea / 1000",
    "totalCost": "totalWeightTons * costPerTon"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalArea",
      "totalWeightTons"
    ],

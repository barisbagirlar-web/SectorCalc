      }
    },
    {
      "id": "pileLength",
      "label": "Pile Length",
      "type": "number",
      "unit": "m",
      "default": 12,
      "businessContext": "Length of each pile",
      "label_i18n": {
        "en": "Pile Length",
        "tr": "Kazık Uzunluğu",
        "de": "Pile Length",
        "fr": "Pile Length",
        "es": "Pile Length",
        "ar": "Pile Length"
      },
      "businessContext_i18n": {
        "en": "Length of each pile",
        "tr": "Her bir palplanşın uzunluğu"
      }
    },
    {
      "id": "numberOfPiles",
      "label": "Number of Piles",
      "type": "number",
      "unit": "unit",
      "default": 100,
      "businessContext": "Total number of piles",
      "label_i18n": {
        "en": "Number of Piles",
        "tr": "Kazık Sayısı",
        "de": "Number of Piles",
        "fr": "Number of Piles",
        "es": "Number of Piles",
        "ar": "Number of Piles"
      },
      "businessContext_i18n": {
        "en": "Total number of piles",
        "tr": "Toplam palplanş sayısı"
      }
    },
    {
      "id": "weightPerArea",
      "label": "Unit Weight",
      "type": "number",
      "unit": "kg/m²",
      "default": 120,
      "businessContext": "Mass of sheet pile per square meter (e.g., from manufacturer)",
      "label_i18n": {
        "en": "Unit Weight",
        "tr": "Birim ağırlık",
        "de": "Unit Weight",
        "fr": "Unit Weight",
        "es": "Unit Weight",
        "ar": "Unit Weight"
      },
      "businessContext_i18n": {
        "en": "Mass of sheet pile per square meter (e.g., from manufacturer)",
        "tr": "Metrekare başına palplanş kütlesi (örneğin üreticiden)"
      }
    },
    {
      "id": "costPerTon",
      "label": "Cost per Ton",
      "type": "number",
      "unit": "$/ton",
      "default": 900,
      "businessContext": "Cost of steel per metric ton",
      "label_i18n": {
        "en": "Cost per Ton",
        "tr": "Ton başına maliyet",
        "de": "Cost per Ton",
        "fr": "Cost per Ton",
        "es": "Cost per Ton",
        "ar": "Cost per Ton"
      },
      "businessContext_i18n": {
        "en": "Cost of steel per metric ton",
        "tr": "Metrik ton başına çelik maliyeti"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Waste factor for cutting and damage",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Atık Faktörü",
        "de": "Abfallfaktor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      },
      "businessContext_i18n": {
        "en": "Waste factor for cutting and damage",
        "tr": "Kesim ve hasar için fire faktörü"
      }
    }
  ],
  "formulas": {
    "totalArea": "pileWidth * pileLength * numberOfPiles * (1 + wasteFactor / 100)",
    "totalWeightTons": "totalArea * weightPerArea / 1000",
    "totalCost": "totalWeightTons * costPerTon"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalArea",
      "totalWeightTons"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "m"
  },
  "category": "Dönüşüm & Ölçüm",

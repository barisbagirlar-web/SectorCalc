  "formulas": {
    "power": "voltage * current * powerFactor",
    "apparentPower": "voltage * current",
    "reactivePower": "voltage * current * Math.sin(Math.acos(powerFactor))",
    "energy": "voltage * current * powerFactor * time / 1000"
  },
  "outputs": {

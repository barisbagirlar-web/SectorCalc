      }
    },
    {
      "id": "stockingDensity",
      "label": "Stocking Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 10,
      "businessContext": "Desired stocking density in kg per cubic meter.",
      "label_i18n": {
        "en": "Stocking Density",
        "tr": "Stocking Density",
        "de": "Stocking Density",
        "fr": "Stocking Density",
        "es": "Stocking Density",
        "ar": "Stocking Density"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.8,
      "businessContext": "Safety factor to reduce stocking from theoretical maximum (0-1).",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "waterVolume": "tankLength * tankWidth * waterDepth",
    "waterWeight": "waterVolume * 1000",
    "singleFishWeightKg": "conditionFactor * Math.pow(fishLength, 3) / 1000",
    "maxBiomass": "stockingDensity * waterVolume",
    "recommendedFish": "Math.floor(safetyFactor * maxBiomass / singleFishWeightKg)"
  },
  "outputs": {
    "primary": "recommendedFish",
    "breakdown": [
      "waterVolume",
      "waterWeight",
      "singleFishWeightKg",
      "maxBiomass"
    ]
  },

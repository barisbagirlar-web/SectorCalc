  "formulas": {
    "total_n": "group1_n + group2_n",
    "grand_mean": "(group1_n * group1_mean + group2_n * group2_mean) / total_n",
    "SSB": "group1_n * (group1_mean - grand_mean)**2 + group2_n * (group2_mean - grand_mean)**2",
    "SSW": "(group1_n - 1) * group1_sd**2 + (group2_n - 1) * group2_sd**2",
    "dfW": "total_n - 2",
    "MSW": "SSW / dfW"
  },
  "outputs": {
    "primary": "MSW",
    "breakdown": [
      "grand_mean",

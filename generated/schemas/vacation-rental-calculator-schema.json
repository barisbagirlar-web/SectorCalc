{
  "toolName": "vacation-rental-calculator",
  "inputs": [
    {
      "id": "nightlyRate",
      "label": "Nightly Rate",
      "type": "number",
      "unit": "USD",
      "default": 150,
      "businessContext": "The base cost per night of the rental.",
      "label_i18n": {
        "en": "Nightly Rate",
        "tr": "Nightly Rate",
        "de": "Nightly Rate",
        "fr": "Nightly Rate",
        "es": "Nightly Rate",
        "ar": "Nightly Rate"
      }
    },
    {
      "id": "numberOfNights",
      "label": "Number of Nights",
      "type": "number",
      "unit": "nights",
      "default": 5,
      "businessContext": "Total nights the rental is booked.",
      "label_i18n": {
        "en": "Number of Nights",
        "tr": "Number of Nights",
        "de": "Number of Nights",
        "fr": "Number of Nights",
        "es": "Number of Nights",
        "ar": "Number of Nights"
      }
    },
    {
      "id": "cleaningFee",
      "label": "Cleaning Fee",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "One-time cleaning fee added to the total.",
      "label_i18n": {
        "en": "Cleaning Fee",
        "tr": "Cleaning Fee",
        "de": "Cleaning Fee",
        "fr": "Cleaning Fee",
        "es": "Cleaning Fee",
        "ar": "Cleaning Fee"
      }
    },
    {
      "id": "serviceFeePercent",
      "label": "Service Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Service fee as a percentage of the rental cost after any discounts.",
      "label_i18n": {
        "en": "Service Fee (%)",
        "tr": "Service Fee (%)",
        "de": "Service Fee (%)",
        "fr": "Service Fee (%)",
        "es": "Service Fee (%)",
        "ar": "Service Fee (%)"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Tax percentage applied to the pre-tax total.",
      "label_i18n": {
        "en": "Tax Rate (%)",
        "tr": "Tax Rate (%)",
        "de": "Tax Rate (%)",
        "fr": "Tax Rate (%)",
        "es": "Tax Rate (%)",
        "ar": "Tax Rate (%)"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Discount percentage applied to the base rental cost (nightly rate × nights).",
      "label_i18n": {
        "en": "Discount (%)",
        "tr": "Discount (%)",
        "de": "Discount (%)",
        "fr": "Discount (%)",
        "es": "Discount (%)",
        "ar": "Discount (%)"
      }
    }
  ],
  "formulas": {
    "subtotal": "nightlyRate * numberOfNights",
    "discountAmount": "subtotal * (discountPercent / 100)",
    "afterDiscount": "subtotal - discountAmount",
    "serviceFee": "afterDiscount * (serviceFeePercent / 100)",
    "beforeTax": "afterDiscount + cleaningFee + serviceFee",
    "tax": "beforeTax * (taxRate / 100)",
    "total": "beforeTax + tax"
  },
  "outputs": {
    "primary": "total",
    "breakdown": [
      "subtotal",
      "discountAmount",
      "afterDiscount",
      "serviceFee",
      "beforeTax",
      "tax",
      "total"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "total"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Emlak & Gayrimenkul",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "lean-production",
  "sectorId": "emlak",
  "profession": "Emlak Danışmanı",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

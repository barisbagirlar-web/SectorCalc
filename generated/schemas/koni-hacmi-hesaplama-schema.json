{
  "toolName": "koni-hacmi-hesaplama",
  "inputs": [
    {
      "id": "yaricap",
      "label": "Taban Yarıçapı",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Koni taban dairesinin yarıçapı. Geometrik hesaplamalar için temel parametre. Kaynak: Temel geometri."
    },
    {
      "id": "yukseklik",
      "label": "Yükseklik",
      "type": "number",
      "unit": "m",
      "default": 1,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Koninin tepe noktasından taban düzlemine dik uzaklık. Kaynak: Temel geometri."
    },
    {
      "id": "birim",
      "label": "Hacim Birimi",
      "type": "select",
      "unit": "",
      "default": "m3",
      "min": null,
      "max": null,
      "options": [
        "m3",
        "cm3",
        "litre"
      ],
      "businessContext": "Hacim sonucunun hangi birimde gösterileceği. Kullanıcı tercihine bağlı."
    }
  ],
  "validation": {
    "rules": [
      "yaricap > 0",
      "yukseklik > 0"
    ],
    "thresholds": {}
  },
  "formulas": {
    "hacim_m3": "(1/3) * Math.PI * yaricap * yaricap * yukseklik",
    "hacim_cm3": "hacim_m3 * 1000000",
    "hacim_litre": "hacim_m3 * 1000",
    "sonuc": "birim === 'm3' ? hacim_m3 : (birim === 'cm3' ? hacim_cm3 : hacim_litre)"
  },
  "outputs": {
    "primary": "sonuc",
    "breakdown": {
      "hacim_m3": "hacim_m3",
      "hacim_cm3": "hacim_cm3",
      "hacim_litre": "hacim_litre"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [],
    "dataConfidenceAdjusted": "sonuc"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Comparison"
  ],
  "premiumRequired": false
}

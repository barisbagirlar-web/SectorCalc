    "deltaT": "desiredTemp - ambientTemp",
    "requiredWattage": "insulationFactor * ((2 * (enclosureLength * enclosureWidth + enclosureLength * enclosureHeight + enclosureWidth * enclosureHeight)) / 10000) * (desiredTemp - ambientTemp)"

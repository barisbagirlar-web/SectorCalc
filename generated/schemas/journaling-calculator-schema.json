  "formulas": {
    "shaftRadius_mm": "shaftDiameter / 2",
    "shaftRadius_m": "shaftRadius_mm / 1000",
    "bearingLength_m": "bearingLength / 1000",
    "radialClearance_m": "radialClearance / 1000",
    "oilViscosity_Pas": "oilViscosity * 0.001",
    "rotationalSpeed_rps": "rotationalSpeed / 60",
    "unitLoadPressure": "(radialLoad * 1e6) / (shaftDiameter * bearingLength)",
    "clearanceRatio": "radialClearance_m / shaftRadius_m"
  },

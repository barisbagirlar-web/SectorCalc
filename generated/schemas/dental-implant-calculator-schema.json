  "formulas": {
    "materialCostOutput": "materialCost",
    "machiningCost": "machiningTime * machineRate",
    "laborCostOutput": "machiningTime * laborCost",
    "setupCost": "(setupTime * machineRate) / batchSize",
    "directCost": "materialCost + machiningTime*machineRate + machiningTime*laborCost + (setupTime*machineRate)/batchSize",
    "overheadCost": "(materialCost + machiningTime*machineRate + machiningTime*laborCost + (setupTime*machineRate)/batchSize) * (overheadPercent/100)",
    "totalCost": "(materialCost + machiningTime*machineRate + machiningTime*laborCost + (setupTime*machineRate)/batchSize) * (1 + overheadPercent/100)"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "directCost",
      "overheadCost",
      "setupCost",
      "machiningCost",
      "laborCostOutput",
      "materialCostOutput"
    ],

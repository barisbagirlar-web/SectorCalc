{
  "toolName": "recipe-cost-calculator",
  "inputs": [
    {
      "id": "ingredientCostPerUnit",
      "label": "Ingredient Cost per Unit",
      "type": "number",
      "unit": "currency/kg",
      "default": 5,
      "businessContext": "The purchase cost of the ingredient per unit weight (e.g., per kg)."
    },
    {
      "id": "ingredientQuantity",
      "label": "Ingredient Quantity Used",
      "type": "number",
      "unit": "kg",
      "default": 0.5,
      "businessContext": "The amount of the ingredient used in the recipe."
    },
    {
      "id": "numberOfPortions",
      "label": "Number of Portions",
      "type": "number",
      "unit": "portions",
      "default": 4,
      "businessContext": "The number of portions the recipe yields."
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour",
      "type": "number",
      "unit": "currency/hour",
      "default": 15,
      "businessContext": "Hourly wage for kitchen staff."
    },
    {
      "id": "laborHours",
      "label": "Labor Time",
      "type": "number",
      "unit": "hours",
      "default": 1,
      "businessContext": "Total labor time required for preparation and cooking."
    },
    {
      "id": "overheadPercent",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage of ingredient cost to cover overheads (rent, utilities, etc.)."
    }
  ],
  "formulas": {
    "totalIngredientCost": "ingredientCostPerUnit * ingredientQuantity",
    "laborCost": "laborCostPerHour * laborHours",
    "overheadCost": "totalIngredientCost * (overheadPercent / 100)",
    "totalRecipeCost": "totalIngredientCost + laborCost + overheadCost",
    "costPerPortion": "totalRecipeCost / numberOfPortions"
  },
  "outputs": {
    "primary": "totalRecipeCost",
    "breakdown": [
      "totalIngredientCost",
      "laborCost",
      "overheadCost",
      "costPerPortion"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "denizcilik",
  "profession": "Gemi Mühendisi",
  "categoryId": "conversion"
}

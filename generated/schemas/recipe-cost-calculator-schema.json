{
  "toolName": "recipe-cost-calculator",
  "inputs": [
    {
      "id": "ingredientCostPerUnit",
      "label": "Ingredient Cost per Unit",
      "type": "number",
      "unit": "currency/kg",
      "default": 5,
      "businessContext": "The purchase cost of the ingredient per unit weight (e.g., per kg).",
      "label_i18n": {
        "en": "Ingredient Cost per Unit",
        "tr": "Ingredient Cost per Unit",
        "de": "Ingredient Cost per Unit",
        "fr": "Ingredient Cost per Unit",
        "es": "Ingredient Cost per Unit",
        "ar": "Ingredient Cost per Unit"
      }
    },
    {
      "id": "ingredientQuantity",
      "label": "Ingredient Quantity Used",
      "type": "number",
      "unit": "kg",
      "default": 0.5,
      "businessContext": "The amount of the ingredient used in the recipe.",
      "label_i18n": {
        "en": "Ingredient Quantity Used",
        "tr": "Ingredient Quantity Used",
        "de": "Ingredient Quantity Used",
        "fr": "Ingredient Quantity Used",
        "es": "Ingredient Quantity Used",
        "ar": "Ingredient Quantity Used"
      }
    },
    {
      "id": "numberOfPortions",
      "label": "Number of Portions",
      "type": "number",
      "unit": "portions",
      "default": 4,
      "businessContext": "The number of portions the recipe yields.",
      "label_i18n": {
        "en": "Number of Portions",
        "tr": "Number of Portions",
        "de": "Number of Portions",
        "fr": "Number of Portions",
        "es": "Number of Portions",
        "ar": "Number of Portions"
      }
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour",
      "type": "number",
      "unit": "currency/hour",
      "default": 15,
      "businessContext": "Hourly wage for kitchen staff.",
      "label_i18n": {
        "en": "Labor Cost per Hour",
        "tr": "Labor Cost per Hour",
        "de": "Labor Cost per Hour",
        "fr": "Labor Cost per Hour",
        "es": "Labor Cost per Hour",
        "ar": "Labor Cost per Hour"
      }
    },
    {
      "id": "laborHours",
      "label": "Labor Time",
      "type": "number",
      "unit": "hours",
      "default": 1,
      "businessContext": "Total labor time required for preparation and cooking.",
      "label_i18n": {
        "en": "Labor Time",
        "tr": "Labor Time",
        "de": "Labor Time",
        "fr": "Labor Time",
        "es": "Labor Time",
        "ar": "Labor Time"
      }
    },
    {
      "id": "overheadPercent",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage of ingredient cost to cover overheads (rent, utilities, etc.).",
      "label_i18n": {
        "en": "Overhead Percentage",
        "tr": "Overhead Percentage",
        "de": "Overhead Percentage",
        "fr": "Overhead Percentage",
        "es": "Overhead Percentage",
        "ar": "Overhead Percentage"
      }
    }
  ],
  "formulas": {
    "totalIngredientCost": "ingredientCostPerUnit * ingredientQuantity",
    "laborCost": "laborCostPerHour * laborHours",
    "overheadCost": "totalIngredientCost * (overheadPercent / 100)",
    "totalRecipeCost": "totalIngredientCost + laborCost + overheadCost",
    "costPerPortion": "totalRecipeCost / numberOfPortions"
  },
  "outputs": {
    "primary": "totalRecipeCost",
    "breakdown": [
      "totalIngredientCost",
      "laborCost",
      "overheadCost",
      "costPerPortion"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerPortion"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,

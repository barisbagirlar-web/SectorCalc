      "businessContext": "Hourly wage for kitchen staff.",
      "label_i18n": {
        "en": "Labor Cost per Hour",
        "tr": "Saatlik işçilik maliyeti",
        "de": "Arbeitskosten pro Stunde",
        "fr": "Labor Cost per Hour",
        "es": "Labor Cost per Hour",
        "ar": "Labor Cost per Hour"
      },
      "businessContext_i18n": {
        "en": "Hourly wage for kitchen staff.",
        "tr": "Mutfak personeli için saatlik ücret."
      }
    },
    {
      "id": "laborHours",
      "label": "Labor Time",
      "type": "number",
      "unit": "hours",
      "default": 1,
      "businessContext": "Total labor time required for preparation and cooking.",
      "label_i18n": {
        "en": "Labor Time",
        "tr": "İşçilik Süresi",
        "de": "Labor Time",
        "fr": "Labor Time",
        "es": "Labor Time",
        "ar": "Labor Time"
      },
      "businessContext_i18n": {
        "en": "Total labor time required for preparation and cooking.",
        "tr": "Hazırlık ve pişirme için gereken toplam işçilik süresi."
      }
    },
    {
      "id": "overheadPercent",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage of ingredient cost to cover overheads (rent, utilities, etc.).",
      "label_i18n": {
        "en": "Overhead Percentage",
        "tr": "Genel Gider Yüzdesi",
        "de": "Gemeinkostenprozentsatz",
        "fr": "Overhead Percentage",
        "es": "Overhead Percentage",
        "ar": "Overhead Percentage"
      },
      "businessContext_i18n": {
        "en": "Percentage of ingredient cost to cover overheads (rent, utilities, etc.).",
        "tr": "Genel giderleri (kira, elektrik vb.) karşılamak için malzeme maliyetinin yüzdesi."
      }
    }
  ],
  "formulas": {
    "totalIngredientCost": "ingredientCostPerUnit * ingredientQuantity",
    "laborCost": "laborCostPerHour * laborHours",
    "overheadCost": "totalIngredientCost * (overheadPercent / 100)",
    "totalRecipeCost": "totalIngredientCost + laborCost + overheadCost",
    "costPerPortion": "totalRecipeCost / numberOfPortions"
  },
  "outputs": {
    "primary": "totalRecipeCost",
    "breakdown": [
      "totalIngredientCost",
      "laborCost",
      "overheadCost",
      "costPerPortion"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerPortion",
    "unit": "currency/kg"
  },

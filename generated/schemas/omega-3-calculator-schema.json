  "formulas": {
    "total_epa_mg": "capsule_size * capsules_per_day * (epa_percent / 100)",
    "total_dha_mg": "capsule_size * capsules_per_day * (dha_percent / 100)",
    "combined_epa_dha_mg": "capsule_size * capsules_per_day * ((epa_percent + dha_percent) / 100)",
    "epa_per_kg": "(capsule_size * capsules_per_day * (epa_percent / 100)) / body_weight_kg",
    "dha_per_kg": "(capsule_size * capsules_per_day * (dha_percent / 100)) / body_weight_kg",
    "combined_per_kg": "(capsule_size * capsules_per_day * ((epa_percent + dha_percent) / 100)) / body_weight_kg"
  },
  "outputs": {
    "primary": "combined_epa_dha_mg",
    "breakdown": [
      "total_epa_mg",
      "total_dha_mg",
      "combined_epa_dha_mg",
      "combined_per_kg"
    ],

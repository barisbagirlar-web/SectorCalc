  "formulas": {
    "jd": "(() => { let y = year; let m = month; let d = day + hour/24; if (m <= 2) { y -= 1; m += 12; } let A = Math.floor(y/100); let B = 2 - A + Math.floor(A/4); return Math.floor(365.25*(y+4716)) + Math.floor(30.6001*(m+1)) + d + B - 1524.5; })()",
    "moonPhaseFraction": "((jd - 2451549.5) % 29.53058867) / 29.53058867",
    "moonAgeDays": "(jd - 2451549.5) % 29.53058867",
    "illuminationPercent": "50*(1 - Math.cos(2*Math.PI*moonPhaseFraction))"
  },
  "outputs": {
    "primary": "moonPhaseFraction",
    "breakdown": [
      "moonAgeDays",
      "illuminationPercent"
    ]
  },

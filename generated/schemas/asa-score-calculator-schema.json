{
  "toolName": "asa-score-calculator",
  "inputs": [
    {
      "id": "scrapRate",
      "label": "Scrap Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of material scrapped during production.",
      "label_i18n": {
        "en": "Scrap Rate (%)",
        "tr": "Scrap Rate (%)",
        "de": "Scrap Rate (%)",
        "fr": "Scrap Rate (%)",
        "es": "Scrap Rate (%)",
        "ar": "Scrap Rate (%)"
      }
    },
    {
      "id": "materialCost",
      "label": "Material Cost (€)",
      "type": "number",
      "unit": "€",
      "default": 1000,
      "businessContext": "Cost of raw materials per batch.",
      "label_i18n": {
        "en": "Material Cost (€)",
        "tr": "Material Cost (€)",
        "de": "Material Cost (€)",
        "fr": "Material Cost (€)",
        "es": "Material Cost (€)",
        "ar": "Material Cost (€)"
      }
    },
    {
      "id": "batchSize",
      "label": "Batch Size (units)",
      "type": "number",
      "unit": "units",
      "default": 100,
      "businessContext": "Number of units produced in a batch.",
      "label_i18n": {
        "en": "Batch Size (units)",
        "tr": "Batch Size (units)",
        "de": "Batch Size (units)",
        "fr": "Batch Size (units)",
        "es": "Batch Size (units)",
        "ar": "Batch Size (units)"
      }
    },
    {
      "id": "reworkFactor",
      "label": "Rework Factor",
      "type": "number",
      "unit": "factor",
      "default": 0.1,
      "businessContext": "Factor accounting for rework effort (0-1).",
      "label_i18n": {
        "en": "Rework Factor",
        "tr": "Rework Factor",
        "de": "Rework Factor",
        "fr": "Rework Factor",
        "es": "Rework Factor",
        "ar": "Rework Factor"
      }
    }
  ],
  "formulas": {
    "scrapCost": "scrapRate / 100 * materialCost",
    "reworkCost": "reworkFactor * materialCost * batchSize",
    "totalCost": "scrapCost + reworkCost",
    "score": "100 - (totalCost / (materialCost * batchSize) * 100)"
  },
  "outputs": {
    "primary": "score",
    "breakdown": [
      "scrapCost",
      "reworkCost",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "score",
    "unit": "%"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Makine & Üretim",

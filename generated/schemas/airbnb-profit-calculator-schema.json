        "es": "Cleaning Fee per Booking",
        "ar": "Cleaning Fee per Booking"
      }
    },
    {
      "id": "airbnbFeePercent",
      "label": "Airbnb Service Fee",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Host service fee percentage charged by Airbnb on each booking",
      "label_i18n": {
        "en": "Airbnb Service Fee",
        "tr": "Airbnb Service Fee",
        "de": "Airbnb Service Fee",
        "fr": "Airbnb Service Fee",
        "es": "Airbnb Service Fee",
        "ar": "Airbnb Service Fee"
      }
    },
    {
      "id": "monthlyExpenses",
      "label": "Monthly Expenses",
      "type": "number",
      "unit": "currency",
      "default": 2000,
      "businessContext": "Total monthly costs including mortgage/rent, utilities, maintenance, insurance, etc.",
      "label_i18n": {
        "en": "Monthly Expenses",
        "tr": "Monthly Expenses",
        "de": "Monthly Expenses",
        "fr": "Monthly Expenses",
        "es": "Monthly Expenses",
        "ar": "Monthly Expenses"
      }
    }
  ],
  "formulas": {
    "bookedNights": "occupancyRate / 100 * nightsAvailable",
    "totalBookings": "bookedNights / avgStay",
    "grossRevenue": "nightlyRate * bookedNights + cleaningFee * totalBookings",
    "airbnbFee": "airbnbFeePercent / 100 * grossRevenue",
    "netRevenue": "grossRevenue - airbnbFee",
    "monthlyProfit": "netRevenue - monthlyExpenses"
  },
  "outputs": {
    "primary": "bookedNights",
    "breakdown": [
      {
        "id": "grossRevenue",
        "label": "Gross Revenue",

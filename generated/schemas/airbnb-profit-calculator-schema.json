      "label": "Average Length of Stay",
      "type": "number",
      "unit": "nights",
      "default": 3,
      "businessContext": "Average duration of a guest's stay in nights",
      "label_i18n": {
        "en": "Average Length of Stay",
        "tr": "Average Length of Stay",
        "de": "Average Length of Stay",
        "fr": "Average Length of Stay",
        "es": "Average Length of Stay",
        "ar": "Average Length of Stay"
      }
    },
    {
      "id": "cleaningFee",
      "label": "Cleaning Fee per Booking",
      "type": "number",
      "unit": "currency",
      "default": 50,
      "businessContext": "Fee charged per guest booking for cleaning",
      "label_i18n": {
        "en": "Cleaning Fee per Booking",
        "tr": "Cleaning Fee per Booking",
        "de": "Cleaning Fee per Booking",

{
  "toolName": "countdown-calculator",
  "inputs": [
    {
      "id": "totalDuration",
      "label": "Total Duration",
      "type": "number",
      "unit": "hours",
      "default": 100,
      "businessContext": "The total allocated time for completion, e.g., planned maintenance duration.",
      "label_i18n": {
        "en": "Total Duration",
        "tr": "Total Duration",
        "de": "Total Duration",
        "fr": "Total Duration",
        "es": "Total Duration",
        "ar": "Total Duration"
      }
    },
    {
      "id": "elapsedDuration",
      "label": "Elapsed Duration",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "businessContext": "The time already passed since the start.",
      "label_i18n": {
        "en": "Elapsed Duration",
        "tr": "Elapsed Duration",
        "de": "Elapsed Duration",
        "fr": "Elapsed Duration",
        "es": "Elapsed Duration",
        "ar": "Elapsed Duration"
      }
    },
    {
      "id": "bufferTime",
      "label": "Buffer Time",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "businessContext": "Additional safety margin added to total duration.",
      "label_i18n": {
        "en": "Buffer Time",
        "tr": "Buffer Time",
        "de": "Buffer Time",
        "fr": "Buffer Time",
        "es": "Buffer Time",
        "ar": "Buffer Time"
      }
    },
    {
      "id": "warningThreshold",
      "label": "Warning Threshold",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "When remaining time falls below this percent, trigger warning.",
      "label_i18n": {
        "en": "Warning Threshold",
        "tr": "Warning Threshold",
        "de": "Warning Threshold",
        "fr": "Warning Threshold",
        "es": "Warning Threshold",
        "ar": "Warning Threshold"
      }
    },
    {
      "id": "criticalThreshold",
      "label": "Critical Threshold",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "When remaining time falls below this percent, trigger critical alert.",
      "label_i18n": {
        "en": "Critical Threshold",
        "tr": "Critical Threshold",
        "de": "Critical Threshold",
        "fr": "Critical Threshold",
        "es": "Critical Threshold",
        "ar": "Critical Threshold"
      }
    }
  ],
  "formulas": {
    "remainingHours": "totalDuration + bufferTime - elapsedDuration",
    "percentRemaining": "((totalDuration + bufferTime - elapsedDuration) / (totalDuration + bufferTime)) * 100",
    "status": "(((totalDuration + bufferTime - elapsedDuration) / (totalDuration + bufferTime)) * 100) <= criticalThreshold ? 2 : ((((totalDuration + bufferTime - elapsedDuration) / (totalDuration + bufferTime)) * 100) <= warningThreshold ? 1 : 0)"
  },
  "outputs": {
    "primary": "remainingHours",
    "breakdown": [
      "percentRemaining",
      "status"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "status"
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,

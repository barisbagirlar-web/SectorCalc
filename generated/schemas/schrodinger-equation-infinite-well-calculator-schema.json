      "label": "Reduced Planck Constant",
      "type": "number",
      "unit": "J·s",
      "default": 1.054571817e-34,
      "businessContext": "Reduced Planck constant (ħ = h/2π).",
      "label_i18n": {
        "en": "Reduced Planck Constant",
        "tr": "Reduced Planck Constant",

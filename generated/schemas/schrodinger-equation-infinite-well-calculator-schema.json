  "formulas": {
    "energy": "(Math.pow(n, 2) * Math.pow(Math.PI, 2) * Math.pow(hbar, 2)) / (2 * m * Math.pow(L, 2))",
    "wavefunction": "Math.sqrt(2 / L) * Math.sin(n * Math.PI * x / L)",
    "probabilityDensity": "(2 / L) * Math.pow(Math.sin(n * Math.PI * x / L), 2)"
  },
  "outputs": {
    "primary": "energy",
    "breakdown": [
      "wavefunction",
      "probabilityDensity"
    ]
  },

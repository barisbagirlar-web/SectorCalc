{
  "toolName": "baseball-exit-velocity-calculator",
  "inputs": [
    {
      "id": "ballMass",
      "label": "Ball Mass",
      "type": "number",
      "unit": "oz",
      "default": 5.125,
      "businessContext": "Mass of the baseball in ounces. MLB regulations: 5 to 5.25 ounces.",
      "label_i18n": {
        "en": "Ball Mass",
        "tr": "Ball Mass",
        "de": "Ball Mass",
        "fr": "Ball Mass",
        "es": "Ball Mass",
        "ar": "Ball Mass"
      }
    },
    {
      "id": "batMass",
      "label": "Effective Bat Mass",
      "type": "number",
      "unit": "oz",
      "default": 28,
      "businessContext": "Effective mass of the bat at the impact point, typically less than total bat weight. Default is for a standard wood bat.",
      "label_i18n": {
        "en": "Effective Bat Mass",
        "tr": "Effective Bat Mass",
        "de": "Effective Bat Mass",
        "fr": "Effective Bat Mass",
        "es": "Effective Bat Mass",
        "ar": "Effective Bat Mass"
      }
    },
    {
      "id": "pitchSpeed",
      "label": "Pitch Speed",
      "type": "number",
      "unit": "mph",
      "default": 90,
      "businessContext": "Speed of the pitched ball as it crosses the plate, in miles per hour.",
      "label_i18n": {
        "en": "Pitch Speed",
        "tr": "Pitch Speed",
        "de": "Pitch Speed",
        "fr": "Pitch Speed",
        "es": "Pitch Speed",
        "ar": "Pitch Speed"
      }
    },
    {
      "id": "batSpeed",
      "label": "Bat Speed",
      "type": "number",
      "unit": "mph",
      "default": 70,
      "businessContext": "Speed of the bat's sweet spot at the moment of impact, in miles per hour.",
      "label_i18n": {
        "en": "Bat Speed",
        "tr": "Bat Speed",
        "de": "Bat Speed",
        "fr": "Bat Speed",
        "es": "Bat Speed",
        "ar": "Bat Speed"
      }
    },
    {
      "id": "cor",
      "label": "Coefficient of Restitution",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Coefficient of restitution between ball and bat, typically 0.5 to 0.55 for wood bats.",
      "label_i18n": {
        "en": "Coefficient of Restitution",
        "tr": "Coefficient of Restitution",
        "de": "Coefficient of Restitution",
        "fr": "Coefficient of Restitution",
        "es": "Coefficient of Restitution",
        "ar": "Coefficient of Restitution"
      }
    }
  ],
  "formulas": {
    "exitVelocity": "((ballMass - cor*batMass) / (ballMass + batMass)) * (-pitchSpeed) + ((1+cor)*batMass / (ballMass + batMass)) * batSpeed",
    "batContribution": "((1+cor)*batMass / (ballMass + batMass)) * batSpeed",
    "pitchContribution": "((ballMass - cor*batMass) / (ballMass + batMass)) * (-pitchSpeed)"
  },
  "outputs": {
    "primary": "exitVelocity",
    "breakdown": [
      "batContribution",
      "pitchContribution"
    ]
  },

    {
      "id": "targetVitaminD",
      "label": "Target Vitamin D Level",
      "type": "number",
      "unit": "ng/mL",
      "default": 50,
      "businessContext": "Desired 25(OH)D level for optimal health",
      "label_i18n": {
        "en": "Target Vitamin D Level",
        "tr": "Target Vitamin D Level",
        "de": "Target Vitamin D Level",
        "fr": "Target Vitamin D Level",
        "es": "Target Vitamin D Level",
        "ar": "Target Vitamin D Level"
      }
    },
    {
      "id": "treatmentDuration",
      "label": "Treatment Duration",
      "type": "number",
      "unit": "weeks",
      "default": 12,
      "businessContext": "Duration for gradual serum level adjustment in production planning",
      "label_i18n": {
        "en": "Treatment Duration",
        "tr": "Treatment Duration",
        "de": "Treatment Duration",
        "fr": "Treatment Duration",
        "es": "Treatment Duration",
        "ar": "Treatment Duration"
      }
    }
  ],
  "formulas": {
    "diff": "targetVitaminD - currentVitaminD",
    "dailyDoseIU": "diff * 100",
    "weeklyDoseIU": "dailyDoseIU * 7",
    "totalDoseIU": "dailyDoseIU * treatmentDuration * 7"
  },
  "outputs": {
    "primary": "dailyDoseIU",
    "breakdown": [
      "weeklyDoseIU",
      "totalDoseIU"
    ],

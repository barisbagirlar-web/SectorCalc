      }
    },
    {
      "id": "halfLife",
      "label": "Half-Life",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Time required for half of the substance to decay",
      "label_i18n": {
        "en": "Half-Life",
        "tr": "Half-Life",
        "de": "Half-Life",
        "fr": "Half-Life",
        "es": "Half-Life",
        "ar": "Half-Life"
      }
    },
    {
      "id": "startTime",
      "label": "Start Time",
      "type": "number",
      "unit": "years",
      "default": 0,
      "businessContext": "Starting point of the decay period",
      "label_i18n": {
        "en": "Start Time",
        "tr": "Start Time",
        "de": "Start Time",
        "fr": "Start Time",
        "es": "Start Time",
        "ar": "Start Time"
      }
    },
    {
      "id": "endTime",
      "label": "End Time",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Ending point of the decay period",
      "label_i18n": {
        "en": "End Time",
        "tr": "End Time",
        "de": "End Time",
        "fr": "End Time",
        "es": "End Time",
        "ar": "End Time"
      }
    }
  ],
  "formulas": {
    "remainingMass": "initialMass * (0.5 ** ((endTime - startTime) / halfLife))",
    "decayFraction": "0.5 ** ((endTime - startTime) / halfLife)",
    "numberOfHalfLives": "(endTime - startTime) / halfLife"
  },
  "outputs": {
    "primary": "remainingMass",
    "breakdown": [
      "decayFraction",
      "numberOfHalfLives"
    ],

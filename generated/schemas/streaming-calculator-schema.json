{
  "toolName": "streaming-calculator",
  "inputs": [
    {
      "id": "pipeDiameter",
      "label": "Pipe Inner Diameter",
      "type": "number",
      "unit": "m",
      "default": 0.1,
      "businessContext": "Internal diameter of the pipe conveying the fluid.",
      "label_i18n": {
        "en": "Pipe Inner Diameter",
        "tr": "Pipe Inner Diameter",
        "de": "Pipe Inner Diameter",
        "fr": "Pipe Inner Diameter",
        "es": "Pipe Inner Diameter",
        "ar": "Pipe Inner Diameter"
      }
    },
    {
      "id": "fluidVelocity",
      "label": "Fluid Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 2,
      "businessContext": "Average velocity of the fluid flow in the pipe.",
      "label_i18n": {
        "en": "Fluid Velocity",
        "tr": "Fluid Velocity",
        "de": "Fluid Velocity",
        "fr": "Fluid Velocity",
        "es": "Fluid Velocity",
        "ar": "Fluid Velocity"
      }
    },
    {
      "id": "fluidDensity",
      "label": "Fluid Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Density of the fluid (e.g., water = 1000 kg/m³).",
      "label_i18n": {
        "en": "Fluid Density",
        "tr": "Fluid Density",
        "de": "Fluid Density",
        "fr": "Fluid Density",
        "es": "Fluid Density",
        "ar": "Fluid Density"
      }
    },
    {
      "id": "dynamicViscosity",
      "label": "Dynamic Viscosity",
      "type": "number",
      "unit": "Pa·s",
      "default": 0.001,
      "businessContext": "Dynamic viscosity of the fluid (e.g., water at 20°C ≈ 0.001 Pa·s).",
      "label_i18n": {
        "en": "Dynamic Viscosity",
        "tr": "Dynamic Viscosity",
        "de": "Dynamic Viscosity",
        "fr": "Dynamic Viscosity",
        "es": "Dynamic Viscosity",
        "ar": "Dynamic Viscosity"
      }
    }
  ],
  "formulas": {
    "crossSectionArea": "Math.PI * (pipeDiameter / 2) ** 2",
    "volumetricFlowRate": "Math.PI * (pipeDiameter / 2) ** 2 * fluidVelocity",
    "massFlowRate": "Math.PI * (pipeDiameter / 2) ** 2 * fluidVelocity * fluidDensity",
    "reynoldsNumber": "(fluidDensity * fluidVelocity * pipeDiameter) / dynamicViscosity"
  },
  "outputs": {
    "primary": "volumetricFlowRate",
    "breakdown": [
      "crossSectionArea",
      "massFlowRate",
      "reynoldsNumber"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "reynoldsNumber"
  },
  "category": "Akışkanlar & Termodinamik",
  "sector": "Teknik & Mühendislik",

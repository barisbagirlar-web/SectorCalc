      }
    },
    {
      "id": "complexityFactor",
      "label": "Complexity Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Scene complexity multiplier. 1 for simple, 5 for highly complex.",
      "label_i18n": {
        "en": "Complexity Factor",
        "tr": "Complexity Factor",
        "de": "Complexity Factor",
        "fr": "Complexity Factor",
        "es": "Complexity Factor",
        "ar": "Complexity Factor"
      }
    },
    {
      "id": "maxBounces",
      "label": "Max Ray Bounces",
      "type": "number",
      "unit": "bounces",
      "default": 4,
      "businessContext": "Maximum light bounces for global illumination. Higher increases realism and time.",
      "label_i18n": {
        "en": "Max Ray Bounces",
        "tr": "Max Ray Bounces",
        "de": "Max Ray Bounces",
        "fr": "Max Ray Bounces",
        "es": "Max Ray Bounces",
        "ar": "Max Ray Bounces"
      }
    }
  ],
  "formulas": {
    "totalPixels": "resolutionWidth * resolutionHeight",
    "totalRaysPerFrame": "totalPixels * samplesPerPixel * maxBounces * complexityFactor",
    "totalRays": "totalRaysPerFrame * frameCount",
    "renderTimeSeconds": "totalRays / renderEngineSpeed",
    "renderTimeMinutes": "renderTimeSeconds / 60",
    "renderTimeHours": "renderTimeMinutes / 60"
  },
  "outputs": {
    "primary": "renderTimeHours",
    "breakdown": [
      "totalRays",
      "renderTimeSeconds",
      "renderTimeMinutes"
    ],

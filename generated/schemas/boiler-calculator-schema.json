{
  "toolName": "boiler-calculator",
  "inputs": [
    {
      "id": "steamFlow",
      "label": "Steam Flow Rate",
      "type": "number",
      "unit": "kg/h",
      "default": 10000,
      "businessContext": "Mass flow rate of steam generated by the boiler, measured in kilograms per hour.",
      "label_i18n": {
        "en": "Steam Flow Rate",

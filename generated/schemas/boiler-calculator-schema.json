      "type": "number",
      "unit": "kJ/kg",
      "default": 2776,
      "businessContext": "Specific enthalpy of the steam at the boiler outlet, typically from steam tables based on pressure and temperature.",
      "label_i18n": {
        "en": "Steam Enthalpy",
        "tr": "Steam Enthalpy",
        "de": "Steam Enthalpy",
        "fr": "Steam Enthalpy",
        "es": "Steam Enthalpy",
        "ar": "Steam Enthalpy"
      }
    },
    {
      "id": "feedWaterTemperature",
      "label": "Feed Water Temperature",
      "type": "number",
      "unit": "°C",
      "default": 105,

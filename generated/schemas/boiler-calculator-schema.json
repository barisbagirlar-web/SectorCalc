      "label_i18n": {
        "en": "Feed Water Temperature",
        "tr": "Feed Water Temperature",
        "de": "Feed Water Temperature",
        "fr": "Feed Water Temperature",
        "es": "Feed Water Temperature",
        "ar": "Feed Water Temperature"
      }
    },
    {
      "id": "fuelFlow",
      "label": "Fuel Flow Rate",
      "type": "number",
      "unit": "kg/h",
      "default": 1500,
      "businessContext": "Mass flow rate of fuel consumed by the boiler, measured in kilograms per hour.",
      "label_i18n": {
        "en": "Fuel Flow Rate",
        "tr": "Fuel Flow Rate",
        "de": "Fuel Flow Rate",
        "fr": "Fuel Flow Rate",
        "es": "Fuel Flow Rate",
        "ar": "Fuel Flow Rate"
      }
    },
    {
      "id": "fuelGCV",
      "label": "Fuel Gross Calorific Value",
      "type": "number",
      "unit": "kJ/kg",
      "default": 25000,
      "businessContext": "Gross calorific value (higher heating value) of the fuel, representing total energy released per kilogram.",
      "label_i18n": {
        "en": "Fuel Gross Calorific Value",
        "tr": "Fuel Gross Calorific Value",
        "de": "Fuel Gross Calorific Value",
        "fr": "Fuel Gross Calorific Value",
        "es": "Fuel Gross Calorific Value",
        "ar": "Fuel Gross Calorific Value"
      }
    }
  ],
  "formulas": {
    "steamEnergyOutput_kW": "(steamFlow * (steamEnthalpy - 4.186 * feedWaterTemperature)) / 3600",
    "fuelEnergyInput_kW": "(fuelFlow * fuelGCV) / 3600",
    "efficiency": "((steamFlow * (steamEnthalpy - 4.186 * feedWaterTemperature)) / (fuelFlow * fuelGCV)) * 100"
  },
  "outputs": {
    "primary": "efficiency",

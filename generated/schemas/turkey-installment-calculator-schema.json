  "formulas": {
    "effectiveMonthlyRate": "(interestRate / 100 / 12) * (1 + bsmv/100 + kkdf/100)",
    "effectiveMonthlyRate_aux": "(interestRate / 100 / 12) * (1 + bsmv/100 + kkdf/100)"
  },

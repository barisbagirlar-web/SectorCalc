      "label_i18n": {
        "en": "Arrangement Fee (TL)",
        "tr": "Düzenleme Ücreti (TL)",
        "de": "Bearbeitungsgebühr (TL)",
        "fr": "Frais de mise en place (TL)",
        "es": "Comisión de gestión (TL)",
        "ar": "رسوم الترتيب (ليرة تركية)"
      },
      "businessContext_i18n": {
        "en": "One-time fee added to loan principal",

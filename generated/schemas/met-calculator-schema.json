{
  "toolName": "met-calculator",
  "inputs": [
    {
      "id": "metValue",
      "label": "MET Değeri",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Gerçekleştirilen aktivitenin MET değeri",
      "label_i18n": {
        "en": "MET Değeri",
        "tr": "MET Değeri",
        "de": "MET Değeri",
        "fr": "MET Değeri",
        "es": "MET Değeri",
        "ar": "MET Değeri"
      }
    },
    {
      "id": "weightKg",
      "label": "Vücut Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Kullanıcının kilogram cinsinden vücut ağırlığı",
      "label_i18n": {
        "en": "Vücut Ağırlığı",
        "tr": "Vücut Ağırlığı",
        "de": "Vücut Ağırlığı",
        "fr": "Vücut Ağırlığı",
        "es": "Vücut Ağırlığı",
        "ar": "Vücut Ağırlığı"
      }
    },
    {
      "id": "durationMin",
      "label": "Süre",
      "type": "number",
      "unit": "dk",
      "default": 30,
      "businessContext": "Aktivitenin dakika cinsinden süresi",
      "label_i18n": {
        "en": "Süre",
        "tr": "Süre",
        "de": "Süre",
        "fr": "Süre",
        "es": "Süre",
        "ar": "Süre"
      }
    },
    {
      "id": "adjustmentFactor",
      "label": "Düzeltme Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Bireysel metabolizma farklılıkları için ayar katsayısı (varsayılan 1)",
      "label_i18n": {
        "en": "Düzeltme Faktörü",
        "tr": "Düzeltme Faktörü",
        "de": "Düzeltme Faktörü",
        "fr": "Düzeltme Faktörü",
        "es": "Düzeltme Faktörü",
        "ar": "Düzeltme Faktörü"
      }
    }
  ],
  "formulas": {
    "totalCal": "metValue * weightKg * (durationMin / 60) * adjustmentFactor",
    "calPerMin": "totalCal / durationMin",
    "metHours": "metValue * (durationMin / 60)"
  },
  "outputs": {
    "primary": "totalCal",
    "breakdown": [
      "calPerMin",
      "metHours"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",

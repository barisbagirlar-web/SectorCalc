        "fr": "Valeur MET de l'activité réalisée",
        "es": "Valor MET de la actividad realizada",
        "ar": "قيمة MET للنشاط المنجز"
      }
    },
    {
      "id": "weightKg",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Vücut Ağırlığı",
        "de": "Körpergewicht",
        "fr": "Poids corporel",
        "es": "Peso corporal",
        "ar": "وزن الجسم"
      },
      "businessContext_i18n": {
        "en": "User's body weight in kilograms",
        "tr": "Kullanıcının kilogram cinsinden vücut ağırlığı",
        "de": "Körpergewicht des Benutzers in Kilogramm",
        "fr": "Poids corporel de l'utilisateur en kilogrammes",
        "es": "Peso corporal del usuario en kilogramos",
        "ar": "وزن جسم المستخدم بالكيلوغرام"
      }
    },
    {
      "id": "durationMin",
      "label": "Duration",
      "type": "number",
      "unit": "dk",
      "default": 30,
      "businessContext": "Duration of the activity in minutes",
      "label_i18n": {
        "en": "Duration",
        "tr": "Süre",
        "de": "Dauer",
        "fr": "Durée",
        "es": "Duración",
        "ar": "المدة"
      },
      "businessContext_i18n": {
        "en": "Duration of activity in minutes",
        "tr": "Aktivitenin dakika cinsinden süresi",
        "de": "Dauer der Aktivität in Minuten",
        "fr": "Durée de l'activité en minutes",
        "es": "Duración de la actividad en minutos",
        "ar": "مدة النشاط بالدقائق"
      }
    },
    {
      "id": "adjustmentFactor",
      "label": "Correction Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Adjustment coefficient for individual metabolic differences (default 1)",
      "label_i18n": {
        "en": "Correction factor",
        "tr": "Düzeltme Faktörü",
        "de": "Korrekturfaktor",
        "fr": "Facteur de correction",
        "es": "Factor de corrección",
        "ar": "عامل التصحيح"
      },
      "businessContext_i18n": {
        "en": "Adjustment coefficient for individual metabolic differences (default 1)",
        "tr": "Bireysel metabolizma farklılıkları için ayar katsayısı (varsayılan 1)",
        "de": "Anpassungskoeffizient für individuelle Stoffwechselunterschiede (Standard 1)",
        "fr": "Coefficient d'ajustement pour les différences métaboliques individuelles (par défaut 1)",
        "es": "Coeficiente de ajuste por diferencias metabólicas individuales (por defecto 1)",
        "ar": "معامل ضبط الاختلافات الأيضية الفردية (الافتراضي 1)"
      }
    }
  ],
  "formulas": {
    "totalCal": "metValue * weightKg * (durationMin / 60) * adjustmentFactor",
    "calPerMin": "totalCal / durationMin",
    "metHours": "metValue * (durationMin / 60)"
  },
  "outputs": {
    "primary": "totalCal",
    "breakdown": [
      "calPerMin",
      "metHours"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "metHours",
    "unit": "kg",
    "breakdownUnits": {
      "metHours": "h"
    }
  },

{
  "toolName": "met-calculator",
  "inputs": [
    {
      "id": "metValue",
      "label": "MET Value",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "MET value of the activity performed",
      "label_i18n": {
        "en": "MET Value",
        "tr": "MET Değeri",
        "de": "MET-Wert",
        "fr": "Valeur MET",
        "es": "Valor MET",
        "ar": "قيمة MET"
      },
      "businessContext_i18n": {
        "en": "MET value of the activity performed",
        "tr": "Gerçekleştirilen aktivitenin MET değeri",

    },
    {
      "id": "extractionEfficiency",
      "label": "Extraction Efficiency",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Percentage of sugar extracted from cane into juice.",
      "label_i18n": {
        "en": "Extraction Efficiency",
        "tr": "Ekstraksiyon Verimliliği",
        "de": "Extraction Efficiency",
        "fr": "Extraction Efficiency",
        "es": "Extraction Efficiency",
        "ar": "Extraction Efficiency"
      },
      "businessContext_i18n": {
        "en": "Percentage of sugar extracted from cane into juice.",
        "tr": "Şeker kamışından meyve suyuna çıkarılan şeker yüzdesi."
      }
    },
    {
      "id": "boilingHouseEfficiency",
      "label": "Boiling House Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Percentage of sugar in juice that is recovered as crystal sugar.",
      "label_i18n": {
        "en": "Boiling House Efficiency",
        "tr": "Kaynatma Evi Verimliliği",
        "de": "Boiling House Efficiency",
        "fr": "Boiling House Efficiency",
        "es": "Boiling House Efficiency",
        "ar": "Boiling House Efficiency"
      },
      "businessContext_i18n": {
        "en": "Percentage of sugar in juice that is recovered as crystal sugar.",
        "tr": "Meyve suyundaki şekerin kristal şeker olarak geri kazanılan yüzdesi."
      }
    }
  ],
  "formulas": {
    "totalSugar": "caneWeight * polCane / 100",
    "extractedSugar": "totalSugar * extractionEfficiency / 100",
    "recoveredSugar": "extractedSugar * boilingHouseEfficiency / 100",
    "extractionLoss": "totalSugar - extractedSugar",
    "boilingLoss": "extractedSugar - recoveredSugar"
  },
  "outputs": {
    "primary": "recoveredSugar",
    "breakdown": [
      "totalSugar",
      "extractedSugar",
      "extractionLoss",
      "boilingLoss"
    ],

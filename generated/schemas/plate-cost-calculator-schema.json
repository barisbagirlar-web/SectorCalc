{
  "toolName": "plate-cost-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length (mm)",
      "type": "number",
      "unit": "mm",
      "default": 1000,
      "businessContext": "The length of the plate in millimeters.",
      "label_i18n": {
        "en": "Length (mm)",
        "tr": "Length (mm)",
        "de": "Length (mm)",
        "fr": "Length (mm)",

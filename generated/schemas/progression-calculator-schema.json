  "formulas": {
    "sum": "((endIndex - startIndex + 1) * (2 * firstTerm + commonDifference * (startIndex + endIndex - 2))) / 2",
    "startValue": "firstTerm + commonDifference * (startIndex - 1)",
    "endValue": "firstTerm + commonDifference * (endIndex - 1)"
  },

{
  "toolName": "progression-calculator",
  "inputs": [
    {
      "id": "firstTerm",
      "label": "First Term (a)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Initial term of the progression"
    },
    {
      "id": "commonDifference",
      "label": "Common Difference (d)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "For arithmetic progression"
    },
    {
      "id": "commonRatio",
      "label": "Common Ratio (r)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "For geometric progression"
    },
    {
      "id": "numberOfTerms",
      "label": "Number of Terms (n)",
      "type": "number",
      "unit": "",
      "default": 5,
      "businessContext": "Total numbers in sequence"
    },
    {
      "id": "progressionType",
      "label": "Type (1=Arithmetic, 0=Geometric)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1 for Arithmetic, 0 for Geometric"
    }
  ],
  "formulas": {
    "nthTerm": "progressionType === 1 ? firstTerm + (numberOfTerms - 1) * commonDifference : firstTerm * (commonRatio ** (numberOfTerms - 1))",
    "sum": "progressionType === 1 ? (numberOfTerms/2) * (2*firstTerm + (numberOfTerms-1)*commonDifference) : (commonRatio === 1 ? firstTerm * numberOfTerms : firstTerm * (1 - commonRatio ** numberOfTerms) / (1 - commonRatio))"
  },
  "outputs": {
    "primary": "nthTerm",
    "breakdown": [
      "sum",
      "firstTerm",
      "commonDifference",
      "commonRatio",
      "numberOfTerms",
      "progressionType"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

{
  "toolName": "quarterly-compound-interest-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Principal Amount",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "The initial sum of money invested or borrowed.",
      "label_i18n": {
        "en": "Principal Amount",
        "tr": "Principal Amount",
        "de": "Principal Amount",
        "fr": "Principal Amount",
        "es": "Principal Amount",
        "ar": "Principal Amount"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "The nominal annual interest rate before compounding.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "years",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "The total time the money is invested or borrowed for.",
      "label_i18n": {
        "en": "Number of Years",
        "tr": "Number of Years",
        "de": "Number of Years",
        "fr": "Number of Years",
        "es": "Number of Years",
        "ar": "Number of Years"
      }
    },
    {
      "id": "compoundingFrequency",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "times per year",
      "default": 4,
      "businessContext": "The number of compounding periods per year. For quarterly, this is 4.",
      "label_i18n": {
        "en": "Compounding Frequency",
        "tr": "Compounding Frequency",
        "de": "Compounding Frequency",
        "fr": "Compounding Frequency",
        "es": "Compounding Frequency",
        "ar": "Compounding Frequency"
      }
    },
    {
      "id": "inflationRate",
      "label": "Annual Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The expected average annual inflation rate, used to calculate the real value of money.",
      "label_i18n": {
        "en": "Annual Inflation Rate",
        "tr": "Annual Inflation Rate",
        "de": "Annual Inflation Rate",
        "fr": "Annual Inflation Rate",
        "es": "Annual Inflation Rate",
        "ar": "Annual Inflation Rate"
      }
    }
  ],
  "formulas": {
    "finalAmount": "principal * (1 + annualInterestRate/100 / compoundingFrequency) ** (compoundingFrequency * years)",
    "totalInterest": "finalAmount - principal",
    "effectiveAnnualRate": "((1 + annualInterestRate/100 / compoundingFrequency) ** compoundingFrequency - 1) * 100",
    "realFinalAmount": "finalAmount / (1 + inflationRate/100) ** years"
  },
  "outputs": {
    "primary": "finalAmount",
    "breakdown": [
      "totalInterest",
      "effectiveAnnualRate",
      "realFinalAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "realFinalAmount"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "telekom",
  "profession": "Ağ Mühendisi",
  "categoryId": "diger",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

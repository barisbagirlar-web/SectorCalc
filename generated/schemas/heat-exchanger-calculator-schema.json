      "label_i18n": {
        "en": "Cold Fluid Mass Flow Rate",
        "tr": "Cold Fluid Mass Flow Rate",
        "de": "Cold Fluid Mass Flow Rate",
        "fr": "Cold Fluid Mass Flow Rate",
        "es": "Cold Fluid Mass Flow Rate",
        "ar": "Cold Fluid Mass Flow Rate"
      }
    },
    {
      "id": "cpCold",
      "label": "Cold Fluid Specific Heat",
      "type": "number",
      "unit": "kJ/(kg·K)",
      "default": 4.18,
      "businessContext": "Specific heat capacity of the cold fluid.",
      "label_i18n": {
        "en": "Cold Fluid Specific Heat",
        "tr": "Cold Fluid Specific Heat",
        "de": "Cold Fluid Specific Heat",
        "fr": "Cold Fluid Specific Heat",
        "es": "Cold Fluid Specific Heat",
        "ar": "Cold Fluid Specific Heat"
      }
    },
    {
      "id": "tempColdIn",
      "label": "Cold Fluid Inlet Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Inlet temperature of the cold fluid.",
      "label_i18n": {
        "en": "Cold Fluid Inlet Temperature",
        "tr": "Cold Fluid Inlet Temperature",
        "de": "Cold Fluid Inlet Temperature",
        "fr": "Cold Fluid Inlet Temperature",
        "es": "Cold Fluid Inlet Temperature",
        "ar": "Cold Fluid Inlet Temperature"
      }
    },
    {
      "id": "overallHeatTransferCoeff",
      "label": "Overall Heat Transfer Coefficient",
      "type": "number",
      "unit": "W/(m²·K)",
      "default": 500,
      "businessContext": "Overall heat transfer coefficient of the heat exchanger.",
      "label_i18n": {
        "en": "Overall Heat Transfer Coefficient",
        "tr": "Overall Heat Transfer Coefficient",
        "de": "Overall Heat Transfer Coefficient",
        "fr": "Overall Heat Transfer Coefficient",
        "es": "Overall Heat Transfer Coefficient",
        "ar": "Overall Heat Transfer Coefficient"
      }
    }
  ],
  "formulas": {
    "heatTransferRate": "massFlowHot * cpHot * (tempHotIn - tempHotOut) * 1000",
    "tempColdOut": "tempColdIn + (heatTransferRate / (massFlowCold * cpCold * 1000))"
  },
  "outputs": {
    "primary": "heatTransferRate",
    "breakdown": [
      "heatTransferRate",
      "tempColdOut",
      "logMeanTempDiff",
      "area"
    ],

{
  "toolName": "heat-exchanger-calculator",
  "inputs": [
    {
      "id": "massFlowHot",
      "label": "Hot Fluid Mass Flow Rate",
      "type": "number",
      "unit": "kg/s",
      "default": 10,
      "businessContext": "Mass flow rate of the hot fluid entering the heat exchanger.",
      "label_i18n": {
        "en": "Hot Fluid Mass Flow Rate",
        "tr": "Hot Fluid Mass Flow Rate",

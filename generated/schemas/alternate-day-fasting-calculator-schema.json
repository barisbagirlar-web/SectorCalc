{
  "toolName": "alternate-day-fasting-calculator",
  "inputs": [
    {
      "id": "normalCal",
      "label": "Normal Day Calorie Intake",
      "type": "number",
      "unit": "kcal/day",
      "default": 2000,
      "businessContext": "Average calorie consumption on normal eating days."
    },
    {
      "id": "fastingCal",
      "label": "Fasting Day Calorie Intake",
      "type": "number",
      "unit": "kcal/day",
      "default": 500,
      "businessContext": "Calorie intake on fasting days (often 0-500 kcal)."
    },
    {
      "id": "totalDays",
      "label": "Number of Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Total number of days to calculate for the regimen."
    },
    {
      "id": "startDay",
      "label": "Starting Day Type",
      "type": "number",
      "unit": "unitless",
      "default": 0,
      "businessContext": "0 if starting with a normal day, 1 if starting with a fasting day."
    }
  ],
  "formulas": {
    "fastingDays": "startDay === 0 ? Math.floor(totalDays / 2) : Math.ceil(totalDays / 2)",
    "normalDays": "totalDays - fastingDays",
    "totalCalories": "normalDays * normalCal + fastingDays * fastingCal",
    "averageDailyCalories": "totalCalories / totalDays"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [
      "averageDailyCalories",
      "fastingDays"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

{
  "toolName": "deans-list-calculator",
  "inputs": [
    {
      "id": "totalCredits",
      "label": "Total Credits Attempted",
      "type": "number",
      "unit": "credits",
      "default": 30,
      "businessContext": "Total number of credits enrolled in the semester",
      "label_i18n": {
        "en": "Total Credits Attempted",
        "tr": "Total Credits Attempted",
        "de": "Total Credits Attempted",
        "fr": "Total Credits Attempted",
        "es": "Total Credits Attempted",
        "ar": "Total Credits Attempted"
      }
    },
    {
      "id": "earnedCredits",
      "label": "Earned Credits",
      "type": "number",
      "unit": "credits",
      "default": 30,
      "businessContext": "Number of credits successfully completed",
      "label_i18n": {
        "en": "Earned Credits",
        "tr": "Earned Credits",
        "de": "Earned Credits",
        "fr": "Earned Credits",
        "es": "Earned Credits",
        "ar": "Earned Credits"
      }
    },
    {
      "id": "gpa",
      "label": "Semester GPA",
      "type": "number",
      "unit": "unit",
      "default": 3.5,
      "businessContext": "Grade point average for the semester (0.0 - 4.0 scale)",
      "label_i18n": {
        "en": "Semester GPA",
        "tr": "Semester GPA",
        "de": "Semester GPA",
        "fr": "Semester GPA",
        "es": "Semester GPA",
        "ar": "Semester GPA"
      }
    },
    {
      "id": "minGpa",
      "label": "Minimum GPA Requirement",
      "type": "number",
      "unit": "unit",
      "default": 3.5,
      "businessContext": "Minimum GPA threshold for Dean's List (e.g., 3.5)",
      "label_i18n": {
        "en": "Minimum GPA Requirement",
        "tr": "Minimum GPA Requirement",
        "de": "Minimum GPA Requirement",
        "fr": "Minimum GPA Requirement",
        "es": "Minimum GPA Requirement",
        "ar": "Minimum GPA Requirement"
      }
    },
    {
      "id": "minCredits",
      "label": "Minimum Credits Requirement",
      "type": "number",
      "unit": "credits",
      "default": 12,
      "businessContext": "Minimum number of earned credits required for Dean's List",
      "label_i18n": {
        "en": "Minimum Credits Requirement",
        "tr": "Minimum Credits Requirement",
        "de": "Minimum Credits Requirement",
        "fr": "Minimum Credits Requirement",
        "es": "Minimum Credits Requirement",
        "ar": "Minimum Credits Requirement"
      }
    }
  ],
  "formulas": {
    "meetsGpaRequirement": "gpa >= minGpa",
    "meetsCreditRequirement": "earnedCredits >= minCredits",
    "isEligible": "meetsGpaRequirement && meetsCreditRequirement",
    "gpaDifference": "gpa - minGpa",
    "creditDeficit": "minCredits - earnedCredits",
    "_GPA_requirement_not_met_": "'GPA requirement not met'",
    "_Credit_requirement_not_met_": "'Credit requirement not met'",
    "_GPA_below_minimum_by_____Math_abs_gpaDi": "'GPA below minimum by ' + Math.abs(gpaDifference).toFixed(2)",
    "____creditDeficit____No_credit_deficit_": "' + creditDeficit : 'No credit deficit'",
    "result": "isEligible ? 'Eligible for Dean\\'s List' : 'Not Eligible for Dean\\'s List'"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "meetsGpaRequirement ? 'GPA requirement met' : 'GPA requirement not met'",
      "meetsCreditRequirement ? 'Credit requirement met' : 'Credit requirement not met'",
      "gpaDifference >= 0 ? 'GPA above minimum by ' + gpaDifference.toFixed(2) : 'GPA below minimum by ' + Math.abs(gpaDifference).toFixed(2)",
      "creditDeficit > 0 ? 'Credit deficit: ' + creditDeficit : 'No credit deficit'"
    ]
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Sigorta",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance"
}

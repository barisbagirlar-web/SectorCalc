  "formulas": {
    "p1": "p01 * (1 + (gamma - 1) / 2 * mach ** 2) ** (-gamma / (gamma - 1))",
    "T1": "T01 * (1 + (gamma - 1) / 2 * mach ** 2) ** (-1)"
  },

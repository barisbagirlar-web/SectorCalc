{
  "toolName": "beehive-calculator",
  "inputs": [
    {
      "id": "hiveCount",
      "label": "Number of Hives",
      "type": "number",
      "unit": "adet",
      "default": 10,
      "businessContext": "Total number of active beehives in the apiary.",
      "label_i18n": {
        "en": "Number of Hives",
        "tr": "Number of Hives",
        "de": "Number of Hives",
        "fr": "Number of Hives",
        "es": "Number of Hives",
        "ar": "Number of Hives"
      }
    },
    {
      "id": "framesPerHive",
      "label": "Frames per Hive",
      "type": "number",
      "unit": "adet",
      "default": 10,
      "businessContext": "Number of frames per hive, typically 10 for Langstroth.",
      "label_i18n": {
        "en": "Frames per Hive",
        "tr": "Frames per Hive",
        "de": "Frames per Hive",
        "fr": "Frames per Hive",
        "es": "Frames per Hive",
        "ar": "Frames per Hive"
      }
    },
    {
      "id": "honeyPerFrame",
      "label": "Honey per Frame",
      "type": "number",
      "unit": "kg",
      "default": 2.5,
      "businessContext": "Average honey yield per fully capped frame.",
      "label_i18n": {
        "en": "Honey per Frame",
        "tr": "Honey per Frame",
        "de": "Honey per Frame",
        "fr": "Honey per Frame",
        "es": "Honey per Frame",
        "ar": "Honey per Frame"
      }
    },
    {
      "id": "extractionLoss",
      "label": "Extraction Loss",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of honey lost during extraction and filtering.",
      "label_i18n": {
        "en": "Extraction Loss",
        "tr": "Extraction Loss",
        "de": "Extraction Loss",
        "fr": "Extraction Loss",
        "es": "Extraction Loss",
        "ar": "Extraction Loss"
      }
    },
    {
      "id": "pricePerKg",
      "label": "Price per kg",
      "type": "number",
      "unit": "TL",
      "default": 150,
      "businessContext": "Selling price per kilogram of honey.",
      "label_i18n": {
        "en": "Price per kg",
        "tr": "Price per kg",
        "de": "Price per kg",
        "fr": "Price per kg",
        "es": "Price per kg",
        "ar": "Price per kg"
      }
    },
    {
      "id": "costPerHive",
      "label": "Cost per Hive",
      "type": "number",
      "unit": "TL",
      "default": 500,
      "businessContext": "Annual operational cost per hive (feed, maintenance, etc.).",
      "label_i18n": {
        "en": "Cost per Hive",
        "tr": "Cost per Hive",
        "de": "Cost per Hive",
        "fr": "Cost per Hive",
        "es": "Cost per Hive",
        "ar": "Cost per Hive"
      }
    }
  ],
  "formulas": {
    "grossHoney": "hiveCount * framesPerHive * honeyPerFrame",
    "netHoney": "grossHoney * (1 - extractionLoss / 100)",
    "revenue": "netHoney * pricePerKg",
    "totalCost": "hiveCount * costPerHive",
    "profit": "revenue - totalCost",
    "profitMargin": "(profit / revenue) * 100"
  },
  "outputs": {
    "primary": "netHoney",
    "breakdown": [
      "grossHoney",
      "revenue",
      "totalCost",
      "profit",
      "profitMargin"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitMargin"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Tarım & Hayvancılık",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "tarim",
  "profession": "Ziraat Mühendisi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

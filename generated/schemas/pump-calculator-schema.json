{
  "toolName": "pump-calculator",
  "inputs": [
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "m³/h",
      "default": 100,
      "businessContext": "The volumetric flow rate of the fluid through the pump.",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Flow Rate",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      }
    },
    {
      "id": "head",
      "label": "Total Head",
      "type": "number",
      "unit": "m",
      "default": 20,
      "businessContext": "The total dynamic head, i.e., the height to which the fluid is pumped.",
      "label_i18n": {
        "en": "Total Head",
        "tr": "Total Head",
        "de": "Total Head",
        "fr": "Total Head",
        "es": "Total Head",
        "ar": "Total Head"
      }
    },
    {
      "id": "density",
      "label": "Fluid Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "The mass density of the fluid. Default value is for water at 20°C.",
      "label_i18n": {
        "en": "Fluid Density",
        "tr": "Fluid Density",
        "de": "Fluid Density",
        "fr": "Fluid Density",
        "es": "Fluid Density",
        "ar": "Fluid Density"
      }
    },
    {
      "id": "pumpEfficiency",
      "label": "Pump Efficiency",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "The hydraulic efficiency of the pump (from manufacturer curve). Enter as percentage.",
      "label_i18n": {
        "en": "Pump Efficiency",
        "tr": "Pump Efficiency",
        "de": "Pump Efficiency",
        "fr": "Pump Efficiency",
        "es": "Pump Efficiency",
        "ar": "Pump Efficiency"
      }
    },
    {
      "id": "motorEfficiency",
      "label": "Motor Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "The efficiency of the electric motor driving the pump. Enter as percentage.",
      "label_i18n": {
        "en": "Motor Efficiency",
        "tr": "Motor Efficiency",
        "de": "Motor Efficiency",
        "fr": "Motor Efficiency",
        "es": "Motor Efficiency",
        "ar": "Motor Efficiency"
      }
    }
  ],
  "formulas": {
    "hydraulicPower": "flowRate / 3600 * head * density * 9.81 / 1000",
    "shaftPower": "flowRate / 3600 * head * density * 9.81 / 1000 / (pumpEfficiency / 100)",
    "motorPower": "flowRate / 3600 * head * density * 9.81 / 1000 / (pumpEfficiency / 100) / (motorEfficiency / 100)"
  },
  "outputs": {
    "primary": "motorPower",
    "breakdown": [
      "hydraulicPower",
      "shaftPower"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "motorPower"
  },
  "category": "Teknik & Mühendislik",
  "sector": "Fizik & Mekanik",
  "premiumRequired": false,

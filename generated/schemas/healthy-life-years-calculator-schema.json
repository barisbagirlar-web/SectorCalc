{
  "toolName": "healthy-life-years-calculator",
  "inputs": [
    {
      "id": "life_expectancy",
      "label": "Life Expectancy at Birth (years)",
      "type": "number",
      "unit": "years",
      "default": 73,
      "businessContext": "Total expected years of life from birth based on current mortality rates.",
      "label_i18n": {
        "en": "Life Expectancy at Birth (years)",
        "tr": "Life Expectancy at Birth (years)",
        "de": "Life Expectancy at Birth (years)",
        "fr": "Life Expectancy at Birth (years)",
        "es": "Life Expectancy at Birth (years)",
        "ar": "Life Expectancy at Birth (years)"
      }
    },
    {
      "id": "severe_prevalence",
      "label": "Prevalence of Severe Activity Limitation",
      "type": "number",
      "unit": "proportion",
      "default": 0.1,
      "businessContext": "Proportion of population with severe long-standing activity limitation, expressed as a decimal (0-1).",
      "label_i18n": {
        "en": "Prevalence of Severe Activity Limitation",
        "tr": "Prevalence of Severe Activity Limitation",
        "de": "Prevalence of Severe Activity Limitation",
        "fr": "Prevalence of Severe Activity Limitation",
        "es": "Prevalence of Severe Activity Limitation",
        "ar": "Prevalence of Severe Activity Limitation"
      }
    },
    {
      "id": "moderate_prevalence",
      "label": "Prevalence of Moderate Activity Limitation",
      "type": "number",
      "unit": "proportion",
      "default": 0.15,
      "businessContext": "Proportion of population with moderate activity limitation, expressed as a decimal (0-1).",
      "label_i18n": {
        "en": "Prevalence of Moderate Activity Limitation",
        "tr": "Prevalence of Moderate Activity Limitation",
        "de": "Prevalence of Moderate Activity Limitation",
        "fr": "Prevalence of Moderate Activity Limitation",
        "es": "Prevalence of Moderate Activity Limitation",
        "ar": "Prevalence of Moderate Activity Limitation"
      }
    },
    {
      "id": "severe_weight",
      "label": "Disability Weight for Severe Limitation",
      "type": "number",
      "unit": "factor",
      "default": 0.7,
      "businessContext": "Health loss weight for severe state (0 = full health, 1 = worst possible health).",
      "label_i18n": {
        "en": "Disability Weight for Severe Limitation",
        "tr": "Disability Weight for Severe Limitation",
        "de": "Disability Weight for Severe Limitation",
        "fr": "Disability Weight for Severe Limitation",
        "es": "Disability Weight for Severe Limitation",
        "ar": "Disability Weight for Severe Limitation"
      }
    },
    {
      "id": "moderate_weight",
      "label": "Disability Weight for Moderate Limitation",
      "type": "number",
      "unit": "factor",
      "default": 0.3,
      "businessContext": "Health loss weight for moderate state (0 = full health, 1 = worst possible health).",
      "label_i18n": {
        "en": "Disability Weight for Moderate Limitation",
        "tr": "Disability Weight for Moderate Limitation",
        "de": "Disability Weight for Moderate Limitation",
        "fr": "Disability Weight for Moderate Limitation",
        "es": "Disability Weight for Moderate Limitation",
        "ar": "Disability Weight for Moderate Limitation"
      }
    }
  ],
  "formulas": {
    "healthy_life_years": "life_expectancy * (1 - (severe_prevalence * severe_weight + moderate_prevalence * moderate_weight))",
    "total_life_expectancy": "life_expectancy",
    "unhealthy_years": "life_expectancy * (severe_prevalence * severe_weight + moderate_prevalence * moderate_weight)"
  },
  "outputs": {
    "primary": "healthy_life_years",
    "breakdown": [
      "total_life_expectancy",
      "unhealthy_years"
    ],

{
  "toolName": "stair-rise-run-calculator",
  "inputs": [
    {
      "id": "totalRise",
      "label": "Total Rise (Floor-to-Floor Height)",
      "type": "number",
      "unit": "mm",
      "default": 2800,
      "businessContext": "The total vertical height between finished floor levels.",
      "label_i18n": {
        "en": "Total Rise (Floor-to-Floor Height)",
        "tr": "Total Rise (Floor-to-Floor Height)",
        "de": "Total Rise (Floor-to-Floor Height)",
        "fr": "Total Rise (Floor-to-Floor Height)",
        "es": "Total Rise (Floor-to-Floor Height)",
        "ar": "Total Rise (Floor-to-Floor Height)"
      }
    },
    {
      "id": "totalRun",
      "label": "Total Run Available",
      "type": "number",
      "unit": "mm",
      "default": 3500,
      "businessContext": "The total horizontal distance available for the staircase.",
      "label_i18n": {
        "en": "Total Run Available",
        "tr": "Total Run Available",
        "de": "Total Run Available",
        "fr": "Total Run Available",
        "es": "Total Run Available",
        "ar": "Total Run Available"
      }
    },
    {
      "id": "maxRiserHeight",
      "label": "Maximum Riser Height (Code)",
      "type": "number",
      "unit": "mm",
      "default": 190,
      "businessContext": "The maximum allowed riser height as per local building regulations.",
      "label_i18n": {
        "en": "Maximum Riser Height (Code)",
        "tr": "Maximum Riser Height (Code)",
        "de": "Maximum Riser Height (Code)",
        "fr": "Maximum Riser Height (Code)",
        "es": "Maximum Riser Height (Code)",
        "ar": "Maximum Riser Height (Code)"
      }
    },
    {
      "id": "minTreadDepth",
      "label": "Minimum Tread Depth (Code)",
      "type": "number",
      "unit": "mm",
      "default": 250,
      "businessContext": "The minimum required tread depth (going) as per local building regulations.",
      "label_i18n": {
        "en": "Minimum Tread Depth (Code)",
        "tr": "Minimum Tread Depth (Code)",
        "de": "Minimum Tread Depth (Code)",
        "fr": "Minimum Tread Depth (Code)",
        "es": "Minimum Tread Depth (Code)",
        "ar": "Minimum Tread Depth (Code)"
      }
    },
    {
      "id": "desiredRise",
      "label": "Desired Riser Height",
      "type": "number",
      "unit": "mm",
      "default": 175,
      "businessContext": "The preferred riser height for comfort, typically between 150-190 mm.",
      "label_i18n": {
        "en": "Desired Riser Height",
        "tr": "Desired Riser Height",
        "de": "Desired Riser Height",
        "fr": "Desired Riser Height",
        "es": "Desired Riser Height",
        "ar": "Desired Riser Height"
      }
    },
    {
      "id": "nosing",
      "label": "Nosing Overhang",
      "type": "number",
      "unit": "mm",
      "default": 25,
      "businessContext": "The distance the tread extends beyond the riser face. Used for precise tread dimensioning.",
      "label_i18n": {
        "en": "Nosing Overhang",
        "tr": "Nosing Overhang",
        "de": "Nosing Overhang",
        "fr": "Nosing Overhang",
        "es": "Nosing Overhang",
        "ar": "Nosing Overhang"
      }
    }
  ],
  "formulas": {
    "numSteps": "Math.ceil(totalRise / desiredRise)",
    "actualRiser": "totalRise / numSteps",
    "treadDepth": "totalRun / (numSteps - 1)",
    "primaryOutput": "'Rise: ' + actualRiser.toFixed(1) + ' mm, Tread: ' + treadDepth.toFixed(1) + ' mm, Steps: ' + numSteps",
    "breakdown_0": "'Rise per step: ' + actualRiser.toFixed(1) + ' mm'",
    "breakdown_1": "'Tread depth: ' + treadDepth.toFixed(1) + ' mm'",
    "breakdown_2": "'Number of risers: ' + numSteps",
    "breakdown_3": "'Number of treads: ' + (numSteps - 1)",
    "breakdown_4": "'Stair angle: ' + (Math.atan(totalRise / totalRun) * 180 / Math.PI).toFixed(2) + '°'"
  },
  "outputs": {
    "primary": "primaryOutput",
    "breakdown": [
      "breakdown_0",
      "breakdown_1",
      "breakdown_2",
      "breakdown_3",
      "breakdown_4"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",

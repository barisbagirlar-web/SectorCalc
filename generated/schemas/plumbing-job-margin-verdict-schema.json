{
  "toolName": "plumbing-job-margin-verdict",
  "inputs": [
    {
      "id": "jobRevenue",
      "label": "Job Revenue",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total revenue from the plumbing job. Based on contract value."
    },
    {
      "id": "materialCost",
      "label": "Material Cost",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Cost of materials used in the job. Includes pipes, fittings, fixtures."
    },
    {
      "id": "laborHours",
      "label": "Labor Hours",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total labor hours spent on the job."
    },
    {
      "id": "hourlyRate",
      "label": "Hourly Labor Rate",
      "type": "number",
      "unit": "USD/hour",
      "default": 50,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Average hourly wage including burden. Industry standard."
    },
    {
      "id": "overheadRate",
      "label": "Overhead Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Percentage of direct costs allocated to overhead. Based on company accounting."
    },
    {
      "id": "equipmentCost",
      "label": "Equipment Cost",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Cost of equipment rental or depreciation for the job."
    },
    {
      "id": "subcontractorCost",
      "label": "Subcontractor Cost",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Cost of any subcontractors used."
    },
    {
      "id": "warrantyReserve",
      "label": "Warranty Reserve",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Reserve for potential warranty claims. Typically 2-5% of revenue."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence",
      "type": "select",
      "unit": "",
      "default": "medium",
      "min": null,
      "max": null,
      "options": [
        "low",
        "medium",
        "high"
      ],
      "businessContext": "Confidence level in input data accuracy. Affects adjusted margin."
    }
  ],
  "validation": {
    "rules": [
      "jobRevenue must be >= 0",
      "materialCost must be >= 0",
      "laborHours must be >= 0",
      "hourlyRate must be > 0",
      "overheadRate must be between 0 and 100",
      "equipmentCost must be >= 0",
      "subcontractorCost must be >= 0",
      "warrantyReserve must be >= 0"
    ],
    "thresholds": {
      "marginPercent": {
        "critical": 0,
        "warning": 10
      }
    }
  },
  "formulas": {
    "directLaborCost": "laborHours * hourlyRate",
    "totalDirectCost": "materialCost + directLaborCost + equipmentCost + subcontractorCost",
    "overheadCost": "totalDirectCost * (overheadRate / 100)",
    "totalCost": "totalDirectCost + overheadCost + warrantyReserve",
    "grossProfit": "jobRevenue - totalCost",
    "marginPercent": "jobRevenue > 0 ? (grossProfit / jobRevenue) * 100 : 0",
    "dataConfidenceAdjustedMargin": "dataConfidence == 'high' ? marginPercent : (dataConfidence == 'medium' ? marginPercent * 0.95 : marginPercent * 0.9)"
  },
  "outputs": {
    "primary": "marginPercent",
    "breakdown": {
      "totalCost": "totalCost",
      "directLaborCost": "directLaborCost",
      "overheadCost": "overheadCost",
      "grossProfit": "grossProfit"
    },
    "hiddenLossDrivers": [
      "marginPercent < 0 ? 'Negative margin: job is unprofitable' : ''",
      "marginPercent < 10 ? 'Margin below 10%: consider cost reduction' : ''"
    ],
    "suggestedActions": [
      "marginPercent < 0 ? 'Renegotiate price or reduce costs immediately' : ''",
      "marginPercent < 10 ? 'Review material sourcing and labor efficiency' : ''",
      "overheadRate > 30 ? 'Investigate overhead allocation' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjustedMargin"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Benchmark Comparison",
    "Detailed Report"
  ],
  "premiumRequired": true
}

      }
    },
    {
      "id": "decimals",
      "label": "Decimal places",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Number of decimal places for output",
      "label_i18n": {
        "en": "Decimal places",
        "tr": "Decimal places",
        "de": "Decimal places",
        "fr": "Decimal places",
        "es": "Decimal places",
        "ar": "Decimal places"
      }
    }
  ],
  "formulas": {
    "thetaRad": "(angleUnit === 1) ? theta * Math.PI / 180 : theta",
    "nTheta": "n * thetaRad",
    "cosNTheta": "Math.cos(nTheta)",
    "sinNTheta": "Math.sin(nTheta)",
    "power": "Math.pow(r, n)",
    "real": "Math.round(power * cosNTheta * Math.pow(10, decimals)) / Math.pow(10, decimals)",
    "imag": "Math.round(power * sinNTheta * Math.pow(10, decimals)) / Math.pow(10, decimals)",
    "result": "real + ' + i' + imag"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "thetaRad",
      "power",
      "nTheta",
      "cosNTheta",
      "sinNTheta",
      "real",
      "imag"
    ]
  },

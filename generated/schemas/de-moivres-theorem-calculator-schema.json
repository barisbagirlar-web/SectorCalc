      }
    },
    {
      "id": "n",
      "label": "Exponent (n)",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Power to which the complex number is raised",
      "label_i18n": {
        "en": "Exponent (n)",
        "tr": "Exponent (n)",
        "de": "Exponent (n)",
        "fr": "Exponent (n)",
        "es": "Exponent (n)",

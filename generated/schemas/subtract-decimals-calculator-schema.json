      "id": "valueB",
      "label": "Second Number (Subtrahend)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "The value to be subtracted from the first number.",
      "label_i18n": {
        "en": "Second Number (Subtrahend)",
        "tr": "Second Number (Subtrahend)",
        "de": "Second Number (Subtrahend)",
        "fr": "Second Number (Subtrahend)",
        "es": "Second Number (Subtrahend)",
        "ar": "Second Number (Subtrahend)"
      }
    },
    {
      "id": "precision",
      "label": "Rounding Precision",
      "type": "number",
      "unit": "decimal places",
      "default": 2,
      "businessContext": "Number of decimal places to round the intermediate difference for final output.",
      "label_i18n": {
        "en": "Rounding Precision",
        "tr": "Rounding Precision",
        "de": "Rounding Precision",
        "fr": "Rounding Precision",
        "es": "Rounding Precision",
        "ar": "Rounding Precision"
      }
    },
    {
      "id": "offset",
      "label": "Offset",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "A constant added to the rounded difference (e.g., calibration or zero-offset).",
      "label_i18n": {
        "en": "Offset",
        "tr": "Offset",
        "de": "Offset",
        "fr": "Offset",
        "es": "Offset",
        "ar": "Offset"
      }
    }
  ],
  "formulas": {
    "rawDifference": "valueA - valueB",
    "roundedDifference": "Math.round((valueA - valueB) * Math.pow(10, precision)) / Math.pow(10, precision)",
    "finalResult": "Math.round((valueA - valueB) * Math.pow(10, precision)) / Math.pow(10, precision) + offset"
  },
  "outputs": {
    "primary": "finalResult",
    "breakdown": [
      "rawDifference",
      "roundedDifference"
    ]
  },

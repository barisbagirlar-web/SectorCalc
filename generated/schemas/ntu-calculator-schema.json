{
  "toolName": "ntu-calculator",
  "inputs": [
    {
      "id": "ntus_value",
      "label": "NTU Değeri",
      "type": "number",
      "unit": "NTU",
      "default": 15,
      "businessContext": "Ölçülen bulanıklık değeri (NTU cinsinden).",
      "label_i18n": {
        "en": "NTU Değeri",
        "tr": "NTU Değeri",
        "de": "NTU Değeri",
        "fr": "NTU Değeri",
        "es": "NTU Değeri",
        "ar": "NTU Değeri"
      }
    },
    {
      "id": "slope_a",
      "label": "Eğim Katsayısı (a)",
      "type": "number",
      "unit": "mg/L/NTU",
      "default": 2.1,
      "businessContext": "Sahaya özgü kalibrasyon eğimi. TSS = a × NTU + b",
      "label_i18n": {
        "en": "Eğim Katsayısı (a)",
        "tr": "Eğim Katsayısı (a)",
        "de": "Eğim Katsayısı (a)",
        "fr": "Eğim Katsayısı (a)",
        "es": "Eğim Katsayısı (a)",
        "ar": "Eğim Katsayısı (a)"
      }
    },
    {
      "id": "intercept_b",
      "label": "Kesişim Sabiti (b)",
      "type": "number",
      "unit": "mg/L",
      "default": 3.2,
      "businessContext": "Sahaya özgü kalibrasyon kesişim değeri.",
      "label_i18n": {
        "en": "Kesişim Sabiti (b)",
        "tr": "Kesişim Sabiti (b)",
        "de": "Kesişim Sabiti (b)",
        "fr": "Kesişim Sabiti (b)",
        "es": "Kesişim Sabiti (b)",
        "ar": "Kesişim Sabiti (b)"
      }
    },
    {
      "id": "dilution_factor",
      "label": "Seyreltme Faktörü",
      "type": "number",
      "unit": "birimsiz",
      "default": 1,
      "businessContext": "Numune seyreltildiyse seyreltme oranı. Seyreltme yoksa 1.",
      "label_i18n": {
        "en": "Seyreltme Faktörü",
        "tr": "Seyreltme Faktörü",
        "de": "Seyreltme Faktörü",
        "fr": "Seyreltme Faktörü",
        "es": "Seyreltme Faktörü",
        "ar": "Seyreltme Faktörü"
      }
    }
  ],
  "formulas": {
    "tss": "(slope_a * ntus_value + intercept_b) * dilution_factor",
    "TSS____slope_a____NTU____intercept_b_": "TSS = {slope_a} × NTU + {intercept_b}",
    "_ntus_value__NTU": "{ntus_value} NTU",
    "_dilution_factor_": "{dilution_factor}",
    "_tss__mg_L": "{tss} mg/L",
    "result": "TSS: {tss} mg/L"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Kalibrasyon denklemi: TSS = {slope_a} × NTU + {intercept_b}",
      "Giriş NTU: {ntus_value} NTU",
      "Seyreltme Faktörü: {dilution_factor}",
      "Hesaplanan TSS (seyreltme dahil): {tss} mg/L"
    ]
  },

      "label": "Pozisyon Hatası Düzeltme Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Pitot-statik sistem pozisyon hatası için düzeltme katsayısı, genellikle 1.0 alınır",
      "label_i18n": {
        "en": "Pozisyon Hatası Düzeltme Faktörü",
        "tr": "Pozisyon Hatası Düzeltme Faktörü",
        "de": "Pozisyon Hatası Düzeltme Faktörü",
        "fr": "Pozisyon Hatası Düzeltme Faktörü",
        "es": "Pozisyon Hatası Düzeltme Faktörü",
        "ar": "Pozisyon Hatası Düzeltme Faktörü"
      }
    }
  ],
  "formulas": {
    "dynamicPressure": "pitotPressure - staticPressure",
    "rawSpeedMS": "Math.sqrt(2 * dynamicPressure / airDensity)",
    "correctedSpeedMS": "rawSpeedMS * positionErrorCorrection",
    "correctedSpeedKnots": "correctedSpeedMS * 1.94384"
  },
  "outputs": {
    "primary": "correctedSpeedKnots",
    "breakdown": [
      "rawSpeedMS",
      "correctedSpeedMS",
      "dynamicPressure"
    ]
  },

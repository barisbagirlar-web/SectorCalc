{
  "toolName": "brine-calculator",
  "inputs": [
    {
      "id": "saltMass",
      "label": "Salt Mass",
      "type": "number",
      "unit": "kg",
      "default": 10,
      "businessContext": "Mass of salt added to brine"
    },
    {
      "id": "waterMass",
      "label": "Water Mass",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Mass of water for brine solution"
    },
    {
      "id": "saltPurity",
      "label": "Salt Purity",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Purity of salt used (0-100)"
    },
    {
      "id": "temp",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Operating temperature for density correction"
    }
  ],
  "formulas": {
    "concentration": "(saltMass * saltPurity / 100) / ((saltMass * saltPurity / 100) + waterMass) * 100",
    "density": "(0.9997 + 0.0078 * ((saltMass * saltPurity / 100) / ((saltMass * saltPurity / 100) + waterMass) * 100)) * (1 - 0.0002 * (temp - 20))",
    "freezingPoint": "- (2 * 1.86 * ((saltMass * saltPurity / 100) * 1000 / 58.44) / waterMass)"
  },
  "outputs": {
    "primary": "concentration",
    "breakdown": [
      "density",
      "freezingPoint"
    ]
  },
  "category": "Çevre & Emisyon",
  "sector": "Sürdürülebilirlik",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "sustainability-resource-esg"
}

  "formulas": {
    "concentration": "(saltMass * saltPurity / 100) / ((saltMass * saltPurity / 100) + waterMass) * 100",
    "density": "(0.9997 + 0.0078 * ((saltMass * saltPurity / 100) / ((saltMass * saltPurity / 100) + waterMass) * 100)) * (1 - 0.0002 * (temp - 20))",
    "freezingPoint": "- (2 * 1.86 * ((saltMass * saltPurity / 100) * 1000 / 58.44) / waterMass)"
  },
  "outputs": {
    "primary": "concentration",
    "breakdown": [

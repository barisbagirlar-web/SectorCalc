  "formulas": {
    "ToolCostPerPart": "(InsertCost / Edges) * (MachiningTime / ToolLife)",
    "ChangeCostPerPart": "(ToolChangeTime * MachineRate) * (MachiningTime / ToolLife)",
    "TotalToolingCost": "ToolCostPerPart + ChangeCostPerPart",
    "WearRate": "FlankWear / MachiningTime",
    "OptimalToolLife": "((1/n - 1) * (ToolChangeTime + InsertCost/Edges / MachineRate))",
    "CostOfPrematureFailure": "(ExpectedLife - ActualLife) / ExpectedLife * InsertCost"
  },

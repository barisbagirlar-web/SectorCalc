{
  "toolName": "uberman-sleep-calculator",
  "inputs": [
    {
      "id": "napDuration",
      "label": "Nap Duration (min)",
      "type": "number",
      "unit": "min",
      "default": 20,
      "businessContext": "Typical nap length in the Uberman cycle is 20 minutes. Adjust for personal adaptation.",
      "label_i18n": {
        "en": "Nap Duration (min)",
        "tr": "Nap Duration (min)",
        "de": "Nap Duration (min)",
        "fr": "Nap Duration (min)",
        "es": "Nap Duration (min)",
        "ar": "Nap Duration (min)"
      }
    },
    {
      "id": "intervalBetweenNaps",
      "label": "Interval Between Naps (h)",
      "type": "number",
      "unit": "h",
      "default": 4,
      "businessContext": "The awake time between consecutive naps, in hours. Standard Uberman schedule uses 4-hour intervals.",
      "label_i18n": {
        "en": "Interval Between Naps (h)",
        "tr": "Interval Between Naps (h)",
        "de": "Interval Between Naps (h)",
        "fr": "Interval Between Naps (h)",
        "es": "Interval Between Naps (h)",
        "ar": "Interval Between Naps (h)"
      }
    },
    {
      "id": "numberOfNaps",
      "label": "Number of Naps per Day",
      "type": "number",
      "unit": "count",
      "default": 6,
      "businessContext": "Total number of naps taken in a 24-hour period. Standard Uberman schedule includes 6 naps per day.",
      "label_i18n": {
        "en": "Number of Naps per Day",
        "tr": "Number of Naps per Day",
        "de": "Number of Naps per Day",
        "fr": "Number of Naps per Day",
        "es": "Number of Naps per Day",
        "ar": "Number of Naps per Day"
      }
    },
    {
      "id": "startHour",
      "label": "Start Hour (24h)",
      "type": "number",
      "unit": "h",
      "default": 0,
      "businessContext": "The starting hour of the first nap in decimal format (e.g., 8.5 for 8:30 AM).",
      "label_i18n": {
        "en": "Start Hour (24h)",
        "tr": "Start Hour (24h)",
        "de": "Start Hour (24h)",
        "fr": "Start Hour (24h)",
        "es": "Start Hour (24h)",
        "ar": "Start Hour (24h)"
      }
    }
  ],
  "formulas": {
    "totalSleep": "napDuration * numberOfNaps / 60",
    "totalSchedule": "(napDuration / 60 + intervalBetweenNaps) * numberOfNaps",
    "freeTime": "24 - ((napDuration / 60 + intervalBetweenNaps) * numberOfNaps)",
    "lastNapEnd": "(startHour + (napDuration / 60 + intervalBetweenNaps) * numberOfNaps) % 24"
  },
  "outputs": {
    "primary": "totalSleep",
    "breakdown": [
      "totalSchedule",
      "freeTime",
      "lastNapEnd"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "lastNapEnd"
  },
  "category": "Diğer",
  "sector": "Sağlık & Tıp",
  "premiumRequired": false,

  "formulas": {
    "conversionFactor": "ounceStandard === 0 ? 29.5735 : 28.4131",
    "mlPerItem": "fluidOunces * conversionFactor",
    "totalMl": "batchSize * mlPerItem"
  },
  "outputs": {

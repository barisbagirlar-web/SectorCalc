{
  "toolName": "discounted-payback-period-calculator",
  "inputs": [
    {
      "id": "initialInvestment",
      "label": "Initial Investment",
      "type": "number",
      "unit": "$",
      "default": 10000,
      "businessContext": "Total upfront capital expenditure for the project",
      "label_i18n": {
        "en": "Initial Investment",
        "tr": "Initial Investment",
        "de": "Initial Investment",
        "fr": "Initial Investment",
        "es": "Initial Investment",
        "ar": "Initial Investment"
      }
    },
    {
      "id": "discountRate",
      "label": "Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Annual discount rate reflecting cost of capital or required return",
      "label_i18n": {
        "en": "Discount Rate",
        "tr": "Discount Rate",
        "de": "Discount Rate",
        "fr": "Discount Rate",
        "es": "Discount Rate",
        "ar": "Discount Rate"
      }
    },
    {
      "id": "annualCashFlow",
      "label": "Annual Cash Flow",
      "type": "number",
      "unit": "$",
      "default": 3000,
      "businessContext": "Expected constant annual net cash inflow from the project",
      "label_i18n": {
        "en": "Annual Cash Flow",
        "tr": "Annual Cash Flow",
        "de": "Annual Cash Flow",
        "fr": "Annual Cash Flow",
        "es": "Annual Cash Flow",
        "ar": "Annual Cash Flow"
      }
    },
    {
      "id": "maxYears",
      "label": "Maximum Evaluation Period",
      "type": "number",
      "unit": "years",
      "default": 50,
      "businessContext": "Maximum number of years to consider for payback; beyond this, payback is not achieved",
      "label_i18n": {
        "en": "Maximum Evaluation Period",
        "tr": "Maximum Evaluation Period",
        "de": "Maximum Evaluation Period",
        "fr": "Maximum Evaluation Period",
        "es": "Maximum Evaluation Period",
        "ar": "Maximum Evaluation Period"
      }
    }
  ],
  "formulas": {
    "discountRateDecimal": "discountRate / 100",
    "paybackFactor": "1 - (initialInvestment * discountRateDecimal / annualCashFlow)",
    "paybackPeriod": "paybackFactor > 0 && annualCashFlow > 0 ? -Math.log(paybackFactor) / Math.log(1 + discountRateDecimal) : maxYears",
    "cumulativePVatPayback": "annualCashFlow * (1 - Math.pow(1 + discountRateDecimal, -paybackPeriod)) / discountRateDecimal",
    "totalDiscountedCashFlows": "annualCashFlow * (1 - Math.pow(1 + discountRateDecimal, -maxYears)) / discountRateDecimal"
  },
  "outputs": {
    "primary": "paybackPeriod",
    "breakdown": [
      "paybackPeriod",
      "cumulativePVatPayback",
      "totalDiscountedCashFlows",
      "initialInvestment",
      "discountRate",
      "annualCashFlow"
    ]
  },
  "category": "Proje & Yatırım",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance"
}

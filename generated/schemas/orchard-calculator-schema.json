      }
    },
    {
      "id": "yieldPerTree",
      "label": "Yield Per Tree",
      "type": "number",
      "unit": "kg/tree/year",
      "default": 50,
      "businessContext": "Average fruit yield per mature tree per year",
      "label_i18n": {
        "en": "Yield Per Tree",
        "tr": "Yield Per Tree",
        "de": "Yield Per Tree",

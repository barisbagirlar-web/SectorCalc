      }
    },
    {
      "id": "pricePerKg",
      "label": "Selling Price",
      "type": "number",
      "unit": "$/kg",
      "default": 2,
      "businessContext": "Farmgate price per kilogram",
      "label_i18n": {
        "en": "Selling Price",
        "tr": "Selling Price",
        "de": "Selling Price",
        "fr": "Selling Price",
        "es": "Selling Price",
        "ar": "Selling Price"
      }
    },
    {
      "id": "annualCostPerTree",
      "label": "Maintenance Cost",
      "type": "number",
      "unit": "$/tree/year",
      "default": 15,
      "businessContext": "Annual cost for pruning, spraying, fertilizing per tree",
      "label_i18n": {
        "en": "Maintenance Cost",
        "tr": "Maintenance Cost",
        "de": "Maintenance Cost",
        "fr": "Maintenance Cost",
        "es": "Maintenance Cost",
        "ar": "Maintenance Cost"
      }
    },
    {
      "id": "initialInvestment",
      "label": "Initial Investment",
      "type": "number",
      "unit": "$",
      "default": 50000,
      "businessContext": "Total one-time cost for land prep, seedlings, infrastructure",
      "label_i18n": {
        "en": "Initial Investment",
        "tr": "Initial Investment",
        "de": "Initial Investment",
        "fr": "Initial Investment",
        "es": "Initial Investment",
        "ar": "Initial Investment"
      }
    }
  ],
  "formulas": {
    "treesPerHa": "10000 / (rowSpacing * treeSpacing)",
    "totalTrees": "area * treesPerHa",
    "totalYield": "totalTrees * yieldPerTree",
    "totalRevenue": "totalYield * pricePerKg",
    "annualCost": "totalTrees * annualCostPerTree",
    "annualProfit": "totalRevenue - annualCost",
    "paybackPeriod": "initialInvestment / annualProfit"
  },
  "outputs": {
    "primary": "annualProfit",
    "breakdown": [
      "totalTrees",
      "totalYield",
      "totalRevenue",
      "annualCost",
      "paybackPeriod"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "paybackPeriod",
    "unit": "ha"
  },

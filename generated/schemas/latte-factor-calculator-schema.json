{
  "toolName": "latte-factor-calculator",
  "inputs": [
    {
      "id": "dailyExpense",
      "label": "Daily Expense Amount",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "The amount you spend daily on the item you're eliminating",
      "label_i18n": {
        "en": "Daily Expense Amount",
        "tr": "Daily Expense Amount",
        "de": "Daily Expense Amount",
        "fr": "Daily Expense Amount",
        "es": "Daily Expense Amount",
        "ar": "Daily Expense Amount"
      }
    },
    {
      "id": "daysPerWeek",
      "label": "Days per Week",
      "type": "number",
      "unit": "days/week",
      "default": 5,
      "businessContext": "Number of days per week you make this purchase",
      "label_i18n": {
        "en": "Days per Week",
        "tr": "Days per Week",
        "de": "Days per Week",
        "fr": "Days per Week",
        "es": "Days per Week",
        "ar": "Days per Week"
      }
    },
    {
      "id": "years",
      "label": "Investment Horizon",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Number of years you plan to invest the saved money",
      "label_i18n": {
        "en": "Investment Horizon",
        "tr": "Investment Horizon",
        "de": "Investment Horizon",
        "fr": "Investment Horizon",
        "es": "Investment Horizon",
        "ar": "Investment Horizon"
      }
    },
    {
      "id": "annualReturnRate",
      "label": "Expected Annual Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual return rate on investment (e.g., 7 for 7%)",
      "label_i18n": {
        "en": "Expected Annual Return",
        "tr": "Expected Annual Return",
        "de": "Expected Annual Return",
        "fr": "Expected Annual Return",
        "es": "Expected Annual Return",
        "ar": "Expected Annual Return"
      }
    }
  ],
  "formulas": {
    "annualContribution": "dailyExpense * daysPerWeek * 52",
    "totalContributions": "annualContribution * years",
    "futureValue": "annualContribution * ((1 + (annualReturnRate/100))**years - 1) / (annualReturnRate/100)",
    "interestEarned": "futureValue - totalContributions"
  },
  "outputs": {
    "primary": "futureValue",
    "breakdown": [
      "annualContribution",
      "totalContributions",
      "interestEarned"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "interestEarned",
    "unit": "currency"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

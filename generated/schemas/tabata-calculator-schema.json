{
  "toolName": "tabata-calculator",
  "inputs": [
    {
      "id": "workDuration",
      "label": "Work Interval (s)",
      "type": "number",
      "unit": "seconds",
      "default": 20,
      "businessContext": "Duration of high-intensity work interval"
    },
    {
      "id": "restDuration",
      "label": "Rest Interval (s)",
      "type": "number",
      "unit": "seconds",
      "default": 10,
      "businessContext": "Duration of rest interval between work intervals"
    },
    {
      "id": "rounds",
      "label": "Number of Rounds",
      "type": "number",
      "unit": "",
      "default": 8,
      "businessContext": "Number of work-rest cycles"
    },
    {
      "id": "preparationTime",
      "label": "Preparation Time (s)",
      "type": "number",
      "unit": "seconds",
      "default": 0,
      "businessContext": "Time allocated before the first work interval"
    },
    {
      "id": "coolDownTime",
      "label": "Cool Down Time (s)",
      "type": "number",
      "unit": "seconds",
      "default": 0,
      "businessContext": "Time allocated after the last rest interval"
    }
  ],
  "formulas": {
    "totalWorkTime": "workDuration * rounds",
    "totalRestTime": "restDuration * rounds",
    "totalWorkoutTime": "preparationTime + coolDownTime + rounds * (workDuration + restDuration)"
  },
  "outputs": {
    "primary": "totalWorkoutTime",
    "breakdown": [
      "totalWorkTime",
      "totalRestTime"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
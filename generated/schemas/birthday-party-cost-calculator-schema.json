      "label_i18n": {
        "en": "Cost per Drink",
        "tr": "Cost per Drink",
        "de": "Cost per Drink",
        "fr": "Cost per Drink",
        "es": "Cost per Drink",
        "ar": "Cost per Drink"
      }
    },
    {
      "id": "cakeCost",
      "label": "Cake Cost",
      "type": "number",
      "unit": "EUR",
      "default": 50,
      "businessContext": "Total cost of the birthday cake, including any custom decorations.",
      "label_i18n": {
        "en": "Cake Cost",
        "tr": "Cake Cost",
        "de": "Cake Cost",
        "fr": "Cake Cost",
        "es": "Cake Cost",
        "ar": "Cake Cost"
      }
    },
    {
      "id": "decorationCost",
      "label": "Decoration Cost",
      "type": "number",
      "unit": "EUR",
      "default": 30,
      "businessContext": "Cost of balloons, banners, tableware, and other decorative items.",
      "label_i18n": {
        "en": "Decoration Cost",
        "tr": "Decoration Cost",
        "de": "Decoration Cost",
        "fr": "Decoration Cost",
        "es": "Decoration Cost",
        "ar": "Decoration Cost"
      }
    },
    {
      "id": "venueRentalCost",
      "label": "Venue Rental Cost",
      "type": "number",
      "unit": "EUR",
      "default": 100,
      "businessContext": "Flat fee for renting the party venue (if applicable).",
      "label_i18n": {
        "en": "Venue Rental Cost",
        "tr": "Venue Rental Cost",
        "de": "Venue Rental Cost",
        "fr": "Venue Rental Cost",
        "es": "Venue Rental Cost",
        "ar": "Venue Rental Cost"
      }
    }
  ],
  "formulas": {
    "totalFoodCost": "numGuests * costPerPlate",
    "totalDrinkCost": "numGuests * numDrinksPerGuest * costPerDrink",
    "totalPartyCost": "totalFoodCost + totalDrinkCost + cakeCost + decorationCost + venueRentalCost",
    "costPerGuest": "totalPartyCost / numGuests"
  },
  "outputs": {
    "primary": "costPerGuest",
    "breakdown": [
      "totalPartyCost",
      "totalFoodCost",
      "totalDrinkCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

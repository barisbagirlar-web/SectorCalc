{
  "toolName": "birthday-party-cost-calculator",
  "inputs": [
    {
      "id": "numGuests",
      "label": "Number of Guests",
      "type": "number",
      "unit": "guests",
      "default": 10,
      "businessContext": "Expected number of attendees at the birthday party.",
      "label_i18n": {

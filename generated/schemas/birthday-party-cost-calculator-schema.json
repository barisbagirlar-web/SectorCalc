      "label": "Cost per Plate (Food)",
      "type": "number",
      "unit": "EUR",
      "default": 15,
      "businessContext": "Catering cost per guest for food, including main course and sides.",
      "label_i18n": {
        "en": "Cost per Plate (Food)",
        "tr": "Cost per Plate (Food)",
        "de": "Cost per Plate (Food)",
        "fr": "Cost per Plate (Food)",
        "es": "Cost per Plate (Food)",
        "ar": "Cost per Plate (Food)"
      }
    },
    {
      "id": "numDrinksPerGuest",
      "label": "Number of Drinks per Guest",
      "type": "number",
      "unit": "drinks/guest",

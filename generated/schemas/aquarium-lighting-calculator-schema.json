{
  "toolName": "aquarium-lighting-calculator",
  "inputs": [
    {
      "id": "tankLength",
      "label": "Aquarium Length",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "businessContext": "Length of the aquarium in centimeters"
    },
    {
      "id": "tankWidth",
      "label": "Aquarium Width",
      "type": "number",
      "unit": "cm",
      "default": 40,
      "businessContext": "Width of the aquarium in centimeters"
    },
    {
      "id": "tankHeight",
      "label": "Aquarium Height",
      "type": "number",
      "unit": "cm",
      "default": 50,
      "businessContext": "Height of the aquarium (water depth) in centimeters"
    },
    {
      "id": "desiredLux",
      "label": "Desired Illuminance",
      "type": "number",
      "unit": "lx",
      "default": 20,
      "businessContext": "Target light intensity at the substrate level in lux (10-20 low, 20-40 medium, 40+ high)"
    },
    {
      "id": "lightEfficiency",
      "label": "Light Efficiency",
      "type": "number",
      "unit": "lm/W",
      "default": 100,
      "businessContext": "Lumens per watt of the light source (LED: 80-100, T5: 90-110)"
    },
    {
      "id": "photoperiod",
      "label": "Photoperiod",
      "type": "number",
      "unit": "h/day",
      "default": 8,
      "businessContext": "Daily lighting duration in hours"
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost of electricity per kilowatt-hour (e.g., EUR or USD)"
    }
  ],
  "formulas": {
    "requiredLumens": "(desiredLux * (tankLength * tankWidth) / 10000)",
    "requiredWatts": "((desiredLux * (tankLength * tankWidth) / 10000) / lightEfficiency)",
    "dailyEnergy": "(((desiredLux * (tankLength * tankWidth) / 10000) / lightEfficiency) * photoperiod) / 1000",
    "monthlyCost": "((((desiredLux * (tankLength * tankWidth) / 10000) / lightEfficiency) * photoperiod) / 1000) * 30 * electricityCost"
  },
  "outputs": {
    "primary": "requiredWatts",
    "breakdown": [
      "requiredLumens",
      "dailyEnergy",
      "monthlyCost"
    ]
  },
  "category": "Enerji & Sürdürülebilirlik",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "cost"
}

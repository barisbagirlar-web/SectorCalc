  "formulas": {
    "requiredLumens": "(desiredLux * (tankLength * tankWidth) / 10000)",
    "requiredWatts": "((desiredLux * (tankLength * tankWidth) / 10000) / lightEfficiency)",
    "dailyEnergy": "(((desiredLux * (tankLength * tankWidth) / 10000) / lightEfficiency) * photoperiod) / 1000",
    "monthlyCost": "((((desiredLux * (tankLength * tankWidth) / 10000) / lightEfficiency) * photoperiod) / 1000) * 30 * electricityCost"
  },
  "outputs": {
    "primary": "requiredWatts",
    "breakdown": [
      "requiredLumens",
      "dailyEnergy",
      "monthlyCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

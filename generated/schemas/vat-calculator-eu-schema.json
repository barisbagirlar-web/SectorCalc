{
  "toolName": "vat-calculator-eu",
  "inputs": [
    {
      "id": "netAmount",
      "label": "Net Amount (EUR)",
      "type": "number",
      "unit": "EUR",
      "default": 100,
      "businessContext": "The net price before VAT",
      "label_i18n": {
        "en": "Net Amount (EUR)",
        "tr": "Net Tutar (EUR)",
        "de": "Nettobetrag (EUR)",
        "fr": "Montant net (EUR)",
        "es": "Importe neto (EUR)",
        "ar": "المبلغ الصافي (يورو)"
      },
      "businessContext_i18n": {
        "en": "The net price before VAT",
        "tr": "KDV öncesi net fiyat",
        "de": "Der Nettopreis vor Mehrwertsteuer",
        "fr": "Le prix net avant TVA",
        "es": "El precio neto antes de IVA",
        "ar": "السعر الصافي قبل ضريبة القيمة المضافة"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Standard VAT rate in the EU country (e.g., 20 for Germany)",
      "label_i18n": {
        "en": "VAT Rate (%)",
        "tr": "KDV Oranı (%)",
        "de": "Mehrwertsteuersatz (%)",
        "fr": "Taux de TVA (%)",
        "es": "Tipo de IVA (%)",
        "ar": "نسبة ضريبة القيمة المضافة (%)"
      },
      "businessContext_i18n": {
        "en": "Standard VAT rate in the EU country (e.g., 20 for Germany)",
        "tr": "AB ülkesindeki standart KDV oranı (ör. Almanya için 20)",
        "de": "Standard-Mehrwertsteuersatz im EU-Land (z. B. 20 für Deutschland)",
        "fr": "Taux de TVA standard dans le pays de l'UE (ex. 20 pour l'Allemagne)",
        "es": "Tipo de IVA estándar en el país de la UE (ej. 20 para Alemania)",
        "ar": "نسبة ضريبة القيمة المضافة القياسية في دولة الاتحاد الأوروبي (مثل 20 لألمانيا)"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1,
      "businessContext": "Number of units",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Miktar",
        "de": "Menge",
        "fr": "Quantité",
        "es": "Cantidad",
        "ar": "الكمية"
      },
      "businessContext_i18n": {
        "en": "Number of units",
        "tr": "Birim sayısı",
        "de": "Anzahl der Einheiten",
        "fr": "Nombre d'unités",
        "es": "Número de unidades",
        "ar": "عدد الوحدات"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Discount applied before VAT",
      "label_i18n": {
        "en": "Discount (%)",
        "tr": "İndirim (%)",
        "de": "Rabatt (%)",
        "fr": "Remise (%)",
        "es": "Descuento (%)",
        "ar": "الخصم (%)"
      },
      "businessContext_i18n": {
        "en": "Discount applied before VAT",
        "tr": "KDV öncesi uygulanan indirim",
        "de": "Rabatt vor Mehrwertsteuer",
        "fr": "Remise appliquée avant TVA",
        "es": "Descuento aplicado antes del IVA",
        "ar": "الخصم المطبق قبل ضريبة القيمة المضافة"
      }
    }
  ],
  "formulas": {
    "discountedNet": "netAmount * (1 - discountPercent / 100)",
    "vatAmount": "discountedNet * (vatRate / 100)",
    "grossAmount": "discountedNet + vatAmount",
    "totalNet": "discountedNet * quantity",
    "totalVat": "vatAmount * quantity",
    "totalGross": "grossAmount * quantity"
  },
  "outputs": {
    "primary": "totalGross",
    "breakdown": [
      "discountedNet",
      "vatAmount",
      "grossAmount",
      "totalNet",
      "totalVat"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalGross",
    "unit": "EUR"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

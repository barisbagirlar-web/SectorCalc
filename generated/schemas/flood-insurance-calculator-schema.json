{
  "toolName": "flood-insurance-calculator",
  "inputs": [
    {
      "id": "propertyValue",
      "label": "Property Value",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "businessContext": "The total value of the insured property including buildings and contents.",
      "label_i18n": {
        "en": "Property Value",
        "tr": "Property Value",
        "de": "Property Value",
        "fr": "Property Value",
        "es": "Property Value",
        "ar": "Property Value"
      }
    },
    {
      "id": "floodZoneFactor",
      "label": "Flood Zone Risk Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.02,
      "businessContext": "A factor representing the flood risk: 0.01 for low risk, 0.05 for high risk. Based on FEMA flood maps.",
      "label_i18n": {
        "en": "Flood Zone Risk Factor",
        "tr": "Flood Zone Risk Factor",
        "de": "Flood Zone Risk Factor",
        "fr": "Flood Zone Risk Factor",
        "es": "Flood Zone Risk Factor",
        "ar": "Flood Zone Risk Factor"
      }
    },
    {
      "id": "coverageAmount",
      "label": "Coverage Amount",
      "type": "number",
      "unit": "USD",
      "default": 400000,
      "businessContext": "The maximum amount the insurance will pay out.",
      "label_i18n": {
        "en": "Coverage Amount",
        "tr": "Coverage Amount",
        "de": "Coverage Amount",
        "fr": "Coverage Amount",
        "es": "Coverage Amount",
        "ar": "Coverage Amount"
      }
    },
    {
      "id": "deductible",
      "label": "Deductible",
      "type": "number",
      "unit": "USD",
      "default": 5000,
      "businessContext": "The amount the policyholder pays out-of-pocket before insurance coverage kicks in.",
      "label_i18n": {
        "en": "Deductible",
        "tr": "Deductible",
        "de": "Deductible",
        "fr": "Deductible",
        "es": "Deductible",
        "ar": "Deductible"
      }
    },
    {
      "id": "buildingTypeFactor",
      "label": "Building Type Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.2,
      "businessContext": "Multiplier based on building type: 1.0 for residential, 1.2 for commercial, 1.5 for industrial.",
      "label_i18n": {
        "en": "Building Type Factor",
        "tr": "Building Type Factor",
        "de": "Building Type Factor",
        "fr": "Building Type Factor",
        "es": "Building Type Factor",
        "ar": "Building Type Factor"
      }
    },
    {
      "id": "ageOfBuilding",
      "label": "Building Age",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Age of the building in years, used to calculate depreciation factor.",
      "label_i18n": {
        "en": "Building Age",
        "tr": "Building Age",
        "de": "Building Age",
        "fr": "Building Age",
        "es": "Building Age",
        "ar": "Building Age"
      }
    }
  ],
  "formulas": {
    "depreciationFactor": "Math.max(0.8, 1 - ageOfBuilding * 0.005)",
    "basePremium": "coverageAmount * floodZoneFactor * buildingTypeFactor * depreciationFactor",
    "deductibleCredit": "deductible * 0.02",
    "finalPremium": "basePremium - deductibleCredit"
  },
  "outputs": {
    "primary": "finalPremium",
    "breakdown": [
      "basePremium",
      "deductibleCredit"
    ]
  },
  "category": "İnşaat & Yapı",
  "sector": "İnşaat & Saha",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "project-construction-management",
  "sectorId": "finans",
  "profession": "Risk Uzmanı",
  "categoryId": "finance"
}

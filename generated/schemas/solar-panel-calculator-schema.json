{
  "toolName": "solar-panel-calculator",
  "inputs": [
    {
      "id": "panelArea",
      "label": "Panel Area",
      "type": "number",
      "unit": "m²",
      "default": 1.6,
      "businessContext": "Area of a single solar panel in square meters.",
      "label_i18n": {
        "en": "Panel Area",
        "tr": "Panel Area",
        "de": "Panel Area",
        "fr": "Panel Area",
        "es": "Panel Area",
        "ar": "Panel Area"
      }
    },
    {
      "id": "panelEfficiency",
      "label": "Panel Efficiency",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Conversion efficiency of the solar panel under standard test conditions.",
      "label_i18n": {
        "en": "Panel Efficiency",
        "tr": "Panel Efficiency",
        "de": "Panel Efficiency",
        "fr": "Panel Efficiency",
        "es": "Panel Efficiency",
        "ar": "Panel Efficiency"
      }
    },
    {
      "id": "solarIrradiance",
      "label": "Solar Irradiance",
      "type": "number",
      "unit": "W/m²",
      "default": 1000,
      "businessContext": "Standard test condition irradiance, typically 1000 W/m².",
      "label_i18n": {
        "en": "Solar Irradiance",
        "tr": "Solar Irradiance",
        "de": "Solar Irradiance",
        "fr": "Solar Irradiance",
        "es": "Solar Irradiance",
        "ar": "Solar Irradiance"
      }
    },
    {
      "id": "systemLosses",
      "label": "System Losses",
      "type": "number",
      "unit": "%",
      "default": 14,
      "businessContext": "Total system losses including wiring, inverter, soiling, and mismatch.",
      "label_i18n": {
        "en": "System Losses",
        "tr": "System Losses",
        "de": "System Losses",
        "fr": "System Losses",
        "es": "System Losses",
        "ar": "System Losses"
      }
    },
    {
      "id": "tiltAngle",
      "label": "Tilt Angle",
      "type": "number",
      "unit": "°",
      "default": 30,
      "businessContext": "Angle of the panel relative to horizontal plane.",
      "label_i18n": {
        "en": "Tilt Angle",
        "tr": "Tilt Angle",
        "de": "Tilt Angle",
        "fr": "Tilt Angle",
        "es": "Tilt Angle",
        "ar": "Tilt Angle"
      }
    },
    {
      "id": "azimuthAngle",
      "label": "Azimuth Angle",
      "type": "number",
      "unit": "°",
      "default": 0,
      "businessContext": "Compass direction the panel faces (0 = south in northern hemisphere).",
      "label_i18n": {
        "en": "Azimuth Angle",
        "tr": "Azimuth Angle",
        "de": "Azimuth Angle",
        "fr": "Azimuth Angle",
        "es": "Azimuth Angle",
        "ar": "Azimuth Angle"
      }
    },
    {
      "id": "latitude",
      "label": "Latitude",
      "type": "number",
      "unit": "°",
      "default": 41,
      "businessContext": "Latitude of the installation site, positive for northern hemisphere.",
      "label_i18n": {
        "en": "Latitude",
        "tr": "Latitude",
        "de": "Latitude",
        "fr": "Latitude",
        "es": "Latitude",
        "ar": "Latitude"
      }
    },
    {
      "id": "annualSunHours",
      "label": "Annual Sun Hours",
      "type": "number",
      "unit": "hours",
      "default": 2000,
      "businessContext": "Total equivalent full-sun hours per year at the location.",
      "label_i18n": {
        "en": "Annual Sun Hours",
        "tr": "Annual Sun Hours",
        "de": "Annual Sun Hours",
        "fr": "Annual Sun Hours",
        "es": "Annual Sun Hours",
        "ar": "Annual Sun Hours"
      }
    }
  ],
  "formulas": {
    "peakPower": "panelArea * panelEfficiency / 100",
    "annualEnergy": "peakPower * annualSunHours * (1 - systemLosses / 100)",
    "dailyEnergy": "annualEnergy / 365",
    "monthlyEnergy": "annualEnergy / 12",
    "co2Reduction": "annualEnergy * 0.5"
  },
  "outputs": {
    "primary": "peakPower",
    "breakdown": [
      {
        "id": "peakPower",
        "label": "Peak Power",
        "unit": "kWp"
      },
      {
        "id": "dailyEnergy",
        "label": "Average Daily Energy",
        "unit": "kWh"
      },
      {
        "id": "monthlyEnergy",
        "label": "Average Monthly Energy",
        "unit": "kWh"
      },
      {
        "id": "co2Reduction",
        "label": "Annual CO₂ Reduction",
        "unit": "kg"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "co2Reduction"
  },

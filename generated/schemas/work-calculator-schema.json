        "ar": "Mass"
      }
    },
    {
      "id": "distance",
      "label": "Distance",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Distance moved along the incline in meters",
      "label_i18n": {
        "en": "Distance",
        "tr": "Distance",
        "de": "Distance",
        "fr": "Distance",
        "es": "Distance",
        "ar": "Distance"
      }
    },
    {
      "id": "angle",
      "label": "Incline Angle",
      "type": "number",
      "unit": "degrees",
      "default": 30,
      "businessContext": "Angle of the incline relative to horizontal",
      "label_i18n": {
        "en": "Incline Angle",
        "tr": "Incline Angle",
        "de": "Incline Angle",
        "fr": "Incline Angle",
        "es": "Incline Angle",
        "ar": "Incline Angle"
      }
    },
    {
      "id": "frictionCoefficient",
      "label": "Friction Coefficient",
      "type": "number",
      "unit": "unit",
      "default": 0.1,
      "businessContext": "Coefficient of kinetic friction (dimensionless)",
      "label_i18n": {
        "en": "Friction Coefficient",
        "tr": "Friction Coefficient",
        "de": "Friction Coefficient",
        "fr": "Friction Coefficient",
        "es": "Friction Coefficient",
        "ar": "Friction Coefficient"
      }
    }
  ],
  "formulas": {
    "angleRad": "angle * Math.PI / 180",
    "workAgainstGravity": "mass * 9.81 * distance * Math.sin(angleRad)",
    "workAgainstFriction": "frictionCoefficient * mass * 9.81 * Math.cos(angleRad) * distance",
    "totalWork": "workAgainstGravity + workAgainstFriction"
  },
  "outputs": {
    "primary": "totalWork",
    "breakdown": [
      "workAgainstGravity",
      "workAgainstFriction"
    ]
  },

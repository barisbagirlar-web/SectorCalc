  "formulas": {
    "expectedSum": "diceCount * (1 + sides) / 2 + modifier",
    "averagePerDie": "(1 + sides) / 2",
    "successProbability": "((sides - target + 1) / sides) ** diceCount",
    "failureProbability": "1 - ((sides - target + 1) / sides) ** diceCount",
    "expectedSuccesses": "diceCount * (sides - target + 1) / sides"
  },
  "outputs": {
    "primary": "expectedSum",
    "breakdown": [

    {
      "id": "coefficientA",
      "label": "Sinclair Katsayısı A",
      "type": "number",
      "unit": "unit",
      "default": 0.722762521,
      "businessContext": "Sinclair formülü A katsayısı (boyutsuz)",
      "label_i18n": {
        "en": "Sinclair Katsayısı A",
        "tr": "Sinclair Katsayısı A",

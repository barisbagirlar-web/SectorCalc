{
  "toolName": "sinclair-calculator",
  "inputs": [
    {
      "id": "bodyweight",
      "label": "Vücut Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 80,
      "businessContext": "Haltercinin vücut ağırlığı (kg)"
    },
    {
      "id": "totalLifted",
      "label": "Toplam Kaldırılan Ağırlık",
      "type": "number",
      "unit": "kg",
      "default": 200,
      "businessContext": "Koparma ve silkme toplamı (kg)"
    },
    {
      "id": "coefficientA",
      "label": "Sinclair Katsayısı A",
      "type": "number",
      "unit": "",
      "default": 0.722762521,
      "businessContext": "Sinclair formülü A katsayısı (boyutsuz)"
    },
    {
      "id": "coefficientB",
      "label": "Sinclair Katsayısı b",
      "type": "number",
      "unit": "kg",
      "default": 193.609,
      "businessContext": "Sinclair formülü b referans ağırlığı (kg)"
    }
  ],
  "formulas": {
    "sinclairScore": "totalLifted * Math.pow(10, coefficientA * Math.pow(Math.log(bodyweight / coefficientB) / Math.log(10), 2))",
    "adjustedFactor": "Math.pow(10, coefficientA * Math.pow(Math.log(bodyweight / coefficientB) / Math.log(10), 2))",
    "bodyweightRatio": "bodyweight / coefficientB"
  },
  "outputs": {
    "primary": {
      "id": "sinclairScore",
      "label": "Sinclair Puanı",
      "unit": "puan"
    },
    "breakdown": [
      {
        "id": "adjustedFactor",
        "label": "Düzeltme Faktörü",
        "unit": ""
      },
      {
        "id": "bodyweightRatio",
        "label": "Ağırlık Oranı",
        "unit": ""
      }
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
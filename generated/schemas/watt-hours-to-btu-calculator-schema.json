{
  "toolName": "watt-hours-to-btu-calculator",
  "inputs": [
    {
      "id": "power",
      "label": "Power",
      "type": "number",
      "unit": "W",
      "default": 1000,
      "businessContext": "Power consumption in watts"
    },
    {
      "id": "time",
      "label": "Time",
      "type": "number",
      "unit": "h",
      "default": 1,
      "businessContext": "Operating time in hours"
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Efficiency of the system (100% means no losses)"
    },
    {
      "id": "btuType",
      "label": "BTU Type",
      "type": "number",
      "unit": "1=IT, 2=th, 3=mean",
      "default": 1,
      "businessContext": "Type of BTU: 1 for IT (ISO 31-4), 2 for thermochemical, 3 for mean"
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "€/kWh",
      "default": 0.152,
      "businessContext": "Cost of electricity per kWh for cost estimation"
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "places",
      "default": 2,
      "businessContext": "Number of decimal places for rounding outputs"
    }
  ],
  "formulas": {
    "wattHours": "power * time * efficiency / 100",
    "btu": "wattHours * (btuType == 1 ? 3.412141633 : btuType == 2 ? 3.4142 : 3.608249)",
    "btuRounded": "Math.round(btu * (10 ** decimalPlaces)) / (10 ** decimalPlaces)",
    "cost": "wattHours / 1000 * electricityCost",
    "costRounded": "Math.round(cost * (10 ** decimalPlaces)) / (10 ** decimalPlaces)"
  },
  "outputs": {
    "primary": "btuRounded",
    "breakdown": [
      "wattHours",
      "costRounded"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems"
}

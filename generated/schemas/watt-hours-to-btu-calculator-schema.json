        "ar": "Time"
      },
      "businessContext_i18n": {
        "en": "Operating time in hours",
        "tr": "Saat cinsinden çalışma süresi"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Efficiency of the system (100% means no losses)",
      "label_i18n": {
        "en": "Efficiency",
        "tr": "Verim",
        "de": "Wirkungsgrad",
        "fr": "Efficiency",
        "es": "Efficiency",
        "ar": "Efficiency"
      },

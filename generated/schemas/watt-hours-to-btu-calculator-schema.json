      }
    },
    {
      "id": "btuType",
      "label": "BTU Type",
      "type": "number",
      "unit": "1=IT, 2=th, 3=mean",
      "default": 1,
      "businessContext": "Type of BTU: 1 for IT (ISO 31-4), 2 for thermochemical, 3 for mean",
      "label_i18n": {
        "en": "BTU Type",
        "tr": "BTU Türü",
        "de": "BTU Type",
        "fr": "BTU Type",
        "es": "BTU Type",
        "ar": "BTU Type"
      },
      "businessContext_i18n": {
        "en": "Type of BTU: 1 for IT (ISO 31-4), 2 for thermochemical, 3 for mean",
        "tr": "BTU türü: 1 BT (ISO 31-4), 2 termokimyasal, 3 ortalama"
      }
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "€/kWh",
      "default": 0.152,
      "businessContext": "Cost of electricity per kWh for cost estimation",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Elektrik Maliyeti",
        "de": "Stromkosten",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      },
      "businessContext_i18n": {
        "en": "Cost of electricity per kWh for cost estimation",
        "tr": "Maliyet tahmini için kWh başına elektrik maliyeti"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "places",
      "default": 2,
      "businessContext": "Number of decimal places for rounding outputs",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Ondalık Basamak",
        "de": "Dezimalstellen",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      },
      "businessContext_i18n": {
        "en": "Number of decimal places for rounding outputs",
        "tr": "Yuvarlama çıktıları için ondalık basamak sayısı"
      }
    }
  ],
  "formulas": {
    "wattHours": "power * time * efficiency / 100",
    "btu": "wattHours * (btuType == 1 ? 3.412141633 : btuType == 2 ? 3.4142 : 3.608249)",
    "cost": "wattHours / 1000 * electricityCost"
  },
  "outputs": {
    "primary": "cost",
    "breakdown": [
      "wattHours",
      "costRounded"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costRounded",
    "unit": "W",
    "breakdownUnits": {
      "wattHours": "h"
    }
  },

  "formulas": {
    "currentProfit": "currentProduction * sellingPrice - currentProduction * variableCost - fixedCosts",
    "newProduction": "currentProduction * (1 + levelUpPercent / 100)",
    "newProfit": "newProduction * sellingPrice - newProduction * variableCost - (fixedCosts + additionalFixedCost)",
    "monthlyProfitIncrease": "newProfit - (currentProduction * sellingPrice - currentProduction * variableCost - fixedCosts)",
    "profitMarginCurrent": "(currentProfit / (currentProduction * sellingPrice)) * 100",
    "profitMarginNew": "(newProfit / (newProduction * sellingPrice)) * 100",
    "roi": "additionalFixedCost > 0 ? (monthlyProfitIncrease / additionalFixedCost) * 100 : 0"
  },
  "outputs": {
    "primary": "monthlyProfitIncrease",
    "breakdown": [
      "currentProfit",
      "newProfit",
      "profitMarginCurrent",
      "profitMarginNew",
      "roi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roi",
    "unit": "adet/ay",
    "breakdownUnits": {
      "profitMarginCurrent": "%",
      "profitMarginNew": "%"
    }
  },

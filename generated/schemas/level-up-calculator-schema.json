      }
    },
    {
      "id": "variableCost",
      "label": "Birim Değişken Maliyet",
      "type": "number",
      "unit": "TL",
      "default": 60,
      "businessContext": "Birim başına değişken maliyet (TL)",
      "label_i18n": {
        "en": "Birim Değişken Maliyet",
        "tr": "Birim Değişken Maliyet",
        "de": "Birim Değişken Maliyet",
        "fr": "Birim Değişken Maliyet",
        "es": "Birim Değişken Maliyet",
        "ar": "Birim Değişken Maliyet"
      }
    },
    {
      "id": "fixedCosts",
      "label": "Mevcut Sabit Maliyetler",
      "type": "number",
      "unit": "TL/ay",
      "default": 150000,
      "businessContext": "Mevcut aylık sabit maliyetler (TL/ay)",
      "label_i18n": {
        "en": "Mevcut Sabit Maliyetler",
        "tr": "Mevcut Sabit Maliyetler",
        "de": "Mevcut Sabit Maliyetler",
        "fr": "Mevcut Sabit Maliyetler",
        "es": "Mevcut Sabit Maliyetler",
        "ar": "Mevcut Sabit Maliyetler"
      }
    },
    {
      "id": "levelUpPercent",
      "label": "Üretim Artış Yüzdesi",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Üretim seviyesini artırma hedef yüzdesi (%)",
      "label_i18n": {
        "en": "Üretim Artış Yüzdesi",
        "tr": "Üretim Artış Yüzdesi",
        "de": "Üretim Artış Yüzdesi",
        "fr": "Üretim Artış Yüzdesi",
        "es": "Üretim Artış Yüzdesi",
        "ar": "Üretim Artış Yüzdesi"
      }
    },
    {
      "id": "additionalFixedCost",
      "label": "Ek Sabit Maliyet",
      "type": "number",
      "unit": "TL/ay",
      "default": 30000,
      "businessContext": "Seviye atlama için gerekli ek aylık sabit maliyet (TL/ay)",
      "label_i18n": {
        "en": "Ek Sabit Maliyet",
        "tr": "Ek Sabit Maliyet",
        "de": "Ek Sabit Maliyet",
        "fr": "Ek Sabit Maliyet",
        "es": "Ek Sabit Maliyet",
        "ar": "Ek Sabit Maliyet"
      }
    }
  ],
  "formulas": {
    "currentProfit": "currentProduction * sellingPrice - currentProduction * variableCost - fixedCosts",
    "newProduction": "currentProduction * (1 + levelUpPercent / 100)",
    "newProfit": "newProduction * sellingPrice - newProduction * variableCost - (fixedCosts + additionalFixedCost)",
    "monthlyProfitIncrease": "newProfit - (currentProduction * sellingPrice - currentProduction * variableCost - fixedCosts)",
    "profitMarginCurrent": "(currentProfit / (currentProduction * sellingPrice)) * 100",
    "profitMarginNew": "(newProfit / (newProduction * sellingPrice)) * 100",
    "roi": "additionalFixedCost > 0 ? (monthlyProfitIncrease / additionalFixedCost) * 100 : 0"
  },
  "outputs": {
    "primary": "monthlyProfitIncrease",
    "breakdown": [
      "currentProfit",
      "newProfit",
      "profitMarginCurrent",
      "profitMarginNew",
      "roi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roi"
  },
  "category": "Diğer",

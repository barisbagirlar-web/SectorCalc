{
  "toolName": "property-tax-calculator",
  "inputs": [
    {
      "id": "marketValue",
      "label": "Property Market Value",
      "type": "number",
      "unit": "USD",
      "default": 300000,
      "businessContext": "The fair market value of the property.",
      "label_i18n": {
        "en": "Property Market Value",
        "tr": "Gayrimenkul Piyasa Değeri",
        "de": "Property Market Value",
        "fr": "Property Market Value",
        "es": "Property Market Value",
        "ar": "Property Market Value"
      },
      "businessContext_i18n": {
        "en": "The fair market value of the property.",
        "tr": "Gayrimenkulün adil piyasa değeri."
      }
    },
    {
      "id": "assessmentRatio",
      "label": "Assessment Ratio",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Percentage of market value used for tax assessment.",
      "label_i18n": {
        "en": "Assessment Ratio",
        "tr": "Değerleme Oranı",
        "de": "Assessment Ratio",
        "fr": "Assessment Ratio",
        "es": "Assessment Ratio",
        "ar": "Assessment Ratio"
      },
      "businessContext_i18n": {
        "en": "Percentage of market value used for tax assessment.",
        "tr": "Vergi değerlemesi için kullanılan piyasa değeri yüzdesi."
      }
    },
    {
      "id": "millRate",
      "label": "Mill Rate",
      "type": "number",
      "unit": "mills",
      "default": 20,
      "businessContext": "Tax per $1,000 of assessed value, expressed in mills.",
      "label_i18n": {
        "en": "Mill Rate",
        "tr": "Vergi Oranı (binde)",
        "de": "Mill Rate",
        "fr": "Mill Rate",
        "es": "Mill Rate",
        "ar": "Mill Rate"
      },
      "businessContext_i18n": {
        "en": "Tax per $1,000 of assessed value, expressed in mills.",
        "tr": "Değerlendirilen değerin 1.000$'ı başına vergi, binde olarak ifade edilir."
      }
    },
    {
      "id": "exemptionAmount",
      "label": "Exemption Amount",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Total value of tax exemptions applied.",
      "label_i18n": {
        "en": "Exemption Amount",
        "tr": "Muafiyet Tutarı",
        "de": "Freibetrag",
        "fr": "Exemption Amount",
        "es": "Exemption Amount",
        "ar": "Exemption Amount"
      },
      "businessContext_i18n": {
        "en": "Total value of tax exemptions applied.",
        "tr": "Uygulanan toplam vergi muafiyet değeri."
      }
    },
    {
      "id": "additionalFees",
      "label": "Additional Fees",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Any additional taxes or fees.",
      "label_i18n": {
        "en": "Additional Fees",
        "tr": "Ek Ücretler",
        "de": "Zusätzliche Gebühren",
        "fr": "Additional Fees",
        "es": "Additional Fees",
        "ar": "Additional Fees"
      },
      "businessContext_i18n": {
        "en": "Any additional taxes or fees.",
        "tr": "Ek vergiler veya ücretler."
      }
    }
  ],
  "formulas": {
    "assessedValue": "marketValue * (assessmentRatio / 100)",
    "taxBeforeExemptions": "(assessedValue * millRate) / 1000",
    "totalTax": "taxBeforeExemptions - exemptionAmount + additionalFees"
  },
  "outputs": {
    "primary": "totalTax",
    "breakdown": [
      "assessedValue",
      "taxBeforeExemptions",
      "totalTax"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTax",
    "unit": "USD"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",

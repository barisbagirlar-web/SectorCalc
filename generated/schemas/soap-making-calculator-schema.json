        "tr": "Bakım için sabunlaşmamış bırakılan yağların yüzdesi"
      }
    },
    {
      "id": "waterPercent",
      "label": "Water as % of Oils",
      "type": "number",
      "unit": "%",
      "default": 38,
      "businessContext": "Weight of water relative to total oil weight",
      "label_i18n": {
        "en": "Water as % of Oils",
        "tr": "Yağların Yüzdesi Olarak Su",
        "de": "Water as % of Oils",
        "fr": "Water as % of Oils",
        "es": "Water as % of Oils",
        "ar": "Water as % of Oils"
      },
      "businessContext_i18n": {
        "en": "Weight of water relative to total oil weight",
        "tr": "Toplam yağ ağırlığına göre su ağırlığı"
      }
    }
  ],
  "formulas": {
    "lyeWeight": "(oilWeight * sapValue / 1000) * (1 - superfat / 100)",
    "waterWeight": "oilWeight * (waterPercent / 100)",
    "totalWeight": "oilWeight + lyeWeight + waterWeight"
  },
  "outputs": {
    "primary": "lyeWeight",
    "breakdown": [

{
  "toolName": "soap-making-calculator",
  "inputs": [
    {
      "id": "oilWeight",
      "label": "Total Oil Weight",
      "type": "number",
      "unit": "g",
      "default": 1000,
      "businessContext": "Weight of all oils in the recipe",
      "label_i18n": {

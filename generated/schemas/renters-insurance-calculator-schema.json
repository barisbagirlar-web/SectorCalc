{
  "toolName": "renters-insurance-calculator",
  "inputs": [
    {
      "id": "personalPropertyValue",
      "label": "Personal Property Value",
      "type": "number",
      "unit": "$",
      "default": 30000,
      "businessContext": "Estimated value of personal belongings to be insured.",
      "label_i18n": {
        "en": "Personal Property Value",
        "tr": "Personal Property Value",
        "de": "Personal Property Value",
        "fr": "Personal Property Value",
        "es": "Personal Property Value",
        "ar": "Personal Property Value"
      }
    },
    {
      "id": "liabilityCoverage",
      "label": "Liability Coverage",
      "type": "number",
      "unit": "$",
      "default": 100000,
      "businessContext": "Amount of liability protection desired.",
      "label_i18n": {
        "en": "Liability Coverage",
        "tr": "Liability Coverage",
        "de": "Liability Coverage",
        "fr": "Liability Coverage",
        "es": "Liability Coverage",
        "ar": "Liability Coverage"
      }
    },
    {
      "id": "deductible",
      "label": "Deductible",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "Amount you pay out-of-pocket before insurance kicks in.",
      "label_i18n": {
        "en": "Deductible",
        "tr": "Deductible",
        "de": "Deductible",
        "fr": "Deductible",
        "es": "Deductible",
        "ar": "Deductible"
      }
    },
    {
      "id": "locationRiskFactor",
      "label": "Location Risk Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier based on crime rate and disaster risk (1.0 = average).",
      "label_i18n": {
        "en": "Location Risk Factor",
        "tr": "Location Risk Factor",
        "de": "Location Risk Factor",
        "fr": "Location Risk Factor",
        "es": "Location Risk Factor",
        "ar": "Location Risk Factor"
      }
    },
    {
      "id": "securityDiscount",
      "label": "Security System Discount",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Discount percentage off premium for having an approved security system.",
      "label_i18n": {
        "en": "Security System Discount",
        "tr": "Security System Discount",
        "de": "Security System Discount",
        "fr": "Security System Discount",
        "es": "Security System Discount",
        "ar": "Security System Discount"
      }
    }
  ],
  "formulas": {
    "totalBasePremium": "(personalPropertyValue * 0.01) + (liabilityCoverage * 0.002)",
    "riskAdjustedPremium": "totalBasePremium * locationRiskFactor",
    "discountAmount": "riskAdjustedPremium * (securityDiscount / 100)",
    "finalAnnualPremium": "riskAdjustedPremium - discountAmount",
    "monthlyPremium": "finalAnnualPremium / 12",
    "totalCoverage": "personalPropertyValue + liabilityCoverage",
    "deductible": "deductible"
  },
  "outputs": {
    "primary": "finalAnnualPremium",
    "breakdown": [
      "monthlyPremium",
      "totalCoverage",
      "deductible"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "hse-ergonomics"
}

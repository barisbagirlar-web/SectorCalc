      "label": "Allowable Bending Stress (Fb)",
      "type": "number",
      "unit": "MPa",
      "default": 10,
      "businessContext": "Allowable bending stress for the wood beam",
      "label_i18n": {
        "en": "Allowable Bending Stress (Fb)",
        "tr": "Allowable Bending Stress (Fb)",
        "de": "Allowable Bending Stress (Fb)",
        "fr": "Allowable Bending Stress (Fb)",
        "es": "Allowable Bending Stress (Fb)",
        "ar": "Allowable Bending Stress (Fb)"
      }
    }
  ],
  "formulas": {
    "M": "load * (span * 1000) ** 2 / 8",
    "S": "width * depth ** 2 / 6",
    "bendingStress": "M / S",
    "I": "width * depth ** 3 / 12",
    "deflection": "(5 * load * (span * 1000) ** 4) / (384 * modulusElasticity * I)",
    "allowableDeflection": "(span * 1000) / 360",
    "stressRatio": "bendingStress / allowableStress",
    "deflectionRatio": "deflection / allowableDeflection"
  },
  "outputs": {
    "primary": "deflectionRatio",
    "breakdown": [
      "bendingStress",
      "deflection",
      "stressRatio",
      "deflectionRatio"
    ],

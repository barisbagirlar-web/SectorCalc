{
  "toolName": "lactate-threshold-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Athlete's age in years.",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "restingHeartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 60,
      "businessContext": "Resting heart rate measured in beats per minute.",
      "label_i18n": {
        "en": "Resting Heart Rate",
        "tr": "Resting Heart Rate",
        "de": "Resting Heart Rate",
        "fr": "Resting Heart Rate",
        "es": "Resting Heart Rate",
        "ar": "Resting Heart Rate"
      }
    },
    {
      "id": "maxHeartRate",
      "label": "Maximum Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 0,
      "businessContext": "Maximum heart rate. Enter 0 to estimate from age (220 - age).",
      "label_i18n": {
        "en": "Maximum Heart Rate",
        "tr": "Maximum Heart Rate",
        "de": "Maximum Heart Rate",
        "fr": "Maximum Heart Rate",
        "es": "Maximum Heart Rate",
        "ar": "Maximum Heart Rate"
      }
    },
    {
      "id": "intensityFactor",
      "label": "Intensity Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 0.85,
      "businessContext": "Fraction of heart rate reserve representing lactate threshold (typically 0.85-0.90).",
      "label_i18n": {
        "en": "Intensity Factor",
        "tr": "Intensity Factor",
        "de": "Intensity Factor",
        "fr": "Intensity Factor",
        "es": "Intensity Factor",
        "ar": "Intensity Factor"
      }
    },
    {
      "id": "thirtyMinTrialHeartRate",
      "label": "30-min Trial Average HR",
      "type": "number",
      "unit": "bpm",
      "default": 0,
      "businessContext": "Average heart rate during a 30-minute all-out effort. If >0, used directly as LTHR.",
      "label_i18n": {
        "en": "30-min Trial Average HR",
        "tr": "30-min Trial Average HR",
        "de": "30-min Trial Average HR",
        "fr": "30-min Trial Average HR",
        "es": "30-min Trial Average HR",
        "ar": "30-min Trial Average HR"
      }
    }
  ],
  "formulas": {
    "maxHR": "maxHeartRate > 0 ? maxHeartRate : 220 - age",
    "heartRateReserve": "maxHR - restingHeartRate",
    "estimatedLTHR": "restingHeartRate + heartRateReserve * intensityFactor",
    "lactateThresholdHeartRate": "thirtyMinTrialHeartRate > 0 ? thirtyMinTrialHeartRate : estimatedLTHR"
  },
  "outputs": {
    "primary": "lactateThresholdHeartRate",
    "breakdown": [
      "maxHR",
      "heartRateReserve",
      "estimatedLTHR"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "lactateThresholdHeartRate"
  },

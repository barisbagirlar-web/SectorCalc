{
  "toolName": "2d-inverse-kinematics-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "other",
  "sector": "Spor, Mimari, Robotik ve Hukuk",
  "sectorId": "other",
  "inputs": [
    {
      "id": "hedefX",
      "label": "Target X (m)",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "min": 0,
      "businessContext": "End effector x position."
    },
    {
      "id": "hedefY",
      "label": "Target Y (m)",
      "type": "number",
      "unit": "m",
      "default": 0.5,
      "min": 0,
      "businessContext": "End effector y position."
    },
    {
      "id": "kol1Uzunluk",
      "label": "Link 1 Length (m)",
      "type": "number",
      "unit": "m",
      "default": 0.4,
      "min": 0,
      "businessContext": "First arm segment."
    },
    {
      "id": "kol2Uzunluk",
      "label": "Link 2 Length (m)",
      "type": "number",
      "unit": "m",
      "default": 0.3,
      "min": 0,
      "businessContext": "Second arm segment."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "aci2": "Math.acos(Math.max(-1, Math.min(1, (hedefX*hedefX + hedefY*hedefY - kol1Uzunluk*kol1Uzunluk - kol2Uzunluk*kol2Uzunluk) / Math.max(0.0001, (2 * kol1Uzunluk * kol2Uzunluk)))))",
    "result": "Math.atan2(hedefY, hedefX) - Math.atan2(kol2Uzunluk*Math.sin(aci2), kol1Uzunluk + kol2Uzunluk*Math.cos(aci2))"
  },
  "outputs": {
    "primary": "result",
    "unit": "rad",
    "breakdown": {
      "aci2": "Eklem 2 (θ₂)",
      "result": "Eklem 1 (θ₁)"
    },
    "breakdownUnits": {
      "aci2": "rad",
      "result": "rad"
    },
    "hiddenLossDrivers": [
      "High asymmetry increases injury risk.",
      "Low H-index may indicate limited academic impact."
    ],
    "suggestedActions": [
      "Balance training for injury prevention.",
      "Use peer review to validate research quality."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate 2D inverse kinematics joint angles for a robotic arm.",
      "long": "Calculate 2D inverse kinematics joint angles for a robotic arm."
    }
  },
  "sectorSlug": "daily-renovation"
}

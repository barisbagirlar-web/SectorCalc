  "formulas": {
    "addReal": "real1 + real2",
    "addImag": "imag1 + imag2",
    "subReal": "real1 - real2",
    "subImag": "imag1 - imag2",
    "mulReal": "real1 * real2 - imag1 * imag2",
    "mulImag": "real1 * imag2 + imag1 * real2",
    "divReal": "(real1 * real2 + imag1 * imag2) / (real2 * real2 + imag2 * imag2)",
    "divImag": "(imag1 * real2 - real1 * imag2) / (real2 * real2 + imag2 * imag2)",
    "magnitude": "Math.sqrt(real1 * real1 + imag1 * imag1)",
    "phase": "Math.atan2(imag1, real1)",

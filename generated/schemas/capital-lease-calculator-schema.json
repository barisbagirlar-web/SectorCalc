{
  "toolName": "capital-lease-calculator",
  "inputs": [
    {
      "id": "assetCost",
      "label": "Asset Cost",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Fair value or cost of the asset being leased.",
      "label_i18n": {
        "en": "Asset Cost",
        "tr": "Asset Cost",
        "de": "Asset Cost",
        "fr": "Asset Cost",
        "es": "Asset Cost",
        "ar": "Asset Cost"
      }
    },
    {
      "id": "leaseTerm",
      "label": "Lease Term",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration of the lease in years.",
      "label_i18n": {
        "en": "Lease Term",
        "tr": "Lease Term",
        "de": "Lease Term",
        "fr": "Lease Term",
        "es": "Lease Term",
        "ar": "Lease Term"
      }
    },
    {
      "id": "interestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Implicit interest rate in the lease, per annum.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "residualValue",
      "label": "Residual Value",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "businessContext": "Estimated fair value of the asset at the end of the lease term.",
      "label_i18n": {
        "en": "Residual Value",
        "tr": "Residual Value",
        "de": "Residual Value",
        "fr": "Residual Value",
        "es": "Residual Value",
        "ar": "Residual Value"
      }
    },
    {
      "id": "paymentFrequency",
      "label": "Payments per Year",
      "type": "number",
      "unit": "per year",
      "default": 12,
      "businessContext": "Number of lease payments per year (12 for monthly, 4 for quarterly, 1 for annual).",
      "label_i18n": {
        "en": "Payments per Year",
        "tr": "Payments per Year",
        "de": "Payments per Year",
        "fr": "Payments per Year",
        "es": "Payments per Year",
        "ar": "Payments per Year"
      }
    }
  ],
  "formulas": {
    "r": "(interestRate / 100) / paymentFrequency",
    "n": "leaseTerm * paymentFrequency"
  },
  "outputs": {
    "primary": "n",
    "breakdown": [
      "totalPayments",
      "totalInterest",
      "effectiveAnnualRate"
    ],

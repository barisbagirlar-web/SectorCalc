      }
    },
    {
      "id": "safetyMarginPercent",
      "label": "Safety Margin",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional time percentage for rests and contingencies",
      "label_i18n": {
        "en": "Safety Margin",
        "tr": "Güvenlik Marjı",
        "de": "Sicherheitsmarge",
        "fr": "Safety Margin",
        "es": "Safety Margin",
        "ar": "Safety Margin"
      },
      "businessContext_i18n": {
        "en": "Additional time percentage for rests and contingencies",
        "tr": "Molalar ve beklenmedik durumlar için ek süre yüzdesi"
      }
    }
  ],
  "formulas": {
    "flatTime": "distance / flatSpeed",
    "ascentTime": "elevationGain / ascentPace",
    "baseTime": "flatTime + ascentTime",
    "totalTime": "baseTime * difficultyMultiplier * (1 + safetyMarginPercent / 100)"
  },
  "outputs": {
    "primary": "totalTime",
    "breakdown": [
      "flatTime",
      "ascentTime"
    ],

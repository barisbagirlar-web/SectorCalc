        "tr": "Distance (km)",
        "de": "Distance (km)",
        "fr": "Distance (km)",
        "es": "Distance (km)",
        "ar": "Distance (km)"
      }
    },
    {
      "id": "fuelConsumption",
      "label": "Fuel Consumption Rate",
      "type": "number",

      "label_i18n": {
        "en": "Fuel Consumption Rate",
        "tr": "Fuel Consumption Rate",
        "de": "Fuel Consumption Rate",
        "fr": "Fuel Consumption Rate",
        "es": "Fuel Consumption Rate",
        "ar": "Fuel Consumption Rate"
      }
    },
    {
      "id": "emissionFactor",
      "label": "Fuel Emission Factor",
      "type": "number",
      "unit": "kg CO₂/L",
      "default": 2.31,
      "businessContext": "CO₂ emissions per liter of fuel burned. For diesel ~2.68 kg/L, gasoline ~2.31 kg/L.",
      "label_i18n": {
        "en": "Fuel Emission Factor",
        "tr": "Fuel Emission Factor",
        "de": "Fuel Emission Factor",
        "fr": "Fuel Emission Factor",
        "es": "Fuel Emission Factor",
        "ar": "Fuel Emission Factor"
      }
    },
    {
      "id": "numberOfTrips",
      "label": "Number of Trips or Vehicles",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of identical trips or vehicles to scale total emissions.",
      "label_i18n": {
        "en": "Number of Trips or Vehicles",
        "tr": "Number of Trips or Vehicles",
        "de": "Number of Trips or Vehicles",
        "fr": "Number of Trips or Vehicles",
        "es": "Number of Trips or Vehicles",
        "ar": "Number of Trips or Vehicles"
      }
    }
  ],
  "formulas": {
    "totalCO2": "distance * fuelConsumption / 100 * emissionFactor * numberOfTrips",
    "fuelUsed": "distance * fuelConsumption / 100 * numberOfTrips",
    "perTripCO2": "distance * fuelConsumption / 100 * emissionFactor"
  },
  "outputs": {
    "primary": "totalCO2",
    "breakdown": [
      "perTripCO2",
      "fuelUsed"
    ]
  },

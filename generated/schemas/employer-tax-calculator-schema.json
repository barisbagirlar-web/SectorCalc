{
  "toolName": "employer-tax-calculator",
  "inputs": [
    {
      "id": "employeeGrossSalary",
      "label": "Employee Gross Salary",
      "type": "number",
      "unit": "TRY",
      "default": 10000,
      "businessContext": "The gross monthly salary of the employee before any deductions.",
      "label_i18n": {
        "en": "Employee Gross Salary",
        "tr": "Employee Gross Salary",
        "de": "Employee Gross Salary",
        "fr": "Employee Gross Salary",
        "es": "Employee Gross Salary",
        "ar": "Employee Gross Salary"
      }
    },
    {
      "id": "employerSocialSecurityRate",
      "label": "Employer Social Security Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 20.5,
      "businessContext": "Employer's contribution rate for social security (including disability, old age, etc.).",
      "label_i18n": {
        "en": "Employer Social Security Rate (%)",
        "tr": "Employer Social Security Rate (%)",
        "de": "Employer Social Security Rate (%)",
        "fr": "Employer Social Security Rate (%)",
        "es": "Employer Social Security Rate (%)",
        "ar": "Employer Social Security Rate (%)"
      }
    },
    {
      "id": "employerHealthInsuranceRate",
      "label": "Employer Health Insurance Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 12,
      "businessContext": "Employer's contribution rate for health insurance.",
      "label_i18n": {
        "en": "Employer Health Insurance Rate (%)",
        "tr": "Employer Health Insurance Rate (%)",
        "de": "Employer Health Insurance Rate (%)",
        "fr": "Employer Health Insurance Rate (%)",
        "es": "Employer Health Insurance Rate (%)",
        "ar": "Employer Health Insurance Rate (%)"
      }
    },
    {
      "id": "employerUnemploymentRate",
      "label": "Employer Unemployment Insurance Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Employer's contribution rate for unemployment insurance.",
      "label_i18n": {
        "en": "Employer Unemployment Insurance Rate (%)",
        "tr": "Employer Unemployment Insurance Rate (%)",
        "de": "Employer Unemployment Insurance Rate (%)",
        "fr": "Employer Unemployment Insurance Rate (%)",
        "es": "Employer Unemployment Insurance Rate (%)",
        "ar": "Employer Unemployment Insurance Rate (%)"
      }
    },
    {
      "id": "additionalCostRate",
      "label": "Additional Employer Cost Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 1,
      "businessContext": "Any other employer-specific costs like worker compensation, insurance, etc.",
      "label_i18n": {
        "en": "Additional Employer Cost Rate (%)",
        "tr": "Additional Employer Cost Rate (%)",
        "de": "Additional Employer Cost Rate (%)",
        "fr": "Additional Employer Cost Rate (%)",
        "es": "Additional Employer Cost Rate (%)",
        "ar": "Additional Employer Cost Rate (%)"
      }
    }
  ],
  "formulas": {
    "employerSocialSecurityAmount": "employeeGrossSalary * employerSocialSecurityRate / 100",
    "employerHealthInsuranceAmount": "employeeGrossSalary * employerHealthInsuranceRate / 100",
    "employerUnemploymentAmount": "employeeGrossSalary * employerUnemploymentRate / 100",
    "additionalCostAmount": "employeeGrossSalary * additionalCostRate / 100",
    "totalEmployerCost": "employeeGrossSalary + employerSocialSecurityAmount + employerHealthInsuranceAmount + employerUnemploymentAmount + additionalCostAmount"
  },
  "outputs": {
    "primary": "totalEmployerCost",
    "breakdown": [
      "employerSocialSecurityAmount",
      "employerHealthInsuranceAmount",
      "employerUnemploymentAmount",
      "additionalCostAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalEmployerCost",
    "unit": "TRY"
  },
  "category": "İK & Personel",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

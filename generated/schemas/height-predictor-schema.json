{
  "toolName": "height-predictor",
  "inputs": [
    {
      "id": "fatherHeight",
      "label": "Father's Height",
      "type": "number",
      "unit": "cm",
      "default": 175,
      "businessContext": "Height of the father in centimeters"
    },
    {
      "id": "motherHeight",
      "label": "Mother's Height",
      "type": "number",
      "unit": "cm",
      "default": 165,
      "businessContext": "Height of the mother in centimeters"
    },
    {
      "id": "gender",
      "label": "Child Gender",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Gender of child: 0 for girl, 1 for boy"
    },
    {
      "id": "correctionFactor",
      "label": "Correction Factor",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Adjustment factor for non-parental genetic influences (1 = no adjustment)"
    }
  ],
  "formulas": {
    "midParentalHeight": "(fatherHeight + motherHeight) / 2",
    "genderAdjustment": "13 * (2 * gender - 1) / 2",
    "genderAdjustedHeight": "(fatherHeight + motherHeight + 13 * (2 * gender - 1)) / 2",
    "predictedHeight": "((fatherHeight + motherHeight + 13 * (2 * gender - 1)) / 2) * correctionFactor"
  },
  "outputs": {
    "primary": "predictedHeight",
    "breakdown": [
      "midParentalHeight",
      "genderAdjustedHeight"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

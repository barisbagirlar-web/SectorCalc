    {
      "id": "particleDiameter",
      "label": "Particle Diameter",
      "type": "number",
      "unit": "m",
      "default": 0.001,
      "businessContext": "Mean diameter of filter medium particles/grains",
      "label_i18n": {
        "en": "Particle Diameter",
        "tr": "Partikül çapı",

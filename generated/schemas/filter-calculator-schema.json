        "de": "Mittlerer Durchmesser der Filtermediumpartikel/-körner"
      }
    },
    {
      "id": "filterArea",
      "label": "Filter Area",
      "type": "number",
      "unit": "m²",
      "default": 0.5,
      "businessContext": "Cross-sectional area of the filter",
      "label_i18n": {
        "en": "Filter Area",
        "tr": "Filtre alanı",
        "de": "Filterfläche",
        "fr": "Filter Area",
        "es": "Filter Area",
        "ar": "Filter Area"
      },
      "businessContext_i18n": {
        "en": "Cross-sectional area of the filter",
        "tr": "Filtrenin kesit alanı",
        "de": "Querschnittsfläche des Filters"
      }
    }
  ],
  "formulas": {
    "pressureDrop": "(180 * viscosity * thickness * flowRate * (1 - porosity) ** 2) / (filterArea * porosity ** 3 * particleDiameter ** 2)",
    "permeability": "(porosity ** 3 * particleDiameter ** 2) / (180 * (1 - porosity) ** 2)"
  },
  "outputs": {
    "primary": "pressureDrop",
    "breakdown": [
      "permeability"
    ],

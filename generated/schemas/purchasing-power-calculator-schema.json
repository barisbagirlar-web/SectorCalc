      }
    },
    {
      "id": "toYear",
      "label": "To Year",
      "type": "number",
      "unit": "year",
      "default": 2025,
      "businessContext": "Target year for purchasing power comparison.",
      "label_i18n": {
        "en": "To Year",
        "tr": "Bitiş Yılı",
        "de": "Bis Jahr",
        "fr": "À l'année",
        "es": "Hasta el año",
        "ar": "إلى السنة"
      },
      "businessContext_i18n": {
        "en": "Target year for purchasing power comparison.",
        "tr": "Satın alma gücü karşılaştırması için hedef yıl.",
        "de": "Zieljahr für den Kaufkraftvergleich.",
        "fr": "Année cible pour la comparaison du pouvoir d'achat.",
        "es": "Año objetivo para la comparación del poder adquisitivo.",
        "ar": "السنة المستهدفة لمقارنة القوة الشرائية."
      }
    },
    {
      "id": "compoundFrequency",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "periods/year",
      "default": 1,
      "businessContext": "Number of times inflation compounds per year (1 for annual, 12 for monthly).",
      "label_i18n": {
        "en": "Compounding Frequency",
        "tr": "Bileşik Sıklığı",
        "de": "Zinseszinshäufigkeit",
        "fr": "Fréquence de capitalisation",
        "es": "Frecuencia de capitalización",
        "ar": "تكرار المركبة"
      },
      "businessContext_i18n": {
        "en": "Number of times inflation compounds per year (1 for annual, 12 for monthly).",
        "tr": "Enflasyonun yılda kaç kez bileşik hesaplandığı (yıllık için 1, aylık için 12).",
        "de": "Anzahl der Inflationsberechnungen pro Jahr (1 für jährlich, 12 für monatlich).",
        "fr": "Nombre de capitalisations de l'inflation par an (1 pour annuel, 12 pour mensuel).",
        "es": "Número de veces que la inflación se capitaliza por año (1 para anual, 12 para mensual).",
        "ar": "عدد مرات تضاعف التضخم سنويًا (1 للسنوي، 12 للشهري)."
      }
    }
  ],
  "formulas": {
    "nYears": "toYear - fromYear",
    "periodRate": "inflationRate / 100 / compoundFrequency",
    "totalPeriods": "compoundFrequency * (toYear - fromYear)",
    "inflationFactor": "(1 + inflationRate / 100 / compoundFrequency) ** (compoundFrequency * (toYear - fromYear))",
    "adjustedPurchasingPower": "initialIncome / ((1 + inflationRate / 100 / compoundFrequency) ** (compoundFrequency * (toYear - fromYear)))",
    "purchasingPowerLoss": "initialIncome - (initialIncome / ((1 + inflationRate / 100 / compoundFrequency) ** (compoundFrequency * (toYear - fromYear))))"
  },
  "outputs": {
    "primary": "adjustedPurchasingPower",
    "breakdown": [
      "adjustedPurchasingPower",
      "purchasingPowerLoss"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "purchasingPowerLoss",
    "unit": "currency"
  },

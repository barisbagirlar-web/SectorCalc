{
  "toolName": "jet-lag-calculator",
  "inputs": [
    {
      "id": "timeZonesCrossed",
      "label": "Time Zones Crossed",
      "type": "number",
      "unit": "time zones",
      "default": 6,
      "businessContext": "Number of time zones crossed during travel."
    },
    {
      "id": "direction",
      "label": "Direction",
      "type": "number",
      "unit": "east=1, west=-1",
      "default": 1,
      "businessContext": "Travel direction: 1 for eastward, -1 for westward. Eastward travel typically causes more severe jet lag."
    },
    {
      "id": "flightDuration",
      "label": "Flight Duration",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Total duration of the flight in hours."
    },
    {
      "id": "preTravelRest",
      "label": "Pre-Travel Rest Quality",
      "type": "number",
      "unit": "scale 0-10",
      "default": 7,
      "businessContext": "Quality of rest before travel, assessed on a 0 (poor) to 10 (excellent) scale."
    },
    {
      "id": "age",
      "label": "Operator Age",
      "type": "number",
      "unit": "years",
      "default": 35,
      "businessContext": "Age of the operator, as older individuals may experience stronger jet lag effects."
    }
  ],
  "formulas": {
    "jetLagSeverity": "Math.min(100, (Math.abs(timeZonesCrossed) * (direction > 0 ? 1.2 : 1) + flightDuration * 0.5) * (1 + (10 - preTravelRest) * 0.1) * (1 + Math.max(0, age - 30) * 0.01) * 10)",
    "recoveryDays": "Math.ceil(timeZonesCrossed * (direction > 0 ? 1 : 0.75) * (1 + (10 - preTravelRest) * 0.1) * (1 + Math.max(0, age - 30) * 0.02))",
    "fatigueScore": "Math.min(100, (Math.abs(timeZonesCrossed) * 10 + flightDuration * 5) * (1 + (10 - preTravelRest) * 0.15))"
  },
  "outputs": {
    "primary": "jetLagSeverity",
    "breakdown": [
      "recoveryDays",
      "fatigueScore"
    ]
  },
  "category": "Rota & Lojistik",
  "sector": "Lojistik & Sevkiyat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

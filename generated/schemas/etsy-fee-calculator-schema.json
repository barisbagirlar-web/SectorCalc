        "es": "Número de artículos vendidos",
        "ar": "عدد القطع المباعة"
      }
    },
    {
      "id": "itemCost",
      "label": "Item Cost (USD)",
      "type": "number",
      "unit": "USD",
      "default": 10,
      "businessContext": "Cost of goods sold per item",
      "label_i18n": {
        "en": "Item Cost (USD)",
        "tr": "Ürün Maliyeti (USD)",
        "de": "Artikelkosten (USD)",
        "fr": "Coût de l'article (USD)",
        "es": "Costo del artículo (USD)",
        "ar": "تكلفة القطعة (بالدولار)"
      },
      "businessContext_i18n": {
        "en": "Cost of goods sold per item",
        "tr": "Satılan malın birim maliyeti",
        "de": "Kosten der verkauften Waren pro Artikel",
        "fr": "Coût des marchandises vendues par article",
        "es": "Costo de los bienes vendidos por artículo",
        "ar": "تكلفة البضاعة المباعة لكل قطعة"
      }
    }
  ],
  "formulas": {
    "listingFees": "quantity * 0.20",
    "transactionFees": "(itemPrice + shippingPrice) * quantity * 0.065",
    "paymentProcessingFees": "((itemPrice + shippingPrice) * quantity * 0.03) + 0.25",
    "totalFees": "listingFees + transactionFees + paymentProcessingFees",
    "netProfit": "(itemPrice * quantity) - totalFees - (itemCost * quantity)"
  },
  "outputs": {
    "primary": "totalFees",
    "breakdown": [
      "listingFees",
      "transactionFees",
      "paymentProcessingFees",
      "netProfit"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netProfit",
    "unit": "USD"
  },

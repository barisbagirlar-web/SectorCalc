        "ar": "تكلفة الشحن المفروضة على المشتري لكل قطعة"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "items",
      "default": 1,
      "businessContext": "Number of items sold",
      "label_i18n": {

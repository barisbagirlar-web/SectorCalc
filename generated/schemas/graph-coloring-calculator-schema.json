{
  "toolName": "graph-coloring-calculator",
  "inputs": [
    {
      "id": "measurement",
      "label": "Measurement Value",
      "type": "number",
      "unit": "units",
      "default": 10,
      "businessContext": "Process measurement to evaluate",
      "label_i18n": {
        "en": "Measurement Value",
        "tr": "Measurement Value",
        "de": "Measurement Value",
        "fr": "Measurement Value",
        "es": "Measurement Value",
        "ar": "Measurement Value"
      }
    },
    {
      "id": "target",
      "label": "Target Value",
      "type": "number",
      "unit": "units",
      "default": 10,
      "businessContext": "Nominal target value",
      "label_i18n": {
        "en": "Target Value",
        "tr": "Target Value",
        "de": "Target Value",
        "fr": "Target Value",
        "es": "Target Value",
        "ar": "Target Value"
      }
    },
    {
      "id": "lowerSpec",
      "label": "Lower Specification Limit",
      "type": "number",
      "unit": "units",
      "default": 8,
      "businessContext": "Minimum acceptable value",
      "label_i18n": {
        "en": "Lower Specification Limit",
        "tr": "Lower Specification Limit",
        "de": "Lower Specification Limit",
        "fr": "Lower Specification Limit",
        "es": "Lower Specification Limit",
        "ar": "Lower Specification Limit"
      }
    },
    {
      "id": "upperSpec",
      "label": "Upper Specification Limit",
      "type": "number",
      "unit": "units",
      "default": 12,
      "businessContext": "Maximum acceptable value",
      "label_i18n": {
        "en": "Upper Specification Limit",
        "tr": "Upper Specification Limit",
        "de": "Upper Specification Limit",
        "fr": "Upper Specification Limit",
        "es": "Upper Specification Limit",
        "ar": "Upper Specification Limit"
      }
    },
    {
      "id": "warningFraction",
      "label": "Warning Zone Fraction",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "businessContext": "Fraction of spec half-range defining green zone around target (0-1)",
      "label_i18n": {
        "en": "Warning Zone Fraction",
        "tr": "Warning Zone Fraction",
        "de": "Warning Zone Fraction",
        "fr": "Warning Zone Fraction",
        "es": "Warning Zone Fraction",
        "ar": "Warning Zone Fraction"
      }
    }
  ],
  "formulas": {
    "specHalfRange": "(upperSpec - lowerSpec) / 2",
    "warningHalfWidth": "specHalfRange * warningFraction",
    "isWithinSpec": "(measurement >= lowerSpec && measurement <= upperSpec) ? 1 : 0",
    "isGood": "(measurement >= target - warningHalfWidth && measurement <= target + warningHalfWidth) ? 1 : 0",
    "colorCode": "isWithinSpec ? (isGood ? 2 : 1) : 0",
    "deviation": "measurement - target",
    "percentDeviation": "((measurement - target) / specHalfRange) * 100"
  },
  "outputs": {
    "primary": "colorCode",
    "breakdown": [
      "deviation",
      "percentDeviation"
    ]
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Gıda & İçecek",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "quality"
}

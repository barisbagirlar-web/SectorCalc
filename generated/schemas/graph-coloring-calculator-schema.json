        "es": "Fracción de zona de advertencia",
        "ar": "Warning Zone Fraction"
      },
      "businessContext_i18n": {
        "en": "Fraction of spec half-range defining green zone around target (0-1)",
        "tr": "Hedef etrafındaki yeşil bölgeyi tanımlayan spesifikasyon yarı aralığının kesri (0-1)",
        "de": "Anteil des Spezifikationshalbbereichs, der die grüne Zone um den Zielwert definiert (0-1)",
        "fr": "Fraction de la demi-plage de spécification définissant la zone verte autour de la cible (0-1)",
        "es": "Fracción del semirango de especificación que define la zona verde alrededor del objetivo (0-1)"
      }
    }
  ],
  "formulas": {
    "specHalfRange": "(upperSpec - lowerSpec) / 2",
    "warningHalfWidth": "specHalfRange * warningFraction",
    "isWithinSpec": "(measurement >= lowerSpec && measurement <= upperSpec) ? 1 : 0",
    "isGood": "(measurement >= target - warningHalfWidth && measurement <= target + warningHalfWidth) ? 1 : 0",
    "colorCode": "isWithinSpec ? (isGood ? 2 : 1) : 0",
    "deviation": "measurement - target",
    "percentDeviation": "((measurement - target) / specHalfRange) * 100"
  },
  "outputs": {
    "primary": "colorCode",
    "breakdown": [
      "deviation",
      "percentDeviation"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "percentDeviation",
    "unit": "—",
    "breakdownUnits": {
      "percentDeviation": "%"
    }
  },

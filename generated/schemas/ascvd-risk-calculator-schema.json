    "calcLogOdds": "(-5) + 0.05*age + 0.01*totalCholesterol - 0.02*hdlCholesterol + 0.01*systolicBP + 0.5*treatedHypertension + 0.5*diabetes + 0.5*smoker + 0.3*male",
    "calcLogOdds_aux": "(-5) + 0.05*age + 0.01*totalCholesterol - 0.02*hdlCholesterol + 0.01*systolicBP + 0.5*treatedHypertension + 0.5*diabetes + 0.5*smoker + 0.3*male"
  },

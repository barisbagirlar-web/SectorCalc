{
  "toolName": "hair-loss-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age is a primary risk factor for androgenetic alopecia; hair loss probability increases with age.",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      }
    },
    {
      "id": "dailyShedding",
      "label": "Daily Hair Shedding",
      "type": "number",
      "unit": "strands/day",
      "default": 100,
      "businessContext": "Normal shedding is 50-100 strands/day; excessive shedding indicates potential hair loss.",
      "label_i18n": {
        "en": "Daily Hair Shedding",
        "tr": "Daily Hair Shedding",
        "de": "Daily Hair Shedding",
        "fr": "Daily Hair Shedding",
        "es": "Daily Hair Shedding",
        "ar": "Daily Hair Shedding"
      }
    },
    {
      "id": "geneticScore",
      "label": "Genetic Predisposition Score",
      "type": "number",
      "unit": "0-100",
      "default": 50,
      "businessContext": "Family history of baldness increases risk; scored 0 (none) to 100 (strong).",
      "label_i18n": {
        "en": "Genetic Predisposition Score",
        "tr": "Genetic Predisposition Score",
        "de": "Genetic Predisposition Score",
        "fr": "Genetic Predisposition Score",
        "es": "Genetic Predisposition Score",
        "ar": "Genetic Predisposition Score"
      }
    },
    {
      "id": "stressLevel",
      "label": "Stress Level",
      "type": "number",
      "unit": "0-10",
      "default": 5,
      "businessContext": "High stress can accelerate hair loss via telogen effluvium.",
      "label_i18n": {
        "en": "Stress Level",
        "tr": "Stress Level",
        "de": "Stress Level",
        "fr": "Stress Level",
        "es": "Stress Level",
        "ar": "Stress Level"
      }
    },
    {
      "id": "nutritionScore",
      "label": "Nutritional Quality Score",
      "type": "number",
      "unit": "0-100",
      "default": 70,
      "businessContext": "Poor nutrition (deficiencies in iron, zinc, biotin) contributes to hair thinning; higher is better.",
      "label_i18n": {
        "en": "Nutritional Quality Score",
        "tr": "Nutritional Quality Score",
        "de": "Nutritional Quality Score",
        "fr": "Nutritional Quality Score",
        "es": "Nutritional Quality Score",
        "ar": "Nutritional Quality Score"
      }
    },
    {
      "id": "hormoneIndex",
      "label": "Hormonal Imbalance Index",
      "type": "number",
      "unit": "0-10",
      "default": 3,
      "businessContext": "Hormonal factors like DHT sensitivity; higher index indicates greater imbalance.",
      "label_i18n": {
        "en": "Hormonal Imbalance Index",
        "tr": "Hormonal Imbalance Index",
        "de": "Hormonal Imbalance Index",
        "fr": "Hormonal Imbalance Index",
        "es": "Hormonal Imbalance Index",
        "ar": "Hormonal Imbalance Index"
      }
    }
  ],
  "formulas": {
    "riskScore": "0.25 * (age / 100) + 0.2 * (dailyShedding / 200) + 0.2 * (geneticScore / 100) + 0.15 * (stressLevel / 10) + 0.1 * ((100 - nutritionScore) / 100) + 0.1 * (hormoneIndex / 10)",
    "hairLossRate": "dailyShedding * 365"
  },
  "outputs": {
    "primary": "hairLossRate",
    "breakdown": [
      "riskScore",
      "hairLossRate"
    ],

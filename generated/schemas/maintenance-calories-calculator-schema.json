{
  "toolName": "maintenance-calories-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Kilo",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Vücut ağırlığı"
    },
    {
      "id": "height",
      "label": "Boy",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Boy uzunluğu"
    },
    {
      "id": "age",
      "label": "Yaş",
      "type": "number",
      "unit": "yıl",
      "default": 30,
      "businessContext": "Yaş"
    },
    {
      "id": "gender",
      "label": "Cinsiyet",
      "type": "number",
      "unit": "0:Kadın, 1:Erkek",
      "default": 0,
      "businessContext": "Cinsiyet kodu (0: kadın, 1: erkek)"
    },
    {
      "id": "activityLevel",
      "label": "Aktivite Seviyesi",
      "type": "number",
      "unit": "çarpan",
      "default": 1.55,
      "businessContext": "Günlük aktivite çarpanı (sedanter:1.2, hafif:1.375, orta:1.55, aktif:1.725, çok aktif:1.9)"
    }
  ],
  "formulas": {
    "bmr": "gender * (10 * weight + 6.25 * height - 5 * age + 5) + (1 - gender) * (10 * weight + 6.25 * height - 5 * age - 161)",
    "maintenance": "bmr * activityLevel",
    "activityLevel": "activityLevel"
  },
  "outputs": {
    "primary": "maintenance",
    "breakdown": [
      "bmr",
      "activityLevel"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

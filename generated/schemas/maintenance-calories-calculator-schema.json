{
  "toolName": "maintenance-calories-calculator",
  "inputs": [
    {
      "id": "gender",
      "label": "Cinsiyet (Kadın=0, Erkek=1)",
      "type": "number",
      "unit": null,
      "default": 1,
      "businessContext": "Kullanıcının cinsiyeti; 0 kadın, 1 erkek olarak alınır."
    },
    {
      "id": "age",
      "label": "Yaş (yıl)",
      "type": "number",
      "unit": "yıl",
      "default": 30,
      "businessContext": "Kullanıcının yaşı, yıl cinsinden."
    },
    {
      "id": "weight",
      "label": "Ağırlık (kg)",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Kullanıcının vücut ağırlığı, kilogram."
    },
    {
      "id": "height",
      "label": "Boy (cm)",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Kullanıcının boyu, santimetre."
    },
    {
      "id": "activityLevel",
      "label": "Aktivite Seviyesi Çarpanı",
      "type": "number",
      "unit": null,
      "default": 1.55,
      "businessContext": "Fiziksel aktivite düzeyi çarpanı (sedanter:1.2, hafif:1.375, orta:1.55, yüksek:1.725, çok yüksek:1.9)."
    }
  ],
  "formulas": {
    "BMR": "66*{gender} + 655*(1-{gender}) + (13.7*{gender} + 9.6*(1-{gender}))*{weight} + (5*{gender} + 1.8*(1-{gender}))*{height} - (6.8*{gender} + 4.7*(1-{gender}))*{age}",
    "TDEE": "BMR * {activityLevel}"
  },
  "outputs": {
    "primary": "TDEE",
    "breakdown": [
      "BMR",
      "TDEE"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
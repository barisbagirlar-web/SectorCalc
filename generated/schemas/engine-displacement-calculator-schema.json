      }
    },
    {
      "id": "outputUnit",
      "label": "Output Unit",
      "type": "number",
      "unit": "1=cc,2=L,3=ci",
      "default": 1,
      "businessContext": "1 for cubic centimeters, 2 for liters, 3 for cubic inches",
      "label_i18n": {
        "en": "Output Unit",
        "tr": "Çıktı Birimi",
        "de": "Ausgabeeinheit",
        "fr": "Unité de sortie",
        "es": "Unidad de salida",
        "ar": "وحدة الإخراج"
      },
      "businessContext_i18n": {
        "en": "1 for cubic centimeters, 2 for liters, 3 for cubic inches",
        "tr": "1: cm³, 2: litre, 3: inç³",
        "de": "1 für Kubikzentimeter, 2 für Liter, 3 für Kubikzoll",
        "fr": "1 pour centimètres cubes, 2 pour litres, 3 pour pouces cubes",
        "es": "1 para centímetros cúbicos, 2 para litros, 3 para pulgadas cúbicas",
        "ar": "1 للسنتيمتر المكعب، 2 للتر، 3 للبوصة المكعبة"
      }
    }
  ],
  "formulas": {
    "volumePerCylinderMM3": "(Math.PI/4) * bore * bore * stroke",
    "totalDisplacementMM3": "volumePerCylinderMM3 * cylinders",
    "totalDisplacementCC": "totalDisplacementMM3 / 1000",
    "totalDisplacementL": "totalDisplacementCC / 1000",
    "totalDisplacementCI": "totalDisplacementMM3 / 16387.064",
    "primaryDisplacement": "outputUnit === 1 ? totalDisplacementCC : outputUnit === 2 ? totalDisplacementL : totalDisplacementCI"
  },
  "outputs": {
    "primary": "primaryDisplacement",
    "breakdown": [
      "totalDisplacementCC",
      "totalDisplacementL"
    ],

{
  "toolName": "engine-displacement-calculator",
  "inputs": [
    {
      "id": "bore",
      "label": "Bore",
      "type": "number",
      "unit": "mm",
      "default": 80,
      "businessContext": "Cylinder bore diameter in millimeters",
      "label_i18n": {
        "en": "Bore",
        "tr": "Bore",
        "de": "Bore",
        "fr": "Bore",
        "es": "Bore",
        "ar": "Bore"
      }
    },
    {
      "id": "stroke",
      "label": "Stroke",
      "type": "number",
      "unit": "mm",
      "default": 90,
      "businessContext": "Piston stroke length in millimeters",
      "label_i18n": {
        "en": "Stroke",
        "tr": "Stroke",
        "de": "Stroke",
        "fr": "Stroke",
        "es": "Stroke",
        "ar": "Stroke"
      }
    },
    {
      "id": "cylinders",
      "label": "Number of Cylinders",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Total number of engine cylinders",
      "label_i18n": {
        "en": "Number of Cylinders",
        "tr": "Number of Cylinders",
        "de": "Number of Cylinders",
        "fr": "Number of Cylinders",
        "es": "Number of Cylinders",
        "ar": "Number of Cylinders"
      }
    },
    {
      "id": "outputUnit",
      "label": "Output Unit",
      "type": "number",
      "unit": "1=cc,2=L,3=ci",
      "default": 1,
      "businessContext": "1 for cubic centimeters, 2 for liters, 3 for cubic inches",
      "label_i18n": {
        "en": "Output Unit",
        "tr": "Output Unit",
        "de": "Output Unit",
        "fr": "Output Unit",
        "es": "Output Unit",
        "ar": "Output Unit"
      }
    }
  ],
  "formulas": {
    "volumePerCylinderMM3": "(Math.PI/4) * bore * bore * stroke",
    "totalDisplacementMM3": "volumePerCylinderMM3 * cylinders",
    "totalDisplacementCC": "totalDisplacementMM3 / 1000",
    "totalDisplacementL": "totalDisplacementCC / 1000",
    "totalDisplacementCI": "totalDisplacementMM3 / 16387.064",
    "primaryDisplacement": "outputUnit === 1 ? totalDisplacementCC : outputUnit === 2 ? totalDisplacementL : totalDisplacementCI"
  },
  "outputs": {
    "primary": "primaryDisplacement",
    "breakdown": [
      "totalDisplacementCC",
      "totalDisplacementL"
    ]
  },
  "category": "Otomotiv",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "maintenance-reliability"
}

{
  "toolName": "strain-calculator",
  "inputs": [
    {
      "id": "initial_length",
      "label": "Initial Length",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Original length before deformation",
      "label_i18n": {
        "en": "Initial Length",
        "tr": "Initial Length",
        "de": "Initial Length",
        "fr": "Initial Length",
        "es": "Initial Length",
        "ar": "Initial Length"
      }
    },
    {
      "id": "final_length",
      "label": "Final Length",
      "type": "number",
      "unit": "mm",
      "default": 100.5,
      "businessContext": "Length after deformation (e.g., under load or temperature)",
      "label_i18n": {
        "en": "Final Length",
        "tr": "Final Length",
        "de": "Final Length",
        "fr": "Final Length",
        "es": "Final Length",
        "ar": "Final Length"
      }
    },
    {
      "id": "temperature_change",
      "label": "Temperature Change",
      "type": "number",
      "unit": "°C",
      "default": 0,
      "businessContext": "Change in temperature for thermal expansion calculation",
      "label_i18n": {
        "en": "Temperature Change",
        "tr": "Temperature Change",
        "de": "Temperature Change",
        "fr": "Temperature Change",
        "es": "Temperature Change",
        "ar": "Temperature Change"
      }
    },
    {
      "id": "cte",
      "label": "Coefficient of Thermal Expansion",
      "type": "number",
      "unit": "/°C",
      "default": 0.000012,
      "businessContext": "Material's linear thermal expansion coefficient (e.g., steel 12e-6)",
      "label_i18n": {
        "en": "Coefficient of Thermal Expansion",
        "tr": "Coefficient of Thermal Expansion",
        "de": "Coefficient of Thermal Expansion",
        "fr": "Coefficient of Thermal Expansion",
        "es": "Coefficient of Thermal Expansion",
        "ar": "Coefficient of Thermal Expansion"
      }
    },
    {
      "id": "elastic_modulus",
      "label": "Young's Modulus",
      "type": "number",
      "unit": "GPa",
      "default": 200,
      "businessContext": "Material's modulus of elasticity. Set to 0 to ignore stress",
      "label_i18n": {
        "en": "Young's Modulus",
        "tr": "Young's Modulus",
        "de": "Young's Modulus",
        "fr": "Young's Modulus",
        "es": "Young's Modulus",
        "ar": "Young's Modulus"
      }
    }
  ],
  "formulas": {
    "mechStrainPct": "((final_length - initial_length) / initial_length) * 100",
    "thermStrainPct": "cte * temperature_change * 100",
    "totalStrainPct": "(((final_length - initial_length) / initial_length) + cte * temperature_change) * 100",
    "stressMpa": "elastic_modulus > 0 ? (((final_length - initial_length) / initial_length) + cte * temperature_change) * elastic_modulus * 1000 : 0"
  },
  "outputs": {
    "primary": "totalStrainPct",
    "breakdown": [
      "Mechanical Strain: ${mechStrainPct.toFixed(2)}%",
      "Thermal Strain: ${thermStrainPct.toFixed(2)}%",
      "Total Strain: ${totalStrainPct.toFixed(2)}%",
      "Stress: ${elastic_modulus > 0 ? stressMpa.toFixed(2) + ' MPa' : 'N/A'}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "stressMpa"
  },
  "category": "Teknik & Mühendislik",
  "sector": "Fizik & Mekanik",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "fizik",
  "profession": "Fizik Mühendisi",
  "categoryId": "engineering",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "chains-to-links-calculator",
  "inputs": [
    {
      "id": "chains",
      "label": "Chains",
      "type": "number",
      "unit": "chains",
      "default": 1,
      "businessContext": "Number of chains to convert",
      "label_i18n": {
        "en": "Chains",
        "tr": "Chains",
        "de": "Chains",
        "fr": "Chains",
        "es": "Chains",
        "ar": "Chains"
      }
    },
    {
      "id": "linksPerChain",
      "label": "Links per Chain",
      "type": "number",
      "unit": "links/chain",
      "default": 100,
      "businessContext": "Number of links in one chain (standard Gunter's chain = 100)",
      "label_i18n": {
        "en": "Links per Chain",
        "tr": "Links per Chain",
        "de": "Links per Chain",
        "fr": "Links per Chain",
        "es": "Links per Chain",
        "ar": "Links per Chain"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "decimal places",
      "default": 2,
      "businessContext": "Number of decimal places for output rounding",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "roundingMethod",
      "label": "Rounding Method",
      "type": "number",
      "unit": "-",
      "default": 0,
      "businessContext": "0 = standard round, 1 = floor, 2 = ceil",
      "label_i18n": {
        "en": "Rounding Method",
        "tr": "Rounding Method",
        "de": "Rounding Method",
        "fr": "Rounding Method",
        "es": "Rounding Method",
        "ar": "Rounding Method"
      }
    }
  ],
  "formulas": {
    "rawLinks": "chains * linksPerChain",
    "roundedLinks": "roundingMethod === 0 ? Math.round(rawLinks * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces) : roundingMethod === 1 ? Math.floor(rawLinks * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces) : Math.ceil(rawLinks * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)"
  },
  "outputs": {
    "primary": "roundedLinks",
    "breakdown": [
      "rawLinks",
      "roundedLinks"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",

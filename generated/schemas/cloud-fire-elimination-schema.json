  "formulas": {
    "ZombieCost": "SUM(UnattachedVolumes * Rate) + SUM(IdleLBs * Rate) + SUM(OrphanSnapshots * StorageRate)",
    "OversizingSavings": "SUM((CurrentCost - RightSizedCost) * Uptime)",
    "SpotSavings": "SUM((OnDemand - Spot) * FaultTolerantHours)",
    "ReservedSavings": "(OnDemand - Reserved) * CommitUtil",
    "IdleHoursCost": "NonBizHours * RunningInstances * HourlyRate",
    "TotalWaste": "Zombie + Oversizing + Spot + Reserved + Idle"
  },
  "outputs": {
    "primary": "TotalWaste",
    "unit": "USD",
    "breakdown": {
      "ZombieCost": "ZombieCost",

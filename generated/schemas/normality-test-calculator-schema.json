{
  "toolName": "normality-test-calculator",
  "inputs": [
    {
      "id": "sampleSize",
      "label": "Sample Size (n)",
      "type": "number",
      "unit": "unit",
      "default": 30,
      "businessContext": "Number of observations in the sample",
      "label_i18n": {
        "en": "Sample Size (n)",
        "tr": "Sample Size (n)",
        "de": "Sample Size (n)",
        "fr": "Sample Size (n)",
        "es": "Sample Size (n)",
        "ar": "Sample Size (n)"
      }
    },
    {
      "id": "skewness",
      "label": "Skewness",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Sample skewness coefficient",
      "label_i18n": {
        "en": "Skewness",
        "tr": "Skewness",
        "de": "Skewness",
        "fr": "Skewness",
        "es": "Skewness",
        "ar": "Skewness"
      }
    },
    {
      "id": "excessKurtosis",
      "label": "Excess Kurtosis",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Excess kurtosis (kurtosis - 3)",
      "label_i18n": {
        "en": "Excess Kurtosis",
        "tr": "Excess Kurtosis",
        "de": "Excess Kurtosis",
        "fr": "Excess Kurtosis",
        "es": "Excess Kurtosis",
        "ar": "Excess Kurtosis"
      }
    },
    {
      "id": "criticalZ",
      "label": "Critical Z-value",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Z-score threshold for normality rule of thumb",
      "label_i18n": {
        "en": "Critical Z-value",
        "tr": "Critical Z-value",
        "de": "Critical Z-value",
        "fr": "Critical Z-value",
        "es": "Critical Z-value",
        "ar": "Critical Z-value"
      }
    }
  ],
  "formulas": {
    "isNormal": "(Math.abs(skewness / Math.sqrt(6 / sampleSize)) <= criticalZ && Math.abs(excessKurtosis / Math.sqrt(24 / sampleSize)) <= criticalZ) ? 1 : 0",
    "zSkew": "skewness / Math.sqrt(6 / sampleSize)",
    "zKurt": "excessKurtosis / Math.sqrt(24 / sampleSize)",
    "seSkew": "Math.sqrt(6 / sampleSize)",
    "seKurt": "Math.sqrt(24 / sampleSize)"
  },
  "outputs": {
    "primary": "isNormal",
    "breakdown": [
      "zSkew",
      "zKurt",
      "seSkew",
      "seKurt"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Diğer",
  "premiumRequired": false,

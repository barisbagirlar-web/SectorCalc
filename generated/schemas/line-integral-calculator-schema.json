  "formulas": {
    "dx": "x2 - x1",
    "dy": "y2 - y1",
    "L": "Math.sqrt(dx**2 + dy**2)",
    "ortalama_f": "c0 + cx*x1 + cy*y1 + (cx*dx + cy*dy)/2",
    "integral": "L * ortalama_f"
  },
  "outputs": {
    "primary": "integral",
    "breakdown": [
      "dx = x2 - x1 = {dx} m",
      "dy = y2 - y1 = {dy} m",
      "L = √(dx² + dy²) = {L} m",
      "Ortalama f = c0 + cx*x1 + cy*y1 + (cx*dx + cy*dy)/2 = {ortalama_f} birim/m",
      "İntegral = L * ortalama_f = {integral} birim"
    ]
  },

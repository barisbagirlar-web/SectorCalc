{
  "toolName": "gratuity-calculator",
  "inputs": [
    {
      "id": "billAmount",
      "label": "Bill Amount",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "The total bill amount before tip and any additional charges.",
      "label_i18n": {
        "en": "Bill Amount",
        "tr": "Bill Amount",
        "de": "Bill Amount",
        "fr": "Bill Amount",
        "es": "Bill Amount",
        "ar": "Bill Amount"
      }
    },
    {
      "id": "tipPercentage",
      "label": "Tip Percentage",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "The percentage of the bill to be given as tip.",
      "label_i18n": {
        "en": "Tip Percentage",
        "tr": "Tip Percentage",
        "de": "Tip Percentage",
        "fr": "Tip Percentage",
        "es": "Tip Percentage",
        "ar": "Tip Percentage"
      }
    },
    {
      "id": "numberOfPeople",
      "label": "Number of People",
      "type": "number",
      "unit": "persons",
      "default": 1,
      "businessContext": "The number of people sharing the bill equally.",
      "label_i18n": {
        "en": "Number of People",
        "tr": "Number of People",
        "de": "Number of People",
        "fr": "Number of People",
        "es": "Number of People",
        "ar": "Number of People"
      }
    },
    {
      "id": "serviceChargePercent",
      "label": "Service Charge Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional service charge percentage added to the bill, if any.",
      "label_i18n": {
        "en": "Service Charge Percentage",
        "tr": "Service Charge Percentage",
        "de": "Service Charge Percentage",
        "fr": "Service Charge Percentage",
        "es": "Service Charge Percentage",
        "ar": "Service Charge Percentage"
      }
    }
  ],
  "formulas": {
    "gratuityAmount": "billAmount * tipPercentage / 100",
    "totalBill": "billAmount + (billAmount * tipPercentage / 100) + (billAmount * serviceChargePercent / 100)",
    "perPersonAmount": "(billAmount + (billAmount * tipPercentage / 100) + (billAmount * serviceChargePercent / 100)) / numberOfPeople"
  },
  "outputs": {
    "primary": "gratuityAmount",
    "breakdown": [
      "totalBill",
      "perPersonAmount"
    ],

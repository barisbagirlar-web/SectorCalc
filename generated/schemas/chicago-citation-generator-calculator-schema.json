{
  "toolName": "chicago-citation-generator-calculator",
  "inputs": [
    {
      "id": "numAuthors",
      "label": "Number of Authors",
      "type": "number",
      "unit": "authors",
      "default": 1,
      "businessContext": "Total number of authors in the cited work",
      "label_i18n": {
        "en": "Number of Authors",
        "tr": "Number of Authors",
        "de": "Number of Authors",
        "fr": "Number of Authors",
        "es": "Number of Authors",
        "ar": "Number of Authors"
      }
    },
    {
      "id": "pubYear",
      "label": "Publication Year",
      "type": "number",
      "unit": "year",
      "default": 2024,
      "businessContext": "Year the work was published",
      "label_i18n": {
        "en": "Publication Year",
        "tr": "Publication Year",
        "de": "Publication Year",
        "fr": "Publication Year",
        "es": "Publication Year",
        "ar": "Publication Year"
      }
    },
    {
      "id": "pageCount",
      "label": "Page Count",
      "type": "number",
      "unit": "pages",
      "default": 100,
      "businessContext": "Total number of pages in the cited work",
      "label_i18n": {
        "en": "Page Count",
        "tr": "Page Count",
        "de": "Page Count",
        "fr": "Page Count",
        "es": "Page Count",
        "ar": "Page Count"
      }
    },
    {
      "id": "citationFreq",
      "label": "Citation Frequency",
      "type": "number",
      "unit": "citations/year",
      "default": 5,
      "businessContext": "Average citations per year for this work",
      "label_i18n": {
        "en": "Citation Frequency",
        "tr": "Citation Frequency",
        "de": "Citation Frequency",
        "fr": "Citation Frequency",
        "es": "Citation Frequency",
        "ar": "Citation Frequency"
      }
    },
    {
      "id": "relevance",
      "label": "Relevance Factor",
      "type": "number",
      "unit": "score",
      "default": 0.8,
      "businessContext": "Relevance score from 0 to 1",
      "label_i18n": {
        "en": "Relevance Factor",
        "tr": "Relevance Factor",
        "de": "Relevance Factor",
        "fr": "Relevance Factor",
        "es": "Relevance Factor",
        "ar": "Relevance Factor"
      }
    }
  ],
  "formulas": {
    "authorContrib": "numAuthors * 2.5",
    "yearContrib": "Math.log(pubYear) * 10",
    "pageContrib": "Math.sqrt(pageCount) * 1.5",
    "citationContrib": "citationFreq * relevance * 3",
    "primary": "authorContrib + yearContrib + pageContrib + citationContrib",
    "numAuthors___2_5": "numAuthors * 2.5",
    "log_pubYear____10": "log(pubYear) * 10",
    "sqrt_pageCount____1_5": "sqrt(pageCount) * 1.5",
    "citationFreq___relevance___3": "citationFreq * relevance * 3"
  },
  "outputs": {
    "primary": "authorContrib",
    "breakdown": [
      "Author Contribution: numAuthors * 2.5",
      "Year Contribution: log(pubYear) * 10",
      "Page Contribution: sqrt(pageCount) * 1.5",
      "Frequency & Relevance: citationFreq * relevance * 3"
    ]
  },

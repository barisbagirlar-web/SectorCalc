{
  "toolName": "hasi-calculator",
  "inputs": [
    {
      "id": "operatingPressure",
      "label": "Operating Pressure",
      "type": "number",
      "unit": "bar",
      "default": 100,
      "businessContext": "System working pressure affects stress on components.",
      "label_i18n": {
        "en": "Operating Pressure",
        "tr": "Operating Pressure",
        "de": "Operating Pressure",
        "fr": "Operating Pressure",
        "es": "Operating Pressure",
        "ar": "Operating Pressure"
      }
    },
    {
      "id": "operatingTemperature",
      "label": "Operating Temperature",
      "type": "number",
      "unit": "°C",
      "default": 80,
      "businessContext": "Elevated temperatures reduce material strength and increase corrosion rates.",
      "label_i18n": {
        "en": "Operating Temperature",
        "tr": "Operating Temperature",
        "de": "Operating Temperature",
        "fr": "Operating Temperature",
        "es": "Operating Temperature",
        "ar": "Operating Temperature"
      }
    },
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "L/min",
      "default": 200,
      "businessContext": "Fluid velocity contributes to erosion and vibration risks.",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Flow Rate",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      }
    },
    {
      "id": "vibrationLevel",
      "label": "Vibration Level",
      "type": "number",
      "unit": "mm/s",
      "default": 5,
      "businessContext": "Vibration can cause fatigue and joint loosening.",
      "label_i18n": {
        "en": "Vibration Level",
        "tr": "Vibration Level",
        "de": "Vibration Level",
        "fr": "Vibration Level",
        "es": "Vibration Level",
        "ar": "Vibration Level"
      }
    },
    {
      "id": "wallThickness",
      "label": "Wall Thickness",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Thinner walls are more susceptible to failure under pressure and corrosion.",
      "label_i18n": {
        "en": "Wall Thickness",
        "tr": "Wall Thickness",
        "de": "Wall Thickness",
        "fr": "Wall Thickness",
        "es": "Wall Thickness",
        "ar": "Wall Thickness"
      }
    },
    {
      "id": "corrosionRate",
      "label": "Corrosion Rate",
      "type": "number",
      "unit": "mm/year",
      "default": 0.1,
      "businessContext": "Material loss over time reduces structural integrity.",
      "label_i18n": {
        "en": "Corrosion Rate",
        "tr": "Corrosion Rate",
        "de": "Corrosion Rate",
        "fr": "Corrosion Rate",
        "es": "Corrosion Rate",
        "ar": "Corrosion Rate"
      }
    }
  ],
  "formulas": {
    "hasiScore": "100 - ((operatingPressure/250*100 + (operatingTemperature-20) + flowRate/500*100 + vibrationLevel/25*100 + (1-wallThickness/20)*100 + corrosionRate/0.5*100) / 6)",
    "pressureRisk": "operatingPressure/250*100",
    "temperatureRisk": "operatingTemperature-20",
    "flowErosionRisk": "flowRate/500*100",
    "vibrationRisk": "vibrationLevel/25*100",
    "wallThinningRisk": "(1-wallThickness/20)*100",
    "corrosionRisk": "corrosionRate/0.5*100"
  },
  "outputs": {
    "primary": "hasiScore",
    "breakdown": [
      "pressureRisk",
      "temperatureRisk",
      "flowErosionRisk",
      "vibrationRisk",
      "wallThinningRisk",
      "corrosionRisk"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "corrosionRisk"
  },

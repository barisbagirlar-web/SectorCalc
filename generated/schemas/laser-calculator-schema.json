      }
    },
    {
      "id": "setupTime",
      "label": "Setup Time",
      "type": "number",
      "unit": "min",
      "default": 5,
      "businessContext": "Time required to load/unload material and set up the machine",
      "label_i18n": {
        "en": "Setup Time",
        "tr": "Kurulum Süresi",
        "de": "Rüstzeit",
        "fr": "Setup Time",
        "es": "Setup Time",
        "ar": "Setup Time"
      },
      "businessContext_i18n": {
        "en": "Time required to load/unload material and set up the machine",
        "tr": "Malzeme yükleme/boşaltma ve makine kurulumu için gereken süre"
      }
    }
  ],
  "formulas": {
    "totalCuttingTime": "cutLength / cuttingSpeed + setupTime",
    "effectivePower": "laserPower * materialAbsorption",
    "energy": "effectivePower * (totalCuttingTime / 60) / 1000",
    "materialRemovalRate": "kerfWidth * materialThickness * (cuttingSpeed / 60)",
    "cost": "operatingCost * (totalCuttingTime / 60)"
  },
  "outputs": {
    "primary": "cost",
    "breakdown": [
      "totalCuttingTime",
      "energy",
      "materialRemovalRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "cost",
    "unit": "W"
  },

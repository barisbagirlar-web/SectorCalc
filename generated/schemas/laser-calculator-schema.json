    },
    {
      "id": "cutLength",
      "label": "Total Cut Length",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "businessContext": "Total length of the laser cut path for the job",
      "label_i18n": {
        "en": "Total Cut Length",
        "tr": "Toplam kesim uzunluğu",

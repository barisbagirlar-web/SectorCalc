  "formulas": {
    "totalPixels": "(screenWidth) * (screenHeight) * (screenDiagonal) * (aspectRatioX) * (aspectRatioY)",
    "totalPixelsMP": "(screenWidth) * (screenHeight) * (screenDiagonal)",
    "aspectDecimal": "(screenWidth) * (screenHeight) * (screenDiagonal)"
  },
  "outputs": {
    "primary": "totalPixels",
    "breakdown": [
      "Resolution: {screenWidth} x {screenHeight}",
      "Aspect Ratio: {aspectDecimal} (Custom: {aspectRatioX}:{aspectRatioY})",
      "Total Pixels: {totalPixels} (~{totalPixelsMP} MP)",
      "Screen Width: {screenWidthInches} in",
      "Screen Height: {screenHeightInches} in",
      "Pixel Pitch: {pixelPitch} mm"

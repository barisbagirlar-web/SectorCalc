{
  "toolName": "stripe-fee-calculator",
  "inputs": [
    {
      "id": "transactionAmount",
      "label": "Transaction Amount",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Total amount of the transaction including taxes.",
      "label_i18n": {
        "en": "Transaction Amount",
        "tr": "Transaction Amount",
        "de": "Transaction Amount",
        "fr": "Transaction Amount",
        "es": "Transaction Amount",
        "ar": "Transaction Amount"
      }
    },
    {
      "id": "percentageFee",
      "label": "Processing Fee Percentage",
      "type": "number",
      "unit": "%",
      "default": 2.9,
      "businessContext": "The percentage fee for domestic card processing (e.g., 2.9% for Stripe).",
      "label_i18n": {
        "en": "Processing Fee Percentage",
        "tr": "Processing Fee Percentage",
        "de": "Processing Fee Percentage",
        "fr": "Processing Fee Percentage",
        "es": "Processing Fee Percentage",
        "ar": "Processing Fee Percentage"
      }
    },
    {
      "id": "fixedFee",
      "label": "Fixed Fee",
      "type": "number",
      "unit": "USD",
      "default": 0.3,
      "businessContext": "The fixed fee per transaction (e.g., $0.30 for Stripe).",
      "label_i18n": {
        "en": "Fixed Fee",
        "tr": "Fixed Fee",
        "de": "Fixed Fee",
        "fr": "Fixed Fee",
        "es": "Fixed Fee",
        "ar": "Fixed Fee"
      }
    },
    {
      "id": "extraPercentage",
      "label": "Additional Fee Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional percentage for international cards or currency conversion (Stripe adds 1% for international, another 1% for conversion if needed).",
      "label_i18n": {
        "en": "Additional Fee Percentage",
        "tr": "Additional Fee Percentage",
        "de": "Additional Fee Percentage",
        "fr": "Additional Fee Percentage",
        "es": "Additional Fee Percentage",
        "ar": "Additional Fee Percentage"
      }
    }
  ],
  "formulas": {
    "processingFee": "transactionAmount * (percentageFee / 100)",
    "extraFee": "transactionAmount * (extraPercentage / 100)",
    "totalFee": "transactionAmount * (percentageFee / 100) + fixedFee + transactionAmount * (extraPercentage / 100)",
    "netAmount": "transactionAmount - (transactionAmount * (percentageFee / 100) + fixedFee + transactionAmount * (extraPercentage / 100))"
  },
  "outputs": {
    "primary": "totalFee",
    "breakdown": [
      "processingFee",
      "extraFee",
      "fixedFee",
      "netAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netAmount"
  },

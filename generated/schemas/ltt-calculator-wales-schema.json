      }
    },
    {
      "id": "co2_emission_factor_kg_per_l",
      "label": "CO2 Emission Factor (kg/L)",
      "type": "number",
      "unit": "kg/L",
      "default": 2.68,
      "businessContext": "CO2 emissions per litre of fuel consumed.",
      "label_i18n": {
        "en": "CO2 Emission Factor (kg/L)",
        "tr": "CO2 Emission Factor (kg/L)",
        "de": "CO2 Emission Factor (kg/L)",
        "fr": "CO2 Emission Factor (kg/L)",
        "es": "CO2 Emission Factor (kg/L)",
        "ar": "CO2 Emission Factor (kg/L)"
      }
    }
  ],
  "formulas": {
    "total_fuel_cost": "distance_km * (fuel_consumption_l_per_100km / 100) * fuel_price_gbp_per_l",
    "travel_time_hours": "distance_km / average_speed_kmh",
    "driver_cost": "travel_time_hours * driver_wage_gbp_per_hour",
    "total_cost": "total_fuel_cost + driver_cost",
    "cost_per_tonne_km": "total_cost / (distance_km * load_tonnes)",
    "total_co2_kg": "distance_km * (fuel_consumption_l_per_100km / 100) * co2_emission_factor_kg_per_l"
  },
  "outputs": {
    "primary": "total_cost",
    "breakdown": [
      "total_fuel_cost",
      "driver_cost",
      "cost_per_tonne_km",
      "total_co2_kg"
    ],

      "unit": "seconds",
      "default": 1,
      "businessContext": "Time available for transfer",
      "label_i18n": {
        "en": "Transfer Time",
        "tr": "Aktarım Süresi",
        "de": "Transferzeit",
        "fr": "Temps de transfert",
        "es": "Tiempo de transferencia",
        "ar": "Transfer Time"
      },
      "businessContext_i18n": {
        "en": "Time available for transfer",
        "tr": "Aktarım için mevcut süre",
        "de": "Verfügbare Zeit für den Transfer",
        "fr": "Temps disponible pour le transfert",
        "es": "Tiempo disponible para transferencia"
      }
    },
    {
      "id": "protocolOverhead",
      "label": "Protocol Overhead",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage overhead added by protocol headers",
      "label_i18n": {
        "en": "Protocol Overhead",
        "tr": "Protokol Ek Yükü",
        "de": "Protokoll-Overhead",
        "fr": "Surcharge de protocole",
        "es": "Sobrecarga de protocolo",
        "ar": "Protocol Overhead"
      },
      "businessContext_i18n": {
        "en": "Percentage overhead added by protocol headers",
        "tr": "Protokol başlıkları tarafından eklenen yüzde ek yük",
        "de": "Prozentualer Overhead durch Protokollheader",
        "fr": "Pourcentage de surcharge ajouté par les en-têtes de protocole",
        "es": "Porcentaje de sobrecarga añadido por las cabeceras del protocolo"
      }
    },
    {
      "id": "channels",
      "label": "Number of Channels",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Number of parallel communication channels",
      "label_i18n": {
        "en": "Number of Channels",
        "tr": "Kanal Sayısı",
        "de": "Anzahl der Kanäle",
        "fr": "Nombre de canaux",
        "es": "Número de canales",
        "ar": "Number of Channels"
      },
      "businessContext_i18n": {
        "en": "Number of parallel communication channels",
        "tr": "Paralel iletişim kanalı sayısı",
        "de": "Anzahl paralleler Kommunikationskanäle",
        "fr": "Nombre de canaux de communication parallèles",
        "es": "Número de canales de comunicación paralelos"
      }
    },
    {
      "id": "encodingEfficiency",
      "label": "Encoding Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Efficiency of encoding scheme (e.g., 8b/10b is 80%)",
      "label_i18n": {
        "en": "Encoding Efficiency",
        "tr": "Kodlama Verimliliği",
        "de": "Codierungseffizienz",
        "fr": "Efficacité du codage",
        "es": "Eficiencia de codificación",
        "ar": "Encoding Efficiency"
      },
      "businessContext_i18n": {
        "en": "Efficiency of encoding scheme (e.g., 8b/10b is 80%)",
        "tr": "Kodlama şemasının verimliliği (ör. 8b/10b için %80)",
        "de": "Effizienz des Codierungsschemas (z.B. 8b/10b ist 80%)",
        "fr": "Efficacité du schéma de codage (ex. 8b/10b est 80%)",
        "es": "Eficiencia del esquema de codificación (ej. 8b/10b es 80%)"
      }
    },
    {
      "id": "redundancyFactor",
      "label": "Redundancy Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Multiplicative redundancy for error correction (e.g., FEC code rate inverse)",
      "label_i18n": {
        "en": "Redundancy Factor",
        "tr": "Yedeklilik Faktörü",
        "de": "Redundanzfaktor",
        "fr": "Facteur de redondance",
        "es": "Factor de redundancia",
        "ar": "Redundancy Factor"
      },
      "businessContext_i18n": {
        "en": "Multiplicative redundancy for error correction (e.g., FEC code rate inverse)",
        "tr": "Hata düzeltme için çarpımsal yedeklilik (ör. FEC kod oranı tersi)",
        "de": "Multiplikative Redundanz für Fehlerkorrektur (z.B. Kehrwert der FEC-Coderate)",
        "fr": "Redondance multiplicative pour la correction d'erreurs (ex. inverse du taux de code FEC)",
        "es": "Redundancia multiplicativa para corrección de errores (ej. inverso de tasa de código FEC)"
      }
    }
  ],
  "formulas": {
    "effectiveData": "dataSize * (1 + protocolOverhead / 100) * redundancyFactor",
    "requiredTotalBandwidth": "effectiveData / transferTime",
    "bandwidthPerChannel": "requiredTotalBandwidth / (channels * (encodingEfficiency / 100))"
  },
  "outputs": {
    "primary": "bandwidthPerChannel",
    "breakdown": [
      "effectiveData",
      "requiredTotalBandwidth"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bandwidthPerChannel",
    "unit": "bits"
  },

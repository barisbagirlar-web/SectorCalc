  "formulas": {
    "grossFee": "transactionAmount * (feePercentage / 100) + fixedFee",
    "taxAmount": "grossFee * (taxRate / 100)",
    "totalFee": "grossFee + taxAmount",
    "totalTransactionCost": "transactionAmount + totalFee"
  },
  "outputs": {
    "primary": "totalFee",
    "breakdown": [
      "grossFee",
      "taxAmount",
      "totalTransactionCost"

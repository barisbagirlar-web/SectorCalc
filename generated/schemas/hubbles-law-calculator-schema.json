  "formulas": {
    "recessionalVelocity": "speedOfLight * ((redshift + 1)**2 - 1) / ((redshift + 1)**2 + 1)",
    "distanceMpc": "recessionalVelocity / hubbleConstant",
    "distanceLy": "distanceMpc * 3.261563777",
    "lookbackTimeGyr": "distanceMpc / (hubbleConstant * 1.022712165e-3)",
    "comovingDistance": "distanceMpc * (1 + redshift)",
    "luminosityDistance": "comovingDistance * (1 + redshift)"
  },
  "outputs": {

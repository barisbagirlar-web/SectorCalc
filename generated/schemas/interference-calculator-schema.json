    },
    {
      "id": "pathDifference",
      "label": "Path Difference",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Difference in path lengths from the two sources to the point of interest",
      "label_i18n": {
        "en": "Path Difference",
        "tr": "Path Difference",
        "de": "Path Difference",
        "fr": "Path Difference",
        "es": "Path Difference",
        "ar": "Path Difference"
      }
    }
  ],
  "formulas": {
    "resultantAmplitude": "Math.sqrt(inputs.amplitude1**2 + inputs.amplitude2**2 + 2 * inputs.amplitude1 * inputs.amplitude2 * Math.cos(2 * Math.PI * inputs.pathDifference / inputs.wavelength))",
    "intensity": "Math.pow(Math.sqrt(inputs.amplitude1**2 + inputs.amplitude2**2 + 2 * inputs.amplitude1 * inputs.amplitude2 * Math.cos(2 * Math.PI * inputs.pathDifference / inputs.wavelength)), 2)",
    "phaseDifferenceDeg": "(inputs.pathDifference / inputs.wavelength) * 360",
    "interferenceType": "Math.abs((inputs.pathDifference / inputs.wavelength * 360) % 360) < 1e-10 ? 'Constructive' : Math.abs(((inputs.pathDifference / inputs.wavelength * 360) % 360) - 180) < 1e-10 ? 'Destructive' : 'Intermediate'"
  },
  "outputs": {
    "primary": "resultantAmplitude",
    "breakdown": [
      "intensity",
      "phaseDifferenceDeg",
      "interferenceType"
    ]
  },

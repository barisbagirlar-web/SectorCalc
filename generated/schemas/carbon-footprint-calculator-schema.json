  "formulas": {
    "totalCO2": "electricity_kwh * 0.5 + natural_gas_m3 * 2 + fuel_liters * 2.3 + waste_kg * 0.5 + water_m3 * 0.3",
    "electricityCO2": "electricity_kwh * 0.5",
    "naturalGasCO2": "natural_gas_m3 * 2",
    "fuelCO2": "fuel_liters * 2.3",
    "wasteCO2": "waste_kg * 0.5",
    "waterCO2": "water_m3 * 0.3"
  },
  "outputs": {
    "primary": "waterCO2",
    "breakdown": [

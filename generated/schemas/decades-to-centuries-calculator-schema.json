        "es": "Temperatura de medición (°C)",
        "ar": "درجة حرارة القياس (°C)"
      },
      "businessContext_i18n": {
        "en": "Ambient temperature of measurement (for traceability)",
        "tr": "Ölçümün yapıldığı ortam sıcaklığı (izlenebilirlik için)",
        "de": "Umgebungstemperatur bei der Messung (für Rückverfolgbarkeit)",

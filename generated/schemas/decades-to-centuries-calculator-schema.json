  "formulas": {
    "rawCenturies": "(decades) * (precision) * (confidenceLevel) * (measurementError) * (roundingMethod) * (ambientTemp)",
    "lowerBound": "(decades) * (precision) * (confidenceLevel)",
    "upperBound": "(decades) * (precision) * (confidenceLevel)"
  },
  "outputs": {
    "primary": "upperBound",
    "breakdown": [
      "rawCenturies",
      "lowerBound",
      "upperBound",
      "roundedCenturies",
      "adjustedLower",
      "adjustedUpper"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "upperBound",
    "unit": "yüzyıl"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Birim & Dönüşüm",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "birim-donusum",
  "profession": "Mühendis",
  "categoryId": "conversion",
  "validation": {
    "rules": [
      {
        "field": "decades",
        "rule": "gt",
        "value": 0,
        "message": "Decades must be greater than 0"
      },
      {
        "field": "precision",
        "rule": "gte",
        "value": 0,
        "message": "Precision must be non-negative"
      },
      {
        "field": "confidenceLevel",
        "rule": "between",
        "value": [
          0,
          100
        ],
        "message": "Confidence level must be between 0 and 100"
      },
      {
        "field": "measurementError",
        "rule": "gte",
        "value": 0,
        "message": "Measurement error must be non-negative"
      },
      {
        "field": "roundingMethod",
        "rule": "in",
        "value": [
          0,
          1,
          2
        ],
        "message": "Rounding method must be 0, 1, or 2"
      }
    ],
    "thresholds": {}
  },
  "premiumFeatures": [],
  "domainModel": "time"
}

{
  "toolName": "noise-exposure-calculator",
  "inputs": [
    {
      "id": "noiseLevel",
      "label": "Noise Level",
      "type": "number",
      "unit": "dB(A)",
      "default": 90,
      "businessContext": "Measured continuous noise level in A-weighted decibels",
      "label_i18n": {
        "en": "Noise Level",
        "tr": "Noise Level",
        "de": "Noise Level",
        "fr": "Noise Level",
        "es": "Noise Level",
        "ar": "Noise Level"
      }
    },
    {
      "id": "exposureTime",
      "label": "Exposure Time",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Total daily noise exposure duration",
      "label_i18n": {
        "en": "Exposure Time",
        "tr": "Exposure Time",
        "de": "Exposure Time",
        "fr": "Exposure Time",
        "es": "Exposure Time",
        "ar": "Exposure Time"
      }
    },
    {
      "id": "exchangeRate",
      "label": "Exchange Rate",
      "type": "number",
      "unit": "dB",
      "default": 3,
      "businessContext": "Decibel exchange rate (3 for equal energy, 5 for OSHA)",
      "label_i18n": {
        "en": "Exchange Rate",
        "tr": "Exchange Rate",
        "de": "Exchange Rate",
        "fr": "Exchange Rate",
        "es": "Exchange Rate",
        "ar": "Exchange Rate"
      }
    },
    {
      "id": "criterionLevel",
      "label": "Criterion Level",
      "type": "number",
      "unit": "dB(A)",
      "default": 85,
      "businessContext": "Permissible noise level for an 8-hour shift",
      "label_i18n": {
        "en": "Criterion Level",
        "tr": "Criterion Level",
        "de": "Criterion Level",
        "fr": "Criterion Level",
        "es": "Criterion Level",
        "ar": "Criterion Level"
      }
    },
    {
      "id": "thresholdLevel",
      "label": "Threshold Level",
      "type": "number",
      "unit": "dB(A)",
      "default": 0,
      "businessContext": "Level below which noise is ignored (0 = no threshold)",
      "label_i18n": {
        "en": "Threshold Level",
        "tr": "Threshold Level",
        "de": "Threshold Level",
        "fr": "Threshold Level",
        "es": "Threshold Level",
        "ar": "Threshold Level"
      }
    }
  ],
  "formulas": {
    "dose": "noiseLevel < thresholdLevel ? 0 : (exposureTime / (8 / Math.pow(2, (noiseLevel - criterionLevel) / exchangeRate))) * 100",
    "twa": "dose === 0 ? 0 : exchangeRate * (Math.log(dose / 100) / Math.LN2) + criterionLevel",
    "allowableTime": "noiseLevel < thresholdLevel ? Infinity : 8 / Math.pow(2, (noiseLevel - criterionLevel) / exchangeRate)"
  },
  "outputs": {
    "primary": "dose",
    "breakdown": [
      {
        "id": "twa",
        "label": "Time-Weighted Average",
        "unit": "dB(A)"
      },
      {
        "id": "allowableTime",
        "label": "Allowable Exposure Time",
        "unit": "hours"
      }
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "conversion"
}

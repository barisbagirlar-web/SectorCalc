        "tr": "Cevherdeki demir kütle yüzdesi"
      }
    },
    {
      "id": "moistureContent",
      "label": "Moisture Content",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Moisture mass percentage in the ore",
      "label_i18n": {
        "en": "Moisture Content",
        "tr": "Nem İçeriği",
        "de": "Moisture Content",
        "fr": "Moisture Content",

    {
      "id": "ironConcentration",
      "label": "Iron Concentration",
      "type": "number",
      "unit": "%",
      "default": 62,
      "businessContext": "Mass percentage of iron in the ore",
      "label_i18n": {
        "en": "Iron Concentration",
        "tr": "Demir Konsantrasyonu",
        "de": "Iron Concentration",
        "fr": "Iron Concentration",

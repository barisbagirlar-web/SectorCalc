        "ar": "Moisture Content"
      },
      "businessContext_i18n": {
        "en": "Moisture mass percentage in the ore",
        "tr": "Cevherdeki nem kütle yüzdesi"
      }
    },
    {
      "id": "recoveryRate",
      "label": "Recovery Rate",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Expected percentage of iron recovered from ore after processing",
      "label_i18n": {
        "en": "Recovery Rate",
        "tr": "Geri Kazanım Oranı",
        "de": "Rückgewinnungsrate",
        "fr": "Recovery Rate",
        "es": "Recovery Rate",
        "ar": "Recovery Rate"
      },
      "businessContext_i18n": {
        "en": "Expected percentage of iron recovered from ore after processing",
        "tr": "İşleme sonrası cevherden geri kazanılan beklenen demir yüzdesi"
      }
    }
  ],
  "formulas": {
    "dryMass": "oreMass * (1 - moistureContent / 100)",
    "ironMass": "dryMass * (ironConcentration / 100)",
    "netIron": "ironMass * (recoveryRate / 100)"
  },
  "outputs": {
    "primary": "netIron",
    "breakdown": [
      "dryMass",
      "ironMass"

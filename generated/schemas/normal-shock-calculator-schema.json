{
  "toolName": "normal-shock-calculator",
  "inputs": [
    {
      "id": "upstreamMach",
      "label": "Upstream Mach Number",
      "type": "number",
      "unit": "dimensionless",
      "default": 2,
      "businessContext": "Enter the Mach number before the shock (M1 > 1 for normal shock).",
      "label_i18n": {
        "en": "Upstream Mach Number",
        "tr": "Yukarı Akış Mach Sayısı",
        "de": "Upstream Mach Number",
        "fr": "Upstream Mach Number",
        "es": "Upstream Mach Number",
        "ar": "Upstream Mach Number"
      },
      "businessContext_i18n": {
        "en": "Enter the Mach number before the shock (M1 > 1 for normal shock).",
        "tr": "Şok öncesi Mach sayısını girin (normal şok için M1 > 1)."
      }
    },
    {
      "id": "gamma",
      "label": "Specific Heat Ratio",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.4,
      "businessContext": "Ratio of specific heats (Cp/Cv), typically 1.4 for air.",
      "label_i18n": {
        "en": "Specific Heat Ratio",
        "tr": "Özgül ısı oranı",
        "de": "Specific Heat Ratio",
        "fr": "Specific Heat Ratio",
        "es": "Specific Heat Ratio",
        "ar": "Specific Heat Ratio"
      },
      "businessContext_i18n": {
        "en": "Ratio of specific heats (Cp/Cv), typically 1.4 for air.",
        "tr": "Özgül ısı oranı (Cp/Cv), tipik olarak hava için 1.4."
      }
    },
    {
      "id": "upstreamPressure",
      "label": "Upstream Static Pressure",
      "type": "number",
      "unit": "Pa",
      "default": 101325,
      "businessContext": "Absolute static pressure before shock (optional for absolute values).",
      "label_i18n": {
        "en": "Upstream Static Pressure",
        "tr": "Yukarı Akış Statik Basıncı",
        "de": "Upstream Static Pressure",
        "fr": "Upstream Static Pressure",
        "es": "Upstream Static Pressure",
        "ar": "Upstream Static Pressure"
      },
      "businessContext_i18n": {
        "en": "Absolute static pressure before shock (optional for absolute values).",
        "tr": "Şok öncesi mutlak statik basınç (mutlak değerler için isteğe bağlı)."
      }
    },
    {
      "id": "upstreamTemperature",
      "label": "Upstream Static Temperature",
      "type": "number",
      "unit": "K",
      "default": 300,
      "businessContext": "Absolute static temperature before shock (optional for absolute values).",
      "label_i18n": {
        "en": "Upstream Static Temperature",
        "tr": "Yukarı Akış Statik Sıcaklığı",
        "de": "Upstream Static Temperature",
        "fr": "Upstream Static Temperature",
        "es": "Upstream Static Temperature",
        "ar": "Upstream Static Temperature"
      },
      "businessContext_i18n": {
        "en": "Absolute static temperature before shock (optional for absolute values).",
        "tr": "Şok öncesi mutlak statik sıcaklık (mutlak değerler için isteğe bağlı)."
      }
    }
  ],
  "formulas": {
    "pressureRatio": "1 + (2*gamma/(gamma+1))*(upstreamMach**2 - 1)",
    "temperatureRatio": "(1 + (2*gamma/(gamma+1))*(upstreamMach**2 - 1)) * ((2 + (gamma-1)*upstreamMach**2)/((gamma+1)*upstreamMach**2))",
    "densityRatio": "(gamma+1)*upstreamMach**2 / (2 + (gamma-1)*upstreamMach**2)",
    "stagnationPressureRatio": "(( (gamma+1)*upstreamMach**2 )/(2 + (gamma-1)*upstreamMach**2))**(gamma/(gamma-1)) * ((gamma+1)/(2*gamma*upstreamMach**2 - (gamma-1)))**(1/(gamma-1))",
    "downstreamPressure": "pressureRatio * upstreamPressure",
    "downstreamTemperature": "temperatureRatio * upstreamTemperature"
  },
  "outputs": {
    "primary": "downstreamTemperature",
    "breakdown": [
      "pressureRatio",
      "temperatureRatio",
      "densityRatio",
      "stagnationPressureRatio",
      "downstreamPressure",
      "downstreamTemperature"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "downstreamTemperature",
    "unit": "°C",
    "breakdownUnits": {
      "pressureRatio": "%",
      "temperatureRatio": "%",
      "densityRatio": "%",
      "stagnationPressureRatio": "%",
      "downstreamPressure": "A",
      "downstreamTemperature": "°C"
    }
  },

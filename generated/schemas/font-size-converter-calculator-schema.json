{
  "toolName": "font-size-converter-calculator",
  "inputs": [
    {
      "id": "fontSizePt",
      "label": "Font Size (Points)",
      "type": "number",
      "unit": "pt",
      "default": 12,
      "businessContext": "The font size in points (1 pt = 1/72 inch). Standard sizes: 10, 11, 12, 14.",
      "label_i18n": {
        "en": "Font Size (Points)",
        "tr": "Font Size (Points)",
        "de": "Font Size (Points)",
        "fr": "Font Size (Points)",
        "es": "Font Size (Points)",
        "ar": "Font Size (Points)"
      }
    },
    {
      "id": "ppi",
      "label": "Screen PPI",
      "type": "number",
      "unit": "ppi",
      "default": 96,
      "businessContext": "Pixel density (pixels per inch) of the target display. Common: 96 (Windows), 72 (Mac).",
      "label_i18n": {
        "en": "Screen PPI",
        "tr": "Screen PPI",
        "de": "Screen PPI",
        "fr": "Screen PPI",
        "es": "Screen PPI",
        "ar": "Screen PPI"
      }
    },
    {
      "id": "baseFontSizePx",
      "label": "Base Font Size (Pixels)",
      "type": "number",
      "unit": "px",
      "default": 16,
      "businessContext": "Browser default root font size in pixels, used for em/percentage calculation. Typically 16px.",
      "label_i18n": {
        "en": "Base Font Size (Pixels)",
        "tr": "Base Font Size (Pixels)",
        "de": "Base Font Size (Pixels)",
        "fr": "Base Font Size (Pixels)",
        "es": "Base Font Size (Pixels)",
        "ar": "Base Font Size (Pixels)"
      }
    },
    {
      "id": "rootFontSizePx",
      "label": "Root Font Size (Pixels)",
      "type": "number",
      "unit": "px",
      "default": 16,
      "businessContext": "Explicit root element font size for rem calculation. Default equals base font size.",
      "label_i18n": {
        "en": "Root Font Size (Pixels)",
        "tr": "Root Font Size (Pixels)",
        "de": "Root Font Size (Pixels)",
        "fr": "Root Font Size (Pixels)",
        "es": "Root Font Size (Pixels)",
        "ar": "Root Font Size (Pixels)"
      }
    },
    {
      "id": "customScale",
      "label": "Custom Scaling Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 1,
      "businessContext": "Additional multiplicative factor for custom-converted size (e.g., 1.2 for 120%).",
      "label_i18n": {
        "en": "Custom Scaling Ratio",
        "tr": "Custom Scaling Ratio",
        "de": "Custom Scaling Ratio",
        "fr": "Custom Scaling Ratio",
        "es": "Custom Scaling Ratio",
        "ar": "Custom Scaling Ratio"
      }
    }
  ],
  "formulas": {
    "px": "fontSizePt * ppi / 72",
    "em": "px / baseFontSizePx",
    "rem": "px / rootFontSizePx",
    "percentage": "(px / baseFontSizePx) * 100",
    "mm": "fontSizePt * 0.3528",
    "inches": "fontSizePt / 72",
    "customPx": "px * customScale"
  },
  "outputs": {
    "primary": "px",
    "breakdown": [
      "em",
      "rem",
      "percentage",
      "mm",
      "inches",
      "customPx"
    ],

{
  "toolName": "decimal-to-hex-calculator",
  "inputs": [
    {
      "id": "decimalNumber",
      "label": "Decimal Number",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "The decimal integer to convert to hexadecimal. Non-negative, integer.",
      "label_i18n": {
        "en": "Decimal Number",
        "tr": "Decimal Number",
        "de": "Decimal Number",
        "fr": "Decimal Number",
        "es": "Decimal Number",
        "ar": "Decimal Number"
      }
    },
    {
      "id": "minLength",
      "label": "Minimum Length",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Minimum number of hexadecimal digits. Pads with leading zeros if result is shorter.",
      "label_i18n": {
        "en": "Minimum Length",
        "tr": "Minimum Length",
        "de": "Minimum Length",
        "fr": "Minimum Length",
        "es": "Minimum Length",
        "ar": "Minimum Length"
      }
    },
    {
      "id": "uppercase",
      "label": "Uppercase",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Set to 1 to output uppercase letters (A-F), 0 for lowercase (a-f).",
      "label_i18n": {
        "en": "Uppercase",
        "tr": "Uppercase",
        "de": "Uppercase",
        "fr": "Uppercase",
        "es": "Uppercase",
        "ar": "Uppercase"
      }
    },
    {
      "id": "prefix",
      "label": "Prefix",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0: no prefix; 1: prefix '0x'; 2: prefix '0X'.",
      "label_i18n": {
        "en": "Prefix",
        "tr": "Prefix",
        "de": "Prefix",
        "fr": "Prefix",
        "es": "Prefix",
        "ar": "Prefix"
      }
    }
  ],
  "formulas": {
    "rawHex": "Math.floor(Math.abs(decimalNumber)).toString(16)",
    "padded": "minLength > 0 ? rawHex.padStart(Math.round(minLength), '0') : rawHex",
    "cased": "uppercase === 1 ? padded.toUpperCase() : padded.toLowerCase()",
    "finalHex": "prefix === 1 ? '0x' + cased : (prefix === 2 ? '0X' + cased : cased)"
  },
  "outputs": {
    "primary": "finalHex",
    "breakdown": [
      "rawHex",
      "cased"
    ]
  },

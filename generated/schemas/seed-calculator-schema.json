{
  "toolName": "seed-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Field Area",
      "type": "number",
      "unit": "ha",
      "default": 1,
      "businessContext": "Total field area in hectares.",
      "label_i18n": {
        "en": "Field Area",
        "tr": "Field Area",
        "de": "Field Area",
        "fr": "Field Area",
        "es": "Field Area",
        "ar": "Field Area"
      }
    },
    {
      "id": "plantDensity",
      "label": "Target Plant Density",
      "type": "number",
      "unit": "plants/m²",
      "default": 200,
      "businessContext": "Desired number of plants per square meter after emergence.",
      "label_i18n": {
        "en": "Target Plant Density",
        "tr": "Target Plant Density",
        "de": "Target Plant Density",
        "fr": "Target Plant Density",
        "es": "Target Plant Density",
        "ar": "Target Plant Density"
      }
    },
    {
      "id": "germinationRate",
      "label": "Germination Rate",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Expected percentage of seeds that will germinate under normal conditions.",
      "label_i18n": {
        "en": "Germination Rate",
        "tr": "Germination Rate",
        "de": "Germination Rate",
        "fr": "Germination Rate",
        "es": "Germination Rate",
        "ar": "Germination Rate"
      }
    },
    {
      "id": "seedPurity",
      "label": "Seed Purity",
      "type": "number",
      "unit": "%",
      "default": 98,
      "businessContext": "Percentage of pure, viable seeds in the lot (excludes inert matter and other crop seeds).",
      "label_i18n": {
        "en": "Seed Purity",
        "tr": "Seed Purity",
        "de": "Seed Purity",
        "fr": "Seed Purity",
        "es": "Seed Purity",
        "ar": "Seed Purity"
      }
    },
    {
      "id": "tkw",
      "label": "Thousand Kernel Weight",
      "type": "number",
      "unit": "g",
      "default": 35,
      "businessContext": "Weight of 1000 kernels in grams, indicating seed size and quality.",
      "label_i18n": {
        "en": "Thousand Kernel Weight",
        "tr": "Thousand Kernel Weight",
        "de": "Thousand Kernel Weight",
        "fr": "Thousand Kernel Weight",
        "es": "Thousand Kernel Weight",
        "ar": "Thousand Kernel Weight"
      }
    }
  ],
  "formulas": {
    "totalSeedWeight": "((area * 10000) * plantDensity / ((germinationRate / 100) * (seedPurity / 100))) * (tkw / 1000000)",
    "seedRate": "(plantDensity / ((germinationRate / 100) * (seedPurity / 100))) * tkw / 100",
    "totalPlantsExpected": "area * 10000 * plantDensity"
  },
  "outputs": {
    "primary": "totalSeedWeight",
    "breakdown": [
      "seedRate",
      "totalPlantsExpected"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPlantsExpected",
    "unit": "ha"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Tarım & Hayvancılık",
  "premiumRequired": false,

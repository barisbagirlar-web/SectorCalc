{
  "toolName": "watts-to-calories-calculator",
  "inputs": [
    {
      "id": "watts",
      "label": "Power (Watts)",
      "type": "number",
      "unit": "W",
      "default": 100,
      "businessContext": "Input power in watts (e.g., electrical device rating).",
      "label_i18n": {
        "en": "Power (Watts)",
        "tr": "Power (Watts)",
        "de": "Power (Watts)",
        "fr": "Power (Watts)",
        "es": "Power (Watts)",
        "ar": "Power (Watts)"
      }
    },
    {
      "id": "time",
      "label": "Time (seconds)",
      "type": "number",
      "unit": "s",
      "default": 1,
      "businessContext": "Duration of power application in seconds.",
      "label_i18n": {
        "en": "Time (seconds)",
        "tr": "Time (seconds)",
        "de": "Time (seconds)",
        "fr": "Time (seconds)",
        "es": "Time (seconds)",
        "ar": "Time (seconds)"
      }
    },
    {
      "id": "calFactor",
      "label": "Joules per calorie",
      "type": "number",
      "unit": "J/cal",
      "default": 4.184,
      "businessContext": "Energy equivalent: 4.184 J per small calorie, 4184 J per kilocalorie (dietary Calorie).",
      "label_i18n": {
        "en": "Joules per calorie",
        "tr": "Joules per calorie",
        "de": "Joules per calorie",
        "fr": "Joules per calorie",
        "es": "Joules per calorie",
        "ar": "Joules per calorie"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Conversion efficiency from electrical power to heat/calories. 100% means all watts converted.",
      "label_i18n": {
        "en": "Efficiency (%)",
        "tr": "Efficiency (%)",
        "de": "Efficiency (%)",
        "fr": "Efficiency (%)",
        "es": "Efficiency (%)",
        "ar": "Efficiency (%)"
      }
    }
  ],
  "formulas": {
    "totalCalories": "(watts * (efficiency / 100) * time) / calFactor",
    "calPerSec": "(watts * (efficiency / 100)) / calFactor",
    "calPerMin": "((watts * (efficiency / 100)) * 60) / calFactor",
    "calPerHour": "((watts * (efficiency / 100)) * 3600) / calFactor"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [
      "calPerSec",
      "calPerMin",
      "calPerHour"
    ],

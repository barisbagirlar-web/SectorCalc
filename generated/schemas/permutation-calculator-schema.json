  "formulas": {
    "permutations": "n >= r ? (function factorial(x) { return x <= 1 ? 1 : x * factorial(x - 1); })(n) / (function factorial(x) { return x <= 1 ? 1 : x * factorial(x - 1); })(n - r) : 0",
    "permutationsWithRepetition": "Math.pow(n, r)",
    "circularPermutations": "n >= 1 ? (function factorial(x) { return x <= 1 ? 1 : x * factorial(x - 1); })(n - 1) : 0"
  },

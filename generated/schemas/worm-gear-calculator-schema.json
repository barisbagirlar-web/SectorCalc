  "formulas": {
    "gearRatio": "z2 / z1",
    "gearPitchDiameter": "module * z2",
    "wormPitchDiameter": "2 * centerDistance - module * z2",
    "lead": "Math.PI * module * z1",
    "wormOuterDiameter": "wormPitchDiameter + 2 * module",
    "gearOuterDiameter": "gearPitchDiameter + 2 * module",
    "wormRootDiameter": "wormPitchDiameter - 2.4 * module",
    "gearRootDiameter": "gearPitchDiameter - 2.4 * module"
  },
  "outputs": {
    "primary": "gearRatio",
    "breakdown": [
      "wormPitchDiameter",
      "gearPitchDiameter",
      "leadAngle",
      "wormOuterDiameter",
      "gearOuterDiameter",
      "wormRootDiameter",
      "gearRootDiameter"
    ],

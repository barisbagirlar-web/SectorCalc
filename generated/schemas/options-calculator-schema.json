      "businessContext_i18n": {
        "en": "Annual risk-free interest rate (e.g., 5 for 5%).",
        "tr": "Yıllık risksiz faiz oranı (örneğin %5 için 5)."
      }
    },
    {
      "id": "sigma",
      "label": "Volatility",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Annualized standard deviation of the underlying's returns (e.g., 20 for 20%).",
      "label_i18n": {
        "en": "Volatility",

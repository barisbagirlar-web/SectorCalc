      "label_i18n": {
        "en": "Time to Maturity",
        "tr": "Vadeye Kalan Süre",
        "de": "Restlaufzeit",
        "fr": "Time to Maturity",
        "es": "Time to Maturity",
        "ar": "Time to Maturity"
      },
      "businessContext_i18n": {
        "en": "Time remaining until option expiration, expressed in years.",
        "tr": "Opsiyon vadesine kalan süre, yıl cinsinden ifade edilir."
      }
    },
    {
      "id": "r",
      "label": "Risk-Free Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual risk-free interest rate (e.g., 5 for 5%).",
      "label_i18n": {
        "en": "Risk-Free Interest Rate",
        "tr": "Risksiz Faiz Oranı",
        "de": "Risk-Free Interest Rate",
        "fr": "Risk-Free Interest Rate",
        "es": "Risk-Free Interest Rate",
        "ar": "Risk-Free Interest Rate"

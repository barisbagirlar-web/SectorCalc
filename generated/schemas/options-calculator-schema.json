        "ar": "Current Stock Price"
      },
      "businessContext_i18n": {
        "en": "The current market price of the underlying asset.",
        "tr": "Dayanak varlığın güncel piyasa fiyatı."
      }
    },
    {
      "id": "K",
      "label": "Strike Price",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "The price at which the option can be exercised.",
      "label_i18n": {
        "en": "Strike Price",
        "tr": "Kullanım Fiyatı",

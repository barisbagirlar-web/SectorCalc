      "unit": "unit",
      "default": 1,
      "businessContext": "How many identical walls to cast",
      "label_i18n": {
        "en": "Number of Walls",
        "tr": "Number of Walls",
        "de": "Number of Walls",
        "fr": "Number of Walls",
        "es": "Number of Walls",
        "ar": "Number of Walls"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional concrete to account for spillage, over-excavation, etc.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "costPerCubicMeter",
      "label": "Concrete Cost per m³",
      "type": "number",
      "unit": "EUR/m³",
      "default": 100,
      "businessContext": "Unit price of ready-mix concrete",
      "label_i18n": {
        "en": "Concrete Cost per m³",
        "tr": "Concrete Cost per m³",
        "de": "Concrete Cost per m³",
        "fr": "Concrete Cost per m³",
        "es": "Concrete Cost per m³",
        "ar": "Concrete Cost per m³"
      }
    }
  ],
  "formulas": {
    "netVolume": "length * height * thickness * quantity",
    "totalVolume": "netVolume * (1 + wasteFactor / 100)",
    "wasteVolume": "totalVolume - netVolume",
    "totalCost": "totalVolume * costPerCubicMeter"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "Net Volume (m³)",
      "Waste Volume (m³)",
      "Total Cost"
    ],

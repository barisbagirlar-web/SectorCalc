{
  "toolName": "aku-kapasitesi-calisma-suresi-hesabi",
  "inputs": [
    {
      "id": "akuKapasitesi",
      "label": "Akü Kapasitesi",
      "type": "number",
      "unit": "Ah",
      "default": 100,
      "min": 1,
      "max": 10000,
      "options": null,
      "businessContext": "Akünün nominal kapasitesi (Amper-saat). Kaynak: IEC 60086, IEEE 485."
    },
    {
      "id": "gerilim",
      "label": "Gerilim",
      "type": "number",
      "unit": "V",
      "default": 12,
      "min": 1,
      "max": 1000,
      "options": null,
      "businessContext": "Akü nominal gerilimi. Kaynak: IEC 60086."
    },
    {
      "id": "yukGucu",
      "label": "Yük Gücü",
      "type": "number",
      "unit": "W",
      "default": 50,
      "min": 0.1,
      "max": 100000,
      "options": null,
      "businessContext": "Bağlı yükün çektiği güç. Kaynak: Mühendislik hesaplamaları."
    },
    {
      "id": "verimlilik",
      "label": "Sistem Verimliliği",
      "type": "number",
      "unit": "%",
      "default": 85,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Dönüştürücü ve bağlantı kayıpları dahil sistem verimi. Kaynak: IEEE 485."
    },
    {
      "id": "deşarjDerinliği",
      "label": "Deşarj Derinliği (DoD)",
      "type": "number",
      "unit": "%",
      "default": 80,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Akünün güvenli deşarj yüzdesi. Kaynak: Üretici teknik dokümanları, IEEE 485."
    },
    {
      "id": "sicaklikFaktoru",
      "label": "Sıcaklık Faktörü",
      "type": "number",
      "unit": "",
      "default": 1,
      "min": 0.5,
      "max": 1.5,
      "options": null,
      "businessContext": "Sıcaklığın kapasiteye etkisi (1 = 25°C). Kaynak: IEEE 485."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "select",
      "unit": "",
      "default": "medium",
      "min": null,
      "max": null,
      "options": [
        "low",
        "medium",
        "high"
      ],
      "businessContext": "Girdi verilerinin güvenilirlik seviyesi. Kaynak: Endüstriyel risk değerlendirme."
    }
  ],
  "validation": {
    "rules": [
      "yukGucu > 0",
      "akuKapasitesi > 0",
      "gerilim > 0",
      "verimlilik >= 0 && verimlilik <= 100",
      "deşarjDerinliği >= 0 && deşarjDerinliği <= 100",
      "sicaklikFaktoru >= 0.5 && sicaklikFaktoru <= 1.5"
    ],
    "thresholds": {
      "verimlilik < 70": "Düşük verimlilik, sistem kayıpları yüksek.",
      "deşarjDerinliği > 80": "Yüksek deşarj derinliği akü ömrünü kısaltabilir.",
      "sicaklikFaktoru < 0.8 || sicaklikFaktoru > 1.2": "Sıcaklık faktörü ideal aralığın dışında."
    }
  },
  "formulas": {
    "kullanilabilirEnerji": "akuKapasitesi * gerilim * (deşarjDerinliği / 100) * sicaklikFaktoru * (verimlilik / 100)",
    "calismaSuresiSaat": "kullanilabilirEnerji / yukGucu",
    "calismaSuresiDakika": "calismaSuresiSaat * 60",
    "dataConfidenceAdjusted": "dataConfidence == 'low' ? calismaSuresiSaat * 0.8 : (dataConfidence == 'medium' ? calismaSuresiSaat * 0.95 : calismaSuresiSaat)"
  },
  "outputs": {
    "primary": "calismaSuresiSaat",
    "breakdown": {
      "kullanilabilirEnerji": "kullanilabilirEnerji",
      "calismaSuresiDakika": "calismaSuresiDakika"
    },
    "hiddenLossDrivers": [
      "verimlilik < 70 ? 'Düşük verimlilik' : ''",
      "deşarjDerinliği > 80 ? 'Yüksek DoD' : ''",
      "sicaklikFaktoru < 0.8 || sicaklikFaktoru > 1.2 ? 'Sıcaklık uç değer' : ''"
    ],
    "suggestedActions": [
      "verimlilik < 70 ? 'Sistem verimliliğini artırmak için dönüştürücü ve kablolamayı kontrol edin.' : ''",
      "deşarjDerinliği > 80 ? 'Deşarj derinliğini azaltmak için daha büyük kapasiteli akü kullanmayı değerlendirin.' : ''",
      "sicaklikFaktoru < 0.8 || sicaklikFaktoru > 1.2 ? 'Aküyü uygun sıcaklık aralığında (20-30°C) çalıştırın.' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

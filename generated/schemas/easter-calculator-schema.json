{
  "toolName": "easter-calculator",
  "inputs": [
    {
      "id": "year",
      "label": "Year",
      "type": "number",
      "unit": "year",
      "default": 2023,
      "businessContext": "Gregorian year for which to calculate Easter date",
      "label_i18n": {
        "en": "Year",
        "tr": "Year",
        "de": "Year",
        "fr": "Year",
        "es": "Year",
        "ar": "Year"
      }
    },
    {
      "id": "daysToAdd",
      "label": "Days Adjustment",
      "type": "number",
      "unit": "days",
      "default": 0,
      "businessContext": "Number of days to shift the computed Easter date",
      "label_i18n": {
        "en": "Days Adjustment",
        "tr": "Days Adjustment",
        "de": "Days Adjustment",
        "fr": "Days Adjustment",
        "es": "Days Adjustment",
        "ar": "Days Adjustment"
      }
    },
    {
      "id": "algorithmVersion",
      "label": "Algorithm Version",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Version of the computus algorithm (1 = Gregorian, 2 = Julian, not used in formula)",
      "label_i18n": {
        "en": "Algorithm Version",
        "tr": "Algorithm Version",
        "de": "Algorithm Version",
        "fr": "Algorithm Version",
        "es": "Algorithm Version",
        "ar": "Algorithm Version"
      }
    },
    {
      "id": "moonPhaseOffset",
      "label": "Moon Phase Offset",
      "type": "number",
      "unit": "days",
      "default": 0,
      "businessContext": "Offset in days to adjust the paschal full moon calculation",
      "label_i18n": {
        "en": "Moon Phase Offset",
        "tr": "Moon Phase Offset",
        "de": "Moon Phase Offset",
        "fr": "Moon Phase Offset",
        "es": "Moon Phase Offset",
        "ar": "Moon Phase Offset"
      }
    }
  ],
  "formulas": {
    "a": "year % 19",
    "b": "Math.floor(year / 100)",
    "c": "year % 100",
    "d": "Math.floor(b / 4)",
    "e": "b % 4",
    "f": "Math.floor((b + 8) / 25)",
    "g": "Math.floor((b - f + 1) / 3)",
    "h": "(19 * a + b - d - g + 15 + moonPhaseOffset) % 30",
    "i": "Math.floor(c / 4)",
    "k": "c % 4",
    "l": "(32 + 2 * e + 2 * i - h - k) % 7",
    "m": "Math.floor((a + 11 * h + 22 * l) / 451)",
    "month": "Math.floor((h + l - 7 * m + 114) / 31)",
    "day": "((h + l - 7 * m + 114) % 31) + 1 + daysToAdd",
    "result": "'Easter: ' + month + '/' + day + '/' + year"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "month",
      "day"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",

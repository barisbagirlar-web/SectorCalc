{
  "toolName": "portion-cost-calculator",
  "inputs": [
    {
      "id": "recipe-cost",
      "label": "Recipe Cost",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Total cost of ingredients for the batch"
    },
    {
      "id": "labor-cost",
      "label": "Labor Cost",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Labor cost per batch"
    },
    {
      "id": "other-costs",
      "label": "Other Costs",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Other costs (overhead, packaging, etc.)"
    },
    {
      "id": "number-of-portions",
      "label": "Number of Portions",
      "type": "number",
      "unit": "portions",
      "default": 1,
      "businessContext": "Total number of portions or servings"
    },
    {
      "id": "desired-margin-percent",
      "label": "Desired Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Desired profit margin percentage"
    }
  ],
  "formulas": {
    "totalBatchCost": "recipeCost + laborCost + otherCosts",
    "portionCost": "totalBatchCost / numberOfPortions",
    "sellingPrice": "portionCost / (1 - desiredMarginPercent / 100)"
  },
  "outputs": {
    "primary": "portionCost",
    "breakdown": [
      "totalBatchCost",
      "sellingPrice"
    ]
  },
  "category": "Maliyet & Marj",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "food-cold-chain-hygiene"
}

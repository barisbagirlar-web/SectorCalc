        "ar": "Width"
      }
    },
    {
      "id": "thickness",
      "label": "Thickness",
      "type": "number",
      "unit": "cm",
      "default": 15,
      "businessContext": "Thickness (depth) of the concrete pour",
      "label_i18n": {
        "en": "Thickness",
        "tr": "Thickness",
        "de": "Thickness",
        "fr": "Thickness",
        "es": "Thickness",
        "ar": "Thickness"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage for spillage, over-excavation, and formwork inaccuracies",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "density",
      "label": "Concrete Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 2400,
      "businessContext": "Standard density for ready mix concrete (typically 2400 kg/m³)",
      "label_i18n": {
        "en": "Concrete Density",
        "tr": "Concrete Density",
        "de": "Concrete Density",
        "fr": "Concrete Density",
        "es": "Concrete Density",
        "ar": "Concrete Density"
      }
    }
  ],
  "formulas": {
    "netVolume": "length * width * (thickness / 100)",
    "wasteVolume": "netVolume * (wasteFactor / 100)",
    "totalVolume": "netVolume + wasteVolume",
    "totalWeight": "totalVolume * density / 1000"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "netVolume",
      "wasteVolume",
      "totalWeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalWeight"
  },

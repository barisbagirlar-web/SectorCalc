    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Width of the concrete slab or formwork",
      "label_i18n": {
        "en": "Width",
        "tr": "Width",
        "de": "Width",
        "fr": "Width",

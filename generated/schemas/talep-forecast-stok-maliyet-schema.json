  "formulas": {
    "ForecastError": "ABS(ActualDemand - ForecastDemand) / ActualDemand",
    "SafetyStock": "Z_Score * StdDev_ForecastError * SQRT(LeadTime)",
    "CarryingCost_Safety": "SafetyStock * UnitCost * HoldingRate",
    "StockoutCost": "IF(ActualDemand > (ForecastDemand + SafetyStock), (ActualDemand - ForecastDemand - SafetyStock) * PenaltyCost, 0)",
    "TotalForecastCost": "CarryingCost_Safety + StockoutCost + ForecastingSystemCost"
  },

{
  "toolName": "simple-harmonic-motion-calculator",
  "inputs": [
    {
      "id": "A",
      "label": "Amplitude",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Maximum displacement from equilibrium (meters). Critical parameter for vibration amplitude in machinery monitoring.",
      "label_i18n": {
        "en": "Amplitude",
        "tr": "Amplitude",
        "de": "Amplitude",
        "fr": "Amplitude",
        "es": "Amplitude",
        "ar": "Amplitude"
      }
    },
    {
      "id": "f",
      "label": "Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1,
      "businessContext": "Oscillation frequency in Hertz. Typically derived from FFT analysis in predictive maintenance.",
      "label_i18n": {
        "en": "Frequency",
        "tr": "Frequency",
        "de": "Frequency",
        "fr": "Frequency",
        "es": "Frequency",
        "ar": "Frequency"
      }
    },
    {
      "id": "phi",
      "label": "Phase Constant",
      "type": "number",
      "unit": "rad",
      "default": 0,
      "businessContext": "Initial phase angle (radians), accounting for the starting point of the oscillation cycle.",
      "label_i18n": {
        "en": "Phase Constant",
        "tr": "Phase Constant",
        "de": "Phase Constant",
        "fr": "Phase Constant",
        "es": "Phase Constant",
        "ar": "Phase Constant"
      }
    },
    {
      "id": "t",
      "label": "Time",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Point in time (seconds) for calculating instantaneous displacement, velocity, etc.",
      "label_i18n": {
        "en": "Time",
        "tr": "Time",
        "de": "Time",
        "fr": "Time",
        "es": "Time",
        "ar": "Time"
      }
    },
    {
      "id": "m",
      "label": "Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of the vibrating component (kg). Used for energy calculations; default 1 if energy analysis is not required.",
      "label_i18n": {
        "en": "Mass",
        "tr": "Mass",
        "de": "Mass",
        "fr": "Mass",
        "es": "Mass",
        "ar": "Mass"
      }
    }
  ],
  "formulas": {
    "omega": "2 * Math.PI * inputs.f",
    "x": "inputs.A * Math.cos(omega * inputs.t + inputs.phi)",
    "v": "-inputs.A * omega * Math.sin(omega * inputs.t + inputs.phi)",
    "a": "-inputs.A * omega**2 * Math.cos(omega * inputs.t + inputs.phi)",
    "T": "1 / inputs.f",
    "k": "inputs.m * omega**2",
    "PE": "0.5 * k * x**2",
    "KE": "0.5 * inputs.m * v**2",
    "E": "0.5 * k * inputs.A**2"
  },
  "outputs": {
    "primary": "x",
    "breakdown": [
      "v",
      "a",
      "T",
      "omega",
      "KE",
      "PE",
      "E"
    ]
  },

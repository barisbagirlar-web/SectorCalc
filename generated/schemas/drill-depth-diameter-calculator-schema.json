        "ar": "Drill Diameter"
      }
    },
    {
      "id": "drillDepth",
      "label": "Drill Depth",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "Hole depth to be drilled",
      "label_i18n": {
        "en": "Drill Depth",

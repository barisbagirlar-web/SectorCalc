        "de": "Drill Depth",
        "fr": "Drill Depth",
        "es": "Drill Depth",
        "ar": "Drill Depth"
      }
    },
    {
      "id": "rotationSpeed",
      "label": "Rotation Speed",
      "type": "number",
      "unit": "RPM",
      "default": 1000,
      "businessContext": "Spindle rotation speed",
      "label_i18n": {
        "en": "Rotation Speed",
        "tr": "Rotation Speed",
        "de": "Rotation Speed",
        "fr": "Rotation Speed",
        "es": "Rotation Speed",
        "ar": "Rotation Speed"
      }
    },
    {
      "id": "feedRate",
      "label": "Feed Rate",
      "type": "number",
      "unit": "mm/rev",
      "default": 0.1,
      "businessContext": "Feed per revolution",
      "label_i18n": {
        "en": "Feed Rate",
        "tr": "Feed Rate",
        "de": "Feed Rate",
        "fr": "Feed Rate",
        "es": "Feed Rate",
        "ar": "Feed Rate"
      }
    },
    {
      "id": "materialFactor",
      "label": "Material Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Material-specific power coefficient",
      "label_i18n": {
        "en": "Material Factor",
        "tr": "Material Factor",
        "de": "Material Factor",
        "fr": "Material Factor",
        "es": "Material Factor",
        "ar": "Material Factor"
      }
    }
  ],
  "formulas": {
    "drillingTime": "drillDepth / (feedRate * rotationSpeed)",
    "materialRemovalRate": "Math.PI * (drillDiameter / 2) ** 2 * feedRate * rotationSpeed",
    "powerRequired": "materialFactor * (Math.PI * (drillDiameter / 2) ** 2 * feedRate * rotationSpeed) * 0.05"
  },
  "outputs": {
    "primary": "drillingTime",
    "breakdown": [
      "materialRemovalRate",
      "powerRequired"
    ]
  },

    {
      "id": "roundingMode",
      "label": "Rounding Mode",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 = standard rounding (half up), 1 = floor, 2 = ceil, 3 = truncate.",
      "label_i18n": {
        "en": "Rounding Mode",

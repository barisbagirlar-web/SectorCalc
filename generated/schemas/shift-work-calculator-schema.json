{
  "toolName": "shift-work-calculator",
  "inputs": [
    {
      "id": "hoursWorked",
      "label": "Hours Worked",
      "type": "number",
      "unit": "hours",
      "default": 40,
      "businessContext": "Total base shift hours worked, excluding overtime",
      "label_i18n": {
        "en": "Hours Worked",
        "tr": "Hours Worked",
        "de": "Hours Worked",
        "fr": "Hours Worked",
        "es": "Hours Worked",
        "ar": "Hours Worked"
      }
    },
    {
      "id": "hourlyRate",
      "label": "Hourly Rate",
      "type": "number",
      "unit": "currency",
      "default": 20,
      "businessContext": "Base hourly pay rate",
      "label_i18n": {
        "en": "Hourly Rate",
        "tr": "Hourly Rate",
        "de": "Hourly Rate",
        "fr": "Hourly Rate",
        "es": "Hourly Rate",
        "ar": "Hourly Rate"
      }
    },
    {
      "id": "shiftMultiplier",
      "label": "Shift Premium Multiplier",
      "type": "number",
      "unit": "multiplier",
      "default": 1.2,
      "businessContext": "Multiplier applied to base hours for shift work premium",
      "label_i18n": {
        "en": "Shift Premium Multiplier",
        "tr": "Shift Premium Multiplier",
        "de": "Shift Premium Multiplier",
        "fr": "Shift Premium Multiplier",
        "es": "Shift Premium Multiplier",
        "ar": "Shift Premium Multiplier"
      }
    },
    {
      "id": "overtimeHours",
      "label": "Overtime Hours",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "businessContext": "Overtime hours worked beyond regular shift",
      "label_i18n": {
        "en": "Overtime Hours",
        "tr": "Overtime Hours",
        "de": "Overtime Hours",
        "fr": "Overtime Hours",
        "es": "Overtime Hours",
        "ar": "Overtime Hours"
      }
    },
    {
      "id": "overtimeMultiplier",
      "label": "Overtime Multiplier",
      "type": "number",
      "unit": "multiplier",
      "default": 1.5,
      "businessContext": "Multiplier for overtime pay",
      "label_i18n": {
        "en": "Overtime Multiplier",
        "tr": "Overtime Multiplier",
        "de": "Overtime Multiplier",
        "fr": "Overtime Multiplier",
        "es": "Overtime Multiplier",
        "ar": "Overtime Multiplier"
      }
    }
  ],
  "formulas": {
    "basePay": "hoursWorked * hourlyRate * shiftMultiplier",
    "overtimePay": "overtimeHours * hourlyRate * overtimeMultiplier",
    "totalPay": "basePay + overtimePay"
  },
  "outputs": {
    "primary": "totalPay",
    "breakdown": [
      "basePay",
      "overtimePay"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

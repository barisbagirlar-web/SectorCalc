{
  "toolName": "bibliography-generator-calculator",
  "inputs": [
    {
      "id": "pageCount",
      "label": "Document Page Count",
      "type": "number",
      "unit": "pages",
      "default": 10,
      "businessContext": "Total number of pages in the document.",
      "label_i18n": {
        "en": "Document Page Count",
        "tr": "Document Page Count",
        "de": "Document Page Count",
        "fr": "Document Page Count",
        "es": "Document Page Count",
        "ar": "Document Page Count"
      }
    },
    {
      "id": "referencesPerPage",
      "label": "Average References per Page",
      "type": "number",
      "unit": "references/page",
      "default": 2,
      "businessContext": "Typical number of citations per page.",
      "label_i18n": {
        "en": "Average References per Page",
        "tr": "Average References per Page",
        "de": "Average References per Page",
        "fr": "Average References per Page",
        "es": "Average References per Page",
        "ar": "Average References per Page"
      }
    },
    {
      "id": "citationDensity",
      "label": "Citation Density",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "Percentage of pages that have citations.",
      "label_i18n": {
        "en": "Citation Density",
        "tr": "Citation Density",
        "de": "Citation Density",
        "fr": "Citation Density",
        "es": "Citation Density",
        "ar": "Citation Density"
      }
    },
    {
      "id": "formattingTimePerRef",
      "label": "Formatting Time per Reference",
      "type": "number",
      "unit": "minutes",
      "default": 5,
      "businessContext": "Time to format one reference according to style.",
      "label_i18n": {
        "en": "Formatting Time per Reference",
        "tr": "Formatting Time per Reference",
        "de": "Formatting Time per Reference",
        "fr": "Formatting Time per Reference",
        "es": "Formatting Time per Reference",
        "ar": "Formatting Time per Reference"
      }
    },
    {
      "id": "styleComplexity",
      "label": "Style Complexity Factor",
      "type": "number",
      "unit": "factor",
      "default": 1.2,
      "businessContext": "Multiplier for bibliography style complexity (e.g., APA = 1.0, Chicago = 1.2).",
      "label_i18n": {
        "en": "Style Complexity Factor",
        "tr": "Style Complexity Factor",
        "de": "Style Complexity Factor",
        "fr": "Style Complexity Factor",
        "es": "Style Complexity Factor",
        "ar": "Style Complexity Factor"
      }
    },
    {
      "id": "overheadTime",
      "label": "Overhead Time",
      "type": "number",
      "unit": "minutes",
      "default": 15,
      "businessContext": "Fixed time for setting up bibliography tools.",
      "label_i18n": {
        "en": "Overhead Time",
        "tr": "Overhead Time",
        "de": "Overhead Time",
        "fr": "Overhead Time",
        "es": "Overhead Time",
        "ar": "Overhead Time"
      }
    },
    {
      "id": "referencesFromExternal",
      "label": "External References Count",
      "type": "number",
      "unit": "count",
      "default": 5,
      "businessContext": "Number of references imported from external databases.",
      "label_i18n": {
        "en": "External References Count",
        "tr": "External References Count",
        "de": "External References Count",
        "fr": "External References Count",
        "es": "External References Count",
        "ar": "External References Count"
      }
    },
    {
      "id": "autoGeneratedPerRef",
      "label": "Auto-Generation Time per Reference",
      "type": "number",
      "unit": "minutes",
      "default": 1,
      "businessContext": "Time to automatically generate a reference from a database.",
      "label_i18n": {
        "en": "Auto-Generation Time per Reference",
        "tr": "Auto-Generation Time per Reference",
        "de": "Auto-Generation Time per Reference",
        "fr": "Auto-Generation Time per Reference",
        "es": "Auto-Generation Time per Reference",
        "ar": "Auto-Generation Time per Reference"
      }
    }
  ],
  "formulas": {
    "totalReferences": "(pageCount * referencesPerPage * citationDensity / 100) + referencesFromExternal",
    "totalManualTime": "totalReferences * formattingTimePerRef * styleComplexity",
    "totalAutoTime": "totalReferences * autoGeneratedPerRef",
    "totalTime": "totalManualTime + totalAutoTime + overheadTime",
    "referencesPerHour": "totalReferences / (totalTime / 60)"
  },
  "outputs": {
    "primary": "totalReferences",
    "breakdown": [
      "Total Time (min): ${totalTime}",
      "References per Hour: ${referencesPerHour}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "referencesPerHour"
  },

  "formulas": {
    "T2s": "T1 * Math.pow(rp, (gamma - 1) / gamma)",
    "T2": "T1 + (T2s - T1) / eta_c",
    "T4s": "T3 / Math.pow(rp, (gamma - 1) / gamma)",
    "T4": "T3 - eta_t * (T3 - T4s)",
    "Wc": "cp * (T2 - T1)",
    "Wt": "cp * (T3 - T4)",
    "Wnet": "Wt - Wc",
    "Q_in": "cp * (T3 - T2)",
    "eta_th": "Wnet / Q_in",
    "bwr": "Wc / Wt"
  },
  "outputs": {
    "primary": "eta_th",
    "breakdown": [
      "Wnet",
      "Wc",
      "Wt",
      "Q_in",
      "bwr"
    ]

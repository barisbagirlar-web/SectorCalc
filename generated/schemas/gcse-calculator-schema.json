      }
    },
    {
      "id": "mortarThickness",
      "label": "Mortar Joint Thickness",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Typical mortar joint thickness between bricks (e.g., 10mm).",
      "label_i18n": {
        "en": "Mortar Joint Thickness",
        "tr": "Mortar Joint Thickness",
        "de": "Mortar Joint Thickness",
        "fr": "Mortar Joint Thickness",
        "es": "Mortar Joint Thickness",
        "ar": "Mortar Joint Thickness"
      }
    },
    {
      "id": "wastagePercent",
      "label": "Wastage Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Allowance for cutting and breakage as a percentage (e.g., 5% => extra 5%).",
      "label_i18n": {
        "en": "Wastage Percentage",
        "tr": "Wastage Percentage",
        "de": "Wastage Percentage",
        "fr": "Wastage Percentage",
        "es": "Wastage Percentage",
        "ar": "Wastage Percentage"
      }
    }
  ],
  "formulas": {
    "wallArea": "wallLength * wallHeight * leafCount",
    "brickArea": "(brickLength/1000 + mortarThickness/1000) * (brickHeight/1000 + mortarThickness/1000)",
    "baseBricks": "wallArea / brickArea",
    "totalBricks": "baseBricks * (1 + wastagePercent/100)"
  },
  "outputs": {
    "primary": "totalBricks",
    "breakdown": [
      "wallArea",
      "brickArea",
      "baseBricks"
    ],

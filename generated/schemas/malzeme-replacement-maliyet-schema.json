  "formulas": {
    "TCO_Current": "MatCost_Current + ProcessingCost_Current + LifecycleMaint_Current + DisposalCost_Current",
    "TCO_Alternative": "MatCost_Alt + ProcessingCost_Alt + LifecycleMaint_Alt + DisposalCost_Alt",
    "WeightSavings": "Weight_Current - Weight_Alt",
    "FuelSavings": "WeightSavings * FuelFactor * LifecycleDistance * FuelPrice",
    "NetBenefit": "TCO_Current - TCO_Alternative + FuelSavings + QualityPremium",
    "Payback": "(ToolingCost_Alt + QualificationCost) / AnnualNetBenefit"
  },

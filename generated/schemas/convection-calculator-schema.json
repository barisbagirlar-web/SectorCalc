  "formulas": {
    "deltaT": "Ts - Tinf",
    "Tf_K": "Tinf + 273.15",
    "beta": "1 / Tf_K",
    "Gr": "9.81 * beta * Math.abs(deltaT) * Math.pow(L, 3) / (nu * nu)",
    "Ra": "Gr * Pr",
    "Nu": "Ra <= 1e9 ? 0.59 * Math.pow(Ra, 0.25) : 0.1 * Math.pow(Ra, 1/3)",
    "h": "Nu * k / L",
    "A": "L * W",
    "Q": "h * A * deltaT",
    "Grashof_Say_s___Gr_": "Grashof Sayısı (Gr)",
    "Rayleigh_Say_s___Ra_": "Rayleigh Sayısı (Ra)",
    "Nusselt_Say_s___Nu_": "Nusselt Sayısı (Nu)",
    "Is__Ta__n_m_Katsay_s___h___W_m_K_": "Isı Taşınım Katsayısı (h) [W/m²K]",
    "Alan__A___m__": "Alan (A) [m²]",
    "S_cakl_k_Fark____T____C_": "Sıcaklık Farkı (ΔT) [°C]"
  },
  "outputs": {
    "primary": "Q",
    "breakdown": [

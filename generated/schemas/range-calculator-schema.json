      }
    },
    {
      "id": "maxValue",
      "label": "Maximum Value",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "The upper bound of the measured data set.",
      "label_i18n": {
        "en": "Maximum Value",
        "tr": "Maximum Value",
        "de": "Maximum Value",
        "fr": "Maximum Value",
        "es": "Maximum Value",
        "ar": "Maximum Value"
      }
    },
    {
      "id": "nominalValue",
      "label": "Nominal Value",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "The target or expected value for the measurement.",
      "label_i18n": {
        "en": "Nominal Value",
        "tr": "Nominal Value",
        "de": "Nominal Value",
        "fr": "Nominal Value",
        "es": "Nominal Value",
        "ar": "Nominal Value"
      }
    },
    {
      "id": "tolerance",
      "label": "Tolerance",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "The permissible deviation from nominal; used to compute out-of-tolerance margins.",
      "label_i18n": {
        "en": "Tolerance",
        "tr": "Tolerance",
        "de": "Tolerance",
        "fr": "Tolerance",
        "es": "Tolerance",
        "ar": "Tolerance"
      }
    }
  ],
  "formulas": {
    "range": "maxValue - minValue",
    "midrange": "(minValue + maxValue) / 2",
    "relativeRange": "(maxValue - minValue) / Math.sqrt(nominalValue ** 2)",
    "toleranceMargin": "tolerance - (maxValue - minValue)"
  },
  "outputs": {
    "primary": "range",
    "breakdown": [
      "midrange",
      "relativeRange",
      "toleranceMargin"
    ]
  },

{
  "toolName": "range-calculator",
  "inputs": [
    {
      "id": "minValue",
      "label": "Minimum Value",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "The lower bound of the measured data set.",
      "label_i18n": {
        "en": "Minimum Value",

    {
      "id": "monthlyExpenses",
      "label": "Monthly Expenses",
      "type": "number",
      "unit": "currency",
      "default": 500,
      "businessContext": "Recurring costs (taxes, insurance, HOA, maintenance)",
      "label_i18n": {
        "en": "Monthly Expenses",
        "tr": "Aylık Giderler",
        "de": "Monatliche Ausgaben",
        "fr": "Dépenses mensuelles",
        "es": "Gastos mensuales",
        "ar": "المصروفات الشهرية"
      },
      "businessContext_i18n": {
        "en": "Recurring costs (taxes, insurance, HOA, maintenance)",
        "tr": "Tekrarlanan maliyetler (vergiler, sigorta, site yönetimi, bakım)",
        "de": "Wiederkehrende Kosten (Steuern, Versicherung, HOA, Instandhaltung)",
        "fr": "Coûts récurrents (taxes, assurance, copropriété, entretien)",
        "es": "Costes recurrentes (impuestos, seguros, HOA, mantenimiento)",
        "ar": "التكاليف المتكررة (الضرائب، التأمين، رسوم الجمعية، الصيانة)"
      }
    }
  ],
  "formulas": {
    "totalInvestment": "purchasePrice + closingCosts + repairCosts",
    "monthlyNetIncome": "monthlyRent - monthlyExpenses",
    "onePercentThreshold": "totalInvestment * 0.01",
    "meetsRule": "monthlyRent >= onePercentThreshold ? 1 : 0",
    "annualReturn": "(monthlyNetIncome * 12 / totalInvestment) * 100"
  },
  "outputs": {
    "primary": "annualReturn",
    "breakdown": [
      "Total Investment: totalInvestment",
      "1% Threshold: onePercentThreshold",
      "Monthly Net Income: monthlyNetIncome",
      "Annual Return (%): annualReturn"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualReturn",
    "unit": "currency",
    "breakdownUnits": {
      "1% Threshold: onePercentThreshold": "%"
    }
  },
  "category": "Matematik & Analiz",

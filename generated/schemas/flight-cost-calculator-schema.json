  "formulas": {
    "flightHours": "distance / avgSpeed",
    "fuelCost": "distance * fuelConsumptionRate * fuelPrice",
    "crewCost": "flightHours * crewCostPerHour",
    "maintenanceCost": "flightHours * maintenanceCostPerHour",
    "totalCost": "fuelCost + crewCost + landingFee + maintenanceCost"
  },

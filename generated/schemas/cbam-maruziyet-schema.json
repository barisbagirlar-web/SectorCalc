  "formulas": {
    "DirectEmissions": "SUM(ActivityData * EmissionFactor)",
    "IndirectEmissions": "ElecConsumption * GridFactor",
    "CarbonIntensity": "(DirectEmissions + IndirectEmissions) / ProductionVolume",
    "CBAMCertificateCost": "(EmbeddedEmissions - FreeAllowance) * EU_ETS_Price",
    "FreeAllowance": "Benchmark * ProductionVolume * LeakageFactor",
    "ComplianceScore": "(DataComplete * 0.3) + (Verification * 0.3) + (Reduction * 0.4)"
  },

    {
      "id": "conversionFactor",
      "label": "Unit Conversion Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Factor to convert input length unit to output length unit. E.g., cm to m: 0.01. Area is squared automatically.",
      "label_i18n": {
        "en": "Unit Conversion Factor",
        "tr": "Unit Conversion Factor",
        "de": "Unit Conversion Factor",
        "fr": "Unit Conversion Factor",
        "es": "Unit Conversion Factor",
        "ar": "Unit Conversion Factor"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for rounding outputs.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "effectiveRadius": "radius * conversionFactor || (diameter * conversionFactor) / 2 || Math.sqrt((area * conversionFactor * conversionFactor) / Math.PI) || 0",
    "effectiveDiameter": "effectiveRadius * 2",
    "circum": "Number((Math.PI * effectiveDiameter).toFixed(decimalPlaces))",
    "radius_out": "Number(effectiveRadius.toFixed(decimalPlaces))",
    "diameter_out": "Number(effectiveDiameter.toFixed(decimalPlaces))",
    "area_out": "Number((Math.PI * effectiveRadius ** 2).toFixed(decimalPlaces))"
  },
  "outputs": {
    "primary": "circum",
    "breakdown": [
      "radius_out",
      "diameter_out",
      "area_out"
    ]
  },

{
  "toolName": "operating-cash-flow-calculator",
  "inputs": [
    {
      "id": "revenue",
      "label": "Revenue",
      "type": "number",
      "unit": "$",
      "default": 1000000,
      "businessContext": "Total sales revenue for the period",
      "label_i18n": {
        "en": "Revenue",
        "tr": "Revenue",
        "de": "Revenue",
        "fr": "Revenue",
        "es": "Revenue",
        "ar": "Revenue"
      }
    },
    {
      "id": "operatingExpenses",
      "label": "Operating Expenses",
      "type": "number",
      "unit": "$",
      "default": 600000,
      "businessContext": "Total operating expenses including COGS, SG&A, etc.",
      "label_i18n": {
        "en": "Operating Expenses",
        "tr": "Operating Expenses",
        "de": "Operating Expenses",
        "fr": "Operating Expenses",
        "es": "Operating Expenses",
        "ar": "Operating Expenses"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 25,
      "businessContext": "Effective tax rate percentage",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "depreciation",
      "label": "Depreciation",
      "type": "number",
      "unit": "$",
      "default": 50000,
      "businessContext": "Depreciation and amortization expense (non-cash)",
      "label_i18n": {
        "en": "Depreciation",
        "tr": "Depreciation",
        "de": "Depreciation",
        "fr": "Depreciation",
        "es": "Depreciation",
        "ar": "Depreciation"
      }
    }
  ],
  "formulas": {
    "operatingCashFlow": "(revenue - operatingExpenses) * (1 - taxRate / 100) + depreciation",
    "ebit": "revenue - operatingExpenses",
    "taxAmount": "(revenue - operatingExpenses) * taxRate / 100",
    "afterTaxEBIT": "(revenue - operatingExpenses) * (1 - taxRate / 100)"
  },
  "outputs": {
    "primary": "operatingCashFlow",
    "breakdown": [
      "EBIT",
      "Tax Amount",
      "After-Tax EBIT",
      "Depreciation Add-back"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "After_Tax_EBIT",
    "unit": "$"
  },

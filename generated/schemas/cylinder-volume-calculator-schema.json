  "formulas": {
    "crossSectionalArea": "Math.PI * (outerRadius ** 2 - innerRadius ** 2)",
    "perCylinderVolume": "crossSectionalArea * height",
    "totalVolume": "perCylinderVolume * quantity"
  },

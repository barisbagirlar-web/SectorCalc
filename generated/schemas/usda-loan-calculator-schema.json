  ],
  "formulas": {
    "upfrontFeeAmount": "baseLoanAmount * upfrontFeePercent / 100",
    "totalLoanAmount": "baseLoanAmount + upfrontFeeAmount",
    "monthlyInterestRate": "(interestRate / 100) / 12",
    "numberOfPayments": "loanTermYears * 12",
    "monthlyPI": "totalLoanAmount * monthlyInterestRate * (1 + monthlyInterestRate) ** numberOfPayments / ((1 + monthlyInterestRate) ** numberOfPayments - 1)",
    "monthlyTax": "annualPropertyTax / 12",
    "monthlyInsurance": "annualHomeInsurance / 12",
    "monthlyAnnualFee": "(baseLoanAmount * annualFeePercent / 100) / 12",
    "totalMonthlyPayment": "monthlyPI + monthlyTax + monthlyInsurance + monthlyAnnualFee"
  },
  "outputs": {
    "primary": "totalMonthlyPayment",
    "breakdown": [
      "monthlyPI",
      "monthlyTax",
      "monthlyInsurance",
      "monthlyAnnualFee"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMonthlyPayment",
    "unit": "USD"
  },

      }
    },
    {
      "id": "annualFeePercent",
      "label": "Annual Fee",
      "type": "number",
      "unit": "%",
      "default": 0.35,
      "businessContext": "Ongoing USDA annual fee as a percentage of the base loan amount, paid monthly.",
      "label_i18n": {
        "en": "Annual Fee",
        "tr": "Yıllık Ücret",
        "de": "Annual Fee",
        "fr": "Annual Fee",
        "es": "Annual Fee",
        "ar": "Annual Fee"
      },
      "businessContext_i18n": {
        "en": "Ongoing USDA annual fee as a percentage of the base loan amount, paid monthly.",
        "tr": "Temel kredi tutarının yüzdesi olarak devam eden USDA yıllık ücreti, aylık ödenir."
      }
    },
    {
      "id": "annualPropertyTax",
      "label": "Annual Property Tax",
      "type": "number",
      "unit": "USD",
      "default": 2400,
      "businessContext": "Annual property tax amount.",
      "label_i18n": {
        "en": "Annual Property Tax",
        "tr": "Yıllık Emlak Vergisi",
        "de": "Annual Property Tax",
        "fr": "Annual Property Tax",
        "es": "Annual Property Tax",
        "ar": "Annual Property Tax"
      },
      "businessContext_i18n": {
        "en": "Annual property tax amount.",
        "tr": "Yıllık emlak vergisi tutarı."
      }
    },
    {
      "id": "annualHomeInsurance",
      "label": "Annual Home Insurance",
      "type": "number",
      "unit": "USD",
      "default": 1200,
      "businessContext": "Annual homeowners insurance premium.",
      "label_i18n": {
        "en": "Annual Home Insurance",
        "tr": "Yıllık Ev Sigortası",
        "de": "Annual Home Insurance",
        "fr": "Annual Home Insurance",
        "es": "Annual Home Insurance",
        "ar": "Annual Home Insurance"
      },
      "businessContext_i18n": {
        "en": "Annual homeowners insurance premium.",
        "tr": "Yıllık ev sahibi sigortası primi."
      }

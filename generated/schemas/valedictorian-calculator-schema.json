{
  "toolName": "valedictorian-calculator",
  "inputs": [
    {
      "id": "qualityRate",
      "label": "Quality Rate",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Percentage of defect-free outputs"
    },
    {
      "id": "efficiencyRate",
      "label": "Efficiency Rate",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Actual production rate vs. ideal rate"
    },
    {
      "id": "availabilityRate",
      "label": "Availability Rate",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Percentage of scheduled uptime"
    },
    {
      "id": "costIndex",
      "label": "Cost Index",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Cost index relative to standard (100 = standard, higher is worse)"
    },
    {
      "id": "safetyScore",
      "label": "Safety Score",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Safety performance score (0–100)"
    },
    {
      "id": "energyEfficiency",
      "label": "Energy Efficiency",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "Energy consumption performance vs. baseline"
    }
  ],
  "formulas": {
    "primary": "qualityRate / 100 * 0.25 + efficiencyRate / 100 * 0.25 + availabilityRate / 100 * 0.2 + (100 / costIndex) * 0.1 + safetyScore / 100 * 0.1 + energyEfficiency / 100 * 0.1",
    "qualityComponent": "qualityRate / 100 * 0.25",
    "efficiencyComponent": "efficiencyRate / 100 * 0.25",
    "availabilityComponent": "availabilityRate / 100 * 0.2",
    "costComponent": "(100 / costIndex) * 0.1",
    "safetyComponent": "safetyScore / 100 * 0.1",
    "energyComponent": "energyEfficiency / 100 * 0.1"
  },
  "outputs": {
    "primary": "valedictorianScore",
    "breakdown": [
      "qualityComponent",
      "efficiencyComponent",
      "availabilityComponent",
      "costComponent",
      "safetyComponent",
      "energyComponent"
    ]
  },
  "category": "Malzeme, Fire & OEE",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "education-academic",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

{
  "toolName": "sunrise-sunset-calculator",
  "inputs": [
    {
      "id": "latitude",
      "label": "Latitude",
      "type": "number",
      "unit": "°",
      "default": 40.7128,
      "businessContext": "Latitude of the location in decimal degrees (north positive)."
    },
    {
      "id": "longitude",
      "label": "Longitude",
      "type": "number",
      "unit": "°",
      "default": -74.006,
      "businessContext": "Longitude of the location in decimal degrees (east positive)."
    },
    {
      "id": "dayOfYear",
      "label": "Day of Year",
      "type": "number",
      "unit": "days",
      "default": 172,
      "businessContext": "Day number of the year (1-365 or 1-366 for leap year)."
    },
    {
      "id": "timezoneOffset",
      "label": "Timezone Offset",
      "type": "number",
      "unit": "hours",
      "default": -4,
      "businessContext": "Offset from UTC in hours (e.g., -4 for EDT)."
    }
  ],
  "formulas": {
    "declination": "23.44 * Math.sin((360/365) * (dayOfYear - 81) * Math.PI / 180)",
    "hourAngle": "Math.acos(-Math.tan(latitude * Math.PI / 180) * Math.tan(declination * Math.PI / 180)) * 180 / Math.PI",
    "sunriseUTC": "12 - hourAngle / 15 - 0.00083",
    "sunsetUTC": "12 + hourAngle / 15 - 0.00083",
    "sunriseLocal": "sunriseUTC + timezoneOffset",
    "sunsetLocal": "sunsetUTC + timezoneOffset"
  },
  "outputs": {
    "primary": "sunriseLocal",
    "breakdown": [
      "sunriseLocal",
      "sunsetLocal",
      "dayLength"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "date-time",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

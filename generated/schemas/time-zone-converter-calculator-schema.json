  "formulas": {
    "sourceOffsetTotalMinutes": "sourceOffsetHours * 60 + sourceOffsetMinutes",
    "targetOffsetTotalMinutes": "targetOffsetHours * 60 + targetOffsetMinutes",
    "utcMinutes": "(inputHours * 60 + inputMinutes - (sourceOffsetHours * 60 + sourceOffsetMinutes) + 1440) % 1440"
  },
  "outputs": {
    "primary": "utcMinutes",

  "formulas": {
    "rate": "factor / life",
    "depreciation": "cost * rate * (1 - rate) ** (year - 1)",
    "bookValueBeginning": "cost * (1 - rate) ** (year - 1)",
    "accumulatedDepreciation": "cost - cost * (1 - rate) ** year",
    "endingBookValue": "cost * (1 - rate) ** year"
  },
  "outputs": {
    "primary": "depreciation",
    "breakdown": [
      "bookValueBeginning",
      "accumulatedDepreciation",
      "endingBookValue"

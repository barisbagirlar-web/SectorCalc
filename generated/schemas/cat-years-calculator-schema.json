      },
      "businessContext_i18n": {
        "en": "Weight in kilograms; average adult cat is 4.5 kg, affecting aging rate.",
        "tr": "Kilogram cinsinden ağırlık; ortalama yetişkin kedi 4,5 kg'dır, yaşlanma hızını etkiler."
      }
    },
    {
      "id": "indoor",
      "label": "Indoor Cat",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 for primarily indoor, 0 for outdoor; outdoor cats age slightly faster.",
      "label_i18n": {
        "en": "Indoor Cat",
        "tr": "İç Mekan Kedisi",
        "de": "Indoor Cat",
        "fr": "Indoor Cat",
        "es": "Indoor Cat",
        "ar": "Indoor Cat"
      },
      "businessContext_i18n": {
        "en": "1 for primarily indoor, 0 for outdoor; outdoor cats age slightly faster.",
        "tr": "1 tamamen iç mekan, 0 dış mekan; dış mekan kedileri biraz daha hızlı yaşlanır."
      }
    }
  ],
  "formulas": {
    "totalAgeYears": "catAgeYears + catAgeMonths / 12",
    "baseHuman": "(totalAgeYears <= 1) ? 15 * totalAgeYears : (totalAgeYears <= 2) ? 15 + 9 * (totalAgeYears - 1) : 24 + 4 * (totalAgeYears - 2)",
    "weightFactor": "1 + 0.02 * (catWeightKg - 4.5)",
    "indoorFactor": "indoor === 0 ? 1.1 : 1.0",
    "finalHumanYears": "baseHuman * weightFactor * indoorFactor"
  },
  "outputs": {
    "primary": "finalHumanYears",
    "breakdown": [
      "Base human years (standard curve): ${baseHuman.toFixed(2)}",
      "Weight adjustment factor: ${weightFactor.toFixed(2)}",
      "Lifestyle factor (indoor/outdoor): ${indoorFactor.toFixed(2)}",
      "Final estimated human age: ${finalHumanYears.toFixed(1)} years"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalHumanYears",
    "unit": "years"
  },

{
  "toolName": "cat-years-calculator",
  "inputs": [
    {
      "id": "catAgeYears",
      "label": "Cat's Age (Years)",
      "type": "number",
      "unit": "years",
      "default": 0,
      "businessContext": "Full years of the cat's life.",
      "label_i18n": {
        "en": "Cat's Age (Years)",
        "tr": "Cat's Age (Years)",
        "de": "Cat's Age (Years)",
        "fr": "Cat's Age (Years)",
        "es": "Cat's Age (Years)",
        "ar": "Cat's Age (Years)"
      }
    },
    {
      "id": "catAgeMonths",
      "label": "Cat's Age (Months)",
      "type": "number",
      "unit": "months",
      "default": 0,
      "businessContext": "Additional months beyond full years (0–11).",
      "label_i18n": {
        "en": "Cat's Age (Months)",
        "tr": "Cat's Age (Months)",
        "de": "Cat's Age (Months)",
        "fr": "Cat's Age (Months)",
        "es": "Cat's Age (Months)",
        "ar": "Cat's Age (Months)"
      }
    },
    {
      "id": "catWeightKg",
      "label": "Cat's Weight",
      "type": "number",
      "unit": "kg",
      "default": 4.5,
      "businessContext": "Weight in kilograms; average adult cat is 4.5 kg, affecting aging rate.",
      "label_i18n": {
        "en": "Cat's Weight",
        "tr": "Cat's Weight",
        "de": "Cat's Weight",
        "fr": "Cat's Weight",
        "es": "Cat's Weight",
        "ar": "Cat's Weight"
      }
    },
    {
      "id": "indoor",
      "label": "Indoor Cat",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1 for primarily indoor, 0 for outdoor; outdoor cats age slightly faster.",
      "label_i18n": {
        "en": "Indoor Cat",
        "tr": "Indoor Cat",
        "de": "Indoor Cat",
        "fr": "Indoor Cat",
        "es": "Indoor Cat",
        "ar": "Indoor Cat"
      }
    }
  ],
  "formulas": {
    "totalAgeYears": "catAgeYears + catAgeMonths / 12",
    "baseHuman": "(totalAgeYears <= 1) ? 15 * totalAgeYears : (totalAgeYears <= 2) ? 15 + 9 * (totalAgeYears - 1) : 24 + 4 * (totalAgeYears - 2)",
    "weightFactor": "1 + 0.02 * (catWeightKg - 4.5)",
    "indoorFactor": "indoor === 0 ? 1.1 : 1.0",
    "finalHumanYears": "baseHuman * weightFactor * indoorFactor",
    "__baseHuman_toFixed_2__": "${baseHuman.toFixed(2)}",
    "__weightFactor_toFixed_2__": "${weightFactor.toFixed(2)}",
    "__indoorFactor_toFixed_2__": "${indoorFactor.toFixed(2)}",
    "__finalHumanYears_toFixed_1___years": "${finalHumanYears.toFixed(1)} years",
    "result": "Human age equivalent: ${finalHumanYears.toFixed(1)} years"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Base human years (standard curve): ${baseHuman.toFixed(2)}",
      "Weight adjustment factor: ${weightFactor.toFixed(2)}",
      "Lifestyle factor (indoor/outdoor): ${indoorFactor.toFixed(2)}",
      "Final estimated human age: ${finalHumanYears.toFixed(1)} years"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

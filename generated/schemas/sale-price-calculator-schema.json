{
  "toolName": "sale-price-calculator",
  "inputs": [
    {
      "id": "costPrice",
      "label": "Cost Price",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "The base cost of the product.",
      "label_i18n": {
        "en": "Cost Price",
        "tr": "Cost Price",
        "de": "Cost Price",
        "fr": "Cost Price",
        "es": "Cost Price",
        "ar": "Cost Price"
      }
    },
    {
      "id": "markupPercentage",
      "label": "Markup Percentage",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage added to cost to determine initial selling price before discount and tax.",
      "label_i18n": {
        "en": "Markup Percentage",
        "tr": "Markup Percentage",
        "de": "Markup Percentage",
        "fr": "Markup Percentage",
        "es": "Markup Percentage",
        "ar": "Markup Percentage"
      }
    },
    {
      "id": "discount",
      "label": "Discount",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage discount applied to the initial selling price before tax.",
      "label_i18n": {
        "en": "Discount",
        "tr": "Discount",
        "de": "Discount",
        "fr": "Discount",
        "es": "Discount",
        "ar": "Discount"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Sales tax rate applied to the discounted selling price.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "basePrice": "costPrice * (1 + markupPercentage / 100)",
    "discountAmount": "costPrice * (1 + markupPercentage / 100) * discount / 100",
    "discountedPrice": "costPrice * (1 + markupPercentage / 100) * (1 - discount / 100)",
    "taxAmount": "costPrice * (1 + markupPercentage / 100) * (1 - discount / 100) * taxRate / 100",
    "finalPrice": "costPrice * (1 + markupPercentage / 100) * (1 - discount / 100) * (1 + taxRate / 100)"
  },
  "outputs": {
    "primary": "finalPrice",
    "breakdown": [
      "basePrice",
      "discountAmount",
      "taxAmount",
      "discountedPrice"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalPrice",
    "unit": "USD"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

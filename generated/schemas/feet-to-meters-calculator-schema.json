      "businessContext": "Inches part of the length measurement (0-11).",
      "label_i18n": {
        "en": "Inches",
        "tr": "Inches",
        "de": "Inches",
        "fr": "Inches",
        "es": "Inches",
        "ar": "Inches"
      }
    },
    {
      "id": "conversionType",
      "label": "Conversion Standard",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1: International foot (0.3048 m), 2: U.S. survey foot (0.3048006096012192 m).",
      "label_i18n": {
        "en": "Conversion Standard",
        "tr": "Conversion Standard",
        "de": "Conversion Standard",
        "fr": "Conversion Standard",
        "es": "Conversion Standard",
        "ar": "Conversion Standard"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the output in meters.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "totalInches": "feet * 12 + inches",
    "conversionFactor": "conversionType === 2 ? 0.3048006096012192 : 0.3048",
    "meters": "totalInches * conversionFactor / 12",
    "metersRounded": "Math.round(meters * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)"
  },
  "outputs": {
    "primary": "metersRounded",
    "breakdown": [
      "totalInches",
      "conversionFactor",
      "meters",
      "metersRounded"
    ]
  },

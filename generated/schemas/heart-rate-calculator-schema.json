        "fr": "Fréquence cardiaque maximale",
        "es": "Frecuencia cardíaca máxima",
        "ar": "أقصى معدل لضربات القلب"
      },
      "businessContext_i18n": {
        "en": "If known, enter maximum heart rate; 0 to estimate from age using Tanaka formula",
        "tr": "Biliniyorsa maksimum kalp atış hızını girin; 0 girilirse Tanaka formülü ile yaşa göre tahmin edilir",
        "de": "Wenn bekannt, maximale Herzfrequenz eingeben; 0 für Schätzung aus Alter mittels Tanaka-Formel",
        "fr": "Si connue, saisir la fréquence cardiaque maximale ; 0 pour estimer à partir de l'âge avec la formule de Tanaka",
        "es": "Si se conoce, ingrese la frecuencia cardíaca máxima; 0 para estimar a partir de la edad usando la fórmula de Tanaka",
        "ar": "إذا كان معروفًا، أدخل أقصى معدل لضربات القلب؛ 0 للتقدير من العمر باستخدام معادلة تاناكا"
      }
    }
  ],
  "formulas": {
    "maxHeartRate": "maxHR > 0 ? maxHR : 208 - 0.7 * age",
    "heartRateReserve": "(maxHR > 0 ? maxHR : 208 - 0.7 * age) - restingHR",
    "targetHR": "((maxHR > 0 ? maxHR : 208 - 0.7 * age) - restingHR) * (intensity / 100) + restingHR"
  },
  "outputs": {
    "primary": "targetHR",
    "breakdown": [
      "maxHeartRate",
      "heartRateReserve"
    ],
    "hiddenLossDrivers": [],

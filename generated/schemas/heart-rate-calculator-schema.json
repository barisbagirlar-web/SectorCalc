{
  "toolName": "heart-rate-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years."
    },
    {
      "id": "restingHeartRate",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Resting heart rate in beats per minute."
    },
    {
      "id": "intensity",
      "label": "Intensity",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Desired exercise intensity as percentage (0-100)."
    }
  ],
  "formulas": {
    "maxHeartRate": "220 - age",
    "heartRateReserve": "maxHeartRate - restingHeartRate",
    "targetHeartRate": "(heartRateReserve * (intensity / 100)) + restingHeartRate"
  },
  "outputs": {
    "primary": "targetHeartRate",
    "breakdown": [
      "maxHeartRate",
      "heartRateReserve"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

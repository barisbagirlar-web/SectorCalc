      }
    },
    {
      "id": "maxHR",
      "label": "Maximum Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 0,
      "businessContext": "If known, enter maximum heart rate; 0 to estimate from age using Tanaka formula",
      "label_i18n": {
        "en": "Maximum Heart Rate",
        "tr": "Maksimum Kalp Atış Hızı",
        "de": "Maximale Herzfrequenz",
        "fr": "Maximum Heart Rate",
        "es": "Maximum Heart Rate",
        "ar": "Maximum Heart Rate"
      },
      "businessContext_i18n": {
        "en": "If known, enter maximum heart rate; 0 to estimate from age using Tanaka formula",
        "tr": "Biliniyorsa maksimum kalp atış hızını girin; 0 girilirse Tanaka formülü ile yaşa göre tahmin edilir"
      }
    }
  ],
  "formulas": {
    "maxHeartRate": "maxHR > 0 ? maxHR : 208 - 0.7 * age",
    "heartRateReserve": "(maxHR > 0 ? maxHR : 208 - 0.7 * age) - restingHR",
    "targetHR": "((maxHR > 0 ? maxHR : 208 - 0.7 * age) - restingHR) * (intensity / 100) + restingHR"
  },
  "outputs": {
    "primary": "targetHR",
    "breakdown": [
      "maxHeartRate",
      "heartRateReserve"
    ],

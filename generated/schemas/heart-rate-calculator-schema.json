{
  "toolName": "heart-rate-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years"
    },
    {
      "id": "restingHR",
      "label": "Resting Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 70,
      "businessContext": "Resting heart rate in beats per minute"
    },
    {
      "id": "intensity",
      "label": "Intensity",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Target intensity as a percentage (0-100)"
    },
    {
      "id": "maxHR",
      "label": "Maximum Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 0,
      "businessContext": "If known, enter maximum heart rate; 0 to estimate from age using Tanaka formula"
    }
  ],
  "formulas": {
    "maxHeartRate": "maxHR > 0 ? maxHR : 208 - 0.7 * age",
    "heartRateReserve": "(maxHR > 0 ? maxHR : 208 - 0.7 * age) - restingHR",
    "targetHR": "((maxHR > 0 ? maxHR : 208 - 0.7 * age) - restingHR) * (intensity / 100) + restingHR"
  },
  "outputs": {
    "primary": "targetHR",
    "breakdown": [
      "maxHeartRate",
      "heartRateReserve"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "categorySlug": "hse-ergonomics",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",

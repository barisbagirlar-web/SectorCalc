    },
    {
      "id": "intensity",
      "label": "Intensity",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Target intensity as a percentage (0-100)",
      "label_i18n": {
        "en": "Intensity",
        "tr": "Yoğunluk",
        "de": "Intensität",
        "fr": "Intensity",
        "es": "Intensity",
        "ar": "Intensity"
      },
      "businessContext_i18n": {

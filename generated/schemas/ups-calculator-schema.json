{
  "toolName": "ups-calculator",
  "inputs": [
    {
      "id": "totalLoad",
      "label": "Total Load",
      "type": "number",
      "unit": "W",
      "default": 500,
      "businessContext": "Total active power consumption of connected equipment (Watts)",
      "label_i18n": {
        "en": "Total Load",
        "tr": "Toplam Yük",
        "de": "Total Load",
        "fr": "Total Load",
        "es": "Total Load",
        "ar": "Total Load"
      },
      "businessContext_i18n": {
        "en": "Total active power consumption of connected equipment (Watts)",
        "tr": "Bağlı ekipmanın toplam aktif güç tüketimi (Watt)."
      }
    },
    {
      "id": "powerFactor",
      "label": "Power Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.8,
      "businessContext": "Power factor of the load (typically 0.7-0.9), ≤1",
      "label_i18n": {
        "en": "Power Factor",
        "tr": "Güç Faktörü",
        "de": "Leistungsfaktor",
        "fr": "Power Factor",
        "es": "Power Factor",
        "ar": "Power Factor"
      },
      "businessContext_i18n": {
        "en": "Power factor of the load (typically 0.7-0.9), ≤1",
        "tr": "Yükün güç faktörü (tipik olarak 0.7-0.9), ≤1."
      }
    },
    {
      "id": "requiredRuntime",
      "label": "Required Runtime",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Required backup time in minutes during power outage",
      "label_i18n": {
        "en": "Required Runtime",
        "tr": "Gerekli Çalışma Süresi",
        "de": "Required Runtime",
        "fr": "Required Runtime",
        "es": "Required Runtime",
        "ar": "Required Runtime"
      },
      "businessContext_i18n": {
        "en": "Required backup time in minutes during power outage",
        "tr": "Elektrik kesintisi sırasında gerekli yedekleme süresi (dakika)."
      }
    },
    {
      "id": "inverterEfficiency",
      "label": "Inverter Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Efficiency of the UPS inverter in converting DC to AC, typically 85-95%",
      "label_i18n": {
        "en": "Inverter Efficiency",
        "tr": "İnvertör Verimliliği",
        "de": "Inverter Efficiency",
        "fr": "Inverter Efficiency",
        "es": "Inverter Efficiency",
        "ar": "Inverter Efficiency"
      },
      "businessContext_i18n": {
        "en": "Efficiency of the UPS inverter in converting DC to AC, typically 85-95%",
        "tr": "UPS invertörünün DC'yi AC'ye dönüştürme verimliliği, tipik olarak %85-95."
      }
    },
    {
      "id": "batteryVoltage",
      "label": "Battery Voltage",
      "type": "number",
      "unit": "V",
      "default": 12,
      "businessContext": "DC system voltage of the battery bank (e.g., 12V, 24V, 48V)",
      "label_i18n": {
        "en": "Battery Voltage",
        "tr": "Akü Gerilimi",
        "de": "Battery Voltage",
        "fr": "Battery Voltage",
        "es": "Battery Voltage",
        "ar": "Battery Voltage"
      },
      "businessContext_i18n": {
        "en": "DC system voltage of the battery bank (e.g., 12V, 24V, 48V)",
        "tr": "Akü bankasının DC sistem gerilimi (örn. 12V, 24V, 48V)."
      }
    },
    {
      "id": "depthOfDischarge",
      "label": "Depth of Discharge",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Maximum depth of discharge for battery, to prolong life (e.g., 50% for lead-acid)",
      "label_i18n": {
        "en": "Depth of Discharge",
        "tr": "Deşarj Derinliği",
        "de": "Depth of Discharge",
        "fr": "Depth of Discharge",
        "es": "Depth of Discharge",
        "ar": "Depth of Discharge"
      },
      "businessContext_i18n": {
        "en": "Maximum depth of discharge for battery, to prolong life (e.g., 50% for lead-acid)",
        "tr": "Akü ömrünü uzatmak için maksimum deşarj derinliği (örn. kurşun-asit için %50)."
      }
    },
    {
      "id": "numberOfBatteries",
      "label": "Number of Batteries in Parallel",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of identical batteries connected in parallel to share load",
      "label_i18n": {
        "en": "Number of Batteries in Parallel",
        "tr": "Paralel Akü Sayısı",
        "de": "Number of Batteries in Parallel",
        "fr": "Number of Batteries in Parallel",
        "es": "Number of Batteries in Parallel",
        "ar": "Number of Batteries in Parallel"
      },
      "businessContext_i18n": {
        "en": "Number of identical batteries connected in parallel to share load",
        "tr": "Yükü paylaşmak için paralel bağlanan özdeş akü sayısı."
      }
    }
  ],
  "formulas": {
    "totalVA": "totalLoad / powerFactor",
    "loadCurrent": "(totalLoad / powerFactor) / batteryVoltage",
    "batteryWattHours": "(totalLoad * requiredRuntime) / 60",
    "adjustedWattHours": "(totalLoad * requiredRuntime) / 60 / (inverterEfficiency / 100) / (depthOfDischarge / 100)",
    "totalRequiredAh": "(((totalLoad * requiredRuntime) / 60) / ((inverterEfficiency / 100) * (depthOfDischarge / 100))) / batteryVoltage",
    "perBatteryCapacityAh": "(((totalLoad * requiredRuntime) / 60) / ((inverterEfficiency / 100) * (depthOfDischarge / 100)) / batteryVoltage) / numberOfBatteries"
  },
  "outputs": {
    "primary": "perBatteryCapacityAh",
    "breakdown": [
      "totalRequiredAh",
      "totalVA",
      "loadCurrent",
      "batteryWattHours",
      "adjustedWattHours"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "perBatteryCapacityAh",
    "unit": "W",
    "breakdownUnits": {
      "batteryWattHours": "h",
      "adjustedWattHours": "h"
    }
  },
  "category": "Verimlilik & OEE",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "electrical-power-systems",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "efficiency",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

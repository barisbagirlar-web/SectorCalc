{
  "toolName": "gold-score-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "g",
      "default": 10,
      "businessContext": "Weight of the gold item in grams",
      "label_i18n": {
        "en": "Weight",
        "tr": "Weight",
        "de": "Weight",
        "fr": "Weight",
        "es": "Weight",
        "ar": "Weight"
      }
    },
    {
      "id": "purity",
      "label": "Purity",
      "type": "number",
      "unit": "karat",
      "default": 24,
      "businessContext": "Karat value indicating purity (24 = pure gold)",
      "label_i18n": {
        "en": "Purity",
        "tr": "Purity",
        "de": "Purity",
        "fr": "Purity",
        "es": "Purity",
        "ar": "Purity"
      }
    },
    {
      "id": "marketPrice",
      "label": "Market Price",
      "type": "number",
      "unit": "€/g",
      "default": 50,
      "businessContext": "Current market price of gold per gram",
      "label_i18n": {
        "en": "Market Price",
        "tr": "Market Price",
        "de": "Market Price",
        "fr": "Market Price",
        "es": "Market Price",
        "ar": "Market Price"
      }
    },
    {
      "id": "makingChargePercent",
      "label": "Making Charge",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage charged for craftsmanship",
      "label_i18n": {
        "en": "Making Charge",
        "tr": "Making Charge",
        "de": "Making Charge",
        "fr": "Making Charge",
        "es": "Making Charge",
        "ar": "Making Charge"
      }
    },
    {
      "id": "taxRatePercent",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Applicable tax rate (e.g., VAT) as a percentage",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "goldContentValue": "weight * (purity / 24) * marketPrice",
    "makingCharges": "goldContentValue * (makingChargePercent / 100)",
    "taxAmount": "(goldContentValue + makingCharges) * (taxRatePercent / 100)",
    "totalCost": "goldContentValue + makingCharges + taxAmount",
    "goldScore": "(goldContentValue / totalCost) * 100"
  },
  "outputs": {
    "primary": "goldScore",
    "breakdown": [
      "goldContentValue",
      "makingCharges",
      "taxAmount",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "goldScore"
  },

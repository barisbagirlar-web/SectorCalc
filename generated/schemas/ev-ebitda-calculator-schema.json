      "unit": "currency",
      "default": 0,
      "businessContext": "Kısa ve uzun vadeli borç toplamı"
    },
    {
      "id": "minority_interest",
      "label": "Azınlık Payları",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Azınlık hissedarların payları (varsa)"
    },
    {
      "id": "preferred_stock",
      "label": "İmtiyazlı Hisse Senetleri",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "İmtiyazlı hisse senedi değeri (varsa)"
    },
    {
      "id": "cash_equivalents",
      "label": "Nakit ve Benzerleri",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Nakit ve nakde eşdeğer varlıklar toplamı"
    },

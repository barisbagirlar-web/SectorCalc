        "ar": "عدد البراغي"
      },
      "businessContext_i18n": {
        "en": "Total number of bolts on the flange",
        "tr": "Flanştaki toplam civata sayısı",
        "de": "Gesamtzahl der Schrauben im Flansch",
        "fr": "Nombre total de boulons sur la bride",
        "es": "Número total de pernos en la brida",
        "ar": "إجمالي عدد البراغي في الشفة"
      }
    }
  ],
  "formulas": {
    "pressureMPa": "designPressure * 0.1",
    "meanDiam": "(innerDiameter + outerDiameter) / 2",
    "effWidth": "(outerDiameter - innerDiameter) / 2",
    "operatingForce": "(Math.PI * meanDiam**2 * pressureMPa / 4) + (2 * effWidth * Math.PI * meanDiam * gasketFactor * pressureMPa)",
    "seatingForce": "Math.PI * effWidth * meanDiam * seatingStress",
    "operatingForcePerBolt": "operatingForce / boltCount",
    "seatingForcePerBolt": "seatingForce / boltCount",
    "effectiveArea": "Math.PI / 4 * (outerDiameter**2 - innerDiameter**2)"
  },
  "outputs": {
    "primary": "effectiveArea",
    "breakdown": [
      "('Çalışma Yükü: ' + (operatingForce / 1000).toFixed(2) + ' kN')",
      "('Oturma Yükü: ' + (seatingForce / 1000).toFixed(2) + ' kN')"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result",
    "unit": "mm"
  },

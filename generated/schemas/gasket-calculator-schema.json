    {
      "id": "boltCount",
      "label": "Number of Bolts",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Total number of bolts on the flange",
      "label_i18n": {
        "en": "Number of Bolts",
        "tr": "Civata Sayısı",
        "de": "Anzahl der Schrauben",
        "fr": "Nombre de boulons",

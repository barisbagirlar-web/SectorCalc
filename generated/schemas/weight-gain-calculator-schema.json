{
  "toolName": "weight-gain-calculator",
  "inputs": [
    {
      "id": "surfaceArea",
      "label": "Surface Area per Part",
      "type": "number",
      "unit": "m²",
      "default": 0.5,
      "businessContext": "Total surface area of a single part to be coated, measured in square meters.",
      "label_i18n": {
        "en": "Surface Area per Part",
        "tr": "Surface Area per Part",
        "de": "Surface Area per Part",
        "fr": "Surface Area per Part",
        "es": "Surface Area per Part",
        "ar": "Surface Area per Part"
      }
    },
    {
      "id": "coatingThickness",
      "label": "Coating Thickness",
      "type": "number",
      "unit": "µm",
      "default": 50,
      "businessContext": "Target dry film thickness of the coating, measured in micrometers.",
      "label_i18n": {
        "en": "Coating Thickness",
        "tr": "Coating Thickness",
        "de": "Coating Thickness",
        "fr": "Coating Thickness",
        "es": "Coating Thickness",
        "ar": "Coating Thickness"
      }
    },
    {
      "id": "coatingDensity",
      "label": "Coating Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1200,
      "businessContext": "Density of the coating material in its dried state, in kilograms per cubic meter.",
      "label_i18n": {
        "en": "Coating Material Density",
        "tr": "Coating Material Density",
        "de": "Coating Material Density",
        "fr": "Coating Material Density",
        "es": "Coating Material Density",
        "ar": "Coating Material Density"
      }
    },
    {
      "id": "numberOfParts",
      "label": "Number of Parts",
      "type": "number",
      "unit": "pieces",
      "default": 100,
      "businessContext": "Quantity of parts to be coated in the batch.",
      "label_i18n": {
        "en": "Number of Parts",
        "tr": "Number of Parts",
        "de": "Number of Parts",
        "fr": "Number of Parts",
        "es": "Number of Parts",
        "ar": "Number of Parts"
      }
    }
  ],
  "formulas": {
    "coatingVolumePerPart": "surfaceArea * coatingThickness / 1000000",
    "weightGainPerPart": "coatingVolumePerPart * coatingDensity",
    "totalWeightGain": "weightGainPerPart * numberOfParts"
  },
  "outputs": {
    "primary": "totalWeightGain",
    "breakdown": [
      "weightGainPerPart",
      "coatingVolumePerPart"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

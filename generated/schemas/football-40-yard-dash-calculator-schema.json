        "tr": "Güç çıkışını tahmin etmek için sporcunun vücut ağırlığı.",
        "de": "Körpergewicht des Athleten zur Schätzung der Leistungsabgabe."
      }
    },
    {
      "id": "wind_mph",
      "label": "Wind Speed (mph)",
      "type": "number",
      "unit": "mph",
      "default": 0,
      "businessContext": "Wind speed, positive for tailwind, negative for headwind, to adjust effective time.",
      "label_i18n": {
        "en": "Wind Speed (mph)",
        "tr": "Rüzgar Hızı (mph)",
        "de": "Windgeschwindigkeit (mph)",
        "fr": "Wind Speed (mph)",
        "es": "Wind Speed (mph)",
        "ar": "Wind Speed (mph)"
      },
      "businessContext_i18n": {
        "en": "Wind speed, positive for tailwind, negative for headwind, to adjust effective time.",
        "tr": "Rüzgar hızı, arkadan rüzgar için pozitif, karşıdan rüzgar için negatif, etkin süreyi ayarlamak için.",
        "de": "Windgeschwindigkeit, positiv für Rückenwind, negativ für Gegenwind, zur Anpassung der effektiven Zeit."
      }
    }
  ],
  "formulas": {
    "distance_m": "distance_yards * 0.9144",
    "time_eff": "time_seconds * (1 - 0.001 * wind_mph)",
    "speed_mph": "(distance_yards * 3600) / (time_eff * 1760)",
    "speed_kmh": "speed_mph * 1.60934",
    "speed_ms": "distance_m / time_eff",
    "mass_kg": "weight_lbs * 0.453592",
    "acceleration_mps2": "(2 * distance_m) / (time_eff * time_eff)",
    "power_watts": "(2 * mass_kg * distance_m * distance_m) / (time_eff * time_eff * time_eff)",
    "power_hp": "power_watts / 745.7"
  },
  "outputs": {
    "primary": "speed_mph",
    "breakdown": [
      "speed_kmh",
      "speed_ms",
      "acceleration_mps2",
      "power_watts",
      "power_hp"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "power_hp",
    "unit": "yd",
    "breakdownUnits": {
      "acceleration_mps2": "%",
      "power_watts": "W"
    }
  },

    {
      "id": "outdoorTemp",
      "label": "Outdoor Temperature",
      "type": "number",
      "unit": "°C",
      "default": -5,
      "businessContext": "Design outdoor air temperature",
      "label_i18n": {
        "en": "Outdoor Temperature",
        "tr": "Dış Ortam Sıcaklığı",
        "de": "Outdoor Temperature",
        "fr": "Outdoor Temperature",
        "es": "Outdoor Temperature",
        "ar": "Outdoor Temperature"
      },
      "businessContext_i18n": {
        "en": "Design outdoor air temperature",
        "tr": "Tasarım dış hava sıcaklığı"
      }
    }
  ],
  "formulas": {
    "deltaT": "indoorTemp - outdoorTemp",
    "wallLoss": "uWall * wallArea * deltaT",
    "windowLoss": "uWindow * windowArea * deltaT",
    "roofLoss": "uRoof * roofArea * deltaT",
    "totalHeatLoss": "wallLoss + windowLoss + roofLoss"
  },
  "outputs": {
    "primary": "totalHeatLoss",
    "breakdown": [
      "wallLoss",
      "windowLoss",
      "roofLoss"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalHeatLoss",
    "unit": "m²"
  },

{
  "toolName": "bogo-calculator",
  "inputs": [
    {
      "id": "originalPrice",
      "label": "Original Price per Item",
      "type": "number",
      "unit": "currency",
      "default": 10,
      "businessContext": "The regular unit selling price of the item before any promotion.",
      "label_i18n": {
        "en": "Original Price per Item",
        "tr": "Original Price per Item",
        "de": "Original Price per Item",
        "fr": "Original Price per Item",
        "es": "Original Price per Item",
        "ar": "Original Price per Item"
      }
    },
    {
      "id": "buyQuantity",
      "label": "Buy Quantity",
      "type": "number",
      "unit": "items",
      "default": 1,
      "businessContext": "Number of items the customer must purchase to qualify for the free items (the 'Buy' part).",
      "label_i18n": {
        "en": "Buy Quantity",
        "tr": "Buy Quantity",
        "de": "Buy Quantity",
        "fr": "Buy Quantity",
        "es": "Buy Quantity",
        "ar": "Buy Quantity"
      }
    },
    {
      "id": "getQuantity",
      "label": "Get Quantity (Free)",
      "type": "number",
      "unit": "items",
      "default": 1,
      "businessContext": "Number of items the customer receives for free (the 'Get' part).",
      "label_i18n": {
        "en": "Get Quantity (Free)",
        "tr": "Get Quantity (Free)",
        "de": "Get Quantity (Free)",
        "fr": "Get Quantity (Free)",
        "es": "Get Quantity (Free)",
        "ar": "Get Quantity (Free)"
      }
    },
    {
      "id": "numberOfSets",
      "label": "Number of Sets",
      "type": "number",
      "unit": "sets",
      "default": 1,
      "businessContext": "How many times the BOGO deal is applied (e.g., buy 2 get 1 free repeated twice).",
      "label_i18n": {
        "en": "Number of Sets",
        "tr": "Number of Sets",
        "de": "Number of Sets",
        "fr": "Number of Sets",
        "es": "Number of Sets",
        "ar": "Number of Sets"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Applicable tax percentage on the purchase. Set to 0 if tax is not considered.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "additionalDiscount",
      "label": "Additional Discount",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Any extra percentage discount applied to the total (e.g., store-wide sale).",
      "label_i18n": {
        "en": "Additional Discount",
        "tr": "Additional Discount",
        "de": "Additional Discount",
        "fr": "Additional Discount",
        "es": "Additional Discount",
        "ar": "Additional Discount"
      }
    }
  ],
  "formulas": {
    "totalItems": "(buyQuantity + getQuantity) * numberOfSets",
    "totalCost": "originalPrice * buyQuantity * numberOfSets * (1 - additionalDiscount / 100) * (1 + taxRate / 100)",
    "costPerItem": "(originalPrice * buyQuantity * numberOfSets * (1 - additionalDiscount / 100) * (1 + taxRate / 100)) / ((buyQuantity + getQuantity) * numberOfSets)",
    "totalSavings": "originalPrice * (buyQuantity + getQuantity) * numberOfSets - originalPrice * buyQuantity * numberOfSets * (1 - additionalDiscount / 100) * (1 + taxRate / 100)",
    "effectiveDiscountPercent": "(1 - (buyQuantity * (1 - additionalDiscount / 100) * (1 + taxRate / 100)) / (buyQuantity + getQuantity)) * 100"
  },
  "outputs": {
    "primary": "effectiveDiscountPercent",
    "breakdown": [
      "totalItems",
      "totalCost",
      "costPerItem",
      "totalSavings",
      "effectiveDiscountPercent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveDiscountPercent"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "dog-age-calculator",
  "inputs": [
    {
      "id": "dogAgeYears",
      "label": "Dog Age Years",
      "type": "number",
      "unit": "years",
      "default": 1,
      "businessContext": "The whole number of years the dog has lived.",
      "label_i18n": {
        "en": "Dog Age Years",
        "tr": "Dog Age Years",
        "de": "Dog Age Years",

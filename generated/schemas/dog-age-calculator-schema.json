      }
    },
    {
      "id": "dogAgeMonths",
      "label": "Dog Age Months",
      "type": "number",
      "unit": "months",
      "default": 0,
      "businessContext": "Additional months beyond last full year.",
      "label_i18n": {
        "en": "Dog Age Months",
        "tr": "Dog Age Months",
        "de": "Dog Age Months",
        "fr": "Dog Age Months",
        "es": "Dog Age Months",
        "ar": "Dog Age Months"
      }
    },
    {
      "id": "sizeCategory",
      "label": "Breed Size Category",
      "type": "number",
      "unit": "1=Small, 2=Medium, 3=Large",
      "default": 2,
      "businessContext": "Size category of the dog breed, impacting age conversion factor.",
      "label_i18n": {
        "en": "Breed Size Category",
        "tr": "Breed Size Category",
        "de": "Breed Size Category",
        "fr": "Breed Size Category",
        "es": "Breed Size Category",
        "ar": "Breed Size Category"
      }
    },
    {
      "id": "conversionModel",
      "label": "Conversion Model",
      "type": "number",
      "unit": "1=Traditional (7:1), 2=Adjusted (Breed-size)",
      "default": 2,
      "businessContext": "Select the mathematical model for age conversion.",
      "label_i18n": {
        "en": "Conversion Model",
        "tr": "Conversion Model",
        "de": "Conversion Model",
        "fr": "Conversion Model",
        "es": "Conversion Model",
        "ar": "Conversion Model"
      }
    }
  ],
  "formulas": {
    "totalHumanAge": "dogAgeYears + dogAgeMonths / 12",
    "sizeMultiplier": "sizeCategory == 1 ? 4 : (sizeCategory == 2 ? 5 : 6)",
    "dogYearsTraditional": "totalHumanAge * 7",
    "dogYearsAdjusted": "totalHumanAge <= 1 ? totalHumanAge * 15 : (totalHumanAge <= 2 ? 15 + (totalHumanAge - 1) * 9 : 24 + (totalHumanAge - 2) * sizeMultiplier)",
    "dogYears": "conversionModel == 1 ? dogYearsTraditional : dogYearsAdjusted"
  },
  "outputs": {
    "primary": "dogYears",
    "breakdown": [
      "totalHumanAge",
      "sizeMultiplier",
      "conversionModel"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dogYears",
    "unit": "years"
  },

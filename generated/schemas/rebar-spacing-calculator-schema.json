{
  "toolName": "rebar-spacing-calculator",
  "inputs": [
    {
      "id": "concreteWidth",
      "label": "Element Width",
      "type": "number",
      "unit": "mm",
      "default": 1000,
      "businessContext": "Total width of the concrete element (e.g., beam or slab dimension perpendicular to rebar direction).",
      "label_i18n": {
        "en": "Element Width",
        "tr": "Element Width",
        "de": "Element Width",
        "fr": "Element Width",
        "es": "Element Width",
        "ar": "Element Width"
      }
    },
    {
      "id": "leftCover",
      "label": "Left Cover",
      "type": "number",
      "unit": "mm",
      "default": 40,
      "businessContext": "Clear concrete cover from left edge to outer surface of leftmost rebar.",
      "label_i18n": {
        "en": "Left Cover",
        "tr": "Left Cover",
        "de": "Left Cover",
        "fr": "Left Cover",
        "es": "Left Cover",
        "ar": "Left Cover"
      }
    },
    {
      "id": "rightCover",
      "label": "Right Cover",
      "type": "number",
      "unit": "mm",
      "default": 40,
      "businessContext": "Clear concrete cover from right edge to outer surface of rightmost rebar.",
      "label_i18n": {
        "en": "Right Cover",
        "tr": "Right Cover",
        "de": "Right Cover",
        "fr": "Right Cover",
        "es": "Right Cover",
        "ar": "Right Cover"
      }
    },
    {
      "id": "rebarDiameter",
      "label": "Rebar Diameter",
      "type": "number",
      "unit": "mm",
      "default": 12,
      "businessContext": "Nominal diameter of the reinforcing bar.",
      "label_i18n": {
        "en": "Rebar Diameter",
        "tr": "Rebar Diameter",
        "de": "Rebar Diameter",
        "fr": "Rebar Diameter",
        "es": "Rebar Diameter",
        "ar": "Rebar Diameter"
      }
    },
    {
      "id": "numberOfBars",
      "label": "Number of Bars",
      "type": "number",
      "unit": "unit",
      "default": 5,
      "businessContext": "Total number of longitudinal bars placed within the element width (must be ≥2).",
      "label_i18n": {
        "en": "Number of Bars",
        "tr": "Number of Bars",
        "de": "Number of Bars",
        "fr": "Number of Bars",
        "es": "Number of Bars",
        "ar": "Number of Bars"
      }
    }
  ],
  "formulas": {
    "centerToCenterSpacing": "(concreteWidth - leftCover - rightCover - rebarDiameter) / (numberOfBars - 1)",
    "clearSpacing": "centerToCenterSpacing - rebarDiameter",
    "firstBarEdgeDistance": "leftCover + rebarDiameter / 2",
    "lastBarEdgeDistance": "rightCover + rebarDiameter / 2"
  },
  "outputs": {
    "primary": "centerToCenterSpacing",
    "breakdown": [
      "clearSpacing",
      "firstBarEdgeDistance",
      "lastBarEdgeDistance"
    ]
  },
  "category": "Diğer",
  "sector": "İnşaat & Yapı",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "diger"
}

{
  "toolName": "envelope-size-calculator",
  "inputs": [
    {
      "id": "width",
      "label": "Envelope Width",
      "type": "number",
      "unit": "mm",
      "default": 229,
      "businessContext": "Width of the envelope in millimeters",
      "label_i18n": {
        "en": "Envelope Width",
        "tr": "Envelope Width",
        "de": "Envelope Width",
        "fr": "Envelope Width",
        "es": "Envelope Width",
        "ar": "Envelope Width"
      }
    },
    {
      "id": "height",
      "label": "Envelope Height",
      "type": "number",
      "unit": "mm",
      "default": 162,
      "businessContext": "Height of the envelope in millimeters",
      "label_i18n": {
        "en": "Envelope Height",
        "tr": "Envelope Height",
        "de": "Envelope Height",
        "fr": "Envelope Height",
        "es": "Envelope Height",
        "ar": "Envelope Height"
      }
    },
    {
      "id": "flapLength",
      "label": "Flap Length",
      "type": "number",
      "unit": "mm",
      "default": 30,
      "businessContext": "Length of the envelope flap in millimeters",
      "label_i18n": {
        "en": "Flap Length",
        "tr": "Flap Length",
        "de": "Flap Length",
        "fr": "Flap Length",
        "es": "Flap Length",
        "ar": "Flap Length"
      }
    },
    {
      "id": "paperThickness",
      "label": "Paper Thickness",
      "type": "number",
      "unit": "mm",
      "default": 0.1,
      "businessContext": "Thickness of the paper used in millimeters",
      "label_i18n": {
        "en": "Paper Thickness",
        "tr": "Paper Thickness",
        "de": "Paper Thickness",
        "fr": "Paper Thickness",
        "es": "Paper Thickness",
        "ar": "Paper Thickness"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 1000,
      "businessContext": "Number of envelopes to be produced",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Quantity",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      }
    }
  ],
  "formulas": {
    "totalPaperArea": "((width + 2 * flapLength) * (height + flapLength)) * quantity",
    "totalPaperVolume": "totalPaperArea * paperThickness",
    "envelopeSurfaceArea": "2 * (width * height + width * flapLength + height * flapLength)",
    "totalSurfaceArea": "envelopeSurfaceArea * quantity"
  },
  "outputs": {
    "primary": "totalPaperArea",
    "breakdown": [
      "totalPaperArea",
      "totalPaperVolume",
      "envelopeSurfaceArea",
      "totalSurfaceArea"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalSurfaceArea"
  },

{
  "toolName": "atom-ekonomisi-hesaplayici",
  "inputs": [
    {
      "id": "target_mass",
      "label": "Hedef Ürün Kütlesi (g)",
      "type": "number",
      "unit": "g",
      "default": 100,
      "businessContext": "Reaksiyonda üretilmesi hedeflenen ana ürünün kütlesi"
    },
    {
      "id": "total_reactant_mass",
      "label": "Toplam Reaktan Kütlesi (g)",
      "type": "number",
      "unit": "g",
      "default": 200,
      "businessContext": "Reaksiyona giren tüm başlangıç maddelerinin toplam kütlesi"
    },
    {
      "id": "byproduct_mass",
      "label": "Yan Ürün Kütlesi (g)",
      "type": "number",
      "unit": "g",
      "default": 50,
      "businessContext": "Reaksiyon sonucu oluşan istenmeyen yan ürünlerin toplam kütlesi"
    },
    {
      "id": "catalyst_mass",
      "label": "Katalizör Kütlesi (g)",
      "type": "number",
      "unit": "g",
      "default": 5,
      "businessContext": "Reaksiyonda kullanılan katalizörün kütlesi (reaksiyona girmeden kalır)"
    },
    {
      "id": "solvent_mass",
      "label": "Çözücü Kütlesi (g)",
      "type": "number",
      "unit": "g",
      "default": 100,
      "businessContext": "Reaksiyonda kullanılan çözücünün kütlesi (reaksiyona girmez)"
    },
    {
      "id": "recovered_mass",
      "label": "Geri Kazanılan Kütle (g)",
      "type": "number",
      "unit": "g",
      "default": 30,
      "businessContext": "Reaksiyon sonrası geri kazanılan katalizör veya çözücü kütlesi"
    }
  ],
  "formulas": {
    "atom_economy": "target_mass / (total_reactant_mass + catalyst_mass + solvent_mass - recovered_mass) * 100",
    "waste_factor": "(total_reactant_mass + catalyst_mass + solvent_mass - recovered_mass - target_mass) / target_mass",
    "e_factor": "(byproduct_mass + (total_reactant_mass + catalyst_mass + solvent_mass - recovered_mass - target_mass)) / target_mass"
  },
  "outputs": {
    "primary": "atom_economy",
    "breakdown": [
      "Atom Ekonomisi: %{atom_economy}",
      "Atık Faktörü: {waste_factor}",
      "E-Faktörü: {e_factor}"
    ]
  },
  "category": "Malzeme, Fire & OEE",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

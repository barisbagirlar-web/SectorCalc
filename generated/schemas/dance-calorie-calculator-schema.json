      "id": "intensityFactor",
      "label": "Intensity Adjustment Factor",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Multiplier to adjust calculated calories for perceived effort (0.5 = half effort, 2.0 = twice effort).",

        "de": "Intensity Adjustment Factor",
        "fr": "Intensity Adjustment Factor",
        "es": "Intensity Adjustment Factor",
        "ar": "Intensity Adjustment Factor"
      }
    }
  ],
  "formulas": {
    "caloriesBurned": "met * weight * intensityFactor * (duration / 60)",

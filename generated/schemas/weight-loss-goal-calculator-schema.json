{
  "toolName": "weight-loss-goal-calculator",
  "inputs": [
    {
      "id": "currentWeight",
      "label": "Current Weight",
      "type": "number",
      "unit": "kg",
      "default": 80,
      "businessContext": "User's current body weight in kilograms"
    },
    {
      "id": "targetWeight",
      "label": "Target Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's desired body weight in kilograms"
    },
    {
      "id": "dailyDeficit",
      "label": "Daily Calorie Deficit",
      "type": "number",
      "unit": "kcal",
      "default": 500,
      "businessContext": "Planned daily calorie deficit"
    },
    {
      "id": "caloriePerKg",
      "label": "Calories per kg of weight loss",
      "type": "number",
      "unit": "kcal/kg",
      "default": 7700,
      "businessContext": "Approximate calories needed to lose one kilogram (7700 kcal/kg)"
    }
  ],
  "formulas": {
    "totalDeficit": "(currentWeight - targetWeight) * caloriePerKg",
    "daysToTarget": "totalDeficit / dailyDeficit",
    "weeklyLoss": "(dailyDeficit * 7) / caloriePerKg"
  },
  "outputs": {
    "primary": "Estimated days to reach target: {{daysToTarget}} days",
    "breakdown": [
      "Weekly weight loss: {{weeklyLoss}} kg",
      "Total calorie deficit needed: {{totalDeficit}} kcal"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

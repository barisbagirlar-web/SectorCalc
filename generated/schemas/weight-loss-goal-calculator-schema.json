      "businessContext": "User's desired body weight in kilograms",
      "label_i18n": {
        "en": "Target Weight",
        "tr": "Target Weight",
        "de": "Target Weight",
        "fr": "Target Weight",
        "es": "Target Weight",
        "ar": "Target Weight"
      }
    },
    {
      "id": "dailyDeficit",
      "label": "Daily Calorie Deficit",
      "type": "number",
      "unit": "kcal",
      "default": 500,
      "businessContext": "Planned daily calorie deficit",
      "label_i18n": {
        "en": "Daily Calorie Deficit",
        "tr": "Daily Calorie Deficit",
        "de": "Daily Calorie Deficit",
        "fr": "Daily Calorie Deficit",
        "es": "Daily Calorie Deficit",
        "ar": "Daily Calorie Deficit"
      }
    },
    {
      "id": "caloriePerKg",
      "label": "Calories per kg of weight loss",
      "type": "number",
      "unit": "kcal/kg",
      "default": 7700,
      "businessContext": "Approximate calories needed to lose one kilogram (7700 kcal/kg)",
      "label_i18n": {
        "en": "Calories per kg of weight loss",
        "tr": "Calories per kg of weight loss",
        "de": "Calories per kg of weight loss",
        "fr": "Calories per kg of weight loss",
        "es": "Calories per kg of weight loss",
        "ar": "Calories per kg of weight loss"
      }
    }
  ],
  "formulas": {
    "totalDeficit": "(currentWeight - targetWeight) * caloriePerKg",
    "daysToTarget": "totalDeficit / dailyDeficit",
    "weeklyLoss": "(dailyDeficit * 7) / caloriePerKg"
  },
  "outputs": {
    "primary": "totalDeficit",
    "breakdown": [
      "Weekly weight loss: {{weeklyLoss}} kg",
      "Total calorie deficit needed: {{totalDeficit}} kcal"
    ],

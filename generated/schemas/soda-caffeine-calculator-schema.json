        "de": "Safe Limit per kg",
        "fr": "Safe Limit per kg",
        "es": "Safe Limit per kg",
        "ar": "Safe Limit per kg"
      }
    },
    {
      "id": "coffeeCaffeinePerCup",
      "label": "Coffee Caffeine per Cup",
      "type": "number",
      "unit": "mg",
      "default": 95,
      "businessContext": "Average caffeine in an 8oz cup of coffee for equivalence",
      "label_i18n": {
        "en": "Coffee Caffeine per Cup",
        "tr": "Coffee Caffeine per Cup",
        "de": "Coffee Caffeine per Cup",
        "fr": "Coffee Caffeine per Cup",
        "es": "Coffee Caffeine per Cup",
        "ar": "Coffee Caffeine per Cup"
      }
    }
  ],
  "formulas": {
    "totalCaffeine": "cansConsumed * caffeinePerServing",
    "safeLimit": "bodyWeight * safeLimitPerKg",
    "percentOfLimit": "(totalCaffeine / safeLimit) * 100",
    "coffeeEquiv": "totalCaffeine / coffeeCaffeinePerCup"
  },
  "outputs": {
    "primary": "totalCaffeine",
    "breakdown": [
      "safeLimit",
      "percentOfLimit",
      "coffeeEquiv"
    ]
  },

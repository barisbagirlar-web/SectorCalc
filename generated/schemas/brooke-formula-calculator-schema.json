{
  "toolName": "brooke-formula-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Patient's body weight in kilograms.",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Body Weight",
        "de": "Body Weight",
        "fr": "Body Weight",
        "es": "Body Weight",
        "ar": "Body Weight"
      }
    },
    {
      "id": "tbsa",
      "label": "Total Burn Surface Area",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage of total body surface area affected by burns.",
      "label_i18n": {
        "en": "Total Burn Surface Area",
        "tr": "Total Burn Surface Area",
        "de": "Total Burn Surface Area",
        "fr": "Total Burn Surface Area",
        "es": "Total Burn Surface Area",
        "ar": "Total Burn Surface Area"
      }
    },
    {
      "id": "fluidFactor",
      "label": "Fluid Volume Factor",
      "type": "number",
      "unit": "mL/kg/%",
      "default": 2,
      "businessContext": "Standard Brooke formula uses 2 mL/kg/% TBSA.",
      "label_i18n": {
        "en": "Fluid Volume Factor",
        "tr": "Fluid Volume Factor",
        "de": "Fluid Volume Factor",
        "fr": "Fluid Volume Factor",
        "es": "Fluid Volume Factor",
        "ar": "Fluid Volume Factor"
      }
    },
    {
      "id": "firstPeriodHours",
      "label": "First Period Hours",
      "type": "number",
      "unit": "h",
      "default": 8,
      "businessContext": "Hours for first half of fluid administration.",
      "label_i18n": {
        "en": "First Period Hours",
        "tr": "First Period Hours",
        "de": "First Period Hours",
        "fr": "First Period Hours",
        "es": "First Period Hours",
        "ar": "First Period Hours"
      }
    },
    {
      "id": "secondPeriodHours",
      "label": "Second Period Hours",
      "type": "number",
      "unit": "h",
      "default": 16,
      "businessContext": "Hours for second half of fluid administration.",
      "label_i18n": {
        "en": "Second Period Hours",
        "tr": "Second Period Hours",
        "de": "Second Period Hours",
        "fr": "Second Period Hours",
        "es": "Second Period Hours",
        "ar": "Second Period Hours"
      }
    }
  ],
  "formulas": {
    "totalFluid": "fluidFactor * weight * tbsa",
    "firstHalf": "totalFluid / 2",
    "secondHalf": "totalFluid / 2",
    "firstHourlyRate": "firstHalf / firstPeriodHours",
    "secondHourlyRate": "secondHalf / secondPeriodHours"
  },
  "outputs": {
    "primary": "totalFluid",
    "breakdown": [
      "firstHalf",
      "secondHalf",
      "firstHourlyRate",
      "secondHourlyRate"
    ],

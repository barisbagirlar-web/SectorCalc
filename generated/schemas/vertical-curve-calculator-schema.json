{
  "toolName": "vertical-curve-calculator",
  "inputs": [
    {
      "id": "g1",
      "label": "Initial Grade (%)",
      "type": "number",
      "unit": "%",
      "default": -2,
      "businessContext": "Initial tangent grade in percent",
      "label_i18n": {
        "en": "Initial Grade (%)",
        "tr": "Initial Grade (%)",
        "de": "Initial Grade (%)",
        "fr": "Initial Grade (%)",
        "es": "Initial Grade (%)",
        "ar": "Initial Grade (%)"
      }
    },
    {
      "id": "g2",
      "label": "Final Grade (%)",
      "type": "number",
      "unit": "%",
      "default": 1,
      "businessContext": "Final tangent grade in percent",
      "label_i18n": {
        "en": "Final Grade (%)",
        "tr": "Final Grade (%)",
        "de": "Final Grade (%)",
        "fr": "Final Grade (%)",
        "es": "Final Grade (%)",
        "ar": "Final Grade (%)"
      }
    },
    {
      "id": "L",
      "label": "Curve Length (m)",
      "type": "number",
      "unit": "m",
      "default": 200,
      "businessContext": "Length of the vertical curve",
      "label_i18n": {
        "en": "Curve Length (m)",
        "tr": "Curve Length (m)",
        "de": "Curve Length (m)",
        "fr": "Curve Length (m)",
        "es": "Curve Length (m)",
        "ar": "Curve Length (m)"
      }
    },
    {
      "id": "station_PVC",
      "label": "Station of PVC (m)",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Station of the point of vertical curvature",
      "label_i18n": {
        "en": "Station of PVC (m)",
        "tr": "Station of PVC (m)",
        "de": "Station of PVC (m)",
        "fr": "Station of PVC (m)",
        "es": "Station of PVC (m)",
        "ar": "Station of PVC (m)"
      }
    },
    {
      "id": "elevation_PVC",
      "label": "Elevation at PVC (m)",
      "type": "number",
      "unit": "m",
      "default": 100,
      "businessContext": "Elevation at the point of vertical curvature",
      "label_i18n": {
        "en": "Elevation at PVC (m)",
        "tr": "Elevation at PVC (m)",
        "de": "Elevation at PVC (m)",
        "fr": "Elevation at PVC (m)",
        "es": "Elevation at PVC (m)",
        "ar": "Elevation at PVC (m)"
      }
    },
    {
      "id": "target_station",
      "label": "Target Station (m)",
      "type": "number",
      "unit": "m",
      "default": 100,
      "businessContext": "Station at which to compute the elevation",
      "label_i18n": {
        "en": "Target Station (m)",
        "tr": "Target Station (m)",
        "de": "Target Station (m)",
        "fr": "Target Station (m)",
        "es": "Target Station (m)",
        "ar": "Target Station (m)"
      }
    }
  ],
  "formulas": {
    "r": "(inputs.g2 - inputs.g1) / (100 * inputs.L)",
    "distance": "inputs.target_station - inputs.station_PVC",
    "elevation_at_target": "inputs.elevation_PVC + (inputs.g1/100) * (inputs.target_station - inputs.station_PVC) + (r/2) * (inputs.target_station - inputs.station_PVC)**2",
    "x_max": "(inputs.g2 - inputs.g1) === 0 ? 0 : - (inputs.g1/100) / r",
    "high_point_station": "inputs.station_PVC + x_max",
    "high_point_elevation": "inputs.elevation_PVC + (inputs.g1/100) * x_max + (r/2) * x_max**2",
    "rate_change": "inputs.g2 - inputs.g1"
  },
  "outputs": {
    "primary": "elevation_at_target",
    "breakdown": [
      "high_point_station",
      "high_point_elevation",
      "rate_change"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

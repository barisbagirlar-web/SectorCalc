        "ar": "Gross Monthly Salary"
      },
      "businessContext_i18n": {
        "en": "The total monthly salary before any deductions.",
        "tr": "Kesintiler öncesi toplam aylık maaş.",
        "de": "Monatsbruttogehalt vor Abzügen",
        "fr": "Salaire mensuel brut avant toute déduction."
      }
    },
    {
      "id": "incomeTaxRate",
      "label": "Income Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Effective income tax rate applied to gross salary.",
      "label_i18n": {
        "en": "Income Tax Rate",
        "tr": "Gelir Vergisi Oranı",
        "de": "Einkommensteuersatz",
        "fr": "Taux d'Impôt sur le Revenu",
        "es": "Tasa del Impuesto sobre la Renta",
        "ar": "Income Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Effective income tax rate applied to gross salary.",
        "tr": "Brüt maaşa uygulanan efektif gelir vergisi oranı.",
        "de": "Effektiver Einkommensteuersatz auf das Bruttogehalt",
        "fr": "Taux d'imposition effectif appliqué au salaire brut."
      }
    },
    {
      "id": "socialSecurityRate",
      "label": "Social Security Contribution Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Employee's social security contribution rate.",
      "label_i18n": {
        "en": "Social Security Contribution Rate",
        "tr": "Sosyal Güvenlik Katkı Oranı",
        "de": "Sozialversicherungsbeitragssatz",
        "fr": "Taux de cotisation de sécurité sociale",
        "es": "Social Security Contribution Rate",
        "ar": "Social Security Contribution Rate"
      },
      "businessContext_i18n": {
        "en": "Employee's social security contribution rate.",
        "tr": "Çalışanın sosyal güvenlik katkı oranı.",
        "de": "Beitragssatz des Arbeitnehmers zur Sozialversicherung.",
        "fr": "Taux de cotisation sociale salariale."
      }
    },
    {
      "id": "otherDeductions",
      "label": "Other Fixed Deductions",
      "type": "number",
      "unit": "currency",
      "default": 200,
      "businessContext": "Any other fixed monthly deductions (e.g., health insurance, union dues).",
      "label_i18n": {
        "en": "Other Fixed Deductions",
        "tr": "Diğer Sabit Kesintiler",
        "de": "Sonstige feste Abzüge",
        "fr": "Autres déductions fixes",
        "es": "Otras deducciones fijas",
        "ar": "Other Fixed Deductions"
      },
      "businessContext_i18n": {
        "en": "Any other fixed monthly deductions (e.g., health insurance, union dues).",
        "tr": "Diğer sabit aylık kesintiler (ör. sağlık sigortası, sendika aidatı).",
        "de": "Sonstige feste monatliche Abzüge (z. B. Krankenversicherung, Gewerkschaftsbeiträge).",
        "fr": "Toute autre déduction mensuelle fixe (ex. assurance santé, cotisations syndicales)."
      }
    }
  ],
  "formulas": {
    "taxAmount": "grossSalary * (incomeTaxRate / 100)",
    "socialSecurityAmount": "grossSalary * (socialSecurityRate / 100)",
    "otherDeductionsAmount": "otherDeductions",
    "totalDeductions": "taxAmount + socialSecurityAmount + otherDeductions",
    "netPay": "grossSalary - totalDeductions"
  },
  "outputs": {
    "primary": "netPay",
    "breakdown": [
      "taxAmount",
      "socialSecurityAmount",
      "otherDeductionsAmount",
      "totalDeductions"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netPay",
    "unit": "currency"
  },

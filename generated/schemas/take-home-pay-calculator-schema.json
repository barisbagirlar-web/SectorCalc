{
  "toolName": "take-home-pay-calculator",
  "inputs": [
    {
      "id": "grossSalary",
      "label": "Gross Monthly Salary",
      "type": "number",
      "unit": "currency",
      "default": 5000,
      "businessContext": "The total monthly salary before any deductions.",
      "label_i18n": {
        "en": "Gross Monthly Salary",
        "tr": "Gross Monthly Salary",
        "de": "Gross Monthly Salary",
        "fr": "Gross Monthly Salary",
        "es": "Gross Monthly Salary",
        "ar": "Gross Monthly Salary"
      }
    },
    {
      "id": "incomeTaxRate",
      "label": "Income Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Effective income tax rate applied to gross salary.",
      "label_i18n": {
        "en": "Income Tax Rate",
        "tr": "Income Tax Rate",
        "de": "Income Tax Rate",
        "fr": "Income Tax Rate",
        "es": "Income Tax Rate",
        "ar": "Income Tax Rate"
      }
    },
    {
      "id": "socialSecurityRate",
      "label": "Social Security Contribution Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Employee's social security contribution rate.",
      "label_i18n": {
        "en": "Social Security Contribution Rate",
        "tr": "Social Security Contribution Rate",
        "de": "Social Security Contribution Rate",
        "fr": "Social Security Contribution Rate",
        "es": "Social Security Contribution Rate",
        "ar": "Social Security Contribution Rate"
      }
    },
    {
      "id": "otherDeductions",
      "label": "Other Fixed Deductions",
      "type": "number",
      "unit": "currency",
      "default": 200,
      "businessContext": "Any other fixed monthly deductions (e.g., health insurance, union dues).",
      "label_i18n": {
        "en": "Other Fixed Deductions",
        "tr": "Other Fixed Deductions",
        "de": "Other Fixed Deductions",
        "fr": "Other Fixed Deductions",
        "es": "Other Fixed Deductions",
        "ar": "Other Fixed Deductions"
      }
    }
  ],
  "formulas": {
    "taxAmount": "grossSalary * (incomeTaxRate / 100)",
    "socialSecurityAmount": "grossSalary * (socialSecurityRate / 100)",
    "otherDeductionsAmount": "otherDeductions",
    "totalDeductions": "taxAmount + socialSecurityAmount + otherDeductions",
    "netPay": "grossSalary - totalDeductions"
  },
  "outputs": {
    "primary": "netPay",
    "breakdown": [
      "taxAmount",
      "socialSecurityAmount",
      "otherDeductionsAmount",
      "totalDeductions"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netPay",
    "unit": "currency"
  },

  "formulas": {
    "natgas_emissions": "natgas_volume * 1.95 / 1000",
    "diesel_stat_emissions": "diesel_stationary * 2.68 / 1000",
    "gasoline_emissions": "gasoline_mobile * 2.31 / 1000",
    "diesel_mob_emissions": "diesel_mobile * 2.68 / 1000",
    "lpg_emissions": "lpg_volume * 3.0 / 1000",
    "coal_emissions": "coal_ton * 2.5",
    "refrigerant_emissions": "refrigerant_leak * 2.088",
    "process_emissions_total": "process_emissions",
    "total": "natgas_emissions + diesel_stat_emissions + gasoline_emissions + diesel_mob_emissions + lpg_emissions + coal_emissions + refrigerant_emissions + process_emissions_total"
  },
  "outputs": {
    "primary": "total",

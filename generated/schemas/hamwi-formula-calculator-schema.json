  "formulas": {
    "totalHeight": "heightFeet * 12 + heightInches",
    "idealWeightLbs": "gender === 1 ? 106 + 6 * (totalHeight - 60) : 100 + 5 * (totalHeight - 60)",
    "idealWeightKg": "idealWeightLbs * 0.453592",
    "idealWeight": "outputUnit === 0 ? idealWeightLbs : idealWeightKg"
  },

{
  "toolName": "cash-out-refinance-calculator",
  "inputs": [
    {
      "id": "propertyValue",
      "label": "Current Property Value",
      "type": "number",
      "unit": "$",
      "default": 300000,
      "businessContext": "The appraised market value of the property.",
      "label_i18n": {
        "en": "Current Property Value",
        "tr": "Mevcut Mülk Değeri",
        "de": "Current Property Value",
        "fr": "Current Property Value",
        "es": "Current Property Value",
        "ar": "Current Property Value"
      },
      "businessContext_i18n": {
        "en": "The appraised market value of the property.",
        "tr": "Mülkün ekspertiz değeri."
      }
    },
    {
      "id": "existingMortgageBalance",
      "label": "Existing Mortgage Balance",
      "type": "number",
      "unit": "$",
      "default": 200000,
      "businessContext": "The outstanding balance on the current mortgage.",
      "label_i18n": {
        "en": "Existing Mortgage Balance",
        "tr": "Mevcut İpotek Bakiyesi",
        "de": "Existing Mortgage Balance",
        "fr": "Existing Mortgage Balance",
        "es": "Existing Mortgage Balance",
        "ar": "Existing Mortgage Balance"
      },
      "businessContext_i18n": {
        "en": "The outstanding balance on the current mortgage.",
        "tr": "Mevcut ipotek üzerindeki ödenmemiş bakiye."
      }
    },
    {
      "id": "cashOutAmount",
      "label": "Desired Cash-Out Amount",
      "type": "number",
      "unit": "$",
      "default": 50000,
      "businessContext": "The amount of equity to withdraw in cash.",
      "label_i18n": {
        "en": "Desired Cash-Out Amount",
        "tr": "İstenen Nakit Çıkış Tutarı",
        "de": "Desired Cash-Out Amount",
        "fr": "Desired Cash-Out Amount",
        "es": "Desired Cash-Out Amount",
        "ar": "Desired Cash-Out Amount"
      },
      "businessContext_i18n": {
        "en": "The amount of equity to withdraw in cash.",
        "tr": "Nakit olarak çekilecek öz sermaye miktarı."
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual interest rate for the new refinance loan.",
      "label_i18n": {
        "en": "Interest Rate",
        "tr": "Faiz Oranı",
        "de": "Interest Rate",
        "fr": "Interest Rate",
        "es": "Interest Rate",
        "ar": "Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual interest rate for the new refinance loan.",
        "tr": "Yeni refinansman kredisi için yıllık faiz oranı."
      }
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "Years",
      "default": 30,
      "businessContext": "The duration of the new loan in years.",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Kredi Vadesi",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      },
      "businessContext_i18n": {
        "en": "The duration of the new loan in years.",
        "tr": "Yeni kredinin yıl cinsinden süresi."
      }
    },
    {
      "id": "closingCosts",
      "label": "Closing Costs",
      "type": "number",
      "unit": "$",
      "default": 5000,
      "businessContext": "Total closing costs and fees for the refinance.",
      "label_i18n": {
        "en": "Closing Costs",
        "tr": "Kapanış Maliyetleri",
        "de": "Closing Costs",
        "fr": "Closing Costs",
        "es": "Closing Costs",
        "ar": "Closing Costs"
      },
      "businessContext_i18n": {
        "en": "Total closing costs and fees for the refinance.",
        "tr": "Refinansman için toplam kapanış maliyetleri ve ücretleri."
      }
    }
  ],
  "formulas": {
    "newLoanAmount": "existingMortgageBalance + cashOutAmount + closingCosts",
    "monthlyInterestRate": "interestRate / 100 / 12",
    "numberOfPayments": "loanTerm * 12",
    "monthlyPayment": "newLoanAmount * monthlyInterestRate * ((1 + monthlyInterestRate) ** numberOfPayments) / (((1 + monthlyInterestRate) ** numberOfPayments) - 1)",
    "totalPayment": "monthlyPayment * numberOfPayments",
    "totalInterest": "totalPayment - newLoanAmount",
    "loanToValue": "(newLoanAmount / propertyValue) * 100"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "newLoanAmount",
      "totalInterest",
      "loanToValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "loanToValue",
    "unit": "$"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

{
  "toolName": "energy-audit-calculator",
  "inputs": [
    {
      "id": "equipmentPower",
      "label": "Equipment Power Rating",
      "type": "number",
      "unit": "kW",
      "default": 50,
      "businessContext": "Total power rating of equipment being audited.",
      "label_i18n": {
        "en": "Equipment Power Rating",
        "tr": "Ekipman Güç Değeri",
        "de": "Equipment Power Rating",
        "fr": "Equipment Power Rating",
        "es": "Equipment Power Rating",
        "ar": "Equipment Power Rating"
      },
      "businessContext_i18n": {
        "en": "Total power rating of equipment being audited.",
        "tr": "Denetlenen ekipmanın toplam güç değeri."
      }
    },
    {
      "id": "operatingHours",
      "label": "Operating Hours per Year",
      "type": "number",
      "unit": "hours",
      "default": 2000,
      "businessContext": "Annual operating hours of the equipment.",
      "label_i18n": {
        "en": "Operating Hours per Year",
        "tr": "Yıllık Çalışma Saati",
        "de": "Operating Hours per Year",
        "fr": "Operating Hours per Year",
        "es": "Operating Hours per Year",
        "ar": "Operating Hours per Year"
      },
      "businessContext_i18n": {
        "en": "Annual operating hours of the equipment.",
        "tr": "Ekipmanın yıllık çalışma saati."
      }
    },
    {
      "id": "loadFactor",
      "label": "Load Factor",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Percentage of full power at which equipment typically operates.",
      "label_i18n": {
        "en": "Load Factor",
        "tr": "Yük Faktörü",
        "de": "Load Factor",
        "fr": "Load Factor",
        "es": "Load Factor",
        "ar": "Load Factor"
      },
      "businessContext_i18n": {
        "en": "Percentage of full power at which equipment typically operates.",
        "tr": "Ekipmanın tipik olarak çalıştığı tam güç yüzdesi."
      }
    },
    {
      "id": "costPerKWh",
      "label": "Cost per kWh",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.12,
      "businessContext": "Electricity cost per kilowatt-hour.",
      "label_i18n": {
        "en": "Cost per kWh",
        "tr": "kWh Başına Maliyet",
        "de": "Cost per kWh",
        "fr": "Cost per kWh",
        "es": "Cost per kWh",
        "ar": "Cost per kWh"
      },
      "businessContext_i18n": {
        "en": "Electricity cost per kilowatt-hour.",
        "tr": "Kilovatsaat başına elektrik maliyeti."
      }
    },
    {
      "id": "floorArea",
      "label": "Floor Area",
      "type": "number",
      "unit": "m²",
      "default": 1000,
      "businessContext": "Total floor area of the facility being audited.",
      "label_i18n": {
        "en": "Floor Area",
        "tr": "Alan",
        "de": "Floor Area",
        "fr": "Floor Area",
        "es": "Floor Area",
        "ar": "Floor Area"
      },
      "businessContext_i18n": {
        "en": "Total floor area of the facility being audited.",
        "tr": "Denetlenen tesisin toplam taban alanı."
      }
    },
    {
      "id": "emissionFactor",
      "label": "CO2 Emission Factor",
      "type": "number",
      "unit": "kg CO2/kWh",
      "default": 0.5,
      "businessContext": "Carbon emission factor for grid electricity.",
      "label_i18n": {
        "en": "CO2 Emission Factor",
        "tr": "CO2 Emisyon Faktörü",
        "de": "CO2 Emission Factor",
        "fr": "CO2 Emission Factor",
        "es": "CO2 Emission Factor",
        "ar": "CO2 Emission Factor"
      },
      "businessContext_i18n": {
        "en": "Carbon emission factor for grid electricity.",
        "tr": "Şebeke elektriği için karbon emisyon faktörü."
      }
    }
  ],
  "formulas": {
    "annualEnergyConsumption": "equipmentPower * operatingHours * (loadFactor / 100)",
    "totalEnergyCost": "annualEnergyConsumption * costPerKWh",
    "energyIntensity": "annualEnergyConsumption / floorArea",
    "carbonFootprint": "annualEnergyConsumption * emissionFactor"
  },
  "outputs": {
    "primary": "totalEnergyCost",
    "breakdown": [
      "annualEnergyConsumption",
      "energyIntensity",
      "carbonFootprint"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "carbonFootprint",
    "unit": "kW"
  },

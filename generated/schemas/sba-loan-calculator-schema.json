{
  "toolName": "sba-loan-calculator",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount",
      "type": "number",
      "unit": "$",
      "default": 100000,
      "businessContext": "Net loan amount requested before SBA guarantee fee",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Kredi Tutarı",
        "de": "Darlehensbetrag",
        "fr": "Loan Amount",
        "es": "Loan Amount",
        "ar": "Loan Amount"
      },
      "businessContext_i18n": {
        "en": "Net loan amount requested before SBA guarantee fee",
        "tr": "SBA garanti ücreti öncesi talep edilen net kredi tutarı"
      }
    },
    {
      "id": "interestRate",
      "label": "Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 6,
      "businessContext": "Annual interest rate",
      "label_i18n": {
        "en": "Interest Rate",
        "tr": "Faiz Oranı",
        "de": "Zinssatz",
        "fr": "Interest Rate",
        "es": "Interest Rate",
        "ar": "Interest Rate"
      },
      "businessContext_i18n": {
        "en": "Annual interest rate",
        "tr": "Yıllık faiz oranı"
      }
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Repayment period in years",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Kredi Vadesi",
        "de": "Darlehenslaufzeit",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      },
      "businessContext_i18n": {
        "en": "Repayment period in years",
        "tr": "Yıl cinsinden geri ödeme süresi"
      }
    },
    {
      "id": "sbaGuaranteeFee",
      "label": "SBA Guarantee Fee",
      "type": "number",
      "unit": "%",
      "default": 3.5,
      "businessContext": "SBA guarantee fee percentage (added to total financed amount)",
      "label_i18n": {
        "en": "SBA Guarantee Fee",
        "tr": "SBA Garanti Ücreti",
        "de": "SBA Guarantee Fee",
        "fr": "SBA Guarantee Fee",
        "es": "SBA Guarantee Fee",
        "ar": "SBA Guarantee Fee"
      },
      "businessContext_i18n": {
        "en": "SBA guarantee fee percentage (added to total financed amount)",
        "tr": "SBA garanti ücreti yüzdesi (toplam finanse edilen tutara eklenir)"
      }
    }
  ],
  "formulas": {
    "totalPrincipal": "loanAmount * (1 + sbaGuaranteeFee / 100)",
    "monthlyRate": "interestRate / 1200",
    "numPayments": "loanTerm * 12"
  },
  "outputs": {
    "primary": "numPayments",
    "breakdown": [
      "totalPayment",
      "totalInterest",
      "totalPrincipal"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalInterest",
    "unit": "$"
  },

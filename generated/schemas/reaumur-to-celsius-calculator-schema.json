{
  "toolName": "reaumur-to-celsius-calculator",
  "inputs": [
    {
      "id": "reaumur",
      "label": "Réaumur Temperature",
      "type": "number",
      "unit": "°Ré",
      "default": 0,
      "businessContext": "The temperature value measured in degrees Réaumur to be converted to Celsius.",
      "label_i18n": {
        "en": "Réaumur Temperature",
        "tr": "Réaumur Temperature",
        "de": "Réaumur Temperature",
        "fr": "Réaumur Temperature",
        "es": "Réaumur Temperature",
        "ar": "Réaumur Temperature"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the output result. Ensures compliance with reporting precision requirements.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty (±)",
      "type": "number",
      "unit": "°Ré",
      "default": 0,
      "businessContext": "The estimated uncertainty of the Réaumur measurement, for quality assurance documentation.",
      "label_i18n": {
        "en": "Measurement Uncertainty (±)",
        "tr": "Measurement Uncertainty (±)",
        "de": "Measurement Uncertainty (±)",
        "fr": "Measurement Uncertainty (±)",
        "es": "Measurement Uncertainty (±)",
        "ar": "Measurement Uncertainty (±)"
      }
    },
    {
      "id": "calibrationOffset",
      "label": "Calibration Offset",
      "type": "number",
      "unit": "°Ré",
      "default": 0,
      "businessContext": "Optional offset to correct for systematic error in the measurement device, as per calibration certificate.",
      "label_i18n": {
        "en": "Calibration Offset",
        "tr": "Calibration Offset",
        "de": "Calibration Offset",
        "fr": "Calibration Offset",
        "es": "Calibration Offset",
        "ar": "Calibration Offset"
      }
    }
  ],
  "formulas": {
    "celsiusRaw": "(reaumur + calibrationOffset) * 1.25",
    "celsius": "Math.round(((reaumur + calibrationOffset) * 1.25) * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "uncertaintyCelsius": "measurementUncertainty * 1.25"
  },
  "outputs": {
    "primary": "celsius",
    "breakdown": [
      "celsius",
      "celsiusRaw",
      "uncertaintyCelsius"
    ]
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Sağlık & Medikal",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",

  "formulas": {
    "determinant": "a11*a22 - a12*a21",
    "isZeroMatrix": "Math.abs(a11)<1e-10 && Math.abs(a12)<1e-10 && Math.abs(a21)<1e-10 && Math.abs(a22)<1e-10",
    "isFullRank": "Math.abs(a11*a22 - a12*a21) > 1e-10",
    "rank": "(Math.abs(a11*a22 - a12*a21) > 1e-10) ? 2 : ((Math.abs(a11)<1e-10 && Math.abs(a12)<1e-10 && Math.abs(a21)<1e-10 && Math.abs(a22)<1e-10) ? 0 : 1)"
  },
  "outputs": {
    "primary": "rank",
    "breakdown": [
      "determinant",
      "isZeroMatrix",
      "isFullRank"
    ]

{
  "toolName": "tire-size-calculator",
  "inputs": [
    {
      "id": "tireWidth",
      "label": "Tire Width",
      "type": "number",
      "unit": "mm",
      "default": 225,
      "businessContext": "Nominal section width of the tire",
      "label_i18n": {
        "en": "Tire Width",
        "tr": "Tire Width",
        "de": "Tire Width",
        "fr": "Tire Width",
        "es": "Tire Width",
        "ar": "Tire Width"
      }
    },
    {
      "id": "aspectRatio",
      "label": "Aspect Ratio",
      "type": "number",
      "unit": "%",
      "default": 45,
      "businessContext": "Sidewall height as a percentage of tire width",
      "label_i18n": {
        "en": "Aspect Ratio",
        "tr": "Aspect Ratio",
        "de": "Aspect Ratio",
        "fr": "Aspect Ratio",
        "es": "Aspect Ratio",
        "ar": "Aspect Ratio"
      }
    },
    {
      "id": "rimDiameter",
      "label": "Rim Diameter",
      "type": "number",
      "unit": "in",
      "default": 17,
      "businessContext": "Diameter of the wheel rim",
      "label_i18n": {
        "en": "Rim Diameter",
        "tr": "Rim Diameter",
        "de": "Rim Diameter",
        "fr": "Rim Diameter",
        "es": "Rim Diameter",
        "ar": "Rim Diameter"
      }
    },
    {
      "id": "treadLoss",
      "label": "Tread Loss",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Amount of tread depth worn off, reducing overall diameter",
      "label_i18n": {
        "en": "Tread Loss",
        "tr": "Tread Loss",
        "de": "Tread Loss",
        "fr": "Tread Loss",
        "es": "Tread Loss",
        "ar": "Tread Loss"
      }
    }
  ],
  "formulas": {
    "sidewallHeightMm": "(tireWidth * aspectRatio / 100) - treadLoss",
    "sidewallHeightIn": "sidewallHeightMm / 25.4",
    "overallDiameterIn": "rimDiameter + 2 * sidewallHeightIn",
    "overallDiameterMm": "overallDiameterIn * 25.4",
    "circumferenceIn": "Math.PI * overallDiameterIn",
    "circumferenceMm": "Math.PI * overallDiameterMm"
  },
  "outputs": {
    "primary": "overallDiameterIn",
    "breakdown": [
      "sidewallHeightMm",
      "sidewallHeightIn",
      "overallDiameterMm",
      "circumferenceIn",
      "circumferenceMm"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "circumferenceMm",
    "unit": "m",
    "breakdownUnits": {
      "sidewallHeightMm": "mm",
      "overallDiameterMm": "mm",
      "circumferenceMm": "mm"
    }
  },
  "category": "Dönüşüm & Ölçüm",

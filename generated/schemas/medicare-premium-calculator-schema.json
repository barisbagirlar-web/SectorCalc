{
  "toolName": "medicare-premium-calculator",
  "inputs": [
    {
      "id": "magi",
      "label": "Modified Adjusted Gross Income (MAGI)",
      "type": "number",
      "unit": "USD",
      "default": 75000,
      "businessContext": "Annual income used to determine IRMAA brackets"
    },
    {
      "id": "filingStatus",
      "label": "Tax Filing Status",
      "type": "number",
      "unit": "category",
      "default": 1,
      "businessContext": "1 = Single, 2 = Married Filing Jointly"
    },
    {
      "id": "partBBase",
      "label": "Part B Standard Premium",
      "type": "number",
      "unit": "USD/month",
      "default": 174.7,
      "businessContext": "Standard monthly Part B premium for current year"
    },
    {
      "id": "partDBase",
      "label": "Part D Base Beneficiary Premium",
      "type": "number",
      "unit": "USD/month",
      "default": 33.35,
      "businessContext": "National base beneficiary premium for Part D"
    },
    {
      "id": "planCost",
      "label": "Medicare Advantage or Part D Plan Premium",
      "type": "number",
      "unit": "USD/month",
      "default": 30,
      "businessContext": "Premium for chosen Part D or Medicare Advantage plan"
    }
  ],
  "formulas": {
    "irmaaB": "magi <= (filingStatus === 1 ? 103000 : 206000) ? 0 : magi <= (filingStatus === 1 ? 129000 : 258000) ? 69.90 : magi <= (filingStatus === 1 ? 161000 : 322000) ? 174.70 : magi <= (filingStatus === 1 ? 193000 : 386000) ? 279.50 : magi < (filingStatus === 1 ? 500000 : 750000) ? 384.30 : 419.30",
    "irmaaD": "magi <= (filingStatus === 1 ? 103000 : 206000) ? 0 : magi <= (filingStatus === 1 ? 129000 : 258000) ? 12.40 : magi <= (filingStatus === 1 ? 161000 : 322000) ? 32.00 : magi <= (filingStatus === 1 ? 193000 : 386000) ? 51.70 : magi < (filingStatus === 1 ? 500000 : 750000) ? 71.30 : 77.90",
    "totalPremium": "partBBase + irmaaB + (planCost > 0 ? planCost : partDBase + irmaaD)"
  },
  "outputs": {
    "primary": "totalPremium",
    "breakdown": [
      "partBBase + irmaaB",
      "planCost > 0 ? planCost : partDBase + irmaaD",
      "irmaaB + irmaaD"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance"
}

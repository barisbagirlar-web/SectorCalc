  "formulas": {
    "xLeft": "approachPoint - epsilon",
    "xRight": "approachPoint + epsilon",
    "leftNumerator": "numCoeff0 + numCoeff1 * xLeft + numCoeff2 * xLeft ** 2",
    "leftDenominator": "denCoeff0 + denCoeff1 * xLeft + denCoeff2 * xLeft ** 2",
    "leftLimit": "leftNumerator / leftDenominator",
    "rightNumerator": "numCoeff0 + numCoeff1 * xRight + numCoeff2 * xRight ** 2",
    "rightDenominator": "denCoeff0 + denCoeff1 * xRight + denCoeff2 * xRight ** 2",
    "rightLimit": "rightNumerator / rightDenominator",
    "primary": "(leftLimit + rightLimit) / 2",
    "breakdown_0": "leftLimit",
    "breakdown_1": "rightLimit",
    "breakdown_2": "Math.abs(leftLimit - rightLimit)",

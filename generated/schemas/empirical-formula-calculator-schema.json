      "unit": "kg",
      "default": 2,
      "businessContext": "İlk veri noktasının bağımlı değişken değeri"
    },
    {
      "id": "x2",
      "label": "x2 Değeri",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "İkinci veri noktasının bağımsız değişken değeri"
    },
    {
      "id": "y2",
      "label": "y2 Değeri",

  "formulas": {
    "b": "(Math.log(y2) - Math.log(y1)) / (Math.log(x2) - Math.log(x1))",
    "log_a": "Math.log(y1) - b * Math.log(x1)",
    "a": "Math.exp(log_a)"
  },
  "outputs": {
    "primary": "Deneysel Formül: y = ${a} * x^${b}",
    "breakdown": [
      "Katsayı a: ${a}",
      "Üs b: ${b}"
    ]
  },

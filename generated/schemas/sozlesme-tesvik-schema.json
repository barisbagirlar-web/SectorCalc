  "formulas": {
    "TargetCost": "BaselineEstimate",
    "TargetFee": "TargetCost * TargetFeePct",
    "ShareRatio": "OverrunShare / UnderrunShare",
    "ActualFee": "TargetFee + (TargetCost - ActualCost) * ContractorSharePct",
    "MaxFee": "TargetFee * MaxFeeMultiplier",
    "MinFee": "TargetFee * MinFeeMultiplier",
    "FinalFee": "MIN(MAX(ActualFee, MinFee), MaxFee)",
    "FinalPrice": "ActualCost + FinalFee",
    "PerformanceBonus": "SUM(MetricWeight_i * MetricScore_i) * BonusPool"
  },
  "outputs": {
    "primary": "PerformanceBonus",
    "unit": "USD",

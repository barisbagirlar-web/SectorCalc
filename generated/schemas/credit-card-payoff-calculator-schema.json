{
  "toolName": "credit-card-payoff-calculator",
  "inputs": [
    {
      "id": "balance",
      "label": "Current Balance",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "Outstanding balance on the credit card."
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Annual interest rate charged on the balance."
    },
    {
      "id": "monthlyPayment",
      "label": "Monthly Payment",
      "type": "number",
      "unit": "currency",
      "default": 50,
      "businessContext": "Fixed amount you plan to pay each month."
    }
  ],
  "formulas": {
    "monthsToPayoff": "Math.log(monthlyPayment / (monthlyPayment - balance * (annualInterestRate/100/12))) / Math.log(1 + (annualInterestRate/100/12))",
    "totalAmountPaid": "monthlyPayment * monthsToPayoff",
    "totalInterestPaid": "totalAmountPaid - balance"
  },
  "outputs": {
    "primary": "monthsToPayoff",
    "breakdown": [
      "totalInterestPaid",
      "totalAmountPaid"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems"
}

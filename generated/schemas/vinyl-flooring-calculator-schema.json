    {
      "id": "plankPrice",
      "label": "Price per Square Meter",
      "type": "number",
      "unit": "€/m²",
      "default": 15,
      "businessContext": "Cost of vinyl flooring per square meter.",
      "label_i18n": {
        "en": "Price per Square Meter",
        "tr": "Metrekare Başına Fiyat",

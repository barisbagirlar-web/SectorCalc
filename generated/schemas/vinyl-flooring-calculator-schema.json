  "formulas": {
    "totalArea": "roomLength * roomWidth",
    "effectiveArea": "totalArea * (1 + wasteFactor / 100)",
    "numberOfPlanks": "effectiveArea / (plankLength * plankWidth)",
    "totalCost": "effectiveArea * plankPrice"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalArea",
      "numberOfPlanks"
    ],

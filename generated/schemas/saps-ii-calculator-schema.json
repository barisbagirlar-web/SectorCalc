  ],
  "formulas": {
    "agePoints": "(age < 40) ? 0 : (age < 60) ? 7 : (age < 70) ? 12 : (age < 75) ? 15 : (age < 80) ? 16 : 18",
    "hrPoints": "(heartRate < 40) ? 11 : (heartRate < 70) ? 2 : (heartRate < 120) ? 0 : (heartRate < 160) ? 4 : 7",
    "sysBPPoints": "(systolicBP < 70) ? 13 : (systolicBP < 100) ? 5 : (systolicBP < 200) ? 0 : 2",
    "tempPoints": "(temperature >= 39) ? 3 : 0",
    "ventPoints": "(ventilation === 1) ? ((paO2FiO2 < 100) ? 11 : (paO2FiO2 < 200) ? 9 : 6) : 0",
    "urinePoints": "(urineOutput < 0.5) ? 11 : (urineOutput < 1) ? 4 : 0",
    "ureaPoints": "(serumUrea < 10) ? 0 : (serumUrea < 30) ? 6 : 10",
    "saps2Score": "agePoints + hrPoints + sysBPPoints + tempPoints + ventPoints + urinePoints + ureaPoints"
  },
  "outputs": {
    "primary": "saps2Score",
    "breakdown": [
      "agePoints",
      "hrPoints",
      "sysBPPoints",
      "tempPoints",
      "ventPoints",
      "urinePoints",
      "ureaPoints"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "saps2Score",
    "unit": "years",
    "breakdownUnits": {
      "tempPoints": "°C"
    }
  },

{
  "toolName": "student-aid-index-calculator",
  "inputs": [
    {
      "id": "parentAGI",
      "label": "Parent AGI",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Parents' Adjusted Gross Income from tax return",
      "label_i18n": {
        "en": "Parent AGI",
        "tr": "Parent AGI",
        "de": "Parent AGI",
        "fr": "Parent AGI",
        "es": "Parent AGI",
        "ar": "Parent AGI"
      }
    },
    {
      "id": "parentAssets",
      "label": "Parent Assets",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Total net worth of parent assets (excluding home and retirement)",
      "label_i18n": {
        "en": "Parent Assets",
        "tr": "Parent Assets",
        "de": "Parent Assets",
        "fr": "Parent Assets",
        "es": "Parent Assets",
        "ar": "Parent Assets"
      }
    },
    {
      "id": "studentIncome",
      "label": "Student Income",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Student's income from all sources",
      "label_i18n": {
        "en": "Student Income",
        "tr": "Student Income",
        "de": "Student Income",
        "fr": "Student Income",
        "es": "Student Income",
        "ar": "Student Income"
      }
    },
    {
      "id": "studentAssets",
      "label": "Student Assets",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Total net worth of student assets",
      "label_i18n": {
        "en": "Student Assets",
        "tr": "Student Assets",
        "de": "Student Assets",
        "fr": "Student Assets",
        "es": "Student Assets",
        "ar": "Student Assets"
      }
    },
    {
      "id": "familySize",
      "label": "Family Size",
      "type": "number",
      "unit": "count",
      "default": 4,
      "businessContext": "Number of people in the household",
      "label_i18n": {
        "en": "Family Size",
        "tr": "Family Size",
        "de": "Family Size",
        "fr": "Family Size",
        "es": "Family Size",
        "ar": "Family Size"
      }
    },
    {
      "id": "numberInCollege",
      "label": "Number in College",
      "type": "number",
      "unit": "count",
      "default": 1,
      "businessContext": "Number of household members attending college",
      "label_i18n": {
        "en": "Number in College",
        "tr": "Number in College",
        "de": "Number in College",
        "fr": "Number in College",
        "es": "Number in College",
        "ar": "Number in College"
      }
    }
  ],
  "formulas": {
    "parentIncomeContrib": "Math.max(0, parentAGI - (10000 + familySize * 5000 + numberInCollege * 3000)) * 0.22",
    "parentAssetContrib": "Math.max(0, parentAssets - (2000 * familySize)) * 0.12",
    "studentIncomeContrib": "Math.max(0, studentIncome - 7000) * 0.50",
    "studentAssetContrib": "studentAssets * 0.20",
    "sai": "Math.round(parentIncomeContrib + parentAssetContrib + studentIncomeContrib + studentAssetContrib)"
  },
  "outputs": {
    "primary": "sai",
    "breakdown": [
      "parentIncomeContrib",
      "parentAssetContrib",
      "studentIncomeContrib",
      "studentAssetContrib"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "otomotiv",
  "profession": "Üretim Mühendisi",
  "categoryId": "finance"
}

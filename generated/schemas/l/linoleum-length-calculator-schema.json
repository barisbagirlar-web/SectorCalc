{
  "toolName": "linoleum-length-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Floor Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 30,
      "min": 0,
      "businessContext": "Area to cover."
    },
    {
      "id": "ruloEn",
      "label": "Roll Width (m)",
      "type": "number",
      "unit": "m",
      "default": 2,
      "min": 0,
      "businessContext": "Roll width."
    },
    {
      "id": "scrap",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "min": 0,
      "businessContext": "Cutting waste."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(area / Math.max(0.0001, ruloEn)) * (1 + scrap / 100)"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Gerekli Rulo Length"
    },
    "breakdownUnits": {
      "result": "m"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate linoleum/vinyl length to cut from roll.",
      "long": "Calculate linoleum/vinyl length to cut from roll."
    }
  },
  "sectorSlug": "daily-renovation"
}

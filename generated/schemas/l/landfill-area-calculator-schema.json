{
  "toolName": "landfill-area-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "sustainability-resource-esg",
  "sector": "Environment and Sustainability",
  "sectorId": "sustainability-resource-esg",
  "inputs": [
    {
      "id": "atikHacmi",
      "label": "Waste Volume (m³)",
      "type": "number",
      "unit": "m3",
      "default": 50000,
      "min": 0,
      "businessContext": "Waste volume to store."
    },
    {
      "id": "sikistirma",
      "label": "Compaction Ratio (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "min": 0,
      "businessContext": "Volume reduction by compaction."
    },
    {
      "id": "depth",
      "label": "Landfill Depth (m)",
      "type": "number",
      "unit": "m",
      "default": 10,
      "min": 0,
      "businessContext": "Average landfill depth."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(atikHacmi * (1 - sikistirma / 100)) / Math.max(0.0001, depth)"
  },
  "outputs": {
    "primary": "result",
    "unit": "m2",
    "breakdown": {
      "result": "Gerekli Deponi Area"
    },
    "breakdownUnits": {
      "result": "m2"
    },
    "hiddenLossDrivers": [
      "High environmental score may reduce operational costs.",
      "Low ESG score may increase capital costs."
    ],
    "suggestedActions": [
      "Set improvement targets for each ESG pillar.",
      "Consider carbon offset programs for residual emissions."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],

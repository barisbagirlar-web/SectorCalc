      "businessContext": "Plant installation cost."
    },
    {
      "id": "toplamIsletme",
      "label": "Lifetime O&M (USD)",
      "type": "number",
      "unit": "USD",
      "default": 2000000,
      "min": 0,
      "businessContext": "Operation and maintenance costs."
    },
    {
      "id": "toplamUretim",
      "label": "Lifetime Production (kWh)",
      "type": "number",
      "unit": "kWh",
      "default": 25000000,
      "min": 1,
      "businessContext": "Total electricity generation."
    }

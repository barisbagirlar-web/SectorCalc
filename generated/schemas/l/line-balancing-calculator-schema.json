{
  "toolName": "line-balancing-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "lean-production",
  "sector": "Industrial Engineering",
  "sectorId": "lean-production",
  "inputs": [
    {
      "id": "toplamIs",
      "label": "Total Work Content (Min)",
      "type": "number",
      "unit": "min",
      "default": 500,
      "min": 0,
      "businessContext": "Sum of all operation times."
    },
    {
      "id": "taktTime",
      "label": "Takt Time (Min)",
      "type": "number",
      "unit": "min",
      "default": 50,
      "min": 0,
      "businessContext": "Maximum cycle time to meet demand."
    },
    {
      "id": "istasyonSayisi",
      "label": "Number of Stations",
      "type": "number",
      "unit": "stations",
      "default": 12,
      "min": 1,
      "businessContext": "Total workstations on the line."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(toplamIs / Math.max(0.0001, (istasyonSayisi * taktTime))) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "Line Balancing Efficiency"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Conduct regular OEE audits for improvement.",
      "Use SMED to reduce setup times."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate assembly line balancing efficiency.",
      "long": "Calculate assembly line balancing efficiency."
    }
  },
  "sectorSlug": "daily-renovation"
}

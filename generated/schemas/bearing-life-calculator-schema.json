{
  "toolName": "bearing-life-calculator",
  "inputs": [
    {
      "id": "C",
      "label": "Basic Dynamic Load Rating (C)",
      "type": "number",
      "unit": "kN",
      "default": 10,
      "businessContext": "Manufacturer's rated load for 1 million revolutions, from bearing catalog.",
      "label_i18n": {
        "en": "Basic Dynamic Load Rating (C)",
        "tr": "Basic Dynamic Load Rating (C)",

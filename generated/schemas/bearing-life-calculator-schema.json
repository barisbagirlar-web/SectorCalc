        "en": "Bearing Life Exponent (p)",
        "tr": "Bearing Life Exponent (p)",
        "de": "Bearing Life Exponent (p)",
        "fr": "Bearing Life Exponent (p)",
        "es": "Bearing Life Exponent (p)",
        "ar": "Bearing Life Exponent (p)"

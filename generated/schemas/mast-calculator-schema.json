      }
    },
    {
      "id": "materialYieldStrength",
      "label": "Material Yield Strength",
      "type": "number",
      "unit": "MPa",
      "default": 250,
      "businessContext": "Yield strength of the mast material.",
      "label_i18n": {
        "en": "Material Yield Strength",
        "tr": "Malzeme Akma Dayanımı",
        "de": "Streckgrenze des Materials",
        "fr": "Material Yield Strength",
        "es": "Material Yield Strength",
        "ar": "Material Yield Strength"
      },
      "businessContext_i18n": {
        "en": "Yield strength of the mast material.",
        "tr": "Direk malzemesinin akma dayanımı."
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Design safety factor.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Güvenlik Faktörü",
        "de": "Sicherheitsfaktor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      },
      "businessContext_i18n": {
        "en": "Design safety factor.",
        "tr": "Tasarım güvenlik faktörü."
      }
    }
  ],
  "formulas": {
    "windPressure": "0.5 * 1.225 * windSpeed ** 2",
    "dragForce": "0.7 * windPressure * (mastDiameter * mastHeight)",
    "bendingMoment": "dragForce * (mastHeight / 2)",
    "sectionModulus": "Math.PI * mastDiameter ** 3 / 32",
    "bendingStressPa": "bendingMoment / sectionModulus",
    "bendingStressMPa": "bendingStressPa / 1e6",
    "allowableStress": "materialYieldStrength / safetyFactor",
    "utilizationRatio": "bendingStressMPa / allowableStress"
  },
  "outputs": {
    "primary": "utilizationRatio",
    "breakdown": [
      "bendingStressMPa",
      "allowableStress"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "utilizationRatio",
    "unit": "%"
  },

  "formulas": {
    "windPressure": "0.5 * 1.225 * windSpeed ** 2",
    "dragForce": "0.7 * windPressure * (mastDiameter * mastHeight)",
    "bendingMoment": "dragForce * (mastHeight / 2)",
    "sectionModulus": "Math.PI * mastDiameter ** 3 / 32",
    "bendingStressPa": "bendingMoment / sectionModulus",
    "bendingStressMPa": "bendingStressPa / 1e6",
    "allowableStress": "materialYieldStrength / safetyFactor",
    "utilizationRatio": "bendingStressMPa / allowableStress"
  },
  "outputs": {
    "primary": "utilizationRatio",
    "breakdown": [
      "bendingStressMPa",
      "allowableStress"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "utilizationRatio",
    "unit": "%"
  },

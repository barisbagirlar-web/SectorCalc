      }
    },
    {
      "id": "windSpeed",
      "label": "Wind Speed",
      "type": "number",
      "unit": "m/s",
      "default": 30,
      "businessContext": "Design wind speed.",
      "label_i18n": {
        "en": "Wind Speed",
        "tr": "Rüzgar Hızı",
        "de": "Wind Speed",

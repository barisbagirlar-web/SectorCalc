      "id": "ebit",
      "label": "EBIT",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Earnings Before Interest and Taxes"
    },
    {
      "id": "interestExpense",
      "label": "Interest Expense",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "businessContext": "Total interest payments on debt"
    },
    {
      "id": "ebitda",
      "label": "EBITDA",
      "type": "number",
      "unit": "USD",
      "default": 120000,
      "businessContext": "Earnings Before Interest, Taxes, Depreciation and Amortization"
    },
    {
      "id": "depreciation",
      "label": "Depreciation & Amortization",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "businessContext": "Depreciation and amortization expenses"
    }
  ],
  "formulas": {
    "interestCoverageRatio": "ebit / interestExpense",
    "ebitdaCoverageRatio": "ebitda / interestExpense"

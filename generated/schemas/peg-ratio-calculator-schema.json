{
  "toolName": "peg-ratio-calculator",
  "inputs": [
    {
      "id": "stockPrice",
      "label": "Stock Price",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Current market price per share"
    },
    {
      "id": "earningsPerShare",
      "label": "Earnings Per Share (EPS)",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Trailing twelve-month earnings per share"
    },
    {
      "id": "growthRate",
      "label": "Earnings Growth Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Expected annual EPS growth rate (percentage)"
    }
  ],
  "formulas": {
    "peRatio": "stockPrice / earningsPerShare",
    "pegRatio": "earningsPerShare !== 0 && growthRate !== 0 ? (stockPrice / earningsPerShare) / (growthRate / 100) : NaN"
  },
  "outputs": {
    "primary": "pegRatio",
    "breakdown": [
      "peRatio",
      "growthRate"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost"
}

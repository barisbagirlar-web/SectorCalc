{
  "toolName": "bonus-tax-calculator",
  "inputs": [
    {
      "id": "bonusAmount",
      "label": "Bonus Amount",
      "type": "number",
      "unit": "EUR",
      "default": 1000,
      "businessContext": "The gross bonus amount before any tax deductions.",
      "label_i18n": {

      },
      "businessContext_i18n": {
        "en": "The gross bonus amount before any tax deductions.",
        "tr": "Herhangi bir vergi kesintisinden önceki brüt bonus tutarı."
      }
    },
    {
      "id": "federalTaxRate",
      "label": "Federal Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 22,
      "businessContext": "Federal income tax withholding rate applied to bonuses (percent).",
      "label_i18n": {
        "en": "Federal Tax Rate",
        "tr": "Federal Vergi Oranı",
        "de": "Federal Tax Rate",
        "fr": "Federal Tax Rate",
        "es": "Federal Tax Rate",
        "ar": "Federal Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Federal income tax withholding rate applied to bonuses (percent).",
        "tr": "İkramiyelere uygulanan federal gelir vergisi stopaj oranı (yüzde)."
      }
    },
    {
      "id": "socialSecurityRate",
      "label": "Social Security Rate",
      "type": "number",
      "unit": "%",
      "default": 6.2,
      "businessContext": "Social Security tax rate on bonuses (percent).",
      "label_i18n": {
        "en": "Social Security Rate",
        "tr": "Sosyal Güvenlik Oranı",
        "de": "Social Security Rate",
        "fr": "Social Security Rate",
        "es": "Social Security Rate",
        "ar": "Social Security Rate"
      },
      "businessContext_i18n": {
        "en": "Social Security tax rate on bonuses (percent).",
        "tr": "İkramiyelere uygulanan Sosyal Güvenlik vergi oranı (yüzde)."
      }
    },
    {
      "id": "medicareRate",
      "label": "Medicare Rate",
      "type": "number",
      "unit": "%",
      "default": 1.45,
      "businessContext": "Medicare tax rate on bonuses (percent).",
      "label_i18n": {
        "en": "Medicare Rate",
        "tr": "Medicare Oranı",
        "de": "Medicare Rate",
        "fr": "Medicare Rate",
        "es": "Medicare Rate",
        "ar": "Medicare Rate"
      },
      "businessContext_i18n": {
        "en": "Medicare tax rate on bonuses (percent).",
        "tr": "İkramiyelere uygulanan Medicare vergi oranı (yüzde)."
      }
    },
    {
      "id": "stateTaxRate",
      "label": "State Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "State income tax withholding rate on bonuses (percent).",
      "label_i18n": {
        "en": "State Tax Rate",
        "tr": "Eyalet Vergi Oranı",
        "de": "State Tax Rate",
        "fr": "State Tax Rate",
        "es": "State Tax Rate",
        "ar": "State Tax Rate"
      },
      "businessContext_i18n": {
        "en": "State income tax withholding rate on bonuses (percent).",
        "tr": "İkramiyelere uygulanan eyalet gelir vergisi stopaj oranı (yüzde)."
      }
    }
  ],
  "formulas": {
    "federalTax": "bonusAmount * federalTaxRate / 100",
    "socialSecurityTax": "bonusAmount * socialSecurityRate / 100",
    "medicareTax": "bonusAmount * medicareRate / 100",
    "stateTax": "bonusAmount * stateTaxRate / 100",
    "totalTax": "federalTax + socialSecurityTax + medicareTax + stateTax",
    "netBonus": "bonusAmount - totalTax"
  },
  "outputs": {
    "primary": "netBonus",
    "breakdown": [
      "totalTax",
      "federalTax",
      "socialSecurityTax",
      "medicareTax",
      "stateTax"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

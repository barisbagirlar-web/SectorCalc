{
  "toolName": "credit-card-interest-calculator",
  "inputs": [
    {
      "id": "outstandingBalance",
      "label": "Outstanding Balance",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "The current credit card balance.",
      "label_i18n": {
        "en": "Outstanding Balance",
        "tr": "Outstanding Balance",
        "de": "Outstanding Balance",
        "fr": "Outstanding Balance",
        "es": "Outstanding Balance",
        "ar": "Outstanding Balance"
      }
    },
    {
      "id": "annualPercentageRate",
      "label": "Annual Percentage Rate (APR)",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "The annual interest rate for the credit card.",
      "label_i18n": {
        "en": "Annual Percentage Rate (APR)",
        "tr": "Annual Percentage Rate (APR)",
        "de": "Annual Percentage Rate (APR)",
        "fr": "Annual Percentage Rate (APR)",
        "es": "Annual Percentage Rate (APR)",
        "ar": "Annual Percentage Rate (APR)"
      }
    },
    {
      "id": "billingDays",
      "label": "Billing Period (Days)",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of days in the billing cycle.",
      "label_i18n": {
        "en": "Billing Period (Days)",
        "tr": "Billing Period (Days)",
        "de": "Billing Period (Days)",
        "fr": "Billing Period (Days)",
        "es": "Billing Period (Days)",
        "ar": "Billing Period (Days)"
      }
    },
    {
      "id": "minimumPaymentPercent",
      "label": "Minimum Payment (%)",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The percentage of the outstanding balance required as minimum payment.",
      "label_i18n": {
        "en": "Minimum Payment (%)",
        "tr": "Minimum Payment (%)",
        "de": "Minimum Payment (%)",
        "fr": "Minimum Payment (%)",
        "es": "Minimum Payment (%)",
        "ar": "Minimum Payment (%)"
      }
    }
  ],
  "formulas": {
    "dailyRate": "annualPercentageRate / (100 * 365)",
    "totalInterest": "outstandingBalance * ((1 + (annualPercentageRate / (100 * 365))) ** billingDays - 1)",
    "newBalance": "outstandingBalance + (outstandingBalance * ((1 + (annualPercentageRate / (100 * 365))) ** billingDays - 1))",
    "minimumPaymentAmount": "outstandingBalance * minimumPaymentPercent / 100"
  },
  "outputs": {
    "primary": "totalInterest",
    "breakdown": [
      "dailyRate",
      "newBalance",
      "minimumPaymentAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "minimumPaymentAmount",
    "unit": "currency"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",

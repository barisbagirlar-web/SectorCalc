        "es": "Operasyonel Giderler",
        "ar": "Operasyonel Giderler"
      }
    },
    {
      "id": "otherFeesMonthly",
      "label": "Diğer Aylık Ücretler",
      "type": "number",
      "unit": "₺/ay",
      "default": 0,
      "businessContext": "Diğer aylık sabit ücretler (lisans, yazılım vb.)",
      "label_i18n": {
        "en": "Diğer Aylık Ücretler",
        "tr": "Diğer Aylık Ücretler",
        "de": "Diğer Aylık Ücretler",
        "fr": "Diğer Aylık Ücretler",
        "es": "Diğer Aylık Ücretler",
        "ar": "Diğer Aylık Ücretler"
      }
    }
  ],
  "formulas": {
    "royaltyAmount": "monthlyRevenue * royaltyRate / 100",
    "marketingAmount": "monthlyRevenue * marketingFeeRate / 100",
    "totalFeesMonthly": "otherFeesMonthly + (monthlyRevenue * royaltyRate / 100) + (monthlyRevenue * marketingFeeRate / 100)",
    "monthlyNetProfit": "monthlyRevenue - operationalCosts - (otherFeesMonthly + monthlyRevenue * royaltyRate / 100 + monthlyRevenue * marketingFeeRate / 100)",
    "breakEvenMonths": "initialInvestment / (monthlyRevenue - operationalCosts - (otherFeesMonthly + monthlyRevenue * royaltyRate / 100 + monthlyRevenue * marketingFeeRate / 100))"
  },
  "outputs": {
    "primary": "monthlyNetProfit",
    "breakdown": [
      "totalFeesMonthly",
      "royaltyAmount",
      "marketingAmount",
      "breakEvenMonths"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "breakEvenMonths"
  },

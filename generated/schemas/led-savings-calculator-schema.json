  ],
  "formulas": {
    "annualEnergySavings": "(currentBulbWattage - ledBulbWattage) * numberOfBulbs * dailyUsageHours * daysPerYear / 1000",
    "annualCostSavings": "annualEnergySavings * electricityRate",
    "paybackPeriod": "annualCostSavings > 0 ? (ledBulbCost - currentBulbCost) * numberOfBulbs / annualCostSavings : null"
  },
  "outputs": {
    "primary": "paybackPeriod",
    "breakdown": [
      "Energy Savings: ${annualEnergySavings.toFixed(2)} kWh/year",
      "Payback Period: ${paybackPeriod !== null ? paybackPeriod.toFixed(2) + ' years' : 'N/A'}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "paybackPeriod",
    "unit": "W",
    "breakdownUnits": {
      "Energy Savings: ${annualEnergySavings.toFixed(2)} kWh/year": "kWh"
    }
  },

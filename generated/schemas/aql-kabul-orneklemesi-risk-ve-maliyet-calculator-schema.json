{
  "toolName": "aql-kabul-orneklemesi-risk-ve-maliyet-calculator",
  "inputs": [
    {
      "id": "lotSize",
      "label": "Lot Size (Parti Büyüklüğü)",
      "type": "number",
      "unit": "adet",
      "default": 1000,
      "min": 1,
      "max": 1000000,
      "options": null,
      "businessContext": "Toplam parti büyüklüğü. ISO 2859-1 standardına göre AQL örneklemesinde kullanılır."
    },
    {
      "id": "aqlLevel",
      "label": "AQL (Kabul Edilebilir Kalite Seviyesi)",
      "type": "number",
      "unit": "%",
      "default": 1,
      "min": 0.01,
      "max": 10,
      "options": null,
      "businessContext": "Kabul edilebilir maksimum kusur oranı. ISO 2859-1 standardına göre belirlenir."
    },
    {
      "id": "inspectionLevel",
      "label": "Muayene Seviyesi",
      "type": "select",
      "unit": "",
      "default": "II",
      "min": null,
      "max": null,
      "options": [
        "I",
        "II",
        "III"
      ],
      "businessContext": "ISO 2859-1'de tanımlanan genel muayene seviyeleri. Seviye II normal kullanılır."
    },
    {
      "id": "sampleSize",
      "label": "Örneklem Büyüklüğü",
      "type": "number",
      "unit": "adet",
      "default": 80,
      "min": 1,
      "max": 10000,
      "options": null,
      "businessContext": "ISO 2859-1 tablolarından lot büyüklüğü ve muayene seviyesine göre belirlenen örneklem sayısı."
    },
    {
      "id": "acceptNumber",
      "label": "Kabul Sayısı (Ac)",
      "type": "number",
      "unit": "adet",
      "default": 2,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "ISO 2859-1'de AQL ve örneklem büyüklüğüne göre belirlenen kabul edilebilir maksimum kusur sayısı."
    },
    {
      "id": "defectRate",
      "label": "Gerçek Kusur Oranı",
      "type": "number",
      "unit": "%",
      "default": 2,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Partideki gerçek kusur oranı. Tahmini veya geçmiş verilere dayanır."
    },
    {
      "id": "unitCost",
      "label": "Birim Maliyet",
      "type": "number",
      "unit": "TL/adet",
      "default": 10,
      "min": 0,
      "max": 100000,
      "options": null,
      "businessContext": "Her bir ürünün üretim maliyeti."
    },
    {
      "id": "inspectionCostPerUnit",
      "label": "Birim Muayene Maliyeti",
      "type": "number",
      "unit": "TL/adet",
      "default": 1,
      "min": 0,
      "max": 1000,
      "options": null,
      "businessContext": "Her bir ürünü muayene etmenin maliyeti."
    },
    {
      "id": "reworkCostPerUnit",
      "label": "Birim Düzeltme Maliyeti",
      "type": "number",
      "unit": "TL/adet",
      "default": 5,
      "min": 0,
      "max": 1000,
      "options": null,
      "businessContext": "Kusurlu ürünü düzeltme maliyeti."
    },
    {
      "id": "rejectionCostPerUnit",
      "label": "Birim Reddetme Maliyeti",
      "type": "number",
      "unit": "TL/adet",
      "default": 20,
      "min": 0,
      "max": 10000,
      "options": null,
      "businessContext": "Kusurlu ürünü reddetme (hurda) maliyeti."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Girdi verilerinin güvenilirliği. Düşük güven, sonuçları düzeltmek için kullanılır."
    }
  ],
  "validation": {
    "rules": [
      "lotSize > 0",
      "aqlLevel > 0 and aqlLevel <= 10",
      "sampleSize > 0 and sampleSize <= lotSize",
      "acceptNumber >= 0",
      "defectRate >= 0 and defectRate <= 100",
      "unitCost >= 0",
      "inspectionCostPerUnit >= 0",
      "reworkCostPerUnit >= 0",
      "rejectionCostPerUnit >= 0",
      "dataConfidence >= 0 and dataConfidence <= 100"
    ],
    "thresholds": {
      "defectRate > aqlLevel": "UYARI: Gerçek kusur oranı AQL seviyesini aşıyor, parti reddedilme riski yüksek.",
      "defectRate > 5": "KRITIK: Kusur oranı %5'in üzerinde, süreç iyileştirme gerekli.",
      "sampleSize < 30": "UYARI: Örneklem büyüklüğü küçük, istatistiksel güven düşük."
    }
  },
  "formulas": {
    "probabilityOfAcceptance": "sum_{k=0}^{acceptNumber} ( (sampleSize choose k) * (defectRate/100)^k * (1 - defectRate/100)^(sampleSize - k) )",
    "producerRisk": "1 - probabilityOfAcceptance",
    "consumerRisk": "probabilityOfAcceptance when defectRate = aqlLevel",
    "expectedDefectsInLot": "lotSize * defectRate / 100",
    "expectedDefectsAccepted": "expectedDefectsInLot * probabilityOfAcceptance",
    "expectedDefectsRejected": "expectedDefectsInLot * (1 - probabilityOfAcceptance)",
    "inspectionCost": "sampleSize * inspectionCostPerUnit",
    "reworkCost": "expectedDefectsAccepted * reworkCostPerUnit",
    "rejectionCost": "expectedDefectsRejected * rejectionCostPerUnit",
    "totalCost": "inspectionCost + reworkCost + rejectionCost",
    "costPerUnit": "totalCost / lotSize",
    "dataConfidenceAdjustedCost": "totalCost * (100 / dataConfidence)"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": {
      "inspectionCost": "inspectionCost",
      "reworkCost": "reworkCost",
      "rejectionCost": "rejectionCost",
      "probabilityOfAcceptance": "probabilityOfAcceptance",
      "producerRisk": "producerRisk",
      "consumerRisk": "consumerRisk"
    },
    "hiddenLossDrivers": [
      "defectRate > aqlLevel ? 'Yüksek kusur oranı nedeniyle artan reddetme maliyeti' : ''",
      "sampleSize < 30 ? 'Küçük örneklem nedeniyle düşük güven' : ''"
    ],
    "suggestedActions": [
      "defectRate > aqlLevel ? 'Süreç iyileştirme ile kusur oranını düşürün.' : 'Mevcut kalite seviyesini koruyun.'",
      "producerRisk > 0.05 ? 'Örneklem büyüklüğünü artırarak üretici riskini azaltın.' : ''",
      "consumerRisk > 0.1 ? 'AQL seviyesini düşürerek tüketici riskini azaltın.' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjustedCost"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Comparison with Historical Data",
    "Detailed Report with OC Curve"
  ],
  "premiumRequired": true
}

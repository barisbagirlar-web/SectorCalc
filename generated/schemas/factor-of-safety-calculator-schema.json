      "label_i18n": {
        "en": "Material Yield Strength",
        "tr": "Material Yield Strength",
        "de": "Material Yield Strength",
        "fr": "Material Yield Strength",
        "es": "Material Yield Strength",
        "ar": "Material Yield Strength"
      }
    },
    {
      "id": "ultimateTensileStrength",
      "label": "Ultimate Tensile Strength",
      "type": "number",
      "unit": "MPa",
      "default": 400,
      "businessContext": "Maximum stress material can withstand while being stretched or pulled before breaking.",
      "label_i18n": {
        "en": "Ultimate Tensile Strength",
        "tr": "Ultimate Tensile Strength",
        "de": "Ultimate Tensile Strength",
        "fr": "Ultimate Tensile Strength",
        "es": "Ultimate Tensile Strength",
        "ar": "Ultimate Tensile Strength"
      }
    },
    {
      "id": "designFactor",
      "label": "Required Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "The minimum allowable factor of safety as per design standards, used for pass/fail check.",
      "label_i18n": {
        "en": "Required Safety Factor",
        "tr": "Required Safety Factor",
        "de": "Required Safety Factor",
        "fr": "Required Safety Factor",
        "es": "Required Safety Factor",
        "ar": "Required Safety Factor"
      }
    },
    {
      "id": "stressConcentrationFactor",
      "label": "Stress Concentration Factor (Kt)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Factor accounting for geometric discontinuities. For basic analysis, set to 1.",
      "label_i18n": {
        "en": "Stress Concentration Factor (Kt)",
        "tr": "Stress Concentration Factor (Kt)",
        "de": "Stress Concentration Factor (Kt)",
        "fr": "Stress Concentration Factor (Kt)",
        "es": "Stress Concentration Factor (Kt)",
        "ar": "Stress Concentration Factor (Kt)"
      }
    }
  ],
  "formulas": {
    "workingStress": "appliedForce / crossSectionArea * stressConcentrationFactor",
    "fosYield": "yieldStrength / workingStress",
    "fosUltimate": "ultimateTensileStrength / workingStress",
    "marginYield": "fosYield - 1"
  },
  "outputs": {
    "primary": "marginYield",
    "breakdown": [

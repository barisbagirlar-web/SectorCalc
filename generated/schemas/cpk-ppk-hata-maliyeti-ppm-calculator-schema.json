{
  "toolName": "cpk-ppk-hata-maliyeti-ppm-calculator",
  "inputs": [
    {
      "id": "usl",
      "label": "Üst Spesifikasyon Limiti (USL)",
      "type": "number",
      "unit": "birim",
      "default": 10,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Müşteri gereksinimlerini tanımlar. ISO 9001 kalite yönetim sistemlerinde spesifikasyon limitleri belirlenir."
    },
    {
      "id": "lsl",
      "label": "Alt Spesifikasyon Limiti (LSL)",
      "type": "number",
      "unit": "birim",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Müşteri gereksinimlerini tanımlar. ISO 9001 kalite yönetim sistemlerinde spesifikasyon limitleri belirlenir."
    },
    {
      "id": "mean",
      "label": "Süreç Ortalaması",
      "type": "number",
      "unit": "birim",
      "default": 5,
      "min": null,
      "max": null,
      "options": null,
      "businessContext": "Sürecin merkezi eğilimini gösterir. Altı Sigma projelerinde süreç performansı ölçümü için kullanılır."
    },
    {
      "id": "stdDev",
      "label": "Standart Sapma",
      "type": "number",
      "unit": "birim",
      "default": 1,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Süreç değişkenliğini ölçer. Altı Sigma'da süreç yetenek analizi için temel parametredir."
    },
    {
      "id": "annualProductionVolume",
      "label": "Yıllık Üretim Hacmi",
      "type": "number",
      "unit": "adet/yıl",
      "default": 100000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Toplam hata maliyetini hesaplamak için kullanılır. Üretim planlamasında temel girdidir."
    },
    {
      "id": "costPerDefect",
      "label": "Hata Başına Maliyet",
      "type": "number",
      "unit": "TL/adet",
      "default": 10,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Hurda, yeniden işleme, garanti vb. maliyetleri içerir. Kalite maliyetleri (COQ) hesaplamalarında kullanılır."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "select",
      "unit": "",
      "default": "medium",
      "min": null,
      "max": null,
      "options": [
        "low",
        "medium",
        "high"
      ],
      "businessContext": "Veri kalitesini değerlendirir. Düşük güven durumunda sonuçlar daha muhafazakar yorumlanmalıdır."
    }
  ],
  "validation": {
    "rules": [
      "usl > lsl",
      "stdDev > 0",
      "annualProductionVolume >= 0",
      "costPerDefect >= 0"
    ],
    "thresholds": {
      "cpk < 1.33": "Süreç yetersiz, iyileştirme gerekli",
      "ppk < 1.33": "Uzun dönem performans yetersiz",
      "ppm > 1000": "Yüksek hata oranı, acil aksiyon",
      "hataMaliyeti > 100000": "Yüksek maliyet, öncelikli iyileştirme"
    }
  },
  "formulas": {
    "cp": "(usl - lsl) / (6 * stdDev)",
    "cpk": "min((usl - mean) / (3 * stdDev), (mean - lsl) / (3 * stdDev))",
    "pp": "(usl - lsl) / (6 * stdDev)",
    "ppk": "min((usl - mean) / (3 * stdDev), (mean - lsl) / (3 * stdDev))",
    "ppm": "(1 - (cdfNormal(usl, mean, stdDev) - cdfNormal(lsl, mean, stdDev))) * 1e6",
    "hataMaliyeti": "ppm / 1e6 * annualProductionVolume * costPerDefect",
    "dataConfidenceAdjusted": "hataMaliyeti * (dataConfidence == 'low' ? 1.2 : (dataConfidence == 'medium' ? 1.0 : 0.9))"
  },
  "outputs": {
    "primary": "hataMaliyeti",
    "breakdown": {
      "cp": "Süreç Yetenek İndeksi (Kısa Dönem)",
      "cpk": "Düzeltilmiş Süreç Yetenek İndeksi (Kısa Dönem)",
      "pp": "Süreç Performans İndeksi (Uzun Dönem)",
      "ppk": "Düzeltilmiş Süreç Performans İndeksi (Uzun Dönem)",
      "ppm": "Milyonda Hata Sayısı",
      "hataMaliyeti": "Yıllık Toplam Hata Maliyeti (TL)"
    },
    "hiddenLossDrivers": [
      "cpk < 1.33 ? 'Süreç yetersiz, iyileştirme gerekli' : ''",
      "ppk < 1.33 ? 'Uzun dönem performans yetersiz' : ''",
      "ppm > 1000 ? 'Yüksek hata oranı, acil aksiyon' : ''",
      "hataMaliyeti > 100000 ? 'Yüksek maliyet, öncelikli iyileştirme' : ''"
    ],
    "suggestedActions": [
      "cpk < 1.33 ? 'Süreç iyileştirme çalışmaları başlatın (DMAIC)' : ''",
      "ppk < cpk ? 'Uzun dönem değişkenliği azaltmak için kontrol planı oluşturun' : ''",
      "ppm > 1000 ? 'Kök neden analizi yapın ve hata önleme mekanizmaları kurun' : ''",
      "hataMaliyeti > 100000 ? 'Kalite maliyet optimizasyonu projesi başlatın' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma (benchmark)",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

  "formulas": {
    "totalInvestment": "purchasePrice + renovationCost + closingCosts",
    "onePercent": "totalInvestment * 0.01",
    "gap": "monthlyRent - onePercent",
    "meetsRule": "gap >= 0 ? 1 : 0"
  },
  "outputs": {
    "primary": "gap",

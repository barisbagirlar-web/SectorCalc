{
  "toolName": "fire-calculator",
  "inputs": [
    {
      "id": "currentAge",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Your current age.",
      "label_i18n": {

        "tr": "Yaşam Beklentisi",
        "de": "Lebenserwartung",
        "fr": "Life Expectancy",
        "es": "Life Expectancy",
        "ar": "Life Expectancy"
      },
      "businessContext_i18n": {
        "en": "Expected lifespan for planning.",
        "tr": "Planlama için beklenen yaşam süresi.",
        "de": "Erwartete Lebensdauer für die Planung"
      }
    },
    {
      "id": "annualExpenses",
      "label": "Annual Expenses in Retirement",
      "type": "number",
      "unit": "currency",
      "default": 40000,
      "businessContext": "Estimated yearly spending after retirement.",
      "label_i18n": {
        "en": "Annual Expenses in Retirement",
        "tr": "Emeklilikte Yıllık Giderler",
        "de": "Jährliche Ausgaben im Ruhestand",
        "fr": "Annual Expenses in Retirement",
        "es": "Annual Expenses in Retirement",
        "ar": "Annual Expenses in Retirement"
      },
      "businessContext_i18n": {
        "en": "Estimated yearly spending after retirement.",
        "tr": "Emeklilikten sonra tahmini yıllık harcama.",
        "de": "Geschätzte jährliche Ausgaben nach der Pensionierung"
      }
    },
    {
      "id": "currentSavings",
      "label": "Current Savings",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "Total current retirement savings.",
      "label_i18n": {
        "en": "Current Savings",
        "tr": "Mevcut Birikimler",
        "de": "Aktuelle Ersparnisse",
        "fr": "Current Savings",
        "es": "Current Savings",
        "ar": "Current Savings"
      },
      "businessContext_i18n": {
        "en": "Total current retirement savings.",
        "tr": "Mevcut toplam emeklilik birikimleri.",
        "de": "Gesamte aktuelle Altersvorsorge-Ersparnisse."
      }
    },
    {
      "id": "annualContribution",
      "label": "Annual Contribution",
      "type": "number",
      "unit": "currency",
      "default": 20000,
      "businessContext": "Amount saved each year until retirement.",
      "label_i18n": {
        "en": "Annual Contribution",
        "tr": "Yıllık Katkı",
        "de": "Jährlicher Beitrag",
        "fr": "Annual Contribution",
        "es": "Annual Contribution",
        "ar": "Annual Contribution"
      },
      "businessContext_i18n": {
        "en": "Amount saved each year until retirement.",
        "tr": "Emekliliğe kadar her yıl biriktirilen miktar.",
        "de": "Jährlich bis zur Rente gesparter Betrag"
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Annual Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected average annual investment return.",
      "label_i18n": {
        "en": "Expected Annual Return",
        "tr": "Beklenen Yıllık Getiri",
        "de": "Erwartete jährliche Rendite",
        "fr": "Expected Annual Return",
        "es": "Expected Annual Return",
        "ar": "Expected Annual Return"
      },
      "businessContext_i18n": {
        "en": "Expected average annual investment return.",
        "tr": "Beklenen ortalama yıllık yatırım getirisi.",
        "de": "Erwartete durchschnittliche jährliche Kapitalrendite"
      }
    },
    {
      "id": "withdrawalRate",
      "label": "Safe Withdrawal Rate",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Percentage of savings you can withdraw annually.",
      "label_i18n": {
        "en": "Safe Withdrawal Rate",
        "tr": "Güvenli Çekme Oranı",
        "de": "Sichere Entnahmerate",
        "fr": "Safe Withdrawal Rate",
        "es": "Safe Withdrawal Rate",
        "ar": "Safe Withdrawal Rate"
      },
      "businessContext_i18n": {
        "en": "Percentage of savings you can withdraw annually.",
        "tr": "Her yıl çekebileceğiniz birikim yüzdesi.",
        "de": "Prozentsatz der Ersparnisse, den Sie jährlich entnehmen können"
      }
    }
  ],
  "formulas": {
    "yearsToRetirement": "retirementAge - currentAge",
    "futureValueOfSavings": "currentSavings * (1 + expectedReturn/100) ** yearsToRetirement + annualContribution * ((1 + expectedReturn/100) ** yearsToRetirement - 1) / (expectedReturn/100)",
    "requiredSavings": "annualExpenses / (withdrawalRate/100)",
    "retirementYears": "lifeExpectancy - retirementAge",
    "savingsAtRetirement": "futureValueOfSavings",
    "isFeasible": "savingsAtRetirement >= requiredSavings ? 1 : 0"
  },
  "outputs": {
    "primary": "savingsAtRetirement",
    "breakdown": [
      "requiredSavings",
      "yearsToRetirement",
      "isFeasible"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "isFeasible",
    "unit": "years"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,

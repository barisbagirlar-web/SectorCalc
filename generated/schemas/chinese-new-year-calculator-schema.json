      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "/",
      "default": 0.2,
      "businessContext": "Applicable tax rate as a decimal (e.g., 0.2 for 20%)",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "grossBonus": "baseSalary * bonusMonths + yearsOfService * 500 + dependents * 300 + overtimeHours * 30",
    "taxAmount": "grossBonus * taxRate",
    "netBonus": "grossBonus - taxAmount"
  },
  "outputs": {
    "primary": "netBonus",
    "breakdown": [
      "grossBonus",
      "taxAmount"
    ]
  },

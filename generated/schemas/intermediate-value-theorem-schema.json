  "formulas": {
    "exists": "((fa - k) * (fb - k) <= 0) ? 1 : 0",
    "c": "((fa - k) * (fb - k) <= 0) ? (a + b) / 2 : null",
    "fc": "((fa - k) * (fb - k) <= 0) ? ((fb - fa) / (b - a)) * (c - a) + fa : null"
  },
  "outputs": {
    "primary": "c",
    "breakdown": [
      "exists: 1 if a solution exists, 0 otherwise",
      "c: approximate root (midpoint) if exists, else null",
      "fc: approximate function value at c",
      "iterations: number of bisection steps needed"
    ],

{
  "toolName": "airspeed-calculator",
  "inputs": [
    {
      "id": "ias",
      "label": "Indicated Airspeed",
      "type": "number",
      "unit": "knots",
      "default": 100,
      "businessContext": "Airspeed shown on the airspeed indicator",
      "label_i18n": {
        "en": "Indicated Airspeed",
        "tr": "Indicated Airspeed",
        "de": "Indicated Airspeed",
        "fr": "Indicated Airspeed",
        "es": "Indicated Airspeed",
        "ar": "Indicated Airspeed"
      }
    },
    {
      "id": "indicatedAltitude",
      "label": "Indicated Altitude",
      "type": "number",
      "unit": "feet",
      "default": 5000,
      "businessContext": "Altitude shown on the altimeter with a given altimeter setting",
      "label_i18n": {
        "en": "Indicated Altitude",
        "tr": "Indicated Altitude",
        "de": "Indicated Altitude",
        "fr": "Indicated Altitude",
        "es": "Indicated Altitude",
        "ar": "Indicated Altitude"
      }
    },
    {
      "id": "altimeterSetting",
      "label": "Altimeter Setting",
      "type": "number",
      "unit": "inHg",
      "default": 29.92,
      "businessContext": "Current altimeter setting from weather station",
      "label_i18n": {
        "en": "Altimeter Setting",
        "tr": "Altimeter Setting",
        "de": "Altimeter Setting",
        "fr": "Altimeter Setting",
        "es": "Altimeter Setting",
        "ar": "Altimeter Setting"
      }
    },
    {
      "id": "oat",
      "label": "Outside Air Temperature",
      "type": "number",
      "unit": "°C",
      "default": 15,
      "businessContext": "OAT measured in Celsius",
      "label_i18n": {
        "en": "Outside Air Temperature",
        "tr": "Outside Air Temperature",
        "de": "Outside Air Temperature",
        "fr": "Outside Air Temperature",
        "es": "Outside Air Temperature",
        "ar": "Outside Air Temperature"
      }
    }
  ],
  "formulas": {
    "pressureAltitude": "indicatedAltitude + 1000 * (29.92 - altimeterSetting)",
    "oatK": "oat + 273.15",
    "delta": "Math.pow(1 - 6.8755856e-6 * pressureAltitude, 5.2561)",
    "theta": "oatK / 288.15",
    "sigma": "delta / theta",
    "tas": "ias / Math.sqrt(sigma)",
    "densityAltitude": "pressureAltitude + 118.8 * (oat - (15 - 1.98 * pressureAltitude / 1000))",
    "mach": "tas / (38.9679 * Math.sqrt(oatK))"
  },
  "outputs": {
    "primary": "tas",
    "breakdown": [
      "densityAltitude",
      "mach"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

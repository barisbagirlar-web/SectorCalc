  "formulas": {
    "pressureAltitude": "indicatedAltitude + 1000 * (29.92 - altimeterSetting)",
    "oatK": "oat + 273.15",
    "theta": "oatK / 288.15",
    "densityAltitude": "pressureAltitude + 118.8 * (oat - (15 - 1.98 * pressureAltitude / 1000))"
  },
  "outputs": {
    "primary": "densityAltitude",
    "breakdown": [
      "densityAltitude",
      "mach"

{
  "toolName": "menu-pricing-calculator",
  "inputs": [
    {
      "id": "totalIngredientCost",
      "label": "Total Ingredient Cost",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "The total cost of all ingredients used to prepare the dish.",
      "label_i18n": {
        "en": "Total Ingredient Cost",
        "tr": "Total Ingredient Cost",
        "de": "Total Ingredient Cost",
        "fr": "Total Ingredient Cost",
        "es": "Total Ingredient Cost",
        "ar": "Total Ingredient Cost"
      }
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour",
      "type": "number",
      "unit": "currency/hour",
      "default": 0,
      "businessContext": "The hourly labor cost for the chef or staff preparing the dish.",
      "label_i18n": {
        "en": "Labor Cost per Hour",
        "tr": "Labor Cost per Hour",
        "de": "Labor Cost per Hour",
        "fr": "Labor Cost per Hour",
        "es": "Labor Cost per Hour",
        "ar": "Labor Cost per Hour"
      }
    },
    {
      "id": "preparationTimeMinutes",
      "label": "Preparation Time",
      "type": "number",
      "unit": "minutes",
      "default": 0,
      "businessContext": "The total time in minutes required to prepare the dish.",
      "label_i18n": {
        "en": "Preparation Time",
        "tr": "Preparation Time",
        "de": "Preparation Time",
        "fr": "Preparation Time",
        "es": "Preparation Time",
        "ar": "Preparation Time"
      }
    },
    {
      "id": "overheadPercentage",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "The overhead costs as a percentage of the total direct costs (e.g., rent, utilities).",
      "label_i18n": {
        "en": "Overhead Percentage",
        "tr": "Overhead Percentage",
        "de": "Overhead Percentage",
        "fr": "Overhead Percentage",
        "es": "Overhead Percentage",
        "ar": "Overhead Percentage"
      }
    },
    {
      "id": "desiredProfitMargin",
      "label": "Desired Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "The target profit margin on the selling price.",
      "label_i18n": {
        "en": "Desired Profit Margin",
        "tr": "Desired Profit Margin",
        "de": "Desired Profit Margin",
        "fr": "Desired Profit Margin",
        "es": "Desired Profit Margin",
        "ar": "Desired Profit Margin"
      }
    },
    {
      "id": "numberOfServings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "The number of servings the recipe yields.",
      "label_i18n": {
        "en": "Number of Servings",
        "tr": "Number of Servings",
        "de": "Number of Servings",
        "fr": "Number of Servings",
        "es": "Number of Servings",
        "ar": "Number of Servings"
      }
    }
  ],
  "formulas": {
    "laborCostTotal": "laborCostPerHour * preparationTimeMinutes / 60",
    "totalDirectCostPerServing": "(totalIngredientCost + laborCostPerHour * preparationTimeMinutes / 60) / numberOfServings",
    "totalCostWithOverhead": "totalDirectCostPerServing * (1 + overheadPercentage / 100)",
    "recommendedMenuPrice": "totalCostWithOverhead / (1 - desiredProfitMargin / 100)",
    "overheadAmount": "totalDirectCostPerServing * overheadPercentage / 100",
    "profitAmount": "recommendedMenuPrice - totalCostWithOverhead"
  },
  "outputs": {
    "primary": "recommendedMenuPrice",
    "breakdown": [
      "totalIngredientCost",
      "laborCostTotal",
      "overheadAmount",
      "profitAmount",
      "totalDirectCostPerServing",
      "totalCostWithOverhead",
      "recommendedMenuPrice"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitAmount"
  },
  "category": "Maliyet & Bütçeleme",

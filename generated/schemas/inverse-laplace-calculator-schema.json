  "formulas": {
    "primary": "if (denominator_order === 1) { return (F_s / denominator_coeffs) * Math.exp(-denominator_coeffs * time_value); } else if (denominator_order === 2) { let omega_n = natural_frequency; let zeta = damping_ratio; let omega_d = omega_n * Math.sqrt(1 - zeta * zeta); let numerator = F_s; let denominator = denominator_coeffs; return (numerator / denominator) * (1 - (Math.exp(-zeta * omega_n * time_value) / Math.sqrt(1 - zeta * zeta)) * Math.sin(omega_d * time_value + Math.acos(zeta))); } else { return 0; }",
    "breakdown": "F_s",
    "Exponential_term": "Exponential term",
    "Sinusoidal_term": "Sinusoidal term",
    "result": "f(t) value"
  },

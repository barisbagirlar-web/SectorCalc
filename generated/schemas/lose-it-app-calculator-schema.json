{
  "toolName": "lose-it-app-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Yaş",
      "type": "number",
      "unit": "yıl",
      "default": 30,
      "businessContext": "Kullanıcının yaşı"
    },
    {
      "id": "height",
      "label": "Boy",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Boy uzunluğu"
    },
    {
      "id": "weight",
      "label": "Kilo",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Vücut ağırlığı"
    },
    {
      "id": "gender",
      "label": "Cinsiyet (0: Erkek, 1: Kadın)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "0 erkek, 1 kadın"
    },
    {
      "id": "activityLevel",
      "label": "Aktivite Seviyesi",
      "type": "number",
      "unit": "",
      "default": 1.2,
      "businessContext": "1.2: sedanter, 1.375: hafif aktif, 1.55: orta, 1.725: yüksek, 1.9: çok yüksek"
    },
    {
      "id": "weightGoal",
      "label": "Hedef Kilo Değişimi (haftada kg)",
      "type": "number",
      "unit": "kg/hafta",
      "default": -0.5,
      "businessContext": "Negatif: kilo verme, pozitif: kilo alma"
    }
  ],
  "formulas": {
    "bmr": "10 * weight + 6.25 * height - 5 * age + (gender === 0 ? 5 : -161)",
    "tdee": "bmr * activityLevel",
    "dailyAdjustment": "(weightGoal * 7700) / 7",
    "calorieBudget": "tdee + dailyAdjustment"
  },
  "outputs": {
    "primary": "calorieBudget",
    "breakdown": [
      "bmr",
      "tdee",
      "dailyAdjustment"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false
}
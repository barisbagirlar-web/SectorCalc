  "formulas": {
    "recoveryScore": "(restTime / (workoutDuration * intensity)) * (1 - age * 0.01) * (bodyWeight / 70) * 100",
    "muscleStrain": "workoutDuration * intensity / 10",
    "fatigueLevel": "(workoutDuration * intensity / 10) * (age / 30)"
  },
  "outputs": {
    "primary": "recoveryScore",
    "breakdown": [
      "muscleStrain",
      "fatigueLevel"
    ],

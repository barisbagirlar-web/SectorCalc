        "en": "Number of Passengers",
        "tr": "Number of Passengers",
        "de": "Number of Passengers",
        "fr": "Number of Passengers",
        "es": "Number of Passengers",
        "ar": "Number of Passengers"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage discount applied to the total fare, e.g., for group travels or promotions.",
      "label_i18n": {
        "en": "Discount Percentage",
        "tr": "Discount Percentage",
        "de": "Discount Percentage",
        "fr": "Discount Percentage",
        "es": "Discount Percentage",
        "ar": "Discount Percentage"
      }
    }
  ],
  "formulas": {
    "totalBeforeDiscount": "baseFarePerKm * distanceKm * numberOfPassengers",
    "discountAmount": "totalBeforeDiscount * (discountPercent / 100)",
    "totalFare": "totalBeforeDiscount - discountAmount"
  },
  "outputs": {
    "primary": "totalFare",
    "breakdown": [
      "totalBeforeDiscount",
      "discountAmount"

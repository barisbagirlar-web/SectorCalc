{
  "toolName": "gdt-calculator",
  "inputs": [
    {
      "id": "nominal_size",
      "label": "Nominal Size (mm)",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "Basic size of the feature per drawing"
    },
    {
      "id": "tolerance_value",
      "label": "Tolerance Value (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0.1,
      "businessContext": "Specified tolerance from GD&T callout"
    },
    {
      "id": "feature_tolerance",
      "label": "Feature Tolerance (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0.05,
      "businessContext": "Tolerance for the feature of size"
    },
    {
      "id": "datum_shift",
      "label": "Datum Shift (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Shift allowed due to datum feature size"
    },
    {
      "id": "bonus_tolerance",
      "label": "Bonus Tolerance (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Additional tolerance from MMC/LMC"
    },
    {
      "id": "angle",
      "label": "Angle (degrees)",
      "type": "number",
      "unit": "deg",
      "default": 90,
      "businessContext": "Angle for angularity or orientation"
    }
  ],
  "formulas": {
    "total_tolerance": "tolerance_value + bonus_tolerance + datum_shift",
    "mmc_size": "nominal_size + feature_tolerance",
    "lmc_size": "nominal_size - feature_tolerance",
    "virtual_condition": "mmc_size + total_tolerance",
    "resultant_condition": "lmc_size - total_tolerance",
    "angular_tolerance": "total_tolerance * Math.sin(angle * Math.PI / 180)"
  },
  "outputs": {
    "primary": "Total Tolerance: {total_tolerance} mm",
    "breakdown": [
      "MMC Size: {mmc_size} mm",
      "LMC Size: {lmc_size} mm",
      "Virtual Condition: {virtual_condition} mm",
      "Resultant Condition: {resultant_condition} mm",
      "Angular Tolerance: {angular_tolerance} mm"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

{
  "toolName": "gdt-calculator",
  "inputs": [
    {
      "id": "nominal_size",
      "label": "Nominal Size (mm)",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "businessContext": "Basic size of the feature per drawing",
      "label_i18n": {
        "en": "Nominal Size (mm)",
        "tr": "Nominal Size (mm)",
        "de": "Nominal Size (mm)",
        "fr": "Nominal Size (mm)",
        "es": "Nominal Size (mm)",
        "ar": "Nominal Size (mm)"
      }
    },
    {
      "id": "tolerance_value",
      "label": "Tolerance Value (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0.1,
      "businessContext": "Specified tolerance from GD&T callout",
      "label_i18n": {
        "en": "Tolerance Value (mm)",
        "tr": "Tolerance Value (mm)",
        "de": "Tolerance Value (mm)",
        "fr": "Tolerance Value (mm)",
        "es": "Tolerance Value (mm)",
        "ar": "Tolerance Value (mm)"
      }
    },
    {
      "id": "feature_tolerance",
      "label": "Feature Tolerance (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0.05,
      "businessContext": "Tolerance for the feature of size",
      "label_i18n": {
        "en": "Feature Tolerance (mm)",
        "tr": "Feature Tolerance (mm)",
        "de": "Feature Tolerance (mm)",
        "fr": "Feature Tolerance (mm)",
        "es": "Feature Tolerance (mm)",
        "ar": "Feature Tolerance (mm)"
      }
    },
    {
      "id": "datum_shift",
      "label": "Datum Shift (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Shift allowed due to datum feature size",
      "label_i18n": {
        "en": "Datum Shift (mm)",
        "tr": "Datum Shift (mm)",
        "de": "Datum Shift (mm)",
        "fr": "Datum Shift (mm)",
        "es": "Datum Shift (mm)",
        "ar": "Datum Shift (mm)"
      }
    },
    {
      "id": "bonus_tolerance",
      "label": "Bonus Tolerance (mm)",
      "type": "number",
      "unit": "mm",
      "default": 0,
      "businessContext": "Additional tolerance from MMC/LMC",
      "label_i18n": {
        "en": "Bonus Tolerance (mm)",
        "tr": "Bonus Tolerance (mm)",
        "de": "Bonus Tolerance (mm)",
        "fr": "Bonus Tolerance (mm)",
        "es": "Bonus Tolerance (mm)",
        "ar": "Bonus Tolerance (mm)"
      }
    },
    {
      "id": "angle",
      "label": "Angle (degrees)",
      "type": "number",
      "unit": "deg",
      "default": 90,
      "businessContext": "Angle for angularity or orientation",
      "label_i18n": {
        "en": "Angle (degrees)",
        "tr": "Angle (degrees)",
        "de": "Angle (degrees)",
        "fr": "Angle (degrees)",
        "es": "Angle (degrees)",
        "ar": "Angle (degrees)"
      }
    }
  ],
  "formulas": {
    "total_tolerance": "tolerance_value + bonus_tolerance + datum_shift",
    "mmc_size": "nominal_size + feature_tolerance",
    "lmc_size": "nominal_size - feature_tolerance",
    "virtual_condition": "mmc_size + total_tolerance",
    "resultant_condition": "lmc_size - total_tolerance",
    "angular_tolerance": "total_tolerance * Math.sin(angle * Math.PI / 180)",
    "_mmc_size__mm": "{mmc_size} mm",
    "_lmc_size__mm": "{lmc_size} mm",
    "_virtual_condition__mm": "{virtual_condition} mm",
    "_resultant_condition__mm": "{resultant_condition} mm",
    "_angular_tolerance__mm": "{angular_tolerance} mm"
  },
  "outputs": {
    "primary": "total_tolerance",
    "breakdown": [
      "MMC Size: {mmc_size} mm",
      "LMC Size: {lmc_size} mm",
      "Virtual Condition: {virtual_condition} mm",
      "Resultant Condition: {resultant_condition} mm",
      "Angular Tolerance: {angular_tolerance} mm"
    ]
  },
  "category": "İK & Personel",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "workforce-hr",
  "sectorId": "havacilik",
  "profession": "Tasarım Mühendisi",
  "categoryId": "conversion"
}

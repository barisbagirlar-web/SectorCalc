  ],
  "formulas": {
    "unseenCards": "totalCards - knownCards",
    "probabilityWin": "numberOfOuts / unseenCards",
    "potOdds": "betToCall / (currentPot + betToCall)",
    "expectedValue": "probabilityWin * (currentPot + betToCall) - (1 - probabilityWin) * betToCall"
  },

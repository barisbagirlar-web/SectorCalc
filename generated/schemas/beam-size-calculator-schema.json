{
  "toolName": "beam-size-calculator",
  "inputs": [
    {
      "id": "span",
      "label": "Beam Span (L)",
      "type": "number",
      "unit": "mm",
      "default": 3000,
      "businessContext": "Clear distance between supports for a simply supported beam.",
      "label_i18n": {
        "en": "Beam Span (L)",
        "tr": "Beam Span (L)",
        "de": "Beam Span (L)",
        "fr": "Beam Span (L)",
        "es": "Beam Span (L)",
        "ar": "Beam Span (L)"
      }
    },
    {
      "id": "udl",
      "label": "Uniformly Distributed Load (w)",
      "type": "number",
      "unit": "N/mm",
      "default": 10,
      "businessContext": "Load applied evenly along the full length of the beam.",
      "label_i18n": {
        "en": "Uniformly Distributed Load (w)",
        "tr": "Uniformly Distributed Load (w)",
        "de": "Uniformly Distributed Load (w)",
        "fr": "Uniformly Distributed Load (w)",
        "es": "Uniformly Distributed Load (w)",
        "ar": "Uniformly Distributed Load (w)"
      }
    },
    {
      "id": "allowableStress",
      "label": "Allowable Bending Stress (σ_allow)",
      "type": "number",
      "unit": "MPa",
      "default": 160,
      "businessContext": "Maximum permissible stress for the beam material under bending.",
      "label_i18n": {
        "en": "Allowable Bending Stress (σ_allow)",
        "tr": "Allowable Bending Stress (σ_allow)",
        "de": "Allowable Bending Stress (σ_allow)",
        "fr": "Allowable Bending Stress (σ_allow)",
        "es": "Allowable Bending Stress (σ_allow)",
        "ar": "Allowable Bending Stress (σ_allow)"
      }
    },
    {
      "id": "elasticModulus",
      "label": "Modulus of Elasticity (E)",
      "type": "number",
      "unit": "MPa",
      "default": 200000,
      "businessContext": "Young's modulus of the beam material.",
      "label_i18n": {
        "en": "Modulus of Elasticity (E)",
        "tr": "Modulus of Elasticity (E)",
        "de": "Modulus of Elasticity (E)",
        "fr": "Modulus of Elasticity (E)",
        "es": "Modulus of Elasticity (E)",
        "ar": "Modulus of Elasticity (E)"
      }
    },
    {
      "id": "deflectionRatio",
      "label": "Deflection Limit Ratio (L/δ)",
      "type": "number",
      "unit": "unit",
      "default": 360,
      "businessContext": "Allowable deflection expressed as span divided by this ratio (e.g., 360 means L/360).",
      "label_i18n": {
        "en": "Deflection Limit Ratio (L/δ)",
        "tr": "Deflection Limit Ratio (L/δ)",
        "de": "Deflection Limit Ratio (L/δ)",
        "fr": "Deflection Limit Ratio (L/δ)",
        "es": "Deflection Limit Ratio (L/δ)",
        "ar": "Deflection Limit Ratio (L/δ)"
      }
    }
  ],
  "formulas": {
    "S_req_mm3": "(udl * Math.pow(span, 2) / 8) / allowableStress",
    "I_req_mm4": "(5 * udl * Math.pow(span, 3) * deflectionRatio) / (384 * elasticModulus)",
    "M_max_Nmm": "udl * Math.pow(span, 2) / 8",
    "delta_allow_mm": "span / deflectionRatio"
  },
  "outputs": {
    "primary": "S_req_mm3",
    "breakdown": [
      "I_req_mm4",
      "M_max_Nmm",
      "delta_allow_mm"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "İnşaat & Yapı",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "engineering"
}

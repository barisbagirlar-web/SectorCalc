{
  "toolName": "btu-to-joules-calculator",
  "inputs": [
    {
      "id": "btuValue",
      "label": "BTU Value",
      "type": "number",
      "unit": "BTU",
      "default": 0,
      "businessContext": "Energy quantity in British Thermal Units",
      "label_i18n": {
        "en": "BTU Value",
        "tr": "BTU Value",
        "de": "BTU Value",
        "fr": "BTU Value",
        "es": "BTU Value",
        "ar": "BTU Value"
      }
    },
    {
      "id": "btuStandard",
      "label": "BTU Standard",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1: IT (1055.06 J), 2: Thermochemical (1054.35 J), 3: ISO (1055.06 J), 4: Mean (1055.87 J)",
      "label_i18n": {
        "en": "BTU Standard",
        "tr": "BTU Standard",
        "de": "BTU Standard",
        "fr": "BTU Standard",
        "es": "BTU Standard",
        "ar": "BTU Standard"
      }
    },
    {
      "id": "precision",
      "label": "Precision",
      "type": "number",
      "unit": "decimal places",
      "default": 2,
      "businessContext": "Number of decimal places for the output",
      "label_i18n": {
        "en": "Precision",
        "tr": "Precision",
        "de": "Precision",
        "fr": "Precision",
        "es": "Precision",
        "ar": "Precision"
      }
    },
    {
      "id": "factorOverride",
      "label": "Custom Conversion Factor",
      "type": "number",
      "unit": "J/BTU",
      "default": 0,
      "businessContext": "Override standard factor; 0 to use selected standard",
      "label_i18n": {
        "en": "Custom Conversion Factor",
        "tr": "Custom Conversion Factor",
        "de": "Custom Conversion Factor",
        "fr": "Custom Conversion Factor",
        "es": "Custom Conversion Factor",
        "ar": "Custom Conversion Factor"
      }
    },
    {
      "id": "outputUnit",
      "label": "Output Unit",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1: Joules, 2: Kilojoules",
      "label_i18n": {
        "en": "Output Unit",
        "tr": "Output Unit",
        "de": "Output Unit",
        "fr": "Output Unit",
        "es": "Output Unit",
        "ar": "Output Unit"
      }
    }
  ],
  "formulas": {
    "conversionFactor": "factorOverride !== 0 ? factorOverride : (btuStandard === 1 ? 1055.05585262 : (btuStandard === 2 ? 1054.350 : (btuStandard === 3 ? 1055.056 : (btuStandard === 4 ? 1055.87 : 1055.05585262))))",
    "rawJoules": "btuValue * conversionFactor",
    "joules": "outputUnit === 2 ? rawJoules / 1000 : rawJoules"
  },
  "outputs": {
    "primary": "joules",
    "breakdown": [
      "`Conversion factor: ${conversionFactor} J/BTU`",
      "`Raw energy: ${rawJoules} ${outputUnit === 2 ? 'kJ' : 'J'}`",
      "`Standard used: ${btuStandard === 1 ? 'IT' : btuStandard === 2 ? 'Thermochemical' : btuStandard === 3 ? 'ISO' : btuStandard === 4 ? 'Mean' : 'Unknown'}`",
      "`Precision: ${precision} decimal places`"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roundedJoules"
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",

{
  "toolName": "biomass-calculator",
  "inputs": [
    {
      "id": "dbh_cm",
      "label": "Tree Diameter at Breast Height (DBH)",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "Measure of tree trunk diameter at 1.3 m above ground; used in allometric equations.",
      "label_i18n": {
        "en": "Tree Diameter at Breast Height (DBH)",
        "tr": "Tree Diameter at Breast Height (DBH)",
        "de": "Tree Diameter at Breast Height (DBH)",
        "fr": "Tree Diameter at Breast Height (DBH)",
        "es": "Tree Diameter at Breast Height (DBH)",
        "ar": "Tree Diameter at Breast Height (DBH)"
      }
    },
    {
      "id": "height_m",
      "label": "Tree Height",
      "type": "number",
      "unit": "m",
      "default": 20,
      "businessContext": "Total tree height; key variable in biomass estimation.",
      "label_i18n": {
        "en": "Tree Height",
        "tr": "Tree Height",
        "de": "Tree Height",
        "fr": "Tree Height",
        "es": "Tree Height",
        "ar": "Tree Height"
      }
    },
    {
      "id": "wood_density",
      "label": "Wood Density",
      "type": "number",
      "unit": "g/cm³",
      "default": 0.6,
      "businessContext": "Oven-dry wood density; varies by species; affects biomass calculation.",
      "label_i18n": {
        "en": "Wood Density",
        "tr": "Wood Density",
        "de": "Wood Density",
        "fr": "Wood Density",
        "es": "Wood Density",
        "ar": "Wood Density"
      }
    },
    {
      "id": "tree_count",
      "label": "Number of Trees",
      "type": "number",
      "unit": "trees",
      "default": 100,
      "businessContext": "Number of trees in the plot or stand for total biomass.",
      "label_i18n": {
        "en": "Number of Trees",
        "tr": "Number of Trees",
        "de": "Number of Trees",
        "fr": "Number of Trees",
        "es": "Number of Trees",
        "ar": "Number of Trees"
      }
    },
    {
      "id": "carbon_fraction",
      "label": "Carbon Fraction of Biomass",
      "type": "number",
      "unit": "(fraction)",
      "default": 0.47,
      "businessContext": "Default 0.47 from IPCC; fraction of biomass that is carbon.",
      "label_i18n": {
        "en": "Carbon Fraction of Biomass",
        "tr": "Carbon Fraction of Biomass",
        "de": "Carbon Fraction of Biomass",
        "fr": "Carbon Fraction of Biomass",
        "es": "Carbon Fraction of Biomass",
        "ar": "Carbon Fraction of Biomass"
      }
    }
  ],
  "formulas": {
    "biomass_per_tree_kg": "0.0673 * (wood_density * dbh_cm ** 2 * height_m) ** 0.976",
    "total_biomass_kg": "biomass_per_tree_kg * tree_count",
    "total_carbon_kg": "total_biomass_kg * carbon_fraction",
    "total_co2e_kg": "total_carbon_kg * 44 / 12"
  },
  "outputs": {
    "primary": "total_biomass_kg",
    "breakdown": [
      "biomass_per_tree_kg",
      "total_carbon_kg",
      "total_co2e_kg"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "total_co2e_kg"
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,

      "label_i18n": {
        "en": "Number in College",
        "tr": "Number in College",
        "de": "Number in College",
        "fr": "Number in College",
        "es": "Number in College",
        "ar": "Number in College"
      }
    },
    {
      "id": "state_tax_rate",
      "label": "State Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Estimated state income tax rate for allowance calculation",
      "label_i18n": {
        "en": "State Tax Rate",
        "tr": "State Tax Rate",
        "de": "State Tax Rate",
        "fr": "State Tax Rate",
        "es": "State Tax Rate",
        "ar": "State Tax Rate"
      }
    },
    {
      "id": "age_older_parent",
      "label": "Age of Older Parent",
      "type": "number",
      "unit": "years",
      "default": 45,
      "businessContext": "Age of the older parent, used to determine asset protection allowance",
      "label_i18n": {
        "en": "Age of Older Parent",
        "tr": "Age of Older Parent",
        "de": "Age of Older Parent",
        "fr": "Age of Older Parent",
        "es": "Age of Older Parent",
        "ar": "Age of Older Parent"
      }
    }
  ],
  "formulas": {
    "apa": "age_older_parent < 26 ? 0 : (age_older_parent >= 65 ? 100000 : (age_older_parent - 25) * 2500)",
    "federal_tax": "parent_agi * 0.15",
    "state_tax": "parent_agi * (state_tax_rate / 100)",
    "fica": "parent_agi * 0.0765",
    "student_asset_contribution": "student_assets * 0.2"
  },
  "outputs": {
    "primary": "student_asset_contribution",
    "breakdown": [
      "total_parent_contribution",
      "total_student_contribution"
    ],

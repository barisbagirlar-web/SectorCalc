  "formulas": {
    "T_internal": "SetupStopped",
    "T_external": "SetupRunning",
    "T_total": "T_internal + T_external",
    "T_target": "T_internal * (1 - ConversionRate) + T_external",
    "EBQ": "SQRT((2 * Demand * SetupCost) / HoldingCost)",
    "SetupCost": "T_total * MachineRate + Labor",
    "AnnualSavings": "(T_total - T_target) * Freq * Rate",
    "CapacityGain": "(T_total - T_target) * Freq / Available"
  },

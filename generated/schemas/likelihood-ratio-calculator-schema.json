{
  "toolName": "likelihood-ratio-calculator",
  "inputs": [
    {
      "id": "truePositives",
      "label": "True Positives",
      "type": "number",
      "unit": "cases",
      "default": 0,
      "businessContext": "Number of cases with condition and positive test",
      "label_i18n": {
        "en": "True Positives",
        "tr": "True Positives",

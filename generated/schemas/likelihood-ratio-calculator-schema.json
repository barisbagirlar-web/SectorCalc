      }
    },
    {
      "id": "falsePositives",
      "label": "False Positives",
      "type": "number",
      "unit": "cases",
      "default": 0,
      "businessContext": "Number of cases without condition but positive test",
      "label_i18n": {
        "en": "False Positives",
        "tr": "False Positives",
        "de": "False Positives",
        "fr": "False Positives",
        "es": "False Positives",
        "ar": "False Positives"
      }
    },
    {
      "id": "falseNegatives",
      "label": "False Negatives",
      "type": "number",
      "unit": "cases",
      "default": 0,
      "businessContext": "Number of cases with condition and negative test",
      "label_i18n": {
        "en": "False Negatives",
        "tr": "False Negatives",
        "de": "False Negatives",
        "fr": "False Negatives",
        "es": "False Negatives",
        "ar": "False Negatives"
      }
    },
    {
      "id": "trueNegatives",
      "label": "True Negatives",
      "type": "number",
      "unit": "cases",
      "default": 0,
      "businessContext": "Number of cases without condition and negative test",
      "label_i18n": {
        "en": "True Negatives",
        "tr": "True Negatives",
        "de": "True Negatives",
        "fr": "True Negatives",
        "es": "True Negatives",
        "ar": "True Negatives"
      }
    }
  ],
  "formulas": {
    "sensitivity": "truePositives + falseNegatives > 0 ? truePositives / (truePositives + falseNegatives) : 0",
    "specificity": "trueNegatives + falsePositives > 0 ? trueNegatives / (trueNegatives + falsePositives) : 0",
    "lrPositive": "specificity < 1 ? sensitivity / (1 - specificity) : 0",
    "lrNegative": "specificity > 0 ? (1 - sensitivity) / specificity : 0"
  },
  "outputs": {
    "primary": "lrPositive",
    "breakdown": [
      "lrNegative"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "lrNegative"
  },

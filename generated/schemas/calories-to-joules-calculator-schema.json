{
  "toolName": "calories-to-joules-calculator",
  "inputs": [
    {
      "id": "calorieAmount",
      "label": "Calorie Amount",
      "type": "number",
      "unit": "cal",
      "default": 0,
      "businessContext": "The amount of energy in calories to convert.",
      "label_i18n": {
        "en": "Calorie Amount",
        "tr": "Calorie Amount",
        "de": "Calorie Amount",
        "fr": "Calorie Amount",
        "es": "Calorie Amount",
        "ar": "Calorie Amount"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (J/cal)",
      "type": "number",
      "unit": "J/cal",
      "default": 4.184,
      "businessContext": "Standard thermochemical conversion factor. Adjust for specific calorie definitions.",
      "label_i18n": {
        "en": "Conversion Factor (J/cal)",
        "tr": "Conversion Factor (J/cal)",
        "de": "Conversion Factor (J/cal)",
        "fr": "Conversion Factor (J/cal)",
        "es": "Conversion Factor (J/cal)",
        "ar": "Conversion Factor (J/cal)"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for the output.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "batchSize",
      "label": "Batch Size",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of identical items to convert total energy.",
      "label_i18n": {
        "en": "Batch Size",
        "tr": "Batch Size",
        "de": "Batch Size",
        "fr": "Batch Size",
        "es": "Batch Size",
        "ar": "Batch Size"
      }
    }
  ],
  "formulas": {
    "joules": "calorieAmount * conversionFactor",
    "totalJoules": "joules * batchSize",
    "roundedJoules": "Math.round(joules * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "roundedTotalJoules": "Math.round(totalJoules * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "kilojoules": "joules / 1000"
  },
  "outputs": {
    "primary": "roundedJoules",
    "breakdown": [
      "joules",
      "totalJoules",
      "roundedTotalJoules",
      "kilojoules"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma"
}

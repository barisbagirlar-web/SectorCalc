      "unit": "J·s",
      "default": 1.054571817e-34,
      "businessContext": "Fundamental quantum constant. Typically fixed, but adjustable for theoretical scenarios.",
      "label_i18n": {
        "en": "Reduced Planck constant (ħ)",
        "tr": "Reduced Planck constant (ħ)",
        "de": "Reduced Planck constant (ħ)",
        "fr": "Reduced Planck constant (ħ)",
        "es": "Reduced Planck constant (ħ)",
        "ar": "Reduced Planck constant (ħ)"
      }
    },
    {
      "id": "tolerance",
      "label": "Compliance tolerance",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "Safety factor multiplier for minimum uncertainty product. >=1 ensures strict Heisenberg compliance.",
      "label_i18n": {
        "en": "Compliance tolerance",
        "tr": "Compliance tolerance",
        "de": "Compliance tolerance",
        "fr": "Compliance tolerance",
        "es": "Compliance tolerance",
        "ar": "Compliance tolerance"
      }
    },
    {
      "id": "mass",
      "label": "Particle mass",
      "type": "number",
      "unit": "kg",
      "default": 9.10938356e-31,
      "businessContext": "Mass of the particle (e.g., electron) for velocity uncertainty derivation.",
      "label_i18n": {
        "en": "Particle mass",
        "tr": "Particle mass",
        "de": "Particle mass",
        "fr": "Particle mass",
        "es": "Particle mass",
        "ar": "Particle mass"
      }
    },
    {
      "id": "deltaV",
      "label": "Velocity uncertainty (Δv)",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "If 0, will be calculated as Δp/mass. Else used as direct input for alternative computations.",
      "label_i18n": {
        "en": "Velocity uncertainty (Δv)",
        "tr": "Velocity uncertainty (Δv)",
        "de": "Velocity uncertainty (Δv)",
        "fr": "Velocity uncertainty (Δv)",
        "es": "Velocity uncertainty (Δv)",
        "ar": "Velocity uncertainty (Δv)"
      }
    }
  ],
  "formulas": {
    "product": "deltaX * deltaP",
    "minProduct": "hBar / 2 * tolerance",
    "certaintyRatio": "product / minProduct",
    "deltaV": "deltaV !== 0 ? deltaV : deltaP / mass"
  },
  "outputs": {

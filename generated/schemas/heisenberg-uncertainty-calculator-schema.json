        "ar": "Position uncertainty (Δx)"
      }
    },
    {
      "id": "deltaP",
      "label": "Momentum uncertainty (Δp)",
      "type": "number",
      "unit": "kg·m/s",
      "default": 1e-25,
      "businessContext": "Standard deviation of momentum measurement. Adjust based on measurement system.",
      "label_i18n": {
        "en": "Momentum uncertainty (Δp)",
        "tr": "Momentum uncertainty (Δp)",

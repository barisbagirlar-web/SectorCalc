{
  "toolName": "newtons-second-law-calculator",
  "inputs": [
    {
      "id": "mode",
      "label": "Calculation Mode",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "1=Calculate Force, 2=Calculate Acceleration, 3=Calculate Mass",
      "label_i18n": {
        "en": "Calculation Mode",
        "tr": "Calculation Mode",
        "de": "Calculation Mode",
        "fr": "Calculation Mode",
        "es": "Calculation Mode",
        "ar": "Calculation Mode"
      }
    },
    {
      "id": "mass",
      "label": "Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of the object",
      "label_i18n": {
        "en": "Mass",
        "tr": "Mass",
        "de": "Mass",
        "fr": "Mass",
        "es": "Mass",
        "ar": "Mass"
      }
    },
    {
      "id": "acceleration",
      "label": "Acceleration",
      "type": "number",
      "unit": "m/s²",
      "default": 0,
      "businessContext": "Acceleration of the object",
      "label_i18n": {
        "en": "Acceleration",
        "tr": "Acceleration",
        "de": "Acceleration",
        "fr": "Acceleration",
        "es": "Acceleration",
        "ar": "Acceleration"
      }
    },
    {
      "id": "force",
      "label": "Force",
      "type": "number",
      "unit": "N",
      "default": 0,
      "businessContext": "Net force acting on the object",
      "label_i18n": {
        "en": "Force",
        "tr": "Force",
        "de": "Force",
        "fr": "Force",
        "es": "Force",
        "ar": "Force"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for engineering safety margin (>=1)",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "forceCalc": "mass * acceleration * safetyFactor",
    "accelCalc": "mass !== 0 ? force / (mass * safetyFactor) : null",
    "massCalc": "acceleration !== 0 ? force / (acceleration * safetyFactor) : null",
    "result": "mode === 1 ? (mass * acceleration * safetyFactor) : (mode === 2 ? (mass !== 0 ? force / (mass * safetyFactor) : null) : (acceleration !== 0 ? force / (acceleration * safetyFactor) : null))"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "forceCalc",
      "accelCalc",
      "massCalc"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Otomotiv & Taşıt",

{
  "toolName": "newtons-second-law-calculator",
  "inputs": [
    {
      "id": "mode",
      "label": "Calculation Mode",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1=Calculate Force, 2=Calculate Acceleration, 3=Calculate Mass"
    },
    {
      "id": "mass",
      "label": "Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of the object"
    },
    {
      "id": "acceleration",
      "label": "Acceleration",
      "type": "number",
      "unit": "m/s²",
      "default": 0,
      "businessContext": "Acceleration of the object"
    },
    {
      "id": "force",
      "label": "Force",
      "type": "number",
      "unit": "N",
      "default": 0,
      "businessContext": "Net force acting on the object"
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Multiplier for engineering safety margin (>=1)"
    }
  ],
  "formulas": {
    "forceCalc": "mass * acceleration * safetyFactor",
    "accelCalc": "mass !== 0 ? force / (mass * safetyFactor) : null",
    "massCalc": "acceleration !== 0 ? force / (acceleration * safetyFactor) : null",
    "result": "mode === 1 ? (mass * acceleration * safetyFactor) : (mode === 2 ? (mass !== 0 ? force / (mass * safetyFactor) : null) : (acceleration !== 0 ? force / (acceleration * safetyFactor) : null))"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "forceCalc",
      "accelCalc",
      "massCalc"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

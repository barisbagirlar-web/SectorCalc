        "es": "Factor de seguridad",
        "ar": "Safety Factor"
      },
      "businessContext_i18n": {
        "en": "Multiplier for engineering safety margin (>=1)",
        "tr": "Mühendislik güvenlik marjı çarpanı (>=1)",
        "de": "Multiplikator für technischen Sicherheitsfaktor (>=1)",

      }
    },
    {
      "id": "demurrageRate",
      "label": "Demurrage Rate",
      "type": "number",
      "unit": "$/day",
      "default": 5000,
      "businessContext": "Daily demurrage cost if port time exceeds allowed.",
      "label_i18n": {
        "en": "Demurrage Rate",
        "tr": "Demuraj Oranı",
        "de": "Liegegeldsatz",
        "fr": "Demurrage Rate",
        "es": "Demurrage Rate",
        "ar": "Demurrage Rate"
      },
      "businessContext_i18n": {
        "en": "Daily demurrage cost if port time exceeds allowed.",
        "tr": "Liman süresinin izin verileni aşması durumunda günlük demuraj maliyeti.",
        "de": "Tägliche Liegegeldkosten, wenn die Hafenzeit die erlaubte überschreitet."
      }
    }
  ],
  "formulas": {
    "baseCost": "weight * distance * ratePerTonKm",
    "cleaningSurcharge": "baseCost * (cleaningSurchargePercent / 100)",
    "demurrageCost": "demurrageRiskFactor * demurrageRate",
    "totalCost": "baseCost + cleaningSurcharge + demurrageCost",
    "costPerTon": "totalCost / weight"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "baseCost",
      "cleaningSurcharge",
      "demurrageCost",
      "costPerTon"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerTon",
    "unit": "tons"
  },

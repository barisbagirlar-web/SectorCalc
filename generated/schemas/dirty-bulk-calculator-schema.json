{
  "toolName": "dirty-bulk-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Cargo Weight",
      "type": "number",
      "unit": "tons",
      "default": 1000,
      "businessContext": "Total weight of dirty bulk cargo to be shipped.",
      "label_i18n": {
        "en": "Cargo Weight",
        "tr": "Cargo Weight",
        "de": "Cargo Weight",
        "fr": "Cargo Weight",
        "es": "Cargo Weight",
        "ar": "Cargo Weight"
      }
    },
    {
      "id": "distance",
      "label": "Shipping Distance",
      "type": "number",
      "unit": "km",
      "default": 500,
      "businessContext": "Distance over sea route.",
      "label_i18n": {
        "en": "Shipping Distance",
        "tr": "Shipping Distance",
        "de": "Shipping Distance",
        "fr": "Shipping Distance",
        "es": "Shipping Distance",
        "ar": "Shipping Distance"
      }
    },
    {
      "id": "ratePerTonKm",
      "label": "Freight Rate",
      "type": "number",
      "unit": "$/ton-km",
      "default": 0.05,
      "businessContext": "Base freight rate per ton-km.",
      "label_i18n": {
        "en": "Freight Rate",
        "tr": "Freight Rate",
        "de": "Freight Rate",
        "fr": "Freight Rate",
        "es": "Freight Rate",
        "ar": "Freight Rate"
      }
    },
    {
      "id": "cleaningSurchargePercent",
      "label": "Cleaning Surcharge",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Additional percentage for tank cleaning after dirty cargo.",
      "label_i18n": {
        "en": "Cleaning Surcharge",
        "tr": "Cleaning Surcharge",
        "de": "Cleaning Surcharge",
        "fr": "Cleaning Surcharge",
        "es": "Cleaning Surcharge",
        "ar": "Cleaning Surcharge"
      }
    },
    {
      "id": "demurrageRiskFactor",
      "label": "Demurrage Risk Factor",
      "type": "number",
      "unit": "days",
      "default": 2,
      "businessContext": "Expected extra days due to cargo residue requiring extra cleaning.",
      "label_i18n": {
        "en": "Demurrage Risk Factor",
        "tr": "Demurrage Risk Factor",
        "de": "Demurrage Risk Factor",
        "fr": "Demurrage Risk Factor",
        "es": "Demurrage Risk Factor",
        "ar": "Demurrage Risk Factor"
      }
    },
    {
      "id": "demurrageRate",
      "label": "Demurrage Rate",
      "type": "number",
      "unit": "$/day",
      "default": 5000,
      "businessContext": "Daily demurrage cost if port time exceeds allowed.",
      "label_i18n": {
        "en": "Demurrage Rate",
        "tr": "Demurrage Rate",
        "de": "Demurrage Rate",
        "fr": "Demurrage Rate",
        "es": "Demurrage Rate",
        "ar": "Demurrage Rate"
      }
    }
  ],
  "formulas": {
    "baseCost": "weight * distance * ratePerTonKm",
    "cleaningSurcharge": "baseCost * (cleaningSurchargePercent / 100)",
    "demurrageCost": "demurrageRiskFactor * demurrageRate",
    "totalCost": "baseCost + cleaningSurcharge + demurrageCost",
    "costPerTon": "totalCost / weight"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "baseCost",
      "cleaningSurcharge",
      "demurrageCost",
      "costPerTon"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "costPerTon",
    "unit": "tons"
  },

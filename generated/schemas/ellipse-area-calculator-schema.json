{
  "toolName": "ellipse-area-calculator",
  "inputs": [
    {
      "id": "semiMajorAxis",
      "label": "Semi-Major Axis (a)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the longest radius of the ellipse",
      "label_i18n": {
        "en": "Semi-Major Axis (a)",
        "tr": "Semi-Major Axis (a)",
        "de": "Semi-Major Axis (a)",
        "fr": "Semi-Major Axis (a)",
        "es": "Semi-Major Axis (a)",
        "ar": "Semi-Major Axis (a)"
      }
    },
    {
      "id": "semiMinorAxis",
      "label": "Semi-Minor Axis (b)",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the shortest radius of the ellipse",
      "label_i18n": {
        "en": "Semi-Minor Axis (b)",
        "tr": "Semi-Minor Axis (b)",
        "de": "Semi-Minor Axis (b)",
        "fr": "Semi-Minor Axis (b)",
        "es": "Semi-Minor Axis (b)",
        "ar": "Semi-Minor Axis (b)"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for output rounding",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "unitConversionFactor",
      "label": "Unit Conversion Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiply the area by this factor to convert to desired area units (e.g., 10000 to convert m² to cm²)",
      "label_i18n": {
        "en": "Unit Conversion Factor",
        "tr": "Unit Conversion Factor",
        "de": "Unit Conversion Factor",
        "fr": "Unit Conversion Factor",
        "es": "Unit Conversion Factor",
        "ar": "Unit Conversion Factor"
      }
    }
  ],
  "formulas": {
    "aTimesB": "semiMajorAxis * semiMinorAxis",
    "area": "Math.PI * aTimesB",
    "convertedArea": "area * unitConversionFactor",
    "roundedArea": "(Math.round(convertedArea * Math.pow(10, precision))) / Math.pow(10, precision)"
  },
  "outputs": {
    "primary": "roundedArea",
    "breakdown": [
      "aTimesB",
      "convertedArea"
    ]
  },

  "formulas": {
    "TCO": "PurchasePrice + OrderingCost + TransportCost + QualityCost + InventoryCost + RiskCost",
    "QualityCost": "DefectRate * AnnualVolume * CostPerDefect",
    "InventoryCost": "(AvgLeadTime + SafetyStockDays) * DailyDemand * HoldingRate",
    "RiskCost": "ProbabilityOfDisruption * ImpactCost",
    "SupplierScore": "(QualityWeight * QualityScore) + (DeliveryWeight * DeliveryScore) + (CostWeight * CostScore)",
    "TCO_Variance": "TCO_Actual - TCO_Quoted"
  },

  "formulas": {
    "stressPower": "Math.pow(stress, n)",
    "exponentialTerm": "Math.exp(-Q / (R * temperature))",
    "creepRate": "A * Math.pow(stress, n) * Math.exp(-Q / (R * temperature))"
  },

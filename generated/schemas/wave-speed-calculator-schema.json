{
  "toolName": "wave-speed-calculator",
  "inputs": [
    {
      "id": "tension",
      "label": "Tension",
      "type": "number",
      "unit": "N",
      "default": 100,
      "businessContext": "String tension"
    },
    {
      "id": "linearDensity",
      "label": "Linear Density",
      "type": "number",
      "unit": "kg/m",
      "default": 0.01,
      "businessContext": "Mass per unit length of the string"
    },
    {
      "id": "length",
      "label": "String Length",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the vibrating part of the string"
    },
    {
      "id": "harmonicNumber",
      "label": "Harmonic Number",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "n-th harmonic (positive integer)"
    }
  ],
  "formulas": {
    "speed": "Math.sqrt(tension / linearDensity)",
    "fundamentalFrequency": "Math.sqrt(tension / linearDensity) / (2 * length)",
    "harmonicFrequency": "harmonicNumber * Math.sqrt(tension / linearDensity) / (2 * length)"
  },
  "outputs": {
    "primary": "speed",
    "breakdown": [
      "fundamentalFrequency",
      "harmonicFrequency"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

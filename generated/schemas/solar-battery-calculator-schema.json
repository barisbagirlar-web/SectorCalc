  "formulas": {
    "requiredEnergyWh": "(dailyEnergyConsumption * 1000 * daysOfAutonomy) / (depthOfDischarge * batteryEfficiency)",
    "requiredAh": "requiredEnergyWh / systemVoltage",
    "batteryCountExact": "requiredAh / batteryCapacityAh"
  },
  "outputs": {
    "primary": "requiredAh",
    "breakdown": [
      "requiredEnergyWh",
      "batteryCountExact"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "batteryCountExact",

{
  "toolName": "wine-blending-calculator",
  "inputs": [
    {
      "id": "volume1",
      "label": "Volume of Wine 1",
      "type": "number",
      "unit": "L",
      "default": 10,
      "businessContext": "Volume of the first wine, typically the one with higher ABV",
      "label_i18n": {
        "en": "Volume of Wine 1",
        "tr": "Volume of Wine 1",
        "de": "Volume of Wine 1",
        "fr": "Volume of Wine 1",
        "es": "Volume of Wine 1",
        "ar": "Volume of Wine 1"
      }
    },
    {
      "id": "abv1",
      "label": "ABV of Wine 1",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Alcohol by volume percentage of the first wine",
      "label_i18n": {
        "en": "ABV of Wine 1",
        "tr": "ABV of Wine 1",
        "de": "ABV of Wine 1",
        "fr": "ABV of Wine 1",
        "es": "ABV of Wine 1",
        "ar": "ABV of Wine 1"
      }
    },
    {
      "id": "abv2",
      "label": "ABV of Wine 2",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Alcohol by volume percentage of the second wine, lower than target ABV",
      "label_i18n": {
        "en": "ABV of Wine 2",
        "tr": "ABV of Wine 2",
        "de": "ABV of Wine 2",
        "fr": "ABV of Wine 2",
        "es": "ABV of Wine 2",
        "ar": "ABV of Wine 2"
      }
    },
    {
      "id": "targetABV",
      "label": "Target ABV",
      "type": "number",
      "unit": "%",
      "default": 13,
      "businessContext": "Desired alcohol by volume percentage of the final blend",
      "label_i18n": {
        "en": "Target ABV",
        "tr": "Target ABV",
        "de": "Target ABV",
        "fr": "Target ABV",
        "es": "Target ABV",
        "ar": "Target ABV"
      }
    }
  ],
  "formulas": {
    "volume2": "volume1 * (abv1 - targetABV) / (targetABV - abv2)",
    "totalVolume": "volume1 + volume2",
    "finalABV": "(volume1 * abv1 + volume2 * abv2) / totalVolume"
  },
  "outputs": {
    "primary": "volume2",
    "breakdown": [
      "totalVolume",
      "finalABV"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "finalABV"
  },

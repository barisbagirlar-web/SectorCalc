        "de": "Energy (eV)",
        "fr": "Energy (eV)",
        "es": "Energy (eV)",
        "ar": "Energy (eV)"
      }
    },
    {
      "id": "inputScale",
      "label": "Input unit multiplier",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Set to 1000 for keV, 1e6 for MeV. Default 1 for eV.",
      "label_i18n": {
        "en": "Input unit multiplier",
        "tr": "Input unit multiplier",
        "de": "Input unit multiplier",
        "fr": "Input unit multiplier",
        "es": "Input unit multiplier",
        "ar": "Input unit multiplier"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion factor",
      "type": "number",
      "unit": "J/eV",
      "default": 1.602176634e-19,
      "businessContext": "1.602176634×10⁻¹⁹ J/eV (exact, CODATA 2018).",
      "label_i18n": {
        "en": "Conversion factor",
        "tr": "Conversion factor",
        "de": "Conversion factor",
        "fr": "Conversion factor",
        "es": "Conversion factor",
        "ar": "Conversion factor"
      }
    },
    {
      "id": "outputScale",
      "label": "Output unit multiplier",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Set to 0.001 for kJ, 1e-6 for MJ. Default 1 for joules.",
      "label_i18n": {
        "en": "Output unit multiplier",
        "tr": "Output unit multiplier",
        "de": "Output unit multiplier",
        "fr": "Output unit multiplier",
        "es": "Output unit multiplier",
        "ar": "Output unit multiplier"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal places",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Number of decimal places for the result.",
      "label_i18n": {
        "en": "Decimal places",
        "tr": "Decimal places",
        "de": "Decimal places",
        "fr": "Decimal places",
        "es": "Decimal places",
        "ar": "Decimal places"
      }
    }
  ],
  "formulas": {
    "joules": "Math.round((electronVolts * inputScale * conversionFactor * outputScale) * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "exactValue": "electronVolts * inputScale * conversionFactor * outputScale",
    "calculationDetails": "'Energy (J) = ' + electronVolts + ' eV × ' + conversionFactor + ' J/eV = ' + (electronVolts * inputScale * conversionFactor * outputScale) + ' J (with input scale ' + inputScale + ' and output scale ' + outputScale + ')'"
  },
  "outputs": {
    "primary": "joules",
    "breakdown": [
      "exactValue",
      "calculationDetails"
    ]
  },

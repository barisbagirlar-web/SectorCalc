{
  "toolName": "voltage-divider-calculator",
  "inputs": [
    {
      "id": "vin",
      "label": "Input Voltage",
      "type": "number",
      "unit": "V",
      "default": 5,
      "businessContext": "The input voltage supplied to the divider.",
      "label_i18n": {
        "en": "Input Voltage",
        "tr": "Input Voltage",
        "de": "Input Voltage",
        "fr": "Input Voltage",
        "es": "Input Voltage",
        "ar": "Input Voltage"
      }
    },
    {
      "id": "r1",
      "label": "Resistance R1",
      "type": "number",
      "unit": "Ω",
      "default": 1000,
      "businessContext": "Resistance of the first resistor (connected to Vin).",
      "label_i18n": {
        "en": "Resistance R1",
        "tr": "Resistance R1",
        "de": "Resistance R1",
        "fr": "Resistance R1",
        "es": "Resistance R1",
        "ar": "Resistance R1"
      }
    },
    {
      "id": "r2",
      "label": "Resistance R2",
      "type": "number",
      "unit": "Ω",
      "default": 1000,
      "businessContext": "Resistance of the second resistor (connected to ground).",
      "label_i18n": {
        "en": "Resistance R2",
        "tr": "Resistance R2",
        "de": "Resistance R2",
        "fr": "Resistance R2",
        "es": "Resistance R2",
        "ar": "Resistance R2"
      }
    },
    {
      "id": "tolerance",
      "label": "Resistor Tolerance",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Resistor tolerance in percentage (e.g., ±1%, ±5%). Used to calculate worst-case output voltages.",
      "label_i18n": {
        "en": "Resistor Tolerance",
        "tr": "Resistor Tolerance",
        "de": "Resistor Tolerance",
        "fr": "Resistor Tolerance",
        "es": "Resistor Tolerance",
        "ar": "Resistor Tolerance"
      }
    }
  ],
  "formulas": {
    "vout": "vin * r2 / (r1 + r2)",
    "voutMin": "vin * (r2 * (1 - tolerance / 100)) / (r1 * (1 + tolerance / 100) + r2 * (1 - tolerance / 100))",
    "voutMax": "vin * (r2 * (1 + tolerance / 100)) / (r1 * (1 - tolerance / 100) + r2 * (1 + tolerance / 100))"
  },
  "outputs": {
    "primary": "vout",
    "breakdown": [
      "voutMin",
      "voutMax"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "voutMax"
  },

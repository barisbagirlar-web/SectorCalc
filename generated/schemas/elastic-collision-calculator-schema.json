  "formulas": {
    "v1f": "((m1 - m2) / (m1 + m2)) * v1i + (2 * m2 / (m1 + m2)) * v2i",
    "v2f": "(2 * m1 / (m1 + m2)) * v1i + ((m2 - m1) / (m1 + m2)) * v2i",
    "KE_before": "0.5 * m1 * v1i**2 + 0.5 * m2 * v2i**2",
    "KE_after": "0.5 * m1 * v1f**2 + 0.5 * m2 * v2f**2"
  },

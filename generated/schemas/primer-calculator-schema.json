      "label_i18n": {
        "en": "Price per Container",
        "tr": "Konteyner Başına Fiyat",
        "de": "Preis pro Gebinde",
        "fr": "Prix par contenant",
        "es": "Precio por envase",
        "ar": "سعر الحاوية"
      },
      "businessContext_i18n": {
        "en": "Unit price per container of primer.",
        "tr": "Astar konteyneri başına birim fiyat.",
        "de": "Stückpreis pro Gebinde Grundierung",

{
  "toolName": "primer-calculator",
  "inputs": [
    {
      "id": "surfaceArea",
      "label": "Surface Area",
      "type": "number",
      "unit": "m²",
      "default": 100,
      "businessContext": "Total area to be primed.",
      "label_i18n": {
        "en": "Surface Area",
        "tr": "Surface Area",
        "de": "Surface Area",
        "fr": "Surface Area",
        "es": "Surface Area",
        "ar": "Surface Area"
      }
    },
    {
      "id": "coverageRate",
      "label": "Coverage Rate",
      "type": "number",
      "unit": "m²/L",
      "default": 10,
      "businessContext": "Area covered per liter of primer as per technical data sheet.",
      "label_i18n": {
        "en": "Coverage Rate",
        "tr": "Coverage Rate",
        "de": "Coverage Rate",
        "fr": "Coverage Rate",
        "es": "Coverage Rate",
        "ar": "Coverage Rate"
      }
    },
    {
      "id": "coats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "coats",
      "default": 1,
      "businessContext": "Recommended number of primer coats.",
      "label_i18n": {
        "en": "Number of Coats",
        "tr": "Number of Coats",
        "de": "Number of Coats",
        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional material for wastage, overspray, etc.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "containerSize",
      "label": "Container Size",
      "type": "number",
      "unit": "L",
      "default": 20,
      "businessContext": "Typical container volume for purchase.",
      "label_i18n": {
        "en": "Container Size",
        "tr": "Container Size",
        "de": "Container Size",
        "fr": "Container Size",
        "es": "Container Size",
        "ar": "Container Size"
      }
    },
    {
      "id": "pricePerContainer",
      "label": "Price per Container",
      "type": "number",
      "unit": "currency",
      "default": 100,
      "businessContext": "Unit price per container of primer.",
      "label_i18n": {
        "en": "Price per Container",
        "tr": "Price per Container",
        "de": "Price per Container",
        "fr": "Price per Container",
        "es": "Price per Container",
        "ar": "Price per Container"
      }
    }
  ],
  "formulas": {
    "baseVolume": "surfaceArea * coats / coverageRate",
    "wasteVolume": "baseVolume * wasteFactor / 100",
    "adjustedVolume": "baseVolume + wasteVolume",
    "containersDecimal": "adjustedVolume / containerSize",
    "totalCost": "containersDecimal * pricePerContainer"
  },
  "outputs": {
    "primary": "adjustedVolume",
    "breakdown": [
      "baseVolume",
      "wasteVolume",
      "containersDecimal",
      "totalCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "m²"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,

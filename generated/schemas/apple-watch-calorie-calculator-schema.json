{
  "toolName": "apple-watch-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's weight in kilograms."
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "User's height in centimeters (optional for BMR)."
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years."
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "0 for female, 1 for male."
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 8,
      "businessContext": "Metabolic Equivalent of Task for the activity."
    },
    {
      "id": "durationMinutes",
      "label": "Duration",
      "type": "number",
      "unit": "minutes",
      "default": 30,
      "businessContext": "Duration of the activity in minutes."
    }
  ],
  "formulas": {
    "totalCalories": "(met * weight * 3.5 / 200) * durationMinutes"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [
      "met",
      "weight",
      "durationMinutes"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
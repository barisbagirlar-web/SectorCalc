      "unit": "ksi",
      "default": 30,
      "businessContext": "Material allowable stress at temperature",
      "label_i18n": {
        "en": "Allowable Stress",
        "tr": "İzin Verilen Gerilme",
        "de": "Zulässige Spannung",

  "formulas": {
    "total_pressure_psi": "nominal_pressure_ksi * 1000 * safety_factor * temperature_derating",
    "design_pressure_psi": "total_pressure_psi - ambient_pressure_psi",
    "utilization_ratio": "(design_pressure_psi / 1000) / allowable_stress_ksi"
  },
  "outputs": {

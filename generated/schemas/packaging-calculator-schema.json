    },
    {
      "id": "numberOfItems",
      "label": "Number of Items",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Total number of items to package",
      "label_i18n": {
        "en": "Number of Items",
        "tr": "Öğe Sayısı",
        "de": "Anzahl der Artikel",

    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional material percentage for waste or scrap",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Atık Faktörü",
        "de": "Abfallfaktor",
        "fr": "Facteur de perte",
        "es": "Factor de desperdicio",
        "ar": "عامل الهدر"
      },
      "businessContext_i18n": {
        "en": "Additional material percentage for waste or scrap",
        "tr": "Fire veya hurda için ek malzeme yüzdesi",
        "de": "Zusätzlicher Materialanteil für Ausschuss oder Abfall",
        "fr": "Pourcentage de matériau supplémentaire pour les déchets ou rebuts",
        "es": "Porcentaje adicional de material por desperdicio o merma",
        "ar": "نسبة المواد الإضافية للهدر أو الفاقد"
      }
    }
  ],
  "formulas": {
    "surfaceAreaPerItem": "2 * (productLength * productWidth + productLength * productHeight + productWidth * productHeight)",
    "areaWithWastePerItem": "surfaceAreaPerItem * (1 + wasteFactor / 100)",
    "totalAreaCm2": "areaWithWastePerItem * numberOfItems",
    "totalAreaM2": "totalAreaCm2 / 10000",
    "totalMaterialCost": "totalAreaM2 * materialCostPerSqm"
  },
  "outputs": {
    "primary": "totalMaterialCost",
    "breakdown": [
      "surfaceAreaPerItem",
      "totalAreaM2"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMaterialCost",
    "unit": "cm"
  },

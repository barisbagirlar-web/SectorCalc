{
  "toolName": "packaging-calculator",
  "inputs": [
    {
      "id": "productLength",
      "label": "Product Length",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Length of the product to be packaged",
      "label_i18n": {
        "en": "Product Length",
        "tr": "Product Length",
        "de": "Product Length",
        "fr": "Product Length",
        "es": "Product Length",
        "ar": "Product Length"
      }
    },
    {
      "id": "productWidth",
      "label": "Product Width",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Width of the product",
      "label_i18n": {
        "en": "Product Width",
        "tr": "Product Width",
        "de": "Product Width",
        "fr": "Product Width",
        "es": "Product Width",
        "ar": "Product Width"
      }
    },
    {
      "id": "productHeight",
      "label": "Product Height",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Height of the product",
      "label_i18n": {
        "en": "Product Height",
        "tr": "Product Height",
        "de": "Product Height",
        "fr": "Product Height",
        "es": "Product Height",
        "ar": "Product Height"
      }
    },
    {
      "id": "materialCostPerSqm",
      "label": "Material Cost per m²",
      "type": "number",
      "unit": "EUR/m²",
      "default": 0.5,
      "businessContext": "Cost of packaging material per square meter",
      "label_i18n": {
        "en": "Material Cost per m²",
        "tr": "Material Cost per m²",
        "de": "Material Cost per m²",
        "fr": "Material Cost per m²",
        "es": "Material Cost per m²",
        "ar": "Material Cost per m²"
      }
    },
    {
      "id": "numberOfItems",
      "label": "Number of Items",
      "type": "number",
      "unit": "pcs",
      "default": 100,
      "businessContext": "Total number of items to package",
      "label_i18n": {
        "en": "Number of Items",
        "tr": "Number of Items",
        "de": "Number of Items",
        "fr": "Number of Items",
        "es": "Number of Items",
        "ar": "Number of Items"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Additional material percentage for waste or scrap",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "surfaceAreaPerItem": "2 * (productLength * productWidth + productLength * productHeight + productWidth * productHeight)",
    "areaWithWastePerItem": "surfaceAreaPerItem * (1 + wasteFactor / 100)",
    "totalAreaCm2": "areaWithWastePerItem * numberOfItems",
    "totalAreaM2": "totalAreaCm2 / 10000",
    "totalMaterialCost": "totalAreaM2 * materialCostPerSqm"
  },
  "outputs": {
    "primary": "totalMaterialCost",
    "breakdown": [
      "surfaceAreaPerItem",
      "totalAreaM2"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMaterialCost",
    "unit": "cm"
  },

{
  "toolName": "coffee-caffeine-calculator",
  "inputs": [
    {
      "id": "cupVolumeMl",
      "label": "Cup Volume",
      "type": "number",
      "unit": "ml",
      "default": 240,
      "businessContext": "Volume of one cup in milliliters.",
      "label_i18n": {
        "en": "Cup Volume",

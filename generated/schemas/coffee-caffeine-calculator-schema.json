        "de": "Koffein pro 100 ml",
        "fr": "Caffeine per 100ml",
        "es": "Caffeine per 100ml",
        "ar": "Caffeine per 100ml"
      },
      "businessContext_i18n": {
        "en": "Caffeine content per 100ml for the coffee type (e.g., drip: 40-60, espresso: 212 per 100ml).",
        "tr": "Kahve türü için 100ml başına kafein miktarı (örneğin, filtre: 40-60, espresso: 212/100ml).",
        "de": "Koffeingehalt pro 100 ml für die Kaffeesorte (z. B. Filterkaffee: 40–60, Espresso: 212 pro 100 ml)."
      }
    },
    {
      "id": "numberOfCups",
      "label": "Number of Cups",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total number of cups consumed.",
      "label_i18n": {
        "en": "Number of Cups",
        "tr": "Fincan Sayısı",
        "de": "Anzahl der Tassen",
        "fr": "Number of Cups",
        "es": "Number of Cups",
        "ar": "Number of Cups"
      },
      "businessContext_i18n": {
        "en": "Total number of cups consumed.",
        "tr": "Tüketilen toplam fincan sayısı.",
        "de": "Gesamtzahl der konsumierten Tassen."
      }
    },
    {
      "id": "brewStrengthFactor",
      "label": "Brew Strength Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for brew strength (1 = standard, >1 stronger, <1 weaker).",
      "label_i18n": {
        "en": "Brew Strength Factor",
        "tr": "Demleme Gücü Faktörü",
        "de": "Brühstärke-Faktor",
        "fr": "Brew Strength Factor",
        "es": "Brew Strength Factor",
        "ar": "Brew Strength Factor"
      },
      "businessContext_i18n": {
        "en": "Multiplier for brew strength (1 = standard, >1 stronger, <1 weaker).",
        "tr": "Demleme gücü çarpanı (1 = standart, >1 daha güçlü, <1 daha zayıf).",
        "de": "Multiplikator für die Brühstärke (1 = Standard, >1 stärker, <1 schwächer)."
      }
    },
    {
      "id": "isDecaf",
      "label": "Decaf",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 = regular coffee, 1 = decaf (removes 97% caffeine).",
      "label_i18n": {
        "en": "Decaf",
        "tr": "Kafeinsiz",
        "de": "Entkoffeiniert",
        "fr": "Decaf",
        "es": "Decaf",
        "ar": "Decaf"
      },
      "businessContext_i18n": {
        "en": "0 = regular coffee, 1 = decaf (removes 97% caffeine).",
        "tr": "0 = normal kahve, 1 = kafeinsiz (kafeinin %97'sini giderir).",
        "de": "0 = normaler Kaffee, 1 = entkoffeiniert (entfernt 97 % Koffein)."
      }
    }
  ],
  "formulas": {
    "caffeinePerCupMg": "(cupVolumeMl / 100) * caffeineMgPer100ml * brewStrengthFactor",
    "totalBeforeDecaf": "(cupVolumeMl / 100) * caffeineMgPer100ml * brewStrengthFactor * numberOfCups",
    "decafReductionMg": "(cupVolumeMl / 100) * caffeineMgPer100ml * brewStrengthFactor * numberOfCups * (isDecaf * 0.97)",
    "totalCaffeineMg": "(cupVolumeMl / 100) * caffeineMgPer100ml * brewStrengthFactor * numberOfCups * (1 - isDecaf * 0.97)"
  },
  "outputs": {
    "primary": "totalCaffeineMg",
    "breakdown": [
      "caffeinePerCupMg",
      "decafReductionMg"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCaffeineMg",
    "unit": "ml"
  },

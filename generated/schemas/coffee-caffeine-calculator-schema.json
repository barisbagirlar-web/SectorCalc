        "es": "Cup Volume",
        "ar": "Cup Volume"
      },
      "businessContext_i18n": {
        "en": "Volume of one cup in milliliters.",
        "tr": "Bir fincanın mililitre cinsinden hacmi.",
        "de": "Volumen eines Bechers in Millilitern."
      }
    },
    {
      "id": "caffeineMgPer100ml",
      "label": "Caffeine per 100ml",
      "type": "number",
      "unit": "mg/100ml",
      "default": 40,
      "businessContext": "Caffeine content per 100ml for the coffee type (e.g., drip: 40-60, espresso: 212 per 100ml).",
      "label_i18n": {
        "en": "Caffeine per 100ml",

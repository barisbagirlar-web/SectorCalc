  "formulas": {
    "WasteRate": "(InputFabric - OutputGarments) / InputFabric",
    "PreConsumerWaste": "CuttingScrap + SewingDefects + DyeingRework",
    "FinancialLoss": "PreConsumerWaste * FabricCostPerKg + ProcessingCost",
    "DisposalCost": "WasteWeight * LandfillFee",
    "CircularRevenue": "RecycledWasteWeight * ScrapValue",
    "NetWasteCost": "FinancialLoss + DisposalCost - CircularRevenue",
    "RiskScore": "NetWasteCost / TotalRevenue"
  },

{
  "toolName": "centripetal-force-calculator",
  "inputs": [
    {
      "id": "mass",
      "label": "Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of the rotating object"
    },
    {
      "id": "velocity",
      "label": "Linear Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 10,
      "businessContext": "Linear velocity of the object along the circular path"
    },
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Radius of the circular path"
    },
    {
      "id": "gravitationalAcceleration",
      "label": "Gravitational Acceleration",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Standard gravitational acceleration (g) for g-force calculation"
    }
  ],
  "formulas": {
    "centripetalForce": "mass * velocity ** 2 / radius",
    "angularVelocity": "velocity / radius",
    "centripetalAcceleration": "velocity ** 2 / radius",
    "gForce": "(velocity ** 2 / radius) / gravitationalAcceleration"
  },
  "outputs": {
    "primary": "centripetalForce",
    "breakdown": [
      "angularVelocity",
      "centripetalAcceleration",
      "gForce"
    ]
  },

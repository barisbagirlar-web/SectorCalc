  "formulas": {
    "AEP": "8760 * SUM(PowerCurve_v * Frequency_v)",
    "CapacityFactor": "AEP / (RatedPower * 8760)",
    "AnnualRevenue": "AEP * FeedInTariff",
    "OPEX": "LandLease + Maintenance + Insurance + GridFees",
    "EBITDA": "AnnualRevenue - OPEX",
    "LCOE": "(SUM(Capex + Opex_t / (1+r)^t)) / (SUM(AEP_t / (1+r)^t))",
    "NPV": "SUM(EBITDA_t / (1+WACC)^t) - Capex",
    "IRR": "0.0"
  },

  "formulas": {
    "efficiency": "((supplyTemp - outdoorTemp) / (exhaustTemp - outdoorTemp)) * 100",
    "temperatureGain": "supplyTemp - outdoorTemp",
    "heatRecoveryRate": "(airflow / 3600) * airDensity * specificHeat * (supplyTemp - outdoorTemp)"
  },
  "outputs": {
    "primary": "efficiency",
    "breakdown": [
      "temperatureGain",
      "heatRecoveryRate"
    ],

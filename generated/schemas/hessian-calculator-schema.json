  "formulas": {
    "f_xx": "-a * Math.sin(x)",
    "f_yy": "-b * Math.cos(y)",
    "f_xy": "c",
    "determinant": "f_xx * f_yy - f_xy**2",
    "eigenvalue1": "(f_xx + f_yy)/2 + Math.sqrt(((f_xx - f_yy)/2)**2 + f_xy**2)",
    "eigenvalue2": "(f_xx + f_yy)/2 - Math.sqrt(((f_xx - f_yy)/2)**2 + f_xy**2)"
  },
  "outputs": {
    "primary": "determinant",
    "breakdown": [
      "f_xx",
      "f_yy",
      "f_xy",
      "eigenvalue1",
      "eigenvalue2"
    ]
  },

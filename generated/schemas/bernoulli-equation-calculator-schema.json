  "formulas": {
    "v2": "Math.sqrt(2 * ((P1 - P2) / density + g * (z1 - z2) + v1 * v1 / 2 - g * head_loss))",
    "_P____P________g_____value__m": "(P₁ - P₂) / (ρ·g) = {value} m",
    "z____z_____value__m": "z₁ - z₂ = {value} m",
    "v____2g_____value__m": "v₁²/(2g) = {value} m",
    "_h____P__P_____g_____z__z_____v____2g___": "Δh = (P₁-P₂)/(ρg) + (z₁-z₂) + v₁²/(2g) - hₗ = {value} m",
    "v______2g__h_____value__m_s": "v₂ = √(2g·Δh) = {value} m/s",
    "result": "Hız (v₂)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Basınç enerjisi farkı yüksekliği: (P₁ - P₂) / (ρ·g) = {value} m",
      "Potansiyel enerji farkı: z₁ - z₂ = {value} m",
      "Kinetik enerji yüksekliği (giriş): v₁²/(2g) = {value} m",
      "Toplam enerji farkı (kayıp dahil) yüksekliği: Δh = (P₁-P₂)/(ρg) + (z₁-z₂) + v₁²/(2g) - hₗ = {value} m",
      "v₂ = √(2g·Δh) = {value} m/s"

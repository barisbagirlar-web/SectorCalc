    },
    {
      "id": "percentImpervious",
      "label": "Percent Impervious",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage of impervious area in the catchment",
      "label_i18n": {
        "en": "Percent Impervious",
        "tr": "Percent Impervious",
        "de": "Percent Impervious",
        "fr": "Percent Impervious",
        "es": "Percent Impervious",
        "ar": "Percent Impervious"
      }
    }
  ],
  "formulas": {
    "kirpichTc": "0.01947 * (flowLength ** 0.77) * (slope ** -0.385)",
    "manningTc": "(0.938 / manningN) * (flowLength ** 0.6) * (slope ** -0.3)",
    "scsLag": "(flowLength ** 0.8) * ((1000 / (25.4 * (rainfallIntensity / 1000) * 1000 / 25.4 + 1)) ** 0.7) / (440 * (slope ** 0.5))",
    "weightedTc": "0.5 * kirpichTc + 0.3 * manningTc + 0.2 * scsLag",
    "adjustedTc": "weightedTc * (1 + 0.2 * (percentImpervious / 100))"
  },
  "outputs": {
    "primary": "adjustedTc",
    "breakdown": [
      "Kirpich Tc (min): kirpichTc",
      "Manning Tc (min): manningTc",
      "SCS Lag (min): scsLag",
      "Weighted Tc (min): weightedTc",
      "Adjusted Tc (min): adjustedTc"
    ],
    "hiddenLossDrivers": [],

      "default": 10,
      "businessContext": "Total drainage area contributing to the point of interest",
      "label_i18n": {
        "en": "Catchment Area (A)",
        "tr": "Catchment Area (A)",
        "de": "Catchment Area (A)",
        "fr": "Catchment Area (A)",

{
  "toolName": "adhesive-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the bonding surface in meters.",
      "label_i18n": {
        "en": "Length",
        "tr": "Length",
        "de": "Length",
        "fr": "Length",
        "es": "Length",
        "ar": "Length"
      }
    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Width of the bonding surface in meters.",
      "label_i18n": {
        "en": "Width",
        "tr": "Width",
        "de": "Width",
        "fr": "Width",
        "es": "Width",
        "ar": "Width"
      }
    },
    {
      "id": "coverageRate",
      "label": "Coverage Rate",
      "type": "number",
      "unit": "kg/m²",
      "default": 1.5,
      "businessContext": "Adhesive consumption per square meter in kilograms per square meter.",
      "label_i18n": {
        "en": "Coverage Rate",
        "tr": "Coverage Rate",
        "de": "Coverage Rate",
        "fr": "Coverage Rate",
        "es": "Coverage Rate",
        "ar": "Coverage Rate"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of additional adhesive to account for waste, spillage, and application loss.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "layers",
      "label": "Number of Layers",
      "type": "number",
      "unit": "layers",
      "default": 1,
      "businessContext": "Number of adhesive layers to be applied (e.g., for multi-coat applications).",
      "label_i18n": {
        "en": "Number of Layers",
        "tr": "Number of Layers",
        "de": "Number of Layers",
        "fr": "Number of Layers",
        "es": "Number of Layers",
        "ar": "Number of Layers"
      }
    }
  ],
  "formulas": {
    "area": "length * width",
    "netAdhesive": "area * coverageRate * layers",
    "waste": "netAdhesive * wasteFactor / 100",
    "total": "netAdhesive + waste"
  },
  "outputs": {
    "primary": "total",
    "breakdown": [
      "netAdhesive",
      "waste"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "total",

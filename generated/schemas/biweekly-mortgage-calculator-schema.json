{
  "toolName": "biweekly-mortgage-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Loan Amount",
      "type": "number",
      "unit": "$",
      "default": 250000,
      "businessContext": "Total principal borrowed.",
      "label_i18n": {
        "en": "Loan Amount",
        "tr": "Loan Amount",
        "de": "Loan Amount",
        "fr": "Loan Amount",
        "es": "Loan Amount",
        "ar": "Loan Amount"
      }
    },
    {
      "id": "annualRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 6.5,
      "businessContext": "Annual interest rate as a percentage.",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "termYears",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Original loan term in years.",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    },
    {
      "id": "extraBiweekly",
      "label": "Extra Biweekly Payment",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Additional amount paid each biweekly period beyond the half-monthly equivalent.",
      "label_i18n": {
        "en": "Extra Biweekly Payment",
        "tr": "Extra Biweekly Payment",
        "de": "Extra Biweekly Payment",
        "fr": "Extra Biweekly Payment",
        "es": "Extra Biweekly Payment",
        "ar": "Extra Biweekly Payment"
      }
    }
  ],
  "formulas": {
    "monthlyRate": "annualRate / 100 / 12",
    "numberOfMonths": "termYears * 12",
    "monthlyPayment": "principal * (monthlyRate * Math.pow(1 + monthlyRate, numberOfMonths)) / (Math.pow(1 + monthlyRate, numberOfMonths) - 1)",
    "biweeklyBase": "monthlyPayment / 2",
    "biweeklyPayment": "biweeklyBase + extraBiweekly",
    "r_bw": "Math.pow(1 + annualRate/100, 1/26) - 1",
    "n_bw": "-Math.log(1 - principal * r_bw / biweeklyPayment) / Math.log(1 + r_bw)",
    "payoffYearsBiweekly": "n_bw / 26",
    "totalInterestMonthly": "monthlyPayment * numberOfMonths - principal",
    "totalInterestBiweekly": "biweeklyPayment * n_bw - principal",
    "interestSaved": "totalInterestMonthly - totalInterestBiweekly"
  },
  "outputs": {
    "primary": "interestSaved",
    "breakdown": [
      "monthlyPayment",
      "biweeklyPayment",
      "totalInterestMonthly",
      "totalInterestBiweekly",
      "payoffYearsBiweekly"
    ]
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance"
}

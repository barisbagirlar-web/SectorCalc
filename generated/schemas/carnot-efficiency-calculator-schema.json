        "es": "Net Work Output (kJ)",
        "ar": "Net Work Output (kJ)"
      }
    }
  ],
  "formulas": {
    "carnotEfficiency": "(1 - (coldTemp / hotTemp)) * 100",
    "actualEfficiency": "(workOutput / heatInput) * 100",
    "efficiencyGap": "((1 - (coldTemp / hotTemp)) - (workOutput / heatInput)) * 100"
  },
  "outputs": {
    "primary": "carnotEfficiency",
    "breakdown": [

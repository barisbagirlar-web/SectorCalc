      "id": "workOutput",
      "label": "Net Work Output (kJ)",
      "type": "number",
      "unit": "kJ",
      "default": 400,
      "businessContext": "Net mechanical work produced by the engine",
      "label_i18n": {
        "en": "Net Work Output (kJ)",

{
  "toolName": "leagues-to-miles-calculator",
  "inputs": [
    {
      "id": "leagues",
      "label": "Leagues",
      "type": "number",
      "unit": "lg",
      "default": 1,
      "businessContext": "Distance in leagues to convert",
      "label_i18n": {
        "en": "Leagues",
        "tr": "Leagues",
        "de": "Leagues",
        "fr": "Leagues",
        "es": "Leagues",
        "ar": "Leagues"
      }
    },
    {
      "id": "leagueType",
      "label": "League Type",
      "type": "number",
      "unit": "type",
      "default": 0,
      "businessContext": "0: Statute (3 mi/lg), 1: Nautical (3.452 mi/lg), 2: Metric (2.485 mi/lg)",
      "label_i18n": {
        "en": "League Type",
        "tr": "League Type",
        "de": "League Type",
        "fr": "League Type",
        "es": "League Type",
        "ar": "League Type"
      }
    },
    {
      "id": "decimals",
      "label": "Decimal Places",
      "type": "number",
      "unit": "dp",
      "default": 2,
      "businessContext": "Number of decimal places for rounded output",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "conversionFactorOverride",
      "label": "Custom Factor (0=use type)",
      "type": "number",
      "unit": "mi/lg",
      "default": 0,
      "businessContext": "Override miles per league; if zero, uses league type default",
      "label_i18n": {
        "en": "Custom Factor (0=use type)",
        "tr": "Custom Factor (0=use type)",
        "de": "Custom Factor (0=use type)",
        "fr": "Custom Factor (0=use type)",
        "es": "Custom Factor (0=use type)",
        "ar": "Custom Factor (0=use type)"
      }
    }
  ],
  "formulas": {
    "factor": "conversionFactorOverride > 0 ? conversionFactorOverride : [3, 3.452, 2.485][leagueType]",
    "miles": "leagues * factor",
    "roundedMiles": "Math.round(miles * Math.pow(10, decimals)) / Math.pow(10, decimals)",
    "__factor___mi_lg": "{{factor}} mi/lg",
    "__miles___mi": "{{miles}} mi",
    "Rounded_to___decimals___decimal_places": "Rounded to {{decimals}} decimal places"
  },
  "outputs": {
    "primary": "factor",
    "breakdown": [
      "Factor used: {{factor}} mi/lg",
      "Raw value: {{miles}} mi",
      "Rounded to {{decimals}} decimal places"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

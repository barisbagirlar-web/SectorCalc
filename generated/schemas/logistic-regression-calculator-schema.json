{
  "toolName": "logistic-regression-calculator",
  "inputs": [
    {
      "id": "intercept",
      "label": "Kesme Terimi (b0)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Tüm tahmin değişkenleri sıfır olduğunda log-odds değeri."
    },
    {
      "id": "coef1",
      "label": "Katsayı 1 (b1)",
      "type": "number",

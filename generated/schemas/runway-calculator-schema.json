{
  "toolName": "runway-calculator",
  "inputs": [
    {
      "id": "cash_balance",
      "label": "Current Cash Balance",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Total liquid cash on hand.",
      "label_i18n": {
        "en": "Current Cash Balance",
        "tr": "Mevcut Nakit Bakiyesi",
        "de": "Current Cash Balance",
        "fr": "Current Cash Balance",
        "es": "Current Cash Balance",
        "ar": "Current Cash Balance"
      },
      "businessContext_i18n": {
        "en": "Total liquid cash on hand.",
        "tr": "Eldeki toplam likit nakit."
      }
    },
    {
      "id": "monthly_expenses",
      "label": "Monthly Expenses",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "businessContext": "Total monthly cash outflows (operational costs, rent, salaries).",
      "label_i18n": {
        "en": "Monthly Expenses",
        "tr": "Aylık Giderler",
        "de": "Monatliche Ausgaben",
        "fr": "Monthly Expenses",
        "es": "Monthly Expenses",
        "ar": "Monthly Expenses"
      },
      "businessContext_i18n": {
        "en": "Total monthly cash outflows (operational costs, rent, salaries).",
        "tr": "Toplam aylık nakit çıkışları (operasyonel maliyetler, kira, maaşlar)."
      }
    },
    {
      "id": "monthly_revenue",
      "label": "Monthly Revenue",
      "type": "number",
      "unit": "USD",
      "default": 5000,
      "businessContext": "Total monthly cash inflows from sales or other income.",
      "label_i18n": {
        "en": "Monthly Revenue",
        "tr": "Aylık Gelir",
        "de": "Monthly Revenue",
        "fr": "Monthly Revenue",
        "es": "Monthly Revenue",
        "ar": "Monthly Revenue"
      },
      "businessContext_i18n": {
        "en": "Total monthly cash inflows from sales or other income.",
        "tr": "Satışlardan veya diğer gelirlerden elde edilen toplam aylık nakit girişleri."
      }
    },
    {
      "id": "buffer_percent",
      "label": "Cash Buffer (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of cash reserved as a safety buffer, not used in runway calculation.",
      "label_i18n": {
        "en": "Cash Buffer (%)",
        "tr": "Nakit Tamponu (%)",
        "de": "Cash Buffer (%)",
        "fr": "Cash Buffer (%)",
        "es": "Cash Buffer (%)",
        "ar": "Cash Buffer (%)"
      },
      "businessContext_i18n": {
        "en": "Percentage of cash reserved as a safety buffer, not used in runway calculation.",
        "tr": "Nakit rezerv olarak ayrılan yüzde, nakit akışı hesaplamasında kullanılmaz."
      }
    }
  ],
  "formulas": {
    "net_monthly_burn": "monthly_expenses - monthly_revenue",
    "effective_cash": "cash_balance * (1 - buffer_percent / 100)",
    "runway_months": "net_monthly_burn > 0 ? effective_cash / net_monthly_burn : Infinity"
  },
  "outputs": {
    "primary": "runway_months",
    "breakdown": [
      "net_monthly_burn",
      "effective_cash",
      "runway_months"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "runway_months",
    "unit": "USD"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

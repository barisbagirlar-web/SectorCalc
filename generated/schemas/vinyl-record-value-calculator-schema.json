{
  "toolName": "vinyl-record-value-calculator",
  "inputs": [
    {
      "id": "basePrice",
      "label": "Base Price (€)",
      "type": "number",
      "unit": "€",
      "default": 20,
      "businessContext": "The typical market price for a common, good-condition record of similar genre."
    },
    {
      "id": "conditionScore",
      "label": "Condition (1-10)",
      "type": "number",
      "unit": "pts",
      "default": 7,
      "businessContext": "Goldmine grading: 1=Poor, 10=Mint/Sealed"
    },
    {
      "id": "rarityScore",
      "label": "Rarity (1-10)",
      "type": "number",
      "unit": "pts",
      "default": 5,
      "businessContext": "Scarcity rating: 1=Mass-produced, 10=Only a handful known"
    },
    {
      "id": "popularityScore",
      "label": "Artist Popularity (1-10)",
      "type": "number",
      "unit": "pts",
      "default": 5,
      "businessContext": "Current market demand for the artist: 1=No interest, 10=Cult following"
    },
    {
      "id": "ageYears",
      "label": "Record Age (years)",
      "type": "number",
      "unit": "yr",
      "default": 10,
      "businessContext": "Years since the record's first pressing"
    }
  ],
  "formulas": {
    "conditionMultiplier": "conditionScore / 10",
    "rarityMultiplier": "1 + rarityScore / 10",
    "popularityMultiplier": "popularityScore / 5",
    "ageMultiplier": "1 + ageYears / 50",
    "totalValue": "basePrice * conditionMultiplier * rarityMultiplier * popularityMultiplier * ageMultiplier"
  },
  "outputs": {
    "primary": "totalValue",
    "breakdown": [
      "conditionMultiplier",
      "rarityMultiplier",
      "popularityMultiplier",
      "ageMultiplier"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "madencilik",
  "profession": "Maden Mühendisi",
  "categoryId": "cost"
}

    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Value Added Tax percentage",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "Mehrwertsteuersatz",
        "fr": "Taux de TVA",
        "es": "Tasa de IVA",
        "ar": "نسبة ضريبة القيمة المضافة"
      },
      "businessContext_i18n": {
        "en": "Value Added Tax percentage",
        "tr": "Katma Değer Vergisi yüzdesi",
        "de": "Mehrwertsteuerprozentsatz",
        "fr": "Pourcentage de taxe sur la valeur ajoutée",
        "es": "Porcentaje de IVA",
        "ar": "نسبة ضريبة القيمة المضافة"
      }
    }
  ],
  "formulas": {
    "unitPriceAfterPercentage": "originalPrice * (1 - markdownPercentage/100)",
    "unitPriceAfterFixed": "unitPriceAfterPercentage - fixedDiscount",
    "totalExclVat": "unitPriceAfterFixed * quantity",
    "vatAmount": "totalExclVat * vatRate/100",
    "totalInclVat": "totalExclVat + vatAmount",
    "totalSavings": "(originalPrice * quantity) - totalExclVat"
  },
  "outputs": {
    "primary": "totalInclVat",
    "breakdown": [
      "unitPriceAfterPercentage",
      "unitPriceAfterFixed",
      "totalExclVat",
      "vatAmount",
      "totalSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

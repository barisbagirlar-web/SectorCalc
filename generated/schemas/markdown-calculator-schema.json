      },
      "businessContext_i18n": {
        "en": "List price before any discount",
        "tr": "Herhangi bir indirim öncesi liste fiyatı"
      }
    },
    {
      "id": "markdownPercentage",
      "label": "Markdown Percentage",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Discount percentage applied to original price",
      "label_i18n": {
        "en": "Markdown Percentage",
        "tr": "İndirim Yüzdesi",
        "de": "Markdown Percentage",
        "fr": "Markdown Percentage",
        "es": "Markdown Percentage",
        "ar": "Markdown Percentage"
      },
      "businessContext_i18n": {
        "en": "Discount percentage applied to original price",
        "tr": "Orijinal fiyata uygulanan indirim yüzdesi"
      }
    },
    {
      "id": "fixedDiscount",
      "label": "Fixed Discount per Unit",
      "type": "number",
      "unit": "EUR",
      "default": 5,
      "businessContext": "Fixed amount off after percentage discount",
      "label_i18n": {
        "en": "Fixed Discount per Unit",
        "tr": "Birim Başına Sabit İndirim",
        "de": "Fixed Discount per Unit",
        "fr": "Fixed Discount per Unit",
        "es": "Fixed Discount per Unit",
        "ar": "Fixed Discount per Unit"
      },
      "businessContext_i18n": {
        "en": "Fixed amount off after percentage discount",
        "tr": "Yüzde indirimden sonra sabit tutar"
      }
    },
    {
      "id": "quantity",
      "label": "Quantity",
      "type": "number",
      "unit": "pcs",
      "default": 10,
      "businessContext": "Number of items purchased",
      "label_i18n": {
        "en": "Quantity",
        "tr": "Miktar",
        "de": "Quantity",
        "fr": "Quantity",
        "es": "Quantity",
        "ar": "Quantity"
      },
      "businessContext_i18n": {
        "en": "Number of items purchased",
        "tr": "Satın alınan ürün sayısı"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Value Added Tax percentage",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "VAT Rate",
        "fr": "VAT Rate",
        "es": "VAT Rate",
        "ar": "VAT Rate"
      },
      "businessContext_i18n": {
        "en": "Value Added Tax percentage",
        "tr": "Katma Değer Vergisi yüzdesi"
      }
    }
  ],
  "formulas": {
    "unitPriceAfterPercentage": "originalPrice * (1 - markdownPercentage/100)",
    "unitPriceAfterFixed": "unitPriceAfterPercentage - fixedDiscount",
    "totalExclVat": "unitPriceAfterFixed * quantity",
    "vatAmount": "totalExclVat * vatRate/100",
    "totalInclVat": "totalExclVat + vatAmount",
    "totalSavings": "(originalPrice * quantity) - totalExclVat"
  },
  "outputs": {
    "primary": "totalInclVat",
    "breakdown": [
      "unitPriceAfterPercentage",
      "unitPriceAfterFixed",
      "totalExclVat",
      "vatAmount",
      "totalSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

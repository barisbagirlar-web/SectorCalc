      }
    },
    {
      "id": "deficitPercent",
      "label": "Calorie Deficit",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Percentage calorie deficit from TDEE for weight loss (typically 10-20%)",
      "label_i18n": {
        "en": "Calorie Deficit",
        "tr": "Calorie Deficit",
        "de": "Calorie Deficit",
        "fr": "Calorie Deficit",
        "es": "Calorie Deficit",
        "ar": "Calorie Deficit"
      }
    }
  ],
  "formulas": {
    "bmr": "sex ? (10 * weight + 6.25 * height - 5 * age + 5) : (10 * weight + 6.25 * height - 5 * age - 161)",
    "tdee": "bmr * activityFactor",
    "deficit": "tdee * (deficitPercent / 100)",
    "dailyCalorieBudget": "tdee - deficit"
  },
  "outputs": {
    "primary": "dailyCalorieBudget",
    "breakdown": [

  "formulas": {
    "travelTimeHours": "distance / speed",
    "totalStopTimeMinutes": "stopCount * stopDuration",
    "totalStopTimeHours": "totalStopTimeMinutes / 60",
    "totalTimeHours": "travelTimeHours + totalStopTimeHours",
    "fuelLitres": "(distance / 100) * fuelConsumption",
    "fuelCostTotal": "fuelLitres * fuelCost",
    "driverCost": "(totalTimeHours / 24) * driverWage",
    "totalCost": "fuelCostTotal + tollCost + driverCost"
  },
  "outputs": {
    "primary": "travelTimeHours",

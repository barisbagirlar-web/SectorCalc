{
  "toolName": "pathfinder-calculator",
  "inputs": [
    {
      "id": "distance",
      "label": "Mesafe (km)",
      "type": "number",
      "unit": "km",
      "default": 100,
      "businessContext": "Kat edilecek toplam mesafe"
    },
    {
      "id": "speed",
      "label": "Ortalama Hız (km/sa)",
      "type": "number",
      "unit": "km/h",
      "default": 80,
      "businessContext": "Seyir hızı"
    },
    {
      "id": "fuelConsumption",
      "label": "Yakıt Tüketimi (L/100km)",
      "type": "number",
      "unit": "L/100km",
      "default": 30,
      "businessContext": "Aracın 100 km'de tükettiği yakıt"
    },
    {
      "id": "fuelCost",
      "label": "Yakıt Birim Fiyatı (TL/L)",
      "type": "number",
      "unit": "TL/L",
      "default": 25,
      "businessContext": "Yakıtın litre fiyatı"
    },
    {
      "id": "stopCount",
      "label": "Mola Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 2,
      "businessContext": "Yolculuk sırasında verilen mola sayısı"
    },
    {
      "id": "stopDuration",
      "label": "Mola Süresi (dk)",
      "type": "number",
      "unit": "dk",
      "default": 30,
      "businessContext": "Her mola için harcanan süre"
    },
    {
      "id": "tollCost",
      "label": "Geçiş Ücreti (TL)",
      "type": "number",
      "unit": "TL",
      "default": 50,
      "businessContext": "Otoyol/geçiş ücretleri toplamı"
    },
    {
      "id": "driverWage",
      "label": "Sürücü Yevmiyesi (TL/gün)",
      "type": "number",
      "unit": "TL/gün",
      "default": 500,
      "businessContext": "Sürücünün günlük maliyeti"
    }
  ],
  "formulas": {
    "travelTimeHours": "distance / speed",
    "totalStopTimeMinutes": "stopCount * stopDuration",
    "totalStopTimeHours": "totalStopTimeMinutes / 60",
    "totalTimeHours": "travelTimeHours + totalStopTimeHours",
    "fuelLitres": "(distance / 100) * fuelConsumption",
    "fuelCostTotal": "fuelLitres * fuelCost",
    "driverCost": "(totalTimeHours / 24) * driverWage",
    "totalCost": "fuelCostTotal + tollCost + driverCost"
  },
  "outputs": {
    "primary": "Toplam Maliyet: {totalCost} TL",
    "breakdown": [
      "Yakıt Maliyeti: {fuelCostTotal} TL",
      "Geçiş Ücreti: {tollCost} TL",
      "Sürücü Maliyeti: {driverCost} TL",
      "Toplam Süre: {totalTimeHours} saat"
    ]
  },
  "category": "Rota & Lojistik",
  "sector": "Lojistik & Sevkiyat",
  "premiumRequired": false,
  "catalogCategory": "gaming-entertainment",
  "sectorSlug": "ecommerce",
  "categorySlug": "packaging-local-business"
}

{
  "toolName": "free-cash-flow-calculator",
  "inputs": [
    {
      "id": "ebit",
      "label": "EBIT (Earnings Before Interest and Taxes)",
      "type": "number",
      "unit": "currency",
      "default": 1000000,
      "businessContext": "The company's operating profit before interest and tax expenses.",
      "label_i18n": {
        "en": "EBIT (Earnings Before Interest and Taxes)",
        "tr": "EBIT (Earnings Before Interest and Taxes)",
        "de": "EBIT (Earnings Before Interest and Taxes)",
        "fr": "EBIT (Earnings Before Interest and Taxes)",
        "es": "EBIT (Earnings Before Interest and Taxes)",
        "ar": "EBIT (Earnings Before Interest and Taxes)"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Effective corporate tax rate as a percentage (e.g., 30 for 30%).",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "depreciation",
      "label": "Depreciation & Amortization",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "Non-cash expenses from depreciation and amortization of assets.",
      "label_i18n": {
        "en": "Depreciation & Amortization",
        "tr": "Depreciation & Amortization",
        "de": "Depreciation & Amortization",
        "fr": "Depreciation & Amortization",
        "es": "Depreciation & Amortization",
        "ar": "Depreciation & Amortization"
      }
    },
    {
      "id": "capex",
      "label": "Capital Expenditures",
      "type": "number",
      "unit": "currency",
      "default": 200000,
      "businessContext": "Cash spent on acquiring or maintaining fixed assets (CapEx).",
      "label_i18n": {
        "en": "Capital Expenditures",
        "tr": "Capital Expenditures",
        "de": "Capital Expenditures",
        "fr": "Capital Expenditures",
        "es": "Capital Expenditures",
        "ar": "Capital Expenditures"
      }
    },
    {
      "id": "changeNWC",
      "label": "Change in Net Working Capital",
      "type": "number",
      "unit": "currency",
      "default": 50000,
      "businessContext": "Increase in net working capital (current assets minus current liabilities) that consumes cash.",
      "label_i18n": {
        "en": "Change in Net Working Capital",
        "tr": "Change in Net Working Capital",
        "de": "Change in Net Working Capital",
        "fr": "Change in Net Working Capital",
        "es": "Change in Net Working Capital",
        "ar": "Change in Net Working Capital"
      }
    }
  ],
  "formulas": {
    "freeCashFlow": "ebit * (1 - taxRate / 100) + depreciation - changeNWC - capex",
    "operatingCashFlow": "ebit * (1 - taxRate / 100) + depreciation",
    "capitalInvestments": "capex + changeNWC"
  },
  "outputs": {
    "primary": "freeCashFlow",
    "breakdown": [
      "operatingCashFlow",
      "capitalInvestments"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "capitalInvestments"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "earth-overshoot-day-calculator",
  "inputs": [
    {
      "id": "globalPopulation",
      "label": "World Population",
      "type": "number",
      "unit": "billion people",
      "default": 7.9,
      "businessContext": "Total global population in billions",
      "label_i18n": {
        "en": "World Population",
        "tr": "World Population",
        "de": "World Population",
        "fr": "World Population",
        "es": "World Population",
        "ar": "World Population"
      }
    },
    {
      "id": "perCapitaBiocapacity",
      "label": "Biocapacity per capita",
      "type": "number",
      "unit": "gha/person",
      "default": 1.6,
      "businessContext": "Average global biocapacity availability per person in global hectares",
      "label_i18n": {
        "en": "Biocapacity per capita",
        "tr": "Biocapacity per capita",
        "de": "Biocapacity per capita",
        "fr": "Biocapacity per capita",
        "es": "Biocapacity per capita",
        "ar": "Biocapacity per capita"
      }
    },
    {
      "id": "perCapitaFootprint",
      "label": "Ecological Footprint per capita",
      "type": "number",
      "unit": "gha/person",
      "default": 2.7,
      "businessContext": "Average global ecological footprint per person in global hectares",
      "label_i18n": {
        "en": "Ecological Footprint per capita",
        "tr": "Ecological Footprint per capita",
        "de": "Ecological Footprint per capita",
        "fr": "Ecological Footprint per capita",
        "es": "Ecological Footprint per capita",
        "ar": "Ecological Footprint per capita"
      }
    },
    {
      "id": "year",
      "label": "Calculation Year",
      "type": "number",
      "unit": "year",
      "default": 2025,
      "businessContext": "Year for which Earth Overshoot Day is calculated (used for date context)",
      "label_i18n": {
        "en": "Calculation Year",
        "tr": "Calculation Year",
        "de": "Calculation Year",
        "fr": "Calculation Year",
        "es": "Calculation Year",
        "ar": "Calculation Year"
      }
    }
  ],
  "formulas": {
    "totalBiocapacity": "globalPopulation * perCapitaBiocapacity",
    "totalFootprint": "globalPopulation * perCapitaFootprint",
    "excessEarths": "totalFootprint / totalBiocapacity",
    "overshootDayFloat": "(totalBiocapacity / totalFootprint) * 365"
  },
  "outputs": {
    "primary": "overshootDayFloat",
    "breakdown": [
      "Earth Overshoot Day falls on day ${overshootDay} of the year.",
      "Humanity uses the equivalent of ${excessEarths} Earths."
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "overshootDay",
    "unit": "billion people"
  },

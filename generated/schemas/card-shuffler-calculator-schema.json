  "formulas": {
    "effectiveMinutes": "(operatingHours - maintenanceHours) * 60",
    "totalCardsPerDay": "machineSpeed * effectiveMinutes",
    "packsPerDay": "totalCardsPerDay / (cardsPerDeck * shuffleCycles)",
    "energyConsumption": "powerRating * (operatingHours - maintenanceHours)",
    "energyCostPerDay": "energyConsumption * electricityCost",
    "laborCostPerDay": "laborCost * operatingHours",
    "totalDailyCost": "energyCostPerDay + laborCostPerDay",
    "costPerPack": "totalDailyCost / packsPerDay",
    "machineUtilization": "((operatingHours - maintenanceHours) / operatingHours) * 100"
  },
  "outputs": {
    "primary": "packsPerDay",
    "breakdown": [
      "costPerPack",
      "machineUtilization"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "machineUtilization",
    "unit": "cards",
    "breakdownUnits": {
      "machineUtilization": "%"
    }
  },

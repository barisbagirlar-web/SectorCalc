      }
    },
    {
      "id": "wastePercent",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional waste or overage percentage (0-100)",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Fire Yüzdesi",
        "de": "Abfallprozentsatz",
        "fr": "Waste Percentage",
        "es": "Waste Percentage",
        "ar": "Waste Percentage"
      },
      "businessContext_i18n": {
        "en": "Additional waste or overage percentage (0-100)",
        "tr": "Ek atık veya fazlalık yüzdesi (0-100)"
      }
    }
  ],
  "formulas": {
    "totalParts": "ratioA + ratioB",
    "effectiveTotal": "totalQuantity * (1 + wastePercent / 100)",
    "amountA": "effectiveTotal * ratioA / totalParts",
    "amountB": "effectiveTotal * ratioB / totalParts"
  },
  "outputs": {
    "primary": "amountA",
    "breakdown": [
      "amountA",
      "amountB"
    ],

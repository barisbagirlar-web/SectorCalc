{
  "toolName": "mixing-ratio-calculator",
  "inputs": [
    {
      "id": "ratioA",
      "label": "Part A",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Parts of component A in the mixing ratio",
      "label_i18n": {
        "en": "Part A",
        "tr": "Part A",
        "de": "Part A",
        "fr": "Part A",
        "es": "Part A",
        "ar": "Part A"
      }
    },
    {
      "id": "ratioB",
      "label": "Part B",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Parts of component B in the mixing ratio",
      "label_i18n": {
        "en": "Part B",
        "tr": "Part B",
        "de": "Part B",
        "fr": "Part B",
        "es": "Part B",
        "ar": "Part B"
      }
    },
    {
      "id": "totalQuantity",
      "label": "Total Mixture Quantity",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Desired total quantity of the mixture (e.g., in kg or L)",
      "label_i18n": {
        "en": "Total Mixture Quantity",
        "tr": "Total Mixture Quantity",
        "de": "Total Mixture Quantity",
        "fr": "Total Mixture Quantity",
        "es": "Total Mixture Quantity",
        "ar": "Total Mixture Quantity"
      }
    },
    {
      "id": "wastePercent",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional waste or overage percentage (0-100)",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Waste Percentage",
        "de": "Waste Percentage",
        "fr": "Waste Percentage",
        "es": "Waste Percentage",
        "ar": "Waste Percentage"
      }
    }
  ],
  "formulas": {
    "totalParts": "ratioA + ratioB",
    "effectiveTotal": "totalQuantity * (1 + wastePercent / 100)",
    "amountA": "effectiveTotal * ratioA / totalParts",
    "amountB": "effectiveTotal * ratioB / totalParts"
  },
  "outputs": {
    "primary": "amountA",
    "breakdown": [
      "amountA",
      "amountB"
    ]
  },

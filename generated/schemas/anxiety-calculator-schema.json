{
  "toolName": "anxiety-calculator",
  "inputs": [
    {
      "id": "measurement_variance",
      "label": "Measurement Variance (σ²)",
      "type": "number",
      "unit": "unit²",
      "default": 0.1,
      "businessContext": "Gauge R&R study result"
    },
    {
      "id": "operator_error_rate",
      "label": "Operator Error Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Defect logs analysis"
    },
    {
      "id": "machine_downtime",
      "label": "Machine Downtime Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.05,
      "businessContext": "OEE tracking database"
    },
    {
      "id": "defect_rate",
      "label": "Historical Defect Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 1.5,
      "businessContext": "Production records"
    },
    {
      "id": "process_temperature_variance",
      "label": "Temperature Fluctuation (σ)",
      "type": "number",
      "unit": "°C",
      "default": 2.1,
      "businessContext": "Process logs"
    },
    {
      "id": "noise_level",
      "label": "Noise Level (dB)",
      "type": "number",
      "unit": "dB",
      "default": 75,
      "businessContext": "Workplace safety measurements"
    }
  ],
  "formulas": {
    "human_factor": "0.2 * Math.log(operator_error_rate + 1)",
    "machine_factor": "0.3 * machine_downtime * 100",
    "measurement_factor": "0.25 * Math.sqrt(measurement_variance)",
    "environmental_factor": "0.15 * process_temperature_variance + 0.1 * Math.max(0, (noise_level - 70) / 10)",
    "anxiety_index": "(0.2 * Math.log(operator_error_rate + 1)) + (0.3 * machine_downtime * 100) + (0.25 * Math.sqrt(measurement_variance)) + (0.15 * process_temperature_variance) + (0.1 * Math.max(0, (noise_level - 70) / 10))"
  },
  "outputs": {
    "primary": "anxiety_index",
    "breakdown": [
      "human_factor",
      "machine_factor",
      "measurement_factor",
      "environmental_factor"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

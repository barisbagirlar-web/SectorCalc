  "formulas": {
    "human_factor": "0.2 * Math.log(operator_error_rate + 1)",
    "machine_factor": "0.3 * machine_downtime * 100",
    "measurement_factor": "0.25 * Math.sqrt(measurement_variance)",
    "environmental_factor": "0.15 * process_temperature_variance + 0.1 * Math.max(0, (noise_level - 70) / 10)",
    "anxiety_index": "(0.2 * Math.log(operator_error_rate + 1)) + (0.3 * machine_downtime * 100) + (0.25 * Math.sqrt(measurement_variance)) + (0.15 * process_temperature_variance) + (0.1 * Math.max(0, (noise_level - 70) / 10))"
  },
  "outputs": {
    "primary": "anxiety_index",
    "breakdown": [
      "human_factor",
      "machine_factor",
      "measurement_factor",
      "environmental_factor"
    ]
  },

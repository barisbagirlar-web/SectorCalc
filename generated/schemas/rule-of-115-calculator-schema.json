{
  "toolName": "rule-of-115-calculator",
  "inputs": [
    {
      "id": "interestRate",
      "label": "Yıllık Faiz Oranı (%)",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Yatırımın yıllık nominal getiri oranı."
    },
    {
      "id": "taxRate",
      "label": "Vergi Oranı (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Getiri üzerinden alınan vergi oranı (0 ise vergi yok)."
    },
    {
      "id": "compoundingFrequency",
      "label": "Bileşik Dönemi (yıl başına)",
      "type": "number",
      "unit": "dönem/yıl",
      "default": 1,
      "businessContext": "Faizin yılda kaç kez bileşiklendiği (ör. aylık için 12)."
    },
    {
      "id": "principal",
      "label": "Başlangıç Anapara",
      "type": "number",
      "unit": "TL",
      "default": 1000,
      "businessContext": "Opsiyonel: 3 katına çıkacak başlangıç tutarı."
    }
  ],
  "formulas": {
    "yearsRule115": "115 / (interestRate * (1 - taxRate/100))",
    "yearsExact": "Math.log(3) / (compoundingFrequency * Math.log(1 + (interestRate*(1-taxRate/100)/100) / compoundingFrequency))",
    "targetAmount": "principal * 3"
  },
  "outputs": {
    "primary": "yearsRule115",
    "breakdown": [
      "yearsExact",
      "targetAmount"
    ]
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital"
}

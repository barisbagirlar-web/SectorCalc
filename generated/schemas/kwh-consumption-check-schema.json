{
  "toolName": "kwh-consumption-check",
  "inputs": [
    {
      "id": "powerRating",
      "label": "Power Rating",
      "type": "number",
      "unit": "kW",
      "default": 0,
      "min": 0,
      "max": 100000,
      "options": null,
      "businessContext": "Nominal power rating of the equipment. Based on ISO 50001 energy management standards."
    },
    {
      "id": "operatingHours",
      "label": "Operating Hours",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "min": 0,
      "max": 8760,
      "options": null,
      "businessContext": "Total operating hours per year. Typical for annual energy consumption calculations."
    },
    {
      "id": "loadFactor",
      "label": "Load Factor",
      "type": "number",
      "unit": "%",
      "default": 100,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Average load as percentage of rated power. Industry standard for energy audits."
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Motor or system efficiency. Based on NEMA MG1 and IEC 60034 standards."
    },
    {
      "id": "energyCost",
      "label": "Energy Cost",
      "type": "number",
      "unit": "$/kWh",
      "default": 0.12,
      "min": 0,
      "max": 1,
      "options": null,
      "businessContext": "Average electricity cost per kWh. Typical US industrial rate."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence",
      "type": "select",
      "unit": "",
      "default": "medium",
      "min": null,
      "max": null,
      "options": [
        "low",
        "medium",
        "high"
      ],
      "businessContext": "Confidence level of input data. Affects adjustment factor for results."
    }
  ],
  "validation": {
    "rules": [
      "powerRating >= 0",
      "operatingHours >= 0 and operatingHours <= 8760",
      "loadFactor >= 0 and loadFactor <= 100",
      "efficiency >= 0 and efficiency <= 100",
      "energyCost >= 0"
    ],
    "thresholds": {
      "annualConsumption": "if annualConsumption > 1000000 then 'High consumption'",
      "efficiency": "if efficiency < 80 then 'Low efficiency'"
    }
  },
  "formulas": {
    "annualConsumption": "powerRating * operatingHours * (loadFactor / 100) * (100 / efficiency)",
    "annualCost": "annualConsumption * energyCost",
    "dataConfidenceAdjusted": "annualCost * (dataConfidence == 'low' ? 1.2 : (dataConfidence == 'medium' ? 1.0 : 0.9))"
  },
  "outputs": {
    "primary": "annualCost",
    "breakdown": {
      "annualConsumption": "annualConsumption",
      "annualCost": "annualCost"
    },
    "hiddenLossDrivers": [
      "if efficiency < 80 then 'Low efficiency'",
      "if loadFactor < 50 then 'Low load factor'"
    ],
    "suggestedActions": [
      "if efficiency < 80 then 'Consider motor replacement or maintenance'",
      "if loadFactor < 50 then 'Evaluate downsizing or variable speed drives'"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Benchmark comparison",
    "Detailed report"
  ],
  "premiumRequired": true
}

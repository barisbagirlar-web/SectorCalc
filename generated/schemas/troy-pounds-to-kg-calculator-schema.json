{
  "toolName": "troy-pounds-to-kg-calculator",
  "inputs": [
    {
      "id": "troyPounds",
      "label": "Troy Pound Amount",
      "type": "number",
      "unit": "troy lb",
      "default": 1,
      "businessContext": "Weight in troy pounds to be converted to kilograms",
      "label_i18n": {

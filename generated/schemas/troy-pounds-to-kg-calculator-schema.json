      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "places",
      "default": 4,
      "businessContext": "Number of decimal places for rounded outputs",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "batchSize",
      "label": "Batch Size",
      "type": "number",
      "unit": "items",
      "default": 1,
      "businessContext": "Number of identical items to calculate total weight for",
      "label_i18n": {
        "en": "Batch Size",
        "tr": "Batch Size",
        "de": "Batch Size",
        "fr": "Batch Size",
        "es": "Batch Size",
        "ar": "Batch Size"
      }
    },
    {
      "id": "scaleCalibrationFactor",
      "label": "Calibration Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Multiplicative calibration correction factor for the weighing scale",
      "label_i18n": {
        "en": "Calibration Factor",
        "tr": "Calibration Factor",
        "de": "Calibration Factor",
        "fr": "Calibration Factor",
        "es": "Calibration Factor",
        "ar": "Calibration Factor"
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty (±%)",
      "type": "number",
      "unit": "%",
      "default": 0.1,
      "businessContext": "Relative measurement uncertainty percentage for conformance bounds",
      "label_i18n": {
        "en": "Measurement Uncertainty (±%)",
        "tr": "Measurement Uncertainty (±%)",
        "de": "Measurement Uncertainty (±%)",
        "fr": "Measurement Uncertainty (±%)",
        "es": "Measurement Uncertainty (±%)",
        "ar": "Measurement Uncertainty (±%)"
      }
    }
  ],
  "formulas": {
    "rawKg": "troyPounds * 0.3732417216 * scaleCalibrationFactor * batchSize",
    "lower": "rawKg * (1 - measurementUncertainty / 100)",
    "upper": "rawKg * (1 + measurementUncertainty / 100)"
  },
  "outputs": {
    "primary": "upper",
    "breakdown": [
      "lowerRounded",
      "upperRounded",
      "rawKg",
      "conversionInfo"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "upperRounded"
  },

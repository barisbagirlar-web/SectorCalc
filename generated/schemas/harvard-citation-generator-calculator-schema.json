        "tr": "Hourly Rate",
        "de": "Hourly Rate",
        "fr": "Hourly Rate",
        "es": "Hourly Rate",
        "ar": "Hourly Rate"
      }
    },
    {
      "id": "overheadPercentage",
      "label": "Overhead %",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Overhead cost as percentage of direct costs",
      "label_i18n": {
        "en": "Overhead %",
        "tr": "Overhead %",
        "de": "Overhead %",
        "fr": "Overhead %",
        "es": "Overhead %",
        "ar": "Overhead %"
      }
    },
    {
      "id": "profitMarginPercentage",
      "label": "Profit Margin %",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Desired profit margin percentage",
      "label_i18n": {
        "en": "Profit Margin %",
        "tr": "Profit Margin %",
        "de": "Profit Margin %",
        "fr": "Profit Margin %",
        "es": "Profit Margin %",
        "ar": "Profit Margin %"
      }
    }
  ],
  "formulas": {
    "laborCost": "laborHours * hourlyRate",
    "directCost": "materialCost + laborCost",
    "overheadCost": "directCost * overheadPercentage / 100",
    "totalCost": "directCost + overheadCost",
    "sellingPrice": "totalCost * (1 + profitMarginPercentage / 100)"
  },
  "outputs": {
    "primary": "sellingPrice",
    "breakdown": [
      "materialCost",
      "laborCost",
      "overheadCost",
      "totalCost"
    ],

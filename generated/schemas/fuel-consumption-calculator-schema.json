{
  "toolName": "fuel-consumption-calculator",
  "inputs": [
    {
      "id": "distance",
      "label": "Distance Traveled",
      "type": "number",
      "unit": "km",
      "default": 100,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total distance traveled by the vehicle. Based on standard odometer readings."
    },
    {
      "id": "fuelUsed",
      "label": "Fuel Used",
      "type": "number",
      "unit": "L",
      "default": 10,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Volume of fuel consumed during the trip. Measured at pump."
    },
    {
      "id": "fuelType",
      "label": "Fuel Type",
      "type": "select",
      "unit": "",
      "default": "gasoline",
      "min": null,
      "max": null,
      "options": [
        "gasoline",
        "diesel",
        "LPG",
        "CNG",
        "electricity"
      ],
      "businessContext": "Type of fuel used. Affects energy density and CO2 emission factors. Reference: ISO 14064."
    },
    {
      "id": "vehicleType",
      "label": "Vehicle Type",
      "type": "select",
      "unit": "",
      "default": "car",
      "min": null,
      "max": null,
      "options": [
        "car",
        "truck",
        "bus",
        "motorcycle",
        "van"
      ],
      "businessContext": "Vehicle category for benchmarking. Reference: EPA fuel economy standards."
    },
    {
      "id": "drivingCondition",
      "label": "Driving Condition",
      "type": "select",
      "unit": "",
      "default": "mixed",
      "min": null,
      "max": null,
      "options": [
        "city",
        "highway",
        "mixed"
      ],
      "businessContext": "Driving pattern affects fuel efficiency. City driving has lower efficiency due to stops."
    },
    {
      "id": "loadFactor",
      "label": "Load Factor",
      "type": "number",
      "unit": "%",
      "default": 50,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Percentage of maximum load capacity. Higher load increases fuel consumption. Reference: ISO 50001."
    },
    {
      "id": "maintenanceScore",
      "label": "Maintenance Score",
      "type": "number",
      "unit": "",
      "default": 80,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Vehicle maintenance condition (0=poor, 100=excellent). Poor maintenance increases fuel use. Reference: Lean TPM."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Confidence in input data accuracy. Used to adjust output reliability."
    }
  ],
  "validation": {
    "rules": [
      "distance > 0",
      "fuelUsed > 0",
      "loadFactor >= 0 and loadFactor <= 100",
      "maintenanceScore >= 0 and maintenanceScore <= 100",
      "dataConfidence >= 0 and dataConfidence <= 100"
    ],
    "thresholds": {
      "fuelConsumptionPer100km > 15": "High fuel consumption warning",
      "maintenanceScore < 50": "Maintenance required",
      "loadFactor > 90": "Overload risk"
    }
  },
  "formulas": {
    "fuelConsumptionPer100km": "fuelUsed / distance * 100",
    "adjustedConsumption": "fuelConsumptionPer100km * (1 + (100 - maintenanceScore) / 200) * (1 + loadFactor / 200)",
    "co2Emission": "fuelUsed * (fuelType === 'gasoline' ? 2.31 : fuelType === 'diesel' ? 2.68 : fuelType === 'LPG' ? 1.51 : fuelType === 'CNG' ? 1.64 : 0) * 1000",
    "cost": "fuelUsed * (fuelType === 'gasoline' ? 1.5 : fuelType === 'diesel' ? 1.4 : fuelType === 'LPG' ? 0.9 : fuelType === 'CNG' ? 0.8 : 0.12)",
    "dataConfidenceAdjusted": "adjustedConsumption * (dataConfidence / 100)"
  },
  "outputs": {
    "primary": "fuelConsumptionPer100km",
    "breakdown": {
      "adjustedConsumption": "adjustedConsumption",
      "co2Emission": "co2Emission",
      "cost": "cost"
    },
    "hiddenLossDrivers": [
      "fuelConsumptionPer100km > 15 ? 'High fuel consumption' : ''",
      "maintenanceScore < 50 ? 'Poor maintenance' : ''",
      "loadFactor > 90 ? 'Overload' : ''"
    ],
    "suggestedActions": [
      "fuelConsumptionPer100km > 15 ? 'Reduce speed and avoid aggressive driving' : ''",
      "maintenanceScore < 50 ? 'Schedule vehicle maintenance' : ''",
      "loadFactor > 90 ? 'Reduce load to improve efficiency' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Comparison with Benchmarks",
    "Detailed Report"
  ],
  "premiumRequired": true
}

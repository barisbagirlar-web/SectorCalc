{
  "toolName": "garmin-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years"
    },
    {
      "id": "heartRate",
      "label": "Heart Rate",
      "type": "number",
      "unit": "bpm",
      "default": 120,
      "businessContext": "Average heart rate during exercise in beats per minute"
    },
    {
      "id": "duration",
      "label": "Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Exercise duration in minutes"
    },
    {
      "id": "genderFactor",
      "label": "Gender (1=Male, 0=Female)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Gender factor: 1 for male, 0 for female"
    }
  ],
  "formulas": {
    "calories": "((genderFactor >= 1) ? ((age * 0.2017 - weight * 0.09036 + heartRate * 0.6309 - 55.0969) * duration / 4.184) : ((age * 0.074 - weight * 0.05741 + heartRate * 0.4472 - 20.4022) * duration / 4.184))",
    "caloriesPerMin": "calories / duration",
    "genderUsed": "genderFactor >= 1 ? 'Male' : 'Female'"
  },
  "outputs": {
    "primary": "calories",
    "breakdown": [
      "genderUsed",
      "caloriesPerMin"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
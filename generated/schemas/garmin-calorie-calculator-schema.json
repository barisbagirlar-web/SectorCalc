  "formulas": {
    "calories": "((genderFactor >= 1) ? ((age * 0.2017 - weight * 0.09036 + heartRate * 0.6309 - 55.0969) * duration / 4.184) : ((age * 0.074 - weight * 0.05741 + heartRate * 0.4472 - 20.4022) * duration / 4.184))",
    "caloriesPerMin": "calories / duration"
  },

        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    },
    {
      "id": "concreteDensity",
      "label": "Concrete Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 2400,
      "businessContext": "Density of concrete mix",
      "label_i18n": {
        "en": "Concrete Density",
        "tr": "Concrete Density",
        "de": "Concrete Density",
        "fr": "Concrete Density",
        "es": "Concrete Density",
        "ar": "Concrete Density"
      }
    },
    {
      "id": "costPerCubicMeter",
      "label": "Cost per m³",
      "type": "number",
      "unit": "currency/m³",
      "default": 100,
      "businessContext": "Unit cost of concrete",
      "label_i18n": {
        "en": "Cost per m³",
        "tr": "Cost per m³",
        "de": "Cost per m³",
        "fr": "Cost per m³",
        "es": "Cost per m³",
        "ar": "Cost per m³"
      }
    }
  ],
  "formulas": {
    "volume": "length * width * thickness",
    "wasteVolume": "length * width * thickness * wasteFactor / 100",
    "totalVolume": "length * width * thickness * (1 + wasteFactor / 100)",
    "totalCost": "length * width * thickness * (1 + wasteFactor / 100) * costPerCubicMeter",
    "weight": "length * width * thickness * (1 + wasteFactor / 100) * concreteDensity"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "volume",
      "wasteVolume",
      "totalVolume",
      "weight"
    ],

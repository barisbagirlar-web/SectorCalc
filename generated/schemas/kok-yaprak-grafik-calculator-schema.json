  "formulas": {
    "kokYaprakGrafik": "const data = [v1, v2, v3, v4, v5, v6, v7, v8].sort((a,b) => a-b); const stems = [...new Set(data.map(x => Math.floor(x/10)))].sort((a,b) => a-b); let result = ''; stems.forEach(s => { const leaves = data.filter(x => Math.floor(x/10) === s).map(x => x % 10).sort((a,b)=>a-b); result += s + ' | ' + leaves.join(' ') + '\\n'; }); result.trim();",
    "adet": "8",
    "minimum": "Math.min(v1, v2, v3, v4, v5, v6, v7, v8)",
    "maksimum": "Math.max(v1, v2, v3, v4, v5, v6, v7, v8)",
    "medyan": "const sorted = [v1, v2, v3, v4, v5, v6, v7, v8].sort((a,b) => a-b); const mid = Math.floor(sorted.length/2); sorted.length % 2 !== 0 ? sorted[mid] : (sorted[mid-1]+sorted[mid])/2;"
  },

    },
    {
      "id": "cogs",
      "label": "Cost of Goods Sold",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Direct costs attributable to production of sold goods",
      "label_i18n": {
        "en": "Cost of Goods Sold",
        "tr": "Satılan Malın Maliyeti",
        "de": "Herstellkosten der verkauften Waren",
        "fr": "Cost of Goods Sold",
        "es": "Cost of Goods Sold",
        "ar": "Cost of Goods Sold"
      },
      "businessContext_i18n": {
        "en": "Direct costs attributable to production of sold goods",
        "tr": "Satılan malların üretimine atfedilebilen doğrudan maliyetler",
        "de": "Direkte Kosten, die der Produktion der verkauften Waren zuzurechnen sind"
      }
    }
  ],
  "formulas": {
    "netSales": "grossSales - salesReturns - salesDiscounts - salesAllowances",
    "grossProfit": "netSales - cogs",
    "grossMargin": "netSales !== 0 ? (grossProfit / netSales) * 100 : 0"
  },
  "outputs": {
    "primary": "grossProfit",
    "breakdown": [
      "netSales",
      "grossProfit",
      "grossMargin"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

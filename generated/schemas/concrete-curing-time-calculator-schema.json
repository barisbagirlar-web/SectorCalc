      }
    },
    {
      "id": "cementType",
      "label": "Çimento Tipi Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Çimento tipine bağlı kür süresi faktörü (Örn: Tip I: 1.0, Tip II: 1.1, Tip III: 0.8)",
      "label_i18n": {
        "en": "Çimento Tipi Faktörü",
        "tr": "Çimento Tipi Faktörü",
        "de": "Çimento Tipi Faktörü",

        "ar": "Çimento Tipi Faktörü"
      }
    },
    {
      "id": "baseDays",
      "label": "Baz Kür Süresi",
      "type": "number",
      "unit": "gün",
      "default": 7,
      "businessContext": "Standart koşullarda (23°C, %100 nem, Tip I çimento) gereken kür süresi",
      "label_i18n": {
        "en": "Baz Kür Süresi",
        "tr": "Baz Kür Süresi",
        "de": "Baz Kür Süresi",
        "fr": "Baz Kür Süresi",
        "es": "Baz Kür Süresi",
        "ar": "Baz Kür Süresi"
      }
    }
  ],
  "formulas": {
    "tempFactor": "Math.pow(23/(temp+10), 1.5)",
    "humidityFactor": "100/humidity",
    "cementAdjust": "cementType",
    "curingTime": "baseDays * tempFactor * humidityFactor * cementAdjust",
    "baseDays": "baseDays"
  },
  "outputs": {
    "primary": "curingTime",
    "breakdown": [
      "baseDays",
      "tempFactor",
      "humidityFactor",
      "cementAdjust"
    ]
  },

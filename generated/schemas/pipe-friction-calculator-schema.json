      }
    },
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "L/s",
      "default": 10,
      "businessContext": "Volumetric flow rate of the fluid",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Flow Rate",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      }
    },
    {
      "id": "roughness",
      "label": "Pipe Roughness",
      "type": "number",
      "unit": "mm",
      "default": 0.045,
      "businessContext": "Surface roughness of the pipe material (e.g., 0.045 for commercial steel)",
      "label_i18n": {
        "en": "Pipe Roughness",
        "tr": "Pipe Roughness",
        "de": "Pipe Roughness",
        "fr": "Pipe Roughness",
        "es": "Pipe Roughness",
        "ar": "Pipe Roughness"
      }
    },
    {
      "id": "fluidDensity",
      "label": "Fluid Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Density of the fluid (e.g., 1000 for water at 20°C)",
      "label_i18n": {
        "en": "Fluid Density",
        "tr": "Fluid Density",
        "de": "Fluid Density",
        "fr": "Fluid Density",
        "es": "Fluid Density",
        "ar": "Fluid Density"
      }
    },
    {
      "id": "dynamicViscosity",
      "label": "Dynamic Viscosity",
      "type": "number",
      "unit": "Pa·s",
      "default": 0.001,
      "businessContext": "Dynamic viscosity of the fluid (e.g., 0.001 for water at 20°C)",
      "label_i18n": {
        "en": "Dynamic Viscosity",
        "tr": "Dynamic Viscosity",
        "de": "Dynamic Viscosity",
        "fr": "Dynamic Viscosity",
        "es": "Dynamic Viscosity",
        "ar": "Dynamic Viscosity"
      }
    }
  ],
  "formulas": {
    "diameterM": "innerDiameter / 1000",
    "flowRateM3ps": "flowRate / 1000",
    "crossArea": "Math.PI * (diameterM / 2) ** 2",
    "velocity": "flowRateM3ps / crossArea",
    "reynoldsNumber": "fluidDensity * velocity * diameterM / dynamicViscosity"
  },
  "outputs": {
    "primary": "reynoldsNumber",
    "breakdown": [
      "velocity",
      "reynoldsNumber",
      "frictionFactor",
      "pressureDrop"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pressureDrop"
  },

{
  "toolName": "stretch-ira-calculator",
  "inputs": [
    {
      "id": "initialBalance",
      "label": "Initial IRA Balance",
      "type": "number",
      "unit": "$",
      "default": 100000,
      "businessContext": "Current total balance of the inherited IRA.",
      "label_i18n": {
        "en": "Initial IRA Balance",
        "tr": "Başlangıç IRA Bakiyesi",
        "de": "Initial IRA Balance",
        "fr": "Initial IRA Balance",
        "es": "Initial IRA Balance",
        "ar": "Initial IRA Balance"
      },
      "businessContext_i18n": {
        "en": "Current total balance of the inherited IRA.",
        "tr": "Miras alınan IRA'nın mevcut toplam bakiyesi."
      }
    },
    {
      "id": "annualReturnRate",
      "label": "Expected Annual Return Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected annual percentage return on investments.",
      "label_i18n": {
        "en": "Expected Annual Return Rate",
        "tr": "Beklenen Yıllık Getiri Oranı",
        "de": "Expected Annual Return Rate",
        "fr": "Expected Annual Return Rate",
        "es": "Expected Annual Return Rate",
        "ar": "Expected Annual Return Rate"
      },
      "businessContext_i18n": {
        "en": "Expected annual percentage return on investments.",
        "tr": "Yatırımlardan beklenen yıllık yüzde getiri."
      }
    },
    {
      "id": "beneficiaryAge",
      "label": "Beneficiary Age",
      "type": "number",
      "unit": "years",
      "default": 50,
      "businessContext": "Age of the beneficiary in the current year.",
      "label_i18n": {
        "en": "Beneficiary Age",
        "tr": "Yararlanıcı Yaşı",
        "de": "Beneficiary Age",
        "fr": "Beneficiary Age",
        "es": "Beneficiary Age",
        "ar": "Beneficiary Age"
      },
      "businessContext_i18n": {
        "en": "Age of the beneficiary in the current year.",
        "tr": "Yararlanıcının içinde bulunulan yıldaki yaşı."
      }
    },
    {
      "id": "lifeExpectancyFactor",
      "label": "Life Expectancy Factor",
      "type": "number",
      "unit": "years",
      "default": 36.2,
      "businessContext": "IRS Single Life Expectancy factor from Table I for the beneficiary's age. E.g., for age 50, factor is 36.2.",
      "label_i18n": {
        "en": "Life Expectancy Factor",
        "tr": "Yaşam Beklentisi Faktörü",
        "de": "Life Expectancy Factor",
        "fr": "Life Expectancy Factor",
        "es": "Life Expectancy Factor",
        "ar": "Life Expectancy Factor"
      },
      "businessContext_i18n": {
        "en": "IRS Single Life Expectancy factor from Table I for the beneficiary's age. E.g., for age 50, factor is 36.2.",
        "tr": "Yararlanıcının yaşına göre IRS Tablo I'den Beklenen Yaşam Süresi faktörü. Örn., 50 yaş için faktör 36,2'dir."
      }
    }
  ],
  "formulas": {
    "requiredMinimumDistribution": "initialBalance / lifeExpectancyFactor",
    "remainingBalance": "initialBalance - (initialBalance / lifeExpectancyFactor)",
    "projectedBalanceNextYear": "(initialBalance - (initialBalance / lifeExpectancyFactor)) * (1 + annualReturnRate / 100)"
  },
  "outputs": {
    "primary": "requiredMinimumDistribution",
    "breakdown": [
      "remainingBalance",
      "projectedBalanceNextYear"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "projectedBalanceNextYear",
    "unit": "$"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

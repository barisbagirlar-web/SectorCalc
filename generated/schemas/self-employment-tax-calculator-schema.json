      }
    },
    {
      "id": "medicareRate",
      "label": "Medicare Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 2.9,
      "businessContext": "Combined employer and employee rate for Medicare (2023).",
      "label_i18n": {
        "en": "Medicare Tax Rate",
        "tr": "Medicare Tax Rate",
        "de": "Medicare Tax Rate",
        "fr": "Medicare Tax Rate",
        "es": "Medicare Tax Rate",
        "ar": "Medicare Tax Rate"
      }
    },
    {
      "id": "socialSecurityWageBase",
      "label": "Social Security Wage Base Limit",
      "type": "number",
      "unit": "$",
      "default": 160200,
      "businessContext": "Maximum earnings subject to Social Security tax (2023).",
      "label_i18n": {
        "en": "Social Security Wage Base Limit",
        "tr": "Social Security Wage Base Limit",
        "de": "Social Security Wage Base Limit",
        "fr": "Social Security Wage Base Limit",
        "es": "Social Security Wage Base Limit",
        "ar": "Social Security Wage Base Limit"
      }
    },
    {
      "id": "additionalMedicareThreshold",
      "label": "Additional Medicare Tax Threshold",
      "type": "number",
      "unit": "$",
      "default": 200000,
      "businessContext": "Earnings above this threshold incur additional Medicare tax (single filer 2023).",
      "label_i18n": {
        "en": "Additional Medicare Tax Threshold",
        "tr": "Additional Medicare Tax Threshold",
        "de": "Additional Medicare Tax Threshold",
        "fr": "Additional Medicare Tax Threshold",
        "es": "Additional Medicare Tax Threshold",
        "ar": "Additional Medicare Tax Threshold"
      }
    },
    {
      "id": "additionalMedicareRate",
      "label": "Additional Medicare Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0.9,
      "businessContext": "Extra Medicare tax rate on earnings above threshold (2023).",
      "label_i18n": {
        "en": "Additional Medicare Tax Rate",
        "tr": "Additional Medicare Tax Rate",
        "de": "Additional Medicare Tax Rate",
        "fr": "Additional Medicare Tax Rate",
        "es": "Additional Medicare Tax Rate",
        "ar": "Additional Medicare Tax Rate"
      }
    }
  ],
  "formulas": {
    "medicareTax": "netEarnings * (medicareRate / 100)",
    "additionalMedicareTax": "netEarnings > additionalMedicareThreshold ? (netEarnings - additionalMedicareThreshold) * (additionalMedicareRate / 100) : 0"
  },
  "outputs": {
    "primary": "additionalMedicareTax",
    "breakdown": [
      "socialSecurityTax",
      "medicareTax",
      "additionalMedicareTax"
    ],

{
  "toolName": "concrete-volume-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Uzunluk",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Döşeme uzunluğu"
    },
    {
      "id": "width",
      "label": "Genişlik",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Döşeme genişliği"
    },
    {
      "id": "thickness",
      "label": "Kalınlık",
      "type": "number",
      "unit": "cm",
      "default": 15,
      "businessContext": "Beton kalınlığı"
    },
    {
      "id": "wasteFactor",
      "label": "Fire Oranı",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Beton fire payı"
    },
    {
      "id": "density",
      "label": "Beton Yoğunluğu",
      "type": "number",
      "unit": "kg/m³",
      "default": 2400,
      "businessContext": "Beton yoğunluğu"
    }
  ],
  "formulas": {
    "volume": "length * width * thickness / 100",
    "volumeWithWaste": "volume * (1 + wasteFactor / 100)",
    "weight": "volumeWithWaste * density"
  },
  "outputs": {
    "primary": "volumeWithWaste",
    "breakdown": [
      "volume",
      "weight"
    ]
  },
  "category": "İnşaat & Saha",
  "sector": "İnşaat & Saha",
  "premiumRequired": false
}
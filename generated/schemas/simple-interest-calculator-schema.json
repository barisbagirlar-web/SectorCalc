        "ar": "Start Year"
      },
      "businessContext_i18n": {
        "en": "The starting year for the interest calculation",
        "tr": "Faiz hesaplamasının başlangıç yılı"
      }
    },
    {
      "id": "endYear",
      "label": "End Year",
      "type": "number",
      "unit": "year",
      "default": 2030,
      "businessContext": "The ending year for the interest calculation",
      "label_i18n": {
        "en": "End Year",
        "tr": "Bitiş Yılı",
        "de": "End Year",
        "fr": "End Year",
        "es": "End Year",
        "ar": "End Year"
      },
      "businessContext_i18n": {
        "en": "The ending year for the interest calculation",
        "tr": "Faiz hesaplamasının bitiş yılı"
      }
    }
  ],
  "formulas": {
    "timeInYears": "endYear - startYear",
    "simpleInterest": "principal * (rate / 100) * timeInYears",
    "totalAmount": "principal + simpleInterest"
  },
  "outputs": {
    "primary": "simpleInterest",
    "breakdown": [
      "totalAmount",
      "principal"
    ],

      "businessContext_i18n": {
        "en": "The annual interest rate as a percentage",
        "tr": "Yıllık faiz oranı yüzde olarak"
      }
    },
    {
      "id": "startYear",
      "label": "Start Year",
      "type": "number",
      "unit": "year",
      "default": 2025,
      "businessContext": "The starting year for the interest calculation",
      "label_i18n": {
        "en": "Start Year",
        "tr": "Başlangıç Yılı",
        "de": "Start Year",
        "fr": "Start Year",

  "formulas": {
    "prAuc": "((r2 - r1) * (p1 + p2) / 2) + ((r3 - r2) * (p2 + p3) / 2) + ((r4 - r3) * (p3 + p4) / 2)",
    "area1": "(r2 - r1) * (p1 + p2) / 2",
    "area2": "(r3 - r2) * (p2 + p3) / 2",
    "area3": "(r4 - r3) * (p3 + p4) / 2"
  },

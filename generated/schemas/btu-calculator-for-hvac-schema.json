      }
    },
    {
      "id": "insulation_factor",
      "label": "Insulation Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Insulation quality: 0.5 (excellent), 1.0 (average), 1.5 (poor).",
      "label_i18n": {
        "en": "Insulation Factor",
        "tr": "Insulation Factor",
        "de": "Insulation Factor",
        "fr": "Insulation Factor",
        "es": "Insulation Factor",
        "ar": "Insulation Factor"
      }
    },
    {
      "id": "sun_exposure",
      "label": "Sun Exposure",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Additional BTU per square foot due to sun: 0 (none), 10 (moderate), 20 (high).",
      "label_i18n": {
        "en": "Sun Exposure",
        "tr": "Sun Exposure",
        "de": "Sun Exposure",
        "fr": "Sun Exposure",
        "es": "Sun Exposure",
        "ar": "Sun Exposure"
      }
    },
    {
      "id": "num_occupants",
      "label": "Number of Occupants",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Typical number of people in the room.",
      "label_i18n": {
        "en": "Number of Occupants",
        "tr": "Number of Occupants",
        "de": "Number of Occupants",
        "fr": "Number of Occupants",
        "es": "Number of Occupants",
        "ar": "Number of Occupants"
      }
    },
    {
      "id": "num_windows",
      "label": "Number of Windows",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of windows in the room.",
      "label_i18n": {
        "en": "Number of Windows",
        "tr": "Number of Windows",
        "de": "Number of Windows",
        "fr": "Number of Windows",
        "es": "Number of Windows",
        "ar": "Number of Windows"
      }
    }
  ],
  "formulas": {
    "volume": "room_length * room_width * ceiling_height",
    "base_btu": "volume * 3.5",
    "insulation_adjustment": "base_btu * insulation_factor",
    "sun_adjustment": "sun_exposure * room_length * room_width",
    "occupant_adjustment": "num_occupants * 400",
    "window_adjustment": "num_windows * 1000",
    "total_btu": "insulation_adjustment + sun_adjustment + occupant_adjustment + window_adjustment"
  },
  "outputs": {
    "primary": "total_btu",
    "breakdown": [
      "base_btu",
      "insulation_adjustment",
      "sun_adjustment",
      "occupant_adjustment",
      "window_adjustment"
    ]
  },
  "category": "Akışkanlar & Termodinamik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "process-chemical"
}

        "ar": "Temperature Coefficient"
      },
      "businessContext_i18n": {
        "en": "Capacitance change per degree Celsius (ppm)",
        "tr": "Santigrat derece başına kapasitans değişimi (ppm)"
      }
    },
    {
      "id": "temperature",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Operating temperature",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ortam Sıcaklığı",
        "de": "Ambient Temperature",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      },
      "businessContext_i18n": {
        "en": "Operating temperature",
        "tr": "Çalışma sıcaklığı"
      }
    },
    {
      "id": "esr",
      "label": "Equivalent Series Resistance",
      "type": "number",
      "unit": "Ω",
      "default": 0.1,
      "businessContext": "ESR of the capacitor",
      "label_i18n": {
        "en": "Equivalent Series Resistance",
        "tr": "Eşdeğer Seri Direnç",
        "de": "Equivalent Series Resistance",
        "fr": "Equivalent Series Resistance",
        "es": "Equivalent Series Resistance",
        "ar": "Equivalent Series Resistance"
      },
      "businessContext_i18n": {
        "en": "ESR of the capacitor",
        "tr": "Kapasitörün ESR'si"
      }
    },
    {
      "id": "safety_factor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Design margin multiplier for reactance",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Güvenlik Faktörü",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      },
      "businessContext_i18n": {
        "en": "Design margin multiplier for reactance",
        "tr": "Reaktans için tasarım marjı çarpanı"
      }
    }
  ],
  "formulas": {
    "C_eff": "capacitance * (1 + (tc * 1e-6) * (temperature - 25))",
    "Xc": "1 / (2 * Math.PI * frequency * C_eff)",
    "Xc_safe": "Xc * safety_factor"
  },
  "outputs": {
    "primary": "Xc_safe",
    "breakdown": [
      "C_eff",
      "Z_total",
      "phase_angle"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "phase_angle",
    "unit": "Hz"
  },

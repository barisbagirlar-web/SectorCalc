{
  "toolName": "capacitive-reactance-calculator",
  "inputs": [
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1000,
      "businessContext": "Operating frequency of the AC signal",
      "label_i18n": {
        "en": "Frequency",
        "tr": "Frequency",
        "de": "Frequency",
        "fr": "Frequency",
        "es": "Frequency",
        "ar": "Frequency"
      }
    },
    {
      "id": "capacitance",
      "label": "Nominal Capacitance",
      "type": "number",
      "unit": "F",
      "default": 0.000001,
      "businessContext": "Rated capacitance at 25°C",
      "label_i18n": {
        "en": "Nominal Capacitance",
        "tr": "Nominal Capacitance",
        "de": "Nominal Capacitance",
        "fr": "Nominal Capacitance",
        "es": "Nominal Capacitance",
        "ar": "Nominal Capacitance"
      }
    },
    {
      "id": "tc",
      "label": "Temperature Coefficient",
      "type": "number",
      "unit": "ppm/°C",
      "default": 0,
      "businessContext": "Capacitance change per degree Celsius (ppm)",
      "label_i18n": {
        "en": "Temperature Coefficient",
        "tr": "Temperature Coefficient",
        "de": "Temperature Coefficient",
        "fr": "Temperature Coefficient",
        "es": "Temperature Coefficient",
        "ar": "Temperature Coefficient"
      }
    },
    {
      "id": "temperature",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "Operating temperature",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ambient Temperature",
        "de": "Ambient Temperature",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      }
    },
    {
      "id": "esr",
      "label": "Equivalent Series Resistance",
      "type": "number",
      "unit": "Ω",
      "default": 0.1,
      "businessContext": "ESR of the capacitor",
      "label_i18n": {
        "en": "Equivalent Series Resistance",
        "tr": "Equivalent Series Resistance",
        "de": "Equivalent Series Resistance",
        "fr": "Equivalent Series Resistance",
        "es": "Equivalent Series Resistance",
        "ar": "Equivalent Series Resistance"
      }
    },
    {
      "id": "safety_factor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Design margin multiplier for reactance",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "C_eff": "capacitance * (1 + (tc * 1e-6) * (temperature - 25))",
    "Xc": "1 / (2 * Math.PI * frequency * C_eff)",
    "Xc_safe": "Xc * safety_factor"
  },
  "outputs": {
    "primary": "Xc_safe",
    "breakdown": [
      "C_eff",
      "Z_total",
      "phase_angle"
    ],

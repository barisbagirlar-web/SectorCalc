        "ar": "Daily Driving Distance"
      },
      "businessContext_i18n": {
        "en": "Average distance driven per day.",
        "tr": "Günde ortalama sürülen mesafe.",
        "de": "Durchschnittliche tägliche Fahrstrecke."
      }
    },
    {
      "id": "maintenance_cost_per_km",
      "label": "Maintenance Cost per km",
      "type": "number",
      "unit": "Currency/km",
      "default": 0.05,
      "businessContext": "Estimated maintenance and repair cost per kilometer driven.",
      "label_i18n": {
        "en": "Maintenance Cost per km",
        "tr": "Km başına bakım maliyeti",
        "de": "Wartungskosten pro km",
        "fr": "Maintenance Cost per km",
        "es": "Maintenance Cost per km",
        "ar": "Maintenance Cost per km"
      },
      "businessContext_i18n": {
        "en": "Estimated maintenance and repair cost per kilometer driven.",
        "tr": "Kilometre başına tahmini bakım ve onarım maliyeti.",
        "de": "Geschätzte Wartungs- und Reparaturkosten pro gefahrenem Kilometer."
      }
    }
  ],
  "formulas": {
    "energy_per_day": "daily_distance / 100 * vehicle_efficiency * (100 / charging_efficiency)",
    "energy_cost_per_day": "energy_per_day * electricity_price",
    "maintenance_cost_per_day": "daily_distance * maintenance_cost_per_km",
    "total_cost_per_day": "energy_cost_per_day + maintenance_cost_per_day"
  },
  "outputs": {
    "primary": "total_cost_per_day",
    "breakdown": [
      "energy_cost_per_day",
      "maintenance_cost_per_day"
    ],

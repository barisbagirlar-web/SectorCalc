  "formulas": {
    "energy_per_day": "daily_distance / 100 * vehicle_efficiency * (100 / charging_efficiency)",
    "energy_cost_per_day": "energy_per_day * electricity_price",
    "maintenance_cost_per_day": "daily_distance * maintenance_cost_per_km",
    "total_cost_per_day": "energy_cost_per_day + maintenance_cost_per_day"
  },
  "outputs": {
    "primary": "total_cost_per_day",
    "breakdown": [
      "energy_cost_per_day",

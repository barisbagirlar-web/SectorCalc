      "businessContext": "Average distance driven per day.",
      "label_i18n": {
        "en": "Daily Driving Distance",
        "tr": "Günlük Sürüş Mesafesi",
        "de": "Tägliche Fahrstrecke",
        "fr": "Daily Driving Distance",

      "label_i18n": {
        "en": "Sphere 4 Radius",
        "tr": "Sphere 4 Radius",
        "de": "Sphere 4 Radius",
        "fr": "Sphere 4 Radius",
        "es": "Sphere 4 Radius",
        "ar": "Sphere 4 Radius"
      }
    },
    {
      "id": "unitMultiplier",
      "label": "Radius Unit Conversion to m",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "Conversion factor to convert input radii to meters (e.g., cm=0.01, mm=0.001)",
      "label_i18n": {
        "en": "Radius Unit Conversion to m",
        "tr": "Radius Unit Conversion to m",
        "de": "Radius Unit Conversion to m",
        "fr": "Radius Unit Conversion to m",
        "es": "Radius Unit Conversion to m",
        "ar": "Radius Unit Conversion to m"
      }
    },
    {
      "id": "density",
      "label": "Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Density of the material for weight calculation",
      "label_i18n": {
        "en": "Material Density",
        "tr": "Material Density",
        "de": "Material Density",
        "fr": "Material Density",
        "es": "Material Density",
        "ar": "Material Density"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Material Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percentage of material waste considered for procurement",
      "label_i18n": {
        "en": "Material Waste Factor",
        "tr": "Material Waste Factor",
        "de": "Material Waste Factor",
        "fr": "Material Waste Factor",
        "es": "Material Waste Factor",
        "ar": "Material Waste Factor"
      }
    }
  ],
  "formulas": {
    "convertedRadius1": "radius1 * unitMultiplier",
    "convertedRadius2": "radius2 * unitMultiplier",
    "convertedRadius3": "radius3 * unitMultiplier",
    "convertedRadius4": "radius4 * unitMultiplier",
    "V1": "(4/3) * Math.PI * Math.pow(convertedRadius1, 3)",
    "V2": "(4/3) * Math.PI * Math.pow(convertedRadius2, 3)",
    "V3": "(4/3) * Math.PI * Math.pow(convertedRadius3, 3)",
    "V4": "(4/3) * Math.PI * Math.pow(convertedRadius4, 3)",
    "totalVolume": "V1 + V2 + V3 + V4",
    "totalMass": "totalVolume * density",
    "totalMassWithWaste": "totalMass * (1 + wasteFactor/100)",
    "_V1__m_": "{V1} m³",
    "_V2__m_": "{V2} m³",
    "_V3__m_": "{V3} m³",
    "_V4__m_": "{V4} m³",
    "_totalMass__kg": "{totalMass} kg",
    "_totalMassWithWaste__kg": "{totalMassWithWaste} kg"
  },
  "outputs": {
    "primary": "convertedRadius1",
    "breakdown": [
      "Sphere 1 Volume: {V1} m³",
      "Sphere 2 Volume: {V2} m³",
      "Sphere 3 Volume: {V3} m³",
      "Sphere 4 Volume: {V4} m³",
      "Total Mass (without waste): {totalMass} kg",
      "Total Mass (with {wasteFactor}% waste): {totalMassWithWaste} kg"
    ]
  },
  "category": "Malzeme & Metalurji",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "metal-plastics-forming"
}

{
  "toolName": "workout-volume-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Room length along the longer side"
    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Room width"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "Ceiling height"
    },
    {
      "id": "fill_factor",
      "label": "Fill Factor",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Percentage of volume occupied by equipment (0-100)"
    }
  ],
  "formulas": {
    "total_volume": "length * width * height",
    "usable_volume": "total_volume * (fill_factor / 100)",
    "unused_volume": "total_volume - usable_volume"
  },
  "outputs": {
    "primary": "usable_volume",
    "breakdown": [
      "total_volume",
      "unused_volume"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "categorySlug": "hse-ergonomics",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning"
}

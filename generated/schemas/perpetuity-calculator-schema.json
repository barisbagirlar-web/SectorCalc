{
  "toolName": "perpetuity-calculator",
  "inputs": [
    {
      "id": "type",
      "label": "Perpetuity Type",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 for constant perpetuity, 1 for growing perpetuity",
      "label_i18n": {
        "en": "Perpetuity Type",
        "tr": "Perpetuity Type",
        "de": "Perpetuity Type",
        "fr": "Perpetuity Type",
        "es": "Perpetuity Type",
        "ar": "Perpetuity Type"
      }
    },
    {
      "id": "payment",
      "label": "Periodic Payment",
      "type": "number",
      "unit": "$",
      "default": 1000,
      "businessContext": "The constant cash flow per period",
      "label_i18n": {
        "en": "Periodic Payment",
        "tr": "Periodic Payment",
        "de": "Periodic Payment",
        "fr": "Periodic Payment",
        "es": "Periodic Payment",
        "ar": "Periodic Payment"
      }
    },
    {
      "id": "discountRate",
      "label": "Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "The required rate of return per period",
      "label_i18n": {
        "en": "Discount Rate",
        "tr": "Discount Rate",
        "de": "Discount Rate",
        "fr": "Discount Rate",
        "es": "Discount Rate",
        "ar": "Discount Rate"
      }
    },
    {
      "id": "growthRate",
      "label": "Growth Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "The constant growth rate of the payment (only used for growing perpetuity)",
      "label_i18n": {
        "en": "Growth Rate",
        "tr": "Growth Rate",
        "de": "Growth Rate",
        "fr": "Growth Rate",
        "es": "Growth Rate",
        "ar": "Growth Rate"
      }
    }
  ],
  "formulas": {
    "presentValue": "type === 0 ? (payment * 100) / discountRate : (payment * 100) / (discountRate - growthRate)",
    "paymentDisplay": "payment",
    "discountRateDisplay": "discountRate",
    "growthRateDisplay": "growthRate",
    "typeDisplay": "type"
  },
  "outputs": {
    "primary": "presentValue",

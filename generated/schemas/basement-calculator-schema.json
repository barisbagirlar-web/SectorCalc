{
  "toolName": "basement-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Bodrum Uzunluğu (m)",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Bodrumun uzun kenarı"
    },
    {
      "id": "width",
      "label": "Bodrum Genişliği (m)",
      "type": "number",
      "unit": "m",
      "default": 8,
      "businessContext": "Bodrumun kısa kenarı"
    },
    {
      "id": "depth",
      "label": "Bodrum Derinliği (m)",
      "type": "number",
      "unit": "m",
      "default": 3,
      "businessContext": "Bodrumun tabanından zemin seviyesine kadar olan yükseklik"
    },
    {
      "id": "wallThickness",
      "label": "Duvar Kalınlığı (cm)",
      "type": "number",
      "unit": "cm",
      "default": 25,
      "businessContext": "Beton duvar kalınlığı"
    },
    {
      "id": "floorThickness",
      "label": "Döşeme Kalınlığı (cm)",
      "type": "number",
      "unit": "cm",
      "default": 20,
      "businessContext": "Taban döşemesi kalınlığı"
    },
    {
      "id": "concreteCost",
      "label": "Beton Maliyeti (TL/m³)",
      "type": "number",
      "unit": "TL/m³",
      "default": 1200,
      "businessContext": "Birim metreküp beton fiyatı"
    },
    {
      "id": "waterproofingCost",
      "label": "Su Yalıtım Maliyeti (TL/m²)",
      "type": "number",
      "unit": "TL/m²",
      "default": 50,
      "businessContext": "Birim metrekare su yalıtım fiyatı"
    }
  ],
  "formulas": {
    "floorArea": "length * width",
    "wallArea": "2 * (length + width) * depth",
    "wallConcreteVolume": "wallArea * (wallThickness / 100)",
    "floorConcreteVolume": "floorArea * (floorThickness / 100)",
    "totalConcreteVolume": "wallConcreteVolume + floorConcreteVolume",
    "waterproofingArea": "floorArea + wallArea",
    "concreteCostAmount": "totalConcreteVolume * concreteCost",
    "waterproofingCostAmount": "waterproofingArea * waterproofingCost",
    "totalCost": "concreteCostAmount + waterproofingCostAmount"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalConcreteVolume",
      "waterproofingArea",
      "concreteCostAmount",
      "waterproofingCostAmount"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

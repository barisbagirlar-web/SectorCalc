{
  "toolName": "caffeine-calculator",
  "inputs": [
    {
      "id": "volumePerServing",
      "label": "Hacim (Servis Başına)",
      "type": "number",
      "unit": "ml",
      "default": 250,
      "businessContext": "Tek bir porsiyonun hacmi (ml cinsinden)",
      "label_i18n": {
        "en": "Hacim (Servis Başına)",
        "tr": "Hacim (Servis Başına)",
        "de": "Hacim (Servis Başına)",
        "fr": "Hacim (Servis Başına)",
        "es": "Hacim (Servis Başına)",
        "ar": "Hacim (Servis Başına)"
      }
    },
    {
      "id": "numberOfServings",
      "label": "Porsiyon Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Tüketilen veya hazırlanan porsiyon sayısı",
      "label_i18n": {
        "en": "Porsiyon Sayısı",
        "tr": "Porsiyon Sayısı",
        "de": "Porsiyon Sayısı",
        "fr": "Porsiyon Sayısı",
        "es": "Porsiyon Sayısı",
        "ar": "Porsiyon Sayısı"
      }
    },
    {
      "id": "caffeineContentPer100ml",
      "label": "100 ml'deki Kafein Miktarı",
      "type": "number",
      "unit": "mg/100ml",
      "default": 40,
      "businessContext": "İçeceğin 100 ml'sinde bulunan kafein miktarı (mg)",
      "label_i18n": {
        "en": "100 ml'deki Kafein Miktarı",
        "tr": "100 ml'deki Kafein Miktarı",
        "de": "100 ml'deki Kafein Miktarı",
        "fr": "100 ml'deki Kafein Miktarı",
        "es": "100 ml'deki Kafein Miktarı",
        "ar": "100 ml'deki Kafein Miktarı"
      }
    },
    {
      "id": "bodyWeight",
      "label": "Vücut Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Kişinin vücut ağırlığı (kg)",
      "label_i18n": {
        "en": "Vücut Ağırlığı",
        "tr": "Vücut Ağırlığı",
        "de": "Vücut Ağırlığı",
        "fr": "Vücut Ağırlığı",
        "es": "Vücut Ağırlığı",
        "ar": "Vücut Ağırlığı"
      }
    }
  ],
  "formulas": {
    "totalCaffeine": "volumePerServing * numberOfServings * (caffeineContentPer100ml / 100)",
    "safeLimit": "bodyWeight * 6",
    "remainingCaffeine": "safeLimit - totalCaffeine"
  },
  "outputs": {
    "primary": "totalCaffeine",
    "breakdown": [
      "safeLimit",
      "remainingCaffeine"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "remainingCaffeine"
  },

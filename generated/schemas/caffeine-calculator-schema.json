  "formulas": {
    "totalCaffeine": "volumePerServing * numberOfServings * (caffeineContentPer100ml / 100)",
    "safeLimit": "bodyWeight * 6",
    "remainingCaffeine": "safeLimit - totalCaffeine"
  },
  "outputs": {
    "primary": "totalCaffeine",
    "breakdown": [

{
  "toolName": "depreciation-calculator",
  "inputs": [
    {
      "id": "initialCost",
      "label": "Initial Cost",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "The initial purchase price of the asset.",
      "label_i18n": {
        "en": "Initial Cost",
        "tr": "Initial Cost",
        "de": "Initial Cost",
        "fr": "Initial Cost",
        "es": "Initial Cost",
        "ar": "Initial Cost"
      }
    },
    {
      "id": "salvageValue",
      "label": "Salvage Value",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "The estimated residual value at the end of useful life.",
      "label_i18n": {
        "en": "Salvage Value",
        "tr": "Salvage Value",
        "de": "Salvage Value",
        "fr": "Salvage Value",
        "es": "Salvage Value",
        "ar": "Salvage Value"
      }
    },
    {
      "id": "usefulLifeYears",
      "label": "Useful Life (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "The expected useful life of the asset in years.",
      "label_i18n": {
        "en": "Useful Life (Years)",
        "tr": "Useful Life (Years)",
        "de": "Useful Life (Years)",
        "fr": "Useful Life (Years)",
        "es": "Useful Life (Years)",
        "ar": "Useful Life (Years)"
      }
    },
    {
      "id": "yearsElapsed",
      "label": "Years Elapsed",
      "type": "number",
      "unit": "years",
      "default": 0,
      "businessContext": "Number of years the asset has been in use.",
      "label_i18n": {
        "en": "Years Elapsed",
        "tr": "Years Elapsed",
        "de": "Years Elapsed",
        "fr": "Years Elapsed",
        "es": "Years Elapsed",
        "ar": "Years Elapsed"
      }
    }
  ],
  "formulas": {
    "annualDepreciation": "(initialCost - salvageValue) / usefulLifeYears",
    "accumulatedDepreciation": "(initialCost - salvageValue) / usefulLifeYears * yearsElapsed",
    "bookValue": "initialCost - ((initialCost - salvageValue) / usefulLifeYears * yearsElapsed)"
  },
  "outputs": {
    "primary": "annualDepreciation",
    "breakdown": [
      "accumulatedDepreciation",
      "bookValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "bookValue",
    "unit": "currency"
  },

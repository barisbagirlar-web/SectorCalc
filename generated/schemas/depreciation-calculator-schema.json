      }
    },
    {
      "id": "yearsElapsed",
      "label": "Years Elapsed",
      "type": "number",
      "unit": "years",
      "default": 0,
      "businessContext": "Number of years the asset has been in use.",
      "label_i18n": {
        "en": "Years Elapsed",
        "tr": "Geçen Yıllar",
        "de": "Verstrichene Jahre",
        "fr": "Years Elapsed",
        "es": "Years Elapsed",
        "ar": "Years Elapsed"
      },
      "businessContext_i18n": {
        "en": "Number of years the asset has been in use.",
        "tr": "Varlığın kullanımda olduğu yıl sayısı.",
        "de": "Anzahl der Jahre, die der Vermögenswert in Nutzung ist."
      }
    }
  ],
  "formulas": {
    "annualDepreciation": "(initialCost - salvageValue) / usefulLifeYears",
    "accumulatedDepreciation": "(initialCost - salvageValue) / usefulLifeYears * yearsElapsed",
    "bookValue": "initialCost - ((initialCost - salvageValue) / usefulLifeYears * yearsElapsed)"
  },
  "outputs": {
    "primary": "annualDepreciation",
    "breakdown": [
      "accumulatedDepreciation",
      "bookValue"
    ],
    "hiddenLossDrivers": [],

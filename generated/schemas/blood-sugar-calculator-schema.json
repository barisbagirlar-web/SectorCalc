{
  "toolName": "blood-sugar-calculator",
  "inputs": [
    {
      "id": "fasting_bs",
      "label": "Fasting Blood Sugar",
      "type": "number",
      "unit": "mg/dL",
      "default": 0,
      "businessContext": "Patient's fasting blood glucose level (measured after 8-12 hours of no caloric intake)",
      "label_i18n": {
        "en": "Fasting Blood Sugar",
        "tr": "Fasting Blood Sugar",
        "de": "Fasting Blood Sugar",
        "fr": "Fasting Blood Sugar",
        "es": "Fasting Blood Sugar",
        "ar": "Fasting Blood Sugar"
      }
    },
    {
      "id": "postprandial_bs",
      "label": "Postprandial Blood Sugar",
      "type": "number",
      "unit": "mg/dL",
      "default": 0,
      "businessContext": "Patient's blood glucose level 2 hours after meal",
      "label_i18n": {
        "en": "Postprandial Blood Sugar",
        "tr": "Postprandial Blood Sugar",
        "de": "Postprandial Blood Sugar",
        "fr": "Postprandial Blood Sugar",
        "es": "Postprandial Blood Sugar",
        "ar": "Postprandial Blood Sugar"
      }
    },
    {
      "id": "random_bs",
      "label": "Random Blood Sugar",
      "type": "number",
      "unit": "mg/dL",
      "default": 0,
      "businessContext": "Patient's random blood glucose level at any time of day",
      "label_i18n": {
        "en": "Random Blood Sugar",
        "tr": "Random Blood Sugar",
        "de": "Random Blood Sugar",
        "fr": "Random Blood Sugar",
        "es": "Random Blood Sugar",
        "ar": "Random Blood Sugar"
      }
    },
    {
      "id": "a1c",
      "label": "HbA1c",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Glycated hemoglobin percentage, reflecting average blood glucose over past 2-3 months",
      "label_i18n": {
        "en": "HbA1c",
        "tr": "HbA1c",
        "de": "HbA1c",
        "fr": "HbA1c",
        "es": "HbA1c",
        "ar": "HbA1c"
      }
    }
  ],
  "formulas": {
    "avg_bs_mgdl": "(fasting_bs + postprandial_bs + random_bs) / 3",
    "avg_bs_mmol": "avg_bs_mgdl / 18.0182",
    "estimated_a1c": "(avg_bs_mgdl + 46.7) / 28.7",
    "eag_from_a1c": "28.7 * a1c - 46.7"
  },
  "outputs": {
    "primary": "eag_from_a1c",
    "breakdown": [
      "Estimated HbA1c: ${estimated_a1c}%",
      "eAG from A1c: ${eag_from_a1c} mg/dL",
      "Blood Sugar in mmol/L: ${avg_bs_mmol} mmol/L"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "eag_from_a1c",
    "unit": "mg/dL"
  },

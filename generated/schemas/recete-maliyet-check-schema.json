  "formulas": {
    "TheoreticalCost": "SUM(FormulationPct_i * IngredientPrice_i)",
    "ActualCost": "TotalMaterialConsumed * AvgPrice / TotalOutput",
    "Variance": "ActualCost - TheoreticalCost",
    "YieldLossCost": "(1 - ActualYield) * TheoreticalCost",
    "EvaporationLoss": "InputWeight - OutputWeight - KnownScrap",
    "Efficiency": "ActualOutput / TheoreticalOutput",
    "CostPerKg": "ActualCost / OutputWeight"
  },

{
  "toolName": "antilog-calculator",
  "inputs": [
    {
      "id": "logValue",
      "label": "Logarithm Value",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "The logarithm value (exponent) to compute the antilogarithm for.",
      "label_i18n": {
        "en": "Logarithm Value",
        "tr": "Logarithm Value",
        "de": "Logarithm Value",
        "fr": "Logarithm Value",
        "es": "Logarithm Value",
        "ar": "Logarithm Value"
      }
    },
    {
      "id": "base",
      "label": "Base",
      "type": "number",
      "unit": "unit",
      "default": 10,
      "businessContext": "The base of the logarithm for the primary antilogarithm calculation.",
      "label_i18n": {
        "en": "Base",
        "tr": "Base",
        "de": "Base",
        "fr": "Base",
        "es": "Base",
        "ar": "Base"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Precision",
      "type": "number",
      "unit": "places",
      "default": 4,
      "businessContext": "Number of decimal places to round the computed results.",
      "label_i18n": {
        "en": "Decimal Precision",
        "tr": "Decimal Precision",
        "de": "Decimal Precision",
        "fr": "Decimal Precision",
        "es": "Decimal Precision",
        "ar": "Decimal Precision"
      }
    },
    {
      "id": "scaleFactor",
      "label": "Scale Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier applied to the primary antilogarithm result for scaling purposes.",
      "label_i18n": {
        "en": "Scale Factor",
        "tr": "Scale Factor",
        "de": "Scale Factor",
        "fr": "Scale Factor",
        "es": "Scale Factor",
        "ar": "Scale Factor"
      }
    }
  ],
  "formulas": {
    "primary": "Math.round(scaleFactor * (base ** logValue) * (10 ** precision)) / (10 ** precision)",
    "antilogBase10": "Math.round((10 ** logValue) * (10 ** precision)) / (10 ** precision)",
    "antilogBaseE": "Math.round(Math.exp(logValue) * (10 ** precision)) / (10 ** precision)",
    "antilogBase2": "Math.round((2 ** logValue) * (10 ** precision)) / (10 ** precision)"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "antilogBase10",
      "antilogBaseE",
      "antilogBase2"
    ]
  },

{
  "toolName": "payroll-tax-calculator",
  "inputs": [
    {
      "id": "grossSalary",
      "label": "Gross Salary",
      "type": "number",
      "unit": "currency",
      "default": 50000,
      "businessContext": "Employee's annual gross salary before taxes.",
      "label_i18n": {
        "en": "Gross Salary",
        "tr": "Gross Salary",
        "de": "Gross Salary",
        "fr": "Gross Salary",
        "es": "Gross Salary",
        "ar": "Gross Salary"
      }
    },
    {
      "id": "taxRate1",
      "label": "Tax Rate Bracket 1",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Tax rate for the first income bracket.",
      "label_i18n": {
        "en": "Tax Rate Bracket 1",
        "tr": "Tax Rate Bracket 1",
        "de": "Tax Rate Bracket 1",
        "fr": "Tax Rate Bracket 1",
        "es": "Tax Rate Bracket 1",
        "ar": "Tax Rate Bracket 1"
      }
    },
    {
      "id": "taxRate2",
      "label": "Tax Rate Bracket 2",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Tax rate for the second income bracket.",
      "label_i18n": {
        "en": "Tax Rate Bracket 2",
        "tr": "Tax Rate Bracket 2",
        "de": "Tax Rate Bracket 2",
        "fr": "Tax Rate Bracket 2",
        "es": "Tax Rate Bracket 2",
        "ar": "Tax Rate Bracket 2"
      }
    },
    {
      "id": "taxRate3",
      "label": "Tax Rate Bracket 3",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Tax rate for the third income bracket.",
      "label_i18n": {
        "en": "Tax Rate Bracket 3",
        "tr": "Tax Rate Bracket 3",
        "de": "Tax Rate Bracket 3",
        "fr": "Tax Rate Bracket 3",
        "es": "Tax Rate Bracket 3",
        "ar": "Tax Rate Bracket 3"
      }
    },
    {
      "id": "bracket1Limit",
      "label": "Bracket 1 Upper Limit",
      "type": "number",
      "unit": "currency",
      "default": 20000,
      "businessContext": "Upper income limit of bracket 1.",
      "label_i18n": {
        "en": "Bracket 1 Upper Limit",
        "tr": "Bracket 1 Upper Limit",
        "de": "Bracket 1 Upper Limit",
        "fr": "Bracket 1 Upper Limit",
        "es": "Bracket 1 Upper Limit",
        "ar": "Bracket 1 Upper Limit"
      }
    },
    {
      "id": "bracket2Limit",
      "label": "Bracket 2 Upper Limit",
      "type": "number",
      "unit": "currency",
      "default": 50000,
      "businessContext": "Upper income limit of bracket 2.",
      "label_i18n": {
        "en": "Bracket 2 Upper Limit",
        "tr": "Bracket 2 Upper Limit",
        "de": "Bracket 2 Upper Limit",
        "fr": "Bracket 2 Upper Limit",
        "es": "Bracket 2 Upper Limit",
        "ar": "Bracket 2 Upper Limit"
      }
    }
  ],
  "formulas": {
    "bracket1Tax": "grossSalary <= bracket1Limit ? grossSalary * taxRate1 / 100 : bracket1Limit * taxRate1 / 100",
    "bracket2Tax": "grossSalary <= bracket1Limit ? 0 : grossSalary <= bracket2Limit ? (grossSalary - bracket1Limit) * taxRate2 / 100 : (bracket2Limit - bracket1Limit) * taxRate2 / 100",
    "bracket3Tax": "grossSalary <= bracket2Limit ? 0 : (grossSalary - bracket2Limit) * taxRate3 / 100",
    "totalTax": "bracket1Tax + bracket2Tax + bracket3Tax",
    "netSalary": "grossSalary - totalTax"
  },
  "outputs": {
    "primary": "totalTax",
    "breakdown": [
      "bracket1Tax",
      "bracket2Tax",
      "bracket3Tax",
      "netSalary"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netSalary",
    "unit": "currency"
  },
  "category": "İK & Personel",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

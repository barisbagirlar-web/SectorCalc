        "de": "Material Ultimate Tensile Strength",
        "fr": "Material Ultimate Tensile Strength",
        "es": "Material Ultimate Tensile Strength",
        "ar": "Material Ultimate Tensile Strength"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1.5,
      "businessContext": "Factor of safety applied to material strength for allowable stress.",

        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    }
  ],
  "formulas": {
    "primary": "4 * ((materialStrength * 1e6 / safetyFactor) * beamWidth * beamHeight ** 2 / 6) / spanLength / 1000",

{
  "toolName": "chain-drive-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "automotive-transport",
  "sector": "Mechanical, Automotive and Aviation",
  "sectorId": "automotive-transport",
  "inputs": [
    {
      "id": "Z1",
      "label": "Small Sprocket Teeth (Z1)",
      "type": "number",
      "unit": "teeth",
      "default": 17,
      "min": 6,
      "businessContext": "Drive sprocket."
    },
    {
      "id": "Z2",
      "label": "Large Sprocket Teeth (Z2)",
      "type": "number",
      "unit": "teeth",
      "default": 45,
      "min": 6,
      "businessContext": "Wheel sprocket."
    },
    {
      "id": "adim",
      "label": "Chain Pitch (mm)",
      "type": "number",
      "unit": "mm",
      "default": 12.7,
      "min": 0,
      "businessContext": "Chain link pitch."
    },
    {
      "id": "merkezC",
      "label": "Center Distance (mm)",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "min": 0,
      "businessContext": "Distance between sprockets."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "ratio": "Z2 / Math.max(1, Z1)",
    "result": "2*merkezC + (Z1+Z2)*adim/2 + Math.pow(((Z2-Z1)*adim)/(2*Math.PI), 2)/Math.max(0.0001, merkezC)"
  },
  "outputs": {
    "primary": "result",
    "unit": "mm",
    "breakdown": {
      "result": "Chain Length"
    },
    "breakdownUnits": {
      "result": "mm"
    },
    "hiddenLossDrivers": [
      "High fuel/energy consumption indicates efficiency losses."
    ],
    "suggestedActions": [
      "Regular maintenance improves overall equipment efficiency.",
      "Simulate real-world driving conditions for accurate range estimates."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate chain drive length and sprocket ratio.",
      "long": "Calculate chain drive length and sprocket ratio."
    }
  },
  "sectorSlug": "daily-renovation"
}

{
  "toolName": "compound-interest-calculator",
  "catalogCategory": "finance-business",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "anapara",
      "label": "Principal (USD)",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "min": 0,
      "businessContext": "Initial investment amount."
    },
    {
      "id": "interest",
      "label": "Annual Interest (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Annual nominal interest rate."
    },
    {
      "id": "year",
      "label": "Term (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "min": 0,
      "businessContext": "Total investment period."
    },
    {
      "id": "siklik",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "per year",
      "default": 12,
      "min": 1,
      "businessContext": "Number of compounding periods per year (12=monthly)."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "anapara * Math.pow(1 + (interest / 100) / Math.max(1, siklik), siklik * year)"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "Maturity Sonu Value"
    },
    "breakdownUnits": {
      "result": "USD"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate compound interest future value with periodic compounding.",
      "long": "Calculate compound interest future value with periodic compounding."
    }
  },
  "sectorSlug": "ecommerce"
}

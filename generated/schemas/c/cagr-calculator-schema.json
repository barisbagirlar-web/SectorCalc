{
  "toolName": "cagr-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "ilkDeger",
      "label": "Initial Value (USD)",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "min": 0,
      "businessContext": "Value at the beginning of the period."
    },
    {
      "id": "sonDeger",
      "label": "Final Value (USD)",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "min": 0,
      "businessContext": "Value at the end of the period."
    },
    {
      "id": "year",
      "label": "Period (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "min": 0,
      "businessContext": "Total investment period."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(Math.pow(sonDeger / Math.max(1, ilkDeger), 1 / Math.max(1, year)) - 1) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "CAGR (Compound Annual Growth Rate)"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate the compound annual growth rate (CAGR) over time.",
      "long": "Calculate the compound annual growth rate (CAGR) over time."
    }
  },
  "sectorSlug": "daily-renovation"
}

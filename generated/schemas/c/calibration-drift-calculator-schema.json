{
  "toolName": "calibration-drift-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "lean-production",
  "sector": "Industrial Engineering",
  "sectorId": "lean-production",
  "inputs": [
    {
      "id": "sonHata",
      "label": "Latest Error",
      "type": "number",
      "unit": "unit",
      "default": 0.5,
      "min": 0,
      "businessContext": "Error at last calibration."
    },
    {
      "id": "oncekiHata",
      "label": "Previous Error",
      "type": "number",
      "unit": "unit",
      "default": 0.2,
      "min": 0,
      "businessContext": "Previous calibration error."
    },
    {
      "id": "gecenSure",
      "label": "Elapsed Time (Days)",
      "type": "number",
      "unit": "days",
      "default": 90,
      "min": 0,
      "businessContext": "Time between calibrations."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(sonHata - oncekiHata) / Math.max(1, gecenSure)"
  },
  "outputs": {
    "primary": "result",
    "unit": "unit/day",
    "breakdown": {
      "result": "Drift Speed"
    },
    "breakdownUnits": {
      "result": "unit/day"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Conduct regular OEE audits for improvement.",
      "Use SMED to reduce setup times."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate measurement instrument drift rate over time.",
      "long": "Calculate measurement instrument drift rate over time."
    }
  },
  "sectorSlug": "daily-renovation"
}

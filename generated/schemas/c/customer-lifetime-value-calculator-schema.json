{
  "toolName": "customer-lifetime-value-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Business",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "ortSiparis",
      "label": "Avg Order Value (USD)",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "min": 0,
      "businessContext": "Average order value."
    },
    {
      "id": "siklik",
      "label": "Orders per Year",
      "type": "number",
      "unit": "per year",
      "default": 12,
      "min": 1,
      "businessContext": "Purchase frequency per year."
    },
    {
      "id": "omur",
      "label": "Customer Lifetime (Years)",
      "type": "number",
      "unit": "years",
      "default": 3,
      "min": 0,
      "businessContext": "Average customer retention."
    },
    {
      "id": "marj",
      "label": "Profit Margin (%)",
      "type": "number",
      "unit": "%",
      "default": 30,
      "min": 0,
      "max": 100,
      "businessContext": "Net profit margin."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "ortSiparis * siklik * omur * (marj / 100)"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "Customer Lifetime Value (CLV)"
    },
    "breakdownUnits": {
      "result": "USD"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [

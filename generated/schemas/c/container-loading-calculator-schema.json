{
  "toolName": "container-loading-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "other",
  "sector": "Lojistik",
  "sectorId": "other",
  "inputs": [
    {
      "id": "konteynerHacim",
      "label": "Container Volume (m³)",
      "type": "number",
      "unit": "m3",
      "default": 33,
      "min": 0,
      "businessContext": "Container internal volume."
    },
    {
      "id": "kutuHacim",
      "label": "Box Volume (m³)",
      "type": "number",
      "unit": "m3",
      "default": 0.036,
      "min": 0,
      "businessContext": "Volume per box."
    },
    {
      "id": "istifleme",
      "label": "Stacking Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 85,
      "min": 0,
      "max": 100,
      "businessContext": "Usable volume percentage."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.floor((konteynerHacim * (istifleme / 100)) / Math.max(0.0001, kutuHacim))"
  },
  "outputs": {
    "primary": "result",
    "unit": "boxes",
    "breakdown": {
      "result": "Maximum Kutu Count"
    },
    "breakdownUnits": {
      "result": "boxes"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inventory turnover metrics monthly.",
      "Factor in seasonality for safety stock."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate maximum boxes that fit in a shipping container.",
      "long": "Calculate maximum boxes that fit in a shipping container."
    }
  },
  "sectorSlug": "daily-renovation"
}

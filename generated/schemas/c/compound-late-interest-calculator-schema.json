{
  "toolName": "compound-late-interest-calculator",
  "catalogCategory": "finance-business",
  "categorySlug": "other",
  "sector": "Spor, Mimari, Robotik ve Hukuk",
  "sectorId": "other",
  "inputs": [
    {
      "id": "anapara",
      "label": "Principal (TL)",
      "type": "number",
      "unit": "TL",
      "default": 10000,
      "min": 0,
      "businessContext": "Principal debt amount."
    },
    {
      "id": "yillikFaiz",
      "label": "Annual Late Interest (%)",
      "type": "number",
      "unit": "%",
      "default": 24,
      "min": 0,
      "businessContext": "Legal default interest rate."
    },
    {
      "id": "gecikmeGun",
      "label": "Days Overdue",
      "type": "number",
      "unit": "days",
      "default": 90,
      "min": 0,
      "businessContext": "Days past due."
    },
    {
      "id": "bilesimSikligi",
      "label": "Compounding Frequency (Days)",
      "type": "number",
      "unit": "days",
      "default": 30,
      "min": 0,
      "businessContext": "Interest capitalization period."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "anapara * Math.pow((1 + (yillikFaiz / 100) * (bilesimSikligi / 365)), gecikmeGun / Math.max(1, bilesimSikligi))"
  },
  "outputs": {
    "primary": "result",
    "unit": "TL",
    "breakdown": {
      "result": "Total Liabilities"
    },
    "breakdownUnits": {
      "result": "TL"
    },
    "hiddenLossDrivers": [
      "High asymmetry increases injury risk.",
      "Low H-index may indicate limited academic impact."
    ],
    "suggestedActions": [
      "Balance training for injury prevention.",
      "Use peer review to validate research quality."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate compound late payment interest on principal debt.",
      "long": "Calculate compound late payment interest on principal debt."

      "label": "Ambient Temperature (°C)",
      "type": "number",
      "unit": "°C",
      "default": 35,
      "min": 0,
      "businessContext": "Outside air temperature."
    },
    {
      "id": "icSicaklik",
      "label": "Storage Temperature (°C)",
      "type": "number",
      "unit": "°C",
      "default": -20,
      "min": 0,

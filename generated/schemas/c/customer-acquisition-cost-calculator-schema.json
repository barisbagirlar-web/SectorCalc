      "min": 0,
      "businessContext": "Marketing expenses."
    },
    {
      "id": "satisGideri",
      "label": "Sales Cost (USD)",
      "type": "number",
      "unit": "USD",
      "default": 30000,
      "min": 0,
      "businessContext": "Sales team costs."
    },
    {
      "id": "yeniMusteri",
      "label": "New Customers",
      "type": "number",
      "unit": "customers",
      "default": 100,
      "min": 0,
      "businessContext": "New customers acquired."

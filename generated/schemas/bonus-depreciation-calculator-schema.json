{
  "toolName": "bonus-depreciation-calculator",
  "inputs": [
    {
      "id": "assetCost",
      "label": "Asset Cost (Purchase Price)",
      "type": "number",
      "unit": "$",
      "default": 10000,
      "businessContext": "The total cost of the asset before any deductions.",
      "label_i18n": {
        "en": "Asset Cost (Purchase Price)",
        "tr": "Asset Cost (Purchase Price)",
        "de": "Asset Cost (Purchase Price)",
        "fr": "Asset Cost (Purchase Price)",
        "es": "Asset Cost (Purchase Price)",
        "ar": "Asset Cost (Purchase Price)"
      }
    },
    {
      "id": "bonusRate",
      "label": "Bonus Depreciation Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "The applicable bonus depreciation percentage for the tax year.",
      "label_i18n": {
        "en": "Bonus Depreciation Rate (%)",
        "tr": "Bonus Depreciation Rate (%)",
        "de": "Bonus Depreciation Rate (%)",
        "fr": "Bonus Depreciation Rate (%)",
        "es": "Bonus Depreciation Rate (%)",
        "ar": "Bonus Depreciation Rate (%)"
      }
    },
    {
      "id": "businessUse",
      "label": "Business Use Percentage",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "The percentage the asset is used for business purposes.",
      "label_i18n": {
        "en": "Business Use Percentage",
        "tr": "Business Use Percentage",
        "de": "Business Use Percentage",
        "fr": "Business Use Percentage",
        "es": "Business Use Percentage",
        "ar": "Business Use Percentage"
      }
    },
    {
      "id": "section179",
      "label": "Section 179 Deduction",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Any Section 179 deduction claimed on this asset before bonus depreciation.",
      "label_i18n": {
        "en": "Section 179 Deduction",
        "tr": "Section 179 Deduction",
        "de": "Section 179 Deduction",
        "fr": "Section 179 Deduction",
        "es": "Section 179 Deduction",
        "ar": "Section 179 Deduction"
      }
    }
  ],
  "formulas": {
    "bonusDepreciation": "(assetCost - section179) * (bonusRate / 100) * (businessUse / 100)",
    "remainingBasis": "assetCost - section179 - ((assetCost - section179) * (bonusRate / 100) * (businessUse / 100))",
    "totalFirstYear": "section179 + ((assetCost - section179) * (bonusRate / 100) * (businessUse / 100))"
  },
  "outputs": {
    "primary": "bonusDepreciation",
    "breakdown": [
      "remainingBasis",
      "totalFirstYear"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalFirstYear"
  },

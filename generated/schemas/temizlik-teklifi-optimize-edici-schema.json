  "formulas": {
    "AreaToClean": "TotalSqM * CleanablePct",
    "LaborHours": "AreaToClean / ProductionRatePerHour",
    "LaborCost": "LaborHours * HourlyWage * (1 + Burden)",
    "MaterialCost": "AreaToClean * ConsumableCostPerSqM",
    "EquipmentCost": "MachineHours * DepreciationRate",
    "Overhead": "(LaborCost + MaterialCost) * OverheadPct",
    "BidPrice": "(LaborCost + MaterialCost + EquipmentCost + Overhead) / (1 - TargetMargin)"
  },

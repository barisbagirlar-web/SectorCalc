{
  "toolName": "dividend-tax-calculator",
  "inputs": [
    {
      "id": "grossDividend",
      "label": "Gross Dividend",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "Total dividend received before any taxes or deductions",
      "label_i18n": {
        "en": "Gross Dividend",
        "tr": "Gross Dividend",
        "de": "Gross Dividend",
        "fr": "Gross Dividend",
        "es": "Gross Dividend",
        "ar": "Gross Dividend"
      }
    },
    {
      "id": "taxFreeAllowance",
      "label": "Tax-Free Allowance",
      "type": "number",
      "unit": "currency",
      "default": 2000,
      "businessContext": "Amount of dividend exempt from taxation",
      "label_i18n": {
        "en": "Tax-Free Allowance",
        "tr": "Tax-Free Allowance",
        "de": "Tax-Free Allowance",
        "fr": "Tax-Free Allowance",
        "es": "Tax-Free Allowance",
        "ar": "Tax-Free Allowance"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Basic tax rate applied to taxable dividends",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "surchargeRate",
      "label": "Surcharge Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional surcharge on the basic tax amount",
      "label_i18n": {
        "en": "Surcharge Rate",
        "tr": "Surcharge Rate",
        "de": "Surcharge Rate",
        "fr": "Surcharge Rate",
        "es": "Surcharge Rate",
        "ar": "Surcharge Rate"
      }
    },
    {
      "id": "cessRate",
      "label": "Cess Rate",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Cess levied on the sum of basic tax and surcharge",
      "label_i18n": {
        "en": "Cess Rate",
        "tr": "Cess Rate",
        "de": "Cess Rate",
        "fr": "Cess Rate",
        "es": "Cess Rate",
        "ar": "Cess Rate"
      }
    }
  ],
  "formulas": {
    "taxableDividend": "grossDividend - taxFreeAllowance",
    "basicTax": "taxableDividend * taxRate / 100",
    "surcharge": "basicTax * surchargeRate / 100",
    "cess": "(basicTax + surcharge) * cessRate / 100",
    "totalTax": "basicTax + surcharge + cess",
    "netDividend": "grossDividend - totalTax"
  },
  "outputs": {
    "primary": "totalTax",
    "breakdown": [
      "basicTax",
      "surcharge",
      "cess",
      "netDividend"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netDividend"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",

{
  "toolName": "rental-income-calculator",
  "inputs": [
    {
      "id": "monthlyRent",
      "label": "Monthly Rent",
      "type": "number",
      "unit": "USD",
      "default": 1500,
      "businessContext": "The monthly rental income from the property.",
      "label_i18n": {
        "en": "Monthly Rent",
        "tr": "Monthly Rent",
        "de": "Monthly Rent",
        "fr": "Monthly Rent",
        "es": "Monthly Rent",
        "ar": "Monthly Rent"
      }
    },
    {
      "id": "occupancyRate",
      "label": "Occupancy Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Expected occupancy rate as a percentage of the year.",
      "label_i18n": {
        "en": "Occupancy Rate (%)",
        "tr": "Occupancy Rate (%)",
        "de": "Occupancy Rate (%)",
        "fr": "Occupancy Rate (%)",
        "es": "Occupancy Rate (%)",
        "ar": "Occupancy Rate (%)"
      }
    },
    {
      "id": "managementFeePercent",
      "label": "Management Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage of gross income for property management.",
      "label_i18n": {
        "en": "Management Fee (%)",
        "tr": "Management Fee (%)",
        "de": "Management Fee (%)",
        "fr": "Management Fee (%)",
        "es": "Management Fee (%)",
        "ar": "Management Fee (%)"
      }
    },
    {
      "id": "maintenanceMonthly",
      "label": "Monthly Maintenance",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Estimated monthly maintenance and repair costs.",
      "label_i18n": {
        "en": "Monthly Maintenance",
        "tr": "Monthly Maintenance",
        "de": "Monthly Maintenance",
        "fr": "Monthly Maintenance",
        "es": "Monthly Maintenance",
        "ar": "Monthly Maintenance"
      }
    },
    {
      "id": "insuranceMonthly",
      "label": "Monthly Insurance",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Monthly insurance premium.",
      "label_i18n": {
        "en": "Monthly Insurance",
        "tr": "Monthly Insurance",
        "de": "Monthly Insurance",
        "fr": "Monthly Insurance",
        "es": "Monthly Insurance",
        "ar": "Monthly Insurance"
      }
    },
    {
      "id": "propertyTaxAnnual",
      "label": "Annual Property Tax",
      "type": "number",
      "unit": "USD",
      "default": 2000,
      "businessContext": "Annual property tax amount.",
      "label_i18n": {
        "en": "Annual Property Tax",
        "tr": "Annual Property Tax",
        "de": "Annual Property Tax",
        "fr": "Annual Property Tax",
        "es": "Annual Property Tax",
        "ar": "Annual Property Tax"
      }
    }
  ],
  "formulas": {
    "grossAnnualIncome": "monthlyRent * 12 * (occupancyRate / 100)",
    "managementFees": "grossAnnualIncome * (managementFeePercent / 100)",
    "totalMaintenance": "maintenanceMonthly * 12",
    "totalInsurance": "insuranceMonthly * 12",
    "totalExpenses": "managementFees + totalMaintenance + totalInsurance + propertyTaxAnnual",
    "netAnnualIncome": "grossAnnualIncome - totalExpenses",
    "netMonthlyIncome": "netAnnualIncome / 12"
  },
  "outputs": {
    "primary": "netAnnualIncome",
    "breakdown": [
      "grossAnnualIncome",
      "totalExpenses",
      "managementFees",
      "totalMaintenance",
      "totalInsurance",
      "propertyTaxAnnual"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netMonthlyIncome",
    "unit": "USD"
  },

      "label": "Personal Correction Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier to adjust for individual physiological differences (e.g., efficiency, fitness level). Default 1.0 indicates standard estimation.",

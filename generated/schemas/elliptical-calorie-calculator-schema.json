        "fr": "Personal Correction Factor",
        "es": "Personal Correction Factor",
        "ar": "Personal Correction Factor"
      }
    }
  ],
  "formulas": {
    "totalCalories": "weight * met * (duration / 60) * correctionFactor",
    "caloriesPerMinute": "weight * met * correctionFactor / 60",

  "validation": {
    "rules": [
      {
        "field": "mn",
        "condition": "mn > 0",
        "message": "Normal module must be positive"
      },
      {
        "field": "z",
        "condition": "z >= 5",
        "message": "Number of teeth must be at least 5"
      },
      {
        "field": "beta",
        "condition": "beta >= 0 && beta < 45",
        "message": "Helix angle must be between 0 and 45 degrees"
      },
      {
        "field": "alpha",
        "condition": "alpha > 0 && alpha < 45",
        "message": "Pressure angle must be between 0 and 45 degrees"
      },
      {
        "field": "ha",
        "condition": "ha > 0",
        "message": "Addendum coefficient must be positive"
      },
      {
        "field": "c",
        "condition": "c >= 0",
        "message": "Dedendum coefficient must be non-negative"
      }
    ],
    "thresholds": {}
  },
  "premiumFeatures": [],
  "domainModel": "general"
}

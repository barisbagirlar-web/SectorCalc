{
  "toolName": "wilks-calculator",
  "inputs": [
    {
      "id": "bodyWeight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 83,
      "businessContext": "The body weight of the lifter in kilograms."
    },
    {
      "id": "liftedWeight",
      "label": "Lifted Weight",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The weight lifted in the competition lift."
    }
  ],
  "formulas": {
    "coefficient": "500 / (-216.0475144 + 16.2606339 * bodyWeight - 0.002388645 * bodyWeight**2 - 0.00113732 * bodyWeight**3 + 7.01863e-6 * bodyWeight**4 - 1.291e-8 * bodyWeight**5)",
    "wilksScore": "coefficient * liftedWeight"
  },
  "outputs": {
    "primary": "wilksScore",
    "breakdown": [
      "coefficient",
      "bodyWeight",
      "liftedWeight"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
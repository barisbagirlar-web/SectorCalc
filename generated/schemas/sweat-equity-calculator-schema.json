        "ar": "Pre-Money Valuation"
      }
    },
    {
      "id": "cashInvestment",
      "label": "Cash Investment",
      "type": "number",
      "unit": "USD",
      "default": 200000,
      "businessContext": "Total cash investment from other parties.",
      "label_i18n": {
        "en": "Cash Investment",
        "tr": "Cash Investment",
        "de": "Cash Investment",
        "fr": "Cash Investment",
        "es": "Cash Investment",
        "ar": "Cash Investment"
      }
    },
    {
      "id": "hoursWorked",
      "label": "Hours Worked",
      "type": "number",
      "unit": "hours",
      "default": 2000,
      "businessContext": "Total hours contributed as sweat equity.",
      "label_i18n": {
        "en": "Hours Worked",
        "tr": "Hours Worked",
        "de": "Hours Worked",
        "fr": "Hours Worked",
        "es": "Hours Worked",
        "ar": "Hours Worked"
      }
    },
    {
      "id": "hourlyRate",
      "label": "Hourly Rate",
      "type": "number",
      "unit": "USD/hour",
      "default": 50,
      "businessContext": "Market hourly rate for the contributor's skills.",
      "label_i18n": {
        "en": "Hourly Rate",
        "tr": "Hourly Rate",
        "de": "Hourly Rate",
        "fr": "Hourly Rate",
        "es": "Hourly Rate",
        "ar": "Hourly Rate"
      }
    }
  ],
  "formulas": {
    "sweatValue": "hoursWorked * hourlyRate",
    "postMoneyValuation": "preMoneyValuation + cashInvestment + sweatValue",
    "equityPercentage": "(sweatValue / postMoneyValuation) * 100"
  },
  "outputs": {
    "primary": "equityPercentage",
    "breakdown": [
      "sweatValue",
      "postMoneyValuation",
      "equityPercentage"
    ],

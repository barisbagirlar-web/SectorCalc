      }
    },
    {
      "id": "hoursWorked",
      "label": "Hours Worked",
      "type": "number",
      "unit": "hours",
      "default": 2000,
      "businessContext": "Total hours contributed as sweat equity.",
      "label_i18n": {
        "en": "Hours Worked",
        "tr": "Çalışılan Saat",
        "de": "Hours Worked",
        "fr": "Hours Worked",
        "es": "Hours Worked",
        "ar": "Hours Worked"
      },
      "businessContext_i18n": {
        "en": "Total hours contributed as sweat equity.",
        "tr": "Emek sermayesi olarak katkıda bulunulan toplam saat."
      }
    },
    {
      "id": "hourlyRate",
      "label": "Hourly Rate",
      "type": "number",
      "unit": "USD/hour",
      "default": 50,
      "businessContext": "Market hourly rate for the contributor's skills.",
      "label_i18n": {
        "en": "Hourly Rate",
        "tr": "Saatlik Ücret",
        "de": "Stundensatz",
        "fr": "Hourly Rate",
        "es": "Hourly Rate",
        "ar": "Hourly Rate"
      },
      "businessContext_i18n": {
        "en": "Market hourly rate for the contributor's skills.",
        "tr": "Katkıda bulunan kişinin becerileri için piyasa saatlik ücreti."
      }
    }
  ],
  "formulas": {
    "sweatValue": "hoursWorked * hourlyRate",
    "postMoneyValuation": "preMoneyValuation + cashInvestment + sweatValue",
    "equityPercentage": "(sweatValue / postMoneyValuation) * 100"
  },
  "outputs": {
    "primary": "equityPercentage",
    "breakdown": [
      "sweatValue",
      "postMoneyValuation",
      "equityPercentage"
    ],

    {
      "id": "cashInvestment",
      "label": "Cash Investment",
      "type": "number",
      "unit": "USD",
      "default": 200000,
      "businessContext": "Total cash investment from other parties.",
      "label_i18n": {
        "en": "Cash Investment",
        "tr": "Nakit Yatırım",
        "de": "Cash Investment",

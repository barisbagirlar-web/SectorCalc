      "id": "preMoneyValuation",
      "label": "Pre-Money Valuation",
      "type": "number",
      "unit": "USD",
      "default": 1000000,
      "businessContext": "Company valuation before any investment or sweat equity.",
      "label_i18n": {
        "en": "Pre-Money Valuation",
        "tr": "Yatırım Öncesi Değerleme",

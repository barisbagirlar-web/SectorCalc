{
  "toolName": "weight-training-calorie-calculator",
  "inputs": [
    {
      "id": "bodyWeight",
      "label": "Vücut Ağırlığı",
      "type": "number",
      "unit": "kg",
      "default": 75,
      "businessContext": "Kullanıcının vücut ağırlığı (kg)"
    },
    {
      "id": "durationHours",
      "label": "Süre (Saat)",
      "type": "number",
      "unit": "saat",
      "default": 0,
      "businessContext": "Antrenman süresi saat cinsinden"
    },
    {
      "id": "durationMinutes",
      "label": "Süre (Dakika)",
      "type": "number",
      "unit": "dk",
      "default": 45,
      "businessContext": "Antrenman süresi dakika cinsinden"
    },
    {
      "id": "metValue",
      "label": "MET Değeri",
      "type": "number",
      "unit": "MET",
      "default": 4,
      "businessContext": "Aktivitenin MET (Metabolik Eşdeğer) değeri. Ağırlık antrenmanı için genellikle 3-6 arası"
    }
  ],
  "formulas": {
    "totalDurationHours": "durationHours + durationMinutes / 60",
    "caloriesBurned": "metValue * bodyWeight * totalDurationHours",
    "totalMinutes": "durationHours * 60 + durationMinutes",
    "caloriesPerMinute": "caloriesBurned / totalMinutes"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "totalDurationHours",
      "caloriesPerMinute"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
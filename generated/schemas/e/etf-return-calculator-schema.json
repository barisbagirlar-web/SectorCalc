{
  "toolName": "etf-return-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "alisFiyati",
      "label": "Purchase Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "min": 0,
      "businessContext": "ETF purchase price."
    },
    {
      "id": "satisFiyati",
      "label": "Sell Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 115,
      "min": 0,
      "businessContext": "ETF sell price."
    },
    {
      "id": "temettu",
      "label": "Dividend (USD)",
      "type": "number",
      "unit": "USD",
      "default": 2,
      "min": 0,
      "businessContext": "Dividend distributed."
    },
    {
      "id": "giderOrani",
      "label": "Expense Ratio (%)",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "min": 0,
      "businessContext": "Annual management fee."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "((satisFiyati + temettu - alisFiyati) / Math.max(1, alisFiyati) * 100) - giderOrani"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "Net ETF Getirisi"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],

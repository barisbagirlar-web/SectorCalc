  "inputs": [
    {
      "id": "yillikTalep",
      "label": "Annual Demand",
      "type": "number",
      "unit": "units",
      "default": 10000,
      "min": 1,
      "businessContext": "Annual total demand."
    },
    {
      "id": "siparisMaliyeti",
      "label": "Order Cost (USD)",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "min": 0,
      "businessContext": "Fixed cost per order."
    },
    {
      "id": "tasimaMaliyeti",
      "label": "Holding Cost (USD/Unit/yr)",
      "type": "number",
      "unit": "USD",
      "default": 5,
      "min": 0,
      "businessContext": "Annual holding cost per unit."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.sqrt(Math.max(0, (2 * yillikTalep * siparisMaliyeti) / Math.max(0.0001, tasimaMaliyeti)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "units",
    "breakdown": {
      "result": "EOQ (Optimum Siparis Amounti)"
    },
    "breakdownUnits": {
      "result": "units"
    },

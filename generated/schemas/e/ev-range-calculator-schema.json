{
  "toolName": "ev-range-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "automotive-transport",
  "sector": "Mechanical, Automotive and Aviation",
  "sectorId": "automotive-transport",
  "inputs": [
    {
      "id": "bataryaEnerji",
      "label": "Battery Energy (kWh)",
      "type": "number",
      "unit": "kWh",
      "default": 60,
      "min": 0,
      "businessContext": "Usable battery capacity."
    },
    {
      "id": "tuketim",
      "label": "Energy Consumption (Wh/km)",
      "type": "number",
      "unit": "Wh/km",
      "default": 180,
      "min": 0,
      "businessContext": "Energy consumption per km."
    },
    {
      "id": "efficiency",
      "label": "Drivetrain Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "businessContext": "Motor-to-wheel efficiency."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(bataryaEnerji * 1000 * (efficiency / 100)) / Math.max(0.0001, tuketim)"
  },
  "outputs": {
    "primary": "result",
    "unit": "km",
    "breakdown": {
      "result": "Tahmini Menzil"
    },
    "breakdownUnits": {
      "result": "km"
    },
    "hiddenLossDrivers": [
      "High fuel/energy consumption indicates efficiency losses."
    ],
    "suggestedActions": [
      "Regular maintenance improves overall equipment efficiency.",
      "Simulate real-world driving conditions for accurate range estimates."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate EV range on a full charge.",
      "long": "Calculate EV range on a full charge."
    }
  },
  "sectorSlug": "daily-renovation"
}

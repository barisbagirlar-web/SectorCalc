{
  "toolName": "ev-charging-time-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "automotive-transport",
  "sector": "Mechanical, Automotive and Aviation",
  "sectorId": "automotive-transport",
  "inputs": [
    {
      "id": "bataryaKapasite",
      "label": "Battery Capacity (kWh)",
      "type": "number",
      "unit": "kWh",
      "default": 60,
      "min": 0,
      "businessContext": "Total battery energy."
    },
    {
      "id": "sarjGuc",
      "label": "Charging Power (kW)",
      "type": "number",
      "unit": "kW",
      "default": 7.4,
      "min": 0,
      "businessContext": "Charger power."
    },
    {
      "id": "efficiency",
      "label": "Charging Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "businessContext": "Charging losses."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "bataryaKapasite / Math.max(0.0001, (sarjGuc * (efficiency / 100)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "hours",
    "breakdown": {
      "result": "Charging Time"
    },
    "breakdownUnits": {
      "result": "hours"
    },
    "hiddenLossDrivers": [
      "High fuel/energy consumption indicates efficiency losses."
    ],
    "suggestedActions": [
      "Regular maintenance improves overall equipment efficiency.",
      "Simulate real-world driving conditions for accurate range estimates."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate EV battery charging time from 0 to 100%.",
      "long": "Calculate EV battery charging time from 0 to 100%."
    }
  },
  "sectorSlug": "daily-renovation"
}

  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "vidaHacim",
      "label": "Screw Volume (cm³/rev)",
      "type": "number",
      "unit": "cm3/rev",
      "default": 100,
      "min": 0,
      "businessContext": "Screw channel volume."
    },
    {
      "id": "devir",
      "label": "Screw Speed (RPM)",
      "type": "number",
      "unit": "rpm",
      "default": 60,
      "min": 0,
      "businessContext": "Screw rotational speed."
    },
    {
      "id": "eriyikYogunluk",
      "label": "Melt Density (g/cm³)",
      "type": "number",
      "unit": "g/cm3",
      "default": 0.9,
      "min": 0,
      "businessContext": "Melt polymer density."
    },
    {
      "id": "efficiency",
      "label": "Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 85,
      "min": 0,
      "businessContext": "Extruder efficiency."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(vidaHacim * devir * eriyikYogunluk * (efficiency / 100) * 60) / 1000"
  },
  "outputs": {
    "primary": "result",
    "unit": "kg/h",
    "breakdown": {

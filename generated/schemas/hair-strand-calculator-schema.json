{
  "toolName": "hair-strand-calculator",
  "inputs": [
    {
      "id": "scalpArea",
      "label": "Scalp Surface Area",
      "type": "number",
      "unit": "cm²",
      "default": 700,
      "businessContext": "The surface area of the scalp in square centimeters. Typical adult scalp area ranges from 600 to 800 cm².",
      "label_i18n": {
        "en": "Scalp Surface Area",
        "tr": "Scalp Surface Area",
        "de": "Scalp Surface Area",
        "fr": "Scalp Surface Area",
        "es": "Scalp Surface Area",
        "ar": "Scalp Surface Area"
      }
    },
    {
      "id": "hairDensity",
      "label": "Hair Density",
      "type": "number",
      "unit": "strands/cm²",
      "default": 200,
      "businessContext": "Average number of hair strands per square centimeter. Typical range is 100-300 strands/cm².",
      "label_i18n": {
        "en": "Hair Density",
        "tr": "Hair Density",
        "de": "Hair Density",
        "fr": "Hair Density",
        "es": "Hair Density",
        "ar": "Hair Density"
      }
    },
    {
      "id": "averageHairLength",
      "label": "Average Hair Length",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "The average length of hair strands from root to tip in centimeters.",
      "label_i18n": {
        "en": "Average Hair Length",
        "tr": "Average Hair Length",
        "de": "Average Hair Length",
        "fr": "Average Hair Length",
        "es": "Average Hair Length",
        "ar": "Average Hair Length"
      }
    },
    {
      "id": "dailyHairLoss",
      "label": "Daily Hair Loss",
      "type": "number",
      "unit": "strands/day",
      "default": 80,
      "businessContext": "Typical number of hair strands lost per day, normally between 50 and 100.",
      "label_i18n": {
        "en": "Daily Hair Loss",
        "tr": "Daily Hair Loss",
        "de": "Daily Hair Loss",
        "fr": "Daily Hair Loss",
        "es": "Daily Hair Loss",
        "ar": "Daily Hair Loss"
      }
    }
  ],
  "formulas": {
    "totalHairStrands": "scalpArea * hairDensity",
    "totalLength": "totalHairStrands * averageHairLength",
    "turnoverDays": "totalHairStrands / dailyHairLoss"
  },
  "outputs": {
    "primary": "totalHairStrands",
    "breakdown": [

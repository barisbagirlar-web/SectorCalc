  "formulas": {
    "effectiveRadius": "radius + diameter / 2",
    "angleRadiansTotal": "angleRadians + angleDegrees * (Math.PI / 180)",
    "radiusSquared": "effectiveRadius ** 2",
    "sectorArea": "0.5 * radiusSquared * angleRadiansTotal"
  },

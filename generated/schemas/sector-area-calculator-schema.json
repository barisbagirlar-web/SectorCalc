{
  "toolName": "sector-area-calculator",
  "inputs": [
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Enter radius (in meters). Leave 0 if using diameter."
    },
    {
      "id": "diameter",
      "label": "Diameter",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Enter diameter (in meters). Leave 0 if using radius."
    },
    {
      "id": "angleDegrees",
      "label": "Central Angle (degrees)",
      "type": "number",
      "unit": "°",
      "default": 90,
      "businessContext": "Enter angle in degrees. Leave 0 if using radians."
    },
    {
      "id": "angleRadians",
      "label": "Central Angle (radians)",
      "type": "number",
      "unit": "rad",
      "default": 0,
      "businessContext": "Enter angle in radians. Leave 0 if using degrees."
    }
  ],
  "formulas": {
    "effectiveRadius": "radius + diameter / 2",
    "angleRadiansTotal": "angleRadians + angleDegrees * (Math.PI / 180)",
    "radiusSquared": "effectiveRadius ** 2",
    "sectorArea": "0.5 * radiusSquared * angleRadiansTotal"
  },
  "outputs": {
    "primary": "sectorArea",
    "breakdown": [
      "effectiveRadius",
      "angleRadiansTotal",
      "radiusSquared"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

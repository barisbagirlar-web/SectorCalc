        "es": "Net Kredili Satışlar",
        "ar": "Net Kredili Satışlar"
      }
    },
    {
      "id": "periodDays",
      "label": "Dönem Gün Sayısı",
      "type": "number",
      "unit": "gün",
      "default": 365,
      "businessContext": "DSO hesaplanacak dönemin gün sayısı (genellikle 365 veya 90)",
      "label_i18n": {
        "en": "Dönem Gün Sayısı",
        "tr": "Dönem Gün Sayısı",
        "de": "Dönem Gün Sayısı",

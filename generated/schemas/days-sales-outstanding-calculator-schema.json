        "es": "Dönem Gün Sayısı",
        "ar": "Dönem Gün Sayısı"
      }
    }
  ],
  "formulas": {
    "averageAR": "(beginningAR + endingAR) / 2",
    "dso": "netCreditSales !== 0 ? (averageAR / netCreditSales * periodDays) : null"
  },

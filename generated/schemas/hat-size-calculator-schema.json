{
  "toolName": "hat-size-calculator",
  "inputs": [
    {
      "id": "headCircumference",
      "label": "Head Circumference",
      "type": "number",
      "unit": "cm",
      "default": 58,
      "businessContext": "Measured circumference around widest part of head.",
      "label_i18n": {
        "en": "Head Circumference",
        "tr": "Head Circumference",
        "de": "Head Circumference",
        "fr": "Head Circumference",
        "es": "Head Circumference",
        "ar": "Head Circumference"
      }
    },
    {
      "id": "unitSystem",
      "label": "Measurement System",
      "type": "number",
      "unit": "0=cm,1=inches",
      "default": 0,
      "businessContext": "0 for metric input in cm, 1 for imperial input in inches.",
      "label_i18n": {
        "en": "Measurement System",
        "tr": "Measurement System",
        "de": "Measurement System",
        "fr": "Measurement System",
        "es": "Measurement System",
        "ar": "Measurement System"
      }
    },
    {
      "id": "hairThickness",
      "label": "Hair Thickness Allowance",
      "type": "number",
      "unit": "cm",
      "default": 0.5,
      "businessContext": "Extra centimeters to add for thick hair (0 for none).",
      "label_i18n": {
        "en": "Hair Thickness Allowance",
        "tr": "Hair Thickness Allowance",
        "de": "Hair Thickness Allowance",
        "fr": "Hair Thickness Allowance",
        "es": "Hair Thickness Allowance",
        "ar": "Hair Thickness Allowance"
      }
    },
    {
      "id": "fitPreference",
      "label": "Fit Preference",
      "type": "number",
      "unit": "tight=0,standard=1,loose=2",
      "default": 1,
      "businessContext": "0 for tight fit (subtract 0.5 cm), 1 for standard, 2 for loose fit (add 0.5 cm).",
      "label_i18n": {
        "en": "Fit Preference",
        "tr": "Fit Preference",
        "de": "Fit Preference",
        "fr": "Fit Preference",
        "es": "Fit Preference",
        "ar": "Fit Preference"
      }
    }
  ],
  "formulas": {
    "usSize": "((headCircumference * (unitSystem === 1 ? 2.54 : 1)) + hairThickness + (fitPreference === 0 ? -0.5 : fitPreference === 2 ? 0.5 : 0)) / 2.54 / Math.PI",
    "euSize": "(headCircumference * (unitSystem === 1 ? 2.54 : 1)) + hairThickness + (fitPreference === 0 ? -0.5 : fitPreference === 2 ? 0.5 : 0)",
    "ukSize": "((headCircumference * (unitSystem === 1 ? 2.54 : 1)) + hairThickness + (fitPreference === 0 ? -0.5 : fitPreference === 2 ? 0.5 : 0)) / 2.54 / Math.PI - 0.125"
  },
  "outputs": {
    "primary": "usSize",
    "breakdown": [
      "euSize",
      "ukSize"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "ukSize"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Birim & Dönüşüm",

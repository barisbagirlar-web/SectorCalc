{
  "toolName": "cycling-ctl-calculator",
  "inputs": [
    {
      "id": "startCTL",
      "label": "Current CTL",
      "type": "number",
      "unit": "TSS",
      "default": 50,
      "businessContext": "Current Chronic Training Load value"
    },
    {
      "id": "dailyTSS",
      "label": "Daily TSS",
      "type": "number",
      "unit": "TSS",
      "default": 70,
      "businessContext": "Training Stress Score per day for the forecast period"
    },
    {
      "id": "timeConstant",
      "label": "Time Constant",
      "type": "number",
      "unit": "days",
      "default": 42,
      "businessContext": "Decay time constant for CTL (typically 42 days)"
    },
    {
      "id": "numDays",
      "label": "Number of Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of consecutive days with the given Daily TSS"
    }
  ],
  "formulas": {
    "steadyStateCTL": "dailyTSS",
    "decayFactor": "Math.exp(-numDays / timeConstant)",
    "finalCTL": "dailyTSS + (startCTL - dailyTSS) * decayFactor"
  },
  "outputs": {
    "primary": "`Projected CTL after ${numDays} days: ${finalCTL.toFixed(1)} TSS`",
    "breakdown": [
      "`Steady-state CTL: ${steadyStateCTL} TSS`",
      "`Decay factor: ${decayFactor.toFixed(3)}`"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

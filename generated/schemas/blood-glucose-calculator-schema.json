  "formulas": {
    "result": "(mode===1 ? (unitFrom===1 ? (unitTo===2 ? value1/18.0182 : value1) : (unitTo===1 ? value1*18.0182 : value1)) : mode===2 ? 28.7*value1 - 46.7 : (value1 + 46.7)/28.7)",
    "result_aux": "(mode===1 ? (unitFrom===1 ? (unitTo===2 ? value1/18.0182 : value1) : (unitTo===1 ? value1*18.0182 : value1)) : mode===2 ? 28.7*value1 - 46.7 : (value1 + 46.7)/28.7)"
  },

      "label_i18n": {
        "en": "Length (L)",
        "tr": "Length (L)",
        "de": "Length (L)",
        "fr": "Length (L)",
        "es": "Length (L)",
        "ar": "Length (L)"
      }
    },
    {
      "id": "referenceLength",
      "label": "Reference Length",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "A standard length over which to compute the diameter reduction (e.g., 100 mm)",
      "label_i18n": {
        "en": "Reference Length",
        "tr": "Reference Length",
        "de": "Reference Length",
        "fr": "Reference Length",
        "es": "Reference Length",
        "ar": "Reference Length"
      }
    }
  ],
  "formulas": {
    "taperRatio": "(largeDiameter - smallDiameter) / length",
    "taperPerRefLength": "((largeDiameter - smallDiameter) / length) * referenceLength",
    "taperAngleDeg": "2 * Math.atan((largeDiameter - smallDiameter) / (2 * length)) * (180 / Math.PI)"
  },
  "outputs": {
    "primary": "taperRatio",
    "breakdown": [
      "taperRatio",
      "taperPerRefLength",
      "taperAngleDeg"
    ]
  },

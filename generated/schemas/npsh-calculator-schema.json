  "formulas": {
    "atmHead": "(atmosphericPressure * 100000) / (liquidDensity * 9.80665)",
    "vaporHead": "(vaporPressure * 100000) / (liquidDensity * 9.80665)",
    "npsha": "atmHead - vaporHead + staticSuctionHead + velocityHead - frictionHeadLoss"

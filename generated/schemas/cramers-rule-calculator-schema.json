  "formulas": {
    "detA": "a11*(a22*a33 - a23*a32) - a12*(a21*a33 - a23*a31) + a13*(a21*a32 - a22*a31)",
    "detA1": "b1*(a22*a33 - a23*a32) - a12*(b2*a33 - a23*b3) + a13*(b2*a32 - a22*b3)",
    "detA2": "a11*(b2*a33 - a23*b3) - b1*(a21*a33 - a23*a31) + a13*(a21*b3 - b2*a31)",
    "detA3": "a11*(a22*b3 - b2*a32) - a12*(a21*b3 - b2*a31) + b1*(a21*a32 - a22*a31)",
    "x1": "detA1 / detA",
    "x2": "detA2 / detA",
    "x3": "detA3 / detA"
  },
  "outputs": {
    "primary": "x1 = detA1/detA, x2 = detA2/detA, x3 = detA3/detA",
    "breakdown": [
      "det(A) = a11*(a22*a33 - a23*a32) - a12*(a21*a33 - a23*a31) + a13*(a21*a32 - a22*a31)",
      "det(A1) = b1*(a22*a33 - a23*a32) - a12*(b2*a33 - a23*b3) + a13*(b2*a32 - a22*b3)",
      "det(A2) = a11*(b2*a33 - a23*b3) - b1*(a21*a33 - a23*a31) + a13*(a21*b3 - b2*a31)",
      "det(A3) = a11*(a22*b3 - b2*a32) - a12*(a21*b3 - b2*a31) + b1*(a21*a32 - a22*a31)",
      "x1 = det(A1) / det(A)",
      "x2 = det(A2) / det(A)",
      "x3 = det(A3) / det(A)"
    ]

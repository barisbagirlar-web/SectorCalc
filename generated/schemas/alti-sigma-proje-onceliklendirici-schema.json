  "formulas": {
    "DPMO": "(Defects / (Units * Opportunities)) * 1000000",
    "Yield": "1 - (Defects / (Units * Opportunities))",
    "Z_bench": "NORMSINV(Yield)",
    "SigmaLevel": "Z_bench + 1.5",
    "COPQ": "InternalFailure + ExternalFailure + Appraisal + Prevention",
    "ProjectScore": "(COPQ * RecoveryProb * 0.35) + (SigmaGap * 0.25) + (StrategicAlignment * 0.25) + (Ease * 0.15)"
  },

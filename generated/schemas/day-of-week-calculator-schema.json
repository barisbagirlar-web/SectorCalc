{
  "toolName": "day-of-week-calculator",
  "inputs": [
    {
      "id": "year",
      "label": "Yıl",
      "type": "number",
      "unit": "yıl",
      "default": 2024,
      "businessContext": "Hesaplanacak yıl (ör. 2024)",
      "label_i18n": {
        "en": "Yıl",
        "tr": "Yıl",
        "de": "Yıl",
        "fr": "Yıl",
        "es": "Yıl",
        "ar": "Yıl"
      }
    },
    {
      "id": "month",
      "label": "Ay",
      "type": "number",
      "unit": "ay",
      "default": 1,
      "businessContext": "Ay (1-12)",
      "label_i18n": {
        "en": "Ay",
        "tr": "Ay",
        "de": "Ay",
        "fr": "Ay",
        "es": "Ay",
        "ar": "Ay"
      }
    },
    {
      "id": "day",
      "label": "Gün",
      "type": "number",
      "unit": "gün",
      "default": 1,
      "businessContext": "Gün (1-31)",
      "label_i18n": {
        "en": "Gün",
        "tr": "Gün",
        "de": "Gün",
        "fr": "Gün",
        "es": "Gün",
        "ar": "Gün"
      }
    }
  ],
  "formulas": {
    "adjustedMonth": "month < 3 ? month + 12 : month",
    "adjustedYear": "month < 3 ? year - 1 : year",
    "q": "day",
    "m": "adjustedMonth",
    "K": "adjustedYear % 100",
    "J": "Math.floor(adjustedYear / 100)",
    "h": "(q + Math.floor((13 * (m + 1)) / 5) + K + Math.floor(K / 4) + Math.floor(J / 4) - 2 * J) % 7",
    "dayOfWeek": "((h % 7) + 7) % 7"
  },
  "outputs": {
    "primary": "adjustedMonth",
    "breakdown": [
      "adjustedMonth",
      "adjustedYear",
      "K",
      "J",
      "h",
      "dayOfWeek"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "date-time",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

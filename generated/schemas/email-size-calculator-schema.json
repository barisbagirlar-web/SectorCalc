        "ar": "Number of Attachments"
      },
      "businessContext_i18n": {
        "en": "Total number of file attachments.",
        "tr": "Toplam dosya eki sayısı."
      }
    },
    {
      "id": "avgAttachmentSize",
      "label": "Average Attachment Size",
      "type": "number",
      "unit": "KB",
      "default": 500,
      "businessContext": "Average file size per attachment in kilobytes.",
      "label_i18n": {
        "en": "Average Attachment Size",
        "tr": "Ortalama Ek Boyutu",
        "de": "Average Attachment Size",
        "fr": "Average Attachment Size",
        "es": "Average Attachment Size",
        "ar": "Average Attachment Size"
      },
      "businessContext_i18n": {
        "en": "Average file size per attachment in kilobytes.",
        "tr": "Ek başına kilobayt cinsinden ortalama dosya boyutu."
      }
    },
    {
      "id": "embeddedImageCount",
      "label": "Number of Embedded Images",
      "type": "number",
      "unit": "count",
      "default": 3,
      "businessContext": "Number of inline/embedded images in the email content.",
      "label_i18n": {
        "en": "Number of Embedded Images",
        "tr": "Gömülü Görsel Sayısı",
        "de": "Number of Embedded Images",
        "fr": "Number of Embedded Images",
        "es": "Number of Embedded Images",
        "ar": "Number of Embedded Images"
      },
      "businessContext_i18n": {
        "en": "Number of inline/embedded images in the email content.",
        "tr": "E-posta içeriğindeki satır içi/gömülü görsel sayısı."
      }
    },
    {
      "id": "avgImageSize",
      "label": "Average Image Size",
      "type": "number",
      "unit": "KB",
      "default": 200,
      "businessContext": "Average size per embedded image in kilobytes.",
      "label_i18n": {
        "en": "Average Image Size",
        "tr": "Ortalama Görsel Boyutu",
        "de": "Average Image Size",
        "fr": "Average Image Size",
        "es": "Average Image Size",
        "ar": "Average Image Size"
      },
      "businessContext_i18n": {
        "en": "Average size per embedded image in kilobytes.",
        "tr": "Gömülü görsel başına kilobayt cinsinden ortalama boyut."
      }
    },
    {
      "id": "metadataSize",
      "label": "Metadata Overhead",
      "type": "number",
      "unit": "bytes",
      "default": 1024,
      "businessContext": "Size of email headers, signatures, and other metadata in bytes.",
      "label_i18n": {
        "en": "Metadata Overhead",
        "tr": "Meta Veri Yükü",
        "de": "Metadata Overhead",
        "fr": "Metadata Overhead",
        "es": "Metadata Overhead",
        "ar": "Metadata Overhead"
      },
      "businessContext_i18n": {
        "en": "Size of email headers, signatures, and other metadata in bytes.",
        "tr": "E-posta başlıkları, imzalar ve diğer meta verilerin bayt cinsinden boyutu."
      }
    }
  ],
  "formulas": {
    "totalBytes": "textCharacters + (attachmentCount * avgAttachmentSize * 1024) + (embeddedImageCount * avgImageSize * 1024) + metadataSize",
    "totalKB": "totalBytes / 1024",
    "totalMB": "totalKB / 1024",
    "textKB": "textCharacters / 1024",
    "attachmentsKB": "attachmentCount * avgAttachmentSize",
    "imagesKB": "embeddedImageCount * avgImageSize",
    "metadataKB": "metadataSize / 1024"
  },
  "outputs": {
    "primary": "totalKB",
    "breakdown": [
      "textKB",
      "attachmentsKB",
      "imagesKB",
      "metadataKB",
      "totalMB"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "metadataKB",
    "unit": "KB",
    "breakdownUnits": {
      "textKB": "KB",
      "attachmentsKB": "KB",
      "imagesKB": "KB",
      "metadataKB": "KB",
      "totalMB": "MB"
    }
  },

{
  "toolName": "email-size-calculator",
  "inputs": [
    {
      "id": "textCharacters",
      "label": "Number of Text Characters",
      "type": "number",
      "unit": "characters",
      "default": 1000,
      "businessContext": "The number of characters in the email body text.",
      "label_i18n": {
        "en": "Number of Text Characters",
        "tr": "Metin Karakter Sayısı",
        "de": "Number of Text Characters",

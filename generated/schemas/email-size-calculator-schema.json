        "ar": "Number of Text Characters"
      },
      "businessContext_i18n": {
        "en": "The number of characters in the email body text.",
        "tr": "E-posta gövde metnindeki karakter sayısı."
      }
    },
    {
      "id": "attachmentCount",
      "label": "Number of Attachments",
      "type": "number",
      "unit": "count",
      "default": 2,
      "businessContext": "Total number of file attachments.",
      "label_i18n": {

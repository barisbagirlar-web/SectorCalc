  "formulas": {
    "linear_predictor": "-10 + 0.03 * age + 0.05 * bmi + 0.02 * systolic_bp + 0.03 * diastolic_bp + 1.5 * previous_preeclampsia + 0.8 * family_history",
    "age_contrib": "0.03 * age",
    "bmi_contrib": "0.05 * bmi",
    "sbp_contrib": "0.02 * systolic_bp",
    "dbp_contrib": "0.03 * diastolic_bp",
    "prev_contrib": "1.5 * previous_preeclampsia",
    "fam_contrib": "0.8 * family_history"
  },
  "outputs": {
    "primary": "fam_contrib",
    "breakdown": [

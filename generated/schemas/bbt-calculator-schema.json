      "label": "Cooling Coefficient",
      "type": "number",
      "unit": "W/°C",
      "default": 5,
      "businessContext": "Thermal dissipation capacity of the bearing housing",
      "label_i18n": {
        "en": "Cooling Coefficient",
        "tr": "Soğutma Katsayısı",

  ],
  "formulas": {
    "powerLoss": "frictionCoeff * load * (Math.PI * boreDiameter * speed / 60) / 1000",
    "tempRise": "powerLoss / coolingCoeff",
    "bearingTemp": "ambientTemp + tempRise"
  },
  "outputs": {
    "primary": "bearingTemp",
    "breakdown": [
      "powerLoss",
      "tempRise"
    ],

{
  "toolName": "baby-head-circumference-calculator",
  "inputs": [
    {
      "id": "head_length",
      "label": "Head Length",
      "type": "number",
      "unit": "cm",
      "default": 12,
      "businessContext": "Maximum front-to-back length of the baby's head in centimeters.",
      "label_i18n": {
        "en": "Head Length",
        "tr": "Head Length",
        "de": "Head Length",
        "fr": "Head Length",
        "es": "Head Length",
        "ar": "Head Length"
      }
    },
    {
      "id": "head_width",
      "label": "Head Width",
      "type": "number",
      "unit": "cm",
      "default": 9,
      "businessContext": "Maximum width of the baby's head in centimeters.",
      "label_i18n": {
        "en": "Head Width",
        "tr": "Head Width",
        "de": "Head Width",
        "fr": "Head Width",
        "es": "Head Width",
        "ar": "Head Width"
      }
    },
    {
      "id": "head_height",
      "label": "Head Height",
      "type": "number",
      "unit": "cm",
      "default": 8,
      "businessContext": "Height from crown to base of skull in centimeters.",
      "label_i18n": {
        "en": "Head Height",
        "tr": "Head Height",
        "de": "Head Height",
        "fr": "Head Height",
        "es": "Head Height",
        "ar": "Head Height"
      }
    },
    {
      "id": "unit_conversion",
      "label": "Output Unit Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiply output lengths by this factor (1 for cm, 0.3937 for inches).",
      "label_i18n": {
        "en": "Output Unit Factor",
        "tr": "Output Unit Factor",
        "de": "Output Unit Factor",
        "fr": "Output Unit Factor",
        "es": "Output Unit Factor",
        "ar": "Output Unit Factor"
      }
    },
    {
      "id": "scale_factor",
      "label": "Scale Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier to adjust circumference for growth or fitting allowance.",
      "label_i18n": {
        "en": "Scale Factor",
        "tr": "Scale Factor",
        "de": "Scale Factor",
        "fr": "Scale Factor",
        "es": "Scale Factor",
        "ar": "Scale Factor"
      }
    }
  ],
  "formulas": {
    "a": "head_length / 2",
    "b": "head_width / 2",
    "c": "head_height / 2",
    "circumference_raw": "Math.PI * (3*(a+b) - Math.sqrt((3*a+b)*(a+3*b)))",
    "baby_head_circumference": "circumference_raw * unit_conversion * scale_factor",
    "head_volume": "(4/3) * Math.PI * a * b * c * Math.pow(unit_conversion, 3)",
    "head_surface_area": "4 * Math.PI * Math.pow( ( (Math.pow(a*b, 1.6) + Math.pow(a*c, 1.6) + Math.pow(b*c, 1.6) ) / 3 ), 1/1.6 ) * Math.pow(unit_conversion, 2)"
  },
  "outputs": {
    "primary": "baby_head_circumference",
    "breakdown": [
      "head_volume",
      "head_surface_area"
    ]
  },
  "category": "Dönüşüm & Ölçüm",

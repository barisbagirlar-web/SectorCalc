  "formulas": {
    "DirectLaborLoss": "DowntimeHours * AffectedWorkers * AvgHourlyRate * (1 + BurdenRate)",
    "ProductionLoss": "DowntimeHours * LineCapacity * ContributionMargin",
    "EnergyWaste": "IdlePowerKW * DowntimeHours * ElectricityRate",
    "RecoveryCost": "OvertimeHours * OvertimeRate * CrewSize",
    "TotalDowntimeCost": "DirectLaborLoss + ProductionLoss + EnergyWaste + RecoveryCost + QualityLoss + Penalty"
  },

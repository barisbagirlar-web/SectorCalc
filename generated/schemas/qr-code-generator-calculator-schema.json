{
  "toolName": "qr-code-generator-calculator",
  "inputs": [
    {
      "id": "version",
      "label": "QR Code Version",
      "type": "number",
      "unit": "version",
      "default": 5,
      "businessContext": "QR code version from 1 to 40, determines data capacity and physical size.",
      "label_i18n": {
        "en": "QR Code Version",
        "tr": "QR Code Version",
        "de": "QR Code Version",
        "fr": "QR Code Version",
        "es": "QR Code Version",
        "ar": "QR Code Version"
      }
    },
    {
      "id": "moduleSize",
      "label": "Module Size",
      "type": "number",
      "unit": "mm",
      "default": 0.5,
      "businessContext": "Edge length of one module (black or white square) in millimeters.",
      "label_i18n": {
        "en": "Module Size",
        "tr": "Module Size",
        "de": "Module Size",
        "fr": "Module Size",
        "es": "Module Size",
        "ar": "Module Size"
      }
    },
    {
      "id": "quietZoneModules",
      "label": "Quiet Zone Width",
      "type": "number",
      "unit": "modules",
      "default": 4,
      "businessContext": "Required clear margin around the QR code, measured in modules (standard is 4).",
      "label_i18n": {
        "en": "Quiet Zone Width",
        "tr": "Quiet Zone Width",
        "de": "Quiet Zone Width",
        "fr": "Quiet Zone Width",
        "es": "Quiet Zone Width",
        "ar": "Quiet Zone Width"
      }
    },
    {
      "id": "dpi",
      "label": "Print Resolution",
      "type": "number",
      "unit": "dpi",
      "default": 300,
      "businessContext": "Printer or display resolution in dots per inch, used for pixel dimension output.",
      "label_i18n": {
        "en": "Print Resolution",
        "tr": "Print Resolution",
        "de": "Print Resolution",
        "fr": "Print Resolution",
        "es": "Print Resolution",
        "ar": "Print Resolution"
      }
    }
  ],
  "formulas": {
    "Total Modules Count": "17 + 4 * version",
    "Quiet Zone (mm)": "2 * quietZoneModules * moduleSize",
    "Width (mm)": "(17 + 4 * version + 2 * quietZoneModules) * moduleSize",
    "Width (px)": "((17 + 4 * version + 2 * quietZoneModules) * moduleSize) / 25.4 * dpi"
  },
  "outputs": {
    "primary": "Width (mm)",
    "breakdown": [
      "Total Modules Count",
      "Width (px)",
      "Quiet Zone (mm)"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "Width (px)"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Birim & Dönüşüm",
  "premiumRequired": false,

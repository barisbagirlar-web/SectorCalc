{
  "toolName": "basal-metabolic-rate",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Body weight in kilograms"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Height in centimeters"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age in years"
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1 for Male, 0 for Female"
    }
  ],
  "formulas": {
    "base": "10 * weight + 6.25 * height - 5 * age",
    "gender_adjustment": "gender == 1 ? 5 : -161",
    "bmr": "base + gender_adjustment"
  },
  "outputs": {
    "primary": "bmr",
    "breakdown": [
      "base",
      "gender_adjustment"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,

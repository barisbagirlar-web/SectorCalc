{
  "toolName": "weight-cycling-calculator",
  "inputs": [
    {
      "id": "mass",
      "label": "Mass of Load",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The mass of the load being cycled (lifted and lowered).",
      "label_i18n": {
        "en": "Mass of Load",
        "tr": "Mass of Load",
        "de": "Mass of Load",
        "fr": "Mass of Load",
        "es": "Mass of Load",
        "ar": "Mass of Load"
      }
    },
    {
      "id": "height",
      "label": "Lifting Height",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Vertical distance the load is lifted each cycle.",
      "label_i18n": {
        "en": "Lifting Height",
        "tr": "Lifting Height",
        "de": "Lifting Height",
        "fr": "Lifting Height",
        "es": "Lifting Height",
        "ar": "Lifting Height"
      }
    },
    {
      "id": "cyclesPerDay",
      "label": "Cycles per Day",
      "type": "number",
      "unit": "cycles/day",
      "default": 100,
      "businessContext": "Number of lift cycles per operating day.",
      "label_i18n": {
        "en": "Cycles per Day",
        "tr": "Cycles per Day",
        "de": "Cycles per Day",
        "fr": "Cycles per Day",
        "es": "Cycles per Day",
        "ar": "Cycles per Day"
      }
    },
    {
      "id": "operatingDays",
      "label": "Operating Days",
      "type": "number",
      "unit": "days",
      "default": 250,
      "businessContext": "Total number of operating days per year or period.",
      "label_i18n": {
        "en": "Operating Days",
        "tr": "Operating Days",
        "de": "Operating Days",
        "fr": "Operating Days",
        "es": "Operating Days",
        "ar": "Operating Days"
      }
    },
    {
      "id": "efficiency",
      "label": "System Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Overall efficiency of the lifting mechanism including motor, transmission, etc. Enter as percentage (0-100).",
      "label_i18n": {
        "en": "System Efficiency",
        "tr": "System Efficiency",
        "de": "System Efficiency",
        "fr": "System Efficiency",
        "es": "System Efficiency",
        "ar": "System Efficiency"
      }
    },
    {
      "id": "energyCost",
      "label": "Energy Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost of electricity per kilowatt-hour in your currency.",
      "label_i18n": {
        "en": "Energy Cost",
        "tr": "Energy Cost",
        "de": "Energy Cost",
        "fr": "Energy Cost",
        "es": "Energy Cost",
        "ar": "Energy Cost"
      }
    }
  ],
  "formulas": {
    "energyPerCycle": "(mass * 9.81 * height) / (3.6e6) / (efficiency / 100)",
    "totalCycles": "cyclesPerDay * operatingDays",
    "totalEnergy": "energyPerCycle * totalCycles",
    "totalCost": "totalEnergy * energyCost"
  },
  "outputs": {
    "primary": "energyPerCycle",
    "breakdown": [
      {
        "id": "totalEnergy",
        "label": "Total Energy Consumed",
        "unit": "kWh",
        "formula": "totalEnergy"
      },
      {
        "id": "totalCycles",
        "label": "Total Number of Cycles",
        "unit": "cycles",
        "formula": "totalCycles"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

{
  "toolName": "password-entropy-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Password Length",
      "type": "number",
      "unit": "char",
      "default": 12,
      "businessContext": "Total number of characters in the password"
    },
    {
      "id": "uppercasePool",
      "label": "Uppercase Letters Pool",
      "type": "number",
      "unit": "chars",
      "default": 26,
      "businessContext": "Number of distinct uppercase letters (A-Z)"
    },
    {
      "id": "lowercasePool",
      "label": "Lowercase Letters Pool",
      "type": "number",
      "unit": "chars",
      "default": 26,
      "businessContext": "Number of distinct lowercase letters (a-z)"
    },
    {
      "id": "digitsPool",
      "label": "Digits Pool",
      "type": "number",
      "unit": "chars",
      "default": 10,
      "businessContext": "Number of digit characters (0-9)"
    },
    {
      "id": "symbolsPool",
      "label": "Symbols Pool",
      "type": "number",
      "unit": "chars",
      "default": 32,
      "businessContext": "Number of special characters (e.g., !@#$...)"
    },
    {
      "id": "customChars",
      "label": "Custom Additional Characters",
      "type": "number",
      "unit": "chars",
      "default": 0,
      "businessContext": "Additional user-defined character count"
    }
  ],
  "formulas": {
    "poolSize": "uppercasePool + lowercasePool + digitsPool + symbolsPool + customChars",
    "entropyPerChar": "Math.log(poolSize) / Math.LN2",
    "entropy": "length * entropyPerChar"
  },
  "outputs": {
    "primary": "entropy",
    "breakdown": [
      "poolSize",
      "entropyPerChar"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

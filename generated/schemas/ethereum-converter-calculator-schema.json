{
  "toolName": "ethereum-converter-calculator",
  "inputs": [
    {
      "id": "ethAmount",
      "label": "Ethereum Amount",
      "type": "number",
      "unit": "ETH",
      "default": 1,
      "businessContext": "The amount of Ethereum to convert, before transaction fees.",
      "label_i18n": {
        "en": "Ethereum Amount",
        "tr": "Ethereum Amount",
        "de": "Ethereum Amount",
        "fr": "Ethereum Amount",
        "es": "Ethereum Amount",
        "ar": "Ethereum Amount"
      }
    },
    {
      "id": "ethPriceUSD",
      "label": "ETH Price (USD)",
      "type": "number",
      "unit": "USD/ETH",
      "default": 3000,
      "businessContext": "Current market price of 1 ETH in US dollars.",
      "label_i18n": {
        "en": "ETH Price (USD)",
        "tr": "ETH Price (USD)",
        "de": "ETH Price (USD)",
        "fr": "ETH Price (USD)",
        "es": "ETH Price (USD)",
        "ar": "ETH Price (USD)"
      }
    },
    {
      "id": "gasLimit",
      "label": "Gas Limit",
      "type": "number",
      "unit": "gas units",
      "default": 21000,
      "businessContext": "Maximum gas units allowed for the Ethereum transaction (standard ETH transfer: 21000).",
      "label_i18n": {
        "en": "Gas Limit",
        "tr": "Gas Limit",
        "de": "Gas Limit",
        "fr": "Gas Limit",
        "es": "Gas Limit",
        "ar": "Gas Limit"
      }
    },
    {
      "id": "maxFeePerGas",
      "label": "Max Fee per Gas",
      "type": "number",
      "unit": "Gwei",
      "default": 50,
      "businessContext": "Maximum fee per gas unit in Gwei (1 ETH = 10^9 Gwei). This covers base fee + priority fee.",
      "label_i18n": {
        "en": "Max Fee per Gas",
        "tr": "Max Fee per Gas",
        "de": "Max Fee per Gas",
        "fr": "Max Fee per Gas",
        "es": "Max Fee per Gas",
        "ar": "Max Fee per Gas"
      }
    },
    {
      "id": "networkMultiplier",
      "label": "Network Congestion Multiplier",
      "type": "number",
      "unit": "scalar",
      "default": 1,
      "businessContext": "Multiplier to simulate higher gas prices during network congestion (1 for normal, >1 for high demand).",
      "label_i18n": {
        "en": "Network Congestion Multiplier",
        "tr": "Network Congestion Multiplier",
        "de": "Network Congestion Multiplier",
        "fr": "Network Congestion Multiplier",
        "es": "Network Congestion Multiplier",
        "ar": "Network Congestion Multiplier"
      }
    },
    {
      "id": "conversionFeePercent",
      "label": "Conversion Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "Percentage fee charged by the exchange or service for converting crypto to fiat currency.",
      "label_i18n": {
        "en": "Conversion Fee (%)",
        "tr": "Conversion Fee (%)",
        "de": "Conversion Fee (%)",
        "fr": "Conversion Fee (%)",
        "es": "Conversion Fee (%)",
        "ar": "Conversion Fee (%)"
      }
    }
  ],
  "formulas": {
    "totalGasETH": "gasLimit * maxFeePerGas * networkMultiplier * 1e-9",
    "netETH": "ethAmount - totalGasETH",
    "grossUSD": "netETH * ethPriceUSD",
    "conversionFeeAmount": "grossUSD * (conversionFeePercent / 100)",
    "netUSD": "grossUSD - conversionFeeAmount"
  },
  "outputs": {
    "primary": "netUSD",
    "breakdown": [
      "totalGasETH",
      "netETH",
      "grossUSD",
      "conversionFeeAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netUSD"
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "conversion",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

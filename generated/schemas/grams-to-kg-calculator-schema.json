{
  "toolName": "grams-to-kg-calculator",
  "inputs": [
    {
      "id": "grossWeightGrams",
      "label": "Gross Weight (g)",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Total measured weight including container or packaging",
      "label_i18n": {
        "en": "Gross Weight (g)",
        "tr": "Gross Weight (g)",
        "de": "Gross Weight (g)",
        "fr": "Gross Weight (g)",
        "es": "Gross Weight (g)",
        "ar": "Gross Weight (g)"
      }
    },
    {
      "id": "tareWeightGrams",
      "label": "Tare Weight (g)",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Weight of empty container or packaging",
      "label_i18n": {
        "en": "Tare Weight (g)",
        "tr": "Tare Weight (g)",
        "de": "Tare Weight (g)",
        "fr": "Tare Weight (g)",
        "es": "Tare Weight (g)",
        "ar": "Tare Weight (g)"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Number of decimal places for the final net weight output",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "roundingMode",
      "label": "Rounding Mode",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 = standard rounding, 1 = floor, 2 = ceil",
      "label_i18n": {
        "en": "Rounding Mode",
        "tr": "Rounding Mode",
        "de": "Rounding Mode",
        "fr": "Rounding Mode",
        "es": "Rounding Mode",
        "ar": "Rounding Mode"
      }
    }
  ],
  "formulas": {
    "netGrams": "grossWeightGrams - tareWeightGrams",
    "kgUnrounded": "netGrams / 1000",
    "netWeightKg": "roundingMode === 0 ? Math.round(kgUnrounded * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces) : roundingMode === 1 ? Math.floor(kgUnrounded * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces) : Math.ceil(kgUnrounded * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "netWeightGrams": "netGrams",
    "grossWeightKg": "grossWeightGrams / 1000"
  },
  "outputs": {
    "primary": "netWeightKg",
    "breakdown": [
      "netWeightGrams",
      "grossWeightKg"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

{
  "toolName": "pasta-calculator",
  "inputs": [
    {
      "id": "servings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 4,
      "businessContext": "Number of portions to prepare.",
      "label_i18n": {
        "en": "Number of Servings",
        "tr": "Number of Servings",
        "de": "Number of Servings",
        "fr": "Number of Servings",
        "es": "Number of Servings",
        "ar": "Number of Servings"
      }
    },
    {
      "id": "portionWeight",
      "label": "Pasta per Portion",
      "type": "number",
      "unit": "g",
      "default": 100,
      "businessContext": "Dry pasta weight per person in grams. Standard is 80-100g.",
      "label_i18n": {
        "en": "Pasta per Portion",
        "tr": "Pasta per Portion",
        "de": "Pasta per Portion",
        "fr": "Pasta per Portion",
        "es": "Pasta per Portion",
        "ar": "Pasta per Portion"
      }
    },
    {
      "id": "waterRatio",
      "label": "Water Ratio",
      "type": "number",
      "unit": "L/kg",
      "default": 10,
      "businessContext": "Water needed per kilogram of dry pasta. Typically 10 liters per kg.",
      "label_i18n": {
        "en": "Water Ratio",
        "tr": "Water Ratio",
        "de": "Water Ratio",
        "fr": "Water Ratio",
        "es": "Water Ratio",
        "ar": "Water Ratio"
      }
    },
    {
      "id": "saltConcentration",
      "label": "Salt Concentration",
      "type": "number",
      "unit": "g/L",
      "default": 10,
      "businessContext": "Salt added per liter of water. Standard is 10 g/L.",
      "label_i18n": {
        "en": "Salt Concentration",
        "tr": "Salt Concentration",
        "de": "Salt Concentration",
        "fr": "Salt Concentration",
        "es": "Salt Concentration",
        "ar": "Salt Concentration"
      }
    },
    {
      "id": "cookingTimeLoss",
      "label": "Water Absorption Factor",
      "type": "number",
      "unit": "ratio",
      "default": 1.8,
      "businessContext": "Multiplier for cooked weight relative to dry weight. Cooked pasta absorbs water. Typical 1.8-2.0.",
      "label_i18n": {
        "en": "Water Absorption Factor",
        "tr": "Water Absorption Factor",
        "de": "Water Absorption Factor",
        "fr": "Water Absorption Factor",
        "es": "Water Absorption Factor",
        "ar": "Water Absorption Factor"
      }
    },
    {
      "id": "caloriesPer100g",
      "label": "Calories per 100g Dry",
      "type": "number",
      "unit": "kcal",
      "default": 371,
      "businessContext": "Energy content per 100 grams of dry pasta (typical 371 kcal).",
      "label_i18n": {
        "en": "Calories per 100g Dry",
        "tr": "Calories per 100g Dry",
        "de": "Calories per 100g Dry",
        "fr": "Calories per 100g Dry",
        "es": "Calories per 100g Dry",
        "ar": "Calories per 100g Dry"
      }
    }
  ],
  "formulas": {
    "totalDryWeight": "servings * portionWeight",
    "totalWater": "(totalDryWeight / 1000) * waterRatio",
    "totalSalt": "totalWater * saltConcentration",
    "cookedWeight": "totalDryWeight * cookingTimeLoss",
    "totalCalories": "(totalDryWeight / 100) * caloriesPer100g"
  },
  "outputs": {
    "primary": "totalDryWeight",
    "breakdown": [
      {
        "id": "totalDryPasta",
        "label": "Dry Pasta",
        "unit": "g",
        "formula": "totalDryWeight"
      },
      {
        "id": "waterNeeded",
        "label": "Water",
        "unit": "L",
        "formula": "totalWater"
      },
      {
        "id": "saltNeeded",
        "label": "Salt",
        "unit": "g",
        "formula": "totalSalt"
      },
      {
        "id": "totalCalories",
        "label": "Calories",
        "unit": "kcal",
        "formula": "totalCalories"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCalories",
    "unit": "servings"
  },
  "category": "Enerji & Karbon",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",

{
  "toolName": "baby-length-calculator",
  "inputs": [
    {
      "id": "ageMonths",
      "label": "Age (months)",
      "type": "number",
      "unit": "months",
      "default": 6,
      "businessContext": "Baby's age in months, used for length estimation based on standard growth curves.",
      "label_i18n": {
        "en": "Age (months)",
        "tr": "Age (months)",
        "de": "Age (months)",
        "fr": "Age (months)",
        "es": "Age (months)",
        "ar": "Age (months)"
      }
    },
    {
      "id": "weightKg",
      "label": "Weight (kg)",
      "type": "number",
      "unit": "kg",
      "default": 7.5,
      "businessContext": "Baby's weight in kilograms, a supplementary predictor for length.",
      "label_i18n": {
        "en": "Weight (kg)",
        "tr": "Weight (kg)",
        "de": "Weight (kg)",
        "fr": "Weight (kg)",
        "es": "Weight (kg)",
        "ar": "Weight (kg)"
      }
    },
    {
      "id": "genderCode",
      "label": "Gender (0=girl, 1=boy)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Gender code (0 for female, 1 for male) to apply length offset.",
      "label_i18n": {
        "en": "Gender (0=girl, 1=boy)",
        "tr": "Gender (0=girl, 1=boy)",
        "de": "Gender (0=girl, 1=boy)",
        "fr": "Gender (0=girl, 1=boy)",
        "es": "Gender (0=girl, 1=boy)",
        "ar": "Gender (0=girl, 1=boy)"
      }
    },
    {
      "id": "prematureWeeks",
      "label": "Premature (weeks)",
      "type": "number",
      "unit": "weeks",
      "default": 0,
      "businessContext": "Number of weeks born early; used to correct age for prematurity adjustment.",
      "label_i18n": {
        "en": "Premature (weeks)",
        "tr": "Premature (weeks)",
        "de": "Premature (weeks)",
        "fr": "Premature (weeks)",
        "es": "Premature (weeks)",
        "ar": "Premature (weeks)"
      }
    }
  ],
  "formulas": {
    "correctedAge": "ageMonths - (prematureWeeks / 4.345)",
    "ageComponent": "45 + 2.5 * correctedAge",
    "weightComponent": "0.8 * weightKg",
    "genderComponent": "genderCode * 1.0",
    "estimatedLength": "ageComponent + weightComponent + genderComponent"
  },
  "outputs": {
    "primary": "estimatedLength",
    "breakdown": [
      "correctedAge",
      "ageComponent",
      "weightComponent",
      "genderComponent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "estimatedLength"
  },

        "de": "Units Sold",
        "fr": "Units Sold",
        "es": "Units Sold",
        "ar": "Units Sold"
      }
    }
  ],
  "formulas": {
    "totalCost": "openingUnits * openingCostPerUnit + purchase1Units * purchase1CostPerUnit + purchase2Units * purchase2CostPerUnit",
    "cogsLifo": "unitsSold <= purchase2Units ? unitsSold * purchase2CostPerUnit : unitsSold - purchase2Units <= purchase1Units ? purchase2Units * purchase2CostPerUnit + (unitsSold - purchase2Units) * purchase1CostPerUnit : purchase2Units * purchase2CostPerUnit + purchase1Units * purchase1CostPerUnit + (unitsSold - purchase2Units - purchase1Units) * openingCostPerUnit",
    "endingInventoryLifo": "totalCost - cogsLifo",
    "cogsFifo": "unitsSold <= openingUnits ? unitsSold * openingCostPerUnit : unitsSold - openingUnits <= purchase1Units ? openingUnits * openingCostPerUnit + (unitsSold - openingUnits) * purchase1CostPerUnit : openingUnits * openingCostPerUnit + purchase1Units * purchase1CostPerUnit + (unitsSold - openingUnits - purchase1Units) * purchase2CostPerUnit",
    "endingInventoryFifo": "totalCost - cogsFifo"
  },
  "outputs": {
    "primary": "cogsLifo",
    "breakdown": [
      "endingInventoryLifo",
      "cogsFifo",
      "endingInventoryFifo"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

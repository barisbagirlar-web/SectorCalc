        "tr": "Düzenli aylık ödeme tutarı."
      }
    },
    {
      "id": "extraMonthlyPayment",
      "label": "Extra Monthly Payment",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Additional amount paid each month to accelerate payoff.",

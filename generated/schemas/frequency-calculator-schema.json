{
  "toolName": "frequency-calculator",
  "inputs": [
    {
      "id": "period",
      "label": "Period (T)",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Time for one complete cycle. Used in f = 1/T.",
      "label_i18n": {
        "en": "Period (T)",
        "tr": "Period (T)",
        "de": "Period (T)",
        "fr": "Period (T)",
        "es": "Period (T)",
        "ar": "Period (T)"
      }
    },
    {
      "id": "cycles",
      "label": "Number of Cycles",
      "type": "number",
      "unit": "cycles",
      "default": 0,
      "businessContext": "Number of cycles observed. Used with Total Time to compute frequency.",
      "label_i18n": {
        "en": "Number of Cycles",
        "tr": "Number of Cycles",
        "de": "Number of Cycles",
        "fr": "Number of Cycles",
        "es": "Number of Cycles",
        "ar": "Number of Cycles"
      }
    },
    {
      "id": "time",
      "label": "Total Time",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Total time over which cycles were counted. Used in f = cycles / time.",
      "label_i18n": {
        "en": "Total Time",
        "tr": "Total Time",
        "de": "Total Time",
        "fr": "Total Time",
        "es": "Total Time",
        "ar": "Total Time"
      }
    },
    {
      "id": "velocity",
      "label": "Velocity (v)",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "Wave propagation speed. Used with Wavelength to compute frequency.",
      "label_i18n": {
        "en": "Velocity (v)",
        "tr": "Velocity (v)",
        "de": "Velocity (v)",
        "fr": "Velocity (v)",
        "es": "Velocity (v)",
        "ar": "Velocity (v)"
      }
    },
    {
      "id": "wavelength",
      "label": "Wavelength (λ)",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Distance between successive peaks. Used with Velocity in f = v/λ.",
      "label_i18n": {
        "en": "Wavelength (λ)",
        "tr": "Wavelength (λ)",
        "de": "Wavelength (λ)",
        "fr": "Wavelength (λ)",
        "es": "Wavelength (λ)",
        "ar": "Wavelength (λ)"
      }
    },
    {
      "id": "angularFrequency",
      "label": "Angular Frequency (ω)",
      "type": "number",
      "unit": "rad/s",
      "default": 0,
      "businessContext": "Angular frequency in radians per second. Converted to Hz via f = ω/(2π).",
      "label_i18n": {
        "en": "Angular Frequency (ω)",
        "tr": "Angular Frequency (ω)",
        "de": "Angular Frequency (ω)",
        "fr": "Angular Frequency (ω)",
        "es": "Angular Frequency (ω)",
        "ar": "Angular Frequency (ω)"
      }
    },
    {
      "id": "rpm",
      "label": "Revolutions per Minute (RPM)",
      "type": "number",
      "unit": "rpm",
      "default": 0,
      "businessContext": "Rotational speed in revolutions per minute. Converted to Hz via f = RPM/60.",
      "label_i18n": {
        "en": "Revolutions per Minute (RPM)",
        "tr": "Revolutions per Minute (RPM)",
        "de": "Revolutions per Minute (RPM)",
        "fr": "Revolutions per Minute (RPM)",
        "es": "Revolutions per Minute (RPM)",
        "ar": "Revolutions per Minute (RPM)"
      }
    }
  ],
  "formulas": {
    "frequency": "period !== 0 ? 1 / period : (cycles !== 0 && time !== 0 ? cycles / time : (velocity !== 0 && wavelength !== 0 ? velocity / wavelength : (angularFrequency !== 0 ? angularFrequency / (2 * Math.PI) : (rpm !== 0 ? rpm / 60 : 0))))",
    "angularFrequencyOut": "frequency * 2 * Math.PI",
    "rpmOut": "frequency * 60"
  },
  "outputs": {
    "primary": "frequency",
    "breakdown": [
      "angularFrequencyOut",
      "rpmOut"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rpmOut"
  },

  "formulas": {
    "Overproduction": "ExcessUnits * UnitCost",
    "Waiting": "WaitingHours * (LaborRate + MachineRate)",
    "Transport": "TransportDistance * CostPerMeter * Trips",
    "Overprocessing": "(ActualTime - StandardTime) * LaborRate",
    "Inventory": "ExcessInventory * HoldingCostRate * Time",
    "Motion": "UnnecessaryMotionTime * LaborRate",
    "Defects": "DefectUnits * (MaterialCost + ReworkCost)",
    "TotalMudaCost": "Overproduction + Waiting + Transport + Overprocessing + Inventory + Motion + Defects"
  },

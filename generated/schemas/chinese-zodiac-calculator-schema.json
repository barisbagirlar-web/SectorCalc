{
  "toolName": "chinese-zodiac-calculator",
  "inputs": [
    {
      "id": "birthYear",
      "label": "Birth Year",
      "type": "number",
      "unit": "year",
      "default": 2000,
      "businessContext": "Gregorian year of birth.",
      "label_i18n": {
        "en": "Birth Year",
        "tr": "Birth Year",
        "de": "Birth Year",
        "fr": "Birth Year",
        "es": "Birth Year",
        "ar": "Birth Year"
      }
    },
    {
      "id": "birthMonth",
      "label": "Birth Month",
      "type": "number",
      "unit": "month",
      "default": 1,
      "businessContext": "Month of birth (1-12). Not used for zodiac, but included for completeness.",
      "label_i18n": {
        "en": "Birth Month",
        "tr": "Birth Month",
        "de": "Birth Month",
        "fr": "Birth Month",
        "es": "Birth Month",
        "ar": "Birth Month"
      }
    },
    {
      "id": "birthDay",
      "label": "Birth Day",
      "type": "number",
      "unit": "day",
      "default": 1,
      "businessContext": "Day of birth (1-31).",
      "label_i18n": {
        "en": "Birth Day",
        "tr": "Birth Day",
        "de": "Birth Day",
        "fr": "Birth Day",
        "es": "Birth Day",
        "ar": "Birth Day"
      }
    },
    {
      "id": "birthHour",
      "label": "Birth Hour",
      "type": "number",
      "unit": "hour",
      "default": 0,
      "businessContext": "Hour of birth (0-23).",
      "label_i18n": {
        "en": "Birth Hour",
        "tr": "Birth Hour",
        "de": "Birth Hour",
        "fr": "Birth Hour",
        "es": "Birth Hour",
        "ar": "Birth Hour"
      }
    }
  ],
  "formulas": {
    "zodiacIndex": "((birthYear - 4) % 12 + 12) % 12",
    "elementIndex": "Math.floor((((birthYear - 4) % 10 + 10) % 10) / 2)",
    "__zodiacIndex_": "${zodiacIndex}",
    "__elementIndex_": "${elementIndex}"
  },
  "outputs": {
    "primary": "zodiacIndex",
    "breakdown": [
      "Zodiac Index: ${zodiacIndex}",
      "Element Index: ${elementIndex}"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber"
}

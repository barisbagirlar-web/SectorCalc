{
  "toolName": "barrel-to-liter-calculator",
  "inputs": [
    {
      "id": "barrelCount",
      "label": "Barrel Count",
      "type": "number",
      "unit": "barrels",
      "default": 1,
      "businessContext": "Number of barrels to convert"
    },
    {
      "id": "conversionRate",
      "label": "Liter per Barrel",
      "type": "number",
      "unit": "L/bbl",
      "default": 158.9873,
      "businessContext": "Default is for US oil barrel (42 US gallons). Adjust for other barrel types."
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 15,
      "businessContext": "Temperature for volume correction (optional)"
    },
    {
      "id": "correctionFactor",
      "label": "Volume Correction Factor",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Multiplier for temperature correction. Use 1 if no correction."
    }
  ],
  "formulas": {
    "totalLiters": "barrelCount * conversionRate * correctionFactor",
    "baseLiters": "barrelCount * conversionRate",
    "correctionDelta": "totalLiters - baseLiters"
  },
  "outputs": {
    "primary": "totalLiters",
    "breakdown": [
      "baseLiters",
      "correctionDelta"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

{
  "toolName": "barrel-to-liter-calculator",
  "inputs": [
    {
      "id": "barrelCount",
      "label": "Barrel Count",
      "type": "number",
      "unit": "barrels",
      "default": 1,
      "businessContext": "Number of barrels to convert",
      "label_i18n": {
        "en": "Barrel Count",
        "tr": "Barrel Count",
        "de": "Barrel Count",
        "fr": "Barrel Count",
        "es": "Barrel Count",
        "ar": "Barrel Count"
      }
    },
    {
      "id": "conversionRate",
      "label": "Liter per Barrel",
      "type": "number",
      "unit": "L/bbl",
      "default": 158.9873,
      "businessContext": "Default is for US oil barrel (42 US gallons). Adjust for other barrel types.",
      "label_i18n": {
        "en": "Liter per Barrel",
        "tr": "Liter per Barrel",
        "de": "Liter per Barrel",
        "fr": "Liter per Barrel",
        "es": "Liter per Barrel",
        "ar": "Liter per Barrel"
      }
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 15,
      "businessContext": "Temperature for volume correction (optional)",
      "label_i18n": {
        "en": "Temperature",
        "tr": "Temperature",
        "de": "Temperature",
        "fr": "Temperature",
        "es": "Temperature",
        "ar": "Temperature"
      }
    },
    {
      "id": "correctionFactor",
      "label": "Volume Correction Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for temperature correction. Use 1 if no correction.",
      "label_i18n": {
        "en": "Volume Correction Factor",
        "tr": "Volume Correction Factor",
        "de": "Volume Correction Factor",
        "fr": "Volume Correction Factor",
        "es": "Volume Correction Factor",
        "ar": "Volume Correction Factor"
      }
    }
  ],
  "formulas": {
    "totalLiters": "barrelCount * conversionRate * correctionFactor",
    "baseLiters": "barrelCount * conversionRate",
    "correctionDelta": "totalLiters - baseLiters"
  },
  "outputs": {
    "primary": "totalLiters",
    "breakdown": [
      "baseLiters",
      "correctionDelta"
    ]
  },

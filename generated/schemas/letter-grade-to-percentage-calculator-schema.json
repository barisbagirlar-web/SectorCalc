{
  "toolName": "letter-grade-to-percentage-calculator",
  "inputs": [
    {
      "id": "gradePoint",
      "label": "Grade Point (4.0 Scale)",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "The numeric grade point on a 4.0 scale, e.g., 4.0 for A, 3.0 for B, etc.",
      "label_i18n": {
        "en": "Grade Point (4.0 Scale)",
        "tr": "Grade Point (4.0 Scale)",
        "de": "Grade Point (4.0 Scale)",
        "fr": "Grade Point (4.0 Scale)",
        "es": "Grade Point (4.0 Scale)",
        "ar": "Grade Point (4.0 Scale)"
      }
    },
    {
      "id": "slope",
      "label": "Slope",
      "type": "number",
      "unit": "unit",
      "default": 10,
      "businessContext": "Points per grade point.",
      "label_i18n": {
        "en": "Slope",
        "tr": "Slope",
        "de": "Slope",
        "fr": "Slope",
        "es": "Slope",
        "ar": "Slope"
      }
    },
    {
      "id": "intercept",
      "label": "Intercept",
      "type": "number",
      "unit": "%",
      "default": 55,
      "businessContext": "Base percentage when grade point is 0.",
      "label_i18n": {
        "en": "Intercept",
        "tr": "Intercept",
        "de": "Intercept",
        "fr": "Intercept",
        "es": "Intercept",
        "ar": "Intercept"
      }
    },
    {
      "id": "clampMin",
      "label": "Minimum Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Lower clamp limit for the output percentage.",
      "label_i18n": {
        "en": "Minimum Percentage",
        "tr": "Minimum Percentage",
        "de": "Minimum Percentage",
        "fr": "Minimum Percentage",
        "es": "Minimum Percentage",
        "ar": "Minimum Percentage"
      }
    },
    {
      "id": "clampMax",
      "label": "Maximum Percentage",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Upper clamp limit for the output percentage.",
      "label_i18n": {
        "en": "Maximum Percentage",
        "tr": "Maximum Percentage",
        "de": "Maximum Percentage",
        "fr": "Maximum Percentage",
        "es": "Maximum Percentage",
        "ar": "Maximum Percentage"
      }
    }
  ],
  "formulas": {
    "rawPercentage": "slope * gradePoint + intercept",
    "percentage": "Math.min(clampMax, Math.max(clampMin, rawPercentage))",
    "letterGradeNumeric": "Math.max(0, Math.min(4, Math.floor((percentage - 50) / 10)))"
  },
  "outputs": {
    "primary": "percentage",
    "breakdown": [
      "rawPercentage",
      "letterGradeNumeric"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma"
}

{
  "toolName": "wet-bulb-temperature",
  "inputs": [
    {
      "id": "dryBulbTemp",
      "label": "Dry Bulb Temperature",
      "type": "number",
      "unit": "°C",
      "default": 25,
      "businessContext": "The temperature of air measured by a thermometer freely exposed to air but shielded from radiation and moisture.",
      "label_i18n": {
        "en": "Dry Bulb Temperature",
        "tr": "Dry Bulb Temperature",
        "de": "Dry Bulb Temperature",
        "fr": "Dry Bulb Temperature",
        "es": "Dry Bulb Temperature",
        "ar": "Dry Bulb Temperature"
      }
    },
    {
      "id": "relativeHumidity",
      "label": "Relative Humidity",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "The ratio of the partial pressure of water vapor to the equilibrium vapor pressure of water at the same temperature.",
      "label_i18n": {
        "en": "Relative Humidity",
        "tr": "Relative Humidity",
        "de": "Relative Humidity",
        "fr": "Relative Humidity",
        "es": "Relative Humidity",
        "ar": "Relative Humidity"
      }
    },
    {
      "id": "atmosphericPressure",
      "label": "Atmospheric Pressure",
      "type": "number",
      "unit": "hPa",
      "default": 1013.25,
      "businessContext": "The pressure exerted by the weight of the atmosphere at the location (standard sea-level pressure is 1013.25 hPa). Not used in this simplified calculation.",
      "label_i18n": {
        "en": "Atmospheric Pressure",
        "tr": "Atmospheric Pressure",
        "de": "Atmospheric Pressure",
        "fr": "Atmospheric Pressure",
        "es": "Atmospheric Pressure",
        "ar": "Atmospheric Pressure"
      }
    },
    {
      "id": "altitude",
      "label": "Altitude",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Elevation above sea level. Not used in this simplified calculation.",
      "label_i18n": {
        "en": "Altitude",
        "tr": "Altitude",
        "de": "Altitude",
        "fr": "Altitude",
        "es": "Altitude",
        "ar": "Altitude"
      }
    }
  ],
  "formulas": {
    "term1": "dryBulbTemp * Math.atan(0.151977 * Math.sqrt(relativeHumidity + 8.313659))",
    "term2": "Math.atan(dryBulbTemp + relativeHumidity)",
    "term3": "-Math.atan(relativeHumidity - 1.676331)",
    "term4": "0.00391838 * Math.pow(relativeHumidity, 1.5) * Math.atan(0.023101 * relativeHumidity)",
    "wetBulbTemp": "term1 + term2 + term3 + term4 - 4.686035"
  },
  "outputs": {
    "primary": "wetBulbTemp",
    "breakdown": [
      "term1",
      "term2",
      "term3",
      "term4"
    ]
  },

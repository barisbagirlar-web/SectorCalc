{
  "toolName": "force-calculator",
  "inputs": [
    {
      "id": "mass",
      "label": "Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "The mass of the object being subjected to force.",
      "label_i18n": {
        "en": "Mass",
        "tr": "Mass",
        "de": "Mass",
        "fr": "Mass",
        "es": "Mass",
        "ar": "Mass"
      }
    },
    {
      "id": "initialVelocity",
      "label": "Initial Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "The initial velocity of the object before the force is applied.",
      "label_i18n": {
        "en": "Initial Velocity",
        "tr": "Initial Velocity",
        "de": "Initial Velocity",
        "fr": "Initial Velocity",
        "es": "Initial Velocity",
        "ar": "Initial Velocity"
      }
    },
    {
      "id": "finalVelocity",
      "label": "Final Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 10,
      "businessContext": "The final velocity of the object after the force is applied.",
      "label_i18n": {
        "en": "Final Velocity",
        "tr": "Final Velocity",
        "de": "Final Velocity",
        "fr": "Final Velocity",
        "es": "Final Velocity",
        "ar": "Final Velocity"
      }
    },
    {
      "id": "time",
      "label": "Time",
      "type": "number",
      "unit": "s",
      "default": 1,
      "businessContext": "The duration over which the force is applied to change the velocity.",
      "label_i18n": {
        "en": "Time",
        "tr": "Time",
        "de": "Time",
        "fr": "Time",
        "es": "Time",
        "ar": "Time"
      }
    }
  ],
  "formulas": {
    "acceleration": "(time !== 0) ? ((finalVelocity - initialVelocity) / time) : 0",
    "force": "mass * ((time !== 0) ? ((finalVelocity - initialVelocity) / time) : 0)",
    "momentumChange": "mass * (finalVelocity - initialVelocity)",
    "impulse": "mass * (finalVelocity - initialVelocity)"
  },
  "outputs": {
    "primary": "force",
    "breakdown": [
      "acceleration",
      "momentumChange",
      "impulse"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "impulse"
  },

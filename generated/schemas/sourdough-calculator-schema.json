  "formulas": {
    "totalFlour": "flourWeight * loafCount",
    "water": "flourWeight * loafCount * hydration / 100",
    "starter": "flourWeight * loafCount * starterPercent / 100",
    "salt": "flourWeight * loafCount * saltPercent / 100",
    "totalDough": "flourWeight * loafCount * (1 + hydration/100 + starterPercent/100 + saltPercent/100)"
  },
  "outputs": {
    "primary": "totalDough",

{
  "toolName": "percent-yield-calculator",
  "inputs": [
    {
      "id": "rawMaterialInput",
      "label": "Raw Material Input",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Total weight of raw material fed into the process",
      "label_i18n": {
        "en": "Raw Material Input",
        "tr": "Hammadde Girdisi",
        "de": "Rohmaterialeinsatz",
        "fr": "Raw Material Input",
        "es": "Raw Material Input",
        "ar": "Raw Material Input"
      },
      "businessContext_i18n": {
        "en": "Total weight of raw material fed into the process",
        "tr": "Proseese beslenen toplam hammadde ağırlığı"
      }
    },
    {
      "id": "productOutput",
      "label": "Product Output",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Net weight of finished good product obtained",
      "label_i18n": {
        "en": "Product Output",
        "tr": "Ürün Çıktısı",
        "de": "Product Output",
        "fr": "Product Output",
        "es": "Product Output",
        "ar": "Product Output"
      },
      "businessContext_i18n": {
        "en": "Net weight of finished good product obtained",
        "tr": "Elde edilen net mamul ürün ağırlığı"
      }
    },
    {
      "id": "expectedYieldPercent",
      "label": "Expected Yield (%)",
      "type": "number",
      "unit": "%",
      "default": 95,
      "businessContext": "Standard or budgeted yield percentage for the process",
      "label_i18n": {
        "en": "Expected Yield (%)",
        "tr": "Beklenen Verim (%)",
        "de": "Expected Yield (%)",
        "fr": "Expected Yield (%)",
        "es": "Expected Yield (%)",
        "ar": "Expected Yield (%)"
      },
      "businessContext_i18n": {
        "en": "Standard or budgeted yield percentage for the process",
        "tr": "Proses için standart veya bütçelenmiş verim yüzdesi"
      }
    },
    {
      "id": "wasteMaterial",
      "label": "Waste Material",
      "type": "number",
      "unit": "kg",
      "default": 0,
      "businessContext": "Weight of waste or scrap produced during production",
      "label_i18n": {
        "en": "Waste Material",
        "tr": "Atık Malzeme",
        "de": "Waste Material",
        "fr": "Waste Material",
        "es": "Waste Material",
        "ar": "Waste Material"
      },
      "businessContext_i18n": {
        "en": "Weight of waste or scrap produced during production",
        "tr": "Üretim sırasında oluşan atık veya fire ağırlığı"
      }
    }
  ],
  "formulas": {
    "yieldPercent": "productOutput / rawMaterialInput * 100",
    "yieldVariance": "(productOutput / rawMaterialInput * 100) - expectedYieldPercent",
    "wastePercent": "wasteMaterial / rawMaterialInput * 100",
    "materialLossPercent": "100 - (productOutput / rawMaterialInput * 100) - (wasteMaterial / rawMaterialInput * 100)"
  },
  "outputs": {
    "primary": "yieldPercent",
    "breakdown": [
      "yieldVariance",
      "wastePercent",
      "materialLossPercent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "materialLossPercent",
    "unit": "%",
    "breakdownUnits": {
      "wastePercent": "%",
      "materialLossPercent": "%"
    }
  },

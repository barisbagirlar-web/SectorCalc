{
  "toolName": "rental-yield-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Property Purchase Price",
      "type": "number",
      "unit": "USD",
      "default": 200000,
      "businessContext": "Total acquisition cost of the property.",
      "label_i18n": {
        "en": "Property Purchase Price",
        "tr": "Mülk Satın Alma Fiyatı",
        "de": "Property Purchase Price",
        "fr": "Property Purchase Price",
        "es": "Property Purchase Price",
        "ar": "Property Purchase Price"
      },
      "businessContext_i18n": {
        "en": "Total acquisition cost of the property.",
        "tr": "Mülkün toplam edinme maliyeti."
      }
    },
    {
      "id": "monthlyRent",
      "label": "Monthly Rental Income",
      "type": "number",
      "unit": "USD/month",
      "default": 1500,
      "businessContext": "Expected monthly rent from the property.",
      "label_i18n": {
        "en": "Monthly Rental Income",
        "tr": "Aylık Kira Geliri",
        "de": "Monthly Rental Income",
        "fr": "Monthly Rental Income",
        "es": "Monthly Rental Income",
        "ar": "Monthly Rental Income"
      },
      "businessContext_i18n": {
        "en": "Expected monthly rent from the property.",
        "tr": "Mülkten beklenen aylık kira."
      }
    },
    {
      "id": "annualExpenses",
      "label": "Total Annual Expenses",
      "type": "number",
      "unit": "USD/year",
      "default": 3000,
      "businessContext": "Sum of all yearly costs (maintenance, taxes, insurance, management fees, etc.).",
      "label_i18n": {
        "en": "Total Annual Expenses",
        "tr": "Toplam Yıllık Giderler",
        "de": "Total Annual Expenses",
        "fr": "Total Annual Expenses",
        "es": "Total Annual Expenses",
        "ar": "Total Annual Expenses"
      },
      "businessContext_i18n": {
        "en": "Sum of all yearly costs (maintenance, taxes, insurance, management fees, etc.).",
        "tr": "Tüm yıllık maliyetlerin toplamı (bakım, vergiler, sigorta, yönetim ücretleri vb.)."
      }
    },
    {
      "id": "vacancyRate",
      "label": "Vacancy Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Estimated percentage of time the property is vacant and not generating rent.",
      "label_i18n": {
        "en": "Vacancy Rate",
        "tr": "Boşluk Oranı",
        "de": "Leerstandsrate",
        "fr": "Vacancy Rate",
        "es": "Vacancy Rate",
        "ar": "Vacancy Rate"
      },
      "businessContext_i18n": {
        "en": "Estimated percentage of time the property is vacant and not generating rent.",
        "tr": "Mülkün boş olduğu ve kira getirmediği tahmini süre yüzdesi."
      }
    }
  ],
  "formulas": {
    "grossYield": "(monthlyRent * 12 / purchasePrice) * 100",
    "netYield": "((monthlyRent * 12 * (1 - vacancyRate / 100) - annualExpenses) / purchasePrice) * 100",
    "cashFlowMonthly": "(monthlyRent * 12 * (1 - vacancyRate / 100) - annualExpenses) / 12"
  },
  "outputs": {
    "primary": "netYield",
    "breakdown": [
      "grossYield",
      "cashFlowMonthly"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "cashFlowMonthly",
    "unit": "USD"
  },

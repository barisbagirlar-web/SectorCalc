{
  "toolName": "invoice-calculator",
  "inputs": [
    {
      "id": "subtotal",
      "label": "Subtotal",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "The total amount of all items before any deductions or additions.",
      "label_i18n": {
        "en": "Subtotal",
        "tr": "Ara Toplam",
        "de": "Subtotal",
        "fr": "Subtotal",
        "es": "Subtotal",
        "ar": "Subtotal"
      },
      "businessContext_i18n": {
        "en": "The total amount of all items before any deductions or additions.",
        "tr": "Herhangi bir kesinti veya eklemeden önceki tüm kalemlerin toplam tutarı."
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount Percentage",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Discount rate applied to the subtotal.",
      "label_i18n": {
        "en": "Discount Percentage",
        "tr": "İndirim Yüzdesi",
        "de": "Discount Percentage",
        "fr": "Discount Percentage",
        "es": "Discount Percentage",
        "ar": "Discount Percentage"
      },
      "businessContext_i18n": {
        "en": "Discount rate applied to the subtotal.",
        "tr": "Ara toplama uygulanan iskonto oranı."
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Tax rate applied after discount, e.g., VAT.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Vergi Oranı",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Tax rate applied after discount, e.g., VAT.",
        "tr": "İskonto sonrası uygulanan vergi oranı, örn. KDV."
      }
    },
    {
      "id": "shippingCost",
      "label": "Shipping Cost",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Flat shipping charge added to the invoice.",
      "label_i18n": {
        "en": "Shipping Cost",
        "tr": "Kargo Ücreti",
        "de": "Shipping Cost",
        "fr": "Shipping Cost",
        "es": "Shipping Cost",
        "ar": "Shipping Cost"
      },
      "businessContext_i18n": {
        "en": "Flat shipping charge added to the invoice.",
        "tr": "Faturaya eklenen sabit kargo ücreti."
      }
    }
  ],
  "formulas": {
    "Final Invoice Total": "subtotal * (1 - discountPercent / 100) * (1 + taxRate / 100) + shippingCost",
    "Discount Amount": "subtotal * discountPercent / 100",
    "Tax Amount": "subtotal * (1 - discountPercent / 100) * taxRate / 100",
    "Subtotal After Discount": "subtotal * (1 - discountPercent / 100)"
  },
  "outputs": {
    "primary": "Final Invoice Total",
    "breakdown": [
      "Discount Amount",
      "Tax Amount",
      "Subtotal After Discount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "Subtotal After Discount",
    "unit": "currency"
  },

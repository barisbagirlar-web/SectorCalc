{
  "toolName": "meat-doneness-calculator",
  "inputs": [
    {
      "id": "meat-weight",
      "label": "Meat Weight",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Weight of the meat cut in kilograms, responsible for heat capacity.",
      "label_i18n": {
        "en": "Meat Weight",
        "tr": "Meat Weight",
        "de": "Meat Weight",
        "fr": "Meat Weight",
        "es": "Meat Weight",
        "ar": "Meat Weight"
      }
    },
    {
      "id": "oven-temp",
      "label": "Oven Temperature",
      "type": "number",
      "unit": "°C",
      "default": 180,
      "businessContext": "Temperature of the cooking environment.",
      "label_i18n": {
        "en": "Oven Temperature",
        "tr": "Oven Temperature",
        "de": "Oven Temperature",
        "fr": "Oven Temperature",
        "es": "Oven Temperature",
        "ar": "Oven Temperature"
      }
    },
    {
      "id": "target-temp",
      "label": "Target Internal Temperature",
      "type": "number",
      "unit": "°C",
      "default": 70,
      "businessContext": "Desired core temperature for doneness.",
      "label_i18n": {
        "en": "Target Internal Temperature",
        "tr": "Target Internal Temperature",
        "de": "Target Internal Temperature",
        "fr": "Target Internal Temperature",
        "es": "Target Internal Temperature",
        "ar": "Target Internal Temperature"
      }
    },
    {
      "id": "starting-temp",
      "label": "Starting Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Initial meat temperature.",
      "label_i18n": {
        "en": "Starting Temperature",
        "tr": "Starting Temperature",
        "de": "Starting Temperature",
        "fr": "Starting Temperature",
        "es": "Starting Temperature",
        "ar": "Starting Temperature"
      }
    },
    {
      "id": "thickness",
      "label": "Meat Thickness",
      "type": "number",
      "unit": "cm",
      "default": 5,
      "businessContext": "Thickness of the cut.",
      "label_i18n": {
        "en": "Meat Thickness",
        "tr": "Meat Thickness",
        "de": "Meat Thickness",
        "fr": "Meat Thickness",
        "es": "Meat Thickness",
        "ar": "Meat Thickness"
      }
    },
    {
      "id": "shape-factor",
      "label": "Shape Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Geometry correction (1: slab, 1.3: cylinder, 1.5: sphere).",
      "label_i18n": {
        "en": "Shape Factor",
        "tr": "Shape Factor",
        "de": "Shape Factor",
        "fr": "Shape Factor",
        "es": "Shape Factor",
        "ar": "Shape Factor"
      }
    }
  ],
  "formulas": {
    "cookingTime": "Math.round((meat_weight ** 0.65) * (thickness ** 0.5) * ((target_temp - starting_temp) / (oven_temp - target_temp)) * 10 * shape_factor * 100) / 100",
    "donenessLevel": "target_temp < 55 ? 'Rare' : target_temp < 65 ? 'Medium-Rare' : target_temp < 70 ? 'Medium' : target_temp < 75 ? 'Medium-Well' : 'Well-Done'",
    "tempDifference": "target_temp - starting_temp"
  },
  "outputs": {
    "primary": "cookingTime",
    "breakdown": [
      "donenessLevel",
      "tempDifference"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "technology-ai-cloud-cyber"
}

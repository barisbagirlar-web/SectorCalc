      "focalLength / (objectDistance - focalLength)",
      "(imageDistance - focalLength) / focalLength"
    ]
  },
  "outputs": {
    "primary": "imageDistance / objectDistance",
    "breakdown": [
      "imageHeight / objectHeight",
      "focalLength / (objectDistance - focalLength)",
      "(imageDistance - focalLength) / focalLength"
    ]
  },

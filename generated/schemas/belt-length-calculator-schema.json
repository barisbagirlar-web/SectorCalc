      "type": "number",
      "unit": "mm",
      "default": 200,
      "businessContext": "Diameter of the larger pulley. Use pitch diameter if available.",
      "label_i18n": {
        "en": "Large Pulley Diameter",
        "tr": "Büyük Kasnak Çapı",

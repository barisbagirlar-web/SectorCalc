        "ar": "Large Pulley Diameter"
      },
      "businessContext_i18n": {
        "en": "Diameter of the larger pulley. Use pitch diameter if available.",
        "tr": "Büyük kasnağın çapı. Mümkünse adım çapını kullanın."
      }
    },
    {
      "id": "small_diameter",
      "label": "Small Pulley Diameter",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Diameter of the smaller pulley.",
      "label_i18n": {
        "en": "Small Pulley Diameter",
        "tr": "Küçük Kasnak Çapı",
        "de": "Small Pulley Diameter",
        "fr": "Small Pulley Diameter",
        "es": "Small Pulley Diameter",
        "ar": "Small Pulley Diameter"
      },
      "businessContext_i18n": {
        "en": "Diameter of the smaller pulley.",
        "tr": "Küçük kasnağın çapı."
      }
    },
    {
      "id": "center_distance",
      "label": "Center Distance",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "businessContext": "Distance between the centers of the two pulleys.",
      "label_i18n": {
        "en": "Center Distance",
        "tr": "Merkez Mesafesi",
        "de": "Center Distance",
        "fr": "Center Distance",
        "es": "Center Distance",
        "ar": "Center Distance"
      },
      "businessContext_i18n": {
        "en": "Distance between the centers of the two pulleys.",
        "tr": "İki kasnağın merkezleri arasındaki mesafe."
      }
    },
    {
      "id": "configuration",
      "label": "Belt Configuration",
      "type": "number",
      "unit": "none",
      "default": 0,
      "businessContext": "0 for open belt drive (pulleys rotate same direction), 1 for crossed belt drive (pulleys rotate opposite directions).",
      "label_i18n": {
        "en": "Belt Configuration",
        "tr": "Kayış Konfigürasyonu",
        "de": "Belt Configuration",
        "fr": "Belt Configuration",
        "es": "Belt Configuration",
        "ar": "Belt Configuration"
      },
      "businessContext_i18n": {
        "en": "0 for open belt drive (pulleys rotate same direction), 1 for crossed belt drive (pulleys rotate opposite directions).",
        "tr": "0 açık kayış tahriki (kasnaklar aynı yönde döner), 1 çapraz kayış tahriki (kasnaklar zıt yönde döner)."
      }
    }
  ],
  "formulas": {
    "straight_length": "2 * center_distance",
    "arc_length": "Math.PI * (large_diameter + small_diameter) / 2",
    "correction_length": "configuration === 0 ? ((large_diameter - small_diameter) ** 2) / (4 * center_distance) : ((large_diameter + small_diameter) ** 2) / (4 * center_distance)",
    "belt_length": "straight_length + arc_length + correction_length"
  },
  "outputs": {
    "primary": "belt_length",
    "breakdown": [
      "straight_length",
      "arc_length",
      "correction_length"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "belt_length",
    "unit": "mm"
  },

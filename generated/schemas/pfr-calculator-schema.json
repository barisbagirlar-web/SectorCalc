  "formulas": {
    "outletConcentration": "Ca0 * (1 - conversion)",
    "theoreticalVolume": "v0 * conversion / (k * Ca0 * (1 - conversion))",
    "spaceTime": "theoreticalVolume / v0",
    "designVolume": "theoreticalVolume * safetyFactor"
  },

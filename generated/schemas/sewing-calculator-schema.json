      }
    },
    {
      "id": "machineCostPerHour",
      "label": "Machine Cost per Hour",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "Hourly cost of machine operation (depreciation, maintenance, energy)",
      "label_i18n": {
        "en": "Machine Cost per Hour",
        "tr": "Makine Saatlik Maliyeti",
        "de": "Machine Cost per Hour",
        "fr": "Machine Cost per Hour",
        "es": "Machine Cost per Hour",
        "ar": "Machine Cost per Hour"
      },
      "businessContext_i18n": {
        "en": "Hourly cost of machine operation (depreciation, maintenance, energy)",
        "tr": "Makine çalışmasının saatlik maliyeti (amortisman, bakım, enerji)"
      }
    }
  ],
  "formulas": {
    "totalStitches": "seamLength * 10 / stitchLength",
    "sewingTimeMinutes": "totalStitches / sewingSpeed",
    "sewingTimeHours": "sewingTimeMinutes / 60",
    "threadLengthMeters": "seamLength / 100 * threadConsumptionFactor",
    "laborCost": "sewingTimeHours * laborCostPerHour",
    "machineCost": "sewingTimeHours * machineCostPerHour",
    "totalCost": "laborCost + machineCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalStitches",
      "sewingTimeMinutes",
      "sewingTimeHours",
      "threadLengthMeters",
      "laborCost",
      "machineCost"
    ],

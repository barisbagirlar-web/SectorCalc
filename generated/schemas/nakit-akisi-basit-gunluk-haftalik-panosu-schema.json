{
  "toolName": "nakit-akisi-basit-gunluk-haftalik-panosu",
  "inputs": [
    {
      "id": "baslangicNakdi",
      "label": "Başlangıç Nakit",
      "type": "number",
      "unit": "TRY",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Dönem başındaki nakit mevcudu. Finansal tablolardan alınır."
    },
    {
      "id": "gunlukGelir",
      "label": "Günlük Gelir",
      "type": "number",
      "unit": "TRY/gün",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Günlük ortalama nakit girişi. Satışlardan elde edilir."
    },
    {
      "id": "gunlukGider",
      "label": "Günlük Gider",
      "type": "number",
      "unit": "TRY/gün",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Günlük ortalama nakit çıkışı. Operasyonel maliyetler."
    },
    {
      "id": "gunlukNetNakitAkisi",
      "label": "Günlük Net Nakit Akışı",
      "type": "number",
      "unit": "TRY/gün",
      "default": 0,
      "min": null,
      "max": null,
      "options": null,
      "businessContext": "Hesaplanan günlük net nakit akışı (gelir - gider)."
    },
    {
      "id": "haftalikGelir",
      "label": "Haftalık Gelir",
      "type": "number",
      "unit": "TRY/hafta",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Haftalık toplam nakit girişi."
    },
    {
      "id": "haftalikGider",
      "label": "Haftalık Gider",
      "type": "number",
      "unit": "TRY/hafta",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Haftalık toplam nakit çıkışı."
    },
    {
      "id": "haftalikNetNakitAkisi",
      "label": "Haftalık Net Nakit Akışı",
      "type": "number",
      "unit": "TRY/hafta",
      "default": 0,
      "min": null,
      "max": null,
      "options": null,
      "businessContext": "Hesaplanan haftalık net nakit akışı (gelir - gider)."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "number",
      "unit": "%",
      "default": 100,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Girdi verilerinin güvenilirlik yüzdesi. Düşükse sonuçlar düzeltilir."
    }
  ],
  "validation": {
    "rules": [
      "gunlukGelir >= 0",
      "gunlukGider >= 0",
      "haftalikGelir >= 0",
      "haftalikGider >= 0",
      "dataConfidence >= 0 && dataConfidence <= 100"
    ],
    "thresholds": {
      "gunlukNetNakitAkisi": "gunlukNetNakitAkisi < 0 ? 'Negatif günlük nakit akışı' : ''",
      "haftalikNetNakitAkisi": "haftalikNetNakitAkisi < 0 ? 'Negatif haftalık nakit akışı' : ''",
      "baslangicNakdi": "baslangicNakdi < 0 ? 'Başlangıç nakdi negatif' : ''"
    }
  },
  "formulas": {
    "gunlukNetNakitAkisi": "gunlukGelir - gunlukGider",
    "haftalikNetNakitAkisi": "haftalikGelir - haftalikGider",
    "gunlukBakiye": "baslangicNakdi + gunlukNetNakitAkisi",
    "haftalikBakiye": "baslangicNakdi + haftalikNetNakitAkisi",
    "dataConfidenceAdjusted": "dataConfidence < 100 ? (gunlukNetNakitAkisi * dataConfidence / 100) : gunlukNetNakitAkisi"
  },
  "outputs": {
    "primary": "gunlukNetNakitAkisi",
    "breakdown": {
      "gunlukBakiye": "baslangicNakdi + gunlukNetNakitAkisi",
      "haftalikBakiye": "baslangicNakdi + haftalikNetNakitAkisi"
    },
    "hiddenLossDrivers": [
      "gunlukNetNakitAkisi < 0 ? 'Negatif günlük nakit akışı' : ''",
      "haftalikNetNakitAkisi < 0 ? 'Negatif haftalık nakit akışı' : ''"
    ],
    "suggestedActions": [
      "gunlukNetNakitAkisi < 0 ? 'Günlük giderleri azaltın veya gelirleri artırın' : ''",
      "haftalikNetNakitAkisi < 0 ? 'Haftalık nakit akışını iyileştirin' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidence < 100 ? (gunlukNetNakitAkisi * dataConfidence / 100) : gunlukNetNakitAkisi"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analizi",
    "Karşılaştırma",
    "Detaylı rapor"
  ],
  "premiumRequired": true
}

        "ar": "Refractive Index (n)"
      }
    },
    {
      "id": "radius1",
      "label": "Radius of Curvature 1 (R1)",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "First surface radius, positive for convex towards object",
      "label_i18n": {
        "en": "Radius of Curvature 1 (R1)",
        "tr": "Radius of Curvature 1 (R1)",
        "de": "Radius of Curvature 1 (R1)",
        "fr": "Radius of Curvature 1 (R1)",
        "es": "Radius of Curvature 1 (R1)",
        "ar": "Radius of Curvature 1 (R1)"
      }
    },
    {
      "id": "radius2",
      "label": "Radius of Curvature 2 (R2)",
      "type": "number",
      "unit": "cm",
      "default": -30,
      "businessContext": "Second surface radius, positive for convex away from object",
      "label_i18n": {
        "en": "Radius of Curvature 2 (R2)",
        "tr": "Radius of Curvature 2 (R2)",
        "de": "Radius of Curvature 2 (R2)",
        "fr": "Radius of Curvature 2 (R2)",
        "es": "Radius of Curvature 2 (R2)",
        "ar": "Radius of Curvature 2 (R2)"
      }
    },
    {
      "id": "objectDistance",
      "label": "Object Distance (do)",
      "type": "number",
      "unit": "cm",
      "default": 100,
      "businessContext": "Distance from object to lens",
      "label_i18n": {
        "en": "Object Distance (do)",
        "tr": "Object Distance (do)",
        "de": "Object Distance (do)",
        "fr": "Object Distance (do)",
        "es": "Object Distance (do)",
        "ar": "Object Distance (do)"
      }
    },
    {
      "id": "objectHeight",
      "label": "Object Height (ho)",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Height of object",
      "label_i18n": {
        "en": "Object Height (ho)",
        "tr": "Object Height (ho)",
        "de": "Object Height (ho)",
        "fr": "Object Height (ho)",
        "es": "Object Height (ho)",
        "ar": "Object Height (ho)"
      }
    }
  ],
  "formulas": {
    "focalLength": "1 / ((refractiveIndex - 1) * (1/radius1 - 1/radius2))",
    "imageDistance": "1 / (1/focalLength - 1/objectDistance)",
    "magnification": "-imageDistance / objectDistance",
    "imageHeight": "magnification * objectHeight"
  },
  "outputs": {
    "primary": "imageHeight",
    "breakdown": [
      "focalLength",
      "imageDistance",
      "magnification"
    ],

  "formulas": {
    "focalLength": "1 / ((refractiveIndex - 1) * (1/radius1 - 1/radius2))",
    "imageDistance": "1 / (1/focalLength - 1/objectDistance)",
    "magnification": "-imageDistance / objectDistance",
    "imageHeight": "magnification * objectHeight"
  },

{
  "toolName": "lens-equation-calculator",
  "inputs": [
    {
      "id": "refractiveIndex",
      "label": "Refractive Index (n)",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Material refractive index",
      "label_i18n": {
        "en": "Refractive Index (n)",
        "tr": "Refractive Index (n)",
        "de": "Refractive Index (n)",
        "fr": "Refractive Index (n)",

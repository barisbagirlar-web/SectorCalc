  "formulas": {
    "totalIngredientCost": "doughCost + sauceCost + cheeseCost + toppingsCost",
    "totalCostPerPizza": "totalIngredientCost + laborCost + overheadCost",
    "sellingPricePerPizza": "totalCostPerPizza / (1 - marginPercent/100)",
    "profitPerPizza": "sellingPricePerPizza - totalCostPerPizza"
  },

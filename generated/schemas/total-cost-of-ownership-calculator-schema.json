    {
      "id": "ownershipYears",
      "label": "Ownership Period",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration of ownership in years",
      "label_i18n": {
        "en": "Ownership Period",
        "tr": "Sahiplik Süresi",
        "de": "Besitzdauer",

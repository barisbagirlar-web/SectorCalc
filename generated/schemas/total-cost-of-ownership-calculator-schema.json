{
  "toolName": "total-cost-of-ownership-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Purchase Price",
      "type": "number",
      "unit": "EUR",
      "default": 10000,
      "businessContext": "Initial acquisition cost of the asset"
    },
    {
      "id": "annualMaintenance",
      "label": "Annual Maintenance Cost",
      "type": "number",
      "unit": "EUR",
      "default": 200,
      "businessContext": "Yearly maintenance expense"
    },
    {
      "id": "annualEnergy",
      "label": "Annual Energy Cost",
      "type": "number",
      "unit": "EUR",
      "default": 500,
      "businessContext": "Yearly energy or fuel cost"
    },
    {
      "id": "resaleValue",
      "label": "Resale Value",
      "type": "number",
      "unit": "EUR",
      "default": 3000,
      "businessContext": "Expected resale or salvage value at end of ownership period"
    },
    {
      "id": "ownershipYears",
      "label": "Ownership Period",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration of ownership in years"
    },
    {
      "id": "discountRate",
      "label": "Annual Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Discount rate reflecting time value of money"
    }
  ],
  "formulas": {
    "totalUndiscounted": "purchasePrice + (annualMaintenance + annualEnergy) * ownershipYears - resaleValue",
    "r": "discountRate / 100",
    "netPresentValue": "purchasePrice + (annualMaintenance + annualEnergy) * ((1 - (1 + discountRate/100) ** (-ownershipYears)) / (discountRate/100)) - resaleValue * (1 + discountRate/100) ** (-ownershipYears)"
  },
  "outputs": {
    "primary": "netPresentValue",
    "breakdown": [
      "totalUndiscounted",
      "netPresentValue"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital"
}

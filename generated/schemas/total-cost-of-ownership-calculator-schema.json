      },
      "businessContext_i18n": {
        "en": "Duration of ownership in years",
        "tr": "Sahiplik süresi (yıl olarak)",
        "de": "Besitzdauer in Jahren",
        "fr": "Durée de possession en années",
        "es": "Duración de la propiedad en años",
        "ar": "مدة الملكية بالسنوات"
      }
    },
    {
      "id": "discountRate",
      "label": "Annual Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Discount rate reflecting time value of money",
      "label_i18n": {
        "en": "Annual Discount Rate",
        "tr": "Yıllık İskonto Oranı",
        "de": "Jährlicher Diskontsatz",
        "fr": "Taux d'actualisation annuel",
        "es": "Tasa de descuento anual",
        "ar": "معدل الخصم السنوي"
      },
      "businessContext_i18n": {
        "en": "Discount rate reflecting time value of money",
        "tr": "Paranın zaman değerini yansıtan iskonto oranı",
        "de": "Abzinsungssatz, der den Zeitwert des Geldes widerspiegelt",
        "fr": "Taux d'actualisation reflétant la valeur temporelle de l'argent",
        "es": "Tasa de descuento que refleja el valor del dinero en el tiempo",
        "ar": "معدل الخصم يعكس القيمة الزمنية للنقود"
      }
    }
  ],
  "formulas": {
    "totalUndiscounted": "purchasePrice + (annualMaintenance + annualEnergy) * ownershipYears - resaleValue",
    "r": "discountRate / 100",
    "netPresentValue": "purchasePrice + (annualMaintenance + annualEnergy) * ((1 - (1 + discountRate/100) ** (-ownershipYears)) / (discountRate/100)) - resaleValue * (1 + discountRate/100) ** (-ownershipYears)"
  },
  "outputs": {
    "primary": "netPresentValue",
    "breakdown": [
      "totalUndiscounted",
      "netPresentValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netPresentValue",
    "unit": "EUR"
  },

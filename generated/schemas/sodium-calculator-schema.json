      "label_i18n": {
        "en": "Sodium Atoms per Molecule",
        "tr": "Sodium Atoms per Molecule",
        "de": "Sodium Atoms per Molecule",
        "fr": "Sodium Atoms per Molecule",
        "es": "Sodium Atoms per Molecule",
        "ar": "Sodium Atoms per Molecule"
      }
    },
    {
      "id": "molarMassCompound",
      "label": "Molar Mass of Compound",
      "type": "number",
      "unit": "g/mol",
      "default": 58.44,
      "businessContext": "Molar mass of the compound (e.g., NaCl: 58.44 g/mol)",
      "label_i18n": {
        "en": "Molar Mass of Compound",
        "tr": "Molar Mass of Compound",
        "de": "Molar Mass of Compound",
        "fr": "Molar Mass of Compound",
        "es": "Molar Mass of Compound",
        "ar": "Molar Mass of Compound"
      }
    },
    {
      "id": "sodiumMolarMass",
      "label": "Molar Mass of Sodium",
      "type": "number",
      "unit": "g/mol",
      "default": 22.99,
      "businessContext": "Standard atomic mass of sodium (22.99 g/mol)",
      "label_i18n": {
        "en": "Molar Mass of Sodium",
        "tr": "Molar Mass of Sodium",
        "de": "Molar Mass of Sodium",
        "fr": "Molar Mass of Sodium",
        "es": "Molar Mass of Sodium",
        "ar": "Molar Mass of Sodium"
      }
    }
  ],
  "formulas": {
    "sodiumMass": "compoundMass * (purity / 100) * (sodiumAtomsPerMolecule * sodiumMolarMass / molarMassCompound)",
    "percentageSodium": "(sodiumAtomsPerMolecule * sodiumMolarMass / molarMassCompound) * 100"
  },
  "outputs": {
    "primary": "sodiumMass",

  "formulas": {
    "normalized_product": "boltInnerDiameter * holeDiameter * numberOfHoles * fluidDensity",
    "result": "boltInnerDiameter * holeDiameter * numberOfHoles * fluidDensity * (fluidViscosity * pressureDifference * dischargeCoefficient)",
    "adjustment_factor": "fluidViscosity * pressureDifference * dischargeCoefficient"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "normalized_product",
      "adjustment_factor"

      }
    },
    {
      "id": "safetyMargin",
      "label": "Safety Margin",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Additional capacity to ensure stable temperature under varying conditions",
      "label_i18n": {
        "en": "Safety Margin",
        "tr": "Safety Margin",
        "de": "Safety Margin",
        "fr": "Safety Margin",
        "es": "Safety Margin",
        "ar": "Safety Margin"
      }
    }
  ],
  "formulas": {
    "tempRise": "targetTemp - roomTemp",
    "heatEnergy": "(volume * 4.186 * tempRise) / 3600",
    "requiredWattage": "(heatEnergy * 1000) / (heatingTime * (efficiency / 100))",
    "recommendedWattage": "requiredWattage * (1 + safetyMargin / 100)"
  },
  "outputs": {
    "primary": "recommendedWattage",
    "breakdown": [
      "tempRise",
      "heatEnergy",
      "requiredWattage"
    ],

    {
      "id": "efficiency",
      "label": "System Efficiency",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Overall efficiency accounting for heat loss through glass and evaporation",
      "label_i18n": {
        "en": "System Efficiency",
        "tr": "System Efficiency",
        "de": "System Efficiency",

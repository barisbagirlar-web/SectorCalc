{
  "toolName": "cable-sizing-calculator",
  "inputs": [
    {
      "id": "loadCurrent",
      "label": "Load Current",
      "type": "number",
      "unit": "A",
      "default": 10,
      "businessContext": "The full load current drawn by the equipment.",
      "label_i18n": {
        "en": "Load Current",
        "tr": "Load Current",
        "de": "Load Current",
        "fr": "Load Current",
        "es": "Load Current",
        "ar": "Load Current"
      }
    },
    {
      "id": "cableLength",
      "label": "Cable Length (one-way)",
      "type": "number",
      "unit": "m",
      "default": 50,
      "businessContext": "One-way distance between power source and load.",
      "label_i18n": {
        "en": "Cable Length (one-way)",
        "tr": "Cable Length (one-way)",
        "de": "Cable Length (one-way)",
        "fr": "Cable Length (one-way)",
        "es": "Cable Length (one-way)",
        "ar": "Cable Length (one-way)"
      }
    },
    {
      "id": "supplyVoltage",
      "label": "Supply Voltage",
      "type": "number",
      "unit": "V",
      "default": 230,
      "businessContext": "Nominal voltage of the supply.",
      "label_i18n": {
        "en": "Supply Voltage",
        "tr": "Supply Voltage",
        "de": "Supply Voltage",
        "fr": "Supply Voltage",
        "es": "Supply Voltage",
        "ar": "Supply Voltage"
      }
    },
    {
      "id": "voltageDropPercent",
      "label": "Max Voltage Drop",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Maximum allowable voltage drop as percentage of supply voltage.",
      "label_i18n": {
        "en": "Max Voltage Drop",
        "tr": "Max Voltage Drop",
        "de": "Max Voltage Drop",
        "fr": "Max Voltage Drop",
        "es": "Max Voltage Drop",
        "ar": "Max Voltage Drop"
      }
    },
    {
      "id": "resistivity",
      "label": "Conductor Resistivity",
      "type": "number",
      "unit": "Ω·mm²/m",
      "default": 0.0172,
      "businessContext": "Resistivity of conductor material at operating temperature (e.g., copper: 0.0172, aluminum: 0.0282).",
      "label_i18n": {
        "en": "Conductor Resistivity",
        "tr": "Conductor Resistivity",
        "de": "Conductor Resistivity",
        "fr": "Conductor Resistivity",
        "es": "Conductor Resistivity",
        "ar": "Conductor Resistivity"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "none",
      "default": 1.25,
      "businessContext": "Design margin to account for future load increases or uncertainties.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    },
    {
      "id": "ambientTempFactor",
      "label": "Temperature Factor",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Correction factor for ambient temperature (1.0 for standard conditions).",
      "label_i18n": {
        "en": "Temperature Factor",
        "tr": "Temperature Factor",
        "de": "Temperature Factor",
        "fr": "Temperature Factor",
        "es": "Temperature Factor",
        "ar": "Temperature Factor"
      }
    }
  ],
  "formulas": {
    "voltageDropVolts": "supplyVoltage * (voltageDropPercent / 100)",
    "minCableArea": "(2 * cableLength * loadCurrent * resistivity * safetyFactor * ambientTempFactor) / voltageDropVolts"
  },
  "outputs": {
    "primary": "minCableArea",
    "breakdown": [
      "voltageDropVolts",
      "minCableArea"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "minCableArea"
  },

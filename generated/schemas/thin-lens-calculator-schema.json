{
  "toolName": "thin-lens-calculator",
  "inputs": [
    {
      "id": "n",
      "label": "Refractive Index n",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Refractive index of the lens material (dimensionless).",
      "label_i18n": {
        "en": "Refractive Index n",
        "tr": "Refractive Index n",
        "de": "Refractive Index n",
        "fr": "Refractive Index n",
        "es": "Refractive Index n",
        "ar": "Refractive Index n"
      }
    },
    {
      "id": "R1",
      "label": "Radius of Curvature R1",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Radius of curvature of the first lens surface. Sign convention: positive if center of curvature is to the right of the vertex.",
      "label_i18n": {
        "en": "Radius of Curvature R1",
        "tr": "Radius of Curvature R1",
        "de": "Radius of Curvature R1",
        "fr": "Radius of Curvature R1",
        "es": "Radius of Curvature R1",
        "ar": "Radius of Curvature R1"
      }
    },
    {
      "id": "R2",
      "label": "Radius of Curvature R2",
      "type": "number",
      "unit": "mm",
      "default": -100,
      "businessContext": "Radius of curvature of the second lens surface. Sign convention: positive if center of curvature is to the right of the vertex.",
      "label_i18n": {
        "en": "Radius of Curvature R2",
        "tr": "Radius of Curvature R2",
        "de": "Radius of Curvature R2",
        "fr": "Radius of Curvature R2",
        "es": "Radius of Curvature R2",
        "ar": "Radius of Curvature R2"
      }
    },
    {
      "id": "u",
      "label": "Object Distance u",
      "type": "number",
      "unit": "mm",
      "default": 200,
      "businessContext": "Distance from the object to the lens, measured along the optical axis. Sign convention: positive if object is on the incident light side (real object).",
      "label_i18n": {
        "en": "Object Distance u",
        "tr": "Object Distance u",
        "de": "Object Distance u",
        "fr": "Object Distance u",
        "es": "Object Distance u",
        "ar": "Object Distance u"
      }
    }
  ],
  "formulas": {
    "focalLength_mm": "1 / ((n - 1) * (1/R1 - 1/R2))",
    "imageDistance_mm": "1 / (1/focalLength_mm - 1/u)",
    "magnification": "-imageDistance_mm / u"
  },
  "outputs": {
    "primary": "focalLength_mm",
    "breakdown": [
      "imageDistance_mm",
      "magnification"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "magnification",
    "unit": "mm",
    "breakdownUnits": {
      "imageDistance_mm": "mm"
    }
  },

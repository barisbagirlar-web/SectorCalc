{
  "toolName": "pay-period-calculator",
  "inputs": [
    {
      "id": "annualSalary",
      "label": "Annual Salary",
      "type": "number",
      "unit": "EUR",
      "default": 30000,
      "businessContext": "Gross annual salary",
      "label_i18n": {
        "en": "Annual Salary",
        "tr": "Annual Salary",
        "de": "Annual Salary",
        "fr": "Annual Salary",
        "es": "Annual Salary",
        "ar": "Annual Salary"
      }
    },
    {
      "id": "payPeriodsPerYear",
      "label": "Number of Pay Periods per Year",
      "type": "number",
      "unit": "unit",
      "default": 12,
      "businessContext": "Frequency of pay checks, e.g., 12 for monthly, 26 for bi-weekly, 52 for weekly",
      "label_i18n": {
        "en": "Number of Pay Periods per Year",
        "tr": "Number of Pay Periods per Year",
        "de": "Number of Pay Periods per Year",
        "fr": "Number of Pay Periods per Year",
        "es": "Number of Pay Periods per Year",
        "ar": "Number of Pay Periods per Year"
      }
    },
    {
      "id": "overtimeHours",
      "label": "Overtime Hours",
      "type": "number",
      "unit": "h",
      "default": 0,
      "businessContext": "Total overtime hours worked in the pay period",
      "label_i18n": {
        "en": "Overtime Hours",
        "tr": "Overtime Hours",
        "de": "Overtime Hours",
        "fr": "Overtime Hours",
        "es": "Overtime Hours",
        "ar": "Overtime Hours"
      }
    },
    {
      "id": "overtimeRateMultiplier",
      "label": "Overtime Rate Multiplier",
      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Multiplier for overtime pay relative to regular hourly rate",
      "label_i18n": {
        "en": "Overtime Rate Multiplier",
        "tr": "Overtime Rate Multiplier",
        "de": "Overtime Rate Multiplier",
        "fr": "Overtime Rate Multiplier",
        "es": "Overtime Rate Multiplier",
        "ar": "Overtime Rate Multiplier"
      }
    },
    {
      "id": "hoursPerPeriod",
      "label": "Hours per Pay Period",
      "type": "number",
      "unit": "h",
      "default": 160,
      "businessContext": "Standard working hours in one pay period",
      "label_i18n": {
        "en": "Hours per Pay Period",
        "tr": "Hours per Pay Period",
        "de": "Hours per Pay Period",
        "fr": "Hours per Pay Period",
        "es": "Hours per Pay Period",
        "ar": "Hours per Pay Period"
      }
    },
    {
      "id": "deductions",
      "label": "Deductions",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Total pre-tax deductions per period",
      "label_i18n": {
        "en": "Deductions",
        "tr": "Deductions",
        "de": "Deductions",
        "fr": "Deductions",
        "es": "Deductions",
        "ar": "Deductions"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Income tax rate applied after deductions",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    },
    {
      "id": "otherWithholdings",
      "label": "Other Withholdings",
      "type": "number",
      "unit": "EUR",
      "default": 0,
      "businessContext": "Additional withholdings like insurance, union dues",
      "label_i18n": {
        "en": "Other Withholdings",
        "tr": "Other Withholdings",
        "de": "Other Withholdings",
        "fr": "Other Withholdings",
        "es": "Other Withholdings",
        "ar": "Other Withholdings"
      }
    }
  ],
  "formulas": {
    "regularPay": "annualSalary / payPeriodsPerYear",
    "hourlyRate": "regularPay / hoursPerPeriod",
    "overtimePay": "overtimeHours * hourlyRate * overtimeRateMultiplier",
    "grossPayPerPeriod": "regularPay + overtimePay",
    "taxableIncome": "grossPayPerPeriod - deductions",
    "taxAmount": "taxableIncome * (taxRate / 100)",
    "netPayPerPeriod": "taxableIncome - taxAmount - otherWithholdings"
  },
  "outputs": {
    "primary": "netPayPerPeriod",
    "breakdown": [
      "grossPayPerPeriod",
      "regularPay",
      "overtimePay",
      "taxAmount"
    ]
  },
  "category": "İK & Personel",
  "sector": "Finans & Sigorta",
  "premiumRequired": false,
  "catalogCategory": "date-time",
  "sectorSlug": "daily-renovation",
  "categorySlug": "workforce-hr",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "hr"
}

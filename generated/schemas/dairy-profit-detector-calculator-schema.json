  "validation": {
    "rules": [
      {
        "id": "rule_1",
        "condition": "milk_volume_liters > 0",
        "message": "Milk volume must be greater than zero."
      },
      {
        "id": "rule_2",
        "condition": "fat_percentage >= 0 && fat_percentage <= 10",
        "message": "Fat percentage must be between 0 and 10."
      },
      {
        "id": "rule_3",
        "condition": "protein_percentage >= 0 && protein_percentage <= 6",
        "message": "Protein percentage must be between 0 and 6."
      },
      {
        "id": "rule_4",
        "condition": "selling_price_per_liter >= 0",
        "message": "Selling price must be non-negative."
      },
      {
        "id": "rule_5",
        "condition": "production_cost_per_liter >= 0",
        "message": "Production cost must be non-negative."
      },
      {
        "id": "rule_6",
        "condition": "waste_percentage >= 0 && waste_percentage <= 20",
        "message": "Waste percentage must be between 0 and 20."
      },
      {
        "id": "rule_7",
        "condition": "labor_hours_per_day >= 0",
        "message": "Labor hours must be non-negative."
      },
      {
        "id": "rule_8",
        "condition": "labor_rate_per_hour >= 0",
        "message": "Labor rate must be non-negative."
      },
      {
        "id": "rule_9",
        "condition": "energy_cost_per_day >= 0",
        "message": "Energy cost must be non-negative."
      },
      {
        "id": "rule_10",
        "condition": "other_variable_cost_per_liter >= 0",
        "message": "Other variable cost must be non-negative."
      },
      {
        "id": "rule_11",
        "condition": "fixed_cost_per_day >= 0",
        "message": "Fixed cost must be non-negative."
      },
      {
        "id": "rule_12",
        "condition": "quality_grade == 'A' || quality_grade == 'B' || quality_grade == 'C'",
        "message": "Quality grade must be A, B, or C."
      },
      {
        "id": "rule_13",
        "condition": "seasonal_demand_factor == 'Low' || seasonal_demand_factor == 'Normal' || seasonal_demand_factor == 'High'",
        "message": "Seasonal demand factor must be Low, Normal, or High."
      }
    ],
    "thresholds": [
      {
        "id": "threshold_1",
        "condition": "profit_margin_percentage < 5",
        "severity": "warning",
        "message": "Profit margin is below 5% – consider cost reduction or price increase."
      },
      {
        "id": "threshold_2",
        "condition": "profit_margin_percentage < 0",
        "severity": "critical",
        "message": "Negative profit margin – immediate action required."
      },
      {
        "id": "threshold_3",
        "condition": "waste_percentage > 5",
        "severity": "warning",
        "message": "Waste exceeds 5% – investigate process losses."
      },
      {
        "id": "threshold_4",
        "condition": "labor_efficiency < 50",
        "severity": "warning",
        "message": "Labor efficiency (liters per labor hour) below 50 – review staffing and automation."
      },
      {
        "id": "threshold_5",
        "condition": "quality_grade == 'C'",
        "severity": "critical",
        "message": "Quality grade C – urgent quality improvement needed to avoid penalties."
      }
    ]
  },

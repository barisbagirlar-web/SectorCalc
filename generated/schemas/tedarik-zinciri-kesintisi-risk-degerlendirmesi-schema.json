  "formulas": {
    "RiskExposure": "ProbabilityOfDisruption * FinancialImpact",
    "TimeToRecover": "DaysToRestoreFullCapacity",
    "RevenueLoss": "DailyRevenue * TimeToRecover * (1 - BufferCapacityPct)",
    "MitigationCost": "DualSourcingPremium + SafetyStockCarryingCost + InsurancePremium",
    "RiskAdjustedCost": "ExpectedAnnualLoss + MitigationCost",
    "ResilienceIndex": "1 / (TimeToRecover * VulnerabilityScore)"
  },

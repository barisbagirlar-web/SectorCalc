    "caloriesFromAlcohol": "alcohol_g * 7",
    "totalCalories": "caloriesFromProtein + caloriesFromCarbs + caloriesFromFat + caloriesFromFiber + caloriesFromAlcohol",
    "caloriesPer100g": "totalCalories * 100 / serving_size_g"

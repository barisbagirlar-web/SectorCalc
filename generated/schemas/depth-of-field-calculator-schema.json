      }
    },
    {
      "id": "circleOfConfusion",
      "label": "Circle of Confusion",
      "type": "number",
      "unit": "mm",
      "default": 0.03,
      "businessContext": "Circle of confusion in mm (0.03 for full-frame 35mm)",
      "label_i18n": {
        "en": "Circle of Confusion",
        "tr": "Karışıklık Çemberi",
        "de": "Zerstreuungskreis",
        "fr": "Cercle de confusion",
        "es": "Círculo de confusión",
        "ar": "دائرة التشويش"
      },
      "businessContext_i18n": {
        "en": "Circle of confusion in mm (0.03 for full-frame 35mm)",
        "tr": "mm cinsinden karışıklık çemberi (tam kare 35mm için 0.03)",
        "de": "Zerstreuungskreis in mm (0,03 für Vollformat 35mm)",
        "fr": "Cercle de confusion en mm (0,03 pour plein format 35 mm)",
        "es": "Círculo de confusión en mm (0.03 para full-frame 35mm)",
        "ar": "دائرة التشويش بالملم (0.03 لكامل الإطار 35 مم)"
      }
    }
  ],
  "formulas": {
    "hyperfocalDistance": "(focalLength * focalLength) / (aperture * circleOfConfusion) / 1000",
    "nearFocusLimit": "(hyperfocalDistance * subjectDistance) / (hyperfocalDistance + subjectDistance)",
    "farFocusLimit": "(hyperfocalDistance * subjectDistance) / (hyperfocalDistance - subjectDistance)",
    "totalDoF": "farFocusLimit - nearFocusLimit"
  },
  "outputs": {
    "primary": "totalDoF",
    "breakdown": [
      "nearFocusLimit",
      "farFocusLimit",
      "hyperfocalDistance"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalDoF",
    "unit": "m"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Birim & Dönüşüm",
  "premiumRequired": false,
  "catalogCategory": "gaming-entertainment",

      "default": 10,
      "businessContext": "Distance from camera to subject in meters",
      "label_i18n": {
        "en": "Subject Distance",
        "tr": "Nesne Mesafesi",
        "de": "Objektabstand",
        "fr": "Distance du sujet",
        "es": "Distancia al sujeto",

      },
      "businessContext_i18n": {
        "en": "Distance from camera to subject in meters",
        "tr": "Kameradan nesneye metre cinsinden mesafe",
        "de": "Abstand von Kamera zum Objekt in Metern",
        "fr": "Distance de l'appareil au sujet en mètres",

{
  "toolName": "butter-calculator",
  "inputs": [
    {
      "id": "creamVolume",
      "label": "Cream Volume",
      "type": "number",
      "unit": "L",
      "default": 100,
      "businessContext": "The volume of cream used in butter production",
      "label_i18n": {
        "en": "Cream Volume",
        "tr": "Krema Hacmi",
        "de": "Sahnevolumen",
        "fr": "Cream Volume",
        "es": "Cream Volume",
        "ar": "Cream Volume"
      },
      "businessContext_i18n": {
        "en": "The volume of cream used in butter production",
        "tr": "Tereyağı üretiminde kullanılan krema hacmi",
        "de": "Das Volumen der bei der Butterherstellung verwendeten Sahne"
      }
    },
    {
      "id": "creamFatPercentage",
      "label": "Cream Fat %",
      "type": "number",
      "unit": "%",
      "default": 35,
      "businessContext": "Fat content of the cream",
      "label_i18n": {
        "en": "Cream Fat %",
        "tr": "Krema Yağ %",
        "de": "Sahne-Fett %",
        "fr": "Cream Fat %",
        "es": "Cream Fat %",
        "ar": "Cream Fat %"
      },
      "businessContext_i18n": {
        "en": "Fat content of the cream",
        "tr": "Kremanın yağ içeriği",
        "de": "Fettgehalt der Sahne"
      }
    },
    {
      "id": "butterFatPercentage",
      "label": "Butter Fat %",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Target fat content in butter",
      "label_i18n": {
        "en": "Butter Fat %",
        "tr": "Tereyağı Yağ %",
        "de": "Butter-Fett %",
        "fr": "Butter Fat %",
        "es": "Butter Fat %",
        "ar": "Butter Fat %"
      },
      "businessContext_i18n": {
        "en": "Target fat content in butter",
        "tr": "Tereyağında hedeflenen yağ içeriği",
        "de": "Ziel-Fettgehalt in der Butter"
      }
    },
    {
      "id": "processEfficiency",
      "label": "Process Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Efficiency of the churning process",
      "label_i18n": {
        "en": "Process Efficiency",
        "tr": "Proses Verimliliği",
        "de": "Prozesseffizienz",
        "fr": "Process Efficiency",
        "es": "Process Efficiency",
        "ar": "Process Efficiency"
      },
      "businessContext_i18n": {
        "en": "Efficiency of the churning process",
        "tr": "Yayıklama prosesinin verimliliği",
        "de": "Effizienz des Butterns"
      }
    },
    {
      "id": "saltPercentage",
      "label": "Salt %",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of salt to add (0 for unsalted butter)",
      "label_i18n": {
        "en": "Salt %",
        "tr": "Tuz %",
        "de": "Salz %",
        "fr": "Salt %",
        "es": "Salt %",
        "ar": "Salt %"
      },
      "businessContext_i18n": {
        "en": "Percentage of salt to add (0 for unsalted butter)",
        "tr": "Eklenecek tuz yüzdesi (tuzsuz tereyağı için 0)",
        "de": "Prozentsatz des zuzugebenden Salzes (0 für ungesalzene Butter)"
      }
    }
  ],
  "formulas": {
    "totalFat": "creamVolume * creamFatPercentage / 100",
    "theoreticalYield": "totalFat / (butterFatPercentage / 100)",
    "butterYield": "theoreticalYield * processEfficiency / 100",
    "buttermilkVolume": "creamVolume - butterYield",
    "saltWeight": "butterYield * saltPercentage / 100",
    "butterWithSalt": "butterYield + saltWeight"
  },
  "outputs": {
    "primary": "butterYield",
    "breakdown": [
      "totalFat",
      "theoreticalYield",
      "buttermilkVolume",
      "saltWeight",
      "butterWithSalt"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "butterWithSalt",
    "unit": "L"
  },
  "category": "Verimlilik & OEE",
  "sector": "Makine & Üretim",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",

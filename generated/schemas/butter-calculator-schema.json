{
  "toolName": "butter-calculator",
  "inputs": [
    {
      "id": "creamVolume",
      "label": "Cream Volume",
      "type": "number",
      "unit": "L",
      "default": 100,
      "businessContext": "The volume of cream used in butter production",
      "label_i18n": {
        "en": "Cream Volume",
        "tr": "Cream Volume",
        "de": "Cream Volume",
        "fr": "Cream Volume",
        "es": "Cream Volume",
        "ar": "Cream Volume"
      }
    },
    {
      "id": "creamFatPercentage",
      "label": "Cream Fat %",
      "type": "number",
      "unit": "%",
      "default": 35,
      "businessContext": "Fat content of the cream",
      "label_i18n": {
        "en": "Cream Fat %",
        "tr": "Cream Fat %",
        "de": "Cream Fat %",
        "fr": "Cream Fat %",
        "es": "Cream Fat %",
        "ar": "Cream Fat %"
      }
    },
    {
      "id": "butterFatPercentage",
      "label": "Butter Fat %",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Target fat content in butter",
      "label_i18n": {
        "en": "Butter Fat %",
        "tr": "Butter Fat %",
        "de": "Butter Fat %",
        "fr": "Butter Fat %",
        "es": "Butter Fat %",
        "ar": "Butter Fat %"
      }
    },
    {
      "id": "processEfficiency",
      "label": "Process Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Efficiency of the churning process",
      "label_i18n": {
        "en": "Process Efficiency",
        "tr": "Process Efficiency",
        "de": "Process Efficiency",
        "fr": "Process Efficiency",
        "es": "Process Efficiency",
        "ar": "Process Efficiency"
      }
    },
    {
      "id": "saltPercentage",
      "label": "Salt %",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of salt to add (0 for unsalted butter)",
      "label_i18n": {
        "en": "Salt %",
        "tr": "Salt %",
        "de": "Salt %",
        "fr": "Salt %",
        "es": "Salt %",
        "ar": "Salt %"
      }
    }
  ],
  "formulas": {
    "totalFat": "creamVolume * creamFatPercentage / 100",
    "theoreticalYield": "totalFat / (butterFatPercentage / 100)",
    "butterYield": "theoreticalYield * processEfficiency / 100",
    "buttermilkVolume": "creamVolume - butterYield",
    "saltWeight": "butterYield * saltPercentage / 100",
    "butterWithSalt": "butterYield + saltWeight"
  },
  "outputs": {
    "primary": "butterYield",
    "breakdown": [
      "totalFat",
      "theoreticalYield",
      "buttermilkVolume",
      "saltWeight",
      "butterWithSalt"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "butterWithSalt"
  },
  "category": "Verimlilik & OEE",
  "sector": "Makine & Üretim",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",

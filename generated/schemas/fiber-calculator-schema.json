  "formulas": {
    "totalLoss": "length * attenuation + connectors * connectorLoss + splices * spliceLoss + margin",
    "fiberLoss": "length * attenuation",
    "connectorLossTotal": "connectors * connectorLoss",
    "spliceLossTotal": "splices * spliceLoss"
  },
  "outputs": {

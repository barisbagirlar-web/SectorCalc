{
  "toolName": "cubic-meters-to-cubic-feet-calculator",
  "inputs": [
    {
      "id": "cubicMeters",
      "label": "Volume (m³)",
      "type": "number",
      "unit": "m³",
      "default": 1,
      "businessContext": "The volume in cubic meters to be converted.",
      "label_i18n": {
        "en": "Volume (m³)",
        "tr": "Volume (m³)",
        "de": "Volume (m³)",
        "fr": "Volume (m³)",
        "es": "Volume (m³)",
        "ar": "Volume (m³)"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (ft³ per m³)",
      "type": "number",
      "unit": "ft³/m³",
      "default": 35.314667,
      "businessContext": "The number of cubic feet per cubic meter. Based on 1 m = 3.28084 ft.",
      "label_i18n": {
        "en": "Conversion Factor (ft³ per m³)",
        "tr": "Conversion Factor (ft³ per m³)",
        "de": "Conversion Factor (ft³ per m³)",
        "fr": "Conversion Factor (ft³ per m³)",
        "es": "Conversion Factor (ft³ per m³)",
        "ar": "Conversion Factor (ft³ per m³)"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Desired number of decimal places for the rounded result.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier for safety or conversion margin, typically 1 for exact conversion.",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Safety Factor",
        "de": "Safety Factor",
        "fr": "Safety Factor",
        "es": "Safety Factor",
        "ar": "Safety Factor"
      }
    },
    {
      "id": "measurementUncertainty",
      "label": "Measurement Uncertainty (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage uncertainty in the input measurement, affecting output uncertainty.",
      "label_i18n": {
        "en": "Measurement Uncertainty (%)",
        "tr": "Measurement Uncertainty (%)",
        "de": "Measurement Uncertainty (%)",
        "fr": "Measurement Uncertainty (%)",
        "es": "Measurement Uncertainty (%)",
        "ar": "Measurement Uncertainty (%)"
      }
    }
  ],
  "formulas": {
    "cubicFeet": "cubicMeters * conversionFactor * safetyFactor",
    "uncertainty": "cubicFeet * (measurementUncertainty / 100)",
    "lowerBound": "cubicFeet - uncertainty",
    "upperBound": "cubicFeet + uncertainty",
    "cubicFeetRounded": "Math.round(cubicFeet * 10**decimalPlaces) / 10**decimalPlaces"
  },
  "outputs": {
    "primary": "cubicFeetRounded",
    "breakdown": [
      "cubicFeet",
      "lowerBound",
      "upperBound"
    ]
  },

{
  "toolName": "flow-rate-converter-calculator",
  "inputs": [
    {
      "id": "massFlow",
      "label": "Mass Flow",
      "type": "number",
      "unit": "kg/h",
      "default": 100,
      "businessContext": "Mass flow rate of fluid, typically gas"
    },
    {
      "id": "molarMass",
      "label": "Molar Mass",
      "type": "number",
      "unit": "g/mol",
      "default": 28.96,
      "businessContext": "Molar mass of the gas (e.g., air ≈ 28.96 g/mol)"
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Gas temperature in Celsius"
    },
    {
      "id": "pressure",
      "label": "Pressure",
      "type": "number",
      "unit": "bar",
      "default": 1.01325,
      "businessContext": "Absolute pressure of gas (1 atm = 1.01325 bar)"
    }
  ],
  "formulas": {
    "volumetricFlow": "(massFlow * 8.314 * (temperature + 273.15)) / (pressure * molarMass * 100)",
    "density": "(pressure * molarMass * 100) / (8.314 * (temperature + 273.15))",
    "volumetricFlowLmin": "(massFlow * 8.314 * (temperature + 273.15)) / (pressure * molarMass * 6)"
  },
  "outputs": {
    "primary": "volumetricFlow",
    "breakdown": [
      "density",
      "volumetricFlowLmin"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management"
}

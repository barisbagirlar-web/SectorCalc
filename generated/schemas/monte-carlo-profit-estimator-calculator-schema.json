        "fr": "Z-Score for CI",
        "es": "Z-Score for CI",
        "ar": "Z-Score for CI"
      }
    }
  ],
  "formulas": {
    "profitMean": "revenueMean - costMean",
    "profitStd": "Math.sqrt(revenueStd**2 + costStd**2 - 2 * correlation * revenueStd * costStd)",
    "lower": "profitMean - zScore * profitStd",
    "upper": "profitMean + zScore * profitStd"
  },
  "outputs": {
    "primary": "profitMean",
    "breakdown": [
      "lower",
      "upper"
    ]
  },

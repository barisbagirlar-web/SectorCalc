      }
    },
    {
      "id": "multiplier",
      "label": "Scale Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplier to apply after conversion.",
      "label_i18n": {
        "en": "Scale Factor",
        "tr": "Scale Factor",
        "de": "Scale Factor",
        "fr": "Scale Factor",
        "es": "Scale Factor",
        "ar": "Scale Factor"
      }
    },
    {
      "id": "constant",
      "label": "Offset",
      "type": "number",
      "unit": "m²",
      "default": 0,
      "businessContext": "Additive constant in square meters.",
      "label_i18n": {
        "en": "Offset",
        "tr": "Offset",
        "de": "Offset",
        "fr": "Offset",
        "es": "Offset",
        "ar": "Offset"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 6,
      "businessContext": "Number of decimal places for rounding.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",

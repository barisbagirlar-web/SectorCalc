{
  "toolName": "menu-profit-leak-detector",
  "inputs": [
    {
      "id": "totalRevenue",
      "label": "Total Revenue",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total revenue from menu sales over the analysis period. Standard financial metric."
    },
    {
      "id": "totalCostOfGoodsSold",
      "label": "Total Cost of Goods Sold",
      "type": "number",
      "unit": "USD",
      "default": 60000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total cost of ingredients and direct materials. Based on standard cost accounting."
    },
    {
      "id": "totalLaborCost",
      "label": "Total Labor Cost",
      "type": "number",
      "unit": "USD",
      "default": 20000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total labor cost including wages, benefits, and payroll taxes. Industry standard."
    },
    {
      "id": "totalOverheadCost",
      "label": "Total Overhead Cost",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Fixed and variable overhead costs (rent, utilities, equipment). Standard cost accounting."
    },
    {
      "id": "totalWasteCost",
      "label": "Total Waste Cost",
      "type": "number",
      "unit": "USD",
      "default": 5000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Cost of wasted ingredients, spoiled items, and overproduction. Lean manufacturing waste reduction."
    },
    {
      "id": "totalTheftCost",
      "label": "Total Theft Cost",
      "type": "number",
      "unit": "USD",
      "default": 2000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Estimated cost of inventory theft or shrinkage. Industry loss prevention."
    },
    {
      "id": "totalDiscountsGiven",
      "label": "Total Discounts Given",
      "type": "number",
      "unit": "USD",
      "default": 3000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total value of discounts, promotions, and comps. Revenue management."
    },
    {
      "id": "totalMenuPriceErrors",
      "label": "Total Menu Price Errors",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Revenue lost due to incorrect pricing or POS errors. Quality control."
    },
    {
      "id": "analysisPeriodDays",
      "label": "Analysis Period (Days)",
      "type": "number",
      "unit": "days",
      "default": 30,
      "min": 1,
      "max": 365,
      "options": null,
      "businessContext": "Duration of the analysis period. Standard time frame for financial analysis."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Confidence level in the accuracy of input data. Used for risk adjustment."
    }
  ],
  "validation": {
    "rules": [
      "totalRevenue >= 0",
      "totalCostOfGoodsSold >= 0",
      "totalLaborCost >= 0",
      "totalOverheadCost >= 0",
      "totalWasteCost >= 0",
      "totalTheftCost >= 0",
      "totalDiscountsGiven >= 0",
      "totalMenuPriceErrors >= 0",
      "analysisPeriodDays >= 1",
      "dataConfidence >= 0 and dataConfidence <= 100"
    ],
    "thresholds": {
      "wasteRatio": "0.05",
      "theftRatio": "0.02",
      "discountRatio": "0.03",
      "priceErrorRatio": "0.01"
    }
  },
  "formulas": {
    "totalCost": "totalCostOfGoodsSold + totalLaborCost + totalOverheadCost",
    "grossProfit": "totalRevenue - totalCost",
    "totalLeak": "totalWasteCost + totalTheftCost + totalDiscountsGiven + totalMenuPriceErrors",
    "netProfit": "grossProfit - totalLeak",
    "profitMargin": "(netProfit / totalRevenue) * 100",
    "leakRatio": "(totalLeak / totalRevenue) * 100",
    "wasteRatio": "totalWasteCost / totalRevenue",
    "theftRatio": "totalTheftCost / totalRevenue",
    "discountRatio": "totalDiscountsGiven / totalRevenue",
    "priceErrorRatio": "totalMenuPriceErrors / totalRevenue",
    "dailyLeak": "totalLeak / analysisPeriodDays",
    "dataConfidenceAdjustedLeak": "totalLeak * (1 + (100 - dataConfidence) / 100)"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": {
      "grossProfit": "grossProfit",
      "totalLeak": "totalLeak",
      "profitMargin": "profitMargin",
      "leakRatio": "leakRatio",
      "dailyLeak": "dailyLeak"
    },
    "hiddenLossDrivers": [
      "wasteRatio > 0.05 ? 'High waste cost' : ''",
      "theftRatio > 0.02 ? 'High theft cost' : ''",
      "discountRatio > 0.03 ? 'High discount cost' : ''",
      "priceErrorRatio > 0.01 ? 'High price error cost' : ''"
    ],
    "suggestedActions": [
      "wasteRatio > 0.05 ? 'Implement portion control and inventory management' : ''",
      "theftRatio > 0.02 ? 'Enhance security and inventory tracking' : ''",
      "discountRatio > 0.03 ? 'Review discount policies and authorization' : ''",
      "priceErrorRatio > 0.01 ? 'Audit POS system and staff training' : ''"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjustedLeak"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Benchmark Comparison",
    "Detailed Report"
  ],
  "premiumRequired": true
}

  "formulas": {
    "Area_Cross": "LookupArea(ProfileType, Size)",
    "Weight_PerMeter": "Area_Cross * Density_Steel",
    "TotalWeight": "Weight_PerMeter * Length * Quantity",
    "Cost_Material": "TotalWeight * PricePerTon",
    "PaintArea": "Perimeter * Length",
    "FireproofingArea": "PaintArea",
    "Deflection_Max": "(5 * w * L^4) / (384 * E * I)",
    "Moment_Max": "(w * L^2) / 8"
  },
  "outputs": {
    "primary": "Moment_Max",
    "unit": "USD",

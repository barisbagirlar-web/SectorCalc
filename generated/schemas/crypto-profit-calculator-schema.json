{
  "toolName": "crypto-profit-calculator",
  "inputs": [
    {
      "id": "investment",
      "label": "Initial Investment",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "businessContext": "Amount invested in fiat currency (USD)",
      "label_i18n": {
        "en": "Initial Investment",
        "tr": "Initial Investment",
        "de": "Initial Investment",
        "fr": "Initial Investment",
        "es": "Initial Investment",
        "ar": "Initial Investment"
      }
    },
    {
      "id": "buyPrice",
      "label": "Buy Price per Coin",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Price at which cryptocurrency was purchased (per unit)",
      "label_i18n": {
        "en": "Buy Price per Coin",
        "tr": "Buy Price per Coin",
        "de": "Buy Price per Coin",
        "fr": "Buy Price per Coin",
        "es": "Buy Price per Coin",
        "ar": "Buy Price per Coin"
      }
    },
    {
      "id": "sellPrice",
      "label": "Sell Price per Coin",
      "type": "number",
      "unit": "USD",
      "default": 150,
      "businessContext": "Price at which cryptocurrency is sold (per unit)",
      "label_i18n": {
        "en": "Sell Price per Coin",
        "tr": "Sell Price per Coin",
        "de": "Sell Price per Coin",
        "fr": "Sell Price per Coin",
        "es": "Sell Price per Coin",
        "ar": "Sell Price per Coin"
      }
    },
    {
      "id": "feePercent",
      "label": "Transaction Fee (%)",
      "type": "number",
      "unit": "%",
      "default": 0.5,
      "businessContext": "Fee percentage charged per transaction (buy and sell)",
      "label_i18n": {
        "en": "Transaction Fee (%)",
        "tr": "Transaction Fee (%)",
        "de": "Transaction Fee (%)",
        "fr": "Transaction Fee (%)",
        "es": "Transaction Fee (%)",
        "ar": "Transaction Fee (%)"
      }
    },
    {
      "id": "taxPercent",
      "label": "Tax on Profit (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Capital gains tax percentage applied to net profit",
      "label_i18n": {
        "en": "Tax on Profit (%)",
        "tr": "Tax on Profit (%)",
        "de": "Tax on Profit (%)",
        "fr": "Tax on Profit (%)",
        "es": "Tax on Profit (%)",
        "ar": "Tax on Profit (%)"
      }
    }
  ],
  "formulas": {
    "amount": "investment / buyPrice",
    "grossProfit": "amount * sellPrice - investment",
    "buyFee": "investment * feePercent / 100",
    "sellFee": "amount * sellPrice * feePercent / 100",
    "netProfitBeforeTax": "grossProfit - buyFee - sellFee",
    "taxAmount": "netProfitBeforeTax * taxPercent / 100",
    "netProfit": "netProfitBeforeTax - taxAmount",
    "roi": "(netProfit / investment) * 100"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "grossProfit",
      "netProfitBeforeTax",
      "taxAmount",
      "roi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roi"
  },

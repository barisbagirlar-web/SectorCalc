{
  "toolName": "life-expectancy-by-country-calculator",
  "inputs": [
    {
      "id": "currentAge",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Current age of the individual.",
      "label_i18n": {
        "en": "Current Age",
        "tr": "Current Age",
        "de": "Current Age",
        "fr": "Current Age",
        "es": "Current Age",
        "ar": "Current Age"
      }
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "none",
      "default": 0,
      "businessContext": "Gender: 0 for male, 1 for female. Used to apply life expectancy adjustment.",
      "label_i18n": {
        "en": "Gender",
        "tr": "Gender",
        "de": "Gender",
        "fr": "Gender",
        "es": "Gender",
        "ar": "Gender"
      }
    },
    {
      "id": "countryLifeExpectancy",
      "label": "Country Life Expectancy at Birth",
      "type": "number",
      "unit": "years",
      "default": 75,
      "businessContext": "Average life expectancy at birth for the country (e.g., from WHO data).",
      "label_i18n": {
        "en": "Country Life Expectancy at Birth",
        "tr": "Country Life Expectancy at Birth",
        "de": "Country Life Expectancy at Birth",
        "fr": "Country Life Expectancy at Birth",
        "es": "Country Life Expectancy at Birth",
        "ar": "Country Life Expectancy at Birth"
      }
    },
    {
      "id": "healthFactor",
      "label": "Health Factor",
      "type": "number",
      "unit": "none",
      "default": 1,
      "businessContext": "Multiplier for individual health relative to average (1.0 = average, <1 worse, >1 better).",
      "label_i18n": {
        "en": "Health Factor",
        "tr": "Health Factor",
        "de": "Health Factor",
        "fr": "Health Factor",
        "es": "Health Factor",
        "ar": "Health Factor"
      }
    }
  ],
  "formulas": {
    "adjustedLifeExpectancy": "countryLifeExpectancy - currentAge",
    "genderAdjustment": "gender === 1 ? 5 : 0",
    "healthMultiplier": "healthFactor",
    "remainingLifeExpectancy": "(adjustedLifeExpectancy + genderAdjustment) * healthMultiplier"
  },
  "outputs": {
    "primary": "remainingLifeExpectancy",
    "breakdown": [
      "adjustedLifeExpectancy",
      "genderAdjustment",
      "healthMultiplier"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

  "formulas": {
    "adjustedLifeExpectancy": "countryLifeExpectancy - currentAge",
    "genderAdjustment": "gender === 1 ? 5 : 0",
    "healthMultiplier": "healthFactor",
    "remainingLifeExpectancy": "(adjustedLifeExpectancy + genderAdjustment) * healthMultiplier"
  },
  "outputs": {
    "primary": "remainingLifeExpectancy",
    "breakdown": [
      "adjustedLifeExpectancy",
      "genderAdjustment",
      "healthMultiplier"
    ],

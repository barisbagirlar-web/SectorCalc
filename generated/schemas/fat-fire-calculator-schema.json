      }
    },
    {
      "id": "annualReturnRate",
      "label": "Expected Annual Real Return",
      "type": "number",
      "unit": "decimal",
      "default": 0.07,
      "businessContext": "Expected annual real return on investments (e.g., 0.07 for 7%).",
      "label_i18n": {
        "en": "Expected Annual Real Return",
        "tr": "Expected Annual Real Return",
        "de": "Expected Annual Real Return",
        "fr": "Expected Annual Real Return",
        "es": "Expected Annual Real Return",
        "ar": "Expected Annual Real Return"
      }
    },
    {
      "id": "inflationRate",
      "label": "Expected Annual Inflation Rate",
      "type": "number",
      "unit": "decimal",
      "default": 0.03,
      "businessContext": "Expected annual inflation rate (e.g., 0.03 for 3%).",
      "label_i18n": {
        "en": "Expected Annual Inflation Rate",
        "tr": "Expected Annual Inflation Rate",
        "de": "Expected Annual Inflation Rate",
        "fr": "Expected Annual Inflation Rate",
        "es": "Expected Annual Inflation Rate",
        "ar": "Expected Annual Inflation Rate"
      }
    },
    {
      "id": "safeWithdrawalRate",
      "label": "Safe Withdrawal Rate",
      "type": "number",
      "unit": "decimal",
      "default": 0.04,
      "businessContext": "Percentage of portfolio you can safely withdraw annually (e.g., 0.04 for 4% rule).",
      "label_i18n": {
        "en": "Safe Withdrawal Rate",
        "tr": "Safe Withdrawal Rate",
        "de": "Safe Withdrawal Rate",
        "fr": "Safe Withdrawal Rate",
        "es": "Safe Withdrawal Rate",
        "ar": "Safe Withdrawal Rate"
      }
    }
  ],
  "formulas": {
    "yearsToRetirement": "retirementAge - currentAge",
    "adjustedExpenses": "annualRetirementExpenses * ((1 + inflationRate) ** yearsToRetirement)",
    "requiredCorpus": "adjustedExpenses / safeWithdrawalRate",
    "futureValueCurrentSavings": "currentSavings * ((1 + annualReturnRate) ** yearsToRetirement)",
    "futureValueContributions": "(monthlyContribution * 12) * (((1 + annualReturnRate) ** yearsToRetirement - 1) / annualReturnRate)",
    "totalSavingsAtRetirement": "futureValueCurrentSavings + futureValueContributions",
    "shortfall": "requiredCorpus - totalSavingsAtRetirement"
  },
  "outputs": {
    "primary": "shortfall",
    "breakdown": [
      "requiredCorpus",
      "totalSavingsAtRetirement",
      "futureValueCurrentSavings",
      "futureValueContributions"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "shortfall"
  },

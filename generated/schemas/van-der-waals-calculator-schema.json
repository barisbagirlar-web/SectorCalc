{
  "toolName": "van-der-waals-calculator",
  "inputs": [
    {
      "id": "volume",
      "label": "Hacim (V)",
      "type": "number",
      "unit": "L",
      "default": 1,
      "businessContext": "Gazın kapladığı hacim (litre)"
    },
    {
      "id": "temperature",
      "label": "Sıcaklık (T)",
      "type": "number",
      "unit": "K",
      "default": 273.15,
      "businessContext": "Gazın mutlak sıcaklığı (Kelvin)"
    },
    {
      "id": "moles",
      "label": "Mol Sayısı (n)",
      "type": "number",
      "unit": "mol",
      "default": 1,
      "businessContext": "Gazın mol miktarı"
    },
    {
      "id": "a",
      "label": "Van der Waals Sabiti a",
      "type": "number",
      "unit": "L²·atm/mol²",
      "default": 1.355,
      "businessContext": "Çekim kuvveti sabiti (a)"
    },
    {
      "id": "b",
      "label": "Van der Waals Sabiti b",
      "type": "number",
      "unit": "L/mol",
      "default": 0.032,
      "businessContext": "Molekül hacim sabiti (b)"
    },
    {
      "id": "R",
      "label": "Gaz Sabiti (R)",
      "type": "number",
      "unit": "L·atm/(mol·K)",
      "default": 0.082057,
      "businessContext": "İdeal gaz sabiti"
    }
  ],
  "formulas": {
    "repulsiveTerm": "(moles * R * temperature) / (volume - moles * b)",
    "attractiveTerm": "(a * moles**2) / (volume**2)",
    "pressure": "repulsiveTerm - attractiveTerm"
  },
  "outputs": {
    "primary": "pressure",
    "breakdown": [
      "repulsiveTerm",
      "attractiveTerm"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "chemistry-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "process-chemical"
}

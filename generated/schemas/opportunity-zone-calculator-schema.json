{
  "toolName": "opportunity-zone-calculator",
  "inputs": [
    {
      "id": "initialCapitalGain",
      "label": "Initial Capital Gain",
      "type": "number",
      "unit": "$",
      "default": 100000,
      "businessContext": "The amount of capital gain being invested into the Qualified Opportunity Fund.",
      "label_i18n": {
        "en": "Initial Capital Gain",
        "tr": "Başlangıç Sermaye Kazancı",
        "de": "Initial Capital Gain",
        "fr": "Initial Capital Gain",
        "es": "Initial Capital Gain",
        "ar": "Initial Capital Gain"
      },
      "businessContext_i18n": {
        "en": "The amount of capital gain being invested into the Qualified Opportunity Fund.",
        "tr": "Nitelikli Fırsat Fonu'na yatırılan sermaye kazancı tutarı."
      }
    },
    {
      "id": "federalTaxRate",
      "label": "Federal Capital Gains Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 23.8,
      "businessContext": "Combined federal capital gains tax rate including net investment income tax if applicable.",
      "label_i18n": {
        "en": "Federal Capital Gains Tax Rate",
        "tr": "Federal Sermaye Kazancı Vergi Oranı",
        "de": "Federal Capital Gains Tax Rate",
        "fr": "Federal Capital Gains Tax Rate",
        "es": "Federal Capital Gains Tax Rate",
        "ar": "Federal Capital Gains Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Combined federal capital gains tax rate including net investment income tax if applicable.",
        "tr": "Varsa net yatırım geliri vergisi dahil birleşik federal sermaye kazancı vergi oranı."
      }
    },
    {
      "id": "stateTaxRate",
      "label": "State Capital Gains Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "State-level capital gains tax rate.",
      "label_i18n": {
        "en": "State Capital Gains Tax Rate",
        "tr": "Eyalet Sermaye Kazancı Vergi Oranı",
        "de": "State Capital Gains Tax Rate",
        "fr": "State Capital Gains Tax Rate",
        "es": "State Capital Gains Tax Rate",
        "ar": "State Capital Gains Tax Rate"
      },
      "businessContext_i18n": {
        "en": "State-level capital gains tax rate.",
        "tr": "Eyalet düzeyinde sermaye kazancı vergi oranı."
      }
    },
    {
      "id": "holdingYears",
      "label": "Holding Period",
      "type": "number",
      "unit": "years",
      "default": 10,
      "businessContext": "Number of years the investment is held in the Opportunity Fund.",
      "label_i18n": {
        "en": "Holding Period",
        "tr": "Tutma Süresi",
        "de": "Holding Period",
        "fr": "Holding Period",
        "es": "Holding Period",
        "ar": "Holding Period"
      },
      "businessContext_i18n": {
        "en": "Number of years the investment is held in the Opportunity Fund.",
        "tr": "Yatırımın Fırsat Fonu'nda tutulduğu yıl sayısı."
      }
    },
    {
      "id": "annualAppreciation",
      "label": "Expected Annual Appreciation",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual rate of return on the Opportunity Fund investment.",
      "label_i18n": {
        "en": "Expected Annual Appreciation",
        "tr": "Beklenen Yıllık Değer Artışı",
        "de": "Expected Annual Appreciation",
        "fr": "Expected Annual Appreciation",
        "es": "Expected Annual Appreciation",
        "ar": "Expected Annual Appreciation"
      },
      "businessContext_i18n": {
        "en": "Expected annual rate of return on the Opportunity Fund investment.",
        "tr": "Fırsat Fonu yatırımında beklenen yıllık getiri oranı."
      }
    }
  ],
  "formulas": {
    "combinedTaxRate": "(federalTaxRate + stateTaxRate) / 100",
    "originalTax": "initialCapitalGain * combinedTaxRate",
    "stepUpRatio": "holdingYears >= 7 ? 0.15 : (holdingYears >= 5 ? 0.10 : 0)",
    "stepUpSavings": "stepUpRatio * initialCapitalGain * combinedTaxRate"
  },
  "outputs": {
    "primary": "combinedTaxRate",
    "breakdown": [
      {
        "id": "deferralSavings",
        "label": "Tax Deferral Savings",
        "unit": "$"
      },
      {
        "id": "stepUpSavings",
        "label": "Basis Step-Up Savings",
        "unit": "$"
      },
      {
        "id": "exclusionSavings",
        "label": "Exclusion Savings",
        "unit": "$"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalSavings",
    "unit": "$"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

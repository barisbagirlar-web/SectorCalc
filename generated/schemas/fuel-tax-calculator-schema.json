{
  "toolName": "fuel-tax-calculator",
  "inputs": [
    {
      "id": "fuelQuantity",
      "label": "Fuel Quantity",
      "type": "number",
      "unit": "liters",
      "default": 100,
      "businessContext": "Amount of fuel purchased in liters",
      "label_i18n": {
        "en": "Fuel Quantity",
        "tr": "Yakıt Miktarı",
        "de": "Fuel Quantity",
        "fr": "Fuel Quantity",
        "es": "Fuel Quantity",
        "ar": "Fuel Quantity"
      },
      "businessContext_i18n": {
        "en": "Amount of fuel purchased in liters",
        "tr": "Litre cinsinden satın alınan yakıt miktarı"
      }
    },
    {
      "id": "pricePerLiter",
      "label": "Price per Liter",
      "type": "number",
      "unit": "currency",
      "default": 1.5,
      "businessContext": "Base price per liter before taxes",
      "label_i18n": {
        "en": "Price per Liter",
        "tr": "Litre başına fiyat",
        "de": "Price per Liter",
        "fr": "Price per Liter",
        "es": "Price per Liter",
        "ar": "Price per Liter"
      },
      "businessContext_i18n": {
        "en": "Base price per liter before taxes",
        "tr": "Vergiler öncesi litre başına taban fiyat"
      }
    },
    {
      "id": "vatRate",
      "label": "VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Value Added Tax percentage",
      "label_i18n": {
        "en": "VAT Rate",
        "tr": "KDV Oranı",
        "de": "VAT Rate",
        "fr": "VAT Rate",
        "es": "VAT Rate",
        "ar": "VAT Rate"
      },
      "businessContext_i18n": {
        "en": "Value Added Tax percentage",
        "tr": "Katma Değer Vergisi yüzdesi"
      }
    },
    {
      "id": "exciseTaxPerLiter",
      "label": "Excise Tax per Liter",
      "type": "number",
      "unit": "currency/liter",
      "default": 0.8,
      "businessContext": "Fixed excise tax per liter",
      "label_i18n": {
        "en": "Excise Tax per Liter",
        "tr": "Litre başına ÖTV",
        "de": "Excise Tax per Liter",
        "fr": "Excise Tax per Liter",
        "es": "Excise Tax per Liter",
        "ar": "Excise Tax per Liter"
      },
      "businessContext_i18n": {
        "en": "Fixed excise tax per liter",
        "tr": "Litre başına sabit özel tüketim vergisi"
      }
    }
  ],
  "formulas": {
    "baseCost": "fuelQuantity * pricePerLiter",
    "vatAmount": "baseCost * (vatRate / 100)",
    "exciseAmount": "fuelQuantity * exciseTaxPerLiter",
    "totalCost": "baseCost + vatAmount + exciseAmount"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "baseCost",
      "vatAmount",
      "exciseAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "liters"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "50-30-20-rule-calculator",
  "inputs": [
    {
      "id": "monthlyIncome",
      "label": "Monthly After-Tax Income",
      "type": "number",
      "unit": "currency",
      "default": 5000,
      "businessContext": "Total monthly income after deductions and taxes.",
      "label_i18n": {
        "en": "Monthly After-Tax Income",
        "tr": "Monthly After-Tax Income",
        "de": "Monthly After-Tax Income",
        "fr": "Monthly After-Tax Income",
        "es": "Monthly After-Tax Income",
        "ar": "Monthly After-Tax Income"
      }
    },
    {
      "id": "needsPercentage",
      "label": "Needs Percentage",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Percentage of income for essential needs (housing, food, utilities).",
      "label_i18n": {
        "en": "Needs Percentage",
        "tr": "Needs Percentage",
        "de": "Needs Percentage",
        "fr": "Needs Percentage",
        "es": "Needs Percentage",
        "ar": "Needs Percentage"
      }
    },
    {
      "id": "wantsPercentage",
      "label": "Wants Percentage",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage of income for non-essential wants (entertainment, dining out).",
      "label_i18n": {
        "en": "Wants Percentage",
        "tr": "Wants Percentage",
        "de": "Wants Percentage",
        "fr": "Wants Percentage",
        "es": "Wants Percentage",
        "ar": "Wants Percentage"
      }
    },
    {
      "id": "savingsPercentage",
      "label": "Savings & Debt Percentage",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage of income for savings, investments, or debt repayment.",
      "label_i18n": {
        "en": "Savings & Debt Percentage",
        "tr": "Savings & Debt Percentage",
        "de": "Savings & Debt Percentage",
        "fr": "Savings & Debt Percentage",
        "es": "Savings & Debt Percentage",
        "ar": "Savings & Debt Percentage"
      }
    }
  ],
  "formulas": {
    "needsAmount": "monthlyIncome * needsPercentage / 100",
    "wantsAmount": "monthlyIncome * wantsPercentage / 100",
    "savingsAmount": "monthlyIncome * savingsPercentage / 100"
  },
  "outputs": {
    "primary": "savingsAmount",
    "breakdown": [
      "Needs: ${needsAmount}",
      "Wants: ${wantsAmount}",
      "Savings: ${savingsAmount}"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "savingsAmount"
  },
  "category": "Finans & Yatırım",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "matematik",
  "profession": "Matematikçi",
  "categoryId": "finance",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

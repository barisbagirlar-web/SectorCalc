{
  "toolName": "capital-gains-tax-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Purchase Price",
      "type": "number",
      "unit": "USD",
      "default": 10000,
      "businessContext": "Initial purchase price of the asset"
    },
    {
      "id": "salePrice",
      "label": "Sale Price",
      "type": "number",
      "unit": "USD",
      "default": 15000,
      "businessContext": "Selling price of the asset"
    },
    {
      "id": "acquisitionCost",
      "label": "Acquisition Cost",
      "type": "number",
      "unit": "USD",
      "default": 500,
      "businessContext": "Costs associated with purchasing the asset (e.g., brokerage fees)"
    },
    {
      "id": "improvementCost",
      "label": "Improvement Cost",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Costs of improvements made to the asset"
    },
    {
      "id": "exemption",
      "label": "Exemption Amount",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Tax-exempt amount, if applicable (e.g., primary residence exemption)"
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Applicable capital gains tax rate (percentage)"
    }
  ],
  "formulas": {
    "capitalGain": "salePrice - (purchasePrice + acquisitionCost + improvementCost)",
    "taxableGain": "Math.max(0, salePrice - (purchasePrice + acquisitionCost + improvementCost) - exemption)",
    "taxOwed": "(Math.max(0, salePrice - (purchasePrice + acquisitionCost + improvementCost) - exemption) * taxRate) / 100"
  },
  "outputs": {
    "primary": "taxOwed",
    "breakdown": [
      "capitalGain",
      "taxableGain"
    ]
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost"
}

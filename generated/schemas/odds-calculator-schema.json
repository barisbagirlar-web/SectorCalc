{
  "toolName": "odds-calculator",
  "inputs": [
    {
      "id": "homeProb",
      "label": "Home Win Probability",
      "type": "number",
      "unit": "%",
      "default": 40,
      "businessContext": "Estimated probability of home team winning, as percentage.",
      "label_i18n": {
        "en": "Home Win Probability",
        "tr": "Home Win Probability",
        "de": "Home Win Probability",
        "fr": "Home Win Probability",
        "es": "Home Win Probability",
        "ar": "Home Win Probability"
      }
    },
    {
      "id": "drawProb",
      "label": "Draw Probability",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Estimated probability of a draw, as percentage.",
      "label_i18n": {
        "en": "Draw Probability",
        "tr": "Draw Probability",
        "de": "Draw Probability",
        "fr": "Draw Probability",
        "es": "Draw Probability",
        "ar": "Draw Probability"
      }
    },
    {
      "id": "awayProb",
      "label": "Away Win Probability",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Estimated probability of away team winning, as percentage.",
      "label_i18n": {
        "en": "Away Win Probability",
        "tr": "Away Win Probability",
        "de": "Away Win Probability",
        "fr": "Away Win Probability",
        "es": "Away Win Probability",
        "ar": "Away Win Probability"
      }
    },
    {
      "id": "margin",
      "label": "Margin (Overround)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Bookmaker margin as percentage over fair odds (e.g., 5% overround).",
      "label_i18n": {
        "en": "Margin (Overround)",
        "tr": "Margin (Overround)",
        "de": "Margin (Overround)",
        "fr": "Margin (Overround)",
        "es": "Margin (Overround)",
        "ar": "Margin (Overround)"
      }
    }
  ],
  "formulas": {
    "fairHomeDecimal": "homeProb > 0 ? 100 / homeProb : 0",
    "fairDrawDecimal": "drawProb > 0 ? 100 / drawProb : 0",
    "fairAwayDecimal": "awayProb > 0 ? 100 / awayProb : 0",
    "marginFactor": "1 + margin / 100",
    "homeOdds": "fairHomeDecimal / marginFactor",
    "drawOdds": "fairDrawDecimal / marginFactor",
    "awayOdds": "fairAwayDecimal / marginFactor",
    "impliedHomeProb": "homeOdds > 0 ? 100 / homeOdds : 0",
    "impliedDrawProb": "drawOdds > 0 ? 100 / drawOdds : 0",
    "impliedAwayProb": "awayOdds > 0 ? 100 / awayOdds : 0",
    "overround": "(impliedHomeProb + impliedDrawProb + impliedAwayProb) - 100"
  },
  "outputs": {
    "primary": "overround",
    "breakdown": [
      "homeOdds",
      "drawOdds",
      "awayOdds",
      "impliedHomeProb",
      "impliedDrawProb",
      "impliedAwayProb"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "overround"
  },

    },
    {
      "id": "fuelEfficiency",
      "label": "Fuel Efficiency",
      "type": "number",
      "unit": "L/100km",
      "default": 7,
      "businessContext": "Car's fuel consumption rate",
      "label_i18n": {
        "en": "Fuel Efficiency",
        "tr": "Yakıt Verimliliği",
        "de": "Kraftstoffeffizienz",
        "fr": "Rendement énergétique",
        "es": "Eficiencia de combustible",

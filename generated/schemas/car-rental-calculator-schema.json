      },
      "businessContext_i18n": {
        "en": "Car's fuel consumption rate",
        "tr": "Aracın yakıt tüketim oranı",
        "de": "Kraftstoffverbrauch des Autos",
        "fr": "Taux de consommation de carburant du véhicule",
        "es": "Tasa de consumo de combustible del vehículo",
        "ar": "معدل استهلاك الوقود للسيارة"
      }
    },
    {
      "id": "insurancePerDay",
      "label": "Insurance Cost per Day",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Optional insurance charge per day",
      "label_i18n": {
        "en": "Insurance Cost per Day",
        "tr": "Günlük Sigorta Maliyeti",
        "de": "Versicherungskosten pro Tag",
        "fr": "Coût d'assurance par jour",
        "es": "Costo de seguro por día",
        "ar": "تكلفة التأمين اليومية"
      },
      "businessContext_i18n": {
        "en": "Optional insurance charge per day",
        "tr": "Günlük isteğe bağlı sigorta ücreti",
        "de": "Optionale Versicherungsgebühr pro Tag",
        "fr": "Frais d'assurance optionnelle par jour",
        "es": "Cargo opcional de seguro por día",
        "ar": "رسوم التأمين الاختياري يوميًا"
      }
    }
  ],
  "formulas": {
    "baseRental": "rentalDurationDays * dailyRate",
    "fuelCost": "rentalDurationDays * (mileagePerDay * fuelEfficiency / 100) * fuelPricePerLiter",
    "insuranceCost": "rentalDurationDays * insurancePerDay",
    "totalCost": "rentalDurationDays * dailyRate + rentalDurationDays * (mileagePerDay * fuelEfficiency / 100) * fuelPricePerLiter + rentalDurationDays * insurancePerDay"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "baseRental",
      "fuelCost",
      "insuranceCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "days"
  },

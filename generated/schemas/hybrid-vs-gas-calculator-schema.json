      "label_i18n": {
        "en": "ANNUAL MILES DRIVEN",
        "tr": "ANNUAL MILES DRIVEN",
        "de": "ANNUAL MILES DRIVEN",
        "fr": "ANNUAL MILES DRIVEN",
        "es": "ANNUAL MILES DRIVEN",
        "ar": "ANNUAL MILES DRIVEN"
      }
    },
    {
      "id": "fuelPricePerGallon",
      "label": "FUEL PRICE PER GALLON",
      "type": "number",
      "unit": "$/gal",
      "default": 3.5,
      "businessContext": "Current fuel price per gallon",
      "label_i18n": {
        "en": "FUEL PRICE PER GALLON",
        "tr": "FUEL PRICE PER GALLON",
        "de": "FUEL PRICE PER GALLON",
        "fr": "FUEL PRICE PER GALLON",
        "es": "FUEL PRICE PER GALLON",
        "ar": "FUEL PRICE PER GALLON"
      }
    }
  ],
  "formulas": {
    "annualFuelCostGas": "(annualMiles / gasMpg) * fuelPricePerGallon",
    "annualFuelCostHybrid": "(annualMiles / hybridMpg) * fuelPricePerGallon",
    "annualSavings": "((annualMiles / gasMpg) - (annualMiles / hybridMpg)) * fuelPricePerGallon",
    "paybackYears": "(hybridVehiclePrice - gasVehiclePrice) / (((annualMiles / gasMpg) - (annualMiles / hybridMpg)) * fuelPricePerGallon)"
  },
  "outputs": {
    "primary": "paybackYears",
    "breakdown": [
      "annualFuelCostGas",
      "annualFuelCostHybrid",
      "annualSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

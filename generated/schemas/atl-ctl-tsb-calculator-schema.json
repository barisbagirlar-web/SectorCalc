    {
      "id": "nominal",
      "label": "Nominal Dimension",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Nominal dimension of the assembly for reference",
      "label_i18n": {
        "en": "Nominal Dimension",
        "tr": "Nominal Dimension",
        "de": "Nominal Dimension",
        "fr": "Nominal Dimension",
        "es": "Nominal Dimension",
        "ar": "Nominal Dimension"
      }
    }
  ],
  "formulas": {
    "atl": "t1 + t2 + t3 + t4",
    "ctl": "Math.sqrt(Math.pow(t1,2) + Math.pow(t2,2) + Math.pow(t3,2) + Math.pow(t4,2))",
    "tsb": "(t1 + t2 + t3 + t4) / Math.sqrt(Math.pow(t1,2) + Math.pow(t2,2) + Math.pow(t3,2) + Math.pow(t4,2))",
    "__atl_toFixed_3___mm_": "${atl.toFixed(3)} mm`",
    "__tsb_toFixed_2___": "${tsb.toFixed(2)}`",
    "result": "`Statistical Tolerance (CTL): ${ctl.toFixed(3)} mm`"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "`Worst-Case Tolerance (ATL): ${atl.toFixed(3)} mm`",
      "`Safety Factor (TSB): ${tsb.toFixed(2)}`"
    ]
  },

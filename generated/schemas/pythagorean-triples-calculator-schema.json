      }
    },
    {
      "id": "n",
      "label": "n (n < m)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Pisagor üçlüsü üretiminde küçük parametre",
      "label_i18n": {
        "en": "n (n < m)",
        "tr": "n (n < m)",
        "de": "n (n < m)",
        "fr": "n (n < m)",
        "es": "n (n < m)",
        "ar": "n (n < m)"
      }
    },
    {
      "id": "scaleFactor",
      "label": "Ölçek Çarpanı",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Üçgen kenarlarını ölçeklemek için pozitif tamsayı",
      "label_i18n": {
        "en": "Ölçek Çarpanı",
        "tr": "Ölçek Çarpanı",
        "de": "Ölçek Çarpanı",
        "fr": "Ölçek Çarpanı",
        "es": "Ölçek Çarpanı",
        "ar": "Ölçek Çarpanı"
      }
    },
    {
      "id": "maxHypotenuse",
      "label": "Maksimum Hipotenüs",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Opsiyonel: hipotenüsün maksimum değeri (0 ise sınırsız)",
      "label_i18n": {
        "en": "Maksimum Hipotenüs",
        "tr": "Maksimum Hipotenüs",
        "de": "Maksimum Hipotenüs",
        "fr": "Maksimum Hipotenüs",
        "es": "Maksimum Hipotenüs",
        "ar": "Maksimum Hipotenüs"
      }
    }
  ],
  "formulas": {
    "actualScale": "maxHypotenuse > 0 ? Math.min(scaleFactor, Math.floor(maxHypotenuse / (m*m + n*n))) : scaleFactor",
    "a": "actualScale * (m*m - n*n)",
    "b": "actualScale * (2*m*n)",
    "c": "actualScale * (m*m + n*n)",
    "perimeter": "a + b + c",
    "area": "(a * b) / 2"
  },
  "outputs": {
    "primary": "c",
    "breakdown": [
      "a",
      "b",
      "c",
      "perimeter",
      "area",
      "actualScale"
    ]
  },

      "label_i18n": {
        "en": "Exposure (Units)",
        "tr": "Exposure (Units)",
        "de": "Exposure (Units)",
        "fr": "Exposure (Units)",
        "es": "Exposure (Units)",
        "ar": "Exposure (Units)"
      }
    },
    {
      "id": "contractSize",
      "label": "Contract Size",
      "type": "number",
      "unit": "units/contract",
      "default": 5000,
      "businessContext": "Number of units of the underlying asset per futures contract.",

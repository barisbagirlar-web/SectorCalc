        "de": "Contract Size",
        "fr": "Contract Size",
        "es": "Contract Size",
        "ar": "Contract Size"
      }
    }
  ],
  "formulas": {
    "optimalHedgeRatio": "correlation * (spotVol / futuresVol)",
    "totalHedgeUnits": "optimalHedgeRatio * exposureUnits",
    "numberOfContracts": "totalHedgeUnits / contractSize"
  },
  "outputs": {
    "primary": "numberOfContracts",

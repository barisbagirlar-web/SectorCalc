      "label_i18n": {
        "en": "Maximum Superelevation",
        "tr": "Maksimum Dever",
        "de": "Maximale Überhöhung",
        "fr": "Dévers maximal",
        "es": "Maximum Superelevation",
        "ar": "Maximum Superelevation"
      },
      "businessContext_i18n": {
        "en": "Maximum allowable superelevation rate per design standards.",
        "tr": "Tasarım standartlarına göre izin verilen maksimum dever oranı.",
        "de": "Maximal zulässiger Überhöhungssatz gemäß Bemessungsnormen.",
        "fr": "Taux de dévers maximal autorisé selon les normes de conception."
      }
    },
    {
      "id": "gravity",
      "label": "Acceleration due to Gravity",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Gravitational acceleration constant.",
      "label_i18n": {
        "en": "Acceleration due to Gravity",
        "tr": "Yerçekimi İvmesi",
        "de": "Erdbeschleunigung",
        "fr": "Accélération due à la gravité",
        "es": "Acceleration due to Gravity",
        "ar": "Acceleration due to Gravity"
      },
      "businessContext_i18n": {
        "en": "Gravitational acceleration constant.",
        "tr": "Yerçekimi ivmesi sabiti.",
        "de": "Konstante der Erdbeschleunigung.",
        "fr": "Constante d'accélération gravitationnelle."
      }
    }
  ],
  "formulas": {
    "V_ms": "designSpeed / 3.6",
    "requiredE_percent": "((V_ms**2 / (gravity * curveRadius)) - frictionCoeff) * 100",
    "calculatedSuperelevation": "requiredE_percent"
  },
  "outputs": {
    "primary": "calculatedSuperelevation",
    "breakdown": [
      "calculatedSuperelevation",
      "isSuperelevationCapped",
      "requiredFrictionCoefficient"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "requiredFrictionCoefficient",

{
  "toolName": "superelevation-calculator",
  "inputs": [
    {
      "id": "designSpeed",
      "label": "Design Speed",
      "type": "number",
      "unit": "km/h",
      "default": 80,
      "businessContext": "The design speed of the road section.",
      "label_i18n": {
        "en": "Design Speed",
        "tr": "Design Speed",
        "de": "Design Speed",
        "fr": "Design Speed",
        "es": "Design Speed",
        "ar": "Design Speed"
      }
    },
    {
      "id": "curveRadius",
      "label": "Curve Radius",
      "type": "number",
      "unit": "m",
      "default": 200,
      "businessContext": "The radius of the horizontal curve.",
      "label_i18n": {
        "en": "Curve Radius",
        "tr": "Curve Radius",
        "de": "Curve Radius",
        "fr": "Curve Radius",
        "es": "Curve Radius",
        "ar": "Curve Radius"
      }
    },
    {
      "id": "frictionCoeff",
      "label": "Side Friction Factor",
      "type": "number",
      "unit": "unit",
      "default": 0.15,
      "businessContext": "The coefficient of side friction assumed for design.",
      "label_i18n": {
        "en": "Side Friction Factor",
        "tr": "Side Friction Factor",
        "de": "Side Friction Factor",
        "fr": "Side Friction Factor",
        "es": "Side Friction Factor",
        "ar": "Side Friction Factor"
      }
    },
    {
      "id": "maxSuperelevation",
      "label": "Maximum Superelevation",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Maximum allowable superelevation rate per design standards.",
      "label_i18n": {
        "en": "Maximum Superelevation",
        "tr": "Maximum Superelevation",
        "de": "Maximum Superelevation",
        "fr": "Maximum Superelevation",
        "es": "Maximum Superelevation",
        "ar": "Maximum Superelevation"
      }
    },
    {
      "id": "gravity",
      "label": "Acceleration due to Gravity",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Gravitational acceleration constant.",
      "label_i18n": {
        "en": "Acceleration due to Gravity",
        "tr": "Acceleration due to Gravity",
        "de": "Acceleration due to Gravity",
        "fr": "Acceleration due to Gravity",
        "es": "Acceleration due to Gravity",
        "ar": "Acceleration due to Gravity"
      }
    }
  ],
  "formulas": {
    "V_ms": "designSpeed / 3.6",
    "requiredE_percent": "((V_ms**2 / (gravity * curveRadius)) - frictionCoeff) * 100",
    "requiredSuperelevation": "Math.max(0, Math.min(requiredE_percent, maxSuperelevation))",
    "calculatedSuperelevation": "requiredE_percent",
    "isSuperelevationCapped": "requiredE_percent > maxSuperelevation",
    "requiredFrictionCoefficient": "(V_ms**2 / (gravity * curveRadius)) - (requiredSuperelevation / 100)"
  },
  "outputs": {
    "primary": "requiredSuperelevation",
    "breakdown": [
      "calculatedSuperelevation",
      "isSuperelevationCapped",
      "requiredFrictionCoefficient"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "quality-six-sigma"
}

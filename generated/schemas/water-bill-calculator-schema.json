{
  "toolName": "water-bill-calculator",
  "inputs": [
    {
      "id": "previousMeterReading",
      "label": "Previous Meter Reading (m³)",
      "type": "number",
      "unit": "m³",
      "default": 0,
      "businessContext": "The meter reading at the start of the billing period, in cubic meters.",
      "label_i18n": {
        "en": "Previous Meter Reading (m³)",
        "tr": "Previous Meter Reading (m³)",
        "de": "Previous Meter Reading (m³)",
        "fr": "Previous Meter Reading (m³)",
        "es": "Previous Meter Reading (m³)",
        "ar": "Previous Meter Reading (m³)"
      }
    },
    {
      "id": "currentMeterReading",
      "label": "Current Meter Reading (m³)",
      "type": "number",
      "unit": "m³",
      "default": 0,
      "businessContext": "The meter reading at the end of the billing period, in cubic meters.",
      "label_i18n": {
        "en": "Current Meter Reading (m³)",
        "tr": "Current Meter Reading (m³)",
        "de": "Current Meter Reading (m³)",
        "fr": "Current Meter Reading (m³)",
        "es": "Current Meter Reading (m³)",
        "ar": "Current Meter Reading (m³)"
      }
    },
    {
      "id": "fixedCharge",
      "label": "Fixed Charge",
      "type": "number",
      "unit": "currency",
      "default": 5,
      "businessContext": "Monthly fixed service charge regardless of consumption.",
      "label_i18n": {
        "en": "Fixed Charge",
        "tr": "Fixed Charge",
        "de": "Fixed Charge",
        "fr": "Fixed Charge",
        "es": "Fixed Charge",
        "ar": "Fixed Charge"
      }
    },
    {
      "id": "ratePerCubicMeter",
      "label": "Rate per Cubic Meter",
      "type": "number",
      "unit": "currency/m³",
      "default": 1.5,
      "businessContext": "Variable charge per cubic meter of water consumed.",
      "label_i18n": {
        "en": "Rate per Cubic Meter",
        "tr": "Rate per Cubic Meter",
        "de": "Rate per Cubic Meter",
        "fr": "Rate per Cubic Meter",
        "es": "Rate per Cubic Meter",
        "ar": "Rate per Cubic Meter"
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Tax percentage applied to the subtotal (usage + fixed charge).",
      "label_i18n": {
        "en": "Tax Rate (%)",
        "tr": "Tax Rate (%)",
        "de": "Tax Rate (%)",
        "fr": "Tax Rate (%)",
        "es": "Tax Rate (%)",
        "ar": "Tax Rate (%)"
      }
    }
  ],
  "formulas": {
    "consumptionM3": "currentMeterReading - previousMeterReading",
    "waterUsageCost": "consumptionM3 * ratePerCubicMeter",
    "fixedCharge": "fixedCharge",
    "taxAmount": "(waterUsageCost + fixedCharge) * taxRate / 100",
    "totalBill": "waterUsageCost + fixedCharge + taxAmount"
  },
  "outputs": {
    "primary": "totalBill",
    "breakdown": [
      "consumptionM3",
      "waterUsageCost",
      "fixedCharge",
      "taxAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalBill"
  },

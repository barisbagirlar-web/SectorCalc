{
  "toolName": "swimming-pool-volume-calculator",
  "inputs": [
    {
      "id": "poolLength",
      "label": "Pool Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Length of the swimming pool",
      "label_i18n": {
        "en": "Pool Length",
        "tr": "Pool Length",
        "de": "Pool Length",
        "fr": "Pool Length",
        "es": "Pool Length",
        "ar": "Pool Length"
      }
    },
    {
      "id": "poolWidth",
      "label": "Pool Width",
      "type": "number",
      "unit": "m",
      "default": 5,
      "businessContext": "Width of the swimming pool",
      "label_i18n": {
        "en": "Pool Width",
        "tr": "Pool Width",
        "de": "Pool Width",
        "fr": "Pool Width",
        "es": "Pool Width",
        "ar": "Pool Width"
      }
    },
    {
      "id": "shallowDepth",
      "label": "Shallow End Depth",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Depth at the shallow end",
      "label_i18n": {
        "en": "Shallow End Depth",
        "tr": "Shallow End Depth",
        "de": "Shallow End Depth",
        "fr": "Shallow End Depth",
        "es": "Shallow End Depth",
        "ar": "Shallow End Depth"
      }
    },
    {
      "id": "deepDepth",
      "label": "Deep End Depth",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Depth at the deep end",
      "label_i18n": {
        "en": "Deep End Depth",
        "tr": "Deep End Depth",
        "de": "Deep End Depth",
        "fr": "Deep End Depth",
        "es": "Deep End Depth",
        "ar": "Deep End Depth"
      }
    }
  ],
  "formulas": {
    "averageDepth": "(inputs.shallowDepth + inputs.deepDepth) / 2",
    "volume": "inputs.poolLength * inputs.poolWidth * averageDepth",
    "waterMass": "volume * 1000",
    "surfaceArea": "inputs.poolLength * inputs.poolWidth",
    "volumeLiters": "volume * 1000"
  },
  "outputs": {
    "primary": "volume",
    "breakdown": [
      "waterMass",
      "surfaceArea",
      "volumeLiters"
    ]
  },

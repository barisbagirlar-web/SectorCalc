  "formulas": {
    "breakOut": "breakHours",
    "meetingOut": "meetingHours",
    "interruptionOut": "interruptionCount * avgInterruptionDuration / 60",
    "nonFocusOut": "breakOut + meetingOut + interruptionOut",
    "focusOut": "totalWorkHours - nonFocusOut"
  },

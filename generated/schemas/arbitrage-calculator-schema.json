      }
    }
  ],
  "formulas": {
    "grossProfit": "(sellPrice - buyPrice) * quantity",
    "totalCosts": "buyFee + sellFee",
    "netProfit": "(sellPrice - buyPrice) * quantity - buyFee - sellFee",
    "breakEvenVolume": "(buyFee + sellFee) / (sellPrice - buyPrice)"
  },
  "outputs": {
    "primary": "netProfit",
    "breakdown": [
      "grossProfit",
      "totalCosts",
      "breakEvenVolume"
    ],

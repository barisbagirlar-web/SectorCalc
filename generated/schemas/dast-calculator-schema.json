        "ar": "Çekme Hızı"
      }
    }
  ],
  "formulas": {
    "rawStrength": "force / area",
    "tempFactor": "1 + 0.002 * (temperature - 23)",
    "humidityFactor": "1 + 0.001 * (humidity - 50)",
    "speedFactor": "Math.log(speed + 1) / Math.log(11)",
    "correctedStrength": "rawStrength * tempFactor * humidityFactor * speedFactor"
  },
  "outputs": {
    "primary": "correctedStrength",
    "breakdown": [
      "rawStrength",
      "tempFactor",
      "humidityFactor",
      "speedFactor"
    ]
  },

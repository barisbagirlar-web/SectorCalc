{
  "toolName": "flat-rate-vat-calculator",
  "inputs": [
    {
      "id": "grossTurnover",
      "label": "Gross Turnover (incl. VAT)",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "Total revenue including VAT charged to customers.",
      "label_i18n": {
        "en": "Gross Turnover (incl. VAT)",
        "tr": "Gross Turnover (incl. VAT)",
        "de": "Gross Turnover (incl. VAT)",
        "fr": "Gross Turnover (incl. VAT)",
        "es": "Gross Turnover (incl. VAT)",
        "ar": "Gross Turnover (incl. VAT)"
      }
    },
    {
      "id": "flatRatePercentage",
      "label": "Flat Rate Percentage",
      "type": "number",
      "unit": "%",
      "default": 13,
      "businessContext": "The flat rate percentage applied to your business category.",
      "label_i18n": {
        "en": "Flat Rate Percentage",
        "tr": "Flat Rate Percentage",
        "de": "Flat Rate Percentage",
        "fr": "Flat Rate Percentage",
        "es": "Flat Rate Percentage",
        "ar": "Flat Rate Percentage"
      }
    },
    {
      "id": "standardVatRate",
      "label": "Standard VAT Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "The standard VAT rate you charge on sales.",
      "label_i18n": {
        "en": "Standard VAT Rate",
        "tr": "Standard VAT Rate",
        "de": "Standard VAT Rate",
        "fr": "Standard VAT Rate",
        "es": "Standard VAT Rate",
        "ar": "Standard VAT Rate"
      }
    }
  ],
  "formulas": {
    "vatPayable": "grossTurnover * flatRatePercentage / 100",
    "vatCharged": "grossTurnover * standardVatRate / (100 + standardVatRate)",
    "surplus": "(grossTurnover * standardVatRate / (100 + standardVatRate)) - (grossTurnover * flatRatePercentage / 100)"
  },
  "outputs": {
    "primary": "vatPayable",
    "breakdown": [
      {
        "label": "VAT Charged to Customers",
        "formula": "vatCharged"
      },
      {
        "label": "Scheme Surplus",
        "formula": "surplus"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "surplus"
  },
  "category": "İK & Personel",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,

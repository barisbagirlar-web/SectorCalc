      }
    },
    {
      "id": "ambientTemperature",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature during measurement in Celsius",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ortam Sıcaklığı",
        "de": "Umgebungstemperatur",
        "fr": "Température ambiante",
        "es": "Temperatura ambiente",
        "ar": "Ambient Temperature"
      },
      "businessContext_i18n": {
        "en": "Temperature during measurement in Celsius",
        "tr": "Ölçüm sırasında Santigrat cinsinden sıcaklık",

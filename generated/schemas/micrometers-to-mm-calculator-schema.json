      }
    },
    {
      "id": "calibrationFactor",
      "label": "Calibration Factor",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Instrument calibration correction as percentage",
      "label_i18n": {
        "en": "Calibration Factor",
        "tr": "Calibration Factor",
        "de": "Calibration Factor",
        "fr": "Calibration Factor",
        "es": "Calibration Factor",
        "ar": "Calibration Factor"
      }
    },
    {
      "id": "temperatureCoeff",
      "label": "Temperature Coefficient",
      "type": "number",
      "unit": "µm/°C",
      "default": 0,
      "businessContext": "Material linear thermal expansion coefficient",
      "label_i18n": {
        "en": "Temperature Coefficient",
        "tr": "Temperature Coefficient",
        "de": "Temperature Coefficient",
        "fr": "Temperature Coefficient",
        "es": "Temperature Coefficient",
        "ar": "Temperature Coefficient"
      }
    },
    {
      "id": "ambientTemperature",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature during measurement in Celsius",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ambient Temperature",
        "de": "Ambient Temperature",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      }
    }
  ],
  "formulas": {
    "correctedMicrometers": "micrometerValue + (calibrationFactor/100 * micrometerValue) + temperatureCoeff * (ambientTemperature - 20)",
    "mm": "correctedMicrometers / 1000"
  },
  "outputs": {
    "primary": "mm",
    "breakdown": [
      "correctedMicrometers",
      "mm"
    ],

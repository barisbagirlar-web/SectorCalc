        "fr": "Température lors de la mesure en degrés Celsius",
        "es": "Temperatura durante la medición en grados Celsius"
      }
    }
  ],
  "formulas": {
    "correctedMicrometers": "micrometerValue + (calibrationFactor/100 * micrometerValue) + temperatureCoeff * (ambientTemperature - 20)",
    "mm": "correctedMicrometers / 1000"
  },
  "outputs": {
    "primary": "mm",

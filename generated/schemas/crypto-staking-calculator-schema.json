{
  "toolName": "crypto-staking-calculator",
  "inputs": [
    {
      "id": "principal",
      "label": "Staked Amount",
      "type": "number",
      "unit": "crypto",
      "default": 1000,
      "businessContext": "The initial amount of cryptocurrency staked.",
      "label_i18n": {
        "en": "Staked Amount",
        "tr": "Staked Amount",
        "de": "Staked Amount",
        "fr": "Staked Amount",
        "es": "Staked Amount",
        "ar": "Staked Amount"
      }
    },
    {
      "id": "apy",
      "label": "Annual Percentage Yield (APY)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "The annual yield offered by the staking protocol, expressed as a percentage.",
      "label_i18n": {
        "en": "Annual Percentage Yield (APY)",
        "tr": "Annual Percentage Yield (APY)",
        "de": "Annual Percentage Yield (APY)",
        "fr": "Annual Percentage Yield (APY)",
        "es": "Annual Percentage Yield (APY)",
        "ar": "Annual Percentage Yield (APY)"
      }
    },
    {
      "id": "duration",
      "label": "Staking Duration",
      "type": "number",
      "unit": "days",
      "default": 365,
      "businessContext": "The period over which the tokens are staked, in days.",
      "label_i18n": {
        "en": "Staking Duration",
        "tr": "Staking Duration",
        "de": "Staking Duration",
        "fr": "Staking Duration",
        "es": "Staking Duration",
        "ar": "Staking Duration"
      }
    },
    {
      "id": "compoundFrequency",
      "label": "Compounds per Year",
      "type": "number",
      "unit": "times/year",
      "default": 365,
      "businessContext": "The number of times interest is compounded annually (e.g., 365 for daily, 12 for monthly, 1 for yearly).",
      "label_i18n": {
        "en": "Compounds per Year",
        "tr": "Compounds per Year",
        "de": "Compounds per Year",
        "fr": "Compounds per Year",
        "es": "Compounds per Year",
        "ar": "Compounds per Year"
      }
    }
  ],
  "formulas": {
    "totalValue": "principal * (1 + (apy / 100) / compoundFrequency) ** (compoundFrequency * (duration / 365))",
    "earnedRewards": "totalValue - principal",
    "initialInvestment": "principal"
  },
  "outputs": {
    "primary": "totalValue",
    "breakdown": [
      "initialInvestment",
      "earnedRewards"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "initialInvestment",
    "unit": "crypto"
  },

{
  "toolName": "boxing-punch-speed-calculator",
  "inputs": [
    {
      "id": "arm_length",
      "label": "Arm Length",
      "type": "number",
      "unit": "m",
      "default": 0.7,
      "businessContext": "Distance from shoulder to fist when arm is fully extended",
      "label_i18n": {
        "en": "Arm Length",
        "tr": "Arm Length",
        "de": "Arm Length",
        "fr": "Arm Length",
        "es": "Arm Length",
        "ar": "Arm Length"
      }
    },
    {
      "id": "arm_angle",
      "label": "Arm Swing Angle",
      "type": "number",
      "unit": "deg",
      "default": 90,
      "businessContext": "Angular displacement of the arm during the punch",
      "label_i18n": {
        "en": "Arm Swing Angle",
        "tr": "Arm Swing Angle",
        "de": "Arm Swing Angle",
        "fr": "Arm Swing Angle",
        "es": "Arm Swing Angle",
        "ar": "Arm Swing Angle"
      }
    },
    {
      "id": "hip_angle",
      "label": "Hip Rotation Angle",
      "type": "number",
      "unit": "deg",
      "default": 45,
      "businessContext": "Angular rotation of the hips contributing to punch reach",
      "label_i18n": {
        "en": "Hip Rotation Angle",
        "tr": "Hip Rotation Angle",
        "de": "Hip Rotation Angle",
        "fr": "Hip Rotation Angle",
        "es": "Hip Rotation Angle",
        "ar": "Hip Rotation Angle"
      }
    },
    {
      "id": "step_length",
      "label": "Forward Step Length",
      "type": "number",
      "unit": "m",
      "default": 0.2,
      "businessContext": "Linear distance moved forward by the body during the punch",
      "label_i18n": {
        "en": "Forward Step Length",
        "tr": "Forward Step Length",
        "de": "Forward Step Length",
        "fr": "Forward Step Length",
        "es": "Forward Step Length",
        "ar": "Forward Step Length"
      }
    },
    {
      "id": "punch_time",
      "label": "Punch Duration",
      "type": "number",
      "unit": "s",
      "default": 0.15,
      "businessContext": "Time from initiation to full extension of the punch",
      "label_i18n": {
        "en": "Punch Duration",
        "tr": "Punch Duration",
        "de": "Punch Duration",
        "fr": "Punch Duration",
        "es": "Punch Duration",
        "ar": "Punch Duration"
      }
    }
  ],
  "formulas": {
    "Punch Speed (m/s)": "(arm_length * ((arm_angle + hip_angle) * Math.PI / 180) + step_length) / punch_time",
    "Punch Speed (mph)": "((arm_length * ((arm_angle + hip_angle) * Math.PI / 180) + step_length) / punch_time) * 2.23694",
    "Angular Distance (m)": "arm_length * ((arm_angle + hip_angle) * Math.PI / 180)",
    "Total Distance (m)": "arm_length * ((arm_angle + hip_angle) * Math.PI / 180) + step_length"
  },
  "outputs": {
    "primary": "Punch Speed (m/s)",
    "breakdown": [
      "Punch Speed (mph)",
      "Angular Distance (m)",
      "Total Distance (m)"
    ],

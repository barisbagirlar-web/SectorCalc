{
  "toolName": "toplanti-saati-maliyeti-hesaplama",
  "inputs": [
    {
      "id": "participantCount",
      "label": "Katılımcı Sayısı",
      "type": "number",
      "unit": "kişi",
      "default": 5,
      "min": 1,
      "max": 100,
      "options": null,
      "businessContext": "Toplantıya katılan kişi sayısı. Endüstri mühendisliğinde toplantı verimliliği analizlerinde temel girdi."
    },
    {
      "id": "meetingDuration",
      "label": "Toplantı Süresi",
      "type": "number",
      "unit": "dakika",
      "default": 60,
      "min": 1,
      "max": 480,
      "options": null,
      "businessContext": "Toplantının planlanan süresi. Lean yönetimde zaman israfını ölçmek için kullanılır."
    },
    {
      "id": "averageHourlyRate",
      "label": "Ortalama Saatlik Ücret",
      "type": "number",
      "unit": "TL/saat",
      "default": 100,
      "min": 0,
      "max": 10000,
      "options": null,
      "businessContext": "Katılımcıların ortalama saatlik maliyeti. İnsan kaynakları maliyet verilerine dayanır."
    },
    {
      "id": "preparationTime",
      "label": "Hazırlık Süresi",
      "type": "number",
      "unit": "dakika",
      "default": 15,
      "min": 0,
      "max": 120,
      "options": null,
      "businessContext": "Toplantı öncesi hazırlık için harcanan süre. Toplam maliyete dahil edilir."
    },
    {
      "id": "followUpTime",
      "label": "Takip Süresi",
      "type": "number",
      "unit": "dakika",
      "default": 10,
      "min": 0,
      "max": 120,
      "options": null,
      "businessContext": "Toplantı sonrası aksiyon takibi için harcanan süre. Toplam maliyete dahil edilir."
    },
    {
      "id": "meetingFrequency",
      "label": "Toplantı Sıklığı",
      "type": "select",
      "unit": "",
      "default": "weekly",
      "min": null,
      "max": null,
      "options": [
        "daily",
        "weekly",
        "biweekly",
        "monthly",
        "quarterly"
      ],
      "businessContext": "Toplantının periyodu. Yıllık maliyet hesaplaması için kullanılır."
    },
    {
      "id": "dataConfidence",
      "label": "Veri Güveni",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Girdi verilerinin güvenilirlik yüzdesi. Düzeltilmiş maliyet hesaplamasında kullanılır."
    }
  ],
  "validation": {
    "rules": [
      "participantCount >= 1",
      "meetingDuration >= 1",
      "averageHourlyRate >= 0",
      "preparationTime >= 0",
      "followUpTime >= 0",
      "dataConfidence >= 0 && dataConfidence <= 100"
    ],
    "thresholds": {
      "totalCostPerMeeting": {
        "warning": "totalCostPerMeeting > 5000",
        "critical": "totalCostPerMeeting > 10000"
      },
      "annualCost": {
        "warning": "annualCost > 100000",
        "critical": "annualCost > 500000"
      }
    }
  },
  "formulas": {
    "totalTimePerMeeting": "meetingDuration + preparationTime + followUpTime",
    "totalCostPerMeeting": "(totalTimePerMeeting / 60) * averageHourlyRate * participantCount",
    "meetingsPerYear": "meetingFrequency == 'daily' ? 260 : (meetingFrequency == 'weekly' ? 52 : (meetingFrequency == 'biweekly' ? 26 : (meetingFrequency == 'monthly' ? 12 : 4)))",
    "annualCost": "totalCostPerMeeting * meetingsPerYear",
    "dataConfidenceAdjusted": "annualCost * (dataConfidence / 100)"
  },
  "outputs": {
    "primary": "annualCost",
    "breakdown": {
      "totalCostPerMeeting": "totalCostPerMeeting",
      "totalTimePerMeeting": "totalTimePerMeeting",
      "meetingsPerYear": "meetingsPerYear"
    },
    "hiddenLossDrivers": [
      "totalCostPerMeeting > 5000 ? 'Toplantı maliyeti yüksek, verimlilik artırılmalı' : ''",
      "annualCost > 100000 ? 'Yıllık maliyet çok yüksek, toplantı sıklığı azaltılmalı' : ''"
    ],
    "suggestedActions": [
      "Toplantı süresini kısaltmak için gündem belirleyin",
      "Katılımcı sayısını azaltmak için sadece gerekli kişileri davet edin",
      "Toplantı sıklığını gözden geçirin",
      "Hazırlık ve takip sürelerini optimize edin"
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF raporu",
    "CSV export",
    "Trend analizi",
    "Karşılaştırma (benchmark)",
    "Detaylı maliyet dökümü"
  ],
  "premiumRequired": true
}

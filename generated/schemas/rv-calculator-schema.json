{
  "toolName": "rv-calculator",
  "inputs": [
    {
      "id": "failureRate",
      "label": "Failure Rate",
      "type": "number",
      "unit": "failures/year",
      "default": 0.5,
      "businessContext": "Number of expected failures per year for the equipment/system.",
      "label_i18n": {
        "en": "Failure Rate",
        "tr": "Failure Rate",
        "de": "Failure Rate",
        "fr": "Failure Rate",
        "es": "Failure Rate",
        "ar": "Failure Rate"
      }
    },
    {
      "id": "downtimeHours",
      "label": "Downtime per Failure",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Average downtime in hours per failure event.",
      "label_i18n": {
        "en": "Downtime per Failure",
        "tr": "Downtime per Failure",
        "de": "Downtime per Failure",
        "fr": "Downtime per Failure",
        "es": "Downtime per Failure",
        "ar": "Downtime per Failure"
      }
    },
    {
      "id": "costPerHour",
      "label": "Cost per Downtime Hour",
      "type": "number",
      "unit": "USD/hour",
      "default": 1000,
      "businessContext": "Cost incurred per hour of downtime, including lost production, labor, etc.",
      "label_i18n": {
        "en": "Cost per Downtime Hour",
        "tr": "Cost per Downtime Hour",
        "de": "Cost per Downtime Hour",
        "fr": "Cost per Downtime Hour",
        "es": "Cost per Downtime Hour",
        "ar": "Cost per Downtime Hour"
      }
    },
    {
      "id": "detectionProbability",
      "label": "Detection Probability",
      "type": "number",
      "unit": "ratio",
      "default": 0.7,
      "businessContext": "Probability of detecting a failure before it causes downtime (0 to 1).",
      "label_i18n": {
        "en": "Detection Probability",
        "tr": "Detection Probability",
        "de": "Detection Probability",
        "fr": "Detection Probability",
        "es": "Detection Probability",
        "ar": "Detection Probability"
      }
    }
  ],
  "formulas": {
    "grossExpectedLoss": "failureRate * downtimeHours * costPerHour",
    "detectionSavings": "grossExpectedLoss * detectionProbability",
    "annualExpectedLoss": "grossExpectedLoss - detectionSavings"
  },
  "outputs": {
    "primary": "annualExpectedLoss",
    "breakdown": [
      "grossExpectedLoss",
      "detectionSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualExpectedLoss"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Makine & Üretim",
  "premiumRequired": false,
  "catalogCategory": "hobbies-diy",
  "sectorSlug": "landscaping-lawn-care",
  "categorySlug": "maintenance-reliability",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

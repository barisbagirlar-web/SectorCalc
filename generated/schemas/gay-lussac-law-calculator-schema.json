  "formulas": {
    "calculated_value": "p1 === 0 ? (p2 * t1 / t2) : (t1 === 0 ? (p1 * t2 / p2) : (p2 === 0 ? (p1 * t2 / t1) : (p2 * t1 / p1)))",

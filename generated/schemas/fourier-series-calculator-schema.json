{
  "toolName": "fourier-series-calculator",
  "inputs": [
    {
      "id": "offset",
      "label": "DC Offset (a₀)",
      "type": "number",
      "unit": "mm/s",
      "default": 0,
      "businessContext": "Sinyalin ortalama seviyesi (titreşim analizi)"
    },
    {
      "id": "amplitude",
      "label": "Genlik (A)",
      "type": "number",
      "unit": "mm/s",
      "default": 1,
      "businessContext": "Kare dalganın tepe genliği"
    },
    {
      "id": "period",
      "label": "Periyot (T)",
      "type": "number",
      "unit": "s",
      "default": 1,
      "businessContext": "Temel titreşim periyodu"
    },
    {
      "id": "time",
      "label": "Zaman (t)",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Sinyalin değerlendirildiği an"
    },
    {
      "id": "numHarmonics",
      "label": "Harmonik Sayısı (N)",
      "type": "number",
      "unit": "adet",
      "default": 3,
      "businessContext": "Kullanılacak tek harmonik sayısı (1, 3, 5)"
    }
  ],
  "formulas": {
    "primary": "offset + (4*amplitude/Math.PI) * ((Math.sin(2*Math.PI*1*time/period) * (numHarmonics >= 1 ? 1 : 0) * (1/1)) + (Math.sin(2*Math.PI*3*time/period) * (numHarmonics >= 2 ? 1 : 0) * (1/3)) + (Math.sin(2*Math.PI*5*time/period) * (numHarmonics >= 3 ? 1 : 0) * (1/5)))",
    "breakdown": [
      "offset",
      "(4*amplitude/Math.PI) * Math.sin(2*Math.PI*1*time/period) * (numHarmonics >= 1 ? 1 : 0) * (1/1)",
      "(4*amplitude/Math.PI) * Math.sin(2*Math.PI*3*time/period) * (numHarmonics >= 2 ? 1 : 0) * (1/3)",
      "(4*amplitude/Math.PI) * Math.sin(2*Math.PI*5*time/period) * (numHarmonics >= 3 ? 1 : 0) * (1/5)"
    ]
  },
  "outputs": {
    "primary": "Fourier Serisi Yaklaşık Değeri (mm/s)",
    "breakdown": [
      "DC Offset Katkısı (mm/s)",
      "1. Harmonik (f₁) Katkısı (mm/s)",
      "3. Harmonik (f₃) Katkısı (mm/s)",
      "5. Harmonik (f₅) Katkısı (mm/s)"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

{
  "toolName": "email-click-rate-calculator",
  "inputs": [
    {
      "id": "totalClicks",
      "label": "Total Clicks",
      "type": "number",
      "unit": "clicks",
      "default": 0,
      "businessContext": "Total number of unique clicks on links in the email campaign.",
      "label_i18n": {
        "en": "Total Clicks",
        "tr": "Total Clicks",

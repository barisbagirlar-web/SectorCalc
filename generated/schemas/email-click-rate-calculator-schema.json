        "ar": "Total Clicks"
      }
    },
    {
      "id": "totalDelivered",
      "label": "Total Delivered Emails",
      "type": "number",
      "unit": "emails",
      "default": 0,
      "businessContext": "Total number of emails successfully delivered to recipients' inboxes.",
      "label_i18n": {
        "en": "Total Delivered Emails",
        "tr": "Total Delivered Emails",
        "de": "Total Delivered Emails",
        "fr": "Total Delivered Emails",
        "es": "Total Delivered Emails",
        "ar": "Total Delivered Emails"
      }
    },
    {
      "id": "totalOpens",
      "label": "Total Opens",
      "type": "number",
      "unit": "opens",
      "default": 0,
      "businessContext": "Total number of times the email was opened (optional, for click-to-open rate).",
      "label_i18n": {
        "en": "Total Opens",
        "tr": "Total Opens",
        "de": "Total Opens",
        "fr": "Total Opens",
        "es": "Total Opens",
        "ar": "Total Opens"
      }
    },
    {
      "id": "totalSent",
      "label": "Total Sent Emails",
      "type": "number",
      "unit": "emails",
      "default": 0,
      "businessContext": "Total number of emails sent in the campaign.",
      "label_i18n": {
        "en": "Total Sent Emails",
        "tr": "Total Sent Emails",
        "de": "Total Sent Emails",
        "fr": "Total Sent Emails",
        "es": "Total Sent Emails",
        "ar": "Total Sent Emails"
      }
    },
    {
      "id": "bouncedEmails",
      "label": "Bounced Emails",
      "type": "number",
      "unit": "emails",
      "default": 0,
      "businessContext": "Number of emails that were not delivered due to hard or soft bounces.",
      "label_i18n": {
        "en": "Bounced Emails",
        "tr": "Bounced Emails",
        "de": "Bounced Emails",
        "fr": "Bounced Emails",
        "es": "Bounced Emails",
        "ar": "Bounced Emails"
      }
    }
  ],
  "formulas": {
    "clickRate": "(totalClicks / totalDelivered) * 100",
    "clickToOpenRate": "(totalClicks / totalOpens) * 100",
    "deliveryRate": "((totalSent - bouncedEmails) / totalSent) * 100"
  },
  "outputs": {
    "primary": "clickRate",
    "breakdown": [
      "clickToOpenRate",
      "deliveryRate"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "deliveryRate",
    "unit": "clicks"
  },

        "de": "KDV Oranı",
        "fr": "KDV Oranı",
        "es": "KDV Oranı",
        "ar": "KDV Oranı"
      }
    }
  ],
  "formulas": {
    "cifValue": "productValue + insurance + freight",
    "dutyAmount": "cifValue * dutyRate / 100",
    "vatAmount": "(cifValue + dutyAmount) * vatRate / 100",
    "totalCost": "cifValue + dutyAmount + vatAmount",
    "totalDuty": "dutyAmount"
  },
  "outputs": {
    "primary": "totalDuty",
    "breakdown": [

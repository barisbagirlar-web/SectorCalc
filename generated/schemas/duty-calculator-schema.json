      }
    },
    {
      "id": "vatRate",
      "label": "KDV Oranı",
      "type": "number",
      "unit": "%",
      "default": 18,
      "businessContext": "Value Added Tax rate applied on duty-paid CIF value",
      "label_i18n": {
        "en": "KDV Oranı",

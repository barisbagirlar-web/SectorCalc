  "formulas": {
    "WaterRequirement": "ETc * Area * (1 - EffectiveRainfall)",
    "PumpEnergy": "(WaterRequirement * TotalHead) / (PumpEff * MotorEff)",
    "EnergyCost": "PumpEnergy * ElecRate",
    "MaintCost": "Area * MaintRatePerHa",
    "TotalIrrigationCost": "EnergyCost + MaintCost + LaborCost + Depreciation",
    "CostPerM3": "TotalIrrigationCost / WaterRequirement",
    "WaterUseEfficiency": "(WaterRequirement - Losses) / WaterRequirement"
  },

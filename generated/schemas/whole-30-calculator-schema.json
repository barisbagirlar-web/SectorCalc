{
  "toolName": "whole-30-calculator",
  "inputs": [
    {
      "id": "dailyDemand",
      "label": "Daily Material Demand",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The amount of raw material required per day in kilograms.",
      "label_i18n": {
        "en": "Daily Material Demand",
        "tr": "Daily Material Demand",
        "de": "Daily Material Demand",
        "fr": "Daily Material Demand",
        "es": "Daily Material Demand",
        "ar": "Daily Material Demand"
      }
    },
    {
      "id": "costPerKg",
      "label": "Cost per kg",
      "type": "number",
      "unit": "EUR",
      "default": 2.5,
      "businessContext": "Unit cost of the material in EUR per kg.",
      "label_i18n": {
        "en": "Cost per kg",
        "tr": "Cost per kg",
        "de": "Cost per kg",
        "fr": "Cost per kg",
        "es": "Cost per kg",
        "ar": "Cost per kg"
      }
    },
    {
      "id": "wasteRate",
      "label": "Waste Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected percentage of material wasted during processing.",
      "label_i18n": {
        "en": "Waste Rate",
        "tr": "Waste Rate",
        "de": "Waste Rate",
        "fr": "Waste Rate",
        "es": "Waste Rate",
        "ar": "Waste Rate"
      }
    },
    {
      "id": "days",
      "label": "Number of Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Production period in days (default 30 for Whole 30).",
      "label_i18n": {
        "en": "Number of Days",
        "tr": "Number of Days",
        "de": "Number of Days",
        "fr": "Number of Days",
        "es": "Number of Days",
        "ar": "Number of Days"
      }
    }
  ],
  "formulas": {
    "totalMaterial": "dailyDemand * days * (1 + wasteRate/100)",
    "wasteAmount": "dailyDemand * days * wasteRate / 100",
    "totalCost": "dailyDemand * days * (1 + wasteRate/100) * costPerKg",
    "wasteCost": "dailyDemand * days * (wasteRate/100) * costPerKg"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalMaterial",
      "wasteAmount",
      "totalCost",
      "wasteCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "wasteCost",
    "unit": "kg"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Birim & Dönüşüm",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "birim-donusum",

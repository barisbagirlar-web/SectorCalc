{
  "toolName": "whole-30-calculator",
  "inputs": [
    {
      "id": "dailyDemand",
      "label": "Daily Material Demand",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The amount of raw material required per day in kilograms."
    },
    {
      "id": "costPerKg",
      "label": "Cost per kg",
      "type": "number",
      "unit": "EUR",
      "default": 2.5,
      "businessContext": "Unit cost of the material in EUR per kg."
    },
    {
      "id": "wasteRate",
      "label": "Waste Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected percentage of material wasted during processing."
    },
    {
      "id": "days",
      "label": "Number of Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Production period in days (default 30 for Whole 30)."
    }
  ],
  "formulas": {
    "totalMaterial": "dailyDemand * days * (1 + wasteRate/100)",
    "wasteAmount": "dailyDemand * days * wasteRate / 100",
    "totalCost": "dailyDemand * days * (1 + wasteRate/100) * costPerKg",
    "wasteCost": "dailyDemand * days * (wasteRate/100) * costPerKg"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalMaterial",
      "wasteAmount",
      "totalCost",
      "wasteCost"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Gıda & İçecek",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "cost"
}

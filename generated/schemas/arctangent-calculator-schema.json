  "formulas": {
    "result": "parseFloat(((outputUnit === 1 ? ((y !== 0 ? Math.atan2(y * scale, x * scale) : Math.atan(x * scale)) * 180 / Math.PI) : (y !== 0 ? Math.atan2(y * scale, x * scale) : Math.atan(x * scale))) + offset).toFixed(precision))",
    "rawRad": "y !== 0 ? Math.atan2(y * scale, x * scale) : Math.atan(x * scale)",
    "finalBeforeRound": "(outputUnit === 1 ? (y !== 0 ? Math.atan2(y * scale, x * scale) : Math.atan(x * scale)) * 180 / Math.PI : (y !== 0 ? Math.atan2(y * scale, x * scale) : Math.atan(x * scale))) + offset"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "rawRad",
      "finalBeforeRound"
    ]
  },

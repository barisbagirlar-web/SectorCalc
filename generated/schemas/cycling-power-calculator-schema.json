  "formulas": {
    "air_resistance_power": "0.5 * air_density * CdA * ((speed / 3.6 + wind_speed / 3.6) ** 2) * (speed / 3.6)",
    "rolling_resistance_power": "(rolling_resistance_coefficient * total_mass * 9.81) * (speed / 3.6)"
  },
  "outputs": {

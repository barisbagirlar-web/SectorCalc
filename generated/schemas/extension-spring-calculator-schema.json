{
  "toolName": "extension-spring-calculator",
  "inputs": [
    {
      "id": "wireDiameter",
      "label": "Wire Diameter (d)",
      "type": "number",
      "unit": "mm",
      "default": 2,
      "businessContext": "Spring wire diameter",
      "label_i18n": {
        "en": "Wire Diameter (d)",
        "tr": "Wire Diameter (d)",
        "de": "Wire Diameter (d)",
        "fr": "Wire Diameter (d)",
        "es": "Wire Diameter (d)",
        "ar": "Wire Diameter (d)"
      }
    },
    {
      "id": "outerDiameter",
      "label": "Outer Diameter (OD)",
      "type": "number",
      "unit": "mm",
      "default": 20,
      "businessContext": "Outer diameter of coil",
      "label_i18n": {
        "en": "Outer Diameter (OD)",
        "tr": "Outer Diameter (OD)",
        "de": "Outer Diameter (OD)",
        "fr": "Outer Diameter (OD)",
        "es": "Outer Diameter (OD)",
        "ar": "Outer Diameter (OD)"
      }
    },
    {
      "id": "totalCoils",
      "label": "Total Coils (Nt)",
      "type": "number",
      "unit": "unit",
      "default": 15,
      "businessContext": "Total number of coils including end hooks",
      "label_i18n": {
        "en": "Total Coils (Nt)",
        "tr": "Total Coils (Nt)",
        "de": "Total Coils (Nt)",
        "fr": "Total Coils (Nt)",
        "es": "Total Coils (Nt)",
        "ar": "Total Coils (Nt)"
      }
    },
    {
      "id": "shearModulus",
      "label": "Shear Modulus (G)",
      "type": "number",
      "unit": "MPa",
      "default": 79000,
      "businessContext": "Material shear modulus (steel ≈ 79000 MPa)",
      "label_i18n": {
        "en": "Shear Modulus (G)",
        "tr": "Shear Modulus (G)",
        "de": "Shear Modulus (G)",
        "fr": "Shear Modulus (G)",
        "es": "Shear Modulus (G)",
        "ar": "Shear Modulus (G)"
      }
    },
    {
      "id": "allowableStress",
      "label": "Allowable Shear Stress",
      "type": "number",
      "unit": "MPa",
      "default": 600,
      "businessContext": "Maximum permissible torsional shear stress",
      "label_i18n": {
        "en": "Allowable Shear Stress",
        "tr": "Allowable Shear Stress",
        "de": "Allowable Shear Stress",
        "fr": "Allowable Shear Stress",
        "es": "Allowable Shear Stress",
        "ar": "Allowable Shear Stress"
      }
    }
  ],
  "formulas": {
    "meanDiameter": "outerDiameter - wireDiameter",
    "springIndex": "meanDiameter / wireDiameter",
    "activeCoils": "totalCoils - 2",
    "wahlFactor": "(4*springIndex - 1) / (4*springIndex - 4) + 0.615 / springIndex",
    "springRate": "(shearModulus * Math.pow(wireDiameter, 4)) / (8 * Math.pow(meanDiameter, 3) * activeCoils)",
    "maxLoad": "(allowableStress * Math.PI * Math.pow(wireDiameter, 3)) / (8 * meanDiameter * wahlFactor)"
  },
  "outputs": {
    "primary": "springRate",
    "breakdown": [
      "meanDiameter",
      "springIndex",
      "activeCoils",
      "wahlFactor",
      "maxLoad"
    ]
  },
  "category": "Makine & Tasarım",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",
  "categoryId": "engineering"
}

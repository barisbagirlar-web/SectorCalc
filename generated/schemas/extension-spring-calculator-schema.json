  "formulas": {
    "meanDiameter": "outerDiameter - wireDiameter",
    "springIndex": "meanDiameter / wireDiameter",
    "activeCoils": "totalCoils - 2",
    "wahlFactor": "(4*springIndex - 1) / (4*springIndex - 4) + 0.615 / springIndex"
  },
  "outputs": {
    "primary": "wahlFactor",
    "breakdown": [
      "meanDiameter",
      "springIndex",
      "activeCoils",
      "wahlFactor",
      "maxLoad"
    ],

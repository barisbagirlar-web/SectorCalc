{
  "toolName": "low-pass-filter-calculator",
  "inputs": [
    {
      "id": "r",
      "label": "Resistance (R)",
      "type": "number",
      "unit": "Ω",
      "default": 1000,
      "businessContext": "Resistor value in ohms",
      "label_i18n": {
        "en": "Resistance (R)",
        "tr": "Resistance (R)",
        "de": "Resistance (R)",
        "fr": "Resistance (R)",
        "es": "Resistance (R)",
        "ar": "Resistance (R)"
      }
    },
    {
      "id": "r_tol",
      "label": "Resistance Tolerance",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Resistor tolerance (±%)",
      "label_i18n": {
        "en": "Resistance Tolerance",
        "tr": "Resistance Tolerance",
        "de": "Resistance Tolerance",
        "fr": "Resistance Tolerance",
        "es": "Resistance Tolerance",
        "ar": "Resistance Tolerance"
      }
    },
    {
      "id": "c",
      "label": "Capacitance (C)",
      "type": "number",
      "unit": "F",
      "default": 0.000001,
      "businessContext": "Capacitor value in farads",
      "label_i18n": {
        "en": "Capacitance (C)",
        "tr": "Capacitance (C)",
        "de": "Capacitance (C)",
        "fr": "Capacitance (C)",
        "es": "Capacitance (C)",
        "ar": "Capacitance (C)"
      }
    },
    {
      "id": "c_tol",
      "label": "Capacitance Tolerance",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Capacitor tolerance (±%)",
      "label_i18n": {
        "en": "Capacitance Tolerance",
        "tr": "Capacitance Tolerance",
        "de": "Capacitance Tolerance",
        "fr": "Capacitance Tolerance",
        "es": "Capacitance Tolerance",
        "ar": "Capacitance Tolerance"
      }
    },
    {
      "id": "fin",
      "label": "Input Signal Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 100,
      "businessContext": "Frequency of the input signal for attenuation calculation",
      "label_i18n": {
        "en": "Input Signal Frequency",
        "tr": "Input Signal Frequency",
        "de": "Input Signal Frequency",
        "fr": "Input Signal Frequency",
        "es": "Input Signal Frequency",
        "ar": "Input Signal Frequency"
      }
    }
  ],
  "formulas": {
    "fc": "1 / (2 * Math.PI * r * c)",
    "tau": "r * c",
    "attenuation": "-10 * (Math.log(1 + (2 * Math.PI * r * c * fin) ** 2) / Math.log(10))",
    "fc_min": "1 / (2 * Math.PI * r * (1 + r_tol/100) * c * (1 + c_tol/100))",
    "fc_max": "1 / (2 * Math.PI * r * (1 - r_tol/100) * c * (1 - c_tol/100))"
  },
  "outputs": {
    "primary": "fc",
    "breakdown": [
      "tau",
      "attenuation",
      "fc_min",
      "fc_max"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "electrical-power-systems",
  "sectorId": "telekom",

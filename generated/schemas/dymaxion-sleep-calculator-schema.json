{
  "toolName": "dymaxion-sleep-calculator",
  "inputs": [
    {
      "id": "napDurationMinutes",
      "label": "Nap Duration (minutes)",
      "type": "number",
      "unit": "minute",
      "default": 30,
      "businessContext": "Duration of each nap in minutes. Dymaxion schedule typically uses 30-minute naps.",
      "label_i18n": {
        "en": "Nap Duration (minutes)",
        "tr": "Nap Duration (minutes)",
        "de": "Nap Duration (minutes)",
        "fr": "Nap Duration (minutes)",
        "es": "Nap Duration (minutes)",
        "ar": "Nap Duration (minutes)"
      }
    },
    {
      "id": "intervalHours",
      "label": "Interval Between Naps (hours)",
      "type": "number",
      "unit": "hour",
      "default": 6,
      "businessContext": "Time between the start of each nap. Standard Dymaxion interval is 6 hours, resulting in 4 naps per day.",
      "label_i18n": {
        "en": "Interval Between Naps (hours)",
        "tr": "Interval Between Naps (hours)",
        "de": "Interval Between Naps (hours)",
        "fr": "Interval Between Naps (hours)",
        "es": "Interval Between Naps (hours)",
        "ar": "Interval Between Naps (hours)"
      }
    },
    {
      "id": "totalDays",
      "label": "Total Days",
      "type": "number",
      "unit": "day",
      "default": 7,
      "businessContext": "Number of consecutive days to calculate total sleep duration.",
      "label_i18n": {
        "en": "Total Days",
        "tr": "Total Days",
        "de": "Total Days",
        "fr": "Total Days",
        "es": "Total Days",
        "ar": "Total Days"
      }
    },
    {
      "id": "baseSleepHours",
      "label": "Baseline Monophasic Sleep (hours)",
      "type": "number",
      "unit": "hour",
      "default": 8,
      "businessContext": "Recommended monophasic sleep duration used for efficiency comparison.",
      "label_i18n": {
        "en": "Baseline Monophasic Sleep (hours)",
        "tr": "Baseline Monophasic Sleep (hours)",
        "de": "Baseline Monophasic Sleep (hours)",
        "fr": "Baseline Monophasic Sleep (hours)",
        "es": "Baseline Monophasic Sleep (hours)",
        "ar": "Baseline Monophasic Sleep (hours)"
      }
    }
  ],
  "formulas": {
    "napsPerDay": "24 / intervalHours",
    "totalNaps": "napsPerDay * totalDays",
    "totalSleepMinutes": "totalNaps * napDurationMinutes",
    "totalSleepHours": "totalSleepMinutes / 60",
    "efficiencyPercent": "(totalSleepMinutes / (baseSleepHours * 60)) * 100",
    "__napsPerDay_toFixed_1____standard_Dymax": "${napsPerDay.toFixed(1)} (standard Dymaxion: 4).",
    "__totalNaps_toFixed_1___": "${totalNaps.toFixed(1)}.",
    "__efficiencyPercent_toFixed_1_____lower_": "${efficiencyPercent.toFixed(1)}% (lower means less sleep).",
    "result": "Total sleep: ${totalSleepHours.toFixed(1)} hours (${totalSleepMinutes} minutes) over ${totalDays} day(s)."
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Number of naps per day: ${napsPerDay.toFixed(1)} (standard Dymaxion: 4).",
      "Total naps: ${totalNaps.toFixed(1)}.",
      "Efficiency relative to ${baseSleepHours}h monophasic: ${efficiencyPercent.toFixed(1)}% (lower means less sleep)."
    ]
  },
  "category": "Verimlilik & OEE",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "efficiency"
}

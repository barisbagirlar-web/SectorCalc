{
  "toolName": "hiit-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's body weight in kilograms."
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "User's height in centimeters."
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years."
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "0 for female, 1 for male."
    },
    {
      "id": "duration",
      "label": "Workout Duration",
      "type": "number",
      "unit": "minutes",
      "default": 30,
      "businessContext": "Total duration of the HIIT session in minutes."
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 8,
      "businessContext": "Metabolic Equivalent of Task for HIIT (typically 8-12)."
    }
  ],
  "formulas": {
    "bmr_male": "88.362 + (13.397 * weight) + (4.799 * height) - (5.677 * age)",
    "bmr_female": "447.593 + (9.247 * weight) + (3.098 * height) - (4.330 * age)",
    "bmr": "gender === 1 ? bmr_male : bmr_female",
    "hourlyBmr": "bmr / 24",
    "calories": "hourlyBmr * met * (duration / 60)",
    "caloriesPerMinute": "calories / duration"
  },
  "outputs": {
    "primary": "calories",
    "breakdown": [
      "caloriesPerMinute",
      "bmr"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false
}
{
  "toolName": "network-calculator",
  "inputs": [
    {
      "id": "ip1",
      "label": "IP Address Octet 1",
      "type": "number",
      "unit": "",
      "default": 192,
      "businessContext": "First octet of the IP address (0-255)"
    },
    {
      "id": "ip2",
      "label": "IP Address Octet 2",
      "type": "number",
      "unit": "",
      "default": 168,
      "businessContext": "Second octet of the IP address (0-255)"
    },
    {
      "id": "ip3",
      "label": "IP Address Octet 3",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Third octet of the IP address (0-255)"
    },
    {
      "id": "ip4",
      "label": "IP Address Octet 4",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Fourth octet of the IP address (0-255)"
    },
    {
      "id": "cidr",
      "label": "CIDR Prefix Length",
      "type": "number",
      "unit": "bits",
      "default": 24,
      "businessContext": "Subnet mask length in CIDR notation (0-32)"
    }
  ],
  "formulas": {
    "ipInt": "((ip1 << 24) | (ip2 << 16) | (ip3 << 8) | ip4) >>> 0",
    "maskInt": "cidr === 0 ? 0 : (0xFFFFFFFF << (32 - cidr)) >>> 0",
    "networkInt": "(ipInt & maskInt) >>> 0",
    "broadcastInt": "(networkInt | (~maskInt >>> 0)) >>> 0",
    "hostCount": "cidr >= 31 ? 0 : Math.pow(2, 32 - cidr) - 2"
  },
  "outputs": {
    "primary": "networkInt",
    "breakdown": [
      "broadcastInt",
      "maskInt",
      "hostCount"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

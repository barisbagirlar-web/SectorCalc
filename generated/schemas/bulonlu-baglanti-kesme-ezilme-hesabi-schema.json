{
  "toolName": "bulonlu-baglanti-kesme-ezilme-hesabi",
  "inputs": [
    {
      "id": "bulonCapi",
      "label": "Bulon Çapı (d)",
      "type": "number",
      "unit": "mm",
      "default": 16,
      "min": 6,
      "max": 48,
      "options": null,
      "businessContext": "Bulonun nominal çapı. TS EN ISO 898-1'e göre standart çaplar kullanılır. Kesme ve ezilme dayanımını doğrudan etkiler."
    },
    {
      "id": "bulonSayisi",
      "label": "Bulon Sayısı (n)",
      "type": "number",
      "unit": "adet",
      "default": 2,
      "min": 1,
      "max": 20,
      "options": null,
      "businessContext": "Bağlantıdaki toplam bulon sayısı. Yük dağılımını etkiler."
    },
    {
      "id": "levhaKalınligi",
      "label": "Levha Kalınlığı (t)",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "min": 3,
      "max": 50,
      "options": null,
      "businessContext": "Bağlanan levhaların kalınlığı. Ezilme dayanımı için kritik."
    },
    {
      "id": "levhaAkmaDayanimi",
      "label": "Levha Akma Dayanımı (fy)",
      "type": "number",
      "unit": "MPa",
      "default": 235,
      "min": 200,
      "max": 700,
      "options": null,
      "businessContext": "Levha malzemesinin akma dayanımı. TS EN 10025'e göre S235, S355 gibi değerler."
    },
    {
      "id": "bulonSinifi",
      "label": "Bulon Sınıfı",
      "type": "select",
      "unit": "",
      "default": "8.8",
      "min": null,
      "max": null,
      "options": [
        "4.6",
        "5.6",
        "6.8",
        "8.8",
        "10.9",
        "12.9"
      ],
      "businessContext": "Bulonun dayanım sınıfı. TS EN ISO 898-1'e göre tanımlanır. Kesme dayanımını belirler."
    },
    {
      "id": "kesitSayisi",
      "label": "Kesit Sayısı (m)",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "min": 1,
      "max": 2,
      "options": null,
      "businessContext": "Kesme düzlemi sayısı. Tek veya çift kesme durumu."
    },
    {
      "id": "yukTuru",
      "label": "Yük Türü",
      "type": "select",
      "unit": "",
      "default": "statik",
      "min": null,
      "max": null,
      "options": [
        "statik",
        "dinamik"
      ],
      "businessContext": "Yükün statik veya dinamik olması. Dinamik yükte dayanım düşürülür."
    },
    {
      "id": "guvenlikFaktoru",
      "label": "Güvenlik Faktörü (γ)",
      "type": "number",
      "unit": "",
      "default": 1.5,
      "min": 1,
      "max": 3,
      "options": null,
      "businessContext": "TS EN 1993-1-8 (Eurocode 3) uyarınca güvenlik faktörü. Statik yük için 1.5, dinamik için 2.0 önerilir."
    },
    {
      "id": "uygulananKuvvet",
      "label": "Uygulanan Kuvvet (F)",
      "type": "number",
      "unit": "kN",
      "default": 100,
      "min": 0,
      "max": 10000,
      "options": null,
      "businessContext": "Bağlantıya etkiyen dış kuvvet. Tasarım yükü."
    }
  ],
  "validation": {
    "rules": [
      "levhaKalınligi >= 3",
      "bulonCapi >= 6",
      "bulonSayisi >= 1",
      "guvenlikFaktoru >= 1.0",
      "uygulananKuvvet >= 0",
      "Eger yukTuru == 'dinamik' ise guvenlikFaktoru >= 2.0",
      "Eger bulonSinifi == '12.9' ise bulonCapi <= 36"
    ],
    "thresholds": {
      "kesmeKontrol": "kesmeDirenci < uygulananKuvvet ? 'Kesme dayanımı yetersiz' : ''",
      "ezilmeKontrol": "ezilmeDirenci < uygulananKuvvet ? 'Ezilme dayanımı yetersiz' : ''",
      "guvenlikFaktoruUyari": "guvenlikFaktoru < 1.5 ? 'Güvenlik faktörü düşük' : ''"
    }
  },
  "formulas": {
    "bulonAkmaDayanimi": "bulonSinifi == '4.6' ? 400 : bulonSinifi == '5.6' ? 500 : bulonSinifi == '6.8' ? 600 : bulonSinifi == '8.8' ? 800 : bulonSinifi == '10.9' ? 1000 : 1200",
    "bulonKesmeDayanimi": "0.6 * bulonAkmaDayanimi",
    "kesmeDirenci": "bulonKesmeDayanimi * (Math.PI * bulonCapi * bulonCapi / 4) * kesitSayisi * bulonSayisi / (guvenlikFaktoru * 1000)",
    "ezilmeDirenci": "levhaAkmaDayanimi * bulonCapi * levhaKalınligi * bulonSayisi / (guvenlikFaktoru * 1000)",
    "emniyetOrani": "Math.min(kesmeDirenci, ezilmeDirenci) / uygulananKuvvet",
    "durum": "emniyetOrani >= 1 ? 'Güvenli' : 'Güvensiz'"
  },
  "outputs": {
    "primary": "emniyetOrani",
    "breakdown": {
      "kesmeDirenci": "kesmeDirenci",
      "ezilmeDirenci": "ezilmeDirenci",
      "bulonAkmaDayanimi": "bulonAkmaDayanimi",
      "bulonKesmeDayanimi": "bulonKesmeDayanimi"
    },
    "hiddenLossDrivers": [
      "kesmeKontrol",
      "ezilmeKontrol",
      "guvenlikFaktoruUyari"
    ],
    "suggestedActions": [
      "Eger emniyetOrani < 1 ise bulon çapını veya sayısını artırın.",
      "Eger emniyetOrani < 1 ise daha yüksek dayanımlı bulon sınıfı seçin.",
      "Eger emniyetOrani < 1 ise levha kalınlığını artırın.",
      "Dinamik yük durumunda güvenlik faktörünü en az 2.0 alın."
    ],
    "dataConfidenceAdjusted": "emniyetOrani * 0.9"
  },
  "premiumFeatures": [
    "PDF raporu",
    "CSV export",
    "Trend analizi",
    "Karşılaştırma (farklı bulon çapları/sınıfları)"
  ],
  "premiumRequired": true
}

  "formulas": {
    "distanceModulus": "5 * (Math.log(distanceParsecs) / Math.log(10) - 1)",
    "absoluteVisualMagnitude": "apparentMagnitude - (5 * (Math.log(distanceParsecs) / Math.log(10) - 1)) - extinction",
    "absoluteBolometricMagnitude": "apparentMagnitude - (5 * (Math.log(distanceParsecs) / Math.log(10) - 1)) - extinction + bolometricCorrection"
  },

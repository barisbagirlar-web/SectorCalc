      "businessContext": "Gross annual income before disability",
      "label_i18n": {
        "en": "Annual Income",
        "tr": "Yıllık Gelir",
        "de": "Jahreseinkommen",
        "fr": "Annual Income",
        "es": "Annual Income",
        "ar": "Annual Income"
      },
      "businessContext_i18n": {
        "en": "Gross annual income before disability",
        "tr": "Engellilik öncesi brüt yıllık gelir",
        "de": "Bruttojahreseinkommen vor Invalidität"
      }
    },
    {
      "id": "replacementRatio",
      "label": "Income Replacement Ratio",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Percentage of income replaced by disability insurance",
      "label_i18n": {
        "en": "Income Replacement Ratio",
        "tr": "Gelir Değiştirme Oranı",

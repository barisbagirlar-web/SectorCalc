{
  "toolName": "disability-insurance-calculator",
  "inputs": [
    {
      "id": "annualIncome",
      "label": "Annual Income",
      "type": "number",
      "unit": "USD",
      "default": 50000,
      "businessContext": "Gross annual income before disability",
      "label_i18n": {
        "en": "Annual Income",
        "tr": "Annual Income",
        "de": "Annual Income",
        "fr": "Annual Income",
        "es": "Annual Income",
        "ar": "Annual Income"
      }
    },
    {
      "id": "replacementRatio",
      "label": "Income Replacement Ratio",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Percentage of income replaced by disability insurance",
      "label_i18n": {
        "en": "Income Replacement Ratio",
        "tr": "Income Replacement Ratio",
        "de": "Income Replacement Ratio",
        "fr": "Income Replacement Ratio",
        "es": "Income Replacement Ratio",
        "ar": "Income Replacement Ratio"
      }
    },
    {
      "id": "benefitPeriodYears",
      "label": "Benefit Period",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration of disability benefit payments",
      "label_i18n": {
        "en": "Benefit Period",
        "tr": "Benefit Period",
        "de": "Benefit Period",
        "fr": "Benefit Period",
        "es": "Benefit Period",
        "ar": "Benefit Period"
      }
    },
    {
      "id": "waitingPeriodMonths",
      "label": "Waiting Period",
      "type": "number",
      "unit": "months",
      "default": 3,
      "businessContext": "Time after disability before benefits start",
      "label_i18n": {
        "en": "Waiting Period",
        "tr": "Waiting Period",
        "de": "Waiting Period",
        "fr": "Waiting Period",
        "es": "Waiting Period",
        "ar": "Waiting Period"
      }
    },
    {
      "id": "discountRate",
      "label": "Annual Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Rate used to calculate present value",
      "label_i18n": {
        "en": "Annual Discount Rate",
        "tr": "Annual Discount Rate",
        "de": "Annual Discount Rate",
        "fr": "Annual Discount Rate",
        "es": "Annual Discount Rate",
        "ar": "Annual Discount Rate"
      }
    },
    {
      "id": "inflationRate",
      "label": "Annual Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Expected inflation rate for benefit escalation (optional)",
      "label_i18n": {
        "en": "Annual Inflation Rate",
        "tr": "Annual Inflation Rate",
        "de": "Annual Inflation Rate",
        "fr": "Annual Inflation Rate",
        "es": "Annual Inflation Rate",
        "ar": "Annual Inflation Rate"
      }
    }
  ],
  "formulas": {
    "monthlyBenefit": "(annualIncome * (replacementRatio / 100)) / 12",
    "totalBenefitsUndiscounted": "monthlyBenefit * benefitPeriodYears * 12"
  },
  "outputs": {
    "primary": "totalBenefitsUndiscounted",
    "breakdown": [
      "monthlyBenefit",
      "totalBenefitsUndiscounted"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "presentValue"
  },
  "category": "Proje & Yatırım",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

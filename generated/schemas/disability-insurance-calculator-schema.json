      }
    },
    {
      "id": "benefitPeriodYears",
      "label": "Benefit Period",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Duration of disability benefit payments",
      "label_i18n": {
        "en": "Benefit Period",
        "tr": "Fayda Süresi",
        "de": "Leistungsdauer",
        "fr": "Benefit Period",

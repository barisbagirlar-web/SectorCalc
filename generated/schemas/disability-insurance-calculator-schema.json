        "de": "Wartezeit",
        "fr": "Waiting Period",
        "es": "Waiting Period",
        "ar": "Waiting Period"
      },
      "businessContext_i18n": {
        "en": "Time after disability before benefits start",
        "tr": "Engellilikten sonra faydaların başlamasından önceki süre",
        "de": "Zeit nach Eintritt der Invalidität bis zum Beginn der Leistungen"
      }
    },
    {
      "id": "discountRate",
      "label": "Annual Discount Rate",
      "type": "number",
      "unit": "%",
      "default": 3,
      "businessContext": "Rate used to calculate present value",
      "label_i18n": {
        "en": "Annual Discount Rate",
        "tr": "Yıllık İskonto Oranı",
        "de": "Jährlicher Diskontsatz",
        "fr": "Annual Discount Rate",
        "es": "Annual Discount Rate",
        "ar": "Annual Discount Rate"
      },
      "businessContext_i18n": {
        "en": "Rate used to calculate present value",
        "tr": "Bugünkü değeri hesaplamak için kullanılan oran",
        "de": "Zinssatz zur Berechnung des Barwerts"
      }
    },
    {
      "id": "inflationRate",
      "label": "Annual Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Expected inflation rate for benefit escalation (optional)",
      "label_i18n": {
        "en": "Annual Inflation Rate",
        "tr": "Yıllık Enflasyon Oranı",
        "de": "Jährliche Inflationsrate",
        "fr": "Annual Inflation Rate",
        "es": "Annual Inflation Rate",
        "ar": "Annual Inflation Rate"
      },
      "businessContext_i18n": {
        "en": "Expected inflation rate for benefit escalation (optional)",
        "tr": "Fayda artışı için beklenen enflasyon oranı (isteğe bağlı)",
        "de": "Erwartete Inflationsrate für Leistungssteigerung (optional)"
      }
    }
  ],
  "formulas": {
    "monthlyBenefit": "(annualIncome * (replacementRatio / 100)) / 12",
    "totalBenefitsUndiscounted": "monthlyBenefit * benefitPeriodYears * 12"
  },
  "outputs": {
    "primary": "totalBenefitsUndiscounted",
    "breakdown": [
      "monthlyBenefit",
      "totalBenefitsUndiscounted"
    ],

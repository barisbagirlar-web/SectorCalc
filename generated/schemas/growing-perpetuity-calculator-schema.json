{
  "toolName": "growing-perpetuity-calculator",
  "inputs": [
    {
      "id": "initialCashFlow",
      "label": "İlk Nakit Akışı",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "İlk dönem sonunda elde edilmesi beklenen nakit akışı (genellikle bir sonraki yıl)",
      "label_i18n": {
        "en": "İlk Nakit Akışı",
        "tr": "İlk Nakit Akışı",
        "de": "İlk Nakit Akışı",
        "fr": "İlk Nakit Akışı",
        "es": "İlk Nakit Akışı",
        "ar": "İlk Nakit Akışı"
      }
    },
    {
      "id": "discountRate",
      "label": "İskonto Oranı",
      "type": "number",
      "unit": "percentage",
      "default": 10,
      "businessContext": "Yatırımcının beklenen getiri oranı veya sermaye maliyeti, iskonto oranı olarak kullanılır",
      "label_i18n": {
        "en": "İskonto Oranı",
        "tr": "İskonto Oranı",
        "de": "İskonto Oranı",
        "fr": "İskonto Oranı",
        "es": "İskonto Oranı",
        "ar": "İskonto Oranı"
      }
    },
    {
      "id": "growthRate",
      "label": "Büyüme Oranı",
      "type": "number",
      "unit": "percentage",
      "default": 3,
      "businessContext": "Nakit akışlarının her dönemdeki sabit büyüme oranı, iskonto oranından küçük olmalıdır",
      "label_i18n": {
        "en": "Büyüme Oranı",
        "tr": "Büyüme Oranı",
        "de": "Büyüme Oranı",
        "fr": "Büyüme Oranı",
        "es": "Büyüme Oranı",
        "ar": "Büyüme Oranı"
      }
    },
    {
      "id": "timingFlag",
      "label": "Ödeme Zamanlaması",
      "type": "number",
      "unit": "binary (0=Dönem Sonu, 1=Dönem Başı)",
      "default": 0,
      "businessContext": "Nakit akışlarının dönem sonunda mı (0) yoksa dönem başında mı (1) gerçekleştiğini belirtir",
      "label_i18n": {
        "en": "Ödeme Zamanlaması",
        "tr": "Ödeme Zamanlaması",
        "de": "Ödeme Zamanlaması",
        "fr": "Ödeme Zamanlaması",
        "es": "Ödeme Zamanlaması",
        "ar": "Ödeme Zamanlaması"
      }
    }
  ],
  "formulas": {
    "discountRateMinusGrowth": "(discountRate - growthRate) / 100",
    "presentValueBeforeTiming": "initialCashFlow / discountRateMinusGrowth",
    "presentValue": "timingFlag === 1 ? presentValueBeforeTiming * (1 + discountRate/100) : presentValueBeforeTiming"
  },
  "outputs": {
    "primary": "presentValue",
    "breakdown": [
      "discountRateMinusGrowth",
      "presentValueBeforeTiming"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "presentValue",
    "unit": "currency"
  },
  "category": "Diğer",
  "sector": "Havacılık & Uzay",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

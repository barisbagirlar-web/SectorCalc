    {
      "id": "uncertaintyPercent",
      "label": "Measurement Uncertainty (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Relative uncertainty (k=2) to compute expanded uncertainty in cm",
      "label_i18n": {
        "en": "Measurement Uncertainty (%)",
        "tr": "Measurement Uncertainty (%)",
        "de": "Measurement Uncertainty (%)",
        "fr": "Measurement Uncertainty (%)",
        "es": "Measurement Uncertainty (%)",
        "ar": "Measurement Uncertainty (%)"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "cm/in",
      "default": 2.54,
      "businessContext": "Fixed factor: 1 inch = 2.54 cm (ISO 80000-3)",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",
        "es": "Conversion Factor",
        "ar": "Conversion Factor"
      }
    },
    {
      "id": "toleranceMm",
      "label": "Tolerance (±)",
      "type": "number",
      "unit": "mm",
      "default": 0.5,
      "businessContext": "Acceptable deviation in mm, e.g., ISO 2768-m",
      "label_i18n": {
        "en": "Tolerance (±)",
        "tr": "Tolerance (±)",
        "de": "Tolerance (±)",
        "fr": "Tolerance (±)",
        "es": "Tolerance (±)",
        "ar": "Tolerance (±)"
      }
    },
    {
      "id": "measurementTemperature",
      "label": "Measurement Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Temperature during measurement for steel (CTE ~11.5e-6/K)",
      "label_i18n": {
        "en": "Measurement Temperature",
        "tr": "Measurement Temperature",
        "de": "Measurement Temperature",
        "fr": "Measurement Temperature",
        "es": "Measurement Temperature",
        "ar": "Measurement Temperature"
      }
    },
    {
      "id": "materialExpansionCoeff",
      "label": "Thermal Expansion Coefficient",
      "type": "number",
      "unit": "1/K",
      "default": 0.0000115,
      "businessContext": "Linear CTE for material (steel ~11.5e-6, aluminum ~23e-6)",
      "label_i18n": {
        "en": "Thermal Expansion Coefficient",
        "tr": "Thermal Expansion Coefficient",
        "de": "Thermal Expansion Coefficient",
        "fr": "Thermal Expansion Coefficient",
        "es": "Thermal Expansion Coefficient",
        "ar": "Thermal Expansion Coefficient"
      }
    },
    {
      "id": "referenceTemperature",
      "label": "Reference Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Reference for material dimensions (typically 20°C)",
      "label_i18n": {
        "en": "Reference Temperature",
        "tr": "Reference Temperature",
        "de": "Reference Temperature",
        "fr": "Reference Temperature",
        "es": "Reference Temperature",
        "ar": "Reference Temperature"
      }
    }
  ],
  "formulas": {
    "rawCm": "(inches + calibrationOffset) * conversionFactor",
    "thermalCorrection": "1 + materialExpansionCoeff * (measurementTemperature - referenceTemperature)",
    "convertedLengthCm": "rawCm * thermalCorrection",
    "expandedUncertaintyCm": "convertedLengthCm * (uncertaintyPercent / 100)"
  },
  "outputs": {
    "primary": "convertedLengthCm",
    "breakdown": [
      "Step 1 – Raw conversion: (inches + calibrationOffset) × conversionFactor = rawCm cm",
      "Step 2 – Thermal expansion correction: 1 + α × (T_meas – T_ref) = thermalCorrection factor",
      "Step 3 – Final converted length: rawCm × thermalCorrection = convertedLengthCm cm",
      "Step 4 – Expanded uncertainty (k=2): convertedLengthCm × (uncertainty%/100) = expandedUncertaintyCm cm",
      "Step 5 – Tolerance check: |expandedUncertaintyCm × 10| ≤ toleranceMm → tolerancePass"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "tolerancePass",
    "unit": "cm",
    "breakdownUnits": {
      "Step 1 – Raw conversion: (inches + calibrationOffset) × conversionFactor = rawCm cm": "%",
      "Step 3 – Final converted length: rawCm × thermalCorrection = convertedLengthCm cm": "cm",
      "Step 4 – Expanded uncertainty (k=2): convertedLengthCm × (uncertainty%/100) = expandedUncertaintyCm cm": "cm"
    }
  },

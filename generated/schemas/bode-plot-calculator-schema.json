{
  "toolName": "bode-plot-calculator",
  "inputs": [
    {
      "id": "gain",
      "label": "DC Gain",
      "type": "number",
      "unit": "V/V",
      "default": 1,
      "businessContext": "System static gain (K)",
      "label_i18n": {
        "en": "DC Gain",
        "tr": "DC Gain",
        "de": "DC Gain",
        "fr": "DC Gain",
        "es": "DC Gain",
        "ar": "DC Gain"
      }
    },
    {
      "id": "poleFreq",
      "label": "Pole Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1000,
      "businessContext": "Cut-off frequency of dominant pole (>0 Hz)",
      "label_i18n": {
        "en": "Pole Frequency",
        "tr": "Pole Frequency",
        "de": "Pole Frequency",
        "fr": "Pole Frequency",
        "es": "Pole Frequency",
        "ar": "Pole Frequency"
      }
    },
    {
      "id": "zeroFreq",
      "label": "Zero Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 10000,
      "businessContext": "Frequency of zero (>0 Hz)",
      "label_i18n": {
        "en": "Zero Frequency",
        "tr": "Zero Frequency",
        "de": "Zero Frequency",
        "fr": "Zero Frequency",
        "es": "Zero Frequency",
        "ar": "Zero Frequency"
      }
    },
    {
      "id": "freq",
      "label": "Test Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1000,
      "businessContext": "Frequency at which to evaluate magnitude",
      "label_i18n": {
        "en": "Test Frequency",
        "tr": "Test Frequency",
        "de": "Test Frequency",
        "fr": "Test Frequency",
        "es": "Test Frequency",
        "ar": "Test Frequency"
      }
    }
  ],
  "formulas": {
    "gain_dB": "20 * Math.log(gain) / Math.log(10)",
    "zeroContrib": "10 * Math.log(1 + (freq/zeroFreq)**2) / Math.log(10)",
    "poleContrib": "-10 * Math.log(1 + (freq/poleFreq)**2) / Math.log(10)",
    "magnitude_dB": "gain_dB + zeroContrib + poleContrib"
  },
  "outputs": {
    "primary": "magnitude_dB",
    "breakdown": [
      "gain_dB",
      "zeroContrib",
      "poleContrib"
    ]
  },

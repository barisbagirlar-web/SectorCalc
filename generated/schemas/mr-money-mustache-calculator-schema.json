{
  "toolName": "mr-money-mustache-calculator",
  "inputs": [
    {
      "id": "annualIncome",
      "label": "Annual Income",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "businessContext": "Total annual after-tax income",
      "label_i18n": {
        "en": "Annual Income",
        "tr": "Annual Income",
        "de": "Annual Income",
        "fr": "Annual Income",
        "es": "Annual Income",
        "ar": "Annual Income"
      }
    },
    {
      "id": "annualExpenses",
      "label": "Annual Expenses",
      "type": "number",
      "unit": "USD",
      "default": 40000,
      "businessContext": "Total annual living expenses",
      "label_i18n": {
        "en": "Annual Expenses",
        "tr": "Annual Expenses",
        "de": "Annual Expenses",
        "fr": "Annual Expenses",
        "es": "Annual Expenses",
        "ar": "Annual Expenses"
      }
    },
    {
      "id": "currentPortfolio",
      "label": "Current Portfolio",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Current invested portfolio value",
      "label_i18n": {
        "en": "Current Portfolio",
        "tr": "Current Portfolio",
        "de": "Current Portfolio",
        "fr": "Current Portfolio",
        "es": "Current Portfolio",
        "ar": "Current Portfolio"
      }
    },
    {
      "id": "expectedReturn",
      "label": "Expected Return",
      "type": "number",
      "unit": "%",
      "default": 7,
      "businessContext": "Expected annual real investment return (after inflation)",
      "label_i18n": {
        "en": "Expected Return",
        "tr": "Expected Return",
        "de": "Expected Return",
        "fr": "Expected Return",
        "es": "Expected Return",
        "ar": "Expected Return"
      }
    },
    {
      "id": "safeWithdrawalRate",
      "label": "Safe Withdrawal Rate",
      "type": "number",
      "unit": "%",
      "default": 4,
      "businessContext": "Safe withdrawal rate for retirement (e.g., 4% rule)",
      "label_i18n": {
        "en": "Safe Withdrawal Rate",
        "tr": "Safe Withdrawal Rate",
        "de": "Safe Withdrawal Rate",
        "fr": "Safe Withdrawal Rate",
        "es": "Safe Withdrawal Rate",
        "ar": "Safe Withdrawal Rate"
      }
    }
  ],
  "formulas": {
    "annualSavings": "annualIncome - annualExpenses",
    "savingsRate": "(annualIncome - annualExpenses) / annualIncome",
    "futurePortfolioNeeded": "annualExpenses / (safeWithdrawalRate / 100)",
    "yearsToFI": "Math.log((futurePortfolioNeeded * (expectedReturn / 100) + annualSavings) / (currentPortfolio * (expectedReturn / 100) + annualSavings)) / Math.log(1 + expectedReturn / 100)"
  },
  "outputs": {
    "primary": "yearsToFI",
    "breakdown": [
      "annualSavings",
      "savingsRate",
      "futurePortfolioNeeded"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "electrical-power-systems",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance"
}

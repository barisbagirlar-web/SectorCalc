  "formulas": {
    "modWorking": "((po2_work / (fo2/100)) - 1) * 10",
    "modDeco": "((po2_deco / (fo2/100)) - 1) * 10",
    "ead": "(((1 - fo2/100) / 0.79) * (depth/10 + 1) - 1) * 10"

      },
      "businessContext_i18n": {
        "en": "Total number of users or licenses under subscription",
        "tr": "Abonelik altındaki toplam kullanıcı veya lisans sayısı"
      }
    },
    {
      "id": "pricePerUser",
      "label": "Price per User (Monthly)",
      "type": "number",
      "unit": "currency",
      "default": 10,
      "businessContext": "Monthly subscription cost per user",
      "label_i18n": {
        "en": "Price per User (Monthly)",
        "tr": "Kullanıcı Başına Fiyat (Aylık)",
        "de": "Price per User (Monthly)",
        "fr": "Price per User (Monthly)",
        "es": "Price per User (Monthly)",

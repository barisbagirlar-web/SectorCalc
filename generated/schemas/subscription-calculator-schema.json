      },
      "businessContext_i18n": {
        "en": "Monthly subscription cost per user",
        "tr": "Kullanıcı başına aylık abonelik maliyeti"
      }
    },
    {
      "id": "durationMonths",
      "label": "Subscription Duration (Months)",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Number of months for the subscription period",
      "label_i18n": {
        "en": "Subscription Duration (Months)",
        "tr": "Abonelik Süresi (Ay)",
        "de": "Subscription Duration (Months)",
        "fr": "Subscription Duration (Months)",
        "es": "Subscription Duration (Months)",
        "ar": "Subscription Duration (Months)"
      },
      "businessContext_i18n": {
        "en": "Number of months for the subscription period",
        "tr": "Abonelik dönemi için ay sayısı"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount Percentage",
      "type": "number",
      "unit": "percent",
      "default": 0,
      "businessContext": "Overall discount percentage applied to subtotal",
      "label_i18n": {
        "en": "Discount Percentage",
        "tr": "İndirim Yüzdesi",
        "de": "Discount Percentage",
        "fr": "Discount Percentage",
        "es": "Discount Percentage",
        "ar": "Discount Percentage"
      },
      "businessContext_i18n": {
        "en": "Overall discount percentage applied to subtotal",
        "tr": "Ara toplama uygulanan genel indirim yüzdesi"
      }
    },
    {
      "id": "taxPercent",
      "label": "Tax Rate",
      "type": "number",
      "unit": "percent",
      "default": 18,
      "businessContext": "Tax rate (e.g., VAT) applied after discount",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Vergi Oranı",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Tax rate (e.g., VAT) applied after discount",
        "tr": "İndirimden sonra uygulanan vergi oranı (örn. KDV)"
      }
    }
  ],
  "formulas": {
    "subtotalCost": "numberOfUsers * pricePerUser * durationMonths",
    "discountAmount": "subtotalCost * (discountPercent / 100)",
    "taxAmount": "(subtotalCost - discountAmount) * (taxPercent / 100)",
    "totalCost": "subtotalCost - discountAmount + taxAmount"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "subtotalCost",
      "discountAmount",
      "taxAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "users"
  },

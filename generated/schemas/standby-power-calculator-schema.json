{
  "toolName": "standby-power-calculator",
  "inputs": [
    {
      "id": "deviceCount",
      "label": "Number of Devices",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total count of devices with standby mode.",
      "label_i18n": {
        "en": "Number of Devices",
        "tr": "Number of Devices",
        "de": "Number of Devices",
        "fr": "Number of Devices",
        "es": "Number of Devices",
        "ar": "Number of Devices"
      }
    },
    {
      "id": "standbyPower",
      "label": "Standby Power per Device",
      "type": "number",
      "unit": "W",
      "default": 5,
      "businessContext": "Power consumed per device in standby mode (watts).",
      "label_i18n": {
        "en": "Standby Power per Device",
        "tr": "Standby Power per Device",
        "de": "Standby Power per Device",
        "fr": "Standby Power per Device",
        "es": "Standby Power per Device",
        "ar": "Standby Power per Device"
      }
    },
    {
      "id": "hoursPerDay",
      "label": "Hours in Standby per Day",
      "type": "number",
      "unit": "h/day",
      "default": 20,
      "businessContext": "Average hours per day the device is in standby (not active).",
      "label_i18n": {
        "en": "Hours in Standby per Day",
        "tr": "Hours in Standby per Day",
        "de": "Hours in Standby per Day",
        "fr": "Hours in Standby per Day",
        "es": "Hours in Standby per Day",
        "ar": "Hours in Standby per Day"
      }
    },
    {
      "id": "daysPerMonth",
      "label": "Days per Month",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of days in billing period (typically 30).",
      "label_i18n": {
        "en": "Days per Month",
        "tr": "Days per Month",
        "de": "Days per Month",
        "fr": "Days per Month",
        "es": "Days per Month",
        "ar": "Days per Month"
      }
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost per kilowatt-hour in local currency.",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Electricity Cost",
        "de": "Electricity Cost",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      }
    },
    {
      "id": "co2Factor",
      "label": "CO2 Emission Factor",
      "type": "number",
      "unit": "kg CO2/kWh",
      "default": 0.5,
      "businessContext": "Carbon intensity of grid electricity (kg CO2 per kWh).",
      "label_i18n": {
        "en": "CO2 Emission Factor",
        "tr": "CO2 Emission Factor",
        "de": "CO2 Emission Factor",
        "fr": "CO2 Emission Factor",
        "es": "CO2 Emission Factor",
        "ar": "CO2 Emission Factor"
      }
    }
  ],
  "formulas": {
    "monthlyEnergyKwh": "(deviceCount * standbyPower * hoursPerDay * daysPerMonth) / 1000",
    "monthlyCost": "((deviceCount * standbyPower * hoursPerDay * daysPerMonth) / 1000) * electricityCost",
    "monthlyCO2": "((deviceCount * standbyPower * hoursPerDay * daysPerMonth) / 1000) * co2Factor"
  },
  "outputs": {
    "primary": "monthlyEnergyKwh",
    "breakdown": [
      "monthlyCost",
      "monthlyCO2"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "ecology-environment",
  "sectorSlug": "energy-carbon",
  "categorySlug": "electrical-power-systems",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "energy"
}

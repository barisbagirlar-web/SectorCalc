    {
      "id": "daysPerMonth",
      "label": "Days per Month",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Number of days in billing period (typically 30).",
      "label_i18n": {
        "en": "Days per Month",
        "tr": "Aylık Gün Sayısı",
        "de": "Tage pro Monat",
        "fr": "Days per Month",
        "es": "Days per Month",
        "ar": "Days per Month"
      },
      "businessContext_i18n": {
        "en": "Number of days in billing period (typically 30).",
        "tr": "Fatura dönemindeki gün sayısı (genellikle 30)."
      }
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost per kilowatt-hour in local currency.",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Elektrik Maliyeti",
        "de": "Stromkosten",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      },
      "businessContext_i18n": {
        "en": "Cost per kilowatt-hour in local currency.",
        "tr": "Kilovatsaat başına yerel para birimi cinsinden maliyet."
      }
    },
    {
      "id": "co2Factor",
      "label": "CO2 Emission Factor",
      "type": "number",
      "unit": "kg CO2/kWh",
      "default": 0.5,
      "businessContext": "Carbon intensity of grid electricity (kg CO2 per kWh).",
      "label_i18n": {
        "en": "CO2 Emission Factor",
        "tr": "CO2 Emisyon Faktörü",
        "de": "CO₂-Emissionsfaktor",
        "fr": "CO2 Emission Factor",
        "es": "CO2 Emission Factor",
        "ar": "CO2 Emission Factor"
      },
      "businessContext_i18n": {
        "en": "Carbon intensity of grid electricity (kg CO2 per kWh).",
        "tr": "Şebeke elektriğinin karbon yoğunluğu (kg CO2/kWh)."
      }
    }
  ],
  "formulas": {
    "monthlyEnergyKwh": "(deviceCount * standbyPower * hoursPerDay * daysPerMonth) / 1000",
    "monthlyCost": "((deviceCount * standbyPower * hoursPerDay * daysPerMonth) / 1000) * electricityCost",
    "monthlyCO2": "((deviceCount * standbyPower * hoursPerDay * daysPerMonth) / 1000) * co2Factor"
  },
  "outputs": {
    "primary": "monthlyEnergyKwh",
    "breakdown": [
      "monthlyCost",
      "monthlyCO2"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "monthlyCO2",
    "unit": "kWh"
  },

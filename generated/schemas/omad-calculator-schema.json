{
  "toolName": "omad-calculator",
  "inputs": [
    {
      "id": "plannedTime",
      "label": "Planned Production Time",
      "type": "number",
      "unit": "min",
      "default": 480,
      "businessContext": "Total planned operating time for the machine.",
      "label_i18n": {
        "en": "Planned Production Time",
        "tr": "Planned Production Time",
        "de": "Planned Production Time",
        "fr": "Planned Production Time",
        "es": "Planned Production Time",
        "ar": "Planned Production Time"
      }
    },
    {
      "id": "unplannedDowntime",
      "label": "Unplanned Downtime",
      "type": "number",
      "unit": "min",
      "default": 60,
      "businessContext": "Time lost due to breakdowns or unscheduled stops.",
      "label_i18n": {
        "en": "Unplanned Downtime",
        "tr": "Unplanned Downtime",
        "de": "Unplanned Downtime",
        "fr": "Unplanned Downtime",
        "es": "Unplanned Downtime",
        "ar": "Unplanned Downtime"
      }
    },
    {
      "id": "idealCycleTime",
      "label": "Ideal Cycle Time",
      "type": "number",
      "unit": "min/unit",
      "default": 0.5,
      "businessContext": "Theoretically fastest time to produce one unit.",
      "label_i18n": {
        "en": "Ideal Cycle Time",
        "tr": "Ideal Cycle Time",
        "de": "Ideal Cycle Time",
        "fr": "Ideal Cycle Time",
        "es": "Ideal Cycle Time",
        "ar": "Ideal Cycle Time"
      }
    },
    {
      "id": "totalUnits",
      "label": "Total Units Produced",
      "type": "number",
      "unit": "units",
      "default": 800,
      "businessContext": "Total output including defective units during planned time.",
      "label_i18n": {
        "en": "Total Units Produced",
        "tr": "Total Units Produced",
        "de": "Total Units Produced",
        "fr": "Total Units Produced",
        "es": "Total Units Produced",
        "ar": "Total Units Produced"
      }
    },
    {
      "id": "defectiveUnits",
      "label": "Defective Units",
      "type": "number",
      "unit": "units",
      "default": 40,
      "businessContext": "Units that do not meet quality standards.",
      "label_i18n": {
        "en": "Defective Units",
        "tr": "Defective Units",
        "de": "Defective Units",
        "fr": "Defective Units",
        "es": "Defective Units",
        "ar": "Defective Units"
      }
    }
  ],
  "formulas": {
    "availability": "(plannedTime - unplannedDowntime) / plannedTime",
    "performance": "(idealCycleTime * totalUnits) / (plannedTime - unplannedDowntime)",
    "quality": "(totalUnits - defectiveUnits) / totalUnits",
    "oee": "((plannedTime - unplannedDowntime) / plannedTime) * ((idealCycleTime * totalUnits) / (plannedTime - unplannedDowntime)) * ((totalUnits - defectiveUnits) / totalUnits)"
  },
  "outputs": {
    "primary": "oee",
    "breakdown": [
      "availability",
      "performance",
      "quality"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "oee",
    "unit": "min",
    "breakdownUnits": {
      "availability": "%"
    }
  },
  "category": "Kalite & Süreç Kontrol",
  "sector": "Makine & Üretim",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "makine",
  "profession": "CNC Operatörü",
  "categoryId": "quality",

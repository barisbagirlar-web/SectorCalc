        "ar": "إجمالي الوقت بالدقائق"
      }
    },
    {
      "id": "timeSeconds",
      "label": "Time (seconds)",
      "type": "number",
      "unit": "seconds",
      "default": 0,
      "businessContext": "Additional seconds component of total time",
      "label_i18n": {
        "en": "Time (seconds)",
        "tr": "Süre (saniye)",
        "de": "Zeit (Sekunden)",
        "fr": "Temps (secondes)",
        "es": "Tiempo (segundos)",
        "ar": "الوقت (ثوانٍ)"
      },
      "businessContext_i18n": {
        "en": "Additional seconds component of total time",
        "tr": "Toplam sürenin ek saniye bileşeni",
        "de": "Zusätzliche Sekundenkomponente der Gesamtzeit",

        "ar": "المكون الإضافي للثواني من الوقت الإجمالي"
      }
    },
    {
      "id": "poolLength",
      "label": "Pool Length",
      "type": "number",
      "unit": "meters",
      "default": 25,
      "businessContext": "Length of the swimming pool in meters",
      "label_i18n": {
        "en": "Pool Length",
        "tr": "Havuz Uzunluğu",
        "de": "Beckenlänge",
        "fr": "Longueur du bassin",
        "es": "Largo de la piscina",
        "ar": "طول المسبح"
      },
      "businessContext_i18n": {
        "en": "Length of the swimming pool in meters",
        "tr": "Yüzme havuzunun metre cinsinden uzunluğu",
        "de": "Länge des Schwimmbeckens in Metern",
        "fr": "Longueur de la piscine en mètres",
        "es": "Longitud de la piscina en metros",
        "ar": "طول حوض السباحة بالأمتار"
      }
    }
  ],
  "formulas": {
    "totalTimeSeconds": "timeMinutes * 60 + timeSeconds",
    "pacePer100m": "totalTimeSeconds / (distance / 100)",
    "pacePerLap": "totalTimeSeconds / (distance / poolLength)",
    "speedMps": "distance / totalTimeSeconds",
    "speedKmph": "speedMps * 3.6"
  },
  "outputs": {
    "primary": "pacePer100m",
    "breakdown": [
      "Pace per 100m: {pacePer100m} seconds",
      "Pace per lap: {pacePerLap} seconds",
      "Speed: {speedKmph} km/h"
    ],

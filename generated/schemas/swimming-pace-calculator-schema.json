{
  "toolName": "swimming-pace-calculator",
  "inputs": [
    {
      "id": "distance",
      "label": "Distance",
      "type": "number",
      "unit": "meters",
      "default": 100,
      "businessContext": "Total distance swum in meters",
      "label_i18n": {
        "en": "Distance",
        "tr": "Mesafe",
        "de": "Entfernung",
        "fr": "Distance",
        "es": "Distance",
        "ar": "Distance"
      },
      "businessContext_i18n": {
        "en": "Total distance swum in meters",
        "tr": "Metre cinsinden yüzülen toplam mesafe"
      }
    },
    {
      "id": "timeMinutes",
      "label": "Time (minutes)",
      "type": "number",
      "unit": "minutes",
      "default": 2,
      "businessContext": "Total time in minutes",
      "label_i18n": {
        "en": "Time (minutes)",
        "tr": "Süre (dakika)",
        "de": "Zeit (Minuten)",
        "fr": "Time (minutes)",
        "es": "Time (minutes)",
        "ar": "Time (minutes)"
      },
      "businessContext_i18n": {
        "en": "Total time in minutes",
        "tr": "Dakika cinsinden toplam süre"
      }
    },
    {
      "id": "timeSeconds",
      "label": "Time (seconds)",
      "type": "number",
      "unit": "seconds",
      "default": 0,
      "businessContext": "Additional seconds component of total time",
      "label_i18n": {
        "en": "Time (seconds)",
        "tr": "Süre (saniye)",
        "de": "Zeit (Sekunden)",
        "fr": "Time (seconds)",
        "es": "Time (seconds)",
        "ar": "Time (seconds)"
      },
      "businessContext_i18n": {
        "en": "Additional seconds component of total time",
        "tr": "Toplam sürenin ek saniye bileşeni"
      }
    },
    {
      "id": "poolLength",
      "label": "Pool Length",
      "type": "number",
      "unit": "meters",
      "default": 25,
      "businessContext": "Length of the swimming pool in meters",
      "label_i18n": {
        "en": "Pool Length",
        "tr": "Havuz Uzunluğu",
        "de": "Pool Length",
        "fr": "Pool Length",
        "es": "Pool Length",
        "ar": "Pool Length"
      },
      "businessContext_i18n": {
        "en": "Length of the swimming pool in meters",
        "tr": "Yüzme havuzunun metre cinsinden uzunluğu"
      }
    }
  ],
  "formulas": {
    "totalTimeSeconds": "timeMinutes * 60 + timeSeconds",
    "pacePer100m": "totalTimeSeconds / (distance / 100)",
    "pacePerLap": "totalTimeSeconds / (distance / poolLength)",
    "speedMps": "distance / totalTimeSeconds",
    "speedKmph": "speedMps * 3.6"
  },
  "outputs": {
    "primary": "pacePer100m",
    "breakdown": [
      "Pace per 100m: {pacePer100m} seconds",
      "Pace per lap: {pacePerLap} seconds",
      "Speed: {speedKmph} km/h"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "speedKmph",
    "unit": "meters"
  },

        "fr": "Dead Load",
        "es": "Dead Load",
        "ar": "Dead Load"
      }
    },
    {
      "id": "fb",
      "label": "Bending Design Value (Fb)",
      "type": "number",
      "unit": "psi",
      "default": 1000,
      "businessContext": "Allowable bending stress for the lumber species and grade (e.g., #2 Douglas Fir-Larch = 900-1000 psi).",
      "label_i18n": {
        "en": "Bending Design Value (Fb)",
        "tr": "Bending Design Value (Fb)",
        "de": "Bending Design Value (Fb)",
        "fr": "Bending Design Value (Fb)",
        "es": "Bending Design Value (Fb)",
        "ar": "Bending Design Value (Fb)"
      }
    }
  ],
  "formulas": {
    "total_load_plf": "(live_load + dead_load) * spacing / 12",
    "section_modulus": "(joist_width * joist_depth ** 2) / 6",
    "max_bending_moment_lb_in": "fb * section_modulus",
    "w_pli": "total_load_plf / 12"
  },
  "outputs": {
    "primary": "w_pli",
    "breakdown": [
      "total_load_plf",
      "section_modulus",
      "max_bending_moment_lb_in",
      "max_span_in"

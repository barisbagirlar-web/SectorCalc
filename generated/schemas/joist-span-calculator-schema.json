      }
    },
    {
      "id": "dead_load",
      "label": "Dead Load",
      "type": "number",
      "unit": "psf",
      "default": 10,
      "businessContext": "Superimposed dead load in pounds per square foot (e.g., flooring, ceiling = 10 psf).",
      "label_i18n": {
        "en": "Dead Load",

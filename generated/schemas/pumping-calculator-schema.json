{
  "toolName": "pumping-calculator",
  "inputs": [
    {
      "id": "flowRate",
      "label": "Flow Rate",
      "type": "number",
      "unit": "m³/h",
      "default": 100,
      "businessContext": "Volumetric flow rate of the fluid being pumped",
      "label_i18n": {
        "en": "Flow Rate",
        "tr": "Flow Rate",
        "de": "Flow Rate",
        "fr": "Flow Rate",
        "es": "Flow Rate",
        "ar": "Flow Rate"
      }
    },
    {
      "id": "head",
      "label": "Head",
      "type": "number",
      "unit": "m",
      "default": 20,
      "businessContext": "Total dynamic head the pump must overcome",
      "label_i18n": {
        "en": "Head",
        "tr": "Head",
        "de": "Head",
        "fr": "Head",
        "es": "Head",
        "ar": "Head"
      }
    },
    {
      "id": "fluidDensity",
      "label": "Fluid Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1000,
      "businessContext": "Density of the fluid (water = 1000 kg/m³)",
      "label_i18n": {
        "en": "Fluid Density",
        "tr": "Fluid Density",
        "de": "Fluid Density",
        "fr": "Fluid Density",
        "es": "Fluid Density",
        "ar": "Fluid Density"
      }
    },
    {
      "id": "pumpEfficiency",
      "label": "Pump Efficiency",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "Efficiency of the pump (0-100%)",
      "label_i18n": {
        "en": "Pump Efficiency",
        "tr": "Pump Efficiency",
        "de": "Pump Efficiency",
        "fr": "Pump Efficiency",
        "es": "Pump Efficiency",
        "ar": "Pump Efficiency"
      }
    },
    {
      "id": "motorEfficiency",
      "label": "Motor Efficiency",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Efficiency of the electric motor driving the pump (0-100%)",
      "label_i18n": {
        "en": "Motor Efficiency",
        "tr": "Motor Efficiency",
        "de": "Motor Efficiency",
        "fr": "Motor Efficiency",
        "es": "Motor Efficiency",
        "ar": "Motor Efficiency"
      }
    },
    {
      "id": "operatingHours",
      "label": "Operating Hours",
      "type": "number",
      "unit": "hours/day",
      "default": 8,
      "businessContext": "Daily operating hours of the pump",
      "label_i18n": {
        "en": "Operating Hours",
        "tr": "Operating Hours",
        "de": "Operating Hours",
        "fr": "Operating Hours",
        "es": "Operating Hours",
        "ar": "Operating Hours"
      }
    }
  ],
  "formulas": {
    "hydraulicPower": "(flowRate * head * fluidDensity * 9.81) / 3600000",
    "shaftPower": "(flowRate * head * fluidDensity * 9.81) / (3600000 * (pumpEfficiency / 100))",
    "motorPower": "(flowRate * head * fluidDensity * 9.81) / (3600000 * (pumpEfficiency / 100) * (motorEfficiency / 100))",
    "dailyEnergyConsumption": "(flowRate * head * fluidDensity * 9.81 * operatingHours) / (3600000 * (pumpEfficiency / 100) * (motorEfficiency / 100))"
  },
  "outputs": {
    "primary": "motorPower",
    "breakdown": [
      "hydraulicPower",
      "shaftPower",
      "dailyEnergyConsumption"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dailyEnergyConsumption"
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Fizik & Mekanik",
  "premiumRequired": false,

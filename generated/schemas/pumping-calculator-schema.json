      "default": 8,
      "businessContext": "Daily operating hours of the pump",
      "label_i18n": {
        "en": "Operating Hours",
        "tr": "Çalışma Saatleri",
        "de": "Betriebsstunden",
        "fr": "Heures de fonctionnement",

      }
    },
    {
      "id": "closingCosts",
      "label": "Closing Costs",
      "type": "number",
      "unit": "$",
      "default": 5000,
      "businessContext": "Additional acquisition costs (taxes, legal fees, commissions)",
      "label_i18n": {
        "en": "Closing Costs",
        "tr": "Kapanış Maliyetleri",
        "de": "Closing Costs",
        "fr": "Closing Costs",

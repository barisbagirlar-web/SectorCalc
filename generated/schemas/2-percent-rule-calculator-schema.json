        "tr": "Ek edinim maliyetleri (vergiler, yasal ücretler, komisyonlar)"
      }
    },
    {
      "id": "monthlyRent",
      "label": "Monthly Rent",
      "type": "number",
      "unit": "$",
      "default": 2000,
      "businessContext": "Expected gross monthly rental income",
      "label_i18n": {
        "en": "Monthly Rent",
        "tr": "Aylık Kira",
        "de": "Monthly Rent",
        "fr": "Monthly Rent",
        "es": "Monthly Rent",
        "ar": "Monthly Rent"
      },
      "businessContext_i18n": {
        "en": "Expected gross monthly rental income",
        "tr": "Beklenen brüt aylık kira geliri"
      }
    },
    {
      "id": "targetPercent",
      "label": "Target Percentage",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Threshold for the 2% rule (typically 2%)",
      "label_i18n": {
        "en": "Target Percentage",
        "tr": "Hedef Yüzde",
        "de": "Target Percentage",
        "fr": "Target Percentage",
        "es": "Target Percentage",
        "ar": "Target Percentage"
      },
      "businessContext_i18n": {
        "en": "Threshold for the 2% rule (typically 2%)",
        "tr": "%2 kuralı için eşik (genellikle %2)"
      }
    }
  ],
  "formulas": {
    "meetsRule": "(monthlyRent / (propertyPrice + closingCosts)) * 100 >= targetPercent",
    "actualPercent": "(monthlyRent / (propertyPrice + closingCosts)) * 100",
    "requiredRent": "(propertyPrice + closingCosts) * targetPercent / 100",
    "maxPrice": "(monthlyRent / (targetPercent / 100)) - closingCosts"
  },
  "outputs": {
    "primary": "meetsRule",
    "breakdown": [
      "actualPercent",
      "requiredRent",
      "maxPrice"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "maxPrice",
    "unit": "$",
    "breakdownUnits": {
      "actualPercent": "%"
    }
  },

      "label_i18n": {
        "en": "Target Percentage",
        "tr": "Hedef Yüzde",
        "de": "Zielprozentsatz",
        "fr": "Pourcentage cible",
        "es": "Porcentaje objetivo",
        "ar": "النسبة المئوية المستهدفة"
      },
      "businessContext_i18n": {
        "en": "Threshold for the 2% rule (typically 2%)",
        "tr": "%2 kuralı için eşik (genellikle %2)",
        "de": "Schwellenwert für die 2%-Regel (typischerweise 2%)",
        "fr": "Seuil pour la règle des 2 % (généralement 2 %)",

    {
      "id": "calorieAdjustment",
      "label": "Calorie Adjustment",
      "type": "number",
      "unit": "kcal",
      "default": 0,
      "businessContext": "Daily calorie surplus or deficit target (e.g., -500 for fat loss)",
      "label_i18n": {
        "en": "Calorie Adjustment",
        "tr": "Kalori Ayarı",
        "de": "Calorie Adjustment",
        "fr": "Calorie Adjustment",
        "es": "Calorie Adjustment",
        "ar": "Calorie Adjustment"
      },
      "businessContext_i18n": {
        "en": "Daily calorie surplus or deficit target (e.g., -500 for fat loss)",
        "tr": "Günlük kalori fazlası veya açığı hedefi (örneğin, yağ kaybı için -500)"
      }
    }
  ],
  "formulas": {
    "bmr": "10*weight + 6.25*height - 5*age + (gender === 0 ? -161 : 5)",
    "tdee": "bmr * activityFactor",
    "adjustedCalories": "tdee + calorieAdjustment",
    "fat": "adjustedCalories * 0.7 / 9",
    "protein": "adjustedCalories * 0.25 / 4",
    "carbs": "adjustedCalories * 0.05 / 4"
  },
  "outputs": {
    "primary": "adjustedCalories",
    "breakdown": [
      "fat",
      "protein",
      "carbs"
    ],

{
  "toolName": "smed-setup-time-calculator",
  "catalogCategory": "manufacturing-workshop",
  "categorySlug": "lean-production",
  "sector": "Industrial Engineering",
  "sectorId": "lean-production",
  "inputs": [
    {
      "id": "icAyar",
      "label": "Internal Setup (Min)",
      "type": "number",
      "unit": "min",
      "default": 60,
      "min": 0,
      "businessContext": "Setup done while machine stopped."
    },
    {
      "id": "disAyar",
      "label": "External Setup (Min)",
      "type": "number",
      "unit": "min",
      "default": 15,
      "min": 0,
      "businessContext": "Setup done while machine runs."
    },
    {
      "id": "donusum",
      "label": "Conversion Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "min": 0,
      "max": 100,
      "businessContext": "Percentage of internal converted to external."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "hedefInner": "icAyar * (1 - donusum / 100)",
    "result": "(icAyar * (1 - donusum / 100)) + disAyar"
  },
  "outputs": {
    "primary": "result",
    "unit": "min",
    "breakdown": {
      "result": "Ymosti Setup Time"
    },
    "breakdownUnits": {
      "result": "min"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Conduct regular OEE audits for improvement.",
      "Use SMED to reduce setup times."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate reduced setup time by converting internal to external SMED adjustments.",
      "long": "Calculate reduced setup time by converting internal to external SMED adjustments."
    }
  },
  "sectorSlug": "cnc-manufacturing"
}

{
  "toolName": "seed-rate-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "agriculture-food-beverage",
  "sector": "Agriculture, Maritime and Drilling",
  "sectorId": "agriculture-food-beverage",
  "inputs": [
    {
      "id": "siraAraligi",
      "label": "Row Spacing (m)",
      "type": "number",
      "unit": "m",
      "default": 0.7,
      "min": 0,
      "businessContext": "Distance between rows."
    },
    {
      "id": "uzeriMesafe",
      "label": "In-Row Spacing (m)",
      "type": "number",
      "unit": "m",
      "default": 0.2,
      "min": 0,
      "businessContext": "Distance between plants."
    },
    {
      "id": "binTaneAgirlik",
      "label": "Thousand Grain Weight (g)",
      "type": "number",
      "unit": "g",
      "default": 350,
      "min": 0,
      "businessContext": "Weight of 1000 seeds."
    },
    {
      "id": "cimlenme",
      "label": "Germination Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "min": 0,
      "businessContext": "Germination percentage."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(10000 / Math.max(0.0001, (siraAraligi * uzeriMesafe))) * (binTaneAgirlik / 1000) / Math.max(0.0001, (cimlenme / 100))"
  },
  "outputs": {
    "primary": "result",
    "unit": "kg/da",
    "breakdown": {
      "result": "Tohum Ihtiyaci"
    },
    "breakdownUnits": {
      "result": "kg/da"
    },
    "hiddenLossDrivers": [
      "Low efficiency may indicate equipment or process issues."
    ],
    "suggestedActions": [
      "Calibrate all measuring equipment regularly.",
      "Use site-specific data when available."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate seed rate per decare (kg/da) for planting.",
      "long": "Calculate seed rate per decare (kg/da) for planting."
    }
  },
  "sectorSlug": "daily-renovation"
}

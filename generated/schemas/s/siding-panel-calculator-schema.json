{
  "toolName": "siding-panel-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Facade Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 100,
      "min": 0,
      "businessContext": "Facade surface area."
    },
    {
      "id": "panelEn",
      "label": "Panel Width (m)",
      "type": "number",
      "unit": "m",
      "default": 0.3,
      "min": 0,
      "businessContext": "Siding panel width."
    },
    {
      "id": "panelBoy",
      "label": "Panel Length (m)",
      "type": "number",
      "unit": "m",
      "default": 3,
      "min": 0,
      "businessContext": "Panel length."
    },
    {
      "id": "scrap",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Cutting waste."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.ceil((area * (1 + scrap / 100)) / Math.max(0.0001, (panelEn * panelBoy)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "panels",
    "breakdown": {
      "result": "Gerekli Panel Count"
    },
    "breakdownUnits": {
      "result": "panels"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate exterior siding panel count needed.",
      "long": "Calculate exterior siding panel count needed."
    }
  },
  "sectorSlug": "daily-renovation"
}

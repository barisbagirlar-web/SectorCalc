{
  "toolName": "ship-draft-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "agriculture-food-beverage",
  "sector": "Agriculture, Maritime and Drilling",
  "sectorId": "agriculture-food-beverage",
  "inputs": [
    {
      "id": "deplasman",
      "label": "Displacement (tons)",
      "type": "number",
      "unit": "tons",
      "default": 5000,
      "min": 0,
      "businessContext": "Ship total weight."
    },
    {
      "id": "suYogunlugu",
      "label": "Water Density (t/m³)",
      "type": "number",
      "unit": "t/m3",
      "default": 1.025,
      "min": 0,
      "businessContext": "Seawater density."
    },
    {
      "id": "boy",
      "label": "Ship Length (m)",
      "type": "number",
      "unit": "m",
      "default": 100,
      "min": 0,
      "businessContext": "Ship length."
    },
    {
      "id": "en",
      "label": "Ship Beam (m)",
      "type": "number",
      "unit": "m",
      "default": 18,
      "min": 0,
      "businessContext": "Ship breadth."
    },
    {
      "id": "blokKatsayi",
      "label": "Block Coefficient",
      "type": "number",
      "unit": "scalar",
      "default": 0.7,
      "min": 0,
      "businessContext": "Ship hull form coefficient."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "deplasman / Math.max(0.0001, (suYogunlugu * length * en * blokKatsayi))"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Draft (Draft)"
    },
    "breakdownUnits": {
      "result": "m"
    },
    "hiddenLossDrivers": [
      "Low efficiency may indicate equipment or process issues."
    ],
    "suggestedActions": [
      "Calibrate all measuring equipment regularly.",
      "Use site-specific data when available."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate ship draft (vertical depth below waterline).",
      "long": "Calculate ship draft (vertical depth below waterline)."
    }
  },
  "sectorSlug": "daily-renovation"

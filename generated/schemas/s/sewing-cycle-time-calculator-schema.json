{
  "toolName": "sewing-cycle-time-calculator",
  "catalogCategory": "manufacturing-workshop",
  "categorySlug": "textile-print-lab",
  "sector": "Tekstil, Gida ve Plastik",
  "sectorId": "textile-print-lab",
  "inputs": [
    {
      "id": "dikisUzunluk",
      "label": "Seam Length (mm)",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "min": 0,
      "businessContext": "Seam length."
    },
    {
      "id": "devirSayisi",
      "label": "Machine Speed (stitches/min)",
      "type": "number",
      "unit": "spm",
      "default": 4000,
      "min": 0,
      "businessContext": "Sewing machine speed."
    },
    {
      "id": "dikisSikligi",
      "label": "Stitch Density (stitches/mm)",
      "type": "number",
      "unit": "per_mm",
      "default": 3,
      "min": 0,
      "businessContext": "Stitches per mm."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(dikisUzunluk * dikisSikligi) / Math.max(0.0001, (devirSayisi / 60))"
  },
  "outputs": {
    "primary": "result",
    "unit": "s",
    "breakdown": {
      "result": "Sewing Time"
    },
    "breakdownUnits": {
      "result": "s"
    },
    "hiddenLossDrivers": [
      "Waste in material or time indicates process improvement opportunity."
    ],
    "suggestedActions": [
      "Optimize drying/cooling parameters for cycle time reduction.",
      "Monitor defects and adjust process conditions accordingly."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,

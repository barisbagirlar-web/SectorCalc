{
  "toolName": "simply-supported-beam-deflection-calculator",
  "catalogCategory": "construction-measurement",
  "categorySlug": "mechanical-hvac-energy-loss",
  "sector": "Mechanical Engineering",
  "sectorId": "mechanical-hvac-energy-loss",
  "inputs": [
    {
      "id": "load",
      "label": "Uniform Load (N/m)",
      "type": "number",
      "unit": "N/m",
      "default": 5000,
      "min": 0,
      "businessContext": "Load per unit length."
    },
    {
      "id": "length",
      "label": "Span (m)",
      "type": "number",
      "unit": "m",
      "default": 5,
      "min": 0,
      "businessContext": "Beam span between supports."
    },
    {
      "id": "elastisiteModulu",
      "label": "Young's Modulus (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 200000000000,
      "min": 0,
      "businessContext": "Material modulus."
    },
    {
      "id": "ataletMomenti",
      "label": "Moment of Inertia (m⁴)",
      "type": "number",
      "unit": "m4",
      "default": 0.0000083,
      "min": 0,
      "businessContext": "Section moment of inertia."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(5 * load * Math.pow(length, 4)) / Math.max(0.0001, (384 * elastisiteModulu * ataletMomenti))"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Maksimum Sehim"
    },
    "breakdownUnits": {
      "result": "m"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify calculations with FEA or physical testing.",
      "Use appropriate safety factors for design."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate maximum deflection of a simply supported beam under uniform load.",
      "long": "Calculate maximum deflection of a simply supported beam under uniform load."
    }
  },
  "sectorSlug": "construction"
}

  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "alis",
      "label": "Buy Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "min": 0,
      "businessContext": "Purchase price per share."
    },
    {
      "id": "satis",
      "label": "Sell Price (USD)",
      "type": "number",
      "unit": "USD",
      "default": 75,
      "min": 0,
      "businessContext": "Sale price per share."
    },
    {
      "id": "temettu",
      "label": "Dividends Received (USD)",
      "type": "number",
      "unit": "USD",
      "default": 5,
      "min": 0,
      "businessContext": "Dividends received during holding period."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "((satis - alis) + temettu) / Math.max(1, alis) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "Total Stock Return"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],

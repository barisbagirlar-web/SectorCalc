      "type": "number",
      "unit": "m3",
      "default": 0.5,
      "min": 0,
      "businessContext": "Package volume."
    },
    {
      "id": "mesafe",
      "label": "Distance (km)",
      "type": "number",
      "unit": "km",
      "default": 1000,
      "min": 0,
      "businessContext": "Transport distance."
    },
    {

{
  "toolName": "tweak-calculator",
  "inputs": [
    {
      "id": "currentValue",
      "label": "Current Parameter Value",
      "type": "number",
      "unit": "units",
      "default": 100,
      "businessContext": "Measured current value of the parameter to be adjusted (e.g., pressure, speed, temperature).",
      "label_i18n": {
        "en": "Current Parameter Value",
        "tr": "Current Parameter Value",
        "de": "Current Parameter Value",
        "fr": "Current Parameter Value",
        "es": "Current Parameter Value",
        "ar": "Current Parameter Value"
      }
    },
    {
      "id": "targetValue",
      "label": "Target Value",
      "type": "number",
      "unit": "units",
      "default": 120,
      "businessContext": "Desired target value for the parameter after adjustment.",
      "label_i18n": {
        "en": "Target Value",
        "tr": "Target Value",
        "de": "Target Value",
        "fr": "Target Value",
        "es": "Target Value",
        "ar": "Target Value"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency Factor",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Current process efficiency affecting the parameter response (0-100).",
      "label_i18n": {
        "en": "Efficiency Factor",
        "tr": "Efficiency Factor",
        "de": "Efficiency Factor",
        "fr": "Efficiency Factor",
        "es": "Efficiency Factor",
        "ar": "Efficiency Factor"
      }
    },
    {
      "id": "safetyFactor",
      "label": "Safety Margin",
      "type": "number",
      "unit": "%",
      "default": 110,
      "businessContext": "Safety factor applied to the adjustment to prevent overshoot (typically >=100).",
      "label_i18n": {
        "en": "Safety Margin",
        "tr": "Safety Margin",
        "de": "Safety Margin",
        "fr": "Safety Margin",
        "es": "Safety Margin",
        "ar": "Safety Margin"
      }
    },
    {
      "id": "tolerance",
      "label": "Adjustment Tolerance",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Maximum permissible tweak percentage variation before issuing a warning.",
      "label_i18n": {
        "en": "Adjustment Tolerance",
        "tr": "Adjustment Tolerance",
        "de": "Adjustment Tolerance",
        "fr": "Adjustment Tolerance",
        "es": "Adjustment Tolerance",
        "ar": "Adjustment Tolerance"
      }
    }
  ],
  "formulas": {
    "rawTweakPercent": "((targetValue - currentValue) / currentValue) * 100",
    "efficiencyAdjustedTweakPercent": "((targetValue - currentValue) / currentValue) * 100 / (efficiency / 100)",
    "recommendedTweakPercent": "((targetValue - currentValue) / currentValue) * 100 * safetyFactor / efficiency",
    "finalParameterValue": "currentValue * (1 + ((targetValue - currentValue) / currentValue) * safetyFactor / efficiency)"
  },
  "outputs": {
    "primary": "recommendedTweakPercent",
    "breakdown": [
      "rawTweakPercent",
      "efficiencyAdjustedTweakPercent",
      "finalParameterValue",
      "withinTolerance"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "withinTolerance"
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "electrical-power-systems",
  "sectorId": "gida",
  "profession": "Üretim Mühendisi",
  "categoryId": "conversion",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

  "formulas": {
    "keplerThirdLaw": "Math.sqrt(semiMajorAxis**3 / massCentralBody)",
    "orbitalPeriodFromSemiMajorAxis": "Math.sqrt(semiMajorAxis**3 / massCentralBody)",
    "semiMajorAxisFromPeriod": "(orbitalPeriod**2 * massCentralBody)**(1/3)",
    "eccentricityFromDistances": "(distanceAtAphelion - distanceAtPerihelion) / (distanceAtAphelion + distanceAtPerihelion)",
    "areaSweptPerTime": "0.5 * Math.sqrt(massCentralBody * semiMajorAxis * (1 - eccentricity**2))"
  },

      "id": "conversionFactor",
      "label": "Conversion Factor",
      "type": "number",
      "unit": "unitless",
      "default": 0.0555,
      "businessContext": "Conversion constant from mg/dL to mmol/L used in laboratory reporting",
      "label_i18n": {
        "en": "Conversion Factor",
        "tr": "Conversion Factor",
        "de": "Conversion Factor",
        "fr": "Conversion Factor",

      "label": "Time Since Last Meal",
      "type": "number",
      "unit": "hours",
      "default": 2,
      "businessContext": "Time elapsed since last meal to adjust for postprandial variation",
      "label_i18n": {
        "en": "Time Since Last Meal",
        "tr": "Time Since Last Meal",
        "de": "Time Since Last Meal",
        "fr": "Time Since Last Meal",
        "es": "Time Since Last Meal",
        "ar": "Time Since Last Meal"
      }
    },
    {
      "id": "targetLow",
      "label": "Target Low Glucose",
      "type": "number",
      "unit": "mg/dL",
      "default": 70,
      "businessContext": "Lower therapeutic target for glucose level in gestational diabetes",
      "label_i18n": {
        "en": "Target Low Glucose",
        "tr": "Target Low Glucose",
        "de": "Target Low Glucose",
        "fr": "Target Low Glucose",
        "es": "Target Low Glucose",
        "ar": "Target Low Glucose"
      }
    },
    {
      "id": "targetHigh",
      "label": "Target High Glucose",
      "type": "number",
      "unit": "mg/dL",
      "default": 140,
      "businessContext": "Upper therapeutic target for glucose level in gestational diabetes",
      "label_i18n": {
        "en": "Target High Glucose",
        "tr": "Target High Glucose",
        "de": "Target High Glucose",
        "fr": "Target High Glucose",
        "es": "Target High Glucose",
        "ar": "Target High Glucose"
      }
    }
  ],
  "formulas": {
    "glucoseScore": "(bloodGlucose - targetLow) / (targetHigh - targetLow)",
    "glucoseMmol": "bloodGlucose * conversionFactor"
  },
  "outputs": {
    "primary": "glucoseScore",
    "breakdown": [

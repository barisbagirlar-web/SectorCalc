{
  "toolName": "landfill-calculator",
  "inputs": [
    {
      "id": "dailyWaste",
      "label": "Daily Waste Quantity",
      "type": "number",
      "unit": "ton/day",
      "default": 1000,
      "businessContext": "Average daily waste received at the landfill",
      "label_i18n": {
        "en": "Daily Waste Quantity",
        "tr": "Daily Waste Quantity",
        "de": "Daily Waste Quantity",
        "fr": "Daily Waste Quantity",
        "es": "Daily Waste Quantity",
        "ar": "Daily Waste Quantity"
      }
    },
    {
      "id": "compactionDensity",
      "label": "Compacted Density",
      "type": "number",
      "unit": "ton/m³",
      "default": 0.8,
      "businessContext": "In-place density of waste after compaction",
      "label_i18n": {
        "en": "Compacted Density",
        "tr": "Compacted Density",
        "de": "Compacted Density",
        "fr": "Compacted Density",
        "es": "Compacted Density",
        "ar": "Compacted Density"
      }
    },
    {
      "id": "coverRatio",
      "label": "Cover to Waste Ratio",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Additional volume for daily and intermediate cover as percentage of waste volume",
      "label_i18n": {
        "en": "Cover to Waste Ratio",
        "tr": "Cover to Waste Ratio",
        "de": "Cover to Waste Ratio",
        "fr": "Cover to Waste Ratio",
        "es": "Cover to Waste Ratio",
        "ar": "Cover to Waste Ratio"
      }
    },
    {
      "id": "lifespanYears",
      "label": "Landfill Lifespan",
      "type": "number",
      "unit": "years",
      "default": 20,
      "businessContext": "Design operational life of the landfill",
      "label_i18n": {
        "en": "Landfill Lifespan",
        "tr": "Landfill Lifespan",
        "de": "Landfill Lifespan",
        "fr": "Landfill Lifespan",
        "es": "Landfill Lifespan",
        "ar": "Landfill Lifespan"
      }
    },
    {
      "id": "existingVolume",
      "label": "Already Filled Volume",
      "type": "number",
      "unit": "m³",
      "default": 500000,
      "businessContext": "Airspace already consumed by waste and cover",
      "label_i18n": {
        "en": "Already Filled Volume",
        "tr": "Already Filled Volume",
        "de": "Already Filled Volume",
        "fr": "Already Filled Volume",
        "es": "Already Filled Volume",
        "ar": "Already Filled Volume"
      }
    },
    {
      "id": "availableArea",
      "label": "Available Footprint Area",
      "type": "number",
      "unit": "m²",
      "default": 200000,
      "businessContext": "Plan area available for landfilling",
      "label_i18n": {
        "en": "Available Footprint Area",
        "tr": "Available Footprint Area",
        "de": "Available Footprint Area",
        "fr": "Available Footprint Area",
        "es": "Available Footprint Area",
        "ar": "Available Footprint Area"
      }
    }
  ],
  "formulas": {
    "wasteMass": "dailyWaste * 365 * lifespanYears",
    "wasteVolume": "wasteMass / compactionDensity",
    "totalVolume": "wasteVolume * (1 + coverRatio / 100)",
    "remainingCapacity": "totalVolume - existingVolume",
    "landfillHeight": "totalVolume / availableArea"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "remainingCapacity",
      "landfillHeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "landfillHeight"
  },

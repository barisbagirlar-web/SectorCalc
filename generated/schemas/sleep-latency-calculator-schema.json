{
  "toolName": "sleep-latency-calculator",
  "inputs": [
    {
      "id": "lightsOutTime",
      "label": "Lights Out Time (decimal hours)",
      "type": "number",
      "unit": "decimal hours",
      "default": 22.5,
      "businessContext": "Time when worker turns off lights and attempts to sleep (e.g., 22.5 for 22:30)",
      "label_i18n": {
        "en": "Lights Out Time (decimal hours)",
        "tr": "Lights Out Time (decimal hours)",
        "de": "Lights Out Time (decimal hours)",
        "fr": "Lights Out Time (decimal hours)",
        "es": "Lights Out Time (decimal hours)",
        "ar": "Lights Out Time (decimal hours)"
      }
    },
    {
      "id": "age",
      "label": "Worker Age",
      "type": "number",
      "unit": "years",
      "default": 35,
      "businessContext": "Worker's age in years; older age may increase sleep latency",
      "label_i18n": {
        "en": "Worker Age",
        "tr": "Worker Age",
        "de": "Worker Age",
        "fr": "Worker Age",
        "es": "Worker Age",
        "ar": "Worker Age"
      }
    },
    {
      "id": "caffeineIntake",
      "label": "Caffeine Intake Before Bed",
      "type": "number",
      "unit": "mg",
      "default": 150,
      "businessContext": "Total caffeine consumed in mg within 6 hours before bedtime",
      "label_i18n": {
        "en": "Caffeine Intake Before Bed",
        "tr": "Caffeine Intake Before Bed",
        "de": "Caffeine Intake Before Bed",
        "fr": "Caffeine Intake Before Bed",
        "es": "Caffeine Intake Before Bed",
        "ar": "Caffeine Intake Before Bed"
      }
    },
    {
      "id": "screenTime",
      "label": "Screen Time Before Bed",
      "type": "number",
      "unit": "minutes",
      "default": 60,
      "businessContext": "Minutes spent on screens (phone, TV, computer) before lights out",
      "label_i18n": {
        "en": "Screen Time Before Bed",
        "tr": "Screen Time Before Bed",
        "de": "Screen Time Before Bed",
        "fr": "Screen Time Before Bed",
        "es": "Screen Time Before Bed",
        "ar": "Screen Time Before Bed"
      }
    },
    {
      "id": "roomTemperature",
      "label": "Room Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Bedroom temperature in degrees Celsius; optimal is around 20°C",
      "label_i18n": {
        "en": "Room Temperature",
        "tr": "Room Temperature",
        "de": "Room Temperature",
        "fr": "Room Temperature",
        "es": "Room Temperature",
        "ar": "Room Temperature"
      }
    },
    {
      "id": "stressLevel",
      "label": "Stress Level (1-10)",
      "type": "number",
      "unit": "scale",
      "default": 5,
      "businessContext": "Self-reported stress level on a scale of 1-10, 10 being extremely stressed",
      "label_i18n": {
        "en": "Stress Level (1-10)",
        "tr": "Stress Level (1-10)",
        "de": "Stress Level (1-10)",
        "fr": "Stress Level (1-10)",
        "es": "Stress Level (1-10)",
        "ar": "Stress Level (1-10)"
      }
    }
  ],
  "formulas": {
    "predictedSleepLatency": "10 + 0.2 * (age - 30) + 0.05 * caffeineIntake + 0.1 * screenTime + ((roomTemperature - 20) ** 2) / 2 + 2 * stressLevel",
    "estimatedSleepOnset": "lightsOutTime + predictedSleepLatency / 60",
    "ageAdjustment": "0.2 * (age - 30)",
    "caffeineAdjustment": "0.05 * caffeineIntake",
    "screenAdjustment": "0.1 * screenTime",
    "temperatureAdjustment": "((roomTemperature - 20) ** 2) / 2",
    "stressAdjustment": "2 * stressLevel"
  },
  "outputs": {
    "primary": "predictedSleepLatency",
    "breakdown": [
      "estimatedSleepOnset",
      "ageAdjustment",
      "caffeineAdjustment",
      "screenAdjustment",
      "temperatureAdjustment",
      "stressAdjustment"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "stressAdjustment"
  },

{
  "toolName": "gibibytes-to-gigabytes-calculator",
  "inputs": [
    {
      "id": "gibibytes",
      "label": "Gibibytes (GiB)",
      "type": "number",
      "unit": "GiB",
      "default": 1,
      "businessContext": "Input value in gibibytes.",
      "label_i18n": {
        "en": "Gibibytes (GiB)",
        "tr": "Gibibytes (GiB)",
        "de": "Gibibytes (GiB)",
        "fr": "Gibibytes (GiB)",
        "es": "Gibibytes (GiB)",
        "ar": "Gibibytes (GiB)"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (GB per GiB)",
      "type": "number",
      "unit": "GB/GiB",
      "default": 1.073741824,
      "businessContext": "Factor for converting GiB to GB (fixed, but overridable for calibration).",
      "label_i18n": {
        "en": "Conversion Factor (GB per GiB)",
        "tr": "Conversion Factor (GB per GiB)",
        "de": "Conversion Factor (GB per GiB)",
        "fr": "Conversion Factor (GB per GiB)",
        "es": "Conversion Factor (GB per GiB)",
        "ar": "Conversion Factor (GB per GiB)"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal digits for output rounding.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "safetyFactorPercent",
      "label": "Safety Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage added to result as safety margin, e.g., 10 means increase by 10%.",
      "label_i18n": {
        "en": "Safety Factor (%)",
        "tr": "Safety Factor (%)",
        "de": "Safety Factor (%)",
        "fr": "Safety Factor (%)",
        "es": "Safety Factor (%)",
        "ar": "Safety Factor (%)"
      }
    }
  ],
  "formulas": {
    "rawGigabytes": "gibibytes * conversionFactor",
    "safetyAppliedGigabytes": "rawGigabytes * (1 + safetyFactorPercent / 100)",
    "roundedGigabytes": "Math.round(safetyAppliedGigabytes * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)"
  },
  "outputs": {
    "primary": "roundedGigabytes",
    "breakdown": [
      "rawGigabytes",
      "safetyAppliedGigabytes"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Tüketici",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "perakende",

        "en": "Operating Expenses",
        "tr": "Operating Expenses",
        "de": "Operating Expenses",
        "fr": "Operating Expenses",
        "es": "Operating Expenses",
        "ar": "Operating Expenses"
      }
    },
    {
      "id": "otherIncome",
      "label": "Other Operating Income",
      "type": "number",
      "unit": "$",
      "default": 0,
      "businessContext": "Any other income directly from operations (negative if expense)",

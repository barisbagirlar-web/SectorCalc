        "de": "Other Operating Income",
        "fr": "Other Operating Income",
        "es": "Other Operating Income",
        "ar": "Other Operating Income"
      }
    }
  ],
  "formulas": {
    "operatingIncome": "revenue - cogs - opex + otherIncome",
    "operatingMargin": "(operatingIncome / revenue) * 100"

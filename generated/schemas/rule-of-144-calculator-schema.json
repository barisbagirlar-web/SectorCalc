        "ar": "Yıllık Bileşik Dönem Sayısı"
      }
    },
    {
      "id": "initialInvestment",
      "label": "Başlangıç Yatırımı",
      "type": "number",
      "unit": "birim",
      "default": 1000,
      "businessContext": "Başlangıçta yatırılan ana para.",
      "label_i18n": {
        "en": "Başlangıç Yatırımı",
        "tr": "Başlangıç Yatırımı",
        "de": "Başlangıç Yatırımı",
        "fr": "Başlangıç Yatırımı",
        "es": "Başlangıç Yatırımı",
        "ar": "Başlangıç Yatırımı"
      }
    },
    {
      "id": "targetMultiplier",
      "label": "Hedef Çarpan",
      "type": "number",
      "unit": "kat",
      "default": 2,
      "businessContext": "Yatırımın kaç katına çıkmasının hedeflendiği.",
      "label_i18n": {
        "en": "Hedef Çarpan",
        "tr": "Hedef Çarpan",
        "de": "Hedef Çarpan",
        "fr": "Hedef Çarpan",
        "es": "Hedef Çarpan",
        "ar": "Hedef Çarpan"
      }
    }
  ],
  "formulas": {
    "rule144Estimate": "144 / interestRate",
    "exactYears": "Math.log(targetMultiplier) / (compoundingPeriods * Math.log(1 + interestRate / (100 * compoundingPeriods)))",
    "difference": "exactYears - rule144Estimate"
  },
  "outputs": {
    "primary": "rule144Estimate",
    "breakdown": [
      "exactYears",
      "difference"
    ]
  },

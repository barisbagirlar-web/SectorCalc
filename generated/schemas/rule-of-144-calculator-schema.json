      }
    },
    {
      "id": "compoundingPeriods",
      "label": "Yıllık Bileşik Dönem Sayısı",
      "type": "number",
      "unit": "kez",
      "default": 1,
      "businessContext": "Faizin yılda kaç kez bileşiklendiği.",
      "label_i18n": {
        "en": "Yıllık Bileşik Dönem Sayısı",
        "tr": "Yıllık Bileşik Dönem Sayısı",

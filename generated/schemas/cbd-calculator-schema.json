    "profit": "(materialUnitCost + laborUnitCost + overheadUnitCost) * quantity * (profitMarginPercent / 100)",
    "sellingPrice": "(materialUnitCost + laborUnitCost + overheadUnitCost) * quantity * (1 + profitMarginPercent / 100)"

{
  "toolName": "warehouse-capacity-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "other",
  "sector": "Lojistik",
  "sectorId": "other",
  "inputs": [
    {
      "id": "toplamAlan",
      "label": "Total Floor Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 5000,
      "min": 0,
      "businessContext": "Total warehouse floor area."
    },
    {
      "id": "rafKullanimi",
      "label": "Rack Utilization (%)",
      "type": "number",
      "unit": "%",
      "default": 60,
      "min": 0,
      "max": 100,
      "businessContext": "Rack space to total floor ratio."
    },
    {
      "id": "paletAlani",
      "label": "Pallet Footprint (m²)",
      "type": "number",
      "unit": "m2",
      "default": 1.2,
      "min": 0,
      "businessContext": "Area per pallet."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.floor((toplamAlan * (rafKullanimi / 100)) / Math.max(0.0001, paletAlani))"
  },
  "outputs": {
    "primary": "result",
    "unit": "pallets",
    "breakdown": {
      "result": "Maksimum Palet Kapasitesi"
    },
    "breakdownUnits": {
      "result": "pallets"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inventory turnover metrics monthly.",
      "Factor in seasonality for safety stock."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate maximum pallet capacity in a warehouse.",
      "long": "Calculate maximum pallet capacity in a warehouse."
    }
  },
  "sectorSlug": "daily-renovation"

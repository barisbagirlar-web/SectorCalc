{
  "toolName": "wacc-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finance",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "E",
      "label": "Equity (USD)",
      "type": "number",
      "unit": "USD",
      "default": 1000000,
      "min": 0,
      "businessContext": "Total equity value."
    },
    {
      "id": "D",
      "label": "Debt (USD)",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "min": 0,
      "businessContext": "Total debt."
    },
    {
      "id": "Re",
      "label": "Cost of Equity (%)",
      "type": "number",
      "unit": "%",
      "default": 15,
      "min": 0,
      "businessContext": "Expected return for shareholders."
    },
    {
      "id": "Rd",
      "label": "Cost of Debt (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "businessContext": "Company's borrowing cost."
    },
    {
      "id": "vergi",
      "label": "Tax Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 25,
      "min": 0,
      "businessContext": "Corporate tax rate."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "V": "E + D",
    "result": "(E / Math.max(1, E + D) * Re) + (D / Math.max(1, E + D) * Rd * (1 - vergi / 100))"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "WACC (Weightli Mean Sermaye Costi)"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate weighted average cost of capital (WACC).",
      "long": "Calculate weighted average cost of capital (WACC)."
    }
  },
  "sectorSlug": "daily-renovation"
}

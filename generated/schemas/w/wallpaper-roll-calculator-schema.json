{
  "toolName": "wallpaper-roll-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Wall Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 50,
      "min": 0,
      "businessContext": "Wall area."
    },
    {
      "id": "ruloEn",
      "label": "Roll Width (m)",
      "type": "number",
      "unit": "m",
      "default": 0.53,
      "min": 0,
      "businessContext": "Wallpaper roll width."
    },
    {
      "id": "ruloBoy",
      "label": "Roll Length (m)",
      "type": "number",
      "unit": "m",
      "default": 10,
      "min": 0,
      "businessContext": "Roll length."
    },
    {
      "id": "desenTekrari",
      "label": "Pattern Repeat (m)",
      "type": "number",
      "unit": "m",
      "default": 0,
      "min": 0,
      "businessContext": "Pattern repeat length."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.ceil(area / Math.max(0.0001, (ruloEn * ruloBoy * (1 - desenTekrari / Math.max(0.0001, ruloBoy)))))"
  },
  "outputs": {
    "primary": "result",
    "unit": "rolls",
    "breakdown": {
      "result": "Required Wallpaper Roll"
    },
    "breakdownUnits": {
      "result": "rolls"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate wallpaper rolls needed including pattern repeat waste.",
      "long": "Calculate wallpaper rolls needed including pattern repeat waste."
    }
  },
  "sectorSlug": "daily-renovation"
}

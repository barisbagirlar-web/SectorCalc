{
  "toolName": "watershed-runoff-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "sustainability-resource-esg",
  "sector": "Environment and Sustainability",
  "sectorId": "sustainability-resource-esg",
  "inputs": [
    {
      "id": "havzaAlani",
      "label": "Watershed Area (km²)",
      "type": "number",
      "unit": "km2",
      "default": 100,
      "min": 0,
      "businessContext": "Catchment area."
    },
    {
      "id": "yagis",
      "label": "Rainfall (mm)",
      "type": "number",
      "unit": "mm",
      "default": 50,
      "min": 0,
      "businessContext": "Single rainfall depth."
    },
    {
      "id": "akisKatsayisi",
      "label": "Runoff Coefficient (0-1)",
      "type": "number",
      "unit": "scalar",
      "default": 0.3,
      "min": 0,
      "businessContext": "Surface permeability coefficient."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "havzaAlani * 1000000 * (yagis / 1000) * akisKatsayisi"
  },
  "outputs": {
    "primary": "result",
    "unit": "m3",
    "breakdown": {
      "result": "Total Surface Runoff Volume"
    },
    "breakdownUnits": {
      "result": "m3"
    },
    "hiddenLossDrivers": [
      "High environmental score may reduce operational costs.",
      "Low ESG score may increase capital costs."
    ],
    "suggestedActions": [
      "Set improvement targets for each ESG pillar.",
      "Consider carbon offset programs for residual emissions."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate surface runoff volume from a watershed after rainfall.",
      "long": "Calculate surface runoff volume from a watershed after rainfall."
    }
  },
  "sectorSlug": "daily-renovation"
}

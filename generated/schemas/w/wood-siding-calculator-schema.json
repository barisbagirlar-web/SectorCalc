{
  "toolName": "wood-siding-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "project-construction-management",
  "sector": "Construction",
  "sectorId": "project-construction-management",
  "inputs": [
    {
      "id": "area",
      "label": "Siding Area (m²)",
      "type": "number",
      "unit": "m2",
      "default": 40,
      "min": 0,
      "businessContext": "Area to cover."
    },
    {
      "id": "tahtaEn",
      "label": "Board Width (m)",
      "type": "number",
      "unit": "m",
      "default": 0.15,
      "min": 0,
      "businessContext": "Board total width."
    },
    {
      "id": "bindirmePayi",
      "label": "Overlap (m)",
      "type": "number",
      "unit": "m",
      "default": 0.025,
      "min": 0,
      "businessContext": "Overlap between boards."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "area / Math.max(0.0001, (tahtaEn - bindirmePayi))"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Total Siding Length"
    },
    "breakdownUnits": {
      "result": "m"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Order 5-10% extra material for waste.",
      "Verify local building codes before purchasing."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate wood siding length needed accounting for overlap.",
      "long": "Calculate wood siding length needed accounting for overlap."
    }
  },
  "sectorSlug": "daily-renovation"
}

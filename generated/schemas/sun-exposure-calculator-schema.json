{
  "toolName": "sun-exposure-calculator",
  "inputs": [
    {
      "id": "uvIndex",
      "label": "UV Index",
      "type": "number",
      "unit": "UVI",
      "default": 5,
      "businessContext": "The ultraviolet index value from weather report (0-11+)",
      "label_i18n": {
        "en": "UV Index",
        "tr": "UV Index",
        "de": "UV Index",
        "fr": "UV Index",
        "es": "UV Index",
        "ar": "UV Index"
      }
    },
    {
      "id": "skinType",
      "label": "Skin Type",
      "type": "number",
      "unit": "Fitzpatrick (1-6)",
      "default": 3,
      "businessContext": "Fitzpatrick skin phototype: 1=very fair, 6=deeply pigmented",
      "label_i18n": {
        "en": "Skin Type",
        "tr": "Skin Type",
        "de": "Skin Type",
        "fr": "Skin Type",
        "es": "Skin Type",
        "ar": "Skin Type"
      }
    },
    {
      "id": "spf",
      "label": "Sunscreen SPF",
      "type": "number",
      "unit": "SPF",
      "default": 15,
      "businessContext": "Sun Protection Factor of applied sunscreen",
      "label_i18n": {
        "en": "Sunscreen SPF",
        "tr": "Sunscreen SPF",
        "de": "Sunscreen SPF",
        "fr": "Sunscreen SPF",
        "es": "Sunscreen SPF",
        "ar": "Sunscreen SPF"
      }
    },
    {
      "id": "cloudCover",
      "label": "Cloud Cover",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Percentage of sky covered by clouds reducing UV",
      "label_i18n": {
        "en": "Cloud Cover",
        "tr": "Cloud Cover",
        "de": "Cloud Cover",
        "fr": "Cloud Cover",
        "es": "Cloud Cover",
        "ar": "Cloud Cover"
      }
    },
    {
      "id": "altitude",
      "label": "Altitude",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Elevation above sea level; UV increases ~5% per 1000m",
      "label_i18n": {
        "en": "Altitude",
        "tr": "Altitude",
        "de": "Altitude",
        "fr": "Altitude",
        "es": "Altitude",
        "ar": "Altitude"
      }
    }
  ],
  "formulas": {
    "effectiveUVI": "uvIndex * (1 + altitude / 1000 * 0.05) * (1 - cloudCover / 100)",
    "erythemalDoseRate": "effectiveUVI * 0.025"
  },
  "outputs": {
    "primary": "erythemalDoseRate",
    "breakdown": [
      "effectiveUVI",
      "erythemalDoseRate",
      "med",
      "medTimeMinutes"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "safeMinutes",
    "unit": "UVI",
    "breakdownUnits": {
      "medTimeMinutes": "min"
    }
  },
  "category": "İSG & Risk",
  "sector": "Havacılık & Uzay",

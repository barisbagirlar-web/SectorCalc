        "de": "Sabit Maliyetler",
        "fr": "Sabit Maliyetler",
        "es": "Sabit Maliyetler",
        "ar": "Sabit Maliyetler"
      }
    }
  ],
  "formulas": {
    "contributionMarginPerUnit": "pricePerUnit - variableCostPerUnit",
    "totalContributionMargin": "quantity * contributionMarginPerUnit",
    "operatingIncome": "totalContributionMargin - fixedCosts",
    "degreeOfOperatingLeverage": "totalContributionMargin / operatingIncome"
  },
  "outputs": {
    "primary": "degreeOfOperatingLeverage",
    "breakdown": [
      "contributionMarginPerUnit",
      "totalContributionMargin",
      "operatingIncome"
    ],

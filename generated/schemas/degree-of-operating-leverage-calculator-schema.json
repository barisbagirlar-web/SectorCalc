      }
    },
    {
      "id": "fixedCosts",
      "label": "Sabit Maliyetler",
      "type": "number",
      "unit": "TL",
      "default": 10000,
      "businessContext": "Toplam sabit işletme maliyetleri",
      "label_i18n": {
        "en": "Sabit Maliyetler",

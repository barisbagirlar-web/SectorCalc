{
  "toolName": "beck-depression-inventory-calculator",
  "inputs": [
    {
      "id": "cognitive_affective",
      "label": "Bilişsel-Duygusal Puan",
      "type": "number",
      "unit": "puan",
      "default": 0,
      "businessContext": "BDI Bilişsel-Duygusal alt ölçek toplamı"
    },
    {
      "id": "somatic",
      "label": "Somatik Puan",
      "type": "number",
      "unit": "puan",
      "default": 0,
      "businessContext": "BDI Somatik alt ölçek toplamı"
    },
    {
      "id": "performance",
      "label": "Performans Puan",
      "type": "number",
      "unit": "puan",
      "default": 0,
      "businessContext": "BDI Performans alt ölçek toplamı"
    },
    {
      "id": "guilt",
      "label": "Suçluluk-İrritabilite Puan",
      "type": "number",
      "unit": "puan",
      "default": 0,
      "businessContext": "BDI Suçluluk-İrritabilite alt ölçek toplamı"
    }
  ],
  "formulas": {
    "totalScore": "cognitive_affective + somatic + performance + guilt",
    "severityIndex": "1 / (1 + Math.exp(-(totalScore - 14.5) / 5))",
    "zScore": "(totalScore - 14.5) / Math.sqrt(21)"
  },
  "outputs": {
    "primary": "totalScore",
    "breakdown": [
      "severityIndex",
      "zScore"
    ]
  },
  "category": "Lojistik & Rota",
  "sector": "Lojistik & Depolama",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "procurement-supply-chain",
  "sectorId": "lojistik",
  "profession": "İthalat/İhracat Uzmanı",
  "categoryId": "logistics"
}

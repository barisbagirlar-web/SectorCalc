      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 4,
      "businessContext": "Number of decimal places for the years output",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "outputMode",
      "label": "Output Mode",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "0 = decimal years only, 1 = years and months breakdown (not used in primary)",
      "label_i18n": {
        "en": "Output Mode",
        "tr": "Output Mode",
        "de": "Output Mode",
        "fr": "Output Mode",
        "es": "Output Mode",
        "ar": "Output Mode"
      }
    }
  ],
  "formulas": {
    "yearsRounded": "Math.round((months / monthsPerYear) * Math.pow(10, decimalPlaces)) / Math.pow(10, decimalPlaces)",
    "yearsPart": "Math.floor(months / monthsPerYear)",
    "monthsPart": "months % monthsPerYear"
  },
  "outputs": {
    "primary": "yearsRounded",
    "breakdown": [
      "yearsPart",
      "monthsPart"
    ]
  },

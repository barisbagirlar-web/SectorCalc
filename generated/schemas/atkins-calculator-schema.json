{
  "toolName": "atkins-calculator",
  "inputs": [
    {
      "id": "powerInput",
      "label": "Güç Girişi",
      "type": "number",
      "unit": "kW",
      "default": 100,
      "businessContext": "Sisteme verilen anlık güç."
    },
    {
      "id": "massFlow",
      "label": "Kütle Akışı",
      "type": "number",
      "unit": "kg/s",
      "default": 2,
      "businessContext": "Isı transfer akışkanının kütlesel debisi."
    },
    {
      "id": "specificHeat",
      "label": "Özgül Isı",
      "type": "number",
      "unit": "kJ/kg·K",
      "default": 4.18,
      "businessContext": "Akışkanın özgül ısı kapasitesi."
    },
    {
      "id": "deltaTemp",
      "label": "Sıcaklık Farkı",
      "type": "number",
      "unit": "K",
      "default": 10,
      "businessContext": "Giriş ve çıkış arasındaki sıcaklık farkı."
    },
    {
      "id": "efficiencyFactor",
      "label": "Verimlilik Faktörü",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "Sistem kayıplarını hesaba katan faktör."
    }
  ],
  "formulas": {
    "actualThermalPower": "massFlow * specificHeat * deltaTemp * efficiencyFactor",
    "atkinsIndex": "powerInput / actualThermalPower"
  },
  "outputs": {
    "primary": "atkinsIndex",
    "breakdown": [
      "actualThermalPower",
      "powerDensity"
    ]
  },
  "category": "Akışkanlar & Termodinamik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "process-chemical",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "diger"
}

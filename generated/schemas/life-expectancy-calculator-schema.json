{
  "toolName": "life-expectancy-calculator",
  "inputs": [
    {
      "id": "currentAge",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years",
      "label_i18n": {
        "en": "Current Age",
        "tr": "Current Age",
        "de": "Current Age",
        "fr": "Current Age",
        "es": "Current Age",
        "ar": "Current Age"
      }
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "0 for male, 1 for female",
      "label_i18n": {
        "en": "Gender",
        "tr": "Gender",
        "de": "Gender",
        "fr": "Gender",
        "es": "Gender",
        "ar": "Gender"
      }
    },
    {
      "id": "smokingStatus",
      "label": "Smoking Status",
      "type": "number",
      "unit": "pack-years",
      "default": 0,
      "businessContext": "Smoking pack-years (0 for non-smoker)",
      "label_i18n": {
        "en": "Smoking Status",
        "tr": "Smoking Status",
        "de": "Smoking Status",
        "fr": "Smoking Status",
        "es": "Smoking Status",
        "ar": "Smoking Status"
      }
    },
    {
      "id": "alcoholConsumption",
      "label": "Alcohol Consumption",
      "type": "number",
      "unit": "drinks per week",
      "default": 3,
      "businessContext": "Average number of alcoholic drinks per week",
      "label_i18n": {
        "en": "Alcohol Consumption",
        "tr": "Alcohol Consumption",
        "de": "Alcohol Consumption",
        "fr": "Alcohol Consumption",
        "es": "Alcohol Consumption",
        "ar": "Alcohol Consumption"
      }
    },
    {
      "id": "bmi",
      "label": "BMI",
      "type": "number",
      "unit": "kg/m²",
      "default": 25,
      "businessContext": "Body Mass Index",
      "label_i18n": {
        "en": "BMI",
        "tr": "BMI",
        "de": "BMI",
        "fr": "BMI",
        "es": "BMI",
        "ar": "BMI"
      }
    },
    {
      "id": "exerciseHours",
      "label": "Weekly Exercise",
      "type": "number",
      "unit": "hours",
      "default": 2,
      "businessContext": "Hours of moderate exercise per week",
      "label_i18n": {
        "en": "Weekly Exercise",
        "tr": "Weekly Exercise",
        "de": "Weekly Exercise",
        "fr": "Weekly Exercise",
        "es": "Weekly Exercise",
        "ar": "Weekly Exercise"
      }
    }
  ],
  "formulas": {
    "baseExpectancy": "75",
    "genderBonus": "inputs.gender * 5",
    "smokingEffect": "- inputs.smokingStatus * 0.5",
    "alcoholEffect": "(inputs.alcoholConsumption - 7) * 0.2",
    "exerciseBonus": "inputs.exerciseHours * 0.5",
    "bmiPenalty": "- (inputs.bmi - 23) ** 2 * 0.02",
    "lifeExpectancy": "75 + inputs.gender * 5 - inputs.smokingStatus * 0.5 + (inputs.alcoholConsumption - 7) * 0.2 + inputs.exerciseHours * 0.5 - (inputs.bmi - 23) ** 2 * 0.02"
  },
  "outputs": {
    "primary": "lifeExpectancy",
    "breakdown": [
      "baseExpectancy",
      "genderBonus",
      "smokingEffect",
      "alcoholEffect",
      "exerciseBonus",
      "bmiPenalty"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "electrical-power-systems"
}

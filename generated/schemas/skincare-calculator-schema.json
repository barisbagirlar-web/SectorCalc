      }
    },
    {
      "id": "overheadCostPerBatch",
      "label": "Overhead Cost per Batch",
      "type": "number",
      "unit": "USD",
      "default": 300,
      "businessContext": "Allocated overhead costs (utilities, rent, etc.) per batch",
      "label_i18n": {
        "en": "Overhead Cost per Batch",
        "tr": "Overhead Cost per Batch",
        "de": "Overhead Cost per Batch",
        "fr": "Overhead Cost per Batch",
        "es": "Overhead Cost per Batch",
        "ar": "Overhead Cost per Batch"
      }
    },
    {
      "id": "profitMarginPercent",
      "label": "Desired Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Target profit margin percentage on selling price",
      "label_i18n": {
        "en": "Desired Profit Margin",
        "tr": "Desired Profit Margin",
        "de": "Desired Profit Margin",
        "fr": "Desired Profit Margin",
        "es": "Desired Profit Margin",
        "ar": "Desired Profit Margin"
      }
    }
  ],
  "formulas": {
    "costPerUnit": "((ingredientCostPerKg * ingredientUsageGramsPerUnit / 1000) + packagingCostPerUnit + ((laborCostPerBatch + overheadCostPerBatch) / batchSize))",
    "sellingPricePerUnit": "((ingredientCostPerKg * ingredientUsageGramsPerUnit / 1000) + packagingCostPerUnit + ((laborCostPerBatch + overheadCostPerBatch) / batchSize)) / (1 - profitMarginPercent / 100)",
    "profitPerUnit": "(((ingredientCostPerKg * ingredientUsageGramsPerUnit / 1000) + packagingCostPerUnit + ((laborCostPerBatch + overheadCostPerBatch) / batchSize)) / (1 - profitMarginPercent / 100)) - ((ingredientCostPerKg * ingredientUsageGramsPerUnit / 1000) + packagingCostPerUnit + ((laborCostPerBatch + overheadCostPerBatch) / batchSize))"
  },
  "outputs": {
    "primary": "sellingPricePerUnit",
    "breakdown": [
      "costPerUnit",
      "profitPerUnit"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "profitPerUnit"
  },

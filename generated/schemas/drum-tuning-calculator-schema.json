      "businessContext": "Thickness of the drum head material (e.g., Mylar) in millimeters.",
      "label_i18n": {
        "en": "Head Thickness",
        "tr": "Head Thickness",
        "de": "Head Thickness",
        "fr": "Head Thickness",
        "es": "Head Thickness",

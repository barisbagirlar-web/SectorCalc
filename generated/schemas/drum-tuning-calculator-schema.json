    "Second_Overtone__Hz_": "Second Overtone (Hz)",
    "result": "Fundamental Frequency (Hz)"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "First Overtone (Hz)",
      "Second Overtone (Hz)"
    ]
  },

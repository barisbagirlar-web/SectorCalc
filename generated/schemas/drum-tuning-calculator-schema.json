      "label": "Head Material Density",
      "type": "number",
      "unit": "kg/m³",
      "default": 1400,
      "businessContext": "Volumetric mass density of the drum head material in kilograms per cubic meter.",
      "label_i18n": {
        "en": "Head Material Density",
        "tr": "Head Material Density",
        "de": "Head Material Density",
        "fr": "Head Material Density",
        "es": "Head Material Density",
        "ar": "Head Material Density"
      }
    },
    {
      "id": "tension",
      "label": "Tension",
      "type": "number",
      "unit": "N/m",
      "default": 500,
      "businessContext": "Tension per unit length applied to the drum head in Newtons per meter.",
      "label_i18n": {
        "en": "Tension",
        "tr": "Tension",
        "de": "Tension",
        "fr": "Tension",
        "es": "Tension",
        "ar": "Tension"
      }
    },
    {
      "id": "densityAdjustment",
      "label": "Density Adjustment Factor",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Multiplicative calibration factor to compensate for material variations or environmental effects.",
      "label_i18n": {
        "en": "Density Adjustment Factor",
        "tr": "Density Adjustment Factor",
        "de": "Density Adjustment Factor",
        "fr": "Density Adjustment Factor",
        "es": "Density Adjustment Factor",
        "ar": "Density Adjustment Factor"
      }
    }

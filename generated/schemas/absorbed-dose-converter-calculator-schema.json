{
  "toolName": "absorbed-dose-converter-calculator",
  "inputs": [
    {
      "id": "doseGray",
      "label": "Absorbed Dose (Gy)",
      "type": "number",
      "unit": "Gy",
      "default": 0,
      "businessContext": "Measured or calculated absorbed dose in Gray"
    },
    {
      "id": "calibrationFactor",
      "label": "Calibration Factor",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Multiplier for instrument calibration"
    },
    {
      "id": "safetyMargin",
      "label": "Safety Margin",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Safety factor to apply for regulatory limits"
    },
    {
      "id": "minimalDetectionLimit",
      "label": "Minimal Detection Limit",
      "type": "number",
      "unit": "Gy",
      "default": 0.001,
      "businessContext": "Smallest dose reliably measurable"
    }
  ],
  "formulas": {
    "adjustedDoseGy": "doseGray * calibrationFactor * safetyMargin",
    "adjustedDoseRad": "doseGray * calibrationFactor * safetyMargin * 100",
    "adjustedDose_mGy": "doseGray * calibrationFactor * safetyMargin * 1000",
    "adjustedDose_µGy": "doseGray * calibrationFactor * safetyMargin * 1000000",
    "signalToNoiseRatio": "doseGray / minimalDetectionLimit"
  },
  "outputs": {
    "primary": "adjustedDoseGy",
    "breakdown": [
      "adjustedDoseRad",
      "adjustedDose_mGy",
      "adjustedDose_µGy",
      "signalToNoiseRatio"
    ]
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "conversion",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost"
}

  "formulas": {
    "ctr": "totalImpressions !== 0 ? (totalClicks / totalImpressions) * 100 : 0",
    "conversionRate": "totalClicks !== 0 ? (totalConversions / totalClicks) * 100 : 0",
    "costPerClick": "totalClicks !== 0 ? totalCost / totalClicks : 0"
  },

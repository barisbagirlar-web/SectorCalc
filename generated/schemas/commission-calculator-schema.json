{
  "toolName": "commission-calculator",
  "inputs": [
    {
      "id": "totalSales",
      "label": "Toplam Satış",
      "type": "number",
      "unit": "currency",
      "default": 5000,
      "businessContext": "Satış temsilcisinin toplam satış tutarı",
      "label_i18n": {
        "en": "Toplam Satış",
        "tr": "Toplam Satış",
        "de": "Toplam Satış",
        "fr": "Toplam Satış",
        "es": "Toplam Satış",
        "ar": "Toplam Satış"
      }
    },
    {
      "id": "baseCommissionRate",
      "label": "Temel Komisyon Oranı",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Temel seviyedeki komisyon yüzdesi",
      "label_i18n": {
        "en": "Temel Komisyon Oranı",
        "tr": "Temel Komisyon Oranı",
        "de": "Temel Komisyon Oranı",
        "fr": "Temel Komisyon Oranı",
        "es": "Temel Komisyon Oranı",
        "ar": "Temel Komisyon Oranı"
      }
    },
    {
      "id": "highTierThreshold",
      "label": "Yüksek Kademe Eşiği",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "Yüksek komisyon oranının uygulanacağı satış eşiği",
      "label_i18n": {
        "en": "Yüksek Kademe Eşiği",
        "tr": "Yüksek Kademe Eşiği",
        "de": "Yüksek Kademe Eşiği",
        "fr": "Yüksek Kademe Eşiği",
        "es": "Yüksek Kademe Eşiği",
        "ar": "Yüksek Kademe Eşiği"
      }
    },
    {
      "id": "highTierRate",
      "label": "Yüksek Kademe Oranı",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Yüksek satış seviyesinde uygulanacak komisyon yüzdesi",
      "label_i18n": {
        "en": "Yüksek Kademe Oranı",
        "tr": "Yüksek Kademe Oranı",
        "de": "Yüksek Kademe Oranı",
        "fr": "Yüksek Kademe Oranı",
        "es": "Yüksek Kademe Oranı",
        "ar": "Yüksek Kademe Oranı"
      }
    }
  ],
  "formulas": {
    "tier1Commission": "totalSales <= highTierThreshold ? totalSales * baseCommissionRate / 100 : highTierThreshold * baseCommissionRate / 100",
    "tier2Commission": "totalSales > highTierThreshold ? (totalSales - highTierThreshold) * highTierRate / 100 : 0",
    "totalCommission": "tier1Commission + tier2Commission"
  },
  "outputs": {
    "primary": "totalCommission",
    "breakdown": [
      "tier1Commission",
      "tier2Commission"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

{
  "toolName": "steps-to-kilometers-calculator",
  "inputs": [
    {
      "id": "steps",
      "label": "Number of Steps",
      "type": "number",
      "unit": "steps",
      "default": 10000,
      "businessContext": "Total step count recorded by a pedometer, fitness tracker, or manual counting.",
      "label_i18n": {
        "en": "Number of Steps",
        "tr": "Number of Steps",
        "de": "Number of Steps",
        "fr": "Number of Steps",
        "es": "Number of Steps",
        "ar": "Number of Steps"
      }
    },
    {
      "id": "stepLengthCm",
      "label": "Step Length",
      "type": "number",
      "unit": "cm",
      "default": 76.2,
      "businessContext": "Measured length of one step in centimeters. Average adult walking step is ~76.2 cm. Used when height-based estimation is disabled.",
      "label_i18n": {
        "en": "Step Length",
        "tr": "Step Length",
        "de": "Step Length",
        "fr": "Step Length",
        "es": "Step Length",
        "ar": "Step Length"
      }
    },
    {
      "id": "heightCm",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "Body height in centimeters. Used as the basis for estimating step length (when height estimation is toggled on).",
      "label_i18n": {
        "en": "Height",
        "tr": "Height",
        "de": "Height",
        "fr": "Height",
        "es": "Height",
        "ar": "Height"
      }
    },
    {
      "id": "useHeightEstimation",
      "label": "Estimate from Height",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "Set to 1 to calculate step length automatically from height (stride ratio * height); set to 0 to use the manual step length.",
      "label_i18n": {
        "en": "Estimate from Height",
        "tr": "Estimate from Height",
        "de": "Estimate from Height",
        "fr": "Estimate from Height",
        "es": "Estimate from Height",
        "ar": "Estimate from Height"
      }
    },
    {
      "id": "strideRatio",
      "label": "Stride-to-Height Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.46,
      "businessContext": "Ratio of step length to height. Typical range: 0.40–0.50. 0.46 is a commonly accepted average for walking.",
      "label_i18n": {
        "en": "Stride-to-Height Ratio",
        "tr": "Stride-to-Height Ratio",
        "de": "Stride-to-Height Ratio",
        "fr": "Stride-to-Height Ratio",
        "es": "Stride-to-Height Ratio",
        "ar": "Stride-to-Height Ratio"
      }
    }
  ],
  "formulas": {
    "distanceKm": "steps * (stepLengthCm * (1 - useHeightEstimation) + heightCm * strideRatio * useHeightEstimation) / 100000",
    "distanceM": "steps * (stepLengthCm * (1 - useHeightEstimation) + heightCm * strideRatio * useHeightEstimation) / 100",
    "distanceMi": "steps * (stepLengthCm * (1 - useHeightEstimation) + heightCm * strideRatio * useHeightEstimation) / 100000 * 0.621371"
  },
  "outputs": {
    "primary": "distanceKm",
    "breakdown": [
      "distanceM",
      "distanceMi"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "distanceMi"
  },
  "category": "Kalite & Laboratuvar",
  "sector": "Kalite, SPC & Altı Sigma",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "quality-six-sigma",

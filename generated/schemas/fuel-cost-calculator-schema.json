  "formulas": {
    "totalFuelConsumed": "(distance * fuelConsumption / 100) * trips",
    "fuelCost": "((distance * fuelConsumption / 100) * trips) * fuelPrice",
    "extraCostTotal": "extraCost * trips",
    "totalCost": "((distance * fuelConsumption / 100) * trips) * fuelPrice + (extraCost * trips)"
  },

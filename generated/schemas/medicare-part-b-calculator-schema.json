{
  "toolName": "medicare-part-b-calculator",
  "inputs": [
    {
      "id": "magi",
      "label": "Modified Adjusted Gross Income (MAGI)",
      "type": "number",
      "unit": "USD/year",
      "default": 0,
      "businessContext": "Annual income used to determine Income Related Monthly Adjustment Amount (IRMAA)",
      "label_i18n": {
        "en": "Modified Adjusted Gross Income (MAGI)",
        "tr": "Modified Adjusted Gross Income (MAGI)",
        "de": "Modified Adjusted Gross Income (MAGI)",
        "fr": "Modified Adjusted Gross Income (MAGI)",
        "es": "Modified Adjusted Gross Income (MAGI)",
        "ar": "Modified Adjusted Gross Income (MAGI)"
      }
    },
    {
      "id": "filingStatus",
      "label": "Filing Status",
      "type": "number",
      "unit": "code (0 = single/individual, 1 = married filing jointly)",
      "default": 0,
      "businessContext": "IRS tax filing status that determines IRMAA brackets",
      "label_i18n": {
        "en": "Filing Status",
        "tr": "Filing Status",
        "de": "Filing Status",
        "fr": "Filing Status",
        "es": "Filing Status",
        "ar": "Filing Status"
      }
    },
    {
      "id": "standardPremium",
      "label": "Standard Part B Monthly Premium",
      "type": "number",
      "unit": "USD/month",
      "default": 174.7,
      "businessContext": "Current year base monthly premium without adjustments",
      "label_i18n": {
        "en": "Standard Part B Monthly Premium",
        "tr": "Standard Part B Monthly Premium",
        "de": "Standard Part B Monthly Premium",
        "fr": "Standard Part B Monthly Premium",
        "es": "Standard Part B Monthly Premium",
        "ar": "Standard Part B Monthly Premium"
      }
    },
    {
      "id": "lateEnrollmentMonths",
      "label": "Late Enrollment Period in Months",
      "type": "number",
      "unit": "months",
      "default": 0,
      "businessContext": "Number of months past Initial Enrollment Period without Part B or creditable coverage; used to compute penalty",
      "label_i18n": {
        "en": "Late Enrollment Period in Months",
        "tr": "Late Enrollment Period in Months",
        "de": "Late Enrollment Period in Months",
        "fr": "Late Enrollment Period in Months",
        "es": "Late Enrollment Period in Months",
        "ar": "Late Enrollment Period in Months"
      }
    }
  ],
  "formulas": {
    "surcharge": "filingStatus === 0 ? (magi <= 103000 ? 0 : magi <= 129000 ? 69.90 : magi <= 161000 ? 174.70 : magi <= 193000 ? 279.50 : magi <= 500000 ? 384.30 : 419.30) : (magi <= 206000 ? 0 : magi <= 258000 ? 69.90 : magi <= 322000 ? 174.70 : magi <= 386000 ? 279.50 : magi <= 750000 ? 384.30 : 419.30)",
    "latePenaltyFactor": "1 + 0.1 * Math.floor(lateEnrollmentMonths / 12)",
    "basePremium": "standardPremium",
    "monthlyPremium": "(standardPremium + surcharge) * latePenaltyFactor",
    "annualCost": "monthlyPremium * 12"
  },
  "outputs": {
    "primary": "monthlyPremium",
    "breakdown": [
      "basePremium",
      "surcharge",
      "latePenaltyFactor",
      "annualCost"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance"
}

  "formulas": {
    "primary": "(() => { const v = value * Math.pow(10, exponent); let e = 0; while (Math.abs(v) >= 1000 && e < maxExponent) { v /= 1000; e += 3; } while (Math.abs(v) < 1 && e > minExponent) { v *= 1000; e -= 3; } const mantissa = v.toFixed(precision); return mantissa + 'e' + e; })()",
    "breakdown": "value",

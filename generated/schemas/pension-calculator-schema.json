{
  "toolName": "pension-calculator",
  "inputs": [
    {
      "id": "currentAge",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Your current age in years.",
      "label_i18n": {
        "en": "Current Age",
        "tr": "Current Age",
        "de": "Current Age",
        "fr": "Current Age",
        "es": "Current Age",
        "ar": "Current Age"
      }
    },
    {
      "id": "retirementAge",
      "label": "Retirement Age",
      "type": "number",
      "unit": "years",
      "default": 65,
      "businessContext": "Age at which you plan to retire.",
      "label_i18n": {
        "en": "Retirement Age",
        "tr": "Retirement Age",
        "de": "Retirement Age",
        "fr": "Retirement Age",
        "es": "Retirement Age",
        "ar": "Retirement Age"
      }
    },
    {
      "id": "currentSavings",
      "label": "Current Pension Savings",
      "type": "number",
      "unit": "TRY",
      "default": 50000,
      "businessContext": "Total amount already saved in your pension fund.",
      "label_i18n": {
        "en": "Current Pension Savings",
        "tr": "Current Pension Savings",
        "de": "Current Pension Savings",
        "fr": "Current Pension Savings",
        "es": "Current Pension Savings",
        "ar": "Current Pension Savings"
      }
    },
    {
      "id": "monthlyContribution",
      "label": "Monthly Contribution",
      "type": "number",
      "unit": "TRY",
      "default": 1000,
      "businessContext": "Amount you contribute to your pension each month.",
      "label_i18n": {
        "en": "Monthly Contribution",
        "tr": "Monthly Contribution",
        "de": "Monthly Contribution",
        "fr": "Monthly Contribution",
        "es": "Monthly Contribution",
        "ar": "Monthly Contribution"
      }
    },
    {
      "id": "annualReturnRate",
      "label": "Expected Annual Return",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected annual return rate on your pension investments.",
      "label_i18n": {
        "en": "Expected Annual Return",
        "tr": "Expected Annual Return",
        "de": "Expected Annual Return",
        "fr": "Expected Annual Return",
        "es": "Expected Annual Return",
        "ar": "Expected Annual Return"
      }
    },
    {
      "id": "inflationRate",
      "label": "Expected Inflation Rate",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "Expected annual inflation rate to adjust for real values.",
      "label_i18n": {
        "en": "Expected Inflation Rate",
        "tr": "Expected Inflation Rate",
        "de": "Expected Inflation Rate",
        "fr": "Expected Inflation Rate",
        "es": "Expected Inflation Rate",
        "ar": "Expected Inflation Rate"
      }
    }
  ],
  "formulas": {
    "yearsToRetirement": "(retirementAge - currentAge)",
    "monthlyReturnRate": "(annualReturnRate / 100 / 12)",
    "totalMonths": "(yearsToRetirement * 12)"
  },
  "outputs": {
    "primary": "totalMonths",
    "breakdown": [
      "realProjectedFund",
      "totalNominalFund",
      "futureValueSavings",
      "futureValueAnnuity",
      "yearsToRetirement"
    ],

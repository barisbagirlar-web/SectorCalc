      }
    },
    {
      "id": "day_of_year",
      "label": "Day of Year (1-365)",
      "type": "number",
      "unit": "days",
      "default": 172,
      "businessContext": "Day of the year (1 = Jan 1). Used for solar declination calculation.",
      "label_i18n": {
        "en": "Day of Year (1-365)",
        "tr": "Day of Year (1-365)",
        "de": "Day of Year (1-365)",
        "fr": "Day of Year (1-365)",
        "es": "Day of Year (1-365)",
        "ar": "Day of Year (1-365)"
      }
    }
  ],
  "formulas": {
    "solar_declination": "23.45 * Math.sin((360/365) * (day_of_year - 81) * Math.PI / 180)",
    "hour_angle_sunrise": "Math.acos(-Math.tan(latitude * Math.PI / 180) * Math.tan(solar_declination * Math.PI / 180)) * 180 / Math.PI",
    "solar_noon": "12 - (longitude / 15) - timezone_offset",
    "sunrise_solar": "solar_noon - hour_angle_sunrise / 15",
    "sunset_solar": "solar_noon + hour_angle_sunrise / 15",
    "blue_hour_morning_start": "sunrise_solar - 0.5",
    "blue_hour_morning_end": "sunrise_solar",
    "blue_hour_evening_start": "sunset_solar",
    "blue_hour_evening_end": "sunset_solar + 0.5",
    "blue_hour_morning_duration": "blue_hour_morning_end - blue_hour_morning_start",
    "blue_hour_evening_duration": "blue_hour_evening_end - blue_hour_evening_start",
    "_blue_hour_morning_start__hours": "{blue_hour_morning_start} hours",
    "_blue_hour_morning_end__hours": "{blue_hour_morning_end} hours",
    "_blue_hour_evening_start__hours": "{blue_hour_evening_start} hours",
    "_blue_hour_evening_end__hours": "{blue_hour_evening_end} hours",
    "_blue_hour_morning_duration__hours": "{blue_hour_morning_duration} hours",
    "_blue_hour_evening_duration__hours": "{blue_hour_evening_duration} hours"
  },
  "outputs": {
    "primary": "solar_declination",
    "breakdown": [
      "Morning blue hour start (local time): {blue_hour_morning_start} hours",
      "Morning blue hour end (local time): {blue_hour_morning_end} hours",
      "Evening blue hour start (local time): {blue_hour_evening_start} hours",
      "Evening blue hour end (local time): {blue_hour_evening_end} hours",
      "Morning blue hour duration: {blue_hour_morning_duration} hours",
      "Evening blue hour duration: {blue_hour_evening_duration} hours"
    ]
  },

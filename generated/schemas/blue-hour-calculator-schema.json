      "label_i18n": {
        "en": "Timezone Offset from UTC (hours)",
        "tr": "Timezone Offset from UTC (hours)",
        "de": "Timezone Offset from UTC (hours)",
        "fr": "Timezone Offset from UTC (hours)",

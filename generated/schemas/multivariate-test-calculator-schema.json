  "formulas": {
    "grandMean": "(mean1 + mean2 + mean3) / 3",
    "ssb": "n * ((mean1 - grandMean) ** 2 + (mean2 - grandMean) ** 2 + (mean3 - grandMean) ** 2)",
    "ssw": "(n - 1) * sd1 ** 2 + (n - 1) * sd2 ** 2 + (n - 1) * sd3 ** 2",
    "msb": "ssb / 2",
    "msw": "ssw / (3 * (n - 1))",
    "f": "msb / msw"
  },

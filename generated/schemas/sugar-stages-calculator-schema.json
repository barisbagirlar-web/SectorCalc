  "formulas": {
    "supersaturation": "(brix * purity) / (temperature * 100)",
    "crystalYield": "seedMass * supersaturation * residenceTime / 10",
    "crystalYieldPercent": "(crystalYield / (crystalYield + 1000)) * 100",
    "finalCrystalSize": "seedSize * (1 + supersaturation * residenceTime * 0.1)",
    "evaporationRate": "(100 + vacuumPressure) * (temperature / 100) * 0.5"
  },
  "outputs": {
    "primary": "crystalYieldPercent",
    "breakdown": [
      "supersaturation",
      "finalCrystalSize",
      "evaporationRate"
    ],

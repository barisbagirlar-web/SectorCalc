{
  "toolName": "medicaid-calculator",
  "inputs": [
    {
      "id": "grossIncome",
      "label": "Annual Gross Income",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Total household income before taxes",
      "label_i18n": {
        "en": "Annual Gross Income",
        "tr": "Annual Gross Income",
        "de": "Annual Gross Income",
        "fr": "Annual Gross Income",
        "es": "Annual Gross Income",
        "ar": "Annual Gross Income"
      }
    },
    {
      "id": "otherIncome",
      "label": "Other Income",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Additional non-taxable income",
      "label_i18n": {
        "en": "Other Income",
        "tr": "Other Income",
        "de": "Other Income",
        "fr": "Other Income",
        "es": "Other Income",
        "ar": "Other Income"
      }
    },
    {
      "id": "deductions",
      "label": "Allowable Deductions",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Total deductions (e.g., child care, alimony paid)",
      "label_i18n": {
        "en": "Allowable Deductions",
        "tr": "Allowable Deductions",
        "de": "Allowable Deductions",
        "fr": "Allowable Deductions",
        "es": "Allowable Deductions",
        "ar": "Allowable Deductions"
      }
    },
    {
      "id": "dependents",
      "label": "Household Size",
      "type": "number",
      "unit": "persons",
      "default": 1,
      "businessContext": "Number of people in household, including applicant",
      "label_i18n": {
        "en": "Household Size",
        "tr": "Household Size",
        "de": "Household Size",
        "fr": "Household Size",
        "es": "Household Size",
        "ar": "Household Size"
      }
    },
    {
      "id": "thresholdPercent",
      "label": "Income Eligibility Threshold",
      "type": "number",
      "unit": "%",
      "default": 138,
      "businessContext": "Maximum MAGI as percentage of Federal Poverty Level for eligibility (e.g., 138% for Medicaid expansion)",
      "label_i18n": {
        "en": "Income Eligibility Threshold",
        "tr": "Income Eligibility Threshold",
        "de": "Income Eligibility Threshold",
        "fr": "Income Eligibility Threshold",
        "es": "Income Eligibility Threshold",
        "ar": "Income Eligibility Threshold"
      }
    }
  ],
  "formulas": {
    "netIncome": "grossIncome + otherIncome - deductions",
    "fpl": "15060 + (dependents - 1) * 5380",
    "incomePercent": "(netIncome / fpl) * 100",
    "eligible": "incomePercent <= thresholdPercent ? 1 : 0"
  },
  "outputs": {
    "primary": "eligible",
    "breakdown": [
      "netIncome",
      "fpl",
      "incomePercent"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "eligible",
    "unit": "USD",
    "breakdownUnits": {
      "incomePercent": "%"
    }
  },

{
  "toolName": "brrrr-strategy-calculator",
  "inputs": [
    {
      "id": "purchasePrice",
      "label": "Purchase Price",
      "type": "number",
      "unit": "€",
      "default": 100000,
      "businessContext": "The price at which the property is purchased.",
      "label_i18n": {
        "en": "Purchase Price",
        "tr": "Purchase Price",
        "de": "Purchase Price",
        "fr": "Purchase Price",
        "es": "Purchase Price",
        "ar": "Purchase Price"
      }
    },
    {
      "id": "rehabCost",
      "label": "Rehab Cost",
      "type": "number",
      "unit": "€",
      "default": 20000,
      "businessContext": "Total cost of renovations and repairs.",
      "label_i18n": {
        "en": "Rehab Cost",
        "tr": "Rehab Cost",
        "de": "Rehab Cost",
        "fr": "Rehab Cost",
        "es": "Rehab Cost",
        "ar": "Rehab Cost"
      }
    },
    {
      "id": "arv",
      "label": "After Repair Value (ARV)",
      "type": "number",
      "unit": "€",
      "default": 150000,
      "businessContext": "Estimated market value of the property after renovations.",
      "label_i18n": {
        "en": "After Repair Value (ARV)",
        "tr": "After Repair Value (ARV)",
        "de": "After Repair Value (ARV)",
        "fr": "After Repair Value (ARV)",
        "es": "After Repair Value (ARV)",
        "ar": "After Repair Value (ARV)"
      }
    },
    {
      "id": "monthlyRent",
      "label": "Monthly Rent",
      "type": "number",
      "unit": "€",
      "default": 1200,
      "businessContext": "Expected monthly rental income.",
      "label_i18n": {
        "en": "Monthly Rent",
        "tr": "Monthly Rent",
        "de": "Monthly Rent",
        "fr": "Monthly Rent",
        "es": "Monthly Rent",
        "ar": "Monthly Rent"
      }
    },
    {
      "id": "operatingExpensePercentage",
      "label": "Operating Expense Percentage",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Percentage of monthly rent reserved for operating expenses (taxes, insurance, maintenance, vacancy, management).",
      "label_i18n": {
        "en": "Operating Expense Percentage",
        "tr": "Operating Expense Percentage",
        "de": "Operating Expense Percentage",
        "fr": "Operating Expense Percentage",
        "es": "Operating Expense Percentage",
        "ar": "Operating Expense Percentage"
      }
    },
    {
      "id": "refinanceLTV",
      "label": "Refinance LTV",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "Loan-to-value ratio for refinancing, expressed as a percentage of ARV.",
      "label_i18n": {
        "en": "Refinance LTV",
        "tr": "Refinance LTV",
        "de": "Refinance LTV",
        "fr": "Refinance LTV",
        "es": "Refinance LTV",
        "ar": "Refinance LTV"
      }
    },
    {
      "id": "refinanceRate",
      "label": "Refinance Interest Rate",
      "type": "number",
      "unit": "% p.a.",
      "default": 4.5,
      "businessContext": "Annual interest rate for the refinance mortgage.",
      "label_i18n": {
        "en": "Refinance Interest Rate",
        "tr": "Refinance Interest Rate",
        "de": "Refinance Interest Rate",
        "fr": "Refinance Interest Rate",
        "es": "Refinance Interest Rate",
        "ar": "Refinance Interest Rate"
      }
    },
    {
      "id": "loanTerm",
      "label": "Loan Term",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Duration of the refinance loan in years.",
      "label_i18n": {
        "en": "Loan Term",
        "tr": "Loan Term",
        "de": "Loan Term",
        "fr": "Loan Term",
        "es": "Loan Term",
        "ar": "Loan Term"
      }
    }
  ],
  "formulas": {
    "totalInvestment": "purchasePrice + rehabCost",
    "refinanceAmount": "arv * refinanceLTV / 100",
    "cashInvested": "totalInvestment - refinanceAmount",
    "monthlyInterestRate": "refinanceRate / 100 / 12",
    "numberOfPayments": "loanTerm * 12",
    "monthlyOperatingExpenses": "monthlyRent * operatingExpensePercentage / 100",
    "equityGained": "arv - purchasePrice - rehabCost"
  },
  "outputs": {
    "primary": "equityGained",
    "breakdown": [
      "annualCashFlow",
      "cashOnCashReturn",
      "equityGained",
      "cashInvested"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "equityGained"
  },
  "category": "Maliyet & Bütçeleme",

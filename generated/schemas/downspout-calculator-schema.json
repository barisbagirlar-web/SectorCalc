{
  "toolName": "downspout-calculator",
  "inputs": [
    {
      "id": "roofLength",
      "label": "Roof Length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Length of the roof area draining to the downspout.",
      "label_i18n": {
        "en": "Roof Length",
        "tr": "Roof Length",
        "de": "Roof Length",
        "fr": "Roof Length",
        "es": "Roof Length",
        "ar": "Roof Length"
      }
    },
    {
      "id": "roofWidth",
      "label": "Roof Width",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Width of the roof area draining to the downspout.",
      "label_i18n": {
        "en": "Roof Width",
        "tr": "Roof Width",
        "de": "Roof Width",
        "fr": "Roof Width",
        "es": "Roof Width",
        "ar": "Roof Width"
      }
    },
    {
      "id": "rainfallIntensity",
      "label": "Rainfall Intensity",
      "type": "number",
      "unit": "mm/hr",
      "default": 50,
      "businessContext": "Design rainfall intensity for the geographical location.",
      "label_i18n": {
        "en": "Rainfall Intensity",
        "tr": "Rainfall Intensity",
        "de": "Rainfall Intensity",
        "fr": "Rainfall Intensity",
        "es": "Rainfall Intensity",
        "ar": "Rainfall Intensity"
      }
    },
    {
      "id": "downspoutDiameter",
      "label": "Downspout Diameter",
      "type": "number",
      "unit": "mm",
      "default": 100,
      "businessContext": "Inner diameter of the downspout pipe.",
      "label_i18n": {
        "en": "Downspout Diameter",
        "tr": "Downspout Diameter",
        "de": "Downspout Diameter",
        "fr": "Downspout Diameter",
        "es": "Downspout Diameter",
        "ar": "Downspout Diameter"
      }
    },
    {
      "id": "efficiencyFactor",
      "label": "Efficiency Factor",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Reduction factor accounting for bends, obstructions, and installation imperfections.",
      "label_i18n": {
        "en": "Efficiency Factor",
        "tr": "Efficiency Factor",
        "de": "Efficiency Factor",
        "fr": "Efficiency Factor",
        "es": "Efficiency Factor",
        "ar": "Efficiency Factor"
      }
    }
  ],
  "formulas": {
    "totalFlow": "roofWidth * roofLength * rainfallIntensity / 3600",
    "downspoutCapacity": "(Math.PI * efficiencyFactor * downspoutDiameter ** 2) / 400000",
    "requiredDownspoutsFloat": "totalFlow / downspoutCapacity"
  },
  "outputs": {
    "primary": "requiredDownspoutsFloat",
    "breakdown": [
      "totalFlow",
      "downspoutCapacity",
      "requiredDownspoutsFloat"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "requiredDownspoutsFloat"
  },

{
  "toolName": "atomic-mass-to-kg-calculator",
  "inputs": [
    {
      "id": "atomicMassU",
      "label": "Atomik Kütle (u)",
      "type": "number",
      "unit": "u",
      "default": 1,
      "businessContext": "Tek bir atom veya molekülün kütlesi, atomik kütle birimi (u) cinsinden.",
      "label_i18n": {
        "en": "Atomik Kütle (u)",

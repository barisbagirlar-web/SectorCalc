    },
    {
      "id": "numberOfEntities",
      "label": "Varlık Sayısı",
      "type": "number",
      "unit": "adet",
      "default": 6.02214076e+23,
      "businessContext": "Dönüştürülecek toplam atom/molekül sayısı.",
      "label_i18n": {
        "en": "Varlık Sayısı",
        "tr": "Varlık Sayısı",
        "de": "Varlık Sayısı",
        "fr": "Varlık Sayısı",
        "es": "Varlık Sayısı",
        "ar": "Varlık Sayısı"
      }
    },
    {
      "id": "conversionFactor",
      "label": "Dönüşüm Faktörü (u → kg)",
      "type": "number",
      "unit": "kg/u",
      "default": 1.6605390666e-27,
      "businessContext": "1 atomik kütle biriminin kilogram cinsinden karşılığı (CODATA 2018).",
      "label_i18n": {
        "en": "Dönüşüm Faktörü (u → kg)",
        "tr": "Dönüşüm Faktörü (u → kg)",
        "de": "Dönüşüm Faktörü (u → kg)",
        "fr": "Dönüşüm Faktörü (u → kg)",
        "es": "Dönüşüm Faktörü (u → kg)",
        "ar": "Dönüşüm Faktörü (u → kg)"
      }
    },
    {
      "id": "batchSize",
      "label": "Parti Büyüklüğü (İsteğe bağlı)",
      "type": "number",
      "unit": "parti",
      "default": 1,
      "businessContext": "Eğer birden fazla parti varsa çarpan olarak kullanılır.",
      "label_i18n": {
        "en": "Parti Büyüklüğü (İsteğe bağlı)",
        "tr": "Parti Büyüklüğü (İsteğe bağlı)",
        "de": "Parti Büyüklüğü (İsteğe bağlı)",
        "fr": "Parti Büyüklüğü (İsteğe bağlı)",
        "es": "Parti Büyüklüğü (İsteğe bağlı)",
        "ar": "Parti Büyüklüğü (İsteğe bağlı)"
      }
    },
    {
      "id": "outputUnitMultiplier",
      "label": "Çıktı Birim Çarpanı",
      "type": "number",
      "unit": "çarpan",
      "default": 1,
      "businessContext": "Çıktı birimini kg'dan başka bir birime dönüştürmek için çarpan (örn: 1000 g için, 1000000 mg için).",
      "label_i18n": {
        "en": "Çıktı Birim Çarpanı",
        "tr": "Çıktı Birim Çarpanı",
        "de": "Çıktı Birim Çarpanı",
        "fr": "Çıktı Birim Çarpanı",
        "es": "Çıktı Birim Çarpanı",
        "ar": "Çıktı Birim Çarpanı"
      }
    }
  ],
  "formulas": {
    "mass_Kg": "atomicMassU * numberOfEntities * conversionFactor * batchSize",
    "mass_Grams": "atomicMassU * numberOfEntities * conversionFactor * batchSize * 1000",
    "numberOfMoles": "numberOfEntities / 602214076000000000000000",
    "totalMass": "atomicMassU * numberOfEntities * conversionFactor * batchSize * outputUnitMultiplier"
  },
  "outputs": {
    "primary": "totalMass",
    "breakdown": [
      "mass_Kg",
      "mass_Grams",
      "numberOfMoles"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalMass",
    "unit": "u",
    "breakdownUnits": {
      "mass_Kg": "kg",
      "mass_Grams": "g"
    }
  },

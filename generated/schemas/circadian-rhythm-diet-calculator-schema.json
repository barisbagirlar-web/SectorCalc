{
  "toolName": "circadian-rhythm-diet-calculator",
  "inputs": [
    {
      "id": "chronotype",
      "label": "Chronotype Score (1-5)",
      "type": "number",
      "unit": "score",
      "default": 3,
      "businessContext": "Morningness-Eveningness score where 1=Extreme Morning, 5=Extreme Evening",
      "label_i18n": {
        "en": "Chronotype Score (1-5)",
        "tr": "Chronotype Score (1-5)",
        "de": "Chronotype Score (1-5)",
        "fr": "Chronotype Score (1-5)",
        "es": "Chronotype Score (1-5)",
        "ar": "Chronotype Score (1-5)"
      }
    },
    {
      "id": "shiftStart",
      "label": "Shift Start Time (hour)",
      "type": "number",
      "unit": "hour",
      "default": 8,
      "businessContext": "Work shift start in 24-hour format (e.g., 8.5 for 08:30)",
      "label_i18n": {
        "en": "Shift Start Time (hour)",
        "tr": "Shift Start Time (hour)",
        "de": "Shift Start Time (hour)",
        "fr": "Shift Start Time (hour)",
        "es": "Shift Start Time (hour)",
        "ar": "Shift Start Time (hour)"
      }
    },
    {
      "id": "mealCount",
      "label": "Number of Meals",
      "type": "number",
      "unit": "meals",
      "default": 3,
      "businessContext": "Total number of meals per day (including snacks)",
      "label_i18n": {
        "en": "Number of Meals",
        "tr": "Number of Meals",
        "de": "Number of Meals",
        "fr": "Number of Meals",
        "es": "Number of Meals",
        "ar": "Number of Meals"
      }
    },
    {
      "id": "fastingWindow",
      "label": "Fasting Window (hours)",
      "type": "number",
      "unit": "hours",
      "default": 12,
      "businessContext": "Duration between last meal and first meal of the next day",
      "label_i18n": {
        "en": "Fasting Window (hours)",
        "tr": "Fasting Window (hours)",
        "de": "Fasting Window (hours)",
        "fr": "Fasting Window (hours)",
        "es": "Fasting Window (hours)",
        "ar": "Fasting Window (hours)"
      }
    },
    {
      "id": "costPerMeal",
      "label": "Average Cost per Meal (EUR)",
      "type": "number",
      "unit": "EUR",
      "default": 5,
      "businessContext": "Estimated average cost per meal including preparation and ingredients",
      "label_i18n": {
        "en": "Average Cost per Meal (EUR)",
        "tr": "Average Cost per Meal (EUR)",
        "de": "Average Cost per Meal (EUR)",
        "fr": "Average Cost per Meal (EUR)",
        "es": "Average Cost per Meal (EUR)",
        "ar": "Average Cost per Meal (EUR)"
      }
    },
    {
      "id": "days",
      "label": "Number of Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Planning period in days",
      "label_i18n": {
        "en": "Number of Days",
        "tr": "Number of Days",
        "de": "Number of Days",
        "fr": "Number of Days",
        "es": "Number of Days",
        "ar": "Number of Days"
      }
    }
  ],
  "formulas": {
    "dailyCost": "mealCount * costPerMeal",
    "totalCost": "dailyCost * days",
    "mealInterval": "mealCount > 1 ? (24 - fastingWindow) / (mealCount - 1) : 0",
    "firstMealTime": "((shiftStart - chronotype * 0.5) % 24 + 24) % 24"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "dailyCost",
      "mealInterval",
      "firstMealTime"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "firstMealTime"
  },
  "category": "Maliyet & Bütçeleme",

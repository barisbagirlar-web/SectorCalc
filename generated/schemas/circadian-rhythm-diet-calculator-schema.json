        "tr": "Sabahçıl-Akşamcıl puanı; 1=Aşırı Sabahçıl, 5=Aşırı Akşamcıl",
        "de": "Morgen-Typ/Abend-Typ-Score, wobei 1=Extremer Morgen-Typ, 5=Extremer Abend-Typ"
      }
    },
    {
      "id": "shiftStart",
      "label": "Shift Start Time (hour)",
      "type": "number",
      "unit": "hour",
      "default": 8,
      "businessContext": "Work shift start in 24-hour format (e.g., 8.5 for 08:30)",
      "label_i18n": {

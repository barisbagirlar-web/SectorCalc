        "ar": "Shift Start Time (hour)"
      },
      "businessContext_i18n": {
        "en": "Work shift start in 24-hour format (e.g., 8.5 for 08:30)",
        "tr": "İş vardiyası başlangıcı 24 saat formatında (örn. 8,5, 08:30 için)",
        "de": "Arbeitsschichtbeginn im 24-Stunden-Format (z.B. 8,5 für 08:30)"
      }
    },
    {

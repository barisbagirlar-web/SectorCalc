      "unit": "meals",
      "default": 3,
      "businessContext": "Total number of meals per day (including snacks)",
      "label_i18n": {
        "en": "Number of Meals",
        "tr": "Öğün Sayısı",
        "de": "Anzahl der Mahlzeiten",
        "fr": "Number of Meals",
        "es": "Number of Meals",
        "ar": "Number of Meals"
      },
      "businessContext_i18n": {
        "en": "Total number of meals per day (including snacks)",
        "tr": "Günlük toplam öğün sayısı (atıştırmalıklar dahil)",
        "de": "Gesamtzahl der Mahlzeiten pro Tag (inkl. Snacks)"
      }
    },
    {
      "id": "fastingWindow",
      "label": "Fasting Window (hours)",
      "type": "number",
      "unit": "hours",
      "default": 12,
      "businessContext": "Duration between last meal and first meal of the next day",
      "label_i18n": {
        "en": "Fasting Window (hours)",
        "tr": "Oruç Aralığı (saat)",
        "de": "Fastenfenster (Stunden)",
        "fr": "Fasting Window (hours)",
        "es": "Fasting Window (hours)",
        "ar": "Fasting Window (hours)"
      },
      "businessContext_i18n": {
        "en": "Duration between last meal and first meal of the next day",
        "tr": "Son öğün ile ertesi günün ilk öğünü arasındaki süre",
        "de": "Dauer zwischen letzter Mahlzeit und erster Mahlzeit des nächsten Tages"
      }
    },
    {
      "id": "costPerMeal",
      "label": "Average Cost per Meal (EUR)",
      "type": "number",
      "unit": "EUR",
      "default": 5,
      "businessContext": "Estimated average cost per meal including preparation and ingredients",
      "label_i18n": {
        "en": "Average Cost per Meal (EUR)",
        "tr": "Öğün Başına Ortalama Maliyet (EUR)",
        "de": "Durchschnittliche Kosten pro Mahlzeit (EUR)",
        "fr": "Average Cost per Meal (EUR)",
        "es": "Average Cost per Meal (EUR)",
        "ar": "Average Cost per Meal (EUR)"
      },
      "businessContext_i18n": {
        "en": "Estimated average cost per meal including preparation and ingredients",
        "tr": "Hazırlık ve malzemeler dahil öğün başına tahmini ortalama maliyet",
        "de": "Geschätzte durchschnittliche Kosten pro Mahlzeit inkl. Zubereitung und Zutaten"
      }
    },
    {
      "id": "days",
      "label": "Number of Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Planning period in days",
      "label_i18n": {
        "en": "Number of Days",
        "tr": "Gün Sayısı",
        "de": "Anzahl der Tage",
        "fr": "Number of Days",
        "es": "Number of Days",
        "ar": "Number of Days"
      },
      "businessContext_i18n": {
        "en": "Planning period in days",
        "tr": "Planlama dönemi (gün)",
        "de": "Planungszeitraum in Tagen"
      }
    }
  ],
  "formulas": {
    "dailyCost": "mealCount * costPerMeal",
    "totalCost": "dailyCost * days",
    "mealInterval": "mealCount > 1 ? (24 - fastingWindow) / (mealCount - 1) : 0",
    "firstMealTime": "((shiftStart - chronotype * 0.5) % 24 + 24) % 24"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "dailyCost",
      "mealInterval",
      "firstMealTime"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "firstMealTime",
    "unit": "score"
  },

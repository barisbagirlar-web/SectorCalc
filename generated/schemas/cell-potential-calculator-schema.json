        "de": "Temperature (T)",
        "fr": "Temperature (T)",
        "es": "Temperature (T)",
        "ar": "Temperature (T)"
      }
    },
    {
      "id": "numberOfElectrons",
      "label": "Number of Electrons Transferred (n)",
      "type": "number",
      "unit": "dimensionless",
      "default": 2,
      "businessContext": "Number of moles of electrons transferred according to the balanced redox reaction.",
      "label_i18n": {
        "en": "Number of Electrons Transferred (n)",
        "tr": "Number of Electrons Transferred (n)",
        "de": "Number of Electrons Transferred (n)",
        "fr": "Number of Electrons Transferred (n)",
        "es": "Number of Electrons Transferred (n)",
        "ar": "Number of Electrons Transferred (n)"
      }
    },
    {
      "id": "reactionQuotient",
      "label": "Reaction Quotient (Q)",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "Ratio of product activities to reactant activities at given concentrations/pressures. For aA + bB → cC + dD, Q = [C]^c[D]^d / [A]^a[B]^b.",
      "label_i18n": {
        "en": "Reaction Quotient (Q)",
        "tr": "Reaction Quotient (Q)",
        "de": "Reaction Quotient (Q)",
        "fr": "Reaction Quotient (Q)",
        "es": "Reaction Quotient (Q)",
        "ar": "Reaction Quotient (Q)"
      }
    }
  ],
  "formulas": {
    "standardCellPotential": "cathodeStandardPotential - anodeStandardPotential",
    "nernstCorrection": "(8.314 * temperature / (numberOfElectrons * 96485)) * Math.log(reactionQuotient)",
    "cellPotential": "standardCellPotential - nernstCorrection"
  },
  "outputs": {
    "primary": "cellPotential",
    "breakdown": [
      "standardCellPotential",
      "nernstCorrection"
    ]
  },

        "es": "Anode Standard Reduction Potential (E°_anode)",
        "ar": "Anode Standard Reduction Potential (E°_anode)"
      }
    },
    {
      "id": "temperature",
      "label": "Temperature (T)",
      "type": "number",
      "unit": "K",

    },
    {
      "id": "activityLevel",
      "label": "Activity Level",
      "type": "number",
      "unit": "multiplier",
      "default": 1.2,
      "businessContext": "Physical activity factor: 1.2 sedentary, 1.375 lightly active, 1.55 moderately active, 1.725 very active, 1.9 extra active.",
      "label_i18n": {
        "en": "Activity Level",
        "tr": "Activity Level",
        "de": "Activity Level",
        "fr": "Activity Level",

    },
    {
      "id": "dailyCalorieIntake",
      "label": "Daily Calorie Intake",
      "type": "number",
      "unit": "kcal/day",
      "default": 2000,
      "businessContext": "Average daily calorie consumption.",
      "label_i18n": {
        "en": "Daily Calorie Intake",
        "tr": "Daily Calorie Intake",
        "de": "Daily Calorie Intake",
        "fr": "Daily Calorie Intake",
        "es": "Daily Calorie Intake",
        "ar": "Daily Calorie Intake"
      }
    }
  ],
  "formulas": {
    "weightDiff_kg": "currentWeight_kg - goalWeight_kg",
    "bmr": "gender === 1 ? (10 * currentWeight_kg + 6.25 * height_cm - 5 * age + 5) : (10 * currentWeight_kg + 6.25 * height_cm - 5 * age - 161)",
    "tdee": "bmr * activityLevel",
    "calorieDeficit": "tdee - dailyCalorieIntake",
    "estimatedDays": "Math.round((weightDiff_kg * 7700) / calorieDeficit)",
    "estimatedWeeks": "estimatedDays / 7",
    "estimatedMonths": "estimatedDays / 30.4375"
  },
  "outputs": {
    "primary": "estimatedDays",
    "breakdown": [
      "weightDiff_kg",
      "calorieDeficit",
      "estimatedWeeks",
      "estimatedMonths"
    ]
  },

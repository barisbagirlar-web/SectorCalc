  "formulas": {
    "totalSeconds": "days * 86400 + hours * 3600 + minutes * 60 + seconds",
    "quarterDays": "totalSeconds / 21600",
    "fullShifts": "Math.floor(totalSeconds / 21600)",
    "remainingQuarterDaySeconds": "totalSeconds % 21600",
    "remainingHours": "remainingQuarterDaySeconds / 3600"
  },
  "outputs": {
    "primary": "quarterDays",
    "breakdown": [
      "fullShifts",
      "remainingHours"
    ]
  },

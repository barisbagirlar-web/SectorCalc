{
  "toolName": "post-hole-calculator",
  "inputs": [
    {
      "id": "holeDiameter",
      "label": "Hole Diameter",
      "type": "number",
      "unit": "cm",
      "default": 30,
      "businessContext": "Diameter of the cylindrical hole for the post, typically 3 times the post width.",
      "label_i18n": {
        "en": "Hole Diameter",
        "tr": "Hole Diameter",
        "de": "Hole Diameter",
        "fr": "Hole Diameter",
        "es": "Hole Diameter",
        "ar": "Hole Diameter"
      }
    },
    {
      "id": "holeDepth",
      "label": "Hole Depth",
      "type": "number",
      "unit": "cm",
      "default": 60,
      "businessContext": "Depth of the hole, usually 1/3 to 1/2 of the above-ground post height.",
      "label_i18n": {
        "en": "Hole Depth",
        "tr": "Hole Depth",
        "de": "Hole Depth",
        "fr": "Hole Depth",
        "es": "Hole Depth",
        "ar": "Hole Depth"
      }
    },
    {
      "id": "postSide",
      "label": "Post Side Width",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Width of a square post. For round posts, use diameter equivalent.",
      "label_i18n": {
        "en": "Post Side Width",
        "tr": "Post Side Width",
        "de": "Post Side Width",
        "fr": "Post Side Width",
        "es": "Post Side Width",
        "ar": "Post Side Width"
      }
    },
    {
      "id": "numberOfPosts",
      "label": "Number of Posts",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total number of post holes to be filled.",
      "label_i18n": {
        "en": "Number of Posts",
        "tr": "Number of Posts",
        "de": "Number of Posts",
        "fr": "Number of Posts",
        "es": "Number of Posts",
        "ar": "Number of Posts"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Extra percentage of concrete to order for spillage, over-digging, etc.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "holeVolume": "Math.PI * (holeDiameter / 2) ** 2 * holeDepth",
    "postVolume": "postSide ** 2 * holeDepth",
    "concretePerHole": "holeVolume - postVolume",
    "totalConcrete": "concretePerHole * numberOfPosts",
    "totalWithWaste": "totalConcrete * (1 + wasteFactor / 100)",
    "totalCubicMeters": "totalWithWaste / 1000000"
  },
  "outputs": {
    "primary": "totalCubicMeters",
    "breakdown": [
      "holeVolume.toFixed(0) + ' cm³'",
      "postVolume.toFixed(0) + ' cm³'",
      "concretePerHole.toFixed(0) + ' cm³ per hole'",
      "totalConcrete.toFixed(0) + ' cm³'",
      "totalWithWaste.toFixed(0) + ' cm³ (with waste)'",
      "totalCubicMeters.toFixed(4) + ' m³'"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "category": "Sürdürülebilirlik",
  "sector": "Matematik & Geometri",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "sustainability-resource-esg",
  "sectorId": "matematik",
  "profession": "Matematikçi",
  "categoryId": "sustainability",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

{
  "toolName": "doppler-effect-calculator",
  "inputs": [
    {
      "id": "sourceFrequency",
      "label": "Source Frequency",
      "type": "number",
      "unit": "Hz",
      "default": 1000,
      "businessContext": "Frequency emitted by the source in Hertz",
      "label_i18n": {
        "en": "Source Frequency",
        "tr": "Source Frequency",
        "de": "Source Frequency",
        "fr": "Source Frequency",
        "es": "Source Frequency",
        "ar": "Source Frequency"
      }
    },
    {
      "id": "waveSpeed",
      "label": "Wave Speed",
      "type": "number",
      "unit": "m/s",
      "default": 343,
      "businessContext": "Speed of sound in the medium (e.g., 343 m/s in air at 20°C)",
      "label_i18n": {
        "en": "Wave Speed",
        "tr": "Wave Speed",
        "de": "Wave Speed",
        "fr": "Wave Speed",
        "es": "Wave Speed",
        "ar": "Wave Speed"
      }
    },
    {
      "id": "sourceVelocity",
      "label": "Source Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "Velocity of the source relative to the medium; positive when moving towards the observer",
      "label_i18n": {
        "en": "Source Velocity",
        "tr": "Source Velocity",
        "de": "Source Velocity",
        "fr": "Source Velocity",
        "es": "Source Velocity",
        "ar": "Source Velocity"
      }
    },
    {
      "id": "observerVelocity",
      "label": "Observer Velocity",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "Velocity of the observer relative to the medium; positive when moving towards the source",
      "label_i18n": {
        "en": "Observer Velocity",
        "tr": "Observer Velocity",
        "de": "Observer Velocity",
        "fr": "Observer Velocity",
        "es": "Observer Velocity",
        "ar": "Observer Velocity"
      }
    }
  ],
  "formulas": {
    "numerator": "waveSpeed + observerVelocity",
    "denominator": "waveSpeed - sourceVelocity",
    "observedFrequency": "sourceFrequency * numerator / denominator"
  },
  "outputs": {
    "primary": "observedFrequency",
    "breakdown": [
      "numerator",
      "denominator",
      "observedFrequency"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "observedFrequency"
  },

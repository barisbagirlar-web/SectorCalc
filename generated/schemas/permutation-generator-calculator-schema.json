  "formulas": {
    "factorial": "function factorial(num) { if (num <= 1) return 1; return num * factorial(num - 1); }",
    "factorialN": "factorial(n)",
    "factorialR": "factorial(r)",
    "factorialNminusR": "factorial(n - r)",
    "totalArrangements": "orderMatters == 1 && repetitionAllowed == 0 ? factorialN / factorialNminusR : (orderMatters == 0 && repetitionAllowed == 0 ? factorialN / (factorialR * factorialNminusR) : (orderMatters == 1 && repetitionAllowed == 1 ? Math.pow(n, r) : factorial(n + r - 1) / (factorial(r) * factorial(n - 1))))",
    "factorial_of_n": "factorialN",
    "factorial_of_r": "factorialR",
    "factorial_of_n_minus_r": "factorialNminusR",
    "method": "orderMatters == 1 && repetitionAllowed == 0 ? 1 : (orderMatters == 0 && repetitionAllowed == 0 ? 2 : (orderMatters == 1 && repetitionAllowed == 1 ? 3 : 4))"
  },
  "outputs": {
    "primary": "totalArrangements",
    "breakdown": [

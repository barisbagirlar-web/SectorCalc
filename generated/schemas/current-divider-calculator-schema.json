      "businessContext": "Resistance of branch 2"
    },
    {
      "id": "R3",
      "label": "Resistance 3",
      "type": "number",
      "unit": "Ω",
      "default": 0,
      "businessContext": "Resistance of branch 3 (optional, set 0 to omit)"
    },
    {
      "id": "R4",
      "label": "Resistance 4",
      "type": "number",
      "unit": "Ω",
      "default": 0,
      "businessContext": "Resistance of branch 4 (optional, set 0 to omit)"

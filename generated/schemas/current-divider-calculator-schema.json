  "formulas": {
    "I1": "R1 > 0 ? I_total * (1/R1) / ((R1>0?1/R1:0) + (R2>0?1/R2:0) + (R3>0?1/R3:0) + (R4>0?1/R4:0)) : 0",
    "I2": "R2 > 0 ? I_total * (1/R2) / ((R1>0?1/R1:0) + (R2>0?1/R2:0) + (R3>0?1/R3:0) + (R4>0?1/R4:0)) : 0",
    "I3": "R3 > 0 ? I_total * (1/R3) / ((R1>0?1/R1:0) + (R2>0?1/R2:0) + (R3>0?1/R3:0) + (R4>0?1/R4:0)) : 0",
    "I4": "R4 > 0 ? I_total * (1/R4) / ((R1>0?1/R1:0) + (R2>0?1/R2:0) + (R3>0?1/R3:0) + (R4>0?1/R4:0)) : 0"
  },
  "outputs": {
    "primary": "I1",
    "breakdown": [
      "I2",
      "I3",
      "I4"
    ]
  },

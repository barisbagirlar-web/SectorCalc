{
  "toolName": "mach-to-mph-calculator",
  "inputs": [
    {
      "id": "mach",
      "label": "Mach Number",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "The ratio of true airspeed to the speed of sound.",
      "label_i18n": {
        "en": "Mach Number",
        "tr": "Mach Number",
        "de": "Mach Number",
        "fr": "Mach Number",
        "es": "Mach Number",
        "ar": "Mach Number"
      }
    },
    {
      "id": "temperature",
      "label": "Ambient Temperature",
      "type": "number",
      "unit": "°C",
      "default": 15,
      "businessContext": "Outside air temperature in Celsius. Used if 'Use ISA' is 0.",
      "label_i18n": {
        "en": "Ambient Temperature",
        "tr": "Ambient Temperature",
        "de": "Ambient Temperature",
        "fr": "Ambient Temperature",
        "es": "Ambient Temperature",
        "ar": "Ambient Temperature"
      }
    },
    {
      "id": "altitude",
      "label": "Altitude",
      "type": "number",
      "unit": "ft",
      "default": 0,
      "businessContext": "Altitude above sea level. Required for ISA temperature calculation.",
      "label_i18n": {
        "en": "Altitude",
        "tr": "Altitude",
        "de": "Altitude",
        "fr": "Altitude",
        "es": "Altitude",
        "ar": "Altitude"
      }
    },
    {
      "id": "useISA",
      "label": "Use ISA Temperature",
      "type": "number",
      "unit": "0=No, 1=Yes",
      "default": 0,
      "businessContext": "Set to 1 to calculate standard temperature from altitude. Otherwise, use the input temperature.",
      "label_i18n": {
        "en": "Use ISA Temperature",
        "tr": "Use ISA Temperature",
        "de": "Use ISA Temperature",
        "fr": "Use ISA Temperature",
        "es": "Use ISA Temperature",
        "ar": "Use ISA Temperature"
      }
    }
  ],
  "formulas": {
    "temperatureEffective": "temperature + useISA * ((15 - 0.00198 * altitude) - temperature)",
    "speedOfSoundMph": "761.2 * Math.sqrt((temperatureEffective + 273.15) / 288.15)",
    "milesPerHour": "mach * speedOfSoundMph"
  },
  "outputs": {
    "primary": "milesPerHour",
    "breakdown": [
      "speedOfSoundMph",
      "temperatureEffective"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

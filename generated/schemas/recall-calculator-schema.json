    {
      "id": "costPerRecallUnit",
      "label": "Birim Geri Çağırma Maliyeti",
      "type": "number",
      "unit": "TL",
      "default": 50,
      "businessContext": "Birim başına geri çağırma işlem maliyeti (lojistik, iletişim)",
      "label_i18n": {
        "en": "Birim Geri Çağırma Maliyeti",

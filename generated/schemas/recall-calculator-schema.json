      }
    },
    {
      "id": "fixedRecallCost",
      "label": "Sabit Geri Çağırma Maliyeti",
      "type": "number",
      "unit": "TL",
      "default": 5000,
      "businessContext": "Sabit yönetim ve organizasyon maliyeti",
      "label_i18n": {
        "en": "Sabit Geri Çağırma Maliyeti",
        "tr": "Sabit Geri Çağırma Maliyeti",
        "de": "Sabit Geri Çağırma Maliyeti",
        "fr": "Sabit Geri Çağırma Maliyeti",
        "es": "Sabit Geri Çağırma Maliyeti",
        "ar": "Sabit Geri Çağırma Maliyeti"
      }
    },
    {
      "id": "replacementCostPerUnit",
      "label": "Birim Değiştirme Maliyeti",
      "type": "number",
      "unit": "TL",
      "default": 30,
      "businessContext": "Birim başına değiştirme veya onarım maliyeti",
      "label_i18n": {
        "en": "Birim Değiştirme Maliyeti",
        "tr": "Birim Değiştirme Maliyeti",
        "de": "Birim Değiştirme Maliyeti",
        "fr": "Birim Değiştirme Maliyeti",
        "es": "Birim Değiştirme Maliyeti",
        "ar": "Birim Değiştirme Maliyeti"
      }
    }
  ],
  "formulas": {
    "defectiveUnits": "totalUnitsProduced * (defectRate / 100)",
    "recalledUnits": "defectiveUnits * (recallEffectiveness / 100)",
    "variableRecallCost": "recalledUnits * costPerRecallUnit",
    "totalReplacementCost": "recalledUnits * replacementCostPerUnit",
    "fixedCost": "fixedRecallCost",
    "totalRecallCost": "fixedCost + variableRecallCost + totalReplacementCost"
  },
  "outputs": {
    "primary": "totalRecallCost",
    "breakdown": [
      "defectiveUnits",
      "recalledUnits",
      "variableRecallCost",
      "totalReplacementCost",
      "fixedCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

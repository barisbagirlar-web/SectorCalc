{
  "toolName": "fascia-calculator",
  "inputs": [
    {
      "id": "totalRoofLength",
      "label": "Total roof length",
      "type": "number",
      "unit": "m",
      "default": 10,
      "businessContext": "Total length of roofline requiring fascia boards",
      "label_i18n": {
        "en": "Total roof length",
        "tr": "Total roof length",
        "de": "Total roof length",
        "fr": "Total roof length",
        "es": "Total roof length",
        "ar": "Total roof length"
      }
    },
    {
      "id": "fasciaBoardLength",
      "label": "Fascia board length",
      "type": "number",
      "unit": "m",
      "default": 3.6,
      "businessContext": "Length of a single fascia board",
      "label_i18n": {
        "en": "Fascia board length",
        "tr": "Fascia board length",
        "de": "Fascia board length",
        "fr": "Fascia board length",
        "es": "Fascia board length",
        "ar": "Fascia board length"
      }
    },
    {
      "id": "overlap",
      "label": "Overlap",
      "type": "number",
      "unit": "m",
      "default": 0.05,
      "businessContext": "Overlap length per joint between boards",
      "label_i18n": {
        "en": "Overlap",
        "tr": "Overlap",
        "de": "Overlap",
        "fr": "Overlap",
        "es": "Overlap",
        "ar": "Overlap"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste factor",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Waste percentage to account for cuts and errors",
      "label_i18n": {
        "en": "Waste factor",
        "tr": "Waste factor",
        "de": "Waste factor",
        "fr": "Waste factor",
        "es": "Waste factor",
        "ar": "Waste factor"
      }
    },
    {
      "id": "pricePerBoard",
      "label": "Price per board",
      "type": "number",
      "unit": "$",
      "default": 20,
      "businessContext": "Unit price of each fascia board",
      "label_i18n": {
        "en": "Price per board",
        "tr": "Price per board",
        "de": "Price per board",
        "fr": "Price per board",
        "es": "Price per board",
        "ar": "Price per board"
      }
    }
  ],
  "formulas": {
    "effectiveLength": "fasciaBoardLength - overlap",
    "boardsNeeded": "Math.ceil(totalRoofLength / effectiveLength)",
    "totalBoards": "Math.ceil(boardsNeeded * (1 + wasteFactor / 100))",
    "totalCost": "totalBoards * pricePerBoard",
    "__fasciaBoardLength__m": "${fasciaBoardLength} m",
    "__effectiveLength__m": "${effectiveLength} m",
    "__boardsNeeded_": "${boardsNeeded}",
    "__wasteFactor__": "${wasteFactor}%",
    "__totalBoards_": "${totalBoards}",
    "___pricePerBoard_": "$${pricePerBoard}",
    "___totalCost_": "$${totalCost}"
  },
  "outputs": {
    "primary": "effectiveLength",
    "breakdown": [
      "Fascia board length: ${fasciaBoardLength} m",
      "Effective length per board (with overlap): ${effectiveLength} m",
      "Boards needed (without waste): ${boardsNeeded}",
      "Waste factor: ${wasteFactor}%",
      "Total boards required (including waste): ${totalBoards}",
      "Price per board: $${pricePerBoard}",
      "Total cost: $${totalCost}"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "İnşaat & Yapı",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management",
  "sectorId": "insaat",
  "profession": "İnşaat Mühendisi",
  "categoryId": "cost"
}

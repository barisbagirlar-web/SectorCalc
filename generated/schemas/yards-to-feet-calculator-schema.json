  "formulas": {
    "primary": "roundingMethod == 0 ? Math.round(yards * conversionFactor * Math.pow(10, precision)) / Math.pow(10, precision) : roundingMethod == 1 ? Math.floor(yards * conversionFactor * Math.pow(10, precision)) / Math.pow(10, precision) : Math.ceil(yards * conversionFactor * Math.pow(10, precision)) / Math.pow(10, precision)",
    "yards___conversionFactor": "yards * conversionFactor",
    "conversionFactor": "conversionFactor"
  },

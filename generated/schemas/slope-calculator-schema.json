  "formulas": {
    "rise": "y2 - y1",
    "run": "x2 - x1",
    "slopeRatio": "run !== 0 ? (rise / run) : null",
    "slopePercentage": "run !== 0 ? (rise / run) * 100 : null",
    "angleDegrees": "run !== 0 ? Math.atan(rise / run) * (180 / Math.PI) : null",
    "hypotenuse": "Math.sqrt(rise**2 + run**2)"
  },
  "outputs": {
    "primary": "slopePercentage",
    "breakdown": [
      "rise",

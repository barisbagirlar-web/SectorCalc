{
  "toolName": "down-syndrome-risk-calculator",
  "inputs": [
    {
      "id": "maternalAge",
      "label": "Maternal Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Mother's age at estimated date of delivery",
      "label_i18n": {
        "en": "Maternal Age",
        "tr": "Maternal Age",
        "de": "Maternal Age",
        "fr": "Maternal Age",
        "es": "Maternal Age",
        "ar": "Maternal Age"
      }
    },
    {
      "id": "nt",
      "label": "Nuchal Translucency",
      "type": "number",
      "unit": "mm",
      "default": 1.5,
      "businessContext": "Fetal nuchal translucency measurement from ultrasound",
      "label_i18n": {
        "en": "Nuchal Translucency",
        "tr": "Nuchal Translucency",
        "de": "Nuchal Translucency",
        "fr": "Nuchal Translucency",
        "es": "Nuchal Translucency",
        "ar": "Nuchal Translucency"
      }
    },
    {
      "id": "pappa",
      "label": "PAPP-A MoM",
      "type": "number",
      "unit": "MoM",
      "default": 1,
      "businessContext": "Pregnancy-associated plasma protein A multiple of median",
      "label_i18n": {
        "en": "PAPP-A MoM",
        "tr": "PAPP-A MoM",
        "de": "PAPP-A MoM",
        "fr": "PAPP-A MoM",
        "es": "PAPP-A MoM",
        "ar": "PAPP-A MoM"
      }
    },
    {
      "id": "hcg",
      "label": "Free β-hCG MoM",
      "type": "number",
      "unit": "MoM",
      "default": 1,
      "businessContext": "Free beta human chorionic gonadotropin multiple of median",
      "label_i18n": {
        "en": "Free β-hCG MoM",
        "tr": "Free β-hCG MoM",
        "de": "Free β-hCG MoM",
        "fr": "Free β-hCG MoM",
        "es": "Free β-hCG MoM",
        "ar": "Free β-hCG MoM"
      }
    }
  ],
  "formulas": {
    "ageRisk": "1 / (1 + Math.exp(-(-16.2395 + 0.286 * maternalAge)))",
    "lrNT": "Math.exp(0.2 * nt)",
    "lrPAPPA": "Math.exp(-0.7 * (pappa - 1))",
    "lrHCG": "Math.exp(0.5 * (hcg - 1))",
    "combinedRisk": "ageRisk * lrNT * lrPAPPA * lrHCG",
    "riskOneIn": "1 / combinedRisk",
    "1_in___Math_round_1_ageRisk__": "1 in ${Math.round(1/ageRisk)}",
    "1_in___Math_round_1__ageRisk___lrNT___": "1 in ${Math.round(1/(ageRisk * lrNT))}",
    "1_in___Math_round_1_combinedRisk__": "1 in ${Math.round(1/combinedRisk)}",
    "result": "1 in ${Math.round(riskOneIn)}"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "Age-related risk: 1 in ${Math.round(1/ageRisk)}",
      "After NT adjustment: 1 in ${Math.round(1/(ageRisk * lrNT))}",
      "After blood markers: 1 in ${Math.round(1/combinedRisk)}"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics",
  "sectorId": "lojistik",
  "profession": "Lojistik Uzmanı",
  "categoryId": "quality"
}

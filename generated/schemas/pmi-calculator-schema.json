        "tr": "Operasyonları yürütmek için yapılan harcamalar."
      }
    },
    {
      "id": "taxRate",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Applicable tax rate as percentage",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Vergi Oranı",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Applicable tax rate as percentage",
        "tr": "Yüzde olarak geçerli vergi oranı."
      }
    }
  ],
  "formulas": {
    "grossProfit": "revenue - costOfGoodsSold",
    "operatingProfit": "grossProfit - operatingExpenses",
    "netProfit": "operatingProfit * (1 - taxRate / 100)",
    "grossProfitMargin": "grossProfit / revenue * 100",
    "operatingProfitMargin": "operatingProfit / revenue * 100",
    "netProfitMargin": "netProfit / revenue * 100"
  },
  "outputs": {
    "primary": "netProfitMargin",
    "breakdown": [
      "grossProfitMargin",
      "operatingProfitMargin"
    ],

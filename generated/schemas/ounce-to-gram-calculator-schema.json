{
  "toolName": "ounce-to-gram-calculator",
  "inputs": [
    {
      "id": "ounces",
      "label": "Weight (oz)",
      "type": "number",
      "unit": "oz",
      "default": 1,
      "businessContext": "Enter weight in avoirdupois ounces",
      "label_i18n": {
        "en": "Weight (oz)",
        "tr": "Weight (oz)",
        "de": "Weight (oz)",

{
  "toolName": "ounce-to-gram-calculator",
  "inputs": [
    {
      "id": "ounces",
      "label": "Ounces",
      "type": "number",
      "unit": "oz",
      "default": 1,
      "businessContext": "Weight in ounces to convert"
    },
    {
      "id": "conversionMode",
      "label": "Ounce Type",
      "type": "number",
      "unit": "mode",
      "default": 0,
      "businessContext": "0 = avoirdupois (28.3495 g/oz), 1 = troy (31.1035 g/oz)"
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "dp",
      "default": 2,
      "businessContext": "Number of decimal places for output"
    },
    {
      "id": "roundingMode",
      "label": "Rounding Mode",
      "type": "number",
      "unit": "mode",
      "default": 0,
      "businessContext": "0 = round, 1 = floor, 2 = ceil"
    }
  ],
  "formulas": {
    "primary": "(roundingMode === 0 ? Math.round(ounces * (conversionMode === 0 ? 28.3495 : 31.1035) * Math.pow(10, precision)) / Math.pow(10, precision) : (roundingMode === 1 ? Math.floor(ounces * (conversionMode === 0 ? 28.3495 : 31.1035) * Math.pow(10, precision)) / Math.pow(10, precision) : Math.ceil(ounces * (conversionMode === 0 ? 28.3495 : 31.1035) * Math.pow(10, precision)) / Math.pow(10, precision)))",
    "breakdown": [
      "'Raw: ' + (ounces * (conversionMode === 0 ? 28.3495 : 31.1035))",
      "'Factor: ' + (conversionMode === 0 ? 28.3495 : 31.1035) + ' g/oz'"
    ]
  },
  "outputs": {
    "primary": "Grams",
    "breakdown": [
      "Raw Value (unrounded)",
      "Conversion Factor"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

      }
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (g/oz)",
      "type": "number",
      "unit": "g/oz",
      "default": 28.349523125,
      "businessContext": "Grams per ounce. Default is avoirdupois ounce. For troy ounce, use 31.1034768",
      "label_i18n": {
        "en": "Conversion Factor (g/oz)",
        "tr": "Conversion Factor (g/oz)",
        "de": "Conversion Factor (g/oz)",
        "fr": "Conversion Factor (g/oz)",
        "es": "Conversion Factor (g/oz)",
        "ar": "Conversion Factor (g/oz)"
      }
    },
    {
      "id": "itemCount",
      "label": "Number of Items",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "If converting total weight of multiple identical items, enter quantity",
      "label_i18n": {
        "en": "Number of Items",
        "tr": "Number of Items",
        "de": "Number of Items",
        "fr": "Number of Items",
        "es": "Number of Items",
        "ar": "Number of Items"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of decimal places for result rounding",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "grams": "Math.round(ounces * conversionFactor * itemCount * 10**decimalPlaces) / 10**decimalPlaces",
    "totalOunces": "ounces * itemCount",
    "unroundedGrams": "ounces * conversionFactor * itemCount"
  },
  "outputs": {
    "primary": "grams",
    "breakdown": [
      "totalOunces",
      "unroundedGrams"
    ]
  },

{
  "toolName": "ounce-to-gram-calculator",
  "inputs": [
    {
      "id": "ounces",
      "label": "Weight (oz)",
      "type": "number",
      "unit": "oz",
      "default": 1,
      "businessContext": "Enter weight in avoirdupois ounces"
    },
    {
      "id": "conversionFactor",
      "label": "Conversion Factor (g/oz)",
      "type": "number",
      "unit": "g/oz",
      "default": 28.349523125,
      "businessContext": "Grams per ounce. Default is avoirdupois ounce. For troy ounce, use 31.1034768"
    },
    {
      "id": "itemCount",
      "label": "Number of Items",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "If converting total weight of multiple identical items, enter quantity"
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "",
      "default": 2,
      "businessContext": "Number of decimal places for result rounding"
    }
  ],
  "formulas": {
    "grams": "Math.round(ounces * conversionFactor * itemCount * 10**decimalPlaces) / 10**decimalPlaces",
    "totalOunces": "ounces * itemCount",
    "unroundedGrams": "ounces * conversionFactor * itemCount"
  },
  "outputs": {
    "primary": "grams",
    "breakdown": [
      "totalOunces",
      "unroundedGrams"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

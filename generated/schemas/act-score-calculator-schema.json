      "id": "englishScore",
      "label": "English Score",
      "type": "number",
      "unit": "points",
      "default": 20,
      "businessContext": "Score from English section of the ACT test"
    },
    {
      "id": "mathScore",
      "label": "Math Score",
      "type": "number",
      "unit": "points",
      "default": 20,
      "businessContext": "Score from Math section"
    },
    {
      "id": "readingScore",
      "label": "Reading Score",
      "type": "number",
      "unit": "points",
      "default": 20,
      "businessContext": "Score from Reading section"
    },
    {
      "id": "scienceScore",
      "label": "Science Score",
      "type": "number",
      "unit": "points",
      "default": 20,
      "businessContext": "Score from Science section"
    }

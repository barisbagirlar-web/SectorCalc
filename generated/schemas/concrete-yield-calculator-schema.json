  "formulas": {
    "totalMass": "cementMass + waterMass + fineAggregateMass + coarseAggregateMass + admixtureMass",
    "yieldVolume": "(cementMass + waterMass + fineAggregateMass + coarseAggregateMass + admixtureMass) / freshDensity",
    "yieldPerBag": "((cementMass + waterMass + fineAggregateMass + coarseAggregateMass + admixtureMass) / freshDensity) / (cementMass / bagMass)"
  },
  "outputs": {
    "primary": "yieldVolume",
    "breakdown": [

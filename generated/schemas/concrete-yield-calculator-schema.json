    {
      "id": "bagMass",
      "label": "Cement Bag Mass",
      "type": "number",
      "unit": "kg",
      "default": 50,
      "businessContext": "Standard mass of one cement bag (e.g., 50 kg). Used to calculate yield per bag.",

      "label_i18n": {
        "en": "Investment Period",
        "tr": "Investment Period",
        "de": "Investment Period",
        "fr": "Investment Period",
        "es": "Investment Period",
        "ar": "Investment Period"
      }
    },
    {
      "id": "compoundFrequency",
      "label": "Compounding Frequency",
      "type": "number",
      "unit": "times/year",
      "default": 12,
      "businessContext": "Number of times interest is compounded per year. Typically 12 for monthly, 4 for quarterly, 1 for annually.",
      "label_i18n": {
        "en": "Compounding Frequency",
        "tr": "Compounding Frequency",
        "de": "Compounding Frequency",
        "fr": "Compounding Frequency",
        "es": "Compounding Frequency",
        "ar": "Compounding Frequency"
      }
    }
  ],
  "formulas": {
    "monthlyRate": "annualInterestRate / 100 / compoundFrequency",
    "totalPeriods": "years * compoundFrequency",
    "totalDeposits": "initialDeposit + monthlyContribution * totalPeriods"
  },
  "outputs": {
    "primary": "totalDeposits",
    "breakdown": [

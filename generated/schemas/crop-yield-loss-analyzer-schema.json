{
  "toolName": "crop-yield-loss-analyzer",
  "inputs": [
    {
      "id": "expectedYield",
      "label": "Expected Yield (kg/ha)",
      "type": "number",
      "unit": "kg/ha",
      "default": 5000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Expected yield under optimal conditions based on historical data or crop models (e.g., FAO crop yield models)."
    },
    {
      "id": "actualYield",
      "label": "Actual Yield (kg/ha)",
      "type": "number",
      "unit": "kg/ha",
      "default": 4000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Measured yield at harvest; used to calculate yield gap."
    },
    {
      "id": "cropPrice",
      "label": "Crop Price (USD/kg)",
      "type": "number",
      "unit": "USD/kg",
      "default": 0.3,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Market price per kg of crop; influences revenue loss calculation."
    },
    {
      "id": "productionCost",
      "label": "Production Cost (USD/ha)",
      "type": "number",
      "unit": "USD/ha",
      "default": 1000,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total cost per hectare including seeds, fertilizer, labor, irrigation, etc."
    },
    {
      "id": "areaHarvested",
      "label": "Area Harvested (ha)",
      "type": "number",
      "unit": "ha",
      "default": 100,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Total harvested area in hectares."
    },
    {
      "id": "lossCategory",
      "label": "Loss Category",
      "type": "select",
      "unit": "",
      "default": "pre-harvest",
      "min": null,
      "max": null,
      "options": [
        "pre-harvest",
        "harvest",
        "post-harvest",
        "storage",
        "transport"
      ],
      "businessContext": "Category of loss based on FAO food loss definitions; affects loss factors."
    },
    {
      "id": "lossFactor",
      "label": "Loss Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Estimated percentage loss for the selected category; typical ranges from FAO or local studies."
    },
    {
      "id": "dataConfidence",
      "label": "Data Confidence (0-1)",
      "type": "number",
      "unit": "",
      "default": 0.8,
      "min": 0,
      "max": 1,
      "options": null,
      "businessContext": "Confidence level in input data (0=low, 1=high); used for risk adjustment."
    }
  ],
  "validation": {
    "rules": [
      "expectedYield > 0",
      "actualYield >= 0",
      "cropPrice >= 0",
      "productionCost >= 0",
      "areaHarvested > 0",
      "lossFactor >= 0 and lossFactor <= 100",
      "dataConfidence >= 0 and dataConfidence <= 1",
      "actualYield <= expectedYield"
    ],
    "thresholds": {
      "yieldLossPercent": "if yieldLossPercent > 20 then 'High yield loss'",
      "revenueLoss": "if revenueLoss > 10000 then 'Significant revenue loss'"
    }
  },
  "formulas": {
    "yieldLoss": "expectedYield - actualYield",
    "yieldLossPercent": "(yieldLoss / expectedYield) * 100",
    "revenueLoss": "yieldLoss * cropPrice * areaHarvested",
    "costLoss": "productionCost * areaHarvested * (yieldLoss / expectedYield)",
    "totalLoss": "revenueLoss + costLoss",
    "dataConfidenceAdjusted": "totalLoss * dataConfidence"
  },
  "outputs": {
    "primary": "totalLoss",
    "breakdown": {
      "yieldLoss": "yieldLoss",
      "yieldLossPercent": "yieldLossPercent",
      "revenueLoss": "revenueLoss",
      "costLoss": "costLoss"
    },
    "hiddenLossDrivers": [
      "if yieldLossPercent > 20 then 'High yield loss'",
      "if revenueLoss > 10000 then 'Significant revenue loss'"
    ],
    "suggestedActions": [
      "Investigate causes of yield gap (pests, disease, water stress).",
      "Improve crop management practices (fertilizer, irrigation).",
      "Consider crop insurance for high-risk areas.",
      "Optimize harvest timing and post-harvest handling."
    ],
    "dataConfidenceAdjusted": "dataConfidenceAdjusted"
  },
  "premiumFeatures": [
    "PDF/CSV export",
    "Trend analysis over multiple seasons",
    "Benchmarking against regional averages",
    "Detailed loss breakdown by category"
  ],
  "premiumRequired": true
}

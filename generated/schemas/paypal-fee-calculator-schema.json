{
  "toolName": "paypal-fee-calculator",
  "inputs": [
    {
      "id": "transactionAmount",
      "label": "Transaction Amount",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "The amount to be sent or received",
      "label_i18n": {
        "en": "Transaction Amount",
        "tr": "İşlem Tutarı",
        "de": "Transaktionsbetrag",
        "fr": "Transaction Amount",
        "es": "Transaction Amount",
        "ar": "Transaction Amount"
      },
      "businessContext_i18n": {
        "en": "The amount to be sent or received",
        "tr": "Gönderilecek veya alınacak tutar"
      }
    },
    {
      "id": "feePercentage",
      "label": "Domestic Fee Percentage",
      "type": "number",
      "unit": "%",
      "default": 2.9,
      "businessContext": "PayPal's domestic transaction fee percentage",
      "label_i18n": {
        "en": "Domestic Fee Percentage",
        "tr": "Yurtiçi Ücret Yüzdesi",
        "de": "Domestic Fee Percentage",
        "fr": "Domestic Fee Percentage",
        "es": "Domestic Fee Percentage",
        "ar": "Domestic Fee Percentage"
      },
      "businessContext_i18n": {
        "en": "PayPal's domestic transaction fee percentage",
        "tr": "PayPal yurt içi işlem ücreti yüzdesi"
      }
    },
    {
      "id": "fixedFee",
      "label": "Fixed Fee per Transaction",
      "type": "number",
      "unit": "USD",
      "default": 0.3,
      "businessContext": "Fixed fee added per domestic transaction",
      "label_i18n": {
        "en": "Fixed Fee per Transaction",
        "tr": "İşlem başına sabit ücret",
        "de": "Fixed Fee per Transaction",
        "fr": "Fixed Fee per Transaction",
        "es": "Fixed Fee per Transaction",
        "ar": "Fixed Fee per Transaction"
      },
      "businessContext_i18n": {
        "en": "Fixed fee added per domestic transaction",
        "tr": "Yurt içi işlem başına eklenen sabit ücret"
      }
    },
    {
      "id": "isInternational",
      "label": "International Transaction (0=No, 1=Yes)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Indicates if the transaction is cross-border",
      "label_i18n": {
        "en": "International Transaction (0=No, 1=Yes)",
        "tr": "Uluslararası İşlem (0=Hayır, 1=Evet)",
        "de": "International Transaction (0=No, 1=Yes)",
        "fr": "International Transaction (0=No, 1=Yes)",
        "es": "International Transaction (0=No, 1=Yes)",
        "ar": "International Transaction (0=No, 1=Yes)"
      },
      "businessContext_i18n": {
        "en": "Indicates if the transaction is cross-border",
        "tr": "İşlemin sınır ötesi olup olmadığını belirtir"
      }
    },
    {
      "id": "internationalFeePercentage",
      "label": "International Fee Percentage",
      "type": "number",
      "unit": "%",
      "default": 1.5,
      "businessContext": "Additional fee percentage for international transactions",
      "label_i18n": {
        "en": "International Fee Percentage",
        "tr": "Uluslararası Ücret Yüzdesi",
        "de": "International Fee Percentage",
        "fr": "International Fee Percentage",
        "es": "International Fee Percentage",
        "ar": "International Fee Percentage"
      },
      "businessContext_i18n": {
        "en": "Additional fee percentage for international transactions",
        "tr": "Uluslararası işlemler için ek ücret yüzdesi"
      }
    }
  ],
  "formulas": {
    "totalFee": "(transactionAmount * feePercentage / 100 + fixedFee) + (isInternational === 1 ? transactionAmount * internationalFeePercentage / 100 : 0)",
    "netAmount": "transactionAmount - ((transactionAmount * feePercentage / 100 + fixedFee) + (isInternational === 1 ? transactionAmount * internationalFeePercentage / 100 : 0))",
    "percentageFee": "transactionAmount * feePercentage / 100",
    "fixedFeeAmount": "fixedFee",
    "internationalFeeAmount": "isInternational === 1 ? transactionAmount * internationalFeePercentage / 100 : 0"
  },
  "outputs": {
    "primary": "netAmount",
    "breakdown": [
      "totalFee",
      "percentageFee",
      "fixedFeeAmount",
      "internationalFeeAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "internationalFeeAmount",
    "unit": "USD",
    "breakdownUnits": {
      "percentageFee": "%"
    }
  },
  "category": "Diğer",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "diger",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

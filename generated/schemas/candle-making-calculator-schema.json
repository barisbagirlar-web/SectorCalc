{
  "toolName": "candle-making-calculator",
  "inputs": [
    {
      "id": "containerVolume",
      "label": "Container Volume",
      "type": "number",
      "unit": "cm³",
      "default": 200,
      "businessContext": "Volume of each candle container.",
      "label_i18n": {
        "en": "Container Volume",
        "tr": "Container Volume",
        "de": "Container Volume",
        "fr": "Container Volume",
        "es": "Container Volume",
        "ar": "Container Volume"
      }
    },
    {
      "id": "numberOfCandles",
      "label": "Number of Candles",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Total number of candles to make.",
      "label_i18n": {
        "en": "Number of Candles",
        "tr": "Number of Candles",
        "de": "Number of Candles",
        "fr": "Number of Candles",
        "es": "Number of Candles",
        "ar": "Number of Candles"
      }
    },
    {
      "id": "waxDensity",
      "label": "Wax Density",
      "type": "number",
      "unit": "g/cm³",
      "default": 0.9,
      "businessContext": "Density of the wax used (e.g., soy wax ~0.9).",
      "label_i18n": {
        "en": "Wax Density",
        "tr": "Wax Density",
        "de": "Wax Density",
        "fr": "Wax Density",
        "es": "Wax Density",
        "ar": "Wax Density"
      }
    },
    {
      "id": "fragranceLoad",
      "label": "Fragrance Load",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Percentage of fragrance oil relative to wax weight.",
      "label_i18n": {
        "en": "Fragrance Load",
        "tr": "Fragrance Load",
        "de": "Fragrance Load",
        "fr": "Fragrance Load",
        "es": "Fragrance Load",
        "ar": "Fragrance Load"
      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Extra material percentage for waste and spillage.",
      "label_i18n": {
        "en": "Waste Factor",
        "tr": "Waste Factor",
        "de": "Waste Factor",
        "fr": "Waste Factor",
        "es": "Waste Factor",
        "ar": "Waste Factor"
      }
    }
  ],
  "formulas": {
    "waxPerCandle": "containerVolume * waxDensity",
    "fragrancePerCandle": "waxPerCandle * fragranceLoad / 100",
    "totalWaxNeeded": "waxPerCandle * numberOfCandles * (1 + wasteFactor / 100)",
    "totalFragranceNeeded": "fragrancePerCandle * numberOfCandles * (1 + wasteFactor / 100)"
  },
  "outputs": {
    "primary": "totalWaxNeeded",
    "breakdown": [
      "waxPerCandle",
      "fragrancePerCandle",
      "totalFragranceNeeded"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalFragranceNeeded",
    "unit": "cm³"
  },

        "de": "Weld Length (mm)",
        "fr": "Weld Length (mm)",
        "es": "Weld Length (mm)",
        "ar": "Weld Length (mm)"
      }
    },
    {
      "id": "weldThroat",
      "label": "Throat Thickness (mm)",
      "type": "number",
      "unit": "mm",
      "default": 5,
      "businessContext": "Effective throat thickness of the weld",
      "label_i18n": {
        "en": "Throat Thickness (mm)",
        "tr": "Throat Thickness (mm)",

      "label_i18n": {
        "en": "Welding Speed (mm/min)",
        "tr": "Kaynak Hızı (mm/dk)",
        "de": "Schweißgeschwindigkeit (mm/min)",
        "fr": "Vitesse de soudage (mm/min)",
        "es": "Velocidad de soldadura (mm/min)",

  ],
  "formulas": {
    "weldVolume": "weldLength * weldThroat * weldThroat * 0.5",
    "weldMass": "weldVolume * electrodeDensity / 1000",
    "electrodeMass": "weldMass / (depositionEfficiency / 100)",
    "electrodeCost": "electrodeMass * electrodeCostPerKg",
    "laborTime": "weldLength / weldingSpeed",
    "laborCost": "laborTime * laborCostPerHour / 60",
    "totalCost": "electrodeCost + laborCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "weldVolume",
      "weldMass",
      "electrodeMass",
      "electrodeCost",
      "laborTime",
      "laborCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "mm"
  },

        "de": "Electrode Diameter (mm)",
        "fr": "Electrode Diameter (mm)",
        "es": "Electrode Diameter (mm)",
        "ar": "Electrode Diameter (mm)"
      }
    },
    {
      "id": "depositionEfficiency",
      "label": "Deposition Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 65,
      "businessContext": "Percentage of electrode material deposited as weld metal",
      "label_i18n": {
        "en": "Deposition Efficiency (%)",
        "tr": "Deposition Efficiency (%)",
        "de": "Deposition Efficiency (%)",
        "fr": "Deposition Efficiency (%)",
        "es": "Deposition Efficiency (%)",
        "ar": "Deposition Efficiency (%)"
      }
    },
    {
      "id": "electrodeDensity",
      "label": "Electrode Density (g/cm³)",
      "type": "number",
      "unit": "g/cm³",
      "default": 7.85,
      "businessContext": "Density of the electrode material",
      "label_i18n": {
        "en": "Electrode Density (g/cm³)",
        "tr": "Electrode Density (g/cm³)",
        "de": "Electrode Density (g/cm³)",
        "fr": "Electrode Density (g/cm³)",
        "es": "Electrode Density (g/cm³)",
        "ar": "Electrode Density (g/cm³)"
      }
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour (€)",
      "type": "number",
      "unit": "€/h",
      "default": 45,
      "businessContext": "Hourly labor cost including overhead",
      "label_i18n": {
        "en": "Labor Cost per Hour (€)",
        "tr": "Labor Cost per Hour (€)",
        "de": "Labor Cost per Hour (€)",
        "fr": "Labor Cost per Hour (€)",
        "es": "Labor Cost per Hour (€)",
        "ar": "Labor Cost per Hour (€)"
      }
    },
    {
      "id": "electrodeCostPerKg",
      "label": "Electrode Cost per kg (€)",
      "type": "number",
      "unit": "€/kg",
      "default": 3.5,
      "businessContext": "Cost per kilogram of electrode",
      "label_i18n": {
        "en": "Electrode Cost per kg (€)",
        "tr": "Electrode Cost per kg (€)",
        "de": "Electrode Cost per kg (€)",
        "fr": "Electrode Cost per kg (€)",
        "es": "Electrode Cost per kg (€)",
        "ar": "Electrode Cost per kg (€)"
      }
    },
    {
      "id": "weldingSpeed",
      "label": "Welding Speed (mm/min)",
      "type": "number",
      "unit": "mm/min",
      "default": 300,
      "businessContext": "Travel speed of the welding process",
      "label_i18n": {
        "en": "Welding Speed (mm/min)",
        "tr": "Welding Speed (mm/min)",
        "de": "Welding Speed (mm/min)",
        "fr": "Welding Speed (mm/min)",
        "es": "Welding Speed (mm/min)",
        "ar": "Welding Speed (mm/min)"
      }
    }
  ],
  "formulas": {
    "weldVolume": "weldLength * weldThroat * weldThroat * 0.5",
    "weldMass": "weldVolume * electrodeDensity / 1000",
    "electrodeMass": "weldMass / (depositionEfficiency / 100)",
    "electrodeCost": "electrodeMass * electrodeCostPerKg",
    "laborTime": "weldLength / weldingSpeed",
    "laborCost": "laborTime * laborCostPerHour / 60",
    "totalCost": "electrodeCost + laborCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "weldVolume",
      "weldMass",
      "electrodeMass",
      "electrodeCost",
      "laborTime",
      "laborCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },
  "category": "Makine & Tasarım",

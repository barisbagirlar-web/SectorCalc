      },
      "businessContext_i18n": {
        "en": "Travel speed of the welding process",
        "tr": "Kaynak prosesinin ilerleme hızı",
        "de": "Vorschubgeschwindigkeit des Schweißprozesses",
        "fr": "Vitesse de déplacement du procédé de soudage",

        "fr": "Frais supplémentaires (TRY)",
        "es": "Gastos adicionales (TRY)",
        "ar": "المصاريف الإضافية (TRY)"
      },
      "businessContext_i18n": {
        "en": "Other expenses added to VAT base",
        "tr": "KDV matrahına eklenen diğer masraflar",
        "de": "Sonstige Kosten, die zur MwSt.-Bemessungsgrundlage hinzugefügt werden",
        "fr": "Autres frais ajoutés à la base de TVA",

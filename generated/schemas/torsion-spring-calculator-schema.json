{
  "toolName": "torsion-spring-calculator",
  "inputs": [
    {
      "id": "wireDiameter",
      "label": "Wire Diameter",
      "type": "number",
      "unit": "mm",
      "default": 1,
      "businessContext": "Wire diameter of the torsion spring (mm).",
      "label_i18n": {
        "en": "Wire Diameter",
        "tr": "Wire Diameter",
        "de": "Wire Diameter",
        "fr": "Wire Diameter",
        "es": "Wire Diameter",
        "ar": "Wire Diameter"
      }
    },
    {
      "id": "meanDiameter",
      "label": "Mean Coil Diameter",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Mean diameter of the spring coil (mm).",
      "label_i18n": {
        "en": "Mean Coil Diameter",
        "tr": "Mean Coil Diameter",
        "de": "Mean Coil Diameter",
        "fr": "Mean Coil Diameter",
        "es": "Mean Coil Diameter",
        "ar": "Mean Coil Diameter"
      }
    },
    {
      "id": "activeCoils",
      "label": "Active Coils",
      "type": "number",
      "unit": "unit",
      "default": 5,
      "businessContext": "Number of active coils in the spring.",
      "label_i18n": {
        "en": "Active Coils",
        "tr": "Active Coils",
        "de": "Active Coils",
        "fr": "Active Coils",
        "es": "Active Coils",
        "ar": "Active Coils"
      }
    },
    {
      "id": "deflectionAngle",
      "label": "Deflection Angle",
      "type": "number",
      "unit": "°",
      "default": 30,
      "businessContext": "Angular deflection from free position (degrees).",
      "label_i18n": {
        "en": "Deflection Angle",
        "tr": "Deflection Angle",
        "de": "Deflection Angle",
        "fr": "Deflection Angle",
        "es": "Deflection Angle",
        "ar": "Deflection Angle"
      }
    },
    {
      "id": "shearModulus",
      "label": "Shear Modulus",
      "type": "number",
      "unit": "MPa",
      "default": 79300,
      "businessContext": "Shear modulus of the spring material (e.g., steel ≈ 79 300 MPa).",
      "label_i18n": {
        "en": "Shear Modulus",
        "tr": "Shear Modulus",
        "de": "Shear Modulus",
        "fr": "Shear Modulus",
        "es": "Shear Modulus",
        "ar": "Shear Modulus"
      }
    }
  ],
  "formulas": {
    "springIndex": "meanDiameter / wireDiameter",
    "springRate": "(shearModulus * wireDiameter**4) / (3667 * meanDiameter * activeCoils)",
    "torque": "springRate * deflectionAngle",
    "uncorrectedStress": "(32 * torque) / (Math.PI * wireDiameter**3)",
    "wahlFactor": "(4 * springIndex**2 - springIndex - 1) / (4 * springIndex * (springIndex - 1))",
    "correctedStress": "uncorrectedStress * wahlFactor"
  },
  "outputs": {
    "primary": "torque",
    "breakdown": [
      "springRate",
      "correctedStress"
    ]
  },
  "category": "Makine & Tasarım",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "cnc-additive-manufacturing",
  "sectorId": "metal",
  "profession": "Sac Teknisyeni",
  "categoryId": "diger"
}

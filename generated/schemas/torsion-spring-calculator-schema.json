    },
    {
      "id": "meanDiameter",
      "label": "Mean Coil Diameter",
      "type": "number",
      "unit": "mm",
      "default": 10,
      "businessContext": "Mean diameter of the spring coil (mm).",
      "label_i18n": {
        "en": "Mean Coil Diameter",
        "tr": "Ortalama bobin çapı",
        "de": "Mittlerer Windungsdurchmesser",
        "fr": "Mean Coil Diameter",
        "es": "Mean Coil Diameter",
        "ar": "Mean Coil Diameter"
      },
      "businessContext_i18n": {
        "en": "Mean diameter of the spring coil (mm).",
        "tr": "Yay sarımının ortalama çapı (mm)."
      }
    },
    {
      "id": "activeCoils",
      "label": "Active Coils",
      "type": "number",
      "unit": "unit",
      "default": 5,
      "businessContext": "Number of active coils in the spring.",
      "label_i18n": {
        "en": "Active Coils",
        "tr": "Aktif Sarımlar",
        "de": "Active Coils",
        "fr": "Active Coils",
        "es": "Active Coils",
        "ar": "Active Coils"
      },
      "businessContext_i18n": {
        "en": "Number of active coils in the spring.",
        "tr": "Yaydaki aktif sarım sayısı."
      }
    },
    {
      "id": "deflectionAngle",
      "label": "Deflection Angle",
      "type": "number",
      "unit": "°",
      "default": 30,
      "businessContext": "Angular deflection from free position (degrees).",
      "label_i18n": {
        "en": "Deflection Angle",
        "tr": "Sapma Açısı",
        "de": "Deflection Angle",
        "fr": "Deflection Angle",
        "es": "Deflection Angle",
        "ar": "Deflection Angle"
      },
      "businessContext_i18n": {
        "en": "Angular deflection from free position (degrees).",
        "tr": "Serbest konumdan açısal sapma (derece)."
      }
    },
    {
      "id": "shearModulus",
      "label": "Shear Modulus",
      "type": "number",
      "unit": "MPa",
      "default": 79300,
      "businessContext": "Shear modulus of the spring material (e.g., steel ≈ 79 300 MPa).",
      "label_i18n": {
        "en": "Shear Modulus",
        "tr": "Kayma modülü",
        "de": "Schubmodul",
        "fr": "Shear Modulus",
        "es": "Shear Modulus",
        "ar": "Shear Modulus"
      },
      "businessContext_i18n": {
        "en": "Shear modulus of the spring material (e.g., steel ≈ 79 300 MPa).",
        "tr": "Yay malzemesinin kayma modülü (örneğin çelik ≈ 79 300 MPa)."
      }
    }
  ],
  "formulas": {
    "springIndex": "meanDiameter / wireDiameter",
    "springRate": "(shearModulus * wireDiameter**4) / (3667 * meanDiameter * activeCoils)",
    "torque": "springRate * deflectionAngle",
    "uncorrectedStress": "(32 * torque) / (Math.PI * wireDiameter**3)",
    "wahlFactor": "(4 * springIndex**2 - springIndex - 1) / (4 * springIndex * (springIndex - 1))",
    "correctedStress": "uncorrectedStress * wahlFactor"
  },
  "outputs": {
    "primary": "torque",
    "breakdown": [
      "springRate",
      "correctedStress"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "correctedStress",
    "unit": "mm"
  },
  "category": "Diğer",

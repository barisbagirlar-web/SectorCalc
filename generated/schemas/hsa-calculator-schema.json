{
  "toolName": "hsa-calculator",
  "inputs": [
    {
      "id": "currentAge",
      "label": "Current Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Your current age for determining the investment horizon until retirement.",
      "label_i18n": {
        "en": "Current Age",
        "tr": "Current Age",
        "de": "Current Age",
        "fr": "Current Age",
        "es": "Current Age",
        "ar": "Current Age"
      }
    },
    {
      "id": "annualContribution",
      "label": "Annual Contribution",
      "type": "number",
      "unit": "USD",
      "default": 3600,
      "businessContext": "Amount you contribute annually to your HSA from your own funds.",
      "label_i18n": {
        "en": "Annual Contribution",
        "tr": "Annual Contribution",
        "de": "Annual Contribution",
        "fr": "Annual Contribution",
        "es": "Annual Contribution",
        "ar": "Annual Contribution"
      }
    },
    {
      "id": "initialBalance",
      "label": "Initial Balance",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Current balance already in the HSA account.",
      "label_i18n": {
        "en": "Initial Balance",
        "tr": "Initial Balance",
        "de": "Initial Balance",
        "fr": "Initial Balance",
        "es": "Initial Balance",
        "ar": "Initial Balance"
      }
    },
    {
      "id": "annualInterestRate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "percent",
      "default": 5,
      "businessContext": "Expected average annual rate of return on HSA investments (before inflation).",
      "label_i18n": {
        "en": "Annual Interest Rate",
        "tr": "Annual Interest Rate",
        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "taxRate",
      "label": "Marginal Tax Rate",
      "type": "number",
      "unit": "percent",
      "default": 22,
      "businessContext": "Your federal marginal income tax rate used to estimate tax savings on contributions.",
      "label_i18n": {
        "en": "Marginal Tax Rate",
        "tr": "Marginal Tax Rate",
        "de": "Marginal Tax Rate",
        "fr": "Marginal Tax Rate",
        "es": "Marginal Tax Rate",
        "ar": "Marginal Tax Rate"
      }
    },
    {
      "id": "yearsUntilRetirement",
      "label": "Years Until Retirement",
      "type": "number",
      "unit": "years",
      "default": 35,
      "businessContext": "Number of years you plan to contribute before retirement.",
      "label_i18n": {
        "en": "Years Until Retirement",
        "tr": "Years Until Retirement",
        "de": "Years Until Retirement",
        "fr": "Years Until Retirement",
        "es": "Years Until Retirement",
        "ar": "Years Until Retirement"
      }
    },
    {
      "id": "employerContribution",
      "label": "Employer Contribution",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Annual contribution from your employer to your HSA, if any.",
      "label_i18n": {
        "en": "Employer Contribution",
        "tr": "Employer Contribution",
        "de": "Employer Contribution",
        "fr": "Employer Contribution",
        "es": "Employer Contribution",
        "ar": "Employer Contribution"
      }
    }
  ],
  "formulas": {
    "totalContributions": "(annualContribution + employerContribution) * yearsUntilRetirement",
    "taxSavings": "((annualContribution + employerContribution) * yearsUntilRetirement) * (taxRate/100)"
  },
  "outputs": {
    "primary": "taxSavings",
    "breakdown": [
      "totalContributions",
      "taxSavings",
      "interestEarned"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "interestEarned"
  },

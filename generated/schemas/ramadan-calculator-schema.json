    "Ramadan Energy Consumption (kWh)": "ramadanDailyHours * workingDaysRamadan * energyConsumptionRate",
    "Total Energy Saved (kWh)": "(normalDailyHours - ramadanDailyHours) * workingDaysRamadan * energyConsumptionRate",
    "CO₂ Emission Reduction (kg)": "(normalDailyHours - ramadanDailyHours) * workingDaysRamadan * energyConsumptionRate * co2EmissionFactor"

  "formulas": {
    "tamOlasilik": "Math.exp(-lambda) * Math.pow(lambda, k) / (k === 0 ? 1 : (() => { let f = 1; for (let i = 2; i <= k; i++) f *= i; return f; })())",
    "kumulatifOlasilik": "(() => { let sum = 0; for (let i = 0; i <= kumulatif; i++) { sum += Math.exp(-lambda) * Math.pow(lambda, i) / (i === 0 ? 1 : (() => { let f = 1; for (let j = 2; j <= i; j++) f *= j; return f; })()); } return sum; })()"
  },

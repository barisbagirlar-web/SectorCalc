    "weightedDifference": "factor1 * value1 - factor2 * value2",
    "percentageDifference": "((factor1 * value1 - factor2 * value2) / (factor2 * value2)) * 100"
  },
  "outputs": {
    "primary": "weightedRatio",
    "breakdown": [

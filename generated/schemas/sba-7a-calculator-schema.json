{
  "toolName": "sba-7a-calculator",
  "inputs": [
    {
      "id": "loanAmount",
      "label": "Loan Amount ($)",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "businessContext": "Total loan amount requested from SBA 7(a) program",
      "label_i18n": {
        "en": "Loan Amount ($)",
        "tr": "Loan Amount ($)",
        "de": "Loan Amount ($)",
        "fr": "Loan Amount ($)",
        "es": "Loan Amount ($)",
        "ar": "Loan Amount ($)"
      }
    },
    {
      "id": "interestRate",
      "label": "Annual Interest Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 7.5,
      "businessContext": "Annual interest rate on the loan",
      "label_i18n": {
        "en": "Annual Interest Rate (%)",
        "tr": "Annual Interest Rate (%)",
        "de": "Annual Interest Rate (%)",
        "fr": "Annual Interest Rate (%)",
        "es": "Annual Interest Rate (%)",
        "ar": "Annual Interest Rate (%)"
      }
    },
    {
      "id": "loanTermMonths",
      "label": "Loan Term (months)",
      "type": "number",
      "unit": "months",
      "default": 120,
      "businessContext": "Repayment period in months",
      "label_i18n": {
        "en": "Loan Term (months)",
        "tr": "Loan Term (months)",
        "de": "Loan Term (months)",
        "fr": "Loan Term (months)",
        "es": "Loan Term (months)",
        "ar": "Loan Term (months)"
      }
    },
    {
      "id": "guaranteeFeeRate",
      "label": "SBA Guarantee Fee Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 2,
      "businessContext": "One-time guarantee fee charged by SBA, typically 2-3.5%",
      "label_i18n": {
        "en": "SBA Guarantee Fee Rate (%)",
        "tr": "SBA Guarantee Fee Rate (%)",
        "de": "SBA Guarantee Fee Rate (%)",
        "fr": "SBA Guarantee Fee Rate (%)",
        "es": "SBA Guarantee Fee Rate (%)",
        "ar": "SBA Guarantee Fee Rate (%)"
      }
    },
    {
      "id": "originationFeeRate",
      "label": "Origination Fee Rate (%)",
      "type": "number",
      "unit": "%",
      "default": 1,
      "businessContext": "Lender origination fee as percentage of loan amount",
      "label_i18n": {
        "en": "Origination Fee Rate (%)",
        "tr": "Origination Fee Rate (%)",
        "de": "Origination Fee Rate (%)",
        "fr": "Origination Fee Rate (%)",
        "es": "Origination Fee Rate (%)",
        "ar": "Origination Fee Rate (%)"
      }
    },
    {
      "id": "annualRevenue",
      "label": "Annual Business Revenue ($)",
      "type": "number",
      "unit": "USD",
      "default": 2000000,
      "businessContext": "Gross annual revenue of the business",
      "label_i18n": {
        "en": "Annual Business Revenue ($)",
        "tr": "Annual Business Revenue ($)",
        "de": "Annual Business Revenue ($)",
        "fr": "Annual Business Revenue ($)",
        "es": "Annual Business Revenue ($)",
        "ar": "Annual Business Revenue ($)"
      }
    }
  ],
  "formulas": {
    "monthlyInterestRate": "interestRate / 100 / 12",
    "monthlyPayment": "loanAmount * (monthlyInterestRate * (1 + monthlyInterestRate) ** loanTermMonths) / ((1 + monthlyInterestRate) ** loanTermMonths - 1)",
    "totalPayment": "monthlyPayment * loanTermMonths",
    "totalInterest": "totalPayment - loanAmount",
    "guaranteeFee": "loanAmount * (guaranteeFeeRate / 100)",
    "originationFee": "loanAmount * (originationFeeRate / 100)",
    "totalFees": "guaranteeFee + originationFee",
    "effectiveLoanCost": "totalInterest + totalFees",
    "debtServiceCoverageRatio": "annualRevenue / (monthlyPayment * 12)"
  },
  "outputs": {
    "primary": "monthlyPayment",
    "breakdown": [
      "totalPayment",
      "totalInterest",
      "guaranteeFee",
      "originationFee",
      "totalFees",
      "effectiveLoanCost",
      "debtServiceCoverageRatio"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "debtServiceCoverageRatio"
  },
  "category": "Finans & Yatırım",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "finance",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

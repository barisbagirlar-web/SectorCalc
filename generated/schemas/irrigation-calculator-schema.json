{
  "toolName": "irrigation-calculator",
  "inputs": [
    {
      "id": "area",
      "label": "Area",
      "type": "number",
      "unit": "ha",
      "default": 1,
      "businessContext": "Irrigated land area in hectares",
      "label_i18n": {
        "en": "Area",
        "tr": "Area",
        "de": "Area",
        "fr": "Area",
        "es": "Area",
        "ar": "Area"
      }
    },
    {
      "id": "cropWater",
      "label": "Crop Water Requirement",
      "type": "number",
      "unit": "mm/day",
      "default": 5,
      "businessContext": "Daily water need of the crop from evapotranspiration data",
      "label_i18n": {
        "en": "Crop Water Requirement",
        "tr": "Crop Water Requirement",
        "de": "Crop Water Requirement",
        "fr": "Crop Water Requirement",
        "es": "Crop Water Requirement",
        "ar": "Crop Water Requirement"
      }
    },
    {
      "id": "efficiency",
      "label": "Application Efficiency",
      "type": "number",
      "unit": "%",
      "default": 75,
      "businessContext": "Application efficiency of the irrigation system (sprinkler, drip, etc.)",
      "label_i18n": {
        "en": "Application Efficiency",
        "tr": "Application Efficiency",
        "de": "Application Efficiency",
        "fr": "Application Efficiency",
        "es": "Application Efficiency",
        "ar": "Application Efficiency"
      }
    },
    {
      "id": "peakFactor",
      "label": "Peak Factor",
      "type": "number",
      "unit": "unit",
      "default": 1.2,
      "businessContext": "Peak multiplier for hot/dry periods",
      "label_i18n": {
        "en": "Peak Factor",
        "tr": "Peak Factor",
        "de": "Peak Factor",
        "fr": "Peak Factor",
        "es": "Peak Factor",
        "ar": "Peak Factor"
      }
    },
    {
      "id": "systemLosses",
      "label": "System Losses",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Percent water loss due to leaks, evaporation, etc.",
      "label_i18n": {
        "en": "System Losses",
        "tr": "System Losses",
        "de": "System Losses",
        "fr": "System Losses",
        "es": "System Losses",
        "ar": "System Losses"
      }
    },
    {
      "id": "operatingHours",
      "label": "Operating Hours",
      "type": "number",
      "unit": "h",
      "default": 12,
      "businessContext": "Hours per day the irrigation system operates",
      "label_i18n": {
        "en": "Operating Hours",
        "tr": "Operating Hours",
        "de": "Operating Hours",
        "fr": "Operating Hours",
        "es": "Operating Hours",
        "ar": "Operating Hours"
      }
    }
  ],
  "formulas": {
    "totalDailyVolume": "(area * cropWater * 100000 * peakFactor) / (efficiency * (100 - systemLosses))",
    "requiredFlowRate": "((area * cropWater * 100000 * peakFactor) / (efficiency * (100 - systemLosses))) / operatingHours",
    "rawWaterRequirement": "area * cropWater * 10"
  },
  "outputs": {
    "primary": "totalDailyVolume",
    "breakdown": [
      "requiredFlowRate",
      "rawWaterRequirement"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "rawWaterRequirement"
  },

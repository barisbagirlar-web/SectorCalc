      "id": "realLength",
      "label": "Real Length",
      "type": "number",
      "unit": "mm",
      "default": 1000,
      "businessContext": "Length of the real object in the same units as other dimensions.",
      "label_i18n": {
        "en": "Real Length",
        "tr": "Real Length",
        "de": "Real Length",
        "fr": "Real Length",
        "es": "Real Length",
        "ar": "Real Length"
      }
    },
    {
      "id": "realWidth",
      "label": "Real Width",
      "type": "number",
      "unit": "mm",
      "default": 500,
      "businessContext": "Width of the real object.",
      "label_i18n": {
        "en": "Real Width",
        "tr": "Real Width",
        "de": "Real Width",
        "fr": "Real Width",
        "es": "Real Width",
        "ar": "Real Width"
      }
    },
    {
      "id": "realHeight",
      "label": "Real Height",
      "type": "number",
      "unit": "mm",
      "default": 200,
      "businessContext": "Height of the real object.",
      "label_i18n": {
        "en": "Real Height",
        "tr": "Real Height",
        "de": "Real Height",
        "fr": "Real Height",
        "es": "Real Height",
        "ar": "Real Height"
      }
    },
    {
      "id": "scaleNumerator",
      "label": "Scale Numerator",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Numerator of the scale ratio (usually 1 for standard scales like 1:100).",
      "label_i18n": {
        "en": "Scale Numerator",
        "tr": "Scale Numerator",
        "de": "Scale Numerator",
        "fr": "Scale Numerator",
        "es": "Scale Numerator",
        "ar": "Scale Numerator"
      }
    },
    {
      "id": "scaleDenominator",
      "label": "Scale Denominator",
      "type": "number",
      "unit": "unit",
      "default": 100,
      "businessContext": "Denominator of the scale ratio (e.g., 100 for 1:100).",
      "label_i18n": {
        "en": "Scale Denominator",
        "tr": "Scale Denominator",
        "de": "Scale Denominator",
        "fr": "Scale Denominator",
        "es": "Scale Denominator",
        "ar": "Scale Denominator"
      }
    }
  ],
  "formulas": {
    "modelLength": "realLength * scaleNumerator / scaleDenominator",
    "modelWidth": "realWidth * scaleNumerator / scaleDenominator",
    "modelHeight": "realHeight * scaleNumerator / scaleDenominator",
    "scaleRatio": "scaleNumerator + ':' + scaleDenominator"
  },
  "outputs": {
    "primary": "modelLength",
    "breakdown": [
      "modelWidth",
      "modelHeight",
      "scaleRatio"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,

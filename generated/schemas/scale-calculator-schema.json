        "tr": "Ölçek oranının paydası (örneğin 1:100 için 100)."
      }
    }
  ],
  "formulas": {
    "modelLength": "realLength * scaleNumerator / scaleDenominator",
    "modelWidth": "realWidth * scaleNumerator / scaleDenominator",
    "modelHeight": "realHeight * scaleNumerator / scaleDenominator",
    "scaleRatio": "scaleNumerator + ':' + scaleDenominator"
  },
  "outputs": {
    "primary": "modelLength",
    "breakdown": [
      "modelWidth",
      "modelHeight",
      "scaleRatio"

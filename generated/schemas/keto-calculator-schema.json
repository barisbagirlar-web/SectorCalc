        "ar": "Activity Level Multiplier"
      },
      "businessContext_i18n": {
        "en": "1.2: Sedentary, 1.375: Lightly Active, 1.55: Moderately Active, 1.725: Very Active, 1.9: Extra Active",
        "tr": "1,2: Hareketsiz, 1,375: Hafif Aktif, 1,55: Orta Aktif, 1,725: Çok Aktif, 1,9: Ekstra Aktif"
      }
    },
    {
      "id": "deficitPercent",
      "label": "Caloric Deficit",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage to reduce maintenance calories (0=maintenance, 20=20% deficit for weight loss)",
      "label_i18n": {
        "en": "Caloric Deficit",
        "tr": "Kalori Açığı",
        "de": "Caloric Deficit",
        "fr": "Caloric Deficit",
        "es": "Caloric Deficit",
        "ar": "Caloric Deficit"
      },
      "businessContext_i18n": {
        "en": "Percentage to reduce maintenance calories (0=maintenance, 20=20% deficit for weight loss)",
        "tr": "Bazal kaloriden düşülecek yüzde (0=koruma, 20=kil kaybı için %20 açık)"
      }
    }
  ],
  "formulas": {
    "leanBodyMass": "weight * (1 - bodyFat / 100)",
    "bmr": "370 + 21.6 * leanBodyMass",
    "tdee": "bmr * activityLevel",
    "dailyCalories": "tdee * (1 - deficitPercent / 100)",
    "proteinGrams": "leanBodyMass * 1.6",
    "proteinCalories": "proteinGrams * 4"
  },
  "outputs": {
    "primary": "dailyCalories",
    "breakdown": [
      "fatGrams",
      "proteinGrams",
      "netCarbs",
      "leanBodyMass",
      "bmr"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "fatGrams",
    "unit": "kg",
    "breakdownUnits": {
      "fatGrams": "g",
      "proteinGrams": "g"
    }
  },

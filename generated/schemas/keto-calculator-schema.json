        "ar": "Gender (1=Male, 0=Female)"
      }
    },
    {
      "id": "activityLevel",
      "label": "Activity Level Multiplier",
      "type": "number",
      "unit": "unit",
      "default": 1.55,
      "businessContext": "1.2: Sedentary, 1.375: Lightly Active, 1.55: Moderately Active, 1.725: Very Active, 1.9: Extra Active",
      "label_i18n": {
        "en": "Activity Level Multiplier",
        "tr": "Activity Level Multiplier",
        "de": "Activity Level Multiplier",
        "fr": "Activity Level Multiplier",
        "es": "Activity Level Multiplier",
        "ar": "Activity Level Multiplier"
      }
    },
    {
      "id": "deficitPercent",
      "label": "Caloric Deficit",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Percentage to reduce maintenance calories (0=maintenance, 20=20% deficit for weight loss)",
      "label_i18n": {
        "en": "Caloric Deficit",
        "tr": "Caloric Deficit",
        "de": "Caloric Deficit",
        "fr": "Caloric Deficit",
        "es": "Caloric Deficit",
        "ar": "Caloric Deficit"
      }
    }
  ],
  "formulas": {
    "leanBodyMass": "weight * (1 - bodyFat / 100)",
    "bmr": "370 + 21.6 * leanBodyMass",
    "tdee": "bmr * activityLevel",
    "dailyCalories": "tdee * (1 - deficitPercent / 100)",
    "proteinGrams": "leanBodyMass * 1.6",
    "proteinCalories": "proteinGrams * 4"
  },
  "outputs": {
    "primary": "dailyCalories",
    "breakdown": [
      "fatGrams",
      "proteinGrams",
      "netCarbs",
      "leanBodyMass",
      "bmr"
    ],

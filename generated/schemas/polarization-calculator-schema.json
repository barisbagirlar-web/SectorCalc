{
  "toolName": "polarization-calculator",
  "inputs": [
    {
      "id": "incident_intensity",
      "label": "Incident Intensity",
      "type": "number",
      "unit": "W/m²",
      "default": 1,
      "businessContext": "Initial light intensity before any polarizer",
      "label_i18n": {
        "en": "Incident Intensity",
        "tr": "Incident Intensity",
        "de": "Incident Intensity",
        "fr": "Incident Intensity",
        "es": "Incident Intensity",
        "ar": "Incident Intensity"
      }
    },
    {
      "id": "incident_angle",
      "label": "Incident Polarization Angle",
      "type": "number",
      "unit": "deg",
      "default": 0,
      "businessContext": "Polarization angle of incident light relative to reference axis",
      "label_i18n": {
        "en": "Incident Polarization Angle",
        "tr": "Incident Polarization Angle",
        "de": "Incident Polarization Angle",
        "fr": "Incident Polarization Angle",
        "es": "Incident Polarization Angle",
        "ar": "Incident Polarization Angle"
      }
    },
    {
      "id": "polarizer1_angle",
      "label": "First Polarizer Angle",
      "type": "number",
      "unit": "deg",
      "default": 0,
      "businessContext": "Transmission axis angle of the first polarizer",
      "label_i18n": {
        "en": "First Polarizer Angle",
        "tr": "First Polarizer Angle",
        "de": "First Polarizer Angle",
        "fr": "First Polarizer Angle",
        "es": "First Polarizer Angle",
        "ar": "First Polarizer Angle"
      }
    },
    {
      "id": "polarizer2_angle",
      "label": "Second Polarizer Angle",
      "type": "number",
      "unit": "deg",
      "default": 45,
      "businessContext": "Transmission axis angle of the second polarizer",
      "label_i18n": {
        "en": "Second Polarizer Angle",
        "tr": "Second Polarizer Angle",
        "de": "Second Polarizer Angle",
        "fr": "Second Polarizer Angle",
        "es": "Second Polarizer Angle",
        "ar": "Second Polarizer Angle"
      }
    }
  ],
  "formulas": {
    "I1": "incident_intensity * Math.cos((incident_angle - polarizer1_angle) * Math.PI / 180) ** 2",
    "I2": "I1 * Math.cos((polarizer1_angle - polarizer2_angle) * Math.PI / 180) ** 2"
  },
  "outputs": {
    "primary": "I1",
    "breakdown": [
      {
        "id": "first_intensity",
        "label": "Intensity after First Polarizer",
        "unit": "W/m²",
        "formula": "I1"
      },
      {
        "id": "transmission_ratio",
        "label": "Total Transmission Ratio",
        "unit": "%",
        "formula": "(I2 / incident_intensity) * 100"
      }
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

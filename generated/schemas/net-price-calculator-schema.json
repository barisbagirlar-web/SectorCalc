{
  "toolName": "net-price-calculator",
  "inputs": [
    {
      "id": "listPrice",
      "label": "List Price",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "The original price before any discounts or taxes.",
      "label_i18n": {
        "en": "List Price",
        "tr": "List Price",
        "de": "List Price",
        "fr": "List Price",
        "es": "List Price",
        "ar": "List Price"
      }
    },
    {
      "id": "discountPercent",
      "label": "Discount (%)",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Percentage discount applied to the list price.",
      "label_i18n": {
        "en": "Discount (%)",
        "tr": "Discount (%)",
        "de": "Discount (%)",
        "fr": "Discount (%)",
        "es": "Discount (%)",
        "ar": "Discount (%)"
      }
    },
    {
      "id": "vatPercent",
      "label": "VAT (%)",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Value Added Tax percentage applied to the discounted price.",
      "label_i18n": {
        "en": "VAT (%)",
        "tr": "VAT (%)",
        "de": "VAT (%)",
        "fr": "VAT (%)",
        "es": "VAT (%)",
        "ar": "VAT (%)"
      }
    },
    {
      "id": "extraCharge",
      "label": "Extra Charges",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Any additional fixed charges (e.g., shipping, handling) added before tax.",
      "label_i18n": {
        "en": "Extra Charges",
        "tr": "Extra Charges",
        "de": "Extra Charges",
        "fr": "Extra Charges",
        "es": "Extra Charges",
        "ar": "Extra Charges"
      }
    }
  ],
  "formulas": {
    "discountedPrice": "listPrice * (1 - discountPercent / 100) + extraCharge",
    "vatAmount": "(listPrice * (1 - discountPercent / 100) + extraCharge) * vatPercent / 100",
    "netPrice": "(listPrice * (1 - discountPercent / 100) + extraCharge) * (1 + vatPercent / 100)"
  },
  "outputs": {
    "primary": "netPrice",
    "breakdown": [
      "discountedPrice",
      "vatAmount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netPrice"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "education-academic",
  "sectorSlug": "ecommerce",

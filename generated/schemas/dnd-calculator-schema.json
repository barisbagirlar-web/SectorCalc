  "formulas": {
    "ability_modifier": "(score - 10) / 2",
    "proficiency_bonus_calc": "Math.floor((level + 7) / 4)",
    "attack_bonus": "ability_modifier + proficiency_bonus",
    "damage_bonus": "ability_modifier",
    "armor_class": "10 + ability_modifier(dexterity)",
    "hit_points": "8 + ability_modifier(constitution) + (level - 1) * (5 + ability_modifier(constitution))"
  },
  "outputs": {

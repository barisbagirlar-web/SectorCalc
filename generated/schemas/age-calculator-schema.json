{
  "toolName": "Age Calculator",
  "inputs": [
    {
      "id": "birthYear",
      "label": "Birth Year",
      "type": "number",
      "unit": "years",
      "default": 1990,
      "min": 1900,
      "max": 2024,
      "options": null,
      "businessContext": "The year of birth used to calculate age. Typically between 1900 and current year."
    },
    {
      "id": "currentYear",
      "label": "Current Year",
      "type": "number",
      "unit": "years",
      "default": 2024,
      "min": 1900,
      "max": 2100,
      "options": null,
      "businessContext": "The reference year for age calculation. Usually the current calendar year."
    }
  ],
  "validation": {
    "rules": [
      "birthYear must be a finite number",
      "currentYear must be a finite number",
      "birthYear must be >= 1900",
      "currentYear must be >= 1900",
      "currentYear must be >= birthYear"
    ],
    "thresholds": {
      "ageYears": "If ageYears < 0, invalid input; if ageYears > 120, unlikely but possible."
    }
  },
  "formulas": {
    "ageYears": "currentYear - birthYear",
    "recommendedPrice": "ageYears * 0.5"
  },
  "outputs": {
    "primary": "ageYears",
    "breakdown": {
      "ageYears": "currentYear - birthYear",
      "recommendedPrice": "ageYears * 0.5"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [],
    "dataConfidenceAdjusted": "ageYears"
  },
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Comparison with sector averages"
  ],
  "premiumRequired": false
}

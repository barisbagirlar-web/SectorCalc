{
  "toolName": "cycling-atl-calculator",
  "inputs": [
    {
      "id": "atlPrevious",
      "label": "Previous ATL",
      "type": "number",
      "unit": "TSS",
      "default": 0,
      "businessContext": "Your Acute Training Load from yesterday",
      "label_i18n": {
        "en": "Previous ATL",
        "tr": "Previous ATL",
        "de": "Previous ATL",
        "fr": "Previous ATL",
        "es": "Previous ATL",
        "ar": "Previous ATL"
      }
    },
    {
      "id": "tssToday",
      "label": "Today's TSS",
      "type": "number",
      "unit": "TSS",
      "default": 0,
      "businessContext": "Training Stress Score for today's ride",
      "label_i18n": {
        "en": "Today's TSS",
        "tr": "Today's TSS",
        "de": "Today's TSS",
        "fr": "Today's TSS",
        "es": "Today's TSS",
        "ar": "Today's TSS"
      }
    },
    {
      "id": "timeConstant",
      "label": "Time Constant",
      "type": "number",
      "unit": "days",
      "default": 7,
      "businessContext": "Number of days for ATL weighting (commonly 7)",
      "label_i18n": {
        "en": "Time Constant",
        "tr": "Time Constant",
        "de": "Time Constant",
        "fr": "Time Constant",
        "es": "Time Constant",
        "ar": "Time Constant"
      }
    },
    {
      "id": "precision",
      "label": "Decimal Places",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of decimal places for rounded output",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    }
  ],
  "formulas": {
    "atlCurrent": "atlPrevious + (tssToday - atlPrevious) / timeConstant",
    "atlChange": "(tssToday - atlPrevious) / timeConstant",
    "atlRounded": "Math.round((atlPrevious + (tssToday - atlPrevious) / timeConstant) * Math.pow(10, precision)) / Math.pow(10, precision)"
  },
  "outputs": {
    "primary": "atlRounded",
    "breakdown": [
      "atlCurrent",
      "atlChange"
    ]
  },
  "category": "Teknik & Mühendislik",

{
  "toolName": "degree-of-combined-leverage-calculator",
  "inputs": [
    {
      "id": "salesRevenue",
      "label": "Sales Revenue",
      "type": "number",
      "unit": "currency",
      "default": 100000,
      "businessContext": "Total revenue from sales.",
      "label_i18n": {
        "en": "Sales Revenue",
        "tr": "Sales Revenue",
        "de": "Sales Revenue",
        "fr": "Sales Revenue",
        "es": "Sales Revenue",
        "ar": "Sales Revenue"
      }
    },
    {
      "id": "variableCosts",
      "label": "Variable Costs",
      "type": "number",
      "unit": "currency",
      "default": 40000,
      "businessContext": "Total variable costs that vary with production volume.",
      "label_i18n": {
        "en": "Variable Costs",
        "tr": "Variable Costs",
        "de": "Variable Costs",
        "fr": "Variable Costs",
        "es": "Variable Costs",
        "ar": "Variable Costs"
      }
    },
    {
      "id": "fixedCosts",
      "label": "Fixed Operating Costs",
      "type": "number",
      "unit": "currency",
      "default": 30000,
      "businessContext": "Fixed costs not dependent on production volume, such as rent, salaries.",
      "label_i18n": {
        "en": "Fixed Operating Costs",
        "tr": "Fixed Operating Costs",
        "de": "Fixed Operating Costs",
        "fr": "Fixed Operating Costs",
        "es": "Fixed Operating Costs",
        "ar": "Fixed Operating Costs"
      }
    },
    {
      "id": "interestExpense",
      "label": "Interest Expense",
      "type": "number",
      "unit": "currency",
      "default": 10000,
      "businessContext": "Interest payments on debt.",
      "label_i18n": {
        "en": "Interest Expense",
        "tr": "Interest Expense",
        "de": "Interest Expense",
        "fr": "Interest Expense",
        "es": "Interest Expense",
        "ar": "Interest Expense"
      }
    }
  ],
  "formulas": {
    "dcl": "(salesRevenue - variableCosts) / (salesRevenue - variableCosts - fixedCosts - interestExpense)",
    "dol": "(salesRevenue - variableCosts) / (salesRevenue - variableCosts - fixedCosts)",
    "dfl": "(salesRevenue - variableCosts - fixedCosts) / (salesRevenue - variableCosts - fixedCosts - interestExpense)"
  },
  "outputs": {
    "primary": "dcl",
    "breakdown": [
      "dol",
      "dfl"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dfl"
  },

    {
      "id": "fractionalDenominator",
      "label": "Fractional Denominator",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Denominator of fractional odds",
      "label_i18n": {
        "en": "Fractional Denominator",
        "tr": "Fractional Denominator",
        "de": "Fractional Denominator",

  "formulas": {
    "dilationScore": "dilation < 1 ? 0 : dilation <= 2 ? 1 : dilation <= 4 ? 2 : 3",
    "effacementScore": "effacement < 30 ? 0 : effacement <= 50 ? 1 : effacement <= 70 ? 2 : 3",
    "stationScore": "station == -3 ? 0 : station == -2 ? 1 : (station == -1 || station == 0) ? 2 : (station == 1 || station == 2) ? 3 : 0",
    "consistencyScore": "consistency",
    "positionScore": "position",
    "totalScore": "dilationScore + effacementScore + stationScore + consistencyScore + positionScore"
  },
  "outputs": {
    "primary": "totalScore",

      "label": "Treatment Cost (TL/m³)",
      "type": "number",
      "unit": "TL/m3",
      "default": 3,
      "min": 0,
      "businessContext": "Greywater treatment unit cost."
    },
    {
      "id": "sebekeFiyat",
      "label": "Mains Water Price (TL/m³)",
      "type": "number",
      "unit": "TL/m3",
      "default": 15,
      "min": 0,
      "businessContext": "Municipal water unit price."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "griSuHacmi * (sebekeFiyat - aritmaMaliyet) * 365"
  },

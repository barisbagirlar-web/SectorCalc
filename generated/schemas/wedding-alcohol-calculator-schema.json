{
  "toolName": "wedding-alcohol-calculator",
  "inputs": [
    {
      "id": "guestCount",
      "label": "Number of Guests",
      "type": "number",
      "unit": "persons",
      "default": 100,
      "businessContext": "Total number of attendees expected at the wedding, essential for scaling all calculations.",
      "label_i18n": {
        "en": "Number of Guests",
        "tr": "Number of Guests",
        "de": "Number of Guests",
        "fr": "Number of Guests",
        "es": "Number of Guests",
        "ar": "Number of Guests"
      }
    },
    {
      "id": "alcoholPercentage",
      "label": "% of Guests Drinking Alcohol",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Estimated percentage of guests who will consume alcoholic beverages; critical for adjusting quantities.",
      "label_i18n": {
        "en": "% of Guests Drinking Alcohol",
        "tr": "% of Guests Drinking Alcohol",
        "de": "% of Guests Drinking Alcohol",
        "fr": "% of Guests Drinking Alcohol",
        "es": "% of Guests Drinking Alcohol",
        "ar": "% of Guests Drinking Alcohol"
      }
    },
    {
      "id": "durationHours",
      "label": "Duration of Event",
      "type": "number",
      "unit": "hours",
      "default": 5,
      "businessContext": "Duration of the event in hours from start to end of alcohol service; impacts total consumption time.",
      "label_i18n": {
        "en": "Duration of Event",
        "tr": "Duration of Event",
        "de": "Duration of Event",
        "fr": "Duration of Event",
        "es": "Duration of Event",
        "ar": "Duration of Event"
      }
    },
    {
      "id": "drinksPerHour",
      "label": "Drinks per Hour per Person",
      "type": "number",
      "unit": "drinks/person/hour",
      "default": 1.5,
      "businessContext": "Average number of drinks each drinking guest is expected to consume per hour; based on event type and crowd.",
      "label_i18n": {
        "en": "Drinks per Hour per Person",
        "tr": "Drinks per Hour per Person",
        "de": "Drinks per Hour per Person",
        "fr": "Drinks per Hour per Person",
        "es": "Drinks per Hour per Person",
        "ar": "Drinks per Hour per Person"
      }
    },
    {
      "id": "beerRatio",
      "label": "Beer Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.4,
      "businessContext": "Fraction of total drinks expected to be beer; guides purchase of beer quantities.",
      "label_i18n": {
        "en": "Beer Ratio",
        "tr": "Beer Ratio",
        "de": "Beer Ratio",
        "fr": "Beer Ratio",
        "es": "Beer Ratio",
        "ar": "Beer Ratio"
      }
    },
    {
      "id": "wineRatio",
      "label": "Wine Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.4,
      "businessContext": "Fraction of total drinks expected to be wine; guides purchase of wine quantities.",
      "label_i18n": {
        "en": "Wine Ratio",
        "tr": "Wine Ratio",
        "de": "Wine Ratio",
        "fr": "Wine Ratio",
        "es": "Wine Ratio",
        "ar": "Wine Ratio"
      }
    },
    {
      "id": "spiritsRatio",
      "label": "Spirits Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.2,
      "businessContext": "Fraction of total drinks expected to be spirits (liquor); guides purchase of spirits quantities.",
      "label_i18n": {
        "en": "Spirits Ratio",
        "tr": "Spirits Ratio",
        "de": "Spirits Ratio",
        "fr": "Spirits Ratio",
        "es": "Spirits Ratio",
        "ar": "Spirits Ratio"
      }
    }
  ],
  "formulas": {
    "drinkingGuests": "guestCount * (alcoholPercentage / 100)",
    "totalDrinks": "drinkingGuests * durationHours * drinksPerHour",
    "beerDrinks": "totalDrinks * beerRatio",
    "wineDrinks": "totalDrinks * wineRatio",
    "spiritsDrinks": "totalDrinks * spiritsRatio"
  },
  "outputs": {
    "primary": "spiritsDrinks",
    "breakdown": [
      "'Beer: ' + Math.round(beerDrinks) + ' drinks'",
      "'Wine: ' + Math.round(wineDrinks) + ' drinks'",
      "'Spirits: ' + Math.round(spiritsDrinks) + ' drinks'"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "result",
    "unit": "persons"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Gıda & Beslenme",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "quality-six-sigma",
  "sectorId": "gida",
  "profession": "Gıda Mühendisi",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

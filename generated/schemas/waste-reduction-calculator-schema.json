        "ar": "Defective Units"
      },
      "businessContext_i18n": {
        "en": "Number of defective or non-conforming units.",
        "tr": "Hatalı veya uygun olmayan birim sayısı."
      }
    },
    {
      "id": "materialInput",
      "label": "Material Input",
      "type": "number",
      "unit": "kg",
      "default": 500,
      "businessContext": "Total raw material consumed.",
      "label_i18n": {
        "en": "Material Input",
        "tr": "Malzeme Girdisi",
        "de": "Material Input",
        "fr": "Material Input",
        "es": "Material Input",
        "ar": "Material Input"
      },
      "businessContext_i18n": {
        "en": "Total raw material consumed.",
        "tr": "Tüketilen toplam hammadde."
      }
    },
    {
      "id": "wasteMaterial",
      "label": "Waste Material",
      "type": "number",
      "unit": "kg",
      "default": 30,
      "businessContext": "Material wasted as scrap, trimmings, rejects.",
      "label_i18n": {
        "en": "Waste Material",
        "tr": "Atık Malzeme",
        "de": "Waste Material",
        "fr": "Waste Material",
        "es": "Waste Material",
        "ar": "Waste Material"
      },
      "businessContext_i18n": {
        "en": "Material wasted as scrap, trimmings, rejects.",
        "tr": "Fire, kırpıntı, reddedilenler olarak israf edilen malzeme."
      }
    },
    {
      "id": "materialCostPerKg",
      "label": "Material Cost per kg",
      "type": "number",
      "unit": "currency/kg",
      "default": 2.5,
      "businessContext": "Unit cost of raw material.",
      "label_i18n": {
        "en": "Material Cost per kg",
        "tr": "Malzeme Maliyeti (kg başına)",
        "de": "Material Cost per kg",
        "fr": "Material Cost per kg",
        "es": "Material Cost per kg",
        "ar": "Material Cost per kg"
      },
      "businessContext_i18n": {
        "en": "Unit cost of raw material.",
        "tr": "Hammadde birim maliyeti."
      }
    },
    {
      "id": "defectReductionTarget",
      "label": "Defect Reduction Target",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Target percentage reduction in defect units (e.g., 20% means reduce defective units by one fifth).",
      "label_i18n": {
        "en": "Defect Reduction Target",
        "tr": "Hata Azaltma Hedefi",
        "de": "Defect Reduction Target",
        "fr": "Defect Reduction Target",
        "es": "Defect Reduction Target",
        "ar": "Defect Reduction Target"
      },
      "businessContext_i18n": {
        "en": "Target percentage reduction in defect units (e.g., 20% means reduce defective units by one fifth).",
        "tr": "Hatalı birimlerde hedeflenen yüzde azalma (örneğin, %20, hatalı birimleri beşte bir oranında azaltmak anlamına gelir)."
      }
    }
  ],
  "formulas": {
    "materialPerUnit": "materialInput / totalProduction",
    "currentDefectRate": "defectUnits / totalProduction * 100",
    "currentWasteRate": "wasteMaterial / materialInput * 100",
    "currentWasteCost": "wasteMaterial * materialCostPerKg",
    "savings": "defectUnits * (defectReductionTarget / 100) * (materialInput / totalProduction) * materialCostPerKg"
  },
  "outputs": {
    "primary": "savings",
    "breakdown": [
      "currentDefectRate",
      "currentWasteRate",
      "materialPerUnit",
      "currentWasteCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "savings",
    "unit": "kg"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Makine & Üretim",

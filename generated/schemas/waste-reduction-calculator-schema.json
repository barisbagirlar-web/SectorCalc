{
  "toolName": "waste-reduction-calculator",
  "inputs": [
    {
      "id": "totalProduction",
      "label": "Total Production",
      "type": "number",
      "unit": "units",
      "default": 1000,
      "businessContext": "Total number of units produced in the period.",
      "label_i18n": {

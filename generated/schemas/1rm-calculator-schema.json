    },
    {
      "id": "weight2",
      "label": "Set 2 Ağırlık (kg)",
      "type": "number",
      "unit": "kg",
      "default": 80,
      "businessContext": "İkinci sette kaldırılan ağırlık"
    },
    {
      "id": "reps2",
      "label": "Set 2 Tekrar",
      "type": "number",
      "unit": "adet",
      "default": 15,
      "businessContext": "İkinci sette tükenişe yakın yapılan tekrar sayısı"
    },
    {
      "id": "weight3",
      "label": "Set 3 Ağırlık (kg)",
      "type": "number",
      "unit": "kg",
      "default": 60,
      "businessContext": "Üçüncü sette kaldırılan ağırlık"
    },
    {
      "id": "reps3",
      "label": "Set 3 Tekrar",

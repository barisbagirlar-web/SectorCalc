    "estimated1RM": "(set1Estimate + set2Estimate + set3Estimate) / 3"
  },
  "outputs": {
    "primary": "estimated1RM",
    "breakdown": [
      "set1Estimate",
      "set2Estimate",
      "set3Estimate"

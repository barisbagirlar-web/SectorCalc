  "formulas": {
    "WaterIntensity": "TotalWaterConsumed / ProductionVolume",
    "BaselineConsumption": "HistoricalAvg * ProductionVolume",
    "WaterSavings": "BaselineConsumption - ActualConsumption",
    "CostSavings": "WaterSavings * (WaterSupplyRate + WastewaterTreatmentRate)",
    "RecycleRate": "RecycledWater / TotalWaterConsumed",
    "LeakLoss": "TotalSupplied - TotalMetered",
    "ROI_Water": "CostSavings / (EquipmentCost + InstallationCost)",
    "CarbonFootprint_Water": "TotalConsumed * EnergyIntensity_Water * GridEmissionFactor"
  },

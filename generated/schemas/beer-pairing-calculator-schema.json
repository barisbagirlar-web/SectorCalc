{
  "toolName": "beer-pairing-calculator",
  "inputs": [
    {
      "id": "beerIBU",
      "label": "Bira IBU",
      "type": "number",
      "unit": "IBU",
      "default": 30,
      "businessContext": "Biranın Uluslararası Acılık Birimi cinsinden acılık derecesi"
    },
    {
      "id": "beerABV",
      "label": "Bira Alkol Oranı",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Biranın alkol oranı (% hacim)"
    },
    {
      "id": "foodRichness",
      "label": "Yiyecek Zenginlik/Yoğunluk",
      "type": "number",
      "unit": "ölçek",
      "default": 5,
      "businessContext": "1 (hafif) ile 10 (ağır/yoğun) arasında yiyecek yoğunluğu"
    },
    {
      "id": "foodSpiciness",
      "label": "Yiyecek Baharat Seviyesi",
      "type": "number",
      "unit": "ölçek",
      "default": 3,
      "businessContext": "1 (baharatsız) ile 10 (çok baharatlı) arasında"
    },
    {
      "id": "foodAcidity",
      "label": "Yiyecek Asidite",
      "type": "number",
      "unit": "ölçek",
      "default": 3,
      "businessContext": "1 (düşük) ile 10 (yüksek) asidite seviyesi"
    }
  ],
  "formulas": {
    "bitternessMatch": "Math.abs(beerIBU - foodRichness * 10) * 0.2",
    "alcoholMatch": "Math.abs(beerABV - foodRichness) * 5",
    "spiceMatch": "Math.abs(foodSpiciness - 5) * 3",
    "acidityMatch": "Math.abs(foodAcidity - 3) * 2",
    "pairingScore": "Math.max(0, 100 - (bitternessMatch + alcoholMatch + spiceMatch + acidityMatch))"
  },
  "outputs": {
    "primary": "pairingScore",
    "breakdown": [
      "bitternessMatch",
      "alcoholMatch",
      "spiceMatch",
      "acidityMatch"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "food-cold-chain-hygiene",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

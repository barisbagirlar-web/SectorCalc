{
  "toolName": "equity-dilution-calculator",
  "inputs": [
    {
      "id": "totalOutstandingShares",
      "label": "Total Outstanding Shares",
      "type": "number",
      "unit": "shares",
      "default": 1000000,
      "businessContext": "Current total number of shares issued and outstanding before the new issuance.",
      "label_i18n": {
        "en": "Total Outstanding Shares",
        "tr": "Total Outstanding Shares",
        "de": "Total Outstanding Shares",
        "fr": "Total Outstanding Shares",
        "es": "Total Outstanding Shares",
        "ar": "Total Outstanding Shares"
      }
    },
    {
      "id": "newSharesIssued",
      "label": "New Shares Issued",
      "type": "number",
      "unit": "shares",
      "default": 200000,
      "businessContext": "Number of new shares to be created and issued in the funding round.",
      "label_i18n": {
        "en": "New Shares Issued",
        "tr": "New Shares Issued",
        "de": "New Shares Issued",
        "fr": "New Shares Issued",
        "es": "New Shares Issued",
        "ar": "New Shares Issued"
      }
    },
    {
      "id": "investorCurrentShares",
      "label": "Investor's Current Shares",
      "type": "number",
      "unit": "shares",
      "default": 100000,
      "businessContext": "Number of shares currently owned by the investor before the round.",
      "label_i18n": {
        "en": "Investor's Current Shares",
        "tr": "Investor's Current Shares",
        "de": "Investor's Current Shares",
        "fr": "Investor's Current Shares",
        "es": "Investor's Current Shares",
        "ar": "Investor's Current Shares"
      }
    },
    {
      "id": "investorNewShares",
      "label": "Investor's New Shares Purchased",
      "type": "number",
      "unit": "shares",
      "default": 0,
      "businessContext": "Number of new shares the investor purchases in this round (0 if not participating).",
      "label_i18n": {
        "en": "Investor's New Shares Purchased",
        "tr": "Investor's New Shares Purchased",
        "de": "Investor's New Shares Purchased",
        "fr": "Investor's New Shares Purchased",
        "es": "Investor's New Shares Purchased",
        "ar": "Investor's New Shares Purchased"
      }
    }
  ],
  "formulas": {
    "totalAfter": "totalOutstandingShares + newSharesIssued",
    "investorTotalAfter": "investorCurrentShares + investorNewShares",
    "ownershipBefore": "investorCurrentShares / totalOutstandingShares",
    "ownershipAfter": "investorTotalAfter / totalAfter",
    "dilutionPercent": "((ownershipBefore - ownershipAfter) / ownershipBefore) * 100"
  },
  "outputs": {
    "primary": "dilutionPercent",
    "breakdown": [
      "ownershipBefore",
      "ownershipAfter"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "dilutionPercent"
  },
  "category": "Diğer",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "electrical-power-systems",
  "sectorId": "finans",
  "profession": "Finans Müdürü",
  "categoryId": "diger",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

      "businessContext_i18n": {
        "en": "Daily number of good units produced",
        "tr": "Günlük üretilen iyi birim sayısı"
      }
    },
    {
      "id": "scrapRate",
      "label": "Scrap Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Scrap generated as percentage of good output",
      "label_i18n": {
        "en": "Scrap Rate",
        "tr": "Fire Oranı",
        "de": "Scrap Rate",
        "fr": "Scrap Rate",
        "es": "Scrap Rate",
        "ar": "Scrap Rate"
      },
      "businessContext_i18n": {

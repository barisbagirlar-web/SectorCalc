{
  "toolName": "refeed-day-calculator",
  "inputs": [
    {
      "id": "productionRate",
      "label": "Production Rate",
      "type": "number",
      "unit": "units/day",
      "default": 1000,
      "businessContext": "Daily number of good units produced",
      "label_i18n": {
        "en": "Production Rate",
        "tr": "Production Rate",
        "de": "Production Rate",
        "fr": "Production Rate",
        "es": "Production Rate",
        "ar": "Production Rate"
      }
    },
    {
      "id": "scrapRate",
      "label": "Scrap Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Scrap generated as percentage of good output",
      "label_i18n": {
        "en": "Scrap Rate",
        "tr": "Scrap Rate",
        "de": "Scrap Rate",
        "fr": "Scrap Rate",
        "es": "Scrap Rate",
        "ar": "Scrap Rate"
      }
    },
    {
      "id": "refeedTargetRatio",
      "label": "Refeed Target Ratio",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Target percentage of total input material from refeed",
      "label_i18n": {
        "en": "Refeed Target Ratio",
        "tr": "Refeed Target Ratio",
        "de": "Refeed Target Ratio",
        "fr": "Refeed Target Ratio",
        "es": "Refeed Target Ratio",
        "ar": "Refeed Target Ratio"
      }
    },
    {
      "id": "refeedMaterialAvailability",
      "label": "Refeed Material Availability",
      "type": "number",
      "unit": "units",
      "default": 500,
      "businessContext": "Total refeed material available in inventory",
      "label_i18n": {
        "en": "Refeed Material Availability",
        "tr": "Refeed Material Availability",
        "de": "Refeed Material Availability",
        "fr": "Refeed Material Availability",
        "es": "Refeed Material Availability",
        "ar": "Refeed Material Availability"
      }
    },
    {
      "id": "maxRefeedCapacity",
      "label": "Max Refeed Capacity",
      "type": "number",
      "unit": "units/day",
      "default": 0,
      "businessContext": "Maximum refeed processing capacity per day (0 for unlimited)",
      "label_i18n": {
        "en": "Max Refeed Capacity",
        "tr": "Max Refeed Capacity",
        "de": "Max Refeed Capacity",
        "fr": "Max Refeed Capacity",
        "es": "Max Refeed Capacity",
        "ar": "Max Refeed Capacity"
      }
    }
  ],
  "formulas": {
    "scrapPerDay": "productionRate * (scrapRate / 100)",
    "totalInputPerDay": "productionRate + scrapPerDay",
    "dailyRefeedTarget": "totalInputPerDay * (refeedTargetRatio / 100)"
  },
  "outputs": {
    "primary": "dailyRefeedTarget",
    "breakdown": [
      "actualDailyRefeed",
      "totalInputPerDay",
      "scrapPerDay",
      "refeedRatioAchieved"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "refeedRatioAchieved"
  },

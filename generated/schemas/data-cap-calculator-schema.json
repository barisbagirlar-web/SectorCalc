{
  "toolName": "data-cap-calculator",
  "inputs": [
    {
      "id": "monthlyDataCap",
      "label": "Monthly Data Cap",
      "type": "number",
      "unit": "GB",
      "default": 100,
      "businessContext": "The total data allowance in gigabytes for the billing period.",
      "label_i18n": {
        "en": "Monthly Data Cap",
        "tr": "Aylık Veri Limiti",
        "de": "Monthly Data Cap",
        "fr": "Monthly Data Cap",
        "es": "Monthly Data Cap",
        "ar": "Monthly Data Cap"
      },
      "businessContext_i18n": {
        "en": "The total data allowance in gigabytes for the billing period.",
        "tr": "Fatura dönemi için toplam veri izni (gigabayt cinsinden)."
      }
    },
    {
      "id": "dataUsed",
      "label": "Data Used So Far",
      "type": "number",
      "unit": "GB",
      "default": 20,
      "businessContext": "Amount of data consumed so far in the current billing period.",
      "label_i18n": {
        "en": "Data Used So Far",
        "tr": "Şu Ana Kadar Kullanılan Veri",
        "de": "Data Used So Far",
        "fr": "Data Used So Far",
        "es": "Data Used So Far",
        "ar": "Data Used So Far"
      },
      "businessContext_i18n": {
        "en": "Amount of data consumed so far in the current billing period.",
        "tr": "Mevcut fatura döneminde şu ana kadar tüketilen veri miktarı."
      }
    },
    {
      "id": "billingCycleDays",
      "label": "Billing Cycle Days",
      "type": "number",
      "unit": "days",
      "default": 30,
      "businessContext": "Total days in the billing cycle.",
      "label_i18n": {
        "en": "Billing Cycle Days",
        "tr": "Fatura Döngüsü Günleri",
        "de": "Billing Cycle Days",
        "fr": "Billing Cycle Days",
        "es": "Billing Cycle Days",
        "ar": "Billing Cycle Days"
      },
      "businessContext_i18n": {
        "en": "Total days in the billing cycle.",
        "tr": "Fatura döngüsündeki toplam gün sayısı."
      }
    },
    {
      "id": "daysElapsed",
      "label": "Days Elapsed",
      "type": "number",
      "unit": "days",
      "default": 10,
      "businessContext": "Number of days that have passed in the current billing cycle.",
      "label_i18n": {
        "en": "Days Elapsed",
        "tr": "Geçen Günler",
        "de": "Days Elapsed",
        "fr": "Days Elapsed",
        "es": "Days Elapsed",
        "ar": "Days Elapsed"
      },
      "businessContext_i18n": {
        "en": "Number of days that have passed in the current billing cycle.",
        "tr": "Mevcut fatura döngüsünde geçen gün sayısı."
      }
    },
    {
      "id": "overageFeePerGB",
      "label": "Overage Fee per GB",
      "type": "number",
      "unit": "$/GB",
      "default": 10,
      "businessContext": "Cost charged per gigabyte when exceeding the data cap.",
      "label_i18n": {
        "en": "Overage Fee per GB",
        "tr": "GB Başına Aşım Ücreti",
        "de": "Overage Fee per GB",
        "fr": "Overage Fee per GB",
        "es": "Overage Fee per GB",
        "ar": "Overage Fee per GB"
      },
      "businessContext_i18n": {
        "en": "Cost charged per gigabyte when exceeding the data cap.",
        "tr": "Veri limitini aştığınızda gigabayt başına uygulanan ücret."
      }
    }
  ],
  "formulas": {
    "dailyAverageUsage": "daysElapsed ? dataUsed / daysElapsed : 0",
    "projectedTotalUsage": "dailyAverageUsage * billingCycleDays",
    "remainingData": "monthlyDataCap - dataUsed"
  },
  "outputs": {
    "primary": "dailyAverageUsage",
    "breakdown": [
      {
        "id": "dailyAverageUsage",
        "label": "Daily Average Usage",
        "unit": "GB/day",
        "formula": "daysElapsed ? dataUsed / daysElapsed : 0"
      },
      {
        "id": "projectedTotalUsage",
        "label": "Projected Total Usage",
        "unit": "GB",
        "formula": "dailyAverageUsage * billingCycleDays"
      },
      {
        "id": "overageData",
        "label": "Overage Data",
        "unit": "GB",
        "formula": "Math.max(0, projectedTotalUsage - monthlyDataCap)"
      },
      {
        "id": "remainingData",
        "label": "Remaining Data",
        "unit": "GB",
        "formula": "monthlyDataCap - dataUsed"
      }
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "remainingData",
    "unit": "GB"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Günlük Yaşam & Ev",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "ev-yasam",
  "profession": "Ev Yöneticisi",

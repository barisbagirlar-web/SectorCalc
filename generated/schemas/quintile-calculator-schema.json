{
  "toolName": "quintile-calculator",
  "inputs": [
    {
      "id": "min",
      "label": "Minimum",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Minimum value of the distribution (0th percentile)"
    },
    {
      "id": "p20",
      "label": "20th Percentile",
      "type": "number",
      "unit": "",
      "default": 20,
      "businessContext": "Value at the 20th percentile (lower boundary of first quintile)"
    },
    {
      "id": "p40",
      "label": "40th Percentile",
      "type": "number",
      "unit": "",
      "default": 40,
      "businessContext": "Value at the 40th percentile (boundary between second and third quintile)"
    },
    {
      "id": "p60",
      "label": "60th Percentile",
      "type": "number",
      "unit": "",
      "default": 60,
      "businessContext": "Value at the 60th percentile"
    },
    {
      "id": "p80",
      "label": "80th Percentile",
      "type": "number",
      "unit": "",
      "default": 80,
      "businessContext": "Value at the 80th percentile"
    },
    {
      "id": "max",
      "label": "Maximum",
      "type": "number",
      "unit": "",
      "default": 100,
      "businessContext": "Maximum value of the distribution (100th percentile)"
    },
    {
      "id": "value",
      "label": "Target Value",
      "type": "number",
      "unit": "",
      "default": 50,
      "businessContext": "The value to place within the distribution"
    }
  ],
  "formulas": {
    "q": "value <= p20 ? 1 : value <= p40 ? 2 : value <= p60 ? 3 : value <= p80 ? 4 : 5",
    "within": "q === 1 ? (value - min) / (p20 - min) : q === 2 ? (value - p20) / (p40 - p20) : q === 3 ? (value - p40) / (p60 - p40) : q === 4 ? (value - p60) / (p80 - p60) : (value - p80) / (max - p80)",
    "primary": "`Quintile ${q} (${Math.round(within*100)}% within)`"
  },
  "outputs": {
    "primary": "Quintile 3 (50% within)",
    "breakdown": [
      "q",
      "within"
    ]
  },
  "category": "Finans & Kredi",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

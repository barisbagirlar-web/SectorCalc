{
  "toolName": "food-cost-calculator",
  "inputs": [
    {
      "id": "ingredientCost",
      "label": "Total Ingredient Cost",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Cost of all ingredients used in recipe"
    },
    {
      "id": "numberOfServings",
      "label": "Number of Servings",
      "type": "number",
      "unit": "servings",
      "default": 1,
      "businessContext": "Total number of servings the recipe yields"
    },
    {
      "id": "laborCostPerHour",
      "label": "Labor Cost per Hour",
      "type": "number",
      "unit": "USD/h",
      "default": 0,
      "businessContext": "Hourly wage for labor"
    },
    {
      "id": "preparationTimeHours",
      "label": "Preparation Time",
      "type": "number",
      "unit": "hours",
      "default": 0,
      "businessContext": "Time taken to prepare the dish"
    },
    {
      "id": "overheadPercentage",
      "label": "Overhead Percentage",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Additional overhead costs as percentage of ingredient cost"
    },
    {
      "id": "profitMarginPercentage",
      "label": "Desired Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Profit margin to apply as percentage of selling price"
    }
  ],
  "formulas": {
    "totalCost": "ingredientCost + (laborCostPerHour * preparationTimeHours) + (ingredientCost * overheadPercentage / 100)",
    "costPerServing": "totalCost / numberOfServings",
    "sellingPricePerServing": "costPerServing / (1 - (profitMarginPercentage / 100))"
  },
  "outputs": {
    "primary": "sellingPricePerServing",
    "breakdown": [
      "totalCost",
      "costPerServing"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "finance-sales-working-capital"
}

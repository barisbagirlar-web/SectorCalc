    {
      "id": "usageHoursPerDay",
      "label": "Günlük Kullanım Saati",
      "type": "number",
      "unit": "saat/gün",
      "default": 5,
      "businessContext": "Cihazın günlük ortalama çalışma süresi",
      "label_i18n": {
        "en": "Günlük Kullanım Saati",
        "tr": "Günlük Kullanım Saati",
        "de": "Günlük Kullanım Saati",
        "fr": "Günlük Kullanım Saati",
        "es": "Günlük Kullanım Saati",
        "ar": "Günlük Kullanım Saati"
      }
    },
    {
      "id": "daysPerMonth",
      "label": "Aylık Kullanım Günü",
      "type": "number",

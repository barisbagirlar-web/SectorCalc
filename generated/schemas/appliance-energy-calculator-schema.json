      "label_i18n": {
        "en": "Aylık Kullanım Günü",
        "tr": "Aylık Kullanım Günü",
        "de": "Aylık Kullanım Günü",
        "fr": "Aylık Kullanım Günü",
        "es": "Aylık Kullanım Günü",
        "ar": "Aylık Kullanım Günü"
      }
    },
    {
      "id": "electricityCost",
      "label": "Elektrik Birim Fiyatı",
      "type": "number",
      "unit": "TL/kWh",
      "default": 0.12,
      "businessContext": "1 kWh elektrik enerjisinin maliyeti",
      "label_i18n": {
        "en": "Elektrik Birim Fiyatı",
        "tr": "Elektrik Birim Fiyatı",
        "de": "Elektrik Birim Fiyatı",
        "fr": "Elektrik Birim Fiyatı",
        "es": "Elektrik Birim Fiyatı",
        "ar": "Elektrik Birim Fiyatı"
      }
    },
    {
      "id": "applianceCount",
      "label": "Cihaz Adedi",
      "type": "number",
      "unit": "adet",
      "default": 1,
      "businessContext": "Aynı özellikteki cihaz sayısı",
      "label_i18n": {
        "en": "Cihaz Adedi",
        "tr": "Cihaz Adedi",
        "de": "Cihaz Adedi",
        "fr": "Cihaz Adedi",
        "es": "Cihaz Adedi",
        "ar": "Cihaz Adedi"
      }
    },
    {
      "id": "standbyPower",
      "label": "StandBy Gücü",
      "type": "number",
      "unit": "W",
      "default": 0,
      "businessContext": "Cihazın bekleme modunda tükettiği güç",
      "label_i18n": {
        "en": "StandBy Gücü",
        "tr": "StandBy Gücü",
        "de": "StandBy Gücü",
        "fr": "StandBy Gücü",
        "es": "StandBy Gücü",
        "ar": "StandBy Gücü"
      }
    }
  ],
  "formulas": {
    "dailyEnergyKWh": "(powerRating * usageHoursPerDay + standbyPower * (24 - usageHoursPerDay)) * applianceCount / 1000",
    "monthlyEnergyKWh": "dailyEnergyKWh * daysPerMonth",
    "monthlyCost": "monthlyEnergyKWh * electricityCost",
    "annualCost": "monthlyCost * 12"
  },
  "outputs": {
    "primary": "monthlyCost",
    "breakdown": [
      "dailyEnergyKWh",
      "monthlyEnergyKWh",
      "annualCost"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "annualCost"
  },

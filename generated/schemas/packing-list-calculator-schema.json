        "tr": "Karton Ağırlığı (dolu)",
        "de": "Carton Weight (full)",
        "fr": "Carton Weight (full)",
        "es": "Carton Weight (full)",
        "ar": "Carton Weight (full)"
      },
      "businessContext_i18n": {
        "en": "Weight of one full carton including items and packaging",
        "tr": "Ürünler ve ambalaj dahil bir dolu kartonun ağırlığı"
      }
    },
    {
      "id": "maxCartonsPerPallet",
      "label": "Max Cartons per Pallet",
      "type": "number",
      "unit": "cartons/pallet",
      "default": 24,
      "businessContext": "Maximum number of cartons that can be stacked on a pallet (based on dimensions)",
      "label_i18n": {
        "en": "Max Cartons per Pallet",
        "tr": "Palet Başına Maksimum Karton",
        "de": "Max Cartons per Pallet",
        "fr": "Max Cartons per Pallet",
        "es": "Max Cartons per Pallet",
        "ar": "Max Cartons per Pallet"
      },
      "businessContext_i18n": {
        "en": "Maximum number of cartons that can be stacked on a pallet (based on dimensions)",
        "tr": "Bir palete (boyutlara göre) istiflenebilecek maksimum karton sayısı"
      }
    },
    {
      "id": "maxWeightPerPallet",
      "label": "Max Weight per Pallet",
      "type": "number",
      "unit": "kg",
      "default": 500,
      "businessContext": "Maximum weight a pallet can safely carry",
      "label_i18n": {
        "en": "Max Weight per Pallet",
        "tr": "Palet Başına Maksimum Ağırlık",
        "de": "Max Weight per Pallet",
        "fr": "Max Weight per Pallet",
        "es": "Max Weight per Pallet",
        "ar": "Max Weight per Pallet"
      },
      "businessContext_i18n": {
        "en": "Maximum weight a pallet can safely carry",
        "tr": "Bir paletin güvenle taşıyabileceği maksimum ağırlık"
      }
    }
  ],
  "formulas": {
    "totalVolume": "(quantityOrdered / unitsPerCarton) * (cartonLength * cartonWidth * cartonHeight) / 1000000",
    "totalWeight": "(quantityOrdered / unitsPerCarton) * cartonWeight",
    "totalCartons": "quantityOrdered / unitsPerCarton",
    "palletsByVolume": "(quantityOrdered / unitsPerCarton) / maxCartonsPerPallet",
    "palletsByWeight": "(quantityOrdered / unitsPerCarton) * cartonWeight / maxWeightPerPallet"
  },
  "outputs": {
    "primary": "totalVolume",
    "breakdown": [
      "totalWeight",
      "totalCartons",
      "palletsByVolume",
      "palletsByWeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "palletsByWeight",
    "unit": "pcs"
  },
  "category": "Dönüşüm & Ölçüm",

  "formulas": {
    "rawMeters": "nmValue / conversionFactor",
    "scaledMeters": "(nmValue / conversionFactor) * scaling",
    "offsetMeters": "((nmValue / conversionFactor) * scaling) + offset",
    "resultInTarget": "((nmValue / conversionFactor) * scaling + offset) * targetUnitFactor",
    "nmValue___conversionFactor": "nmValue / conversionFactor",
    "_nmValue___conversionFactor____scaling": "(nmValue / conversionFactor) * scaling",
    "__nmValue___conversionFactor____scaling_": "((nmValue / conversionFactor) * scaling) + offset",
    "___nmValue___conversionFactor____scaling": "(((nmValue / conversionFactor) * scaling) + offset) * targetUnitFactor",
    "result": "parseFloat(((((nmValue / conversionFactor) * scaling) + offset) * targetUnitFactor).toFixed(precision))"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "nmValue / conversionFactor",
      "(nmValue / conversionFactor) * scaling",
      "((nmValue / conversionFactor) * scaling) + offset",
      "(((nmValue / conversionFactor) * scaling) + offset) * targetUnitFactor"
    ]
  },

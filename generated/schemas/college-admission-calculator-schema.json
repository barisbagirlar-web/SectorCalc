  "formulas": {
    "academicScore": "(gpa / 4) * 30 + (testScore / 1600) * 30",
    "extracurricularScore": "(extracurriculars / 10) * 20",
    "essayScore": "(essayRating / 10) * 20",
    "admissionChance": "academicScore + extracurricularScore + essayScore"
  },
  "outputs": {
    "primary": "admissionChance",
    "breakdown": [
      "academicScore",
      "extracurricularScore",
      "essayScore"

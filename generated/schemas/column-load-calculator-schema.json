  "formulas": {
    "criticalBucklingLoad": "(Math.PI**2 * elasticModulus * 1000 * inertia) / (effectiveLengthFactor*length)**2",
    "yieldLoad": "area*yieldStrength"
  },
  "outputs": {
    "primary": "yieldLoad",
    "breakdown": [
      "criticalBucklingLoad",
      "yieldLoad",
      "slendernessRatio"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "designLoad",
    "unit": "mm",
    "breakdownUnits": {
      "slendernessRatio": "%"
    }
  },

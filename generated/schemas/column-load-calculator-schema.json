      "type": "number",
      "unit": "unit",
      "default": 1.5,
      "businessContext": "Factor of safety for design load",
      "label_i18n": {
        "en": "Safety Factor",
        "tr": "Güvenlik Faktörü",
        "de": "Sicherheitsfaktor",
        "fr": "Coefficient de sécurité",
        "es": "Factor de seguridad",
        "ar": "Safety Factor"
      },
      "businessContext_i18n": {
        "en": "Factor of safety for design load",

      }
    }
  ],
  "formulas": {
    "availableMinutes": "(wakeUpTimeHours - currentTimeHours) * 60",
    "recommendedNapMinutes": "(availableMinutes >= sleepCycleMinutes) ? sleepCycleMinutes : ((availableMinutes >= minNapMinutes) ? minNapMinutes : 0)",
    "cycleNapWakeTime": "currentTimeHours + sleepCycleMinutes/60",
    "shortNapWakeTime": "currentTimeHours + minNapMinutes/60",
    "maxNapWakeTime": "currentTimeHours + maxNapMinutes/60"
  },
  "outputs": {
    "primary": "availableMinutes",
    "breakdown": [
      "Kullanılabilir pencere: ${availableMinutes} dakika",
      "Tam döngü (${sleepCycleMinutes} dk) → uyanış: ${cycleNapWakeTime.toFixed(2)}",
      "Kısa şekerleme (${minNapMinutes} dk) → uyanış: ${shortNapWakeTime.toFixed(2)}",
      "Maksimum kısa şekerleme (${maxNapMinutes} dk) → uyanış: ${maxNapWakeTime.toFixed(2)}"
    ],

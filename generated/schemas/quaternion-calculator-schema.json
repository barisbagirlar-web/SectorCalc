    "productY": "q0*p2 - q1*p3 + q2*p0 + q3*p1",
    "productZ": "q0*p3 + q1*p2 - q2*p1 + q3*p0",
    "normQ": "Math.sqrt(q0*q0 + q1*q1 + q2*q2 + q3*q3)",
    "normP": "Math.sqrt(p0*p0 + p1*p1 + p2*p2 + p3*p3)",
    "productString": "\"(\" + (q0*p0 - q1*p1 - q2*p2 - q3*p3) + \", \" + (q0*p1 + q1*p0 + q2*p3 - q3*p2) + \", \" + (q0*p2 - q1*p3 + q2*p0 + q3*p1) + \", \" + (q0*p3 + q1*p2 - q2*p1 + q3*p0) + \")\""

{
  "toolName": "reduced-temperature-calculator",
  "inputs": [
    {
      "id": "actual_temperature_value",
      "label": "Actual Temperature",
      "type": "number",
      "unit": "K",
      "default": 300,
      "businessContext": "Gerçek sıcaklık değeri"
    },
    {
      "id": "actual_temperature_unit",
      "label": "Actual Temperature Unit",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1: K, 2: °C, 3: °F, 4: °R"
    },
    {
      "id": "critical_temperature_value",
      "label": "Critical Temperature",
      "type": "number",
      "unit": "K",
      "default": 400,
      "businessContext": "Kritik sıcaklık değeri"
    },
    {
      "id": "critical_temperature_unit",
      "label": "Critical Temperature Unit",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1: K, 2: °C, 3: °F, 4: °R"
    }
  ],
  "formulas": {
    "reduced_temperature": "actual_temperature_K / critical_temperature_K",
    "actual_temperature_K": "(actual_temperature_unit == 1 ? actual_temperature_value : (actual_temperature_unit == 2 ? actual_temperature_value + 273.15 : (actual_temperature_unit == 3 ? (actual_temperature_value - 32) * 5/9 + 273.15 : (actual_temperature_unit == 4 ? actual_temperature_value * 5/9 : 0))))",
    "critical_temperature_K": "(critical_temperature_unit == 1 ? critical_temperature_value : (critical_temperature_unit == 2 ? critical_temperature_value + 273.15 : (critical_temperature_unit == 3 ? (critical_temperature_value - 32) * 5/9 + 273.15 : (critical_temperature_unit == 4 ? critical_temperature_value * 5/9 : 0))))"
  },
  "outputs": {
    "primary": "reduced_temperature",
    "breakdown": [
      "actual_temperature_K",
      "critical_temperature_K"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

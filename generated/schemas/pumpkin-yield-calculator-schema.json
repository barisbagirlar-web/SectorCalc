{
  "toolName": "pumpkin-yield-calculator",
  "inputs": [
    {
      "id": "fieldArea",
      "label": "Tarla Alanı",
      "type": "number",
      "unit": "m²",
      "default": 1000,
      "businessContext": "Kabak ekili tarla alanı"
    },
    {
      "id": "plantDensity",
      "label": "Bitki Sıklığı",
      "type": "number",
      "unit": "adet/m²",
      "default": 0.5,
      "businessContext": "Metrekare başına düşen kabak bitkisi sayısı"
    },
    {
      "id": "pumpkinsPerPlant",
      "label": "Bitki Başı Kabak",
      "type": "number",
      "unit": "adet",
      "default": 1.5,
      "businessContext": "Bitki başına ortalama hasat edilen kabak sayısı"
    },
    {
      "id": "avgWeight",
      "label": "Ortalama Ağırlık",
      "type": "number",
      "unit": "kg",
      "default": 5,
      "businessContext": "Kabak başına ortalama ağırlık"
    },
    {
      "id": "lossRate",
      "label": "Kayıp Oranı",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Zararlı, hasar vb. nedenli kayıp yüzdesi"
    }
  ],
  "formulas": {
    "totalPumpkins": "fieldArea * plantDensity * pumpkinsPerPlant",
    "lossPumpkins": "totalPumpkins * (lossRate / 100)",
    "netPumpkins": "totalPumpkins - lossPumpkins",
    "totalYield": "netPumpkins * avgWeight"
  },
  "outputs": {
    "primary": "totalYield",
    "breakdown": [
      "totalPumpkins",
      "lossPumpkins",
      "netPumpkins"
    ]
  },
  "category": "Malzeme, Fire & OEE",
  "sector": "Perakende & Gıda",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

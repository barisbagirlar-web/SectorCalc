{
  "toolName": "pumpkin-yield-calculator",
  "inputs": [
    {
      "id": "fieldArea",
      "label": "Tarla Alanı",
      "type": "number",
      "unit": "m²",
      "default": 1000,
      "businessContext": "Kabak ekili tarla alanı",
      "label_i18n": {
        "en": "Tarla Alanı",
        "tr": "Tarla Alanı",
        "de": "Tarla Alanı",
        "fr": "Tarla Alanı",
        "es": "Tarla Alanı",
        "ar": "Tarla Alanı"
      }
    },
    {
      "id": "plantDensity",
      "label": "Bitki Sıklığı",
      "type": "number",
      "unit": "adet/m²",
      "default": 0.5,
      "businessContext": "Metrekare başına düşen kabak bitkisi sayısı",
      "label_i18n": {
        "en": "Bitki Sıklığı",
        "tr": "Bitki Sıklığı",
        "de": "Bitki Sıklığı",
        "fr": "Bitki Sıklığı",
        "es": "Bitki Sıklığı",
        "ar": "Bitki Sıklığı"
      }
    },
    {
      "id": "pumpkinsPerPlant",
      "label": "Bitki Başı Kabak",
      "type": "number",
      "unit": "adet",
      "default": 1.5,
      "businessContext": "Bitki başına ortalama hasat edilen kabak sayısı",
      "label_i18n": {
        "en": "Bitki Başı Kabak",
        "tr": "Bitki Başı Kabak",
        "de": "Bitki Başı Kabak",
        "fr": "Bitki Başı Kabak",
        "es": "Bitki Başı Kabak",
        "ar": "Bitki Başı Kabak"
      }
    },
    {
      "id": "avgWeight",
      "label": "Ortalama Ağırlık",
      "type": "number",
      "unit": "kg",
      "default": 5,
      "businessContext": "Kabak başına ortalama ağırlık",
      "label_i18n": {
        "en": "Ortalama Ağırlık",
        "tr": "Ortalama Ağırlık",
        "de": "Ortalama Ağırlık",
        "fr": "Ortalama Ağırlık",
        "es": "Ortalama Ağırlık",
        "ar": "Ortalama Ağırlık"
      }
    },
    {
      "id": "lossRate",
      "label": "Kayıp Oranı",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Zararlı, hasar vb. nedenli kayıp yüzdesi",
      "label_i18n": {
        "en": "Kayıp Oranı",
        "tr": "Kayıp Oranı",
        "de": "Kayıp Oranı",
        "fr": "Kayıp Oranı",
        "es": "Kayıp Oranı",
        "ar": "Kayıp Oranı"
      }
    }
  ],
  "formulas": {
    "totalPumpkins": "fieldArea * plantDensity * pumpkinsPerPlant",
    "lossPumpkins": "totalPumpkins * (lossRate / 100)",
    "netPumpkins": "totalPumpkins - lossPumpkins",
    "totalYield": "netPumpkins * avgWeight"
  },
  "outputs": {
    "primary": "totalYield",
    "breakdown": [
      "totalPumpkins",
      "lossPumpkins",
      "netPumpkins"
    ],

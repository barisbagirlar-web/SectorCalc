      }
    },
    {
      "id": "wasteFactor",
      "label": "Waste Factor (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Additional percentage to account for waste and spillage.",
      "label_i18n": {
        "en": "Waste Factor (%)",
        "tr": "Fire Faktörü (%)",
        "de": "Verschnittfaktor (%)",
        "fr": "Waste Factor (%)",
        "es": "Waste Factor (%)",
        "ar": "Waste Factor (%)"
      },
      "businessContext_i18n": {
        "en": "Additional percentage to account for waste and spillage.",
        "tr": "Atık ve dökülme için ek yüzde.",
        "de": "Zusätzlicher Prozentsatz zur Berücksichtigung von Abfall und Verschütten."
      }
    }
  ],
  "formulas": {
    "totalParts": "resinRatio + hardenerRatio",
    "adjustedWeight": "desiredWeight * (1 + wasteFactor/100)",
    "resinWeight": "adjustedWeight * resinRatio / totalParts",
    "hardenerWeight": "adjustedWeight * hardenerRatio / totalParts"
  },
  "outputs": {
    "primary": "adjustedWeight",
    "breakdown": [
      "resinWeight",
      "hardenerWeight"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

  "formulas": {
    "totalWeight": "weightE + weightS + weightG",
    "environContrib": "(environScore * weightE) / totalWeight",
    "socialContrib": "(socialScore * weightS) / totalWeight",
    "governContrib": "(governScore * weightG) / totalWeight",
    "esgScore": "environContrib + socialContrib + governContrib"
  },

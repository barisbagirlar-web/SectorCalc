  "formulas": {
    "deckArea": "deckLength * deckWidth",
    "boardArea": "boardLength * ((boardWidth + gap) / 12)",
    "rawCount": "(deckLength * deckWidth) / (boardLength * ((boardWidth + gap) / 12))",
    "totalBoards": "(deckLength * deckWidth) / (boardLength * ((boardWidth + gap) / 12)) * (1 + wasteFactor / 100)"

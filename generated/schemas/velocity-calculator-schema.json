{
  "toolName": "velocity-calculator",
  "inputs": [
    {
      "id": "initialVelocity",
      "label": "Initial Velocity (u)",
      "type": "number",
      "unit": "m/s",
      "default": 0,
      "businessContext": "Starting velocity of the object"
    },
    {
      "id": "acceleration",
      "label": "Acceleration (a)",
      "type": "number",
      "unit": "m/s²",
      "default": 0,
      "businessContext": "Constant acceleration applied"
    },
    {
      "id": "time",
      "label": "Time (t)",
      "type": "number",
      "unit": "s",
      "default": 0,
      "businessContext": "Time interval for the motion"
    },
    {
      "id": "distance",
      "label": "Distance (s)",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Optional: known distance traveled, for comparison with calculated value"
    }
  ],
  "formulas": {
    "finalVelocity": "initialVelocity + acceleration * time",
    "distanceTravelled": "initialVelocity * time + 0.5 * acceleration * time ** 2",
    "averageVelocity": "initialVelocity + 0.5 * acceleration * time"
  },
  "outputs": {
    "primary": "finalVelocity",
    "breakdown": [
      "distanceTravelled",
      "averageVelocity"
    ]
  },
  "category": "Diğer",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

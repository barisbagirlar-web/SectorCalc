  ],
  "formulas": {
    "angleRad": "inputs.angleDeg > 0 ? inputs.angleDeg * Math.PI / 180 : inputs.arcLength > 0 ? inputs.arcLength / inputs.radius : inputs.chordOffset > 0 ? 2 * Math.acos(inputs.chordOffset / inputs.radius) : 0",
    "chord": "2 * inputs.radius * Math.sin(angleRad / 2)",
    "chordFinal": "Math.round(chord * Math.pow(10, inputs.precision)) / Math.pow(10, inputs.precision)",
    "arcLength": "angleRad * inputs.radius",
    "arcLengthFinal": "Math.round(arcLength * Math.pow(10, inputs.precision)) / Math.pow(10, inputs.precision)",
    "sagitta": "inputs.radius - Math.sqrt(Math.pow(inputs.radius, 2) - Math.pow(chord / 2, 2))",
    "sagittaFinal": "Math.round(sagitta * Math.pow(10, inputs.precision)) / Math.pow(10, inputs.precision)",
    "segmentArea": "0.5 * Math.pow(inputs.radius, 2) * (angleRad - Math.sin(angleRad))",
    "segmentAreaFinal": "Math.round(segmentArea * Math.pow(10, inputs.precision)) / Math.pow(10, inputs.precision)"
  },
  "outputs": {
    "primary": "chordFinal",
    "breakdown": [
      "arcLengthFinal",
      "sagittaFinal",
      "segmentAreaFinal"
    ]
  },

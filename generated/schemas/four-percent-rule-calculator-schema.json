  "formulas": {
    "safeWithdrawal": "portfolioValue * withdrawalRate / 100",
    "neededPortfolio": "desiredAnnualWithdrawal / (withdrawalRate / 100)",
    "primary": "portfolioValue > 0 ? portfolioValue * withdrawalRate / 100 : (desiredAnnualWithdrawal > 0 ? desiredAnnualWithdrawal / (withdrawalRate / 100) : 0)"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "safeWithdrawal",
      "neededPortfolio"

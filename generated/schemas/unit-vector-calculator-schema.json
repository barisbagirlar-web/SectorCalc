  "formulas": {
    "deltaX": "endX - startX",
    "deltaY": "endY - startY",
    "deltaZ": "endZ - startZ",
    "magnitude": "Math.sqrt(deltaX**2 + deltaY**2 + deltaZ**2)",
    "_deltaX___magnitude__toFixed_4_": "(deltaX / magnitude).toFixed(4)",
    "_deltaY___magnitude__toFixed_4_": "(deltaY / magnitude).toFixed(4)",
    "_deltaZ___magnitude__toFixed_4_": "(deltaZ / magnitude).toFixed(4)",
    "magnitude_toFixed_4_": "magnitude.toFixed(4)",
    "result": "magnitude === 0 ? 'Undefined (zero vector)' : '(' + (deltaX/magnitude).toFixed(4) + ', ' + (deltaY/magnitude).toFixed(4) + ', ' + (deltaZ/magnitude).toFixed(4) + ')'"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "magnitude === 0 ? 'N/A' : (deltaX / magnitude).toFixed(4)",
      "magnitude === 0 ? 'N/A' : (deltaY / magnitude).toFixed(4)",
      "magnitude === 0 ? 'N/A' : (deltaZ / magnitude).toFixed(4)",
      "magnitude === 0 ? '0' : magnitude.toFixed(4)"
    ]
  },

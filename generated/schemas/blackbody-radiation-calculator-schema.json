  "formulas": {
    "totalRadiatedPower": "area * emissivity * 5.670374419e-8 * temperature**4",
    "peakWavelength": "(2.897771955e-3 / temperature) * 1e9",
    "spectralRadiance": "(2 * 6.62607015e-34 * 2.99792458e8**2 / ((wavelength * 1e-9)**5)) * (1 / (Math.exp((6.62607015e-34 * 2.99792458e8) / ((wavelength * 1e-9) * 1.380649e-23 * temperature)) - 1)) * emissivity",
    "irradiance": "(area * emissivity * 5.670374419e-8 * temperature**4) / (4 * Math.PI * distance**2)"
  },
  "outputs": {
    "primary": "totalRadiatedPower",
    "breakdown": [
      "peakWavelength",
      "spectralRadiance",
      "irradiance"
    ]
  },

{
  "toolName": "blackbody-radiation-calculator",
  "inputs": [
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "K",
      "default": 3000,
      "businessContext": "Temperature of the blackbody radiator in Kelvin"
    },
    {
      "id": "wavelength",
      "label": "Wavelength",
      "type": "number",
      "unit": "nm",
      "default": 500,
      "businessContext": "Wavelength for spectral radiance calculation in nanometers"
    },
    {
      "id": "emissivity",
      "label": "Emissivity",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Surface emissivity (1 for perfect blackbody, 0-1 for graybody)"
    },
    {
      "id": "area",
      "label": "Surface Area",
      "type": "number",
      "unit": "m²",
      "default": 1,
      "businessContext": "Emitting surface area"
    },
    {
      "id": "distance",
      "label": "Distance",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Distance from the radiator for irradiance calculation"
    }
  ],
  "formulas": {
    "totalRadiatedPower": "area * emissivity * 5.670374419e-8 * temperature**4",
    "peakWavelength": "(2.897771955e-3 / temperature) * 1e9",
    "spectralRadiance": "(2 * 6.62607015e-34 * 2.99792458e8**2 / ((wavelength * 1e-9)**5)) * (1 / (Math.exp((6.62607015e-34 * 2.99792458e8) / ((wavelength * 1e-9) * 1.380649e-23 * temperature)) - 1)) * emissivity",
    "irradiance": "(area * emissivity * 5.670374419e-8 * temperature**4) / (4 * Math.PI * distance**2)"
  },
  "outputs": {
    "primary": "totalRadiatedPower",
    "breakdown": [
      "peakWavelength",
      "spectralRadiance",
      "irradiance"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

      "label": "Workout Duration",
      "type": "number",
      "unit": "minutes",
      "default": 30,
      "businessContext": "Total duration of the CrossFit workout in minutes.",
      "label_i18n": {
        "en": "Workout Duration",
        "tr": "Workout Duration",
        "de": "Workout Duration",
        "fr": "Workout Duration",
        "es": "Workout Duration",
        "ar": "Workout Duration"
      }
    },
    {
      "id": "metValue",
      "label": "MET Value",
      "type": "number",
      "unit": "MET",
      "default": 8,
      "businessContext": "Metabolic Equivalent of Task (MET) for the workout intensity. CrossFit typically ranges 6-12 METs.",
      "label_i18n": {
        "en": "MET Value",
        "tr": "MET Value",
        "de": "MET Value",
        "fr": "MET Value",
        "es": "MET Value",
        "ar": "MET Value"
      }
    },
    {
      "id": "genderFactor",
      "label": "Gender Adjustment Factor",
      "type": "number",
      "unit": "factor",
      "default": 1,
      "businessContext": "Multiplier to adjust calories for gender differences (commonly 1.0 for males, 0.9 for females).",
      "label_i18n": {
        "en": "Gender Adjustment Factor",
        "tr": "Gender Adjustment Factor",
        "de": "Gender Adjustment Factor",
        "fr": "Gender Adjustment Factor",
        "es": "Gender Adjustment Factor",
        "ar": "Gender Adjustment Factor"
      }
    }
  ],
  "formulas": {
    "totalCalories": "genderFactor * metValue * weight * (duration / 60)",
    "caloriesPerMinute": "genderFactor * metValue * weight / 60",
    "caloriesPerHour": "genderFactor * metValue * weight"
  },
  "outputs": {
    "primary": "totalCalories",
    "breakdown": [

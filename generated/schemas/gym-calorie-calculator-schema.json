{
  "toolName": "gym-calorie-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User's weight in kilograms."
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "User's height in centimeters."
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User's age in years."
    },
    {
      "id": "gender",
      "label": "Gender",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "0 for female, 1 for male."
    },
    {
      "id": "duration",
      "label": "Exercise Duration",
      "type": "number",
      "unit": "min",
      "default": 30,
      "businessContext": "Duration of exercise in minutes."
    },
    {
      "id": "met",
      "label": "MET Value",
      "type": "number",
      "unit": "",
      "default": 8,
      "businessContext": "Metabolic Equivalent of Task for the activity (e.g., running 8 METs)."
    }
  ],
  "formulas": {
    "bmr": "gender === 1 ? 88.362 + (13.397 * weight) + (4.799 * height) - (5.677 * age) : 447.593 + (9.247 * weight) + (3.098 * height) - (4.330 * age)",
    "caloriesBurned": "met * weight * (duration / 60)",
    "caloriesPerMinute": "met * weight * (1 / 60)"
  },
  "outputs": {
    "primary": "caloriesBurned",
    "breakdown": [
      "bmr",
      "caloriesPerMinute"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Karbon",
  "premiumRequired": false
}
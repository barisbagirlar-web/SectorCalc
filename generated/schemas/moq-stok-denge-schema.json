  "formulas": {
    "EOQ": "SQRT((2 * AnnualDemand * OrderCost) / HoldingCost)",
    "MOQ_Penalty": "IF(MOQ > EOQ, (MOQ - EOQ)/2 * HoldingCost, 0)",
    "PriceBreakSavings": "(UnitPrice_Standard - UnitPrice_MOQ) * AnnualDemand",
    "NetBenefit": "PriceBreakSavings - MOQ_Penalty - AdditionalOrderCostSavings",
    "OptimalOrderQty": "IF(NetBenefit > 0, MOQ, EOQ)",
    "CycleStock_Cost": "(OptimalOrderQty / 2) * HoldingCost"
  },
  "outputs": {
    "primary": "CycleStock_Cost",
    "unit": "USD",

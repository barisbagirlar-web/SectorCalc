      }
    },
    {
      "id": "picketSpacing",
      "label": "Picket Spacing",
      "type": "number",
      "unit": "m",
      "default": 0.05,
      "businessContext": "Gap between adjacent pickets (meters). Use 0 for solid fence.",
      "label_i18n": {
        "en": "Picket Spacing",
        "tr": "Picket Spacing",
        "de": "Picket Spacing",
        "fr": "Picket Spacing",
        "es": "Picket Spacing",
        "ar": "Picket Spacing"
      }
    },
    {
      "id": "coveragePerGallon",
      "label": "Coverage per Liter",
      "type": "number",
      "unit": "m²/L",
      "default": 5,
      "businessContext": "Stain coverage area per liter as per manufacturer data (m² per L).",
      "label_i18n": {
        "en": "Coverage per Liter",
        "tr": "Coverage per Liter",
        "de": "Coverage per Liter",
        "fr": "Coverage per Liter",
        "es": "Coverage per Liter",
        "ar": "Coverage per Liter"
      }
    },
    {
      "id": "numberOfCoats",
      "label": "Number of Coats",
      "type": "number",
      "unit": "unit",
      "default": 2,
      "businessContext": "Number of stain coats to apply (typ. 2 for durability).",
      "label_i18n": {
        "en": "Number of Coats",
        "tr": "Number of Coats",
        "de": "Number of Coats",
        "fr": "Number of Coats",
        "es": "Number of Coats",
        "ar": "Number of Coats"
      }
    }
  ],
  "formulas": {
    "totalArea": "2 * fenceLength * fenceHeight * picketWidth / (picketWidth + picketSpacing)",
    "stainNeededWithoutCoats": "totalArea / coveragePerGallon",
    "numberOfPickets": "fenceLength / (picketWidth + picketSpacing)",
    "totalStain": "stainNeededWithoutCoats * numberOfCoats"
  },
  "outputs": {
    "primary": "totalStain",
    "breakdown": [
      "totalArea",
      "stainNeededWithoutCoats",
      "numberOfPickets"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

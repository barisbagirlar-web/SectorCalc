      "id": "picketWidth",
      "label": "Picket Width",
      "type": "number",
      "unit": "m",
      "default": 0.1,
      "businessContext": "Width of each individual fence board or picket (meters).",
      "label_i18n": {
        "en": "Picket Width",
        "tr": "Picket Width",
        "de": "Picket Width",
        "fr": "Picket Width",
        "es": "Picket Width",

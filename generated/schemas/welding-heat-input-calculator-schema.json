        "fr": "Arc Efficiency",
        "es": "Arc Efficiency",
        "ar": "Arc Efficiency"
      }
    }
  ],
  "formulas": {
    "heatInput": "(voltage * current * 60 * efficiency) / (travelSpeed * 1000)",
    "effectiveHeatRate": "(voltage * current * efficiency * 60) / 1000",
    "powerInput": "voltage * current"

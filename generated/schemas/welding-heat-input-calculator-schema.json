      "label_i18n": {
        "en": "Current",
        "tr": "Current",
        "de": "Current",
        "fr": "Current",
        "es": "Current",
        "ar": "Current"
      }
    },
    {
      "id": "travelSpeed",
      "label": "Travel Speed",
      "type": "number",
      "unit": "mm/min",
      "default": 300,

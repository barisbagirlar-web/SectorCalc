        "de": "Travel Speed",
        "fr": "Travel Speed",
        "es": "Travel Speed",
        "ar": "Travel Speed"
      }
    },
    {
      "id": "efficiency",
      "label": "Arc Efficiency",
      "type": "number",
      "unit": "unit",
      "default": 0.8,
      "businessContext": "Thermal efficiency factor of the welding process (e.g., 0.8 for SMAW, 0.9 for GMAW, 1.0 for SAW).",

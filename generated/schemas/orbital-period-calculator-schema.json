{
  "toolName": "orbital-period-calculator",
  "inputs": [
    {
      "id": "altitude",
      "label": "Altitude",
      "type": "number",
      "unit": "m",
      "default": 400000,
      "businessContext": "Altitude of the satellite above the central body's surface."
    },
    {
      "id": "bodyRadius",
      "label": "Central Body Radius",
      "type": "number",
      "unit": "m",
      "default": 6371000,
      "businessContext": "Radius of the central body (planet or star)."
    },
    {
      "id": "bodyMass",
      "label": "Central Body Mass",
      "type": "number",
      "unit": "kg",
      "default": 5.972e+24,
      "businessContext": "Mass of the central body."
    },
    {
      "id": "gravitationalConstant",
      "label": "Gravitational Constant (G)",
      "type": "number",
      "unit": "m³/(kg·s²)",
      "default": 6.6743e-11,
      "businessContext": "Universal gravitational constant. Default is SI value."
    }
  ],
  "formulas": {
    "semiMajorAxis": "altitude + bodyRadius",
    "periodSeconds": "2 * Math.PI * Math.sqrt(Math.pow(semiMajorAxis, 3) / (gravitationalConstant * bodyMass))",
    "periodMinutes": "periodSeconds / 60",
    "periodHours": "periodMinutes / 60",
    "periodDays": "periodHours / 24"
  },
  "outputs": {
    "primary": "periodSeconds",
    "breakdown": [
      "periodMinutes",
      "periodHours",
      "periodDays"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

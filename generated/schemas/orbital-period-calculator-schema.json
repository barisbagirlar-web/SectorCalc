      }
    },
    {
      "id": "gravitationalConstant",
      "label": "Gravitational Constant (G)",
      "type": "number",
      "unit": "m³/(kg·s²)",
      "default": 6.6743e-11,
      "businessContext": "Universal gravitational constant. Default is SI value.",
      "label_i18n": {
        "en": "Gravitational Constant (G)",
        "tr": "Gravitational Constant (G)",
        "de": "Gravitational Constant (G)",
        "fr": "Gravitational Constant (G)",
        "es": "Gravitational Constant (G)",
        "ar": "Gravitational Constant (G)"
      }
    }
  ],
  "formulas": {
    "semiMajorAxis": "altitude + bodyRadius",
    "periodSeconds": "2 * Math.PI * Math.sqrt(Math.pow(semiMajorAxis, 3) / (gravitationalConstant * bodyMass))",
    "periodMinutes": "periodSeconds / 60",
    "periodHours": "periodMinutes / 60",
    "periodDays": "periodHours / 24"
  },
  "outputs": {
    "primary": "periodSeconds",
    "breakdown": [
      "periodMinutes",
      "periodHours",
      "periodDays"
    ]
  },

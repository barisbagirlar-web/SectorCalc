      }
    },
    {
      "id": "appraisalFee",
      "label": "Appraisal Fee",
      "type": "number",
      "unit": "USD",
      "default": 500,
      "businessContext": "Cost of professional property appraisal",
      "label_i18n": {
        "en": "Appraisal Fee",
        "tr": "Appraisal Fee",
        "de": "Appraisal Fee",
        "fr": "Appraisal Fee",
        "es": "Appraisal Fee",
        "ar": "Appraisal Fee"
      }
    },
    {
      "id": "titleInsurance",
      "label": "Title Insurance",
      "type": "number",
      "unit": "USD",
      "default": 1000,
      "businessContext": "Insurance protecting against title defects",
      "label_i18n": {
        "en": "Title Insurance",
        "tr": "Title Insurance",
        "de": "Title Insurance",
        "fr": "Title Insurance",
        "es": "Title Insurance",
        "ar": "Title Insurance"
      }
    },
    {
      "id": "recordingFees",
      "label": "Recording Fees",
      "type": "number",
      "unit": "USD",
      "default": 200,
      "businessContext": "Government fees for recording the deed",
      "label_i18n": {
        "en": "Recording Fees",
        "tr": "Recording Fees",
        "de": "Recording Fees",
        "fr": "Recording Fees",
        "es": "Recording Fees",
        "ar": "Recording Fees"
      }
    }
  ],
  "formulas": {
    "downPayment": "propertyPrice * downPaymentRate / 100",
    "loanAmount": "propertyPrice - downPayment",
    "originationFee": "loanAmount * originationFeeRate / 100",
    "totalClosingCosts": "downPayment + originationFee + appraisalFee + titleInsurance + recordingFees"
  },
  "outputs": {
    "primary": "totalClosingCosts",
    "breakdown": [
      "downPayment",
      "originationFee",
      "appraisalFee",
      "titleInsurance",
      "recordingFees"
    ],

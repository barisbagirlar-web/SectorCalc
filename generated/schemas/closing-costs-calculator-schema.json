      "unit": "%",
      "default": 1,
      "businessContext": "Lender's fee as percentage of loan amount",
      "label_i18n": {
        "en": "Loan Origination Fee Rate",
        "tr": "Loan Origination Fee Rate",
        "de": "Loan Origination Fee Rate",
        "fr": "Loan Origination Fee Rate",

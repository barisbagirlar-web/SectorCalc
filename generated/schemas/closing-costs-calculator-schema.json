{
  "toolName": "closing-costs-calculator",
  "inputs": [
    {
      "id": "propertyPrice",
      "label": "Property Price",
      "type": "number",
      "unit": "USD",
      "default": 300000,
      "businessContext": "Purchase price of the property",
      "label_i18n": {
        "en": "Property Price",
        "tr": "Property Price",
        "de": "Property Price",
        "fr": "Property Price",

  "formulas": {
    "bmrMifflin": "10 * weight + 6.25 * height - 5 * age + (gender === 1 ? 5 : -161)",
    "tdee": "bmrMifflin * activityLevel",
    "feastCalories": "tdee * 0.8",
    "undereatingCalories": "tdee * 0.2"
  },
  "outputs": {
    "primary": "feastCalories",

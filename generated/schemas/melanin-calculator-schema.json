{
  "toolName": "melanin-calculator",
  "inputs": [
    {
      "id": "eumelaninPercent",
      "label": "Eumelanin (%)",
      "type": "number",
      "unit": "%",
      "default": 70,
      "businessContext": "Percentage of eumelanin pigment in total melanin content. Typically ranges 60-80% for darker skin.",
      "label_i18n": {
        "en": "Eumelanin (%)",
        "tr": "Eumelanin (%)",
        "de": "Eumelanin (%)",
        "fr": "Eumelanin (%)",
        "es": "Eumelanin (%)",
        "ar": "Eumelanin (%)"
      }
    },
    {
      "id": "pheomelaninPercent",
      "label": "Pheomelanin (%)",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Percentage of pheomelanin pigment. Sum with eumelanin should be 100%.",
      "label_i18n": {
        "en": "Pheomelanin (%)",
        "tr": "Pheomelanin (%)",
        "de": "Pheomelanin (%)",
        "fr": "Pheomelanin (%)",
        "es": "Pheomelanin (%)",
        "ar": "Pheomelanin (%)"
      }
    },
    {
      "id": "melanocyteDensity",
      "label": "Melanocyte Density (cells/mm²)",
      "type": "number",
      "unit": "cells/mm²",
      "default": 1000,
      "businessContext": "Number of melanocytes per square millimeter of skin. Typically 900-2000.",
      "label_i18n": {
        "en": "Melanocyte Density (cells/mm²)",
        "tr": "Melanocyte Density (cells/mm²)",
        "de": "Melanocyte Density (cells/mm²)",
        "fr": "Melanocyte Density (cells/mm²)",
        "es": "Melanocyte Density (cells/mm²)",
        "ar": "Melanocyte Density (cells/mm²)"
      }
    },
    {
      "id": "avgMelaninPerCell",
      "label": "Avg. Melanin per Cell (ng)",
      "type": "number",
      "unit": "ng",
      "default": 0.05,
      "businessContext": "Average melanin content per melanocyte in nanograms.",
      "label_i18n": {
        "en": "Avg. Melanin per Cell (ng)",
        "tr": "Avg. Melanin per Cell (ng)",
        "de": "Avg. Melanin per Cell (ng)",
        "fr": "Avg. Melanin per Cell (ng)",
        "es": "Avg. Melanin per Cell (ng)",
        "ar": "Avg. Melanin per Cell (ng)"
      }
    }
  ],
  "formulas": {
    "melaninIndex": "(eumelaninPercent * melanocyteDensity * avgMelaninPerCell) / (pheomelaninPercent + 1)",
    "melaninIndex_aux": "(eumelaninPercent * melanocyteDensity * avgMelaninPerCell) / (pheomelaninPercent + 1)"
  },
  "outputs": {
    "primary": "melaninIndex",
    "breakdown": [
      "Step 1: Calculate eumelanin contribution = Eumelanin (%) × Melanocyte Density × Avg. Melanin per Cell",
      "Step 2: Calculate pheomelanin correction = 1 / (Pheomelanin (%) + 1)",
      "Step 3: Melanin Index = Eumelanin contribution × Pheomelanin correction"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "melaninIndex_aux",
    "unit": "%"
  },

    },
    {
      "id": "dod",
      "label": "Depth of Discharge (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Maximum discharge depth to avoid battery damage",
      "label_i18n": {
        "en": "Depth of Discharge (%)",
        "tr": "Deşarj Derinliği (%)",
        "de": "Depth of Discharge (%)",
        "fr": "Depth of Discharge (%)",
        "es": "Depth of Discharge (%)",
        "ar": "Depth of Discharge (%)"
      },
      "businessContext_i18n": {

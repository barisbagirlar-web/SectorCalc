      },
      "businessContext_i18n": {
        "en": "Nominal voltage of the battery",
        "tr": "Akünün nominal gerilimi"
      }
    },
    {
      "id": "loadPower",
      "label": "Load Power (W)",
      "type": "number",
      "unit": "W",
      "default": 50,
      "businessContext": "Continuous power draw from the battery",
      "label_i18n": {
        "en": "Load Power (W)",
        "tr": "Yük Gücü (W)",
        "de": "Load Power (W)",

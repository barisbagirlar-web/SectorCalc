        "tr": "Akü hasarını önlemek için maksimum deşarj derinliği"
      }
    },
    {
      "id": "efficiency",
      "label": "System Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Combined inverter and wiring efficiency losses",
      "label_i18n": {
        "en": "System Efficiency (%)",
        "tr": "Sistem Verimliliği (%)",
        "de": "System Efficiency (%)",
        "fr": "System Efficiency (%)",
        "es": "System Efficiency (%)",
        "ar": "System Efficiency (%)"
      },
      "businessContext_i18n": {
        "en": "Combined inverter and wiring efficiency losses",
        "tr": "Kombine invertör ve kablo kayıpları"
      }
    },
    {
      "id": "numberOfBatteries",
      "label": "Number of Batteries",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Total number of identical batteries in parallel (adds capacity)",
      "label_i18n": {
        "en": "Number of Batteries",
        "tr": "Akü Sayısı",
        "de": "Number of Batteries",
        "fr": "Number of Batteries",
        "es": "Number of Batteries",
        "ar": "Number of Batteries"
      },
      "businessContext_i18n": {
        "en": "Total number of identical batteries in parallel (adds capacity)",
        "tr": "Paralel bağlı toplam özdeş akü sayısı (kapasite ekler)"
      }
    }
  ],
  "formulas": {
    "totalWh": "capacity * voltage * numberOfBatteries",
    "usableWh": "capacity * voltage * numberOfBatteries * (dod / 100) * (efficiency / 100)",
    "totalAh": "capacity * numberOfBatteries",
    "runtimeHours": "usableWh / loadPower"
  },
  "outputs": {
    "primary": "runtimeHours",
    "breakdown": [
      "totalWh",
      "usableWh",
      "totalAh"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "runtimeHours",
    "unit": "h"
  },

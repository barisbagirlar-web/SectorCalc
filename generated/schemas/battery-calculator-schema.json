{
  "toolName": "battery-calculator",
  "inputs": [
    {
      "id": "capacity",
      "label": "Battery Capacity (Ah)",
      "type": "number",
      "unit": "Ah",
      "default": 100,
      "businessContext": "Rated ampere-hour capacity of a single battery"
    },
    {
      "id": "voltage",
      "label": "Nominal Voltage (V)",
      "type": "number",
      "unit": "V",
      "default": 12,
      "businessContext": "Nominal voltage of the battery"
    },
    {
      "id": "loadPower",
      "label": "Load Power (W)",
      "type": "number",
      "unit": "W",
      "default": 50,
      "businessContext": "Continuous power draw from the battery"
    },
    {
      "id": "dod",
      "label": "Depth of Discharge (%)",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Maximum discharge depth to avoid battery damage"
    },
    {
      "id": "efficiency",
      "label": "System Efficiency (%)",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Combined inverter and wiring efficiency losses"
    },
    {
      "id": "numberOfBatteries",
      "label": "Number of Batteries",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "Total number of identical batteries in parallel (adds capacity)"
    }
  ],
  "formulas": {
    "totalWh": "capacity * voltage * numberOfBatteries",
    "usableWh": "capacity * voltage * numberOfBatteries * (dod / 100) * (efficiency / 100)",
    "totalAh": "capacity * numberOfBatteries",
    "runtimeHours": "usableWh / loadPower"
  },
  "outputs": {
    "primary": "runtimeHours",
    "breakdown": [
      "totalWh",
      "usableWh",
      "totalAh"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Karbon",
  "premiumRequired": false,
  "catalogCategory": "construction-measurement",
  "sectorSlug": "construction",
  "categorySlug": "project-construction-management"
}

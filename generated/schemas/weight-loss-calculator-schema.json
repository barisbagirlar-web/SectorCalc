  "toolName": "weight-loss-calculator",
  "inputs": [
    {
      "id": "initialWeight",
      "label": "Initial Weight",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Weight of the material before the drying process.",
      "label_i18n": {
        "en": "Initial Weight",

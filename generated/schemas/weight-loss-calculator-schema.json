      }
    },
    {
      "id": "initialMoisture",
      "label": "Initial Moisture Content",
      "type": "number",
      "unit": "%",
      "default": 50,
      "businessContext": "Moisture content of the material before drying as a percentage of total weight.",
      "label_i18n": {
        "en": "Initial Moisture Content",
        "tr": "Initial Moisture Content",
        "de": "Initial Moisture Content",
        "fr": "Initial Moisture Content",
        "es": "Initial Moisture Content",
        "ar": "Initial Moisture Content"
      }
    },
    {
      "id": "finalMoisture",
      "label": "Final Moisture Content",
      "type": "number",
      "unit": "%",
      "default": 10,
      "businessContext": "Desired moisture content after drying as a percentage of total weight.",
      "label_i18n": {
        "en": "Final Moisture Content",
        "tr": "Final Moisture Content",
        "de": "Final Moisture Content",
        "fr": "Final Moisture Content",
        "es": "Final Moisture Content",
        "ar": "Final Moisture Content"
      }
    },
    {
      "id": "targetWeightLoss",
      "label": "Target Weight Loss",
      "type": "number",
      "unit": "kg",
      "default": 40,
      "businessContext": "Expected weight loss based on process specifications for comparison.",
      "label_i18n": {
        "en": "Target Weight Loss",
        "tr": "Target Weight Loss",
        "de": "Target Weight Loss",
        "fr": "Target Weight Loss",
        "es": "Target Weight Loss",
        "ar": "Target Weight Loss"
      }
    }
  ],
  "formulas": {
    "boneDryWeight": "initialWeight / (1 + initialMoisture / 100)",
    "finalWeight": "boneDryWeight * (1 + finalMoisture / 100)",
    "weightLoss": "initialWeight - finalWeight",
    "percentageLoss": "(weightLoss / initialWeight) * 100",
    "targetDelta": "targetWeightLoss - weightLoss"
  },
  "outputs": {
    "primary": "weightLoss",
    "breakdown": [
      "percentageLoss",
      "targetDelta"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "targetDelta"
  },

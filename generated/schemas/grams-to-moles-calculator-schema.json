{
  "toolName": "grams-to-moles-calculator",
  "inputs": [
    {
      "id": "mass_in_grams",
      "label": "Mass (g)",
      "type": "number",
      "unit": "g",
      "default": 0,
      "businessContext": "Mass of the substance in grams. Ensure unit consistency; if using kg or mg, convert to g first.",
      "label_i18n": {
        "en": "Mass (g)",
        "tr": "Mass (g)",
        "de": "Mass (g)",
        "fr": "Mass (g)",
        "es": "Mass (g)",
        "ar": "Mass (g)"
      }
    },
    {
      "id": "molecular_weight",
      "label": "Molecular Weight",
      "type": "number",
      "unit": "g/mol",
      "default": 18.015,
      "businessContext": "Molar mass in grams per mole. Obtain from periodic table or material datasheet. Default: water (18.015 g/mol).",
      "label_i18n": {
        "en": "Molecular Weight",
        "tr": "Molecular Weight",
        "de": "Molecular Weight",
        "fr": "Molecular Weight",
        "es": "Molecular Weight",
        "ar": "Molecular Weight"
      }
    },
    {
      "id": "purity_percent",
      "label": "Purity (%)",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Substance purity as percentage. Adjust for impure samples; 100% ideal. Used to calculate effective mass.",
      "label_i18n": {
        "en": "Purity (%)",
        "tr": "Purity (%)",
        "de": "Purity (%)",
        "fr": "Purity (%)",
        "es": "Purity (%)",
        "ar": "Purity (%)"
      }
    },
    {
      "id": "yield_percent",
      "label": "Process Yield (%)",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Process yield efficiency (actual output / theoretical). 100% means no loss. Affects final mole quantity.",
      "label_i18n": {
        "en": "Process Yield (%)",
        "tr": "Process Yield (%)",
        "de": "Process Yield (%)",
        "fr": "Process Yield (%)",
        "es": "Process Yield (%)",
        "ar": "Process Yield (%)"
      }
    }
  ],
  "formulas": {
    "effectiveMass": "mass_in_grams * (purity_percent / 100)",
    "theoreticalMoles": "effectiveMass / molecular_weight",
    "actualMoles": "theoreticalMoles * (yield_percent / 100)"
  },
  "outputs": {
    "primary": "actualMoles",
    "breakdown": [
      "effectiveMass",
      "theoreticalMoles",
      "actualMoles"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "actualMoles"
  },

{
  "slug": "dairy-profit-detector",
  "premiumRequired": true,
  "premiumFeatures": [
    "PDF export",
    "CSV export",
    "Trend analysis",
    "Benchmarking against industry standards",
    "Automated root cause alerts"
  ],
  "inputs": [
    {
      "id": "milk_volume_liters",
      "label": "Milk Volume (Liters per day)",
      "type": "number",
      "unit": "L/day",
      "default": 10000,
      "min": 0,
      "max": 1000000,
      "businessContext": "Total raw milk received daily from suppliers or own herd."
    },
    {
      "id": "fat_percentage",
      "label": "Fat Content (%)",
      "type": "number",
      "unit": "%",
      "default": 3.5,
      "min": 0,
      "max": 10,
      "businessContext": "Average butterfat content of incoming milk, critical for yield calculations."
    },
    {
      "id": "protein_percentage",
      "label": "Protein Content (%)",
      "type": "number",
      "unit": "%",
      "default": 3.2,
      "min": 0,
      "max": 6,
      "businessContext": "Average protein content, affects cheese and powder yields."
    },
    {
      "id": "selling_price_per_liter",
      "label": "Selling Price (per Liter)",
      "type": "number",
      "unit": "USD/L",
      "default": 0.45,
      "min": 0,
      "max": 10,
      "businessContext": "Average revenue per liter of raw milk sold to processor or retail."
    },
    {
      "id": "production_cost_per_liter",
      "label": "Production Cost (per Liter)",
      "type": "number",
      "unit": "USD/L",
      "default": 0.35,
      "min": 0,
      "max": 10,
      "businessContext": "Includes feed, labor, utilities, veterinary, and overhead per liter."
    },
    {
      "id": "waste_percentage",
      "label": "Waste / Shrinkage (%)",
      "type": "number",
      "unit": "%",
      "default": 2,
      "min": 0,
      "max": 20,
      "businessContext": "Milk lost due to spoilage, spillage, or quality rejection."
    },
    {
      "id": "labor_hours_per_day",
      "label": "Labor Hours per Day",
      "type": "number",
      "unit": "hours",
      "default": 40,
      "min": 0,
      "max": 500,
      "businessContext": "Total direct labor hours used in milk production and handling."
    },
    {
      "id": "labor_rate_per_hour",
      "label": "Labor Rate (per Hour)",
      "type": "number",
      "unit": "USD/hour",
      "default": 15,
      "min": 0,
      "max": 100,
      "businessContext": "Average hourly wage including benefits."
    },
    {
      "id": "energy_cost_per_day",
      "label": "Energy Cost (per Day)",
      "type": "number",
      "unit": "USD/day",
      "default": 200,
      "min": 0,
      "max": 10000,
      "businessContext": "Daily electricity, fuel, and cooling costs."
    },
    {
      "id": "other_variable_cost_per_liter",
      "label": "Other Variable Cost (per Liter)",
      "type": "number",
      "unit": "USD/L",
      "default": 0.05,
      "min": 0,
      "max": 5,
      "businessContext": "Supplies, additives, packaging, and miscellaneous variable costs."
    },
    {
      "id": "fixed_cost_per_day",
      "label": "Fixed Cost (per Day)",
      "type": "number",
      "unit": "USD/day",
      "default": 500,
      "min": 0,
      "max": 50000,
      "businessContext": "Depreciation, rent, insurance, and other fixed overhead."
    },
    {
      "id": "quality_grade",
      "label": "Quality Grade",
      "type": "select",
      "unit": "",
      "default": "A",
      "min": null,
      "max": null,
      "businessContext": "Milk quality grade based on somatic cell count and bacteria (A, B, C).",
      "options": [
        "A",
        "B",
        "C"
      ]
    },
    {
      "id": "seasonal_demand_factor",
      "label": "Seasonal Demand Factor",
      "type": "select",
      "unit": "",
      "default": "Normal",
      "min": null,
      "max": null,
      "businessContext": "Adjusts for peak/off-peak demand periods.",
      "options": [
        "Low",
        "Normal",
        "High"
      ]
    }
  ],
  "validation": {
    "rules": [
      {
        "id": "rule_1",
        "condition": "milk_volume_liters > 0",
        "message": "Milk volume must be greater than zero."
      },
      {
        "id": "rule_2",
        "condition": "fat_percentage >= 0 && fat_percentage <= 10",
        "message": "Fat percentage must be between 0 and 10."
      },
      {
        "id": "rule_3",
        "condition": "protein_percentage >= 0 && protein_percentage <= 6",
        "message": "Protein percentage must be between 0 and 6."
      },
      {
        "id": "rule_4",
        "condition": "selling_price_per_liter >= 0",
        "message": "Selling price must be non-negative."
      },
      {
        "id": "rule_5",
        "condition": "production_cost_per_liter >= 0",
        "message": "Production cost must be non-negative."
      },
      {
        "id": "rule_6",
        "condition": "waste_percentage >= 0 && waste_percentage <= 20",
        "message": "Waste percentage must be between 0 and 20."
      },
      {
        "id": "rule_7",
        "condition": "labor_hours_per_day >= 0",
        "message": "Labor hours must be non-negative."
      },
      {
        "id": "rule_8",
        "condition": "labor_rate_per_hour >= 0",
        "message": "Labor rate must be non-negative."
      },
      {
        "id": "rule_9",
        "condition": "energy_cost_per_day >= 0",
        "message": "Energy cost must be non-negative."
      },
      {
        "id": "rule_10",
        "condition": "other_variable_cost_per_liter >= 0",
        "message": "Other variable cost must be non-negative."
      },
      {
        "id": "rule_11",
        "condition": "fixed_cost_per_day >= 0",
        "message": "Fixed cost must be non-negative."
      },
      {
        "id": "rule_12",
        "condition": "quality_grade == 'A' || quality_grade == 'B' || quality_grade == 'C'",
        "message": "Quality grade must be A, B, or C."
      },
      {
        "id": "rule_13",
        "condition": "seasonal_demand_factor == 'Low' || seasonal_demand_factor == 'Normal' || seasonal_demand_factor == 'High'",
        "message": "Seasonal demand factor must be Low, Normal, or High."
      }
    ],
    "thresholds": [
      {
        "id": "threshold_1",
        "condition": "profit_margin_percentage < 5",
        "severity": "warning",
        "message": "Profit margin is below 5% – consider cost reduction or price increase."
      },
      {
        "id": "threshold_2",
        "condition": "profit_margin_percentage < 0",
        "severity": "critical",
        "message": "Negative profit margin – immediate action required."
      },
      {
        "id": "threshold_3",
        "condition": "waste_percentage > 5",
        "severity": "warning",
        "message": "Waste exceeds 5% – investigate process losses."
      },
      {
        "id": "threshold_4",
        "condition": "labor_efficiency < 50",
        "severity": "warning",
        "message": "Labor efficiency (liters per labor hour) below 50 – review staffing and automation."
      },
      {
        "id": "threshold_5",
        "condition": "quality_grade == 'C'",
        "severity": "critical",
        "message": "Quality grade C – urgent quality improvement needed to avoid penalties."
      }
    ]
  },
  "formulas": [
    {
      "id": "net_milk_volume",
      "label": "Net Milk Volume (after waste)",
      "expression": "milk_volume_liters * (1 - waste_percentage / 100)",
      "unit": "L/day",
      "description": "Effective milk volume after accounting for shrinkage."
    },
    {
      "id": "total_variable_cost_per_day",
      "label": "Total Variable Cost per Day",
      "expression": "(production_cost_per_liter + other_variable_cost_per_liter) * milk_volume_liters + labor_hours_per_day * labor_rate_per_hour + energy_cost_per_day",
      "unit": "USD/day",
      "description": "Sum of all variable costs including labor and energy."
    },
    {
      "id": "total_cost_per_day",
      "label": "Total Cost per Day",
      "expression": "total_variable_cost_per_day + fixed_cost_per_day",
      "unit": "USD/day",
      "description": "Total daily cost (variable + fixed)."
    },
    {
      "id": "revenue_per_day",
      "label": "Revenue per Day",
      "expression": "net_milk_volume * selling_price_per_liter",
      "unit": "USD/day",
      "description": "Daily revenue from milk sales."
    },
    {
      "id": "profit_per_day",
      "label": "Profit per Day",
      "expression": "revenue_per_day - total_cost_per_day",
      "unit": "USD/day",
      "description": "Daily net profit."
    },
    {
      "id": "profit_margin_percentage",
      "label": "Profit Margin (%)",
      "expression": "(profit_per_day / revenue_per_day) * 100",
      "unit": "%",
      "description": "Profit as a percentage of revenue."
    },
    {
      "id": "labor_efficiency",
      "label": "Labor Efficiency (Liters per Labor Hour)",
      "expression": "net_milk_volume / labor_hours_per_day",
      "unit": "L/hour",
      "description": "Milk volume processed per labor hour."
    }
  ],
  "outputs": {
    "primary": {
      "id": "profit_per_day",
      "label": "Daily Profit",
      "unit": "USD/day",
      "description": "Primary result – net profit per day."
    },
    "breakdown": {
      "revenue_per_day": {
        "id": "revenue_per_day",
        "label": "Revenue per Day",
        "unit": "USD/day"
      },
      "total_cost_per_day": {
        "id": "total_cost_per_day",
        "label": "Total Cost per Day",
        "unit": "USD/day"
      },
      "total_variable_cost_per_day": {
        "id": "total_variable_cost_per_day",
        "label": "Total Variable Cost per Day",
        "unit": "USD/day"
      },
      "fixed_cost_per_day": {
        "id": "fixed_cost_per_day",
        "label": "Fixed Cost per Day",
        "unit": "USD/day"
      },
      "net_milk_volume": {
        "id": "net_milk_volume",
        "label": "Net Milk Volume",
        "unit": "L/day"
      },
      "profit_margin_percentage": {
        "id": "profit_margin_percentage",
        "label": "Profit Margin (%)",
        "unit": "%"
      },
      "labor_efficiency": {
        "id": "labor_efficiency",
        "label": "Labor Efficiency",
        "unit": "L/hour"
      }
    },
    "hiddenLossDrivers": [
      {
        "id": "waste_loss",
        "label": "Waste Loss",
        "value": "milk_volume_liters * waste_percentage / 100 * selling_price_per_liter",
        "unit": "USD/day",
        "description": "Revenue lost due to waste."
      },
      {
        "id": "quality_penalty",
        "label": "Quality Penalty",
        "value": "quality_grade == 'C' ? 0.02 * milk_volume_liters : (quality_grade == 'B' ? 0.01 * milk_volume_liters : 0)",
        "unit": "USD/day",
        "description": "Estimated revenue loss from lower quality grade."
      },
      {
        "id": "labor_inefficiency_cost",
        "label": "Labor Inefficiency Cost",
        "value": "labor_hours_per_day * labor_rate_per_hour * (1 - (net_milk_volume / (labor_hours_per_day * 100)))",
        "unit": "USD/day",
        "description": "Cost of labor above benchmark efficiency (100 L/hour)."
      },
      {
        "id": "energy_overuse_cost",
        "label": "Energy Overuse Cost",
        "value": "energy_cost_per_day * 0.1",
        "unit": "USD/day",
        "description": "Estimated 10% energy waste due to inefficiencies."
      }
    ],
    "suggestedActions": [
      {
        "id": "action_1",
        "priority": "high",
        "description": "Reduce waste by improving cooling and handling processes – target waste below 2%."
      },
      {
        "id": "action_2",
        "priority": "medium",
        "description": "Review labor scheduling and consider automation if labor efficiency is below 80 L/hour."
      },
      {
        "id": "action_3",
        "priority": "high",
        "description": "Negotiate better milk prices or shift to higher-value products (cheese, yogurt) if margin is low."
      },
      {
        "id": "action_4",
        "priority": "medium",
        "description": "Implement energy audits and upgrade to energy-efficient equipment to reduce energy cost."
      },
      {
        "id": "action_5",
        "priority": "critical",
        "description": "Immediate quality improvement program if grade is C – review herd health and milking hygiene."
      }
    ],
    "dataConfidenceAdjusted": 0.85
  }
}
{
  "toolName": "plateau-calculator",
  "inputs": [
    {
      "id": "initialOutput",
      "label": "Başlangıç Performansı",
      "type": "number",
      "unit": "birim/saat",
      "default": 10,
      "businessContext": "Öğrenme eğrisinin başlangıç noktasındaki saatlik çıktı miktarı"
    },
    {
      "id": "outputAfterPeriod",
      "label": "Öğrenme Sonrası Performans",
      "type": "number",
      "unit": "birim/saat",
      "default": 20,
      "businessContext": "Belirli bir öğrenme süresi sonunda ulaşılan saatlik çıktı"
    },
    {
      "id": "timePeriod",
      "label": "Öğrenme Süresi",
      "type": "number",
      "unit": "hafta",
      "default": 8,
      "businessContext": "Performans ölçümleri arasındaki geçen hafta sayısı"
    },
    {
      "id": "learningRate",
      "label": "Öğrenme Hızı Sabiti",
      "type": "number",
      "unit": "1/hafta",
      "default": 0.25,
      "businessContext": "Öğrenme eğrisinin diklik katsayısı, üstel yaklaşım modeli için"
    }
  ],
  "formulas": {
    "plateau": "(outputAfterPeriod - initialOutput * Math.exp(-learningRate * timePeriod)) / (1 - Math.exp(-learningRate * timePeriod))",
    "approachPercent": "(outputAfterPeriod / ((outputAfterPeriod - initialOutput * Math.exp(-learningRate * timePeriod)) / (1 - Math.exp(-learningRate * timePeriod)))) * 100",
    "timeTo95": "-(Math.log(0.05)) / learningRate"
  },
  "outputs": {
    "primary": "plateau",
    "breakdown": [
      {
        "id": "approachPercent",
        "label": "Platoya Yaklaşma Yüzdesi",
        "unit": "%",
        "formula": "approachPercent"
      },
      {
        "id": "timeTo95",
        "label": "%95 Platoya Ulaşma Süresi",
        "unit": "hafta",
        "formula": "timeTo95"
      }
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "categorySlug": "technology-ai-cloud-cyber",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning"
}

        "ar": "Body Mass"
      }
    },
    {
      "id": "fallHeight",
      "label": "Fall Height",
      "type": "number",
      "unit": "m",
      "default": 2,
      "businessContext": "Vertical drop from climber's feet to pad surface",
      "label_i18n": {
        "en": "Fall Height",
        "tr": "Fall Height",
        "de": "Fall Height",
        "fr": "Fall Height",
        "es": "Fall Height",
        "ar": "Fall Height"
      }
    },
    {
      "id": "matThickness",
      "label": "Mat Thickness",
      "type": "number",
      "unit": "cm",
      "default": 10,
      "businessContext": "Crash pad thickness",
      "label_i18n": {
        "en": "Mat Thickness",
        "tr": "Mat Thickness",
        "de": "Mat Thickness",
        "fr": "Mat Thickness",
        "es": "Mat Thickness",
        "ar": "Mat Thickness"
      }
    },
    {
      "id": "matStiffness",
      "label": "Mat Stiffness",
      "type": "number",
      "unit": "kN/m",
      "default": 50,
      "businessContext": "Overall pad stiffness (typical 20-100 kN/m)",
      "label_i18n": {
        "en": "Mat Stiffness",
        "tr": "Mat Stiffness",
        "de": "Mat Stiffness",
        "fr": "Mat Stiffness",
        "es": "Mat Stiffness",
        "ar": "Mat Stiffness"
      }
    },
    {
      "id": "g",
      "label": "Gravity",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Acceleration due to gravity",
      "label_i18n": {
        "en": "Gravity",
        "tr": "Gravity",
        "de": "Gravity",
        "fr": "Gravity",
        "es": "Gravity",
        "ar": "Gravity"
      }
    }
  ],
  "formulas": {
    "matThicknessM": "matThickness / 100",
    "matStiffnessNm": "matStiffness * 1000",
    "mg": "bodyMass * g",
    "discriminant": "Math.sqrt(mg**2 + 2 * mg * matStiffnessNm * fallHeight)",
    "matCompression": "(mg + discriminant) / matStiffnessNm",
    "maxForce": "matStiffnessNm * matCompression",
    "matCompression___100": "matCompression * 100",
    "_maxForce___mg_____bodyMass___g_": "(maxForce - mg) / (bodyMass * g)",
    "12000___maxForce": "12000 / maxForce",
    "result": "maxForce / 1000"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "matCompression * 100",
      "(maxForce - mg) / (bodyMass * g)",
      "12000 / maxForce"
    ]
  },

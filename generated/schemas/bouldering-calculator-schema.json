{
  "toolName": "bouldering-calculator",
  "inputs": [
    {
      "id": "bodyMass",
      "label": "Body Mass",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "Total mass of the climber including gear",
      "label_i18n": {

      }
    },
    {
      "id": "upperIntensity",
      "label": "Upper Intensity Zone",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Target heart rate zone upper bound",
      "label_i18n": {
        "en": "Upper Intensity Zone",
        "tr": "Yüksek Yoğunluk Bölgesi",
        "de": "Hohe Intensitätszone",
        "fr": "Zone d'intensité supérieure",
        "es": "Zona de intensidad alta",
        "ar": "Upper Intensity Zone"
      },
      "businessContext_i18n": {
        "en": "Target heart rate zone upper bound",
        "tr": "Hedef kalp atış hızı bölgesi üst sınırı",
        "de": "Obere Grenze der Zielherzfrequenzzone",
        "fr": "Limite supérieure de la zone de fréquence cardiaque cible",
        "es": "Límite superior de la zona de frecuencia cardíaca objetivo"
      }
    }
  ],
  "formulas": {
    "age": "currentYear - birthYear",
    "maxHR": "220 - age",
    "heartRateReserve": "maxHR - restingHR",
    "lowerTarget": "restingHR + heartRateReserve * (lowerIntensity / 100)",
    "upperTarget": "restingHR + heartRateReserve * (upperIntensity / 100)"
  },
  "outputs": {
    "primary": "maxHR",
    "breakdown": [
      "lowerTarget",
      "upperTarget"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "upperTarget",

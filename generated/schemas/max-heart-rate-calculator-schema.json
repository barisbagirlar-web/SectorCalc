    },
    {
      "id": "lowerIntensity",
      "label": "Lower Intensity Zone",
      "type": "number",
      "unit": "%",
      "default": 60,
      "businessContext": "Target heart rate zone lower bound",
      "label_i18n": {
        "en": "Lower Intensity Zone",
        "tr": "Düşük Yoğunluk Bölgesi",

{
  "toolName": "texas-method-calculator",
  "inputs": [
    {
      "id": "oneRepMax",
      "label": "1RM (One Rep Max)",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "The maximum weight you can lift for one repetition.",
      "label_i18n": {
        "en": "1RM (One Rep Max)",
        "tr": "1RM (One Rep Max)",
        "de": "1RM (One Rep Max)",
        "fr": "1RM (One Rep Max)",
        "es": "1RM (One Rep Max)",
        "ar": "1RM (One Rep Max)"
      }
    },
    {
      "id": "fiveRepMaxPercentage",
      "label": "5RM % of 1RM",
      "type": "number",
      "unit": "%",
      "default": 85,
      "businessContext": "Percentage of your 1RM that represents your 5-rep max. Typically 85%.",
      "label_i18n": {
        "en": "5RM % of 1RM",
        "tr": "5RM % of 1RM",
        "de": "5RM % of 1RM",
        "fr": "5RM % of 1RM",
        "es": "5RM % of 1RM",
        "ar": "5RM % of 1RM"
      }
    },
    {
      "id": "volumeDayPercentage",
      "label": "Volume Day % of 5RM",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Percentage of your 5RM used for the volume day (5 sets of 5 reps).",
      "label_i18n": {
        "en": "Volume Day % of 5RM",
        "tr": "Volume Day % of 5RM",
        "de": "Volume Day % of 5RM",
        "fr": "Volume Day % of 5RM",
        "es": "Volume Day % of 5RM",
        "ar": "Volume Day % of 5RM"
      }
    },
    {
      "id": "lightDayPercentage",
      "label": "Light Day % of Volume",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Percentage of the volume day weight used for the light day (2 sets of 5 reps).",
      "label_i18n": {
        "en": "Light Day % of Volume",
        "tr": "Light Day % of Volume",
        "de": "Light Day % of Volume",
        "fr": "Light Day % of Volume",
        "es": "Light Day % of Volume",
        "ar": "Light Day % of Volume"
      }
    },
    {
      "id": "intensityDayIncrement",
      "label": "Intensity Day Increment",
      "type": "number",
      "unit": "kg",
      "default": 2.5,
      "businessContext": "Weight added to the previous week's intensity day weight for a new 5RM attempt. Set to 0 if not incrementing.",
      "label_i18n": {
        "en": "Intensity Day Increment",
        "tr": "Intensity Day Increment",
        "de": "Intensity Day Increment",
        "fr": "Intensity Day Increment",
        "es": "Intensity Day Increment",
        "ar": "Intensity Day Increment"
      }
    }
  ],
  "formulas": {
    "fiveRM": "oneRepMax * (fiveRepMaxPercentage / 100)",
    "volumeDayWeight": "fiveRM * (volumeDayPercentage / 100)",
    "lightDayWeight": "volumeDayWeight * (lightDayPercentage / 100)",
    "intensityDayWeight": "fiveRM + intensityDayIncrement"
  },
  "outputs": {
    "primary": "volumeDayWeight",
    "breakdown": [

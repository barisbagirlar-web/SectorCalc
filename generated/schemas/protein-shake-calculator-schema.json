{
  "toolName": "protein-shake-calculator",
  "inputs": [
    {
      "id": "scoopWeight",
      "label": "Scoop Weight (g)",
      "type": "number",
      "unit": "g",
      "default": 30,
      "businessContext": "Weight of one scoop of protein powder",
      "label_i18n": {
        "en": "Scoop Weight (g)",
        "tr": "Scoop Weight (g)",
        "de": "Scoop Weight (g)",
        "fr": "Scoop Weight (g)",

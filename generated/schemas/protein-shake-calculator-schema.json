        "ar": "Scoop Weight (g)"
      }
    },
    {
      "id": "numScoops",
      "label": "Number of Scoops",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of scoops used in the shake",
      "label_i18n": {
        "en": "Number of Scoops",
        "tr": "Number of Scoops",
        "de": "Number of Scoops",
        "fr": "Number of Scoops",
        "es": "Number of Scoops",
        "ar": "Number of Scoops"
      }
    },
    {
      "id": "proteinPer100g",
      "label": "Protein per 100g (%)",
      "type": "number",
      "unit": "%",
      "default": 80,
      "businessContext": "Protein content as percentage of powder weight",
      "label_i18n": {
        "en": "Protein per 100g (%)",
        "tr": "Protein per 100g (%)",
        "de": "Protein per 100g (%)",
        "fr": "Protein per 100g (%)",
        "es": "Protein per 100g (%)",
        "ar": "Protein per 100g (%)"
      }
    },
    {
      "id": "caloriesPer100g",
      "label": "Calories per 100g",
      "type": "number",
      "unit": "kcal",
      "default": 400,
      "businessContext": "Caloric content per 100g of powder",
      "label_i18n": {
        "en": "Calories per 100g",
        "tr": "Calories per 100g",
        "de": "Calories per 100g",
        "fr": "Calories per 100g",
        "es": "Calories per 100g",
        "ar": "Calories per 100g"
      }
    },
    {
      "id": "liquidVolume",
      "label": "Liquid Volume (ml)",
      "type": "number",
      "unit": "ml",
      "default": 300,
      "businessContext": "Volume of liquid added (milk or water)",
      "label_i18n": {
        "en": "Liquid Volume (ml)",
        "tr": "Liquid Volume (ml)",
        "de": "Liquid Volume (ml)",
        "fr": "Liquid Volume (ml)",
        "es": "Liquid Volume (ml)",
        "ar": "Liquid Volume (ml)"
      }
    }
  ],
  "formulas": {
    "totalProtein": "scoopWeight * numScoops * proteinPer100g / 100",
    "totalPowderWeight": "scoopWeight * numScoops",
    "totalCalories": "scoopWeight * numScoops * caloriesPer100g / 100",
    "proteinPer100ml": "scoopWeight * numScoops * proteinPer100g / liquidVolume"
  },
  "outputs": {
    "primary": "totalProtein",
    "breakdown": [
      "totalPowderWeight",
      "totalCalories",
      "proteinPer100ml"
    ],

  "formulas": {
    "GrossAnnualSalary": "BaseSalary + Bonuses",
    "EmployerTaxes": "GrossAnnualSalary * TaxRate",
    "Benefits": "HealthInsurance + RetirementMatch + PaidTimeOffCost",
    "TotalLaborCost": "GrossAnnualSalary + EmployerTaxes + Benefits",
    "ProductiveHours": "(WeeksPerYear - VacationWeeks) * HoursPerWeek * (1 - IdleTimePct)",
    "FullyBurdenedHourlyRate": "TotalLaborCost / ProductiveHours",
    "MarginRate": "FullyBurdenedHourlyRate * (1 + TargetMargin)"
  },

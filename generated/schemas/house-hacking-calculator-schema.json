    {
      "id": "vacancyRate",
      "label": "Vacancy Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Expected percentage of time the rental units are vacant.",
      "label_i18n": {
        "en": "Vacancy Rate",
        "tr": "Vacancy Rate",
        "de": "Vacancy Rate",
        "fr": "Vacancy Rate",
        "es": "Vacancy Rate",
        "ar": "Vacancy Rate"
      }
    }
  ],
  "formulas": {
    "loanAmount": "propertyPrice - downPayment",
    "monthlyInterestRate": "interestRate / 100 / 12",
    "numberOfPayments": "loanTerm * 12",
    "vacancyLoss": "monthlyRentIncome * (vacancyRate / 100)",
    "effectiveRentIncome": "monthlyRentIncome - vacancyLoss"
  },
  "outputs": {
    "primary": "loanAmount",
    "breakdown": [
      "Monthly Mortgage Payment",
      "Effective Rental Income",
      "Cash-on-Cash Return"
    ],

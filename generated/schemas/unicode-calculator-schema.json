        "de": "Öbek Sayısı",
        "fr": "Öbek Sayısı",
        "es": "Öbek Sayısı",
        "ar": "Öbek Sayısı"
      }
    },
    {
      "id": "costPerMB",
      "label": "MB Maliyeti",
      "type": "number",
      "unit": "TL/MB",
      "default": 0.05,
      "businessContext": "1 MB veri depolama veya iletim maliyeti",
      "label_i18n": {
        "en": "MB Maliyeti",
        "tr": "MB Maliyeti",
        "de": "MB Maliyeti",
        "fr": "MB Maliyeti",
        "es": "MB Maliyeti",
        "ar": "MB Maliyeti"
      }
    }
  ],
  "formulas": {
    "totalBytes": "charCount * (encoding == 1 ? 2 : encoding == 2 ? 2 : 4) + overhead * lineCount",
    "totalMB": "totalBytes / (1024 * 1024)",
    "totalCost": "totalMB * costPerMB"
  },

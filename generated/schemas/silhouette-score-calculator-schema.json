  "formulas": {
    "silhouette1": "(b1 - a1) / (Math.max(a1, b1) + 1e-9)",
    "silhouette2": "(b2 - a2) / (Math.max(a2, b2) + 1e-9)",
    "avgSilhouette": "(silhouette1 + silhouette2) / 2"
  },
  "outputs": {

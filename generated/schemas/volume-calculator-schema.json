{
  "toolName": "volume-calculator",
  "inputs": [
    {
      "id": "length",
      "label": "Length",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of the object in meters"
    },
    {
      "id": "width",
      "label": "Width",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Width of the object in meters"
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Height of the object in meters"
    },
    {
      "id": "shape",
      "label": "Shape Factor",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "1 for rectangular, 0.5236 for spherical (4/3*pi/8), etc."
    }
  ],
  "formulas": {
    "volume": "length * width * height * shape",
    "surfaceArea": "2 * (length * width + length * height + width * height)",
    "mass": "volume * 1000"
  },
  "outputs": {
    "primary": "volume",
    "breakdown": [
      "surfaceArea",
      "mass"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

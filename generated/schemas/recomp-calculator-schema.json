        "de": "Annual Interest Rate",
        "fr": "Annual Interest Rate",
        "es": "Annual Interest Rate",
        "ar": "Annual Interest Rate"
      }
    },
    {
      "id": "time",
      "label": "Time Period",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Duration in months.",
      "label_i18n": {
        "en": "Time Period",
        "tr": "Time Period",
        "de": "Time Period",
        "fr": "Time Period",
        "es": "Time Period",
        "ar": "Time Period"
      }
    },
    {
      "id": "expenses",
      "label": "Additional Expenses",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Any additional expenses to include.",
      "label_i18n": {
        "en": "Additional Expenses",
        "tr": "Additional Expenses",
        "de": "Additional Expenses",
        "fr": "Additional Expenses",
        "es": "Additional Expenses",
        "ar": "Additional Expenses"
      }
    },
    {
      "id": "adjustmentFactor",
      "label": "Adjustment Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "A factor to adjust the compensation (e.g., risk factor).",
      "label_i18n": {
        "en": "Adjustment Factor",
        "tr": "Adjustment Factor",
        "de": "Adjustment Factor",
        "fr": "Adjustment Factor",
        "es": "Adjustment Factor",
        "ar": "Adjustment Factor"
      }
    }
  ],
  "formulas": {
    "interestAmount": "baseAmount * (rate / 100) * (time / 12)",
    "totalBeforeAdjustment": "baseAmount + interestAmount + expenses",
    "totalCompensation": "totalBeforeAdjustment * adjustmentFactor"
  },
  "outputs": {
    "primary": "totalCompensation",
    "breakdown": [
      "interestAmount",
      "totalBeforeAdjustment"
    ],

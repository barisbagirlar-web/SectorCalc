        "fr": "Durée en mois.",
        "es": "Duración en meses."
      }
    },
    {
      "id": "expenses",
      "label": "Additional Expenses",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Any additional expenses to include.",
      "label_i18n": {
        "en": "Additional Expenses",
        "tr": "Ek Giderler",
        "de": "Zusätzliche Ausgaben",
        "fr": "Frais supplémentaires",
        "es": "Gastos adicionales",
        "ar": "Additional Expenses"
      },
      "businessContext_i18n": {
        "en": "Any additional expenses to include.",
        "tr": "Dahil edilecek ek masraflar.",
        "de": "Zusätzliche Ausgaben, die einbezogen werden sollen.",
        "fr": "Toute dépense supplémentaire à inclure.",
        "es": "Cualquier gasto adicional a incluir."
      }
    },
    {
      "id": "adjustmentFactor",
      "label": "Adjustment Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "A factor to adjust the compensation (e.g., risk factor).",
      "label_i18n": {
        "en": "Adjustment Factor",
        "tr": "Düzeltme Faktörü",
        "de": "Düzeltme Faktörü",
        "fr": "Facteur d'ajustement",
        "es": "Düzeltme Faktörü",
        "ar": "Adjustment Factor"
      },
      "businessContext_i18n": {
        "en": "A factor to adjust the compensation (e.g., risk factor).",
        "tr": "Tazminatı ayarlamak için bir faktör (örneğin, risk faktörü).",
        "de": "Ein Faktor zur Anpassung der Vergütung (z. B. Risikofaktor).",
        "fr": "Un facteur pour ajuster la compensation (par exemple, facteur de risque).",
        "es": "Factor para ajustar la compensación (p. ej., factor de riesgo)."
      }
    }
  ],
  "formulas": {
    "interestAmount": "baseAmount * (rate / 100) * (time / 12)",
    "totalBeforeAdjustment": "baseAmount + interestAmount + expenses",
    "totalCompensation": "totalBeforeAdjustment * adjustmentFactor"
  },
  "outputs": {
    "primary": "totalCompensation",
    "breakdown": [
      "interestAmount",
      "totalBeforeAdjustment"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

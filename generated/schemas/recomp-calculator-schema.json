      },
      "businessContext_i18n": {
        "en": "Annual interest rate for compensation calculation.",
        "tr": "Tazminat hesaplaması için yıllık faiz oranı.",
        "de": "Jährlicher Zinssatz für die Vergütungsberechnung.",
        "fr": "Taux d'intérêt annuel pour le calcul de la compensation.",
        "es": "Tasa de interés anual para el cálculo de compensación."
      }
    },
    {
      "id": "time",
      "label": "Time Period",

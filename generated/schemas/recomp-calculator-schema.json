{
  "toolName": "recomp-calculator",
  "inputs": [
    {
      "id": "baseAmount",
      "label": "Base Amount",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "The initial principal or base value."
    },
    {
      "id": "rate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual interest rate for compensation calculation."
    },
    {
      "id": "time",
      "label": "Time Period",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Duration in months."
    },
    {
      "id": "expenses",
      "label": "Additional Expenses",
      "type": "number",
      "unit": "currency",
      "default": 0,
      "businessContext": "Any additional expenses to include."
    },
    {
      "id": "adjustmentFactor",
      "label": "Adjustment Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "A factor to adjust the compensation (e.g., risk factor)."
    }
  ],
  "formulas": {
    "interestAmount": "baseAmount * (rate / 100) * (time / 12)",
    "totalBeforeAdjustment": "baseAmount + interestAmount + expenses",
    "totalCompensation": "totalBeforeAdjustment * adjustmentFactor"
  },
  "outputs": {
    "primary": "totalCompensation",
    "breakdown": [
      "interestAmount",
      "totalBeforeAdjustment"
    ]
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "categorySlug": "finance-sales-working-capital",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "sectorId": "finans",
  "profession": "Risk Uzmanı",
  "categoryId": "cost"
}

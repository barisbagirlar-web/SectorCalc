      }
    },
    {
      "id": "rate",
      "label": "Annual Interest Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Annual interest rate for compensation calculation.",
      "label_i18n": {
        "en": "Annual Interest Rate",

      "label": "Base Amount",
      "type": "number",
      "unit": "currency",
      "default": 1000,
      "businessContext": "The initial principal or base value.",
      "label_i18n": {
        "en": "Base Amount",
        "tr": "Temel Tutar",
        "de": "Basisbetrag",

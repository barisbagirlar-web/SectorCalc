  "formulas": {
    "diameter_inches_used": "diameter_inches > 0 ? diameter_inches : (circumference_inches > 0 ? circumference_inches / Math.PI : (diameter_mm > 0 ? diameter_mm / 25.4 : (circumference_mm > 0 ? (circumference_mm / 25.4) / Math.PI : 0)))",
    "us_size": "(diameter_inches_used - 0.562) / 0.087",
    "eu_size": "(diameter_inches_used * Math.PI * 25.4) - 40",
    "circumference_mm_used": "diameter_inches_used * Math.PI * 25.4"
  },
  "outputs": {
    "primary": "us_size",
    "breakdown": [
      "us_size",
      "eu_size",
      "circumference_mm_used",
      "diameter_inches_used"
    ]
  },

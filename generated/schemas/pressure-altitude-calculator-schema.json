{
  "toolName": "pressure-altitude-calculator",
  "inputs": [
    {
      "id": "fieldElevation",
      "label": "Field Elevation (ft)",
      "type": "number",
      "unit": "ft",
      "default": 0,
      "businessContext": "Elevation of the location above mean sea level in feet. Use either this or the meters input.",
      "label_i18n": {
        "en": "Field Elevation (ft)",
        "tr": "Field Elevation (ft)",
        "de": "Field Elevation (ft)",
        "fr": "Field Elevation (ft)",
        "es": "Field Elevation (ft)",
        "ar": "Field Elevation (ft)"
      }
    },
    {
      "id": "fieldElevationMeters",
      "label": "Field Elevation (m)",
      "type": "number",
      "unit": "m",
      "default": 0,
      "businessContext": "Elevation of the location above mean sea level in meters. Used only if fieldElevation is 0.",
      "label_i18n": {
        "en": "Field Elevation (m)",
        "tr": "Field Elevation (m)",
        "de": "Field Elevation (m)",
        "fr": "Field Elevation (m)",
        "es": "Field Elevation (m)",
        "ar": "Field Elevation (m)"
      }
    },
    {
      "id": "altimeterSetting",
      "label": "Altimeter Setting (inHg)",
      "type": "number",
      "unit": "inHg",
      "default": 29.92,
      "businessContext": "Current altimeter setting or QNH in inches of mercury. Use either this or QNH hPa.",
      "label_i18n": {
        "en": "Altimeter Setting (inHg)",
        "tr": "Altimeter Setting (inHg)",
        "de": "Altimeter Setting (inHg)",
        "fr": "Altimeter Setting (inHg)",
        "es": "Altimeter Setting (inHg)",
        "ar": "Altimeter Setting (inHg)"
      }
    },
    {
      "id": "qnhHpa",
      "label": "QNH (hPa)",
      "type": "number",
      "unit": "hPa",
      "default": 1013.25,
      "businessContext": "Current altimeter setting or QNH in hectopascals. Used only if altimeterSetting is 0.",
      "label_i18n": {
        "en": "QNH (hPa)",
        "tr": "QNH (hPa)",
        "de": "QNH (hPa)",
        "fr": "QNH (hPa)",
        "es": "QNH (hPa)",
        "ar": "QNH (hPa)"
      }
    },
    {
      "id": "standardPressure",
      "label": "Standard Pressure (inHg)",
      "type": "number",
      "unit": "inHg",
      "default": 29.92,
      "businessContext": "Standard pressure at sea level in inches of mercury. Normally 29.92 inHg.",
      "label_i18n": {
        "en": "Standard Pressure (inHg)",
        "tr": "Standard Pressure (inHg)",
        "de": "Standard Pressure (inHg)",
        "fr": "Standard Pressure (inHg)",
        "es": "Standard Pressure (inHg)",
        "ar": "Standard Pressure (inHg)"
      }
    }
  ],
  "formulas": {
    "eleFt": "fieldElevation > 0 ? fieldElevation : (fieldElevationMeters > 0 ? fieldElevationMeters * 3.28084 : 0)",
    "pressInHg": "altimeterSetting > 0 ? altimeterSetting : (qnhHpa > 0 ? qnhHpa * 0.02953 : 29.92)",
    "pressureAltitudeFt": "eleFt + (standardPressure - pressInHg) * 1000",
    "pressureAltitudeM": "pressureAltitudeFt * 0.3048"
  },
  "outputs": {
    "primary": "pressureAltitudeFt",
    "breakdown": [
      "pressureAltitudeM",
      "eleFt",
      "pressInHg"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pressureAltitudeM",
    "unit": "ft"
  },
  "category": "Diğer",
  "sector": "Fizik & Mekanik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "process-chemical",
  "sectorId": "fizik",
  "profession": "Fizik Mühendisi",
  "categoryId": "diger",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

  "formulas": {
    "exponent": "number === 0 ? 0 : (notationMode === 0 ? Math.floor(Math.log10(Math.abs(number))) : Math.floor(Math.log10(Math.abs(number)) / 3) * 3)",
    "mantissa": "(function() { if (number === 0) return 0; var exp = number === 0 ? 0 : (notationMode === 0 ? Math.floor(Math.log10(Math.abs(number))) : Math.floor(Math.log10(Math.abs(number)) / 3) * 3); var m = number / Math.pow(10, exp); if (m === 0) return 0; var d = Math.ceil(Math.log10(Math.abs(m))); var power = sigFig - d; var mag = Math.pow(10, power); return Math.round(m * mag) / mag; })()",
    "primary": "mantissa + ' × 10^' + exponent",

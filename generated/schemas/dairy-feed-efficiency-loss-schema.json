{
  "toolName": "dairy-feed-efficiency-loss",
  "inputs": [
    {
      "id": "milkYieldPerCow",
      "label": "Milk Yield per Cow (kg/day)",
      "type": "number",
      "unit": "kg/day",
      "default": 30,
      "min": 0,
      "max": 100,
      "options": null,
      "businessContext": "Average daily milk production per cow. Standard dairy industry metric."
    },
    {
      "id": "feedIntakePerCow",
      "label": "Feed Intake per Cow (kg DM/day)",
      "type": "number",
      "unit": "kg DM/day",
      "default": 20,
      "min": 0,
      "max": 50,
      "options": null,
      "businessContext": "Dry matter feed intake per cow per day. Key input for feed efficiency calculation."
    },
    {
      "id": "feedCostPerKg",
      "label": "Feed Cost per kg DM ($)",
      "type": "number",
      "unit": "$/kg DM",
      "default": 0.3,
      "min": 0,
      "max": 1,
      "options": null,
      "businessContext": "Cost per kilogram of dry matter feed. Varies by region and feed type."
    },
    {
      "id": "milkPricePerKg",
      "label": "Milk Price per kg ($)",
      "type": "number",
      "unit": "$/kg",
      "default": 0.4,
      "min": 0,
      "max": 1,
      "options": null,
      "businessContext": "Revenue per kilogram of milk. Market price."
    },
    {
      "id": "herdSize",
      "label": "Herd Size (number of cows)",
      "type": "number",
      "unit": "cows",
      "default": 100,
      "min": 1,
      "max": 10000,
      "options": null,
      "businessContext": "Total number of lactating cows in the herd."
    },
    {
      "id": "daysInMilk",
      "label": "Days in Milk (days)",
      "type": "number",
      "unit": "days",
      "default": 305,
      "min": 0,
      "max": 365,
      "options": null,
      "businessContext": "Average lactation length per cow per year. Typically 305 days."
    },
    {
      "id": "targetFeedEfficiency",
      "label": "Target Feed Efficiency (kg milk/kg DM)",
      "type": "number",
      "unit": "kg milk/kg DM",
      "default": 1.5,
      "min": 0.5,
      "max": 3,
      "options": null,
      "businessContext": "Industry benchmark for feed efficiency. Typically 1.2-1.8."
    }
  ],
  "validation": {
    "rules": [
      "milkYieldPerCow > 0",
      "feedIntakePerCow > 0",
      "feedCostPerKg > 0",
      "milkPricePerKg > 0",
      "herdSize > 0",
      "daysInMilk >= 0",
      "targetFeedEfficiency > 0"
    ],
    "thresholds": {
      "feedEfficiency": {
        "low": 1.2,
        "high": 1.8
      }
    }
  },
  "formulas": {
    "actualFeedEfficiency": "milkYieldPerCow / feedIntakePerCow",
    "efficiencyLossRatio": "max(0, (targetFeedEfficiency - actualFeedEfficiency) / targetFeedEfficiency)",
    "milkRevenuePerCowPerDay": "milkYieldPerCow * milkPricePerKg",
    "feedCostPerCowPerDay": "feedIntakePerCow * feedCostPerKg",
    "incomeOverFeedCostPerCowPerDay": "milkRevenuePerCowPerDay - feedCostPerCowPerDay",
    "potentialIncomeOverFeedCostPerCowPerDay": "(targetFeedEfficiency * feedIntakePerCow * milkPricePerKg) - feedCostPerCowPerDay",
    "lossPerCowPerDay": "max(0, potentialIncomeOverFeedCostPerCowPerDay - incomeOverFeedCostPerCowPerDay)",
    "totalAnnualLoss": "lossPerCowPerDay * herdSize * daysInMilk"
  },
  "outputs": {
    "primary": "totalAnnualLoss",
    "breakdown": {
      "actualFeedEfficiency": "actualFeedEfficiency",
      "efficiencyLossRatio": "efficiencyLossRatio",
      "lossPerCowPerDay": "lossPerCowPerDay",
      "incomeOverFeedCostPerCowPerDay": "incomeOverFeedCostPerCowPerDay",
      "potentialIncomeOverFeedCostPerCowPerDay": "potentialIncomeOverFeedCostPerCowPerDay"
    },
    "hiddenLossDrivers": [
      "if actualFeedEfficiency < 1.2 then 'Low feed efficiency detected'",
      "if actualFeedEfficiency > 1.8 then 'High feed efficiency (possible overestimation)'"
    ],
    "suggestedActions": [
      "Review feed ration formulation and quality",
      "Check for health issues affecting milk production",
      "Optimize milking frequency and parlor management",
      "Consider genetic improvement for feed efficiency"
    ],
    "dataConfidenceAdjusted": "totalAnnualLoss * (1 - dataConfidenceAdjustment)"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Benchmark Comparison",
    "Detailed Report with Breakdown"
  ],
  "premiumRequired": true
}

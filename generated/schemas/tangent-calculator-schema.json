        "ar": "Compute tan(2θ)?"
      }
    }
  ],
  "formulas": {
    "thetaRad": "(unitRadians == 1) ? angle : angle * Math.PI / 180",
    "effectiveAngle": "(computeDouble == 1) ? 2 * thetaRad : thetaRad"

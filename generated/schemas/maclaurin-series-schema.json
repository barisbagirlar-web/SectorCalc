    {
      "id": "terms",
      "label": "Number of terms n",
      "type": "number",
      "unit": "unit",
      "default": 5,
      "businessContext": "Number of terms in the series",
      "label_i18n": {
        "en": "Number of terms n",
        "tr": "Number of terms n",

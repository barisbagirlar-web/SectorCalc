        "ar": "Number of terms n"
      }
    }
  ],
  "formulas": {
    "approximation": "let sum = 0; for(let k=0; k<terms; k++) { let coeff = (k%2===0 ? 1 : -1) / factorial(2*k+1); sum += coeff * Math.pow(x_value, 2*k+1); } sum",
    "exact": "Math.sin(x_value)",
    "error": "Math.abs(approximation - exact)"
  },
  "outputs": {
    "primary": "approximation",
    "breakdown": [
      "exact",
      "error"
    ]
  },

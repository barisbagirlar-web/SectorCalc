  "formulas": {
    "L_m": "tileLength / 1000",
    "W_m": "tileWidth / 1000",
    "J_m": "jointWidth / 1000",
    "D_m": "tileThickness / 1000",
    "volumePerM2": "((L_m + W_m) / (L_m * W_m)) * J_m * D_m * wasteFactor * 1000",
    "totalVolume": "volumePerM2 * area",
    "totalWeight": "totalVolume * groutDensity"
  },
  "outputs": {
    "primary": "totalWeight",
    "breakdown": [
      "Grout Volume per m²: ${volumePerM2.toFixed(2)} L/m²",
      "Total Grout Volume: ${totalVolume.toFixed(2)} L",
      "Tiles Needed: ${tilesNeeded} pieces"

{
  "toolName": "rsu-calculator",
  "inputs": [
    {
      "id": "totalRSUs",
      "label": "Total RSUs Granted",
      "type": "number",
      "unit": "units",
      "default": 1000,
      "businessContext": "Total number of restricted stock units awarded.",
      "label_i18n": {
        "en": "Total RSUs Granted",
        "tr": "Verilen Toplam RSU",
        "de": "Total RSUs Granted",
        "fr": "Total RSUs Granted",
        "es": "Total RSUs Granted",
        "ar": "Total RSUs Granted"
      },
      "businessContext_i18n": {
        "en": "Total number of restricted stock units awarded.",
        "tr": "Verilen toplam kısıtlı hisse senedi birimi sayısı"
      }
    },
    {
      "id": "vestedPercentage",
      "label": "Vested Percentage",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Percentage of RSUs that have vested.",
      "label_i18n": {
        "en": "Vested Percentage",
        "tr": "Hakedilen Yüzde",
        "de": "Vested Percentage",
        "fr": "Vested Percentage",
        "es": "Vested Percentage",
        "ar": "Vested Percentage"
      },
      "businessContext_i18n": {
        "en": "Percentage of RSUs that have vested.",
        "tr": "Hakedilen RSU'ların yüzdesi"
      }
    },
    {
      "id": "sharePrice",
      "label": "Current Share Price",
      "type": "number",
      "unit": "USD",
      "default": 50,
      "businessContext": "Current market price per share.",
      "label_i18n": {
        "en": "Current Share Price",
        "tr": "Güncel Hisse Fiyatı",
        "de": "Aktueller Aktienkurs",
        "fr": "Current Share Price",
        "es": "Current Share Price",
        "ar": "Current Share Price"
      },
      "businessContext_i18n": {
        "en": "Current market price per share.",
        "tr": "Hisse başına güncel piyasa fiyatı"
      }
    },
    {
      "id": "taxRate",
      "label": "Estimated Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 30,
      "businessContext": "Combined federal and state tax rate applied at vesting.",
      "label_i18n": {
        "en": "Estimated Tax Rate",
        "tr": "Tahmini Vergi Oranı",
        "de": "Estimated Tax Rate",
        "fr": "Estimated Tax Rate",
        "es": "Estimated Tax Rate",
        "ar": "Estimated Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Combined federal and state tax rate applied at vesting.",
        "tr": "Hakedişte uygulanan birleşik federal ve eyalet vergi oranı"
      }
    }
  ],
  "formulas": {
    "vestedShares": "totalRSUs * (vestedPercentage / 100)",
    "preTaxValue": "vestedShares * sharePrice",
    "estimatedTax": "preTaxValue * (taxRate / 100)",
    "netValue": "preTaxValue - estimatedTax"
  },
  "outputs": {
    "primary": "netValue",
    "breakdown": [
      "vestedShares",
      "preTaxValue",
      "estimatedTax",
      "netValue"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netValue",
    "unit": "%",
    "breakdownUnits": {
      "vestedShares": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & Muhasebe",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",

{
  "toolName": "motor-gucu-kw-hp-cevirici",
  "inputs": [
    {
      "id": "powerKw",
      "label": "Güç (kW)",
      "type": "number",
      "unit": "kW",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Motor gücü kilowatt cinsinden. ISO 80000-4 standardına göre SI birimi."
    },
    {
      "id": "powerHp",
      "label": "Güç (HP)",
      "type": "number",
      "unit": "HP",
      "default": 0,
      "min": 0,
      "max": null,
      "options": null,
      "businessContext": "Motor gücü beygir gücü cinsinden. Metrik HP (PS) kullanılır; 1 HP = 0.7355 kW (metrik)."
    },
    {
      "id": "conversionType",
      "label": "Dönüşüm Yönü",
      "type": "select",
      "unit": "",
      "default": "kWtoHP",
      "min": null,
      "max": null,
      "options": [
        "kWtoHP",
        "HPtoKW"
      ],
      "businessContext": "Dönüşüm yönü seçimi: kW'tan HP'ye veya HP'den kW'a."
    }
  ],
  "validation": {
    "rules": [
      "powerKw >= 0",
      "powerHp >= 0",
      "Eğer conversionType='kWtoHP' ise powerKw > 0",
      "Eğer conversionType='HPtoKW' ise powerHp > 0"
    ],
    "thresholds": {
      "powerKw": "Eğer powerKw > 1000 ise 'Yüksek güç seviyesi'",
      "powerHp": "Eğer powerHp > 1341 ise 'Yüksek güç seviyesi'"
    }
  },
  "formulas": {
    "convertedPower": "conversionType === 'kWtoHP' ? powerKw * 1.35962 : powerHp * 0.7355",
    "primaryResult": "convertedPower"
  },
  "outputs": {
    "primary": "convertedPower",
    "breakdown": {
      "inputPower": "conversionType === 'kWtoHP' ? powerKw : powerHp",
      "conversionFactor": "conversionType === 'kWtoHP' ? 1.35962 : 0.7355",
      "outputUnit": "conversionType === 'kWtoHP' ? 'HP' : 'kW'"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [],
    "dataConfidenceAdjusted": "convertedPower"
  },
  "premiumFeatures": [
    "PDF Export",
    "CSV Export",
    "Trend Analysis",
    "Comparison"
  ],
  "premiumRequired": false
}

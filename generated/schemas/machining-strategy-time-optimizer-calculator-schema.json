  "validation": {
    "rules": [
      {
        "id": "feed_speed_ratio",
        "condition": "feed_rate > 0.005 * cutting_speed",
        "message": "Feed rate too high relative to cutting speed; risk of poor surface finish (ISO 1302)."
      },
      {
        "id": "depth_limit",
        "condition": "depth_of_cut > 0.5 * part_diameter",
        "message": "Depth of cut exceeds 50% of part diameter; risk of chatter and tool breakage."
      },
      {
        "id": "tool_life_warning",
        "condition": "tool_life_minutes < 10",
        "message": "Tool life less than 10 minutes; excessive downtime and cost (Lean waste)."
      }
    ],
    "thresholds": [
      {
        "id": "cycle_time_alert",
        "condition": "primaryResult > 15",
        "message": "Cycle time exceeds 15 minutes; consider high-feed strategy or multi-tooling."
      },
      {
        "id": "cost_alert",
        "condition": "primaryResult * 2.5 > 50",
        "message": "Estimated cost per part exceeds $50; review tooling and parameters."
      }
    ]
  },
  "formulas": {
    "result": "cutting_speed + feed_rate + depth_of_cut",
    "result_copy": "cutting_speed + feed_rate + depth_of_cut"
  },

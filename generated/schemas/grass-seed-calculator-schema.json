        "ar": "Tohum Saflığı"
      }
    },
    {
      "id": "overseedingFactor",
      "label": "Yeniden Tohumlama Faktörü",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Yeniden tohumlama çarpanı (1 = yeni çim, >1 = mevcut çime ek tohumlama)",
      "label_i18n": {
        "en": "Yeniden Tohumlama Faktörü",
        "tr": "Yeniden Tohumlama Faktörü",
        "de": "Yeniden Tohumlama Faktörü",
        "fr": "Yeniden Tohumlama Faktörü",
        "es": "Yeniden Tohumlama Faktörü",
        "ar": "Yeniden Tohumlama Faktörü"
      }
    }
  ],
  "formulas": {
    "area": "length * width",
    "baseSeedGrams": "area * seedingRate",
    "adjustedSeedGrams": "baseSeedGrams / (germinationRate / 100) / (seedPurity / 100) * (1 + wasteFactor / 100) * overseedingFactor",
    "totalSeedKg": "adjustedSeedGrams / 1000"
  },
  "outputs": {
    "primary": "totalSeedKg",
    "breakdown": [
      "area",
      "baseSeedGrams",
      "adjustedSeedGrams"
    ]
  },

{
  "toolName": "latent-heat-calculator",
  "inputs": [
    {
      "id": "mass",
      "label": "Mass",
      "type": "number",
      "unit": "kg",
      "default": 1,
      "businessContext": "Mass of the substance undergoing phase change",
      "label_i18n": {
        "en": "Mass",
        "tr": "Mass",
        "de": "Mass",
        "fr": "Mass",
        "es": "Mass",
        "ar": "Mass"
      }
    },
    {
      "id": "specificLatentHeat",
      "label": "Specific Latent Heat",
      "type": "number",
      "unit": "kJ/kg",
      "default": 334,
      "businessContext": "Energy required per kilogram to change phase at constant temperature",
      "label_i18n": {
        "en": "Specific Latent Heat",
        "tr": "Specific Latent Heat",
        "de": "Specific Latent Heat",
        "fr": "Specific Latent Heat",
        "es": "Specific Latent Heat",
        "ar": "Specific Latent Heat"
      }
    },
    {
      "id": "numberOfCycles",
      "label": "Number of Cycles",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Number of complete phase change cycles (e.g., melt-freeze)",
      "label_i18n": {
        "en": "Number of Cycles",
        "tr": "Number of Cycles",
        "de": "Number of Cycles",
        "fr": "Number of Cycles",
        "es": "Number of Cycles",
        "ar": "Number of Cycles"
      }
    },
    {
      "id": "efficiency",
      "label": "Efficiency",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Heat transfer efficiency (0–100%) accounting for losses",
      "label_i18n": {
        "en": "Efficiency",
        "tr": "Efficiency",
        "de": "Efficiency",
        "fr": "Efficiency",
        "es": "Efficiency",
        "ar": "Efficiency"
      }
    }
  ],
  "formulas": {
    "energy_kj": "mass * specificLatentHeat * numberOfCycles * (efficiency / 100)",
    "energy_kwh": "mass * specificLatentHeat * numberOfCycles * (efficiency / 100) / 3600",
    "energy_per_cycle": "mass * specificLatentHeat * (efficiency / 100)"
  },
  "outputs": {
    "primary": "energy_kj",
    "breakdown": [
      "energy_kwh",
      "energy_per_cycle"
    ],

{
  "toolName": "minimum-weld-throat-thickness-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "mechanical-hvac-energy-loss",
  "sector": "Mechanical Engineering",
  "sectorId": "mechanical-hvac-energy-loss",
  "inputs": [
    {
      "id": "load",
      "label": "Applied Load (N)",
      "type": "number",
      "unit": "N",
      "default": 50000,
      "min": 0,
      "businessContext": "Force on weld."
    },
    {
      "id": "kaynakBoyu",
      "label": "Weld Length (m)",
      "type": "number",
      "unit": "m",
      "default": 0.1,
      "min": 0,
      "businessContext": "Weld seam length."
    },
    {
      "id": "kaynakGerilmesi",
      "label": "Allowable Weld Stress (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 120000000,
      "min": 0,
      "businessContext": "Weld metal allowable stress."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "load / Math.max(0.0001, (kaynakBoyu * kaynakGerilmesi))"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Min. Weld Throat Thickness"
    },

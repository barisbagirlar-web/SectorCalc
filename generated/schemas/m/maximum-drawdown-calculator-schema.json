  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "((zirveDeger - dipDeger) / Math.max(1, zirveDeger)) * 100"
  },

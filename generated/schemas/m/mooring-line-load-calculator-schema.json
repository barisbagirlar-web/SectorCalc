{
  "toolName": "mooring-line-load-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "agriculture-food-beverage",
  "sector": "Agriculture, Maritime and Drilling",
  "sectorId": "agriculture-food-beverage",
  "inputs": [
    {
      "id": "halatCapi",
      "label": "Rope Diameter (mm)",
      "type": "number",
      "unit": "mm",
      "default": 20,
      "min": 0,
      "businessContext": "Rope diameter in mm."
    },
    {
      "id": "malzemeKatsayisi",
      "label": "Material Coefficient (N/mm²)",
      "type": "number",
      "unit": "N/mm2",
      "default": 800,
      "min": 0,
      "businessContext": "Rope material tensile strength."
    },
    {
      "id": "guvenlikFaktoru",
      "label": "Safety Factor",
      "type": "number",
      "unit": "scalar",
      "default": 5,
      "min": 0,
      "businessContext": "Safety factor."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "kopmaYuku": "(Math.PI * Math.pow(halatCapi / 2, 2) * malzemeKatsayisi) / 1000",
    "result": "kopmaYuku / Math.max(0.0001, guvenlikFaktoru)"
  },
  "outputs": {
    "primary": "result",
    "unit": "kN",
    "breakdown": {

{
  "toolName": "minimum-sample-size-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "mathematics-statistics",
  "sector": "Veri ve Istatistik",
  "sectorId": "mathematics-statistics",
  "inputs": [
    {
      "id": "Z",
      "label": "Z Value",
      "type": "number",
      "unit": "scalar",
      "default": 1.96,
      "min": 0,
      "businessContext": "Z-score for confidence level."
    },
    {
      "id": "stdSapma",
      "label": "Estimated Std Dev",
      "type": "number",
      "unit": "scalar",
      "default": 10,
      "min": 0,
      "businessContext": "Population standard deviation."
    },
    {
      "id": "hataPayi",
      "label": "Margin of Error",
      "type": "number",
      "unit": "scalar",
      "default": 2,
      "min": 0,
      "businessContext": "Maximum allowable error."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.ceil(Math.pow((Z * stdSapma / Math.max(0.0001, hataPayi)), 2))"
  },
  "outputs": {
    "primary": "result",
    "unit": "samples",
    "breakdown": {
      "result": "Gereken Minimum Orneklem"
    },
    "breakdownUnits": {
      "result": "samples"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify statistical assumptions before making decisions.",
      "Use larger sample sizes for better accuracy."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],

{
  "toolName": "mud-annular-velocity-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "agriculture-food-beverage",
  "sector": "Agriculture, Maritime and Drilling",
  "sectorId": "agriculture-food-beverage",
  "inputs": [
    {
      "id": "camurDebi",
      "label": "Mud Flow Rate (m³/s)",
      "type": "number",
      "unit": "m3/s",
      "default": 0.01,
      "min": 0,
      "businessContext": "Mud flow rate."
    },
    {
      "id": "kuyuCapi",
      "label": "Wellbore Diameter (m)",
      "type": "number",
      "unit": "m",
      "default": 0.3,
      "min": 0,
      "businessContext": "Hole diameter."
    },
    {
      "id": "matkapCapi",
      "label": "Drill Pipe OD (m)",
      "type": "number",
      "unit": "m",
      "default": 0.1,
      "min": 0,
      "businessContext": "Drill pipe outer diameter."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(4 * camurDebi) / Math.max(0.0001, (Math.PI * (kuyuCapi * kuyuCapi - matkapCapi * matkapCapi)))"
  },
  "outputs": {
    "primary": "result",
    "unit": "m/s",
    "breakdown": {
      "result": "Halkasal Speed"
    },
    "breakdownUnits": {
      "result": "m/s"
    },
    "hiddenLossDrivers": [
      "Low efficiency may indicate equipment or process issues."
    ],

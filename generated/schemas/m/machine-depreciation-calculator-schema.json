  "inputs": [
    {
      "id": "bedel",
      "label": "Machine Cost (USD)",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "min": 0,
      "businessContext": "Machine purchase cost."
    },
    {
      "id": "kalinti",
      "label": "Salvage Value (USD)",
      "type": "number",
      "unit": "USD",
      "default": 50000,
      "min": 0,
      "businessContext": "End-of-life value."
    },
    {
      "id": "uretimKapasite",
      "label": "Total Production Capacity",
      "type": "number",
      "unit": "units",
      "default": 1000000,
      "min": 1,
      "businessContext": "Total units over machine life."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(bedel - kalinti) / Math.max(1, uretimKapasite)"
  },

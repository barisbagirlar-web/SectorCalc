    {
      "id": "familyHistory",
      "label": "Family History of Diabetes",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "First-degree relative with diabetes (1 if yes, 0 if no)",
      "label_i18n": {
        "en": "Family History of Diabetes",
        "tr": "Family History of Diabetes",
        "de": "Family History of Diabetes",
        "fr": "Family History of Diabetes",
        "es": "Family History of Diabetes",
        "ar": "Family History of Diabetes"
      }

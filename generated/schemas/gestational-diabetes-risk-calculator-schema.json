      "id": "fastingGlucose",
      "label": "Fasting Plasma Glucose",
      "type": "number",
      "unit": "mg/dL",
      "default": 90,
      "businessContext": "First trimester fasting glucose level",
      "label_i18n": {
        "en": "Fasting Plasma Glucose",
        "tr": "Fasting Plasma Glucose",
        "de": "Fasting Plasma Glucose",
        "fr": "Fasting Plasma Glucose",
        "es": "Fasting Plasma Glucose",
        "ar": "Fasting Plasma Glucose"
      }
    },
    {
      "id": "hba1c",
      "label": "HbA1c",
      "type": "number",
      "unit": "%",
      "default": 5.2,
      "businessContext": "Glycated hemoglobin percentage",
      "label_i18n": {
        "en": "HbA1c",
        "tr": "HbA1c",
        "de": "HbA1c",
        "fr": "HbA1c",
        "es": "HbA1c",
        "ar": "HbA1c"
      }
    },
    {
      "id": "triglycerides",
      "label": "Triglycerides",
      "type": "number",
      "unit": "mg/dL",
      "default": 130,
      "businessContext": "Fasting triglyceride level",
      "label_i18n": {
        "en": "Triglycerides",
        "tr": "Triglycerides",
        "de": "Triglycerides",
        "fr": "Triglycerides",
        "es": "Triglycerides",
        "ar": "Triglycerides"
      }
    }
  ],
  "formulas": {
    "logitScore": "(age-25)*0.05 + (bmi-22)*0.1 + familyHistory*0.7 + previousGdm*1.2 + ethnicity*0.4 + (fastingGlucose-80)*0.02 + (hba1c-4.5)*0.5 + (triglycerides-100)*0.003",
    "logitScore_aux": "(age-25)*0.05 + (bmi-22)*0.1 + familyHistory*0.7 + previousGdm*1.2 + ethnicity*0.4 + (fastingGlucose-80)*0.02 + (hba1c-4.5)*0.5 + (triglycerides-100)*0.003"
  },
  "outputs": {
    "primary": "logitScore_aux",

      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Maternal age at conception",
      "label_i18n": {
        "en": "Age",
        "tr": "Age",
        "de": "Age",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"

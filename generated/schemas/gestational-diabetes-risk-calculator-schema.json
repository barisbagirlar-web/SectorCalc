  "formulas": {
    "logitScore": "(age-25)*0.05 + (bmi-22)*0.1 + familyHistory*0.7 + previousGdm*1.2 + ethnicity*0.4 + (fastingGlucose-80)*0.02 + (hba1c-4.5)*0.5 + (triglycerides-100)*0.003",

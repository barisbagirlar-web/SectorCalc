        "fr": "Previous Gestational Diabetes",
        "es": "Previous Gestational Diabetes",
        "ar": "Previous Gestational Diabetes"
      }
    },
    {
      "id": "ethnicity",
      "label": "Ethnicity Risk Factor",
      "type": "number",
      "unit": "score",
      "default": 1,
      "businessContext": "High-risk ethnicity score (e.g., South Asian=2, Hispanic=1.5, Caucasian=1, etc.)",
      "label_i18n": {
        "en": "Ethnicity Risk Factor",

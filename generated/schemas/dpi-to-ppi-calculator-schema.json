    },
    {
      "id": "displayWidth",
      "label": "Display Width",
      "type": "number",
      "unit": "inches",
      "default": 5,
      "businessContext": "Desired physical width for display",
      "label_i18n": {
        "en": "Display Width",
        "tr": "Display Width",
        "de": "Display Width",
        "fr": "Display Width",
        "es": "Display Width",
        "ar": "Display Width"
      }
    },
    {
      "id": "displayHeight",
      "label": "Display Height",
      "type": "number",
      "unit": "inches",
      "default": 7,
      "businessContext": "Desired physical height for display",
      "label_i18n": {
        "en": "Display Height",
        "tr": "Display Height",
        "de": "Display Height",
        "fr": "Display Height",
        "es": "Display Height",
        "ar": "Display Height"
      }
    }
  ],
  "formulas": {
    "fittedPPI": "dpi / Math.min(displayWidth / originalWidth, displayHeight / originalHeight)",
    "horizontalPPI": "(dpi * originalWidth) / displayWidth",
    "verticalPPI": "(dpi * originalHeight) / displayHeight",
    "aspectRatioDelta": "Math.abs(originalWidth / originalHeight - displayWidth / displayHeight)"
  },
  "outputs": {
    "primary": "fittedPPI",
    "breakdown": [
      {
        "id": "horizontalPPI",
        "label": "Horizontal PPI",
        "unit": "PPI",
        "businessContext": "PPI if width is stretched to fill display width exactly"
      },
      {
        "id": "verticalPPI",
        "label": "Vertical PPI",
        "unit": "PPI",
        "businessContext": "PPI if height is stretched to fill display height exactly"
      },
      {
        "id": "aspectRatioDelta",
        "label": "Aspect Ratio Difference",
        "unit": "",
        "businessContext": "Absolute difference between original and display aspect ratios"
      }
    ]
  },

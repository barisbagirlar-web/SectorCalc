  "formulas": {
    "standardFactor": "unitType === 0 ? 3.78541 : 4.54609",
    "effectiveFactor": "customFactor > 0 ? customFactor : standardFactor",
    "totalGallons": "containerCount * gallonsPerContainer",
    "totalLiters": "totalGallons * effectiveFactor * (1 + wastePercentage / 100)"
  },
  "outputs": {
    "primary": "totalLiters",
    "breakdown": [
      "totalGallons",
      "effectiveFactor",
      "totalLiters"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "roundedLiters",
    "unit": "L",
    "breakdownUnits": {
      "totalGallons": "gal",
      "totalLiters": "L"
    }
  },

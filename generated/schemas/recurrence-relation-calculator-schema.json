{
  "toolName": "recurrence-relation-calculator",
  "inputs": [
    {
      "id": "n",
      "label": "Terim indeksi (n)",
      "type": "number",
      "unit": "",
      "default": 10,
      "businessContext": "Hesaplanacak terimin sıra numarası (0'dan başlar)."
    },
    {
      "id": "a0",
      "label": "Başlangıç değeri a0",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "n=0 için dizi değeri."
    },
    {
      "id": "a1",
      "label": "Başlangıç değeri a1",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "n=1 için dizi değeri."
    },
    {
      "id": "c1",
      "label": "Katsayı c1 (önceki terimin çarpanı)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "a_{n-1} teriminin katsayısı."
    },
    {
      "id": "c2",
      "label": "Katsayı c2 (iki önceki terimin çarpanı)",
      "type": "number",
      "unit": "",
      "default": 1,
      "businessContext": "a_{n-2} teriminin katsayısı."
    }
  ],
  "formulas": {
    "a_n": "((n,a0,a1,c1,c2)=>{if(n===0)return a0;if(n===1)return a1;let p2=a0,p1=a1;for(let i=2;i<=n;i++){let cur=c1*p1+c2*p2;p2=p1;p1=cur;}return p1;})(n,a0,a1,c1,c2)",
    "a0_out": "a0",
    "a1_out": "a1"
  },
  "outputs": {
    "primary": "a_n",
    "breakdown": [
      "a0_out",
      "a1_out"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "packaging-local-business"
}

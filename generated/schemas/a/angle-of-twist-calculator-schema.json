{
  "toolName": "angle-of-twist-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "mechanical-hvac-energy-loss",
  "sector": "Mechanical Engineering",
  "sectorId": "mechanical-hvac-energy-loss",
  "inputs": [
    {
      "id": "torque",
      "label": "Torque (N.m)",
      "type": "number",
      "unit": "N.m",
      "default": 1000,
      "min": 0,
      "businessContext": "Torque on shaft."
    },
    {
      "id": "length",
      "label": "Shaft Length (m)",
      "type": "number",
      "unit": "m",
      "default": 2,
      "min": 0,
      "businessContext": "Shaft length under torsion."
    },
    {
      "id": "kaymaModulu",
      "label": "Shear Modulus (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 80000000000,
      "min": 0,
      "businessContext": "Material shear modulus."
    },
    {
      "id": "kutupsalAtalet",
      "label": "Polar Moment (m⁴)",
      "type": "number",
      "unit": "m4",
      "default": 6.14e-7,
      "min": 0,
      "businessContext": "J = πR⁴/2."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(torque * length) / Math.max(0.0001, (kaymaModulu * kutupsalAtalet))"
  },
  "outputs": {
    "primary": "result",
    "unit": "rad",
    "breakdown": {
      "result": "Twist Angle (θ)"
    },
    "breakdownUnits": {
      "result": "rad"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify calculations with FEA or physical testing.",
      "Use appropriate safety factors for design."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate total angle of twist in a shaft under torsion.",
      "long": "Calculate total angle of twist in a shaft under torsion."
    }
  },
  "sectorSlug": "daily-renovation"
}

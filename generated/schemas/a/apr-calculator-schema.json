  "formulas": {
    "netKredi": "kredi - masraf",
    "aylikTaksit": "kredi * ((faiz/12/100) * Math.pow(1 + faiz/12/100, vade)) / (Math.pow(1 + faiz/12/100, vade) - 1)",
    "sonuc": "((kredi - masraf) > 0) ? ((((kredi * ((faiz/12/100) * Math.pow(1 + faiz/12/100, vade)) / (Math.pow(1 + faiz/12/100, vade) - 1)) * vade) - kredi) / kredi) * 100 / (vade/12) : 0"
  },

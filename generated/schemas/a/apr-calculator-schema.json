{
  "toolName": "apr-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "credit",
      "label": "Loan Amount (USD)",
      "type": "number",
      "unit": "USD",
      "default": 50000,
      "min": 0,
      "businessContext": "Total loan principal."
    },
    {
      "id": "interest",
      "label": "Nominal Interest (%)",
      "type": "number",
      "unit": "%",
      "default": 12,
      "min": 0,
      "businessContext": "Annual nominal interest rate."
    },
    {
      "id": "vade",
      "label": "Term (Months)",
      "type": "number",
      "unit": "months",
      "default": 36,
      "min": 1,
      "businessContext": "Total loan term."
    },
    {
      "id": "masraf",
      "label": "Total Fees (USD)",
      "type": "number",
      "unit": "USD",
      "default": 1500,
      "min": 0,
      "businessContext": "Origination, appraisal and insurance fees."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "monthlyInstallment": "credit * ((interest/12/100) * Math.pow(1 + interest/12/100, vade)) / (Math.pow(1 + interest/12/100, vade) - 1)",
    "result": "((credit - masraf) > 0) ? ((((credit * ((interest/12/100) * Math.pow(1 + interest/12/100, vade)) / (Math.pow(1 + interest/12/100, vade) - 1)) * vade) - credit) / credit) * 100 / (vade/12) : 0",
    "netCredit": "credit - masraf"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "APR (Annual Cost Ratio)",
      "monthlyInstallment": "Monthly Installment"
    },
    "breakdownUnits": {
      "aylikTaksit": "%",
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate the true annual percentage rate including all fees.",
      "long": "Calculate the true annual percentage rate including all fees."
    }
  },
  "sectorSlug": "daily-renovation"
}

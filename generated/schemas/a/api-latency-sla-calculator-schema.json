{
  "toolName": "api-latency-sla-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "technology-ai-cloud-cyber",
  "sector": "IT, Biomedical and Mining",
  "sectorId": "technology-ai-cloud-cyber",
  "inputs": [
    {
      "id": "toplamIstek",
      "label": "Total Requests",
      "type": "number",
      "unit": "requests",
      "default": 10000,
      "min": 0,
      "businessContext": "Total API calls."
    },
    {
      "id": "hataliIstek",
      "label": "Failed Requests",
      "type": "number",
      "unit": "requests",
      "default": 50,
      "min": 0,
      "businessContext": "Number of failed requests."
    },
    {
      "id": "toplamGecikme",
      "label": "Total Latency (ms)",
      "type": "number",
      "unit": "ms",
      "default": 250000,
      "min": 0,
      "businessContext": "Sum of all request durations."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "toplamGecikme / Math.max(1, toplamIstek)",
    "sla": "((toplamIstek - hataliIstek) / Math.max(1, toplamIstek)) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "ms",
    "breakdown": {
      "result": "Ortalama Gecikme",
      "sla": "SLA (%)"
    },
    "breakdownUnits": {
      "sla": "ms",
      "result": "ms"
    },
    "hiddenLossDrivers": [
      "Low SLA indicates service reliability issue.",
      "High latency degrades user experience."
    ],
    "suggestedActions": [
      "Monitor system performance regularly.",
      "Implement redundancy for critical infrastructure."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate API average latency and SLA success rate.",
      "long": "Calculate API average latency and SLA success rate."
    }
  },
  "sectorSlug": "daily-renovation"
}

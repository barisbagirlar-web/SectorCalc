{
  "toolName": "asme-shaft-diameter-bending-torsion-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "mechanical-hvac-energy-loss",
  "sector": "Mechanical Engineering",
  "sectorId": "mechanical-hvac-energy-loss",
  "inputs": [
    {
      "id": "moment",
      "label": "Bending Moment (N.m)",
      "type": "number",
      "unit": "N.m",
      "default": 500,
      "min": 0,
      "businessContext": "Bending moment on shaft."
    },
    {
      "id": "torque",
      "label": "Torque (N.m)",
      "type": "number",
      "unit": "N.m",
      "default": 1000,
      "min": 0,
      "businessContext": "Torque on shaft."
    },
    {
      "id": "akmaGerilmesi",
      "label": "Yield Stress (Pa)",
      "type": "number",
      "unit": "Pa",
      "default": 300000000,
      "min": 0,
      "businessContext": "Shaft material yield strength."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "Math.pow((16 / (Math.PI * akmaGerilmesi)) * Math.sqrt(Math.max(0, moment*moment + 0.75*torque*torque)), 1/3)"
  },
  "outputs": {
    "primary": "result",
    "unit": "m",
    "breakdown": {
      "result": "Min. Mil Diameter"
    },
    "breakdownUnits": {
      "result": "m"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify calculations with FEA or physical testing.",
      "Use appropriate safety factors for design."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate minimum shaft diameter under bending and torsion (ASME).",
      "long": "Calculate minimum shaft diameter under bending and torsion (ASME)."
    }
  },
  "sectorSlug": "daily-renovation"
}

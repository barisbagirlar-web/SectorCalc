{
  "toolName": "annuity-income-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finance",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "principalAmount",
      "label": "Principal (USD)",
      "type": "number",
      "unit": "USD",
      "default": 500000,
      "min": 0,
      "businessContext": "Total principal invested."
    },
    {
      "id": "interest",
      "label": "Annual Interest (%)",
      "type": "number",
      "unit": "%",
      "default": 8,
      "min": 0,
      "businessContext": "Annual interest rate."
    },
    {
      "id": "period",
      "label": "Period (Months)",
      "type": "number",
      "unit": "months",
      "default": 120,
      "min": 1,
      "businessContext": "Total income withdrawal months."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "monthlyRatio": "interest / 12 / 100",
    "result": "principalAmount * ((interest/12/100) / Math.max(0.0001, (1 - Math.pow(1 + interest/12/100, -period))))"
  },
  "outputs": {
    "primary": "result",
    "unit": "USD",
    "breakdown": {
      "result": "Monthly Annuity Income"
    },
    "breakdownUnits": {
      "result": "USD"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Calculate fixed periodic income from a principal amount at a given interest rate.",
      "long": "Calculate fixed periodic income from a principal amount at a given interest rate."
    }
  },
  "sectorSlug": "daily-renovation"
}

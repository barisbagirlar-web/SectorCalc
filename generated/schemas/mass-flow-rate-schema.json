  "formulas": {
    "crossSectionArea": "Math.PI * (diameter / 2) ** 2",
    "massFlowRate": "density * velocity * crossSectionArea",
    "volumetricFlowRate": "velocity * crossSectionArea",
    "correctedDensity": "density * (pressure / 1.01325) * (273.15 / (273.15 + temperature)) * compressibility"
  },
  "outputs": {
    "primary": "massFlowRate",
    "breakdown": [
      "crossSectionArea",
      "volumetricFlowRate",
      "correctedDensity"
    ],

      "id": "compressibility",
      "label": "Compressibility Factor (Z)",
      "type": "number",
      "unit": "dimensionless",
      "default": 1,
      "businessContext": "For gases, typically 1 for ideal gas",
      "label_i18n": {
        "en": "Compressibility Factor (Z)",
        "tr": "Sıkıştırılabilirlik Faktörü (Z)",
        "de": "Compressibility Factor (Z)",
        "fr": "Compressibility Factor (Z)",

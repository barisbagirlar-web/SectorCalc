{
  "toolName": "file-size-calculator",
  "inputs": [
    {
      "id": "numberOfFiles",
      "label": "Number of Files",
      "type": "number",
      "unit": "files",
      "default": 100,
      "businessContext": "Total count of files to store or transfer",
      "label_i18n": {
        "en": "Number of Files",
        "tr": "Number of Files",
        "de": "Number of Files",
        "fr": "Number of Files",
        "es": "Number of Files",
        "ar": "Number of Files"
      }
    },
    {
      "id": "sizePerFileMB",
      "label": "Size per File",
      "type": "number",
      "unit": "MB",
      "default": 10,
      "businessContext": "Average size of each file in megabytes",
      "label_i18n": {
        "en": "Size per File",
        "tr": "Size per File",
        "de": "Size per File",
        "fr": "Size per File",
        "es": "Size per File",
        "ar": "Size per File"
      }
    },
    {
      "id": "redundancyFactor",
      "label": "Redundancy Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1.2,
      "businessContext": "Storage overhead factor for redundancy, e.g., RAID 5 = 1.2",
      "label_i18n": {
        "en": "Redundancy Factor",
        "tr": "Redundancy Factor",
        "de": "Redundancy Factor",
        "fr": "Redundancy Factor",
        "es": "Redundancy Factor",
        "ar": "Redundancy Factor"
      }
    },
    {
      "id": "compressionRatio",
      "label": "Compression Ratio",
      "type": "number",
      "unit": "ratio",
      "default": 0.8,
      "businessContext": "Expected compression ratio between 0 and 1 (1 = no compression)",
      "label_i18n": {
        "en": "Compression Ratio",
        "tr": "Compression Ratio",
        "de": "Compression Ratio",
        "fr": "Compression Ratio",
        "es": "Compression Ratio",
        "ar": "Compression Ratio"
      }
    },
    {
      "id": "overheadPerFileKB",
      "label": "Filesystem Overhead",
      "type": "number",
      "unit": "KB",
      "default": 4,
      "businessContext": "Filesystem metadata overhead per file in kilobytes",
      "label_i18n": {
        "en": "Filesystem Overhead",
        "tr": "Filesystem Overhead",
        "de": "Filesystem Overhead",
        "fr": "Filesystem Overhead",
        "es": "Filesystem Overhead",
        "ar": "Filesystem Overhead"
      }
    },
    {
      "id": "transferSpeedMbps",
      "label": "Network Transfer Speed",
      "type": "number",
      "unit": "Mbps",
      "default": 100,
      "businessContext": "Network speed in megabits per second for download/upload time estimation",
      "label_i18n": {
        "en": "Network Transfer Speed",
        "tr": "Network Transfer Speed",
        "de": "Network Transfer Speed",
        "fr": "Network Transfer Speed",
        "es": "Network Transfer Speed",
        "ar": "Network Transfer Speed"
      }
    }
  ],
  "formulas": {
    "totalUncompressedMB": "numberOfFiles * sizePerFileMB",
    "overheadTotalMB": "(overheadPerFileKB / 1024) * numberOfFiles",
    "totalWithOverheadMB": "totalUncompressedMB + overheadTotalMB",
    "totalCompressedMB": "totalWithOverheadMB * compressionRatio",
    "storageRequiredGB": "totalCompressedMB * redundancyFactor / 1024",
    "downloadTimeSeconds": "(storageRequiredGB * (1024**3) * 8) / (transferSpeedMbps * (10**6))",
    "downloadTimeMinutes": "downloadTimeSeconds / 60"
  },
  "outputs": {
    "primary": "storageRequiredGB",
    "breakdown": [
      "totalUncompressedMB",
      "totalCompressedMB",
      "downloadTimeMinutes"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "downloadTimeMinutes"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",

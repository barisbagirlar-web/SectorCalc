{
  "toolName": "arc-length-calculator",
  "inputs": [
    {
      "id": "radius",
      "label": "Radius",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Radius of the circle or arc in meters"
    },
    {
      "id": "startAngle",
      "label": "Start Angle",
      "type": "number",
      "unit": "deg",
      "default": 0,
      "businessContext": "Starting angle of the arc (degrees if unit=0, radians if unit=1)"
    },
    {
      "id": "endAngle",
      "label": "End Angle",
      "type": "number",
      "unit": "deg",
      "default": 90,
      "businessContext": "Ending angle of the arc (degrees if unit=0, radians if unit=1)"
    },
    {
      "id": "angleUnit",
      "label": "Angle Unit (0=deg, 1=rad)",
      "type": "number",
      "unit": "-",
      "default": 0,
      "businessContext": "Unit for angles: 0 for degrees, 1 for radians"
    }
  ],
  "formulas": {
    "angleDiffRad": "Math.abs(inputs.endAngle - inputs.startAngle) * (inputs.angleUnit === 0 ? Math.PI / 180 : 1)",
    "arcLength": "inputs.radius * angleDiffRad",
    "chordLength": "2 * inputs.radius * Math.sin(angleDiffRad / 2)",
    "sectorArea": "0.5 * inputs.radius * inputs.radius * angleDiffRad"
  },
  "outputs": {
    "primary": "arcLength",
    "breakdown": [
      "chordLength",
      "sectorArea"
    ]
  },
  "category": "Dönüşüm & Ölçüm",
  "sector": "Diğer",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "conversion"
}

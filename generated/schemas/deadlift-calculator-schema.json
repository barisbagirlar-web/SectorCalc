{
  "toolName": "deadlift-calculator",
  "inputs": [
    {
      "id": "weight_lifted",
      "label": "Lifted Weight",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Weight used for the set",
      "label_i18n": {
        "en": "Lifted Weight",
        "tr": "Kaldırılan Ağırlık",
        "de": "Gehobenes Gewicht",
        "fr": "Poids soulevé",

        "fr": "Nombre de répétitions effectuées jusqu'à l'échec ou presque",
        "es": "Número de repeticiones realizadas hasta el fallo o cerca del fallo",
        "ar": "عدد التكرارات المنفذة حتى الفشل أو قريباً منه"
      }
    },
    {
      "id": "body_weight",
      "label": "Body Weight",
      "type": "number",
      "unit": "kg",
      "default": 80,
      "businessContext": "Lifter's body weight",
      "label_i18n": {
        "en": "Body Weight",
        "tr": "Vücut Ağırlığı",
        "de": "Körpergewicht",
        "fr": "Poids corporel",
        "es": "Peso corporal",
        "ar": "وزن الجسم"
      },
      "businessContext_i18n": {
        "en": "Lifter's body weight",
        "tr": "Kaldırıcının vücut ağırlığı",
        "de": "Körpergewicht des Hebers",
        "fr": "Poids corporel du sportif",
        "es": "Peso corporal del levantador",
        "ar": "وزن جسم الرافع"
      }
    },
    {
      "id": "fatigue_factor",
      "label": "Fatigue Factor",
      "type": "number",
      "unit": "%",
      "default": 90,
      "businessContext": "Freshness percentage (100 = no fatigue)",
      "label_i18n": {
        "en": "Fatigue Factor",
        "tr": "Yorgunluk Faktörü",
        "de": "Ermüdungsfaktor",
        "fr": "Facteur de fatigue",
        "es": "Factor de fatiga",
        "ar": "عامل التعب"
      },
      "businessContext_i18n": {
        "en": "Freshness percentage (100 = no fatigue)",
        "tr": "Tazelik yüzdesi (100 = yorgunluk yok)",
        "de": "Frischeprozentsatz (100 = keine Ermüdung)",
        "fr": "Pourcentage de fraîcheur (100 = pas de fatigue)",
        "es": "Porcentaje de frescura (100 = sin fatiga)",
        "ar": "نسبة النشاط (100 = لا تعب)"
      }
    }
  ],
  "formulas": {
    "estimated_1rm": "weight_lifted * (1 + repetitions / 30) * (fatigue_factor / 100)",
    "relative_strength": "(weight_lifted * (1 + repetitions / 30) * (fatigue_factor / 100)) / body_weight"
  },
  "outputs": {
    "primary": "estimated_1rm",
    "breakdown": [
      "relative_strength"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "relative_strength",
    "unit": "kg"
  },

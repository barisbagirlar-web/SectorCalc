        "es": "Peso utilizado para el conjunto",
        "ar": "الوزن المستخدم للمجموعة"
      }
    },
    {
      "id": "repetitions",
      "label": "Repetitions",
      "type": "number",
      "unit": "rep",
      "default": 5,
      "businessContext": "Number of reps performed to failure or near failure",
      "label_i18n": {
        "en": "Repetitions",
        "tr": "Tekrar Sayısı",
        "de": "Wiederholungen",

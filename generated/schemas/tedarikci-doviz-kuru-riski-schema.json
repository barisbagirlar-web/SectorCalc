    "VaR": "Exposure * Volatility * Z_Score * SQRT(TimeHorizon)",
    "HedgingCost": "Exposure * (ForwardRate - SpotRate)",
    "NetRiskCost": "ExpectedLoss + HedgingCost",
    "CurrencyClauseSavings": "IF(ContractHasAdjustment, Exposure * AdjustmentFactor, 0)"

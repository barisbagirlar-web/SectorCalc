{
  "toolName": "total-lift-calculator",
  "inputs": [
    {
      "id": "loadMass",
      "label": "Yük Kütlesi",
      "type": "number",
      "unit": "kg",
      "default": 1000,
      "businessContext": "Kaldırılacak ana yükün kütlesi (rigging hariç)."
    },
    {
      "id": "gravity",
      "label": "Yerçekimi İvmesi",
      "type": "number",
      "unit": "m/s²",
      "default": 9.81,
      "businessContext": "Yerel yerçekimi ivmesi değeri."
    },
    {
      "id": "safetyFactor",
      "label": "Güvenlik Katsayısı",
      "type": "number",
      "unit": "boyutsuz",
      "default": 1.5,
      "businessContext": "Standartlara uygun güvenlik faktörü (EN 13001 vb.)."
    },
    {
      "id": "additionalLoad",
      "label": "Ek Yük (Rigging)",
      "type": "number",
      "unit": "kg",
      "default": 100,
      "businessContext": "Sapan, kanca, travers gibi ekipmanların toplam kütlesi."
    },
    {
      "id": "liftAcceleration",
      "label": "Kaldırma İvmesi",
      "type": "number",
      "unit": "m/s²",
      "default": 0.5,
      "businessContext": "Kaldırma sırasındaki ivme (dinamik yük etkisi)."
    },
    {
      "id": "frictionCoefficient",
      "label": "Sürtünme Katsayısı",
      "type": "number",
      "unit": "boyutsuz",
      "default": 0.05,
      "businessContext": "Kaldırma mekanizmasındaki sürtünme kayıp katsayısı."
    }
  ],
  "formulas": {
    "netWeight": "(loadMass + additionalLoad) * gravity",
    "dynamicForce": "(loadMass + additionalLoad) * (gravity + liftAcceleration)",
    "totalLiftForce": "dynamicForce * (1 + frictionCoefficient) * safetyFactor"
  },
  "outputs": {
    "primary": "totalLiftForce",
    "breakdown": [
      "netWeight",
      "dynamicForce",
      "totalLiftForce"
    ]
  },
  "category": "İSG & Risk Yönetimi",
  "sector": "İSG & Risk",
  "premiumRequired": false,
  "categorySlug": "hse-ergonomics",
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "diger"
}

        "de": "Betriebskosten (Miete, Personal, Marketing usw.)",
        "fr": "Dépenses d'exploitation (loyer, personnel, marketing, etc.)",
        "es": "Gastos operativos (alquiler, personal, marketing, etc.)",
        "ar": "مصروفات التشغيل (الإيجار، الرواتب، التسويق، إلخ)"
      }
    },
    {
      "id": "otherExpenses",
      "label": "Other Expenses",
      "type": "number",
      "unit": "EUR",
      "default": 5000,
      "businessContext": "Other expenses (interest, depreciation, etc.)",
      "label_i18n": {
        "en": "Other Expenses",
        "tr": "Diğer Giderler",
        "de": "Sonstige Ausgaben",
        "fr": "Autres dépenses",
        "es": "Otros gastos",
        "ar": "مصاريف أخرى"
      },
      "businessContext_i18n": {
        "en": "Other Expenses (interest, depreciation, etc.)",
        "tr": "Diğer giderler (faiz, amortisman vb.)",
        "de": "Sonstige Kosten (Zinsen, Abschreibungen usw.)",
        "fr": "Autres dépenses (intérêts, amortissements, etc.)",
        "es": "Otros gastos (intereses, depreciación, etc.)",
        "ar": "مصروفات أخرى (فوائد، إهلاك، إلخ)"
      }
    },
    {
      "id": "taxExpense",
      "label": "Tax Expense",
      "type": "number",
      "unit": "EUR",
      "default": 5000,
      "businessContext": "Tax expense",
      "label_i18n": {
        "en": "Tax Expense",
        "tr": "Vergi Gideri",
        "de": "Steueraufwand",
        "fr": "Charge fiscale",
        "es": "Gasto fiscal",
        "ar": "مصروف الضريبة"
      },
      "businessContext_i18n": {
        "en": "Tax expense",
        "tr": "Vergi gideri",
        "de": "Steueraufwand",
        "fr": "Charge fiscale",
        "es": "Gasto fiscal",
        "ar": "مصروفات الضرائب"
      }
    }
  ],
  "formulas": {
    "grossProfit": "totalRevenue - costOfGoodsSold",
    "grossMargin": "(totalRevenue - costOfGoodsSold) / totalRevenue * 100",
    "operatingProfit": "totalRevenue - costOfGoodsSold - operatingExpenses",
    "operatingMargin": "(totalRevenue - costOfGoodsSold - operatingExpenses) / totalRevenue * 100",
    "profitBeforeTax": "totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses",
    "preTaxMargin": "(totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses) / totalRevenue * 100",
    "netProfit": "totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses - taxExpense",
    "netMargin": "(totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses - taxExpense) / totalRevenue * 100"
  },
  "outputs": {
    "primary": "netMargin",
    "breakdown": [
      "grossMargin",
      "operatingMargin",
      "preTaxMargin",
      "netMargin"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netMargin",
    "unit": "%",
    "breakdownUnits": {
      "grossMargin": "%",
      "operatingMargin": "%",
      "preTaxMargin": "%",
      "netMargin": "%"
    }
  },
  "category": "Maliyet & Bütçeleme",

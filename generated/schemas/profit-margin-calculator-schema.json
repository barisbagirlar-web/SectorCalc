  "formulas": {
    "grossProfit": "totalRevenue - costOfGoodsSold",
    "grossMargin": "(totalRevenue - costOfGoodsSold) / totalRevenue * 100",
    "operatingProfit": "totalRevenue - costOfGoodsSold - operatingExpenses",
    "operatingMargin": "(totalRevenue - costOfGoodsSold - operatingExpenses) / totalRevenue * 100",
    "profitBeforeTax": "totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses",
    "preTaxMargin": "(totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses) / totalRevenue * 100",
    "netProfit": "totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses - taxExpense",
    "netMargin": "(totalRevenue - costOfGoodsSold - operatingExpenses - otherExpenses - taxExpense) / totalRevenue * 100"
  },
  "outputs": {
    "primary": "netMargin",
    "breakdown": [
      "grossMargin",

        "ar": "Task Complexity"
      }
    },
    {
      "id": "certifications",
      "label": "Certifications",
      "type": "number",
      "unit": "count",
      "default": 0,
      "businessContext": "Number of relevant certifications held",
      "label_i18n": {
        "en": "Certifications",
        "tr": "Certifications",
        "de": "Certifications",
        "fr": "Certifications",

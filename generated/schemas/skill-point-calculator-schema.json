      }
    },
    {
      "id": "errorRate",
      "label": "Error Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Average error rate in task execution (0-100%)",
      "label_i18n": {
        "en": "Error Rate",
        "tr": "Hata Oranı",
        "de": "Error Rate",
        "fr": "Error Rate",
        "es": "Error Rate",
        "ar": "Error Rate"
      },
      "businessContext_i18n": {
        "en": "Average error rate in task execution (0-100%)",
        "tr": "Görev yürütmede ortalama hata oranı (0-100%)"
      }
    }
  ],
  "formulas": {
    "baseSkill": "currentSkillLevel",
    "trainingImpact": "trainingHours * 0.1",
    "experienceImpact": "experienceYears * 5",
    "certificationImpact": "certifications * 3",
    "errorPenalty": "errorRate * 2",
    "complexityFactor": "taskComplexity / 10",
    "skillPoints": "(currentSkillLevel + (trainingHours * 0.1) + (experienceYears * 5) + (certifications * 3) - (errorRate * 2)) * (taskComplexity / 10)"
  },
  "outputs": {
    "primary": "skillPoints",
    "breakdown": [
      "baseSkill",
      "trainingImpact",
      "experienceImpact",
      "certificationImpact",
      "errorPenalty",
      "complexityFactor"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "skillPoints",
    "unit": "points"
  },

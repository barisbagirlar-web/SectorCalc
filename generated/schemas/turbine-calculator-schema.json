{
  "toolName": "turbine-calculator",
  "inputs": [
    {
      "id": "airDensity",
      "label": "Hava Yoğunluğu",
      "type": "number",
      "unit": "kg/m³",
      "default": 1.225,
      "businessContext": "Deniz seviyesinde 15°C'de standart hava yoğunluğu. Rakım ve sıcaklığa göre değişir.",
      "label_i18n": {
        "en": "Hava Yoğunluğu",
        "tr": "Hava Yoğunluğu",
        "de": "Hava Yoğunluğu",
        "fr": "Hava Yoğunluğu",
        "es": "Hava Yoğunluğu",
        "ar": "Hava Yoğunluğu"
      }
    },
    {
      "id": "rotorDiameter",
      "label": "Rotor Çapı",
      "type": "number",
      "unit": "m",
      "default": 80,
      "businessContext": "Türbin kanatlarının süpürdüğü dairenin çapı.",
      "label_i18n": {
        "en": "Rotor Çapı",
        "tr": "Rotor Çapı",
        "de": "Rotor Çapı",
        "fr": "Rotor Çapı",
        "es": "Rotor Çapı",
        "ar": "Rotor Çapı"
      }
    },
    {
      "id": "windSpeed",
      "label": "Rüzgar Hızı",
      "type": "number",
      "unit": "m/s",
      "default": 12,
      "businessContext": "Kanat yüksekliğindeki ortalama rüzgar hızı.",
      "label_i18n": {
        "en": "Rüzgar Hızı",
        "tr": "Rüzgar Hızı",
        "de": "Rüzgar Hızı",
        "fr": "Rüzgar Hızı",
        "es": "Rüzgar Hızı",
        "ar": "Rüzgar Hızı"
      }
    },
    {
      "id": "efficiency",
      "label": "Verimlilik",
      "type": "number",
      "unit": "%",
      "default": 40,
      "businessContext": "Türbinin genel aerodinamik ve mekanik verimliliği. Tipik olarak %35-45 arası.",
      "label_i18n": {
        "en": "Verimlilik",
        "tr": "Verimlilik",
        "de": "Verimlilik",
        "fr": "Verimlilik",
        "es": "Verimlilik",
        "ar": "Verimlilik"
      }
    }
  ],
  "formulas": {
    "sweptArea": "Math.PI * (rotorDiameter / 2) ** 2",
    "rawPower": "0.5 * airDensity * sweptArea * Math.pow(windSpeed, 3) / 1000",
    "power": "rawPower * efficiency / 100",
    "__sweptArea__m_": "${sweptArea} m²",
    "__rawPower__kW": "${rawPower} kW"
  },
  "outputs": {
    "primary": "sweptArea",
    "breakdown": [
      "Süpürme Alanı: ${sweptArea} m²",
      "Ham Güç (Verimsiz): ${rawPower} kW"
    ]
  },
  "category": "Diğer",
  "sector": "Havacılık & Savunma",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "metal-plastics-forming",
  "sectorId": "havacilik",
  "profession": "Tasarım Mühendisi",
  "categoryId": "diger"
}

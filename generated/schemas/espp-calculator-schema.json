{
  "toolName": "espp-calculator",
  "inputs": [
    {
      "id": "fmv",
      "label": "Fair Market Value per Share",
      "type": "number",
      "unit": "USD",
      "default": 100,
      "businessContext": "Current market price per share at purchase date",
      "label_i18n": {
        "en": "Fair Market Value per Share",
        "tr": "Fair Market Value per Share",
        "de": "Fair Market Value per Share",
        "fr": "Fair Market Value per Share",
        "es": "Fair Market Value per Share",
        "ar": "Fair Market Value per Share"
      }
    },
    {
      "id": "discountRate",
      "label": "ESPP Discount",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Discount percentage offered by the plan (e.g., 15 means 15% off FMV)",
      "label_i18n": {
        "en": "ESPP Discount",
        "tr": "ESPP Discount",
        "de": "ESPP Discount",
        "fr": "ESPP Discount",
        "es": "ESPP Discount",
        "ar": "ESPP Discount"
      }
    },
    {
      "id": "numberOfShares",
      "label": "Number of Shares Purchased",
      "type": "number",
      "unit": "shares",
      "default": 100,
      "businessContext": "Total number of shares bought through the ESPP",
      "label_i18n": {
        "en": "Number of Shares Purchased",
        "tr": "Number of Shares Purchased",
        "de": "Number of Shares Purchased",
        "fr": "Number of Shares Purchased",
        "es": "Number of Shares Purchased",
        "ar": "Number of Shares Purchased"
      }
    },
    {
      "id": "holdingPeriodMonths",
      "label": "Holding Period in Months",
      "type": "number",
      "unit": "months",
      "default": 0,
      "businessContext": "Number of months held before selling; 0 for immediate sale",
      "label_i18n": {
        "en": "Holding Period in Months",
        "tr": "Holding Period in Months",
        "de": "Holding Period in Months",
        "fr": "Holding Period in Months",
        "es": "Holding Period in Months",
        "ar": "Holding Period in Months"
      }
    },
    {
      "id": "ordinaryIncomeTaxRate",
      "label": "Ordinary Income Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 22,
      "businessContext": "Applicable marginal tax rate for ordinary income",
      "label_i18n": {
        "en": "Ordinary Income Tax Rate",
        "tr": "Ordinary Income Tax Rate",
        "de": "Ordinary Income Tax Rate",
        "fr": "Ordinary Income Tax Rate",
        "es": "Ordinary Income Tax Rate",
        "ar": "Ordinary Income Tax Rate"
      }
    },
    {
      "id": "capitalGainsTaxRate",
      "label": "Long-Term Capital Gains Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 15,
      "businessContext": "Tax rate for long-term capital gains (if holding period > 12 months)",
      "label_i18n": {
        "en": "Long-Term Capital Gains Tax Rate",
        "tr": "Long-Term Capital Gains Tax Rate",
        "de": "Long-Term Capital Gains Tax Rate",
        "fr": "Long-Term Capital Gains Tax Rate",
        "es": "Long-Term Capital Gains Tax Rate",
        "ar": "Long-Term Capital Gains Tax Rate"
      }
    }
  ],
  "formulas": {
    "purchasePricePerShare": "fmv * (1 - discountRate / 100)",
    "totalCost": "purchasePricePerShare * numberOfShares",
    "immediateMarketValue": "fmv * numberOfShares",
    "immediateGain": "immediateMarketValue - totalCost",
    "taxIfSoldImmediately": "immediateGain * (holdingPeriodMonths === 0 ? ordinaryIncomeTaxRate : capitalGainsTaxRate) / 100",
    "afterTaxGain": "immediateGain - taxIfSoldImmediately",
    "effectiveDiscount": "(immediateGain / totalCost) * 100"
  },
  "outputs": {
    "primary": "afterTaxGain",
    "breakdown": [
      "totalCost",
      "immediateMarketValue",
      "immediateGain",
      "taxIfSoldImmediately",
      "effectiveDiscount"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "effectiveDiscount"
  },
  "category": "Vergi & Finansal Raporlama",
  "sector": "Finans & İK",
  "premiumRequired": false,
  "catalogCategory": "finance-business",
  "sectorSlug": "ecommerce",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

        "ar": "Conduit Inner Diameter"
      }
    },
    {
      "id": "cableOuterDiameter",
      "label": "Cable Outer Diameter",
      "type": "number",
      "unit": "in",
      "default": 0.25,
      "businessContext": "Outer diameter of a single conductor cable in inches.",
      "label_i18n": {
        "en": "Cable Outer Diameter",
        "tr": "Cable Outer Diameter",
        "de": "Cable Outer Diameter",
        "fr": "Cable Outer Diameter",
        "es": "Cable Outer Diameter",
        "ar": "Cable Outer Diameter"
      }
    },
    {
      "id": "numberOfConductors",
      "label": "Number of Conductors",
      "type": "number",
      "unit": "unit",
      "default": 3,
      "businessContext": "Total number of conductors to be pulled, identical size.",
      "label_i18n": {
        "en": "Number of Conductors",
        "tr": "Number of Conductors",
        "de": "Number of Conductors",
        "fr": "Number of Conductors",
        "es": "Number of Conductors",
        "ar": "Number of Conductors"
      }
    },
    {
      "id": "conduitFillLimitPercent",
      "label": "Custom Fill Limit (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Optionally override NEC fill limit; set to 0 for automatic NEC rule.",
      "label_i18n": {
        "en": "Custom Fill Limit (%)",
        "tr": "Custom Fill Limit (%)",
        "de": "Custom Fill Limit (%)",
        "fr": "Custom Fill Limit (%)",
        "es": "Custom Fill Limit (%)",
        "ar": "Custom Fill Limit (%)"
      }
    },
    {
      "id": "safetyMarginPercent",
      "label": "Safety Margin (%)",
      "type": "number",
      "unit": "%",
      "default": 0,
      "businessContext": "Additional derating or future growth margin on fill percent.",
      "label_i18n": {
        "en": "Safety Margin (%)",
        "tr": "Safety Margin (%)",
        "de": "Safety Margin (%)",
        "fr": "Safety Margin (%)",
        "es": "Safety Margin (%)",
        "ar": "Safety Margin (%)"
      }
    }
  ],
  "formulas": {
    "allowedFillPercent": "conduitFillLimitPercent > 0 ? conduitFillLimitPercent - safetyMarginPercent : (numberOfConductors === 1 ? 53 : numberOfConductors === 2 ? 31 : 40) - safetyMarginPercent",
    "allowedFillPercent_aux": "conduitFillLimitPercent > 0 ? conduitFillLimitPercent - safetyMarginPercent : (numberOfConductors === 1 ? 53 : numberOfConductors === 2 ? 31 : 40) - safetyMarginPercent"
  },
  "outputs": {
    "primary": "allowedFillPercent_aux",
    "breakdown": [
      "allowedFillPercent",
      "maxAllowedConductors",
      "remainingArea",

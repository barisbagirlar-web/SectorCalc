      "unit": "unit",
      "default": 1,
      "businessContext": "Adjusts for moisture content (normal: 1.0, humid: >1).",
      "label_i18n": {
        "en": "Humidity Factor",
        "tr": "Nem Faktörü",
        "de": "Humidity Factor",
        "fr": "Humidity Factor",

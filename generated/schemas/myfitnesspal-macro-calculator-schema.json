{
  "toolName": "myfitnesspal-macro-calculator",
  "inputs": [
    {
      "id": "weight",
      "label": "Weight (kg)",
      "type": "number",
      "unit": "kg",
      "default": 70,
      "businessContext": "User body weight in kilograms"
    },
    {
      "id": "height",
      "label": "Height (cm)",
      "type": "number",
      "unit": "cm",
      "default": 170,
      "businessContext": "User height in centimeters"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "User age in years"
    },
    {
      "id": "gender",
      "label": "Gender (0: Female, 1: Male)",
      "type": "number",
      "unit": "",
      "default": 0,
      "businessContext": "Biological gender for BMR formula (0 for female, 1 for male)"
    },
    {
      "id": "activityLevel",
      "label": "Activity Level",
      "type": "number",
      "unit": "",
      "default": 1.55,
      "businessContext": "Physical activity multiplier: 1.2=sedentary, 1.375=light, 1.55=moderate, 1.725=very active, 1.9=extra active"
    },
    {
      "id": "goalFactor",
      "label": "Goal Factor",
      "type": "number",
      "unit": "",
      "default": 0.8,
      "businessContext": "Calorie adjustment factor: 0.8 for weight loss, 1.0 for maintenance, 1.2 for muscle gain"
    }
  ],
  "formulas": {
    "BMR": "gender === 0 ? (10 * weight + 6.25 * height - 5 * age - 161) : (10 * weight + 6.25 * height - 5 * age + 5)",
    "TDEE": "BMR * activityLevel",
    "dailyCalories": "TDEE * goalFactor",
    "protein": "(dailyCalories * 0.30) / 4",
    "carbs": "(dailyCalories * 0.45) / 4",
    "fat": "(dailyCalories * 0.25) / 9"
  },
  "outputs": {
    "primary": "dailyCalories",
    "breakdown": [
      "protein",
      "carbs",
      "fat"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Perakende & Gıda",
  "premiumRequired": false
}
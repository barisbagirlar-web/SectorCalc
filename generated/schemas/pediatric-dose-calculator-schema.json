      "type": "number",
      "unit": "mg/mL",
      "default": 100,
      "businessContext": "Liquid drug concentration (mg/mL)",
      "label_i18n": {
        "en": "Concentration",
        "tr": "Konsantrasyon",
        "de": "Konzentration",
        "fr": "Concentration",
        "es": "Concentración",
        "ar": "التركيز"
      },
      "businessContext_i18n": {
        "en": "Liquid drug concentration (mg/mL)",

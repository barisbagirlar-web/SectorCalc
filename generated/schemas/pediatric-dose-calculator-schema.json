  ],
  "formulas": {
    "youngDose": "(childAge / (childAge + 12)) * adultDose",
    "maxAllowedDose": "maxDosePerKg * childWeight",
    "volumeYoung": "youngDose / concentration"
  },
  "outputs": {
    "primary": "youngDose",
    "breakdown": [
      "Young's Rule: ${youngDose} mg (${volumeYoung} mL), Safe: ${isYoungSafe}",
      "Maximum Safe Daily Dose: ${maxAllowedDose} mg"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "volumeYoung",
    "unit": "mg"
  },
  "category": "Safety & Risk",
  "sector": "Healthcare & Medicine",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "healthcare",
  "categorySlug": "hse-ergonomics",
  "sectorId": "healthcare",
  "profession": "Biomedical Engineer",
  "categoryId": "safety",
  "validation": {
    "rules": [
      {
        "field": "childAge",
        "condition": "childAge >= 0 && childAge <= 18",
        "message": "Child age must be between 0 and 18 years."
      },
      {
        "field": "childWeight",
        "condition": "childWeight > 0 && childWeight <= 150",
        "message": "Child weight must be between 0 and 150 kg."
      },
      {
        "field": "adultDose",
        "condition": "adultDose > 0",
        "message": "Adult dose must be positive."
      },
      {
        "field": "maxDosePerKg",
        "condition": "maxDosePerKg > 0",
        "message": "Maximum dose per kg must be positive."
      },
      {
        "field": "concentration",
        "condition": "concentration > 0",
        "message": "Concentration must be positive."
      }
    ],
    "thresholds": {}
  },
  "premiumFeatures": []
}

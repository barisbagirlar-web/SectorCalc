        "en": "Customer Lifespan",
        "tr": "Customer Lifespan",
        "de": "Customer Lifespan",
        "fr": "Customer Lifespan",
        "es": "Customer Lifespan",
        "ar": "Customer Lifespan"
      }
    },
    {
      "id": "grossMarginPercent",
      "label": "Gross Margin",
      "type": "number",
      "unit": "%",
      "default": 100,
      "businessContext": "Gross margin percentage applied to revenue to reflect profit contribution.",

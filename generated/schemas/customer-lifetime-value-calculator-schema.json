      }
    },
    {
      "id": "purchaseFrequency",
      "label": "Purchase Frequency",
      "type": "number",
      "unit": "purchases/year",
      "default": 12,
      "businessContext": "Average number of purchases a customer makes per year.",
      "label_i18n": {
        "en": "Purchase Frequency",
        "tr": "Purchase Frequency",
        "de": "Purchase Frequency",
        "fr": "Purchase Frequency",
        "es": "Purchase Frequency",
        "ar": "Purchase Frequency"
      }
    },
    {
      "id": "lifespanYears",
      "label": "Customer Lifespan",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Average duration a customer remains active (in years).",

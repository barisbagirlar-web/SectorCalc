  "formulas": {
    "row1_total": "observed_11 + observed_12",
    "row2_total": "observed_21 + observed_22",
    "col1_total": "observed_11 + observed_21",
    "col2_total": "observed_12 + observed_22",
    "grand_total": "observed_11 + observed_12 + observed_21 + observed_22",
    "expected_11": "(row1_total * col1_total) / grand_total",
    "expected_12": "(row1_total * col2_total) / grand_total",
    "expected_21": "(row2_total * col1_total) / grand_total",
    "expected_22": "(row2_total * col2_total) / grand_total",
    "chi_square": "((observed_11 - expected_11) ** 2 / expected_11) + ((observed_12 - expected_12) ** 2 / expected_12) + ((observed_21 - expected_21) ** 2 / expected_21) + ((observed_22 - expected_22) ** 2 / expected_22)"
  },

{
  "toolName": "chi-square-test-of-independence",
  "inputs": [
    {
      "id": "observed_11",
      "label": "Observed Cell (1,1)",
      "type": "number",
      "unit": "count",
      "default": 10,
      "businessContext": "Observed frequency in row 1, column 1"
    },
    {
      "id": "observed_12",
      "label": "Observed Cell (1,2)",
      "type": "number",
      "unit": "count",
      "default": 20,
      "businessContext": "Observed frequency in row 1, column 2"
    },
    {
      "id": "observed_21",
      "label": "Observed Cell (2,1)",
      "type": "number",
      "unit": "count",
      "default": 30,
      "businessContext": "Observed frequency in row 2, column 1"
    },
    {
      "id": "observed_22",
      "label": "Observed Cell (2,2)",
      "type": "number",
      "unit": "count",
      "default": 40,
      "businessContext": "Observed frequency in row 2, column 2"
    }
  ],
  "formulas": {
    "row1_total": "observed_11 + observed_12",
    "row2_total": "observed_21 + observed_22",
    "col1_total": "observed_11 + observed_21",
    "col2_total": "observed_12 + observed_22",
    "grand_total": "observed_11 + observed_12 + observed_21 + observed_22",
    "expected_11": "(row1_total * col1_total) / grand_total",
    "expected_12": "(row1_total * col2_total) / grand_total",
    "expected_21": "(row2_total * col1_total) / grand_total",
    "expected_22": "(row2_total * col2_total) / grand_total",
    "chi_square": "((observed_11 - expected_11) ** 2 / expected_11) + ((observed_12 - expected_12) ** 2 / expected_12) + ((observed_21 - expected_21) ** 2 / expected_21) + ((observed_22 - expected_22) ** 2 / expected_22)"
  },
  "outputs": {
    "primary": "chi_square",
    "breakdown": [
      "expected_11",
      "expected_12",
      "expected_21",
      "expected_22"
    ]
  },
  "category": "Diğer",
  "sector": "Telekomünikasyon",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "quality-six-sigma",
  "sectorId": "telekom",
  "profession": "Ağ Mühendisi",
  "categoryId": "diger"
}

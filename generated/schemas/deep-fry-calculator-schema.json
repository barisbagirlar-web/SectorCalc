{
  "toolName": "deep-fry-calculator",
  "inputs": [
    {
      "id": "oilVolume",
      "label": "Oil Volume",
      "type": "number",
      "unit": "L",
      "default": 20,
      "businessContext": "Volume of frying oil in the fryer"
    },
    {
      "id": "initialTemp",
      "label": "Initial Oil Temperature",
      "type": "number",
      "unit": "°C",
      "default": 20,
      "businessContext": "Starting temperature of oil before heating"
    },
    {
      "id": "fryingTemp",
      "label": "Frying Temperature",
      "type": "number",
      "unit": "°C",
      "default": 180,
      "businessContext": "Target frying temperature"
    },
    {
      "id": "fryingTime",
      "label": "Frying Time per Batch",
      "type": "number",
      "unit": "min",
      "default": 10,
      "businessContext": "Duration of frying one batch of food"
    },
    {
      "id": "fryerPower",
      "label": "Fryer Power",
      "type": "number",
      "unit": "kW",
      "default": 3.5,
      "businessContext": "Rated power of the deep fryer"
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost of electricity per kilowatt-hour"
    },
    {
      "id": "oilCostPerLiter",
      "label": "Oil Cost per Liter",
      "type": "number",
      "unit": "currency/L",
      "default": 1.5,
      "businessContext": "Purchase price of frying oil per liter"
    },
    {
      "id": "oilLifeBatches",
      "label": "Oil Life (Batches)",
      "type": "number",
      "unit": "batches",
      "default": 40,
      "businessContext": "Number of frying batches before oil replacement"
    }
  ],
  "formulas": {
    "mass": "oilVolume * 0.92",
    "deltaT": "fryingTemp - initialTemp",
    "energyHeating": "mass * 1.67 * deltaT / 3600",
    "energyFrying": "fryerPower * (fryingTime / 60)",
    "totalEnergy": "energyHeating + energyFrying",
    "energyCost": "totalEnergy * electricityCost",
    "oilCostPerBatch": "(oilVolume * oilCostPerLiter) / oilLifeBatches",
    "totalCost": "energyCost + oilCostPerBatch"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalEnergy",
      "energyCost",
      "oilCostPerBatch"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "food-cooking",
  "sectorSlug": "restaurant",
  "categorySlug": "electrical-power-systems",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "energy"
}

      }
    },
    {
      "id": "electricityCost",
      "label": "Electricity Cost",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Cost of electricity per kilowatt-hour",
      "label_i18n": {
        "en": "Electricity Cost",
        "tr": "Electricity Cost",
        "de": "Electricity Cost",
        "fr": "Electricity Cost",
        "es": "Electricity Cost",
        "ar": "Electricity Cost"
      }
    },
    {
      "id": "oilCostPerLiter",
      "label": "Oil Cost per Liter",
      "type": "number",
      "unit": "currency/L",
      "default": 1.5,
      "businessContext": "Purchase price of frying oil per liter",
      "label_i18n": {
        "en": "Oil Cost per Liter",
        "tr": "Oil Cost per Liter",
        "de": "Oil Cost per Liter",
        "fr": "Oil Cost per Liter",
        "es": "Oil Cost per Liter",
        "ar": "Oil Cost per Liter"
      }
    },
    {
      "id": "oilLifeBatches",
      "label": "Oil Life (Batches)",
      "type": "number",
      "unit": "batches",
      "default": 40,
      "businessContext": "Number of frying batches before oil replacement",
      "label_i18n": {
        "en": "Oil Life (Batches)",
        "tr": "Oil Life (Batches)",
        "de": "Oil Life (Batches)",
        "fr": "Oil Life (Batches)",
        "es": "Oil Life (Batches)",
        "ar": "Oil Life (Batches)"
      }
    }
  ],
  "formulas": {
    "mass": "oilVolume * 0.92",
    "deltaT": "fryingTemp - initialTemp",
    "energyHeating": "mass * 1.67 * deltaT / 3600",
    "energyFrying": "fryerPower * (fryingTime / 60)",
    "totalEnergy": "energyHeating + energyFrying",
    "energyCost": "totalEnergy * electricityCost",
    "oilCostPerBatch": "(oilVolume * oilCostPerLiter) / oilLifeBatches",
    "totalCost": "energyCost + oilCostPerBatch"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalEnergy",
      "energyCost",
      "oilCostPerBatch"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost"
  },

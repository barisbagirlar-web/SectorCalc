      }
    },
    {
      "id": "fryerPower",
      "label": "Fryer Power",
      "type": "number",
      "unit": "kW",
      "default": 3.5,
      "businessContext": "Rated power of the deep fryer",
      "label_i18n": {
        "en": "Fryer Power",
        "tr": "Fryer Power",
        "de": "Fryer Power",
        "fr": "Fryer Power",
        "es": "Fryer Power",

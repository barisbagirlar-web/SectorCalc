    {
      "id": "oilLifeBatches",
      "label": "Oil Life (Batches)",
      "type": "number",
      "unit": "batches",
      "default": 40,
      "businessContext": "Number of frying batches before oil replacement",
      "label_i18n": {
        "en": "Oil Life (Batches)",
        "tr": "Yağ Ömrü (Parti)",
        "de": "Öllebensdauer (Chargen)",
        "fr": "Oil Life (Batches)",
        "es": "Oil Life (Batches)",
        "ar": "Oil Life (Batches)"
      },
      "businessContext_i18n": {
        "en": "Number of frying batches before oil replacement",
        "tr": "Yağ değişiminden önceki kızartma partisi sayısı",
        "de": "Anzahl der Frittierchargen vor Ölwechsel"
      }
    }
  ],
  "formulas": {
    "mass": "oilVolume * 0.92",
    "deltaT": "fryingTemp - initialTemp",
    "energyHeating": "mass * 1.67 * deltaT / 3600",
    "energyFrying": "fryerPower * (fryingTime / 60)",
    "totalEnergy": "energyHeating + energyFrying",
    "energyCost": "totalEnergy * electricityCost",
    "oilCostPerBatch": "(oilVolume * oilCostPerLiter) / oilLifeBatches",
    "totalCost": "energyCost + oilCostPerBatch"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "totalEnergy",
      "energyCost",
      "oilCostPerBatch"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalCost",
    "unit": "L"
  },

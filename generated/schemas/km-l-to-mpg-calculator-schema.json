      "businessContext": "Specify 0 if input is in km/L, 1 if in mpg.",
      "label_i18n": {
        "en": "Source Unit",
        "tr": "Source Unit",
        "de": "Source Unit",
        "fr": "Source Unit",
        "es": "Source Unit",
        "ar": "Source Unit"
      }
    },
    {
      "id": "decimalPlaces",
      "label": "Decimal Places",
      "type": "number",
      "unit": "places",
      "default": 2,
      "businessContext": "Number of decimal places for the output.",
      "label_i18n": {
        "en": "Decimal Places",
        "tr": "Decimal Places",
        "de": "Decimal Places",
        "fr": "Decimal Places",
        "es": "Decimal Places",
        "ar": "Decimal Places"
      }
    },
    {
      "id": "gallonType",
      "label": "Gallon Type",
      "type": "number",
      "unit": "0=US, 1=UK",
      "default": 0,
      "businessContext": "Select gallon type: 0 for US gallon (3.785 L), 1 for Imperial gallon (4.546 L).",
      "label_i18n": {
        "en": "Gallon Type",
        "tr": "Gallon Type",
        "de": "Gallon Type",
        "fr": "Gallon Type",
        "es": "Gallon Type",
        "ar": "Gallon Type"
      }
    }
  ],
  "formulas": {
    "primary": "(sourceUnit == 0 ? (gallonType == 0 ? value * 2.352145833333333 : value * 2.8248094) : (gallonType == 0 ? value / 2.352145833333333 : value / 2.8248094)).toFixed(decimalPlaces) + (sourceUnit == 0 ? (gallonType == 0 ? ' mpg (US)' : ' mpg (UK)') : (gallonType == 0 ? ' km/L (from US mpg)' : ' km/L (from UK mpg)'))",
    "breakdown": "value",
    "breakdown_0_": "breakdown[0]",
    "breakdown_1_": "breakdown[1]"
  },
  "outputs": {
    "primary": "primary",
    "breakdown": [
      "breakdown[0]",
      "breakdown[1]"
    ]
  },

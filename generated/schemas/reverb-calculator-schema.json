  "formulas": {
    "volume": "length * width * height",
    "surfaceArea": "2 * (length*width + length*height + width*height)",
    "totalAbsorption": "surfaceArea * alpha",
    "rt60": "totalAbsorption ? 0.161 * volume / totalAbsorption : 0"
  },

        "de": "Salvage Value",
        "fr": "Salvage Value",
        "es": "Salvage Value",
        "ar": "Salvage Value"
      }
    },
    {
      "id": "life",
      "label": "Useful Life (years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "businessContext": "Useful life of the asset in years",
      "label_i18n": {
        "en": "Useful Life (years)",
        "tr": "Useful Life (years)",
        "de": "Useful Life (years)",
        "fr": "Useful Life (years)",
        "es": "Useful Life (years)",
        "ar": "Useful Life (years)"
      }
    },
    {
      "id": "year",
      "label": "Year Number",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Year for which to calculate depreciation (1-based)",
      "label_i18n": {
        "en": "Year Number",
        "tr": "Year Number",
        "de": "Year Number",
        "fr": "Year Number",
        "es": "Year Number",
        "ar": "Year Number"
      }
    }
  ],
  "formulas": {
    "sum_of_years": "life * (life + 1) / 2",
    "depreciable_base": "cost - salvage",
    "remaining_life": "life - year + 1",
    "depreciation_fraction": "remaining_life / sum_of_years",
    "depreciation_expense": "depreciable_base * depreciation_fraction"
  },
  "outputs": {
    "primary": "depreciation_expense",
    "breakdown": [
      "sum_of_years",
      "depreciable_base",
      "depreciation_fraction"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [

  "formulas": {
    "sum_of_years": "life * (life + 1) / 2",
    "depreciable_base": "cost - salvage",
    "remaining_life": "life - year + 1",
    "depreciation_fraction": "remaining_life / sum_of_years",
    "depreciation_expense": "depreciable_base * depreciation_fraction"
  },
  "outputs": {
    "primary": "depreciation_expense",
    "breakdown": [

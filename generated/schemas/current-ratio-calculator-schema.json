        "en": "Short-Term Debt",
        "tr": "Short-Term Debt",
        "de": "Short-Term Debt",
        "fr": "Short-Term Debt",
        "es": "Short-Term Debt",
        "ar": "Short-Term Debt"
      }
    },
    {
      "id": "otherCurrentLiabilities",
      "label": "Other Current Liabilities",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Other obligations due within one year, such as accrued expenses, taxes payable",
      "label_i18n": {
        "en": "Other Current Liabilities",

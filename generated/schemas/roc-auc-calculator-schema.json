  "formulas": {
    "auc": "0.5 * (fpr1 * tpr1 + (fpr2 - fpr1) * (tpr1 + tpr2) + (fpr3 - fpr2) * (tpr2 + tpr3) + (fpr4 - fpr3) * (tpr3 + tpr4) + (1 - fpr4) * (tpr4 + 1))",
    "gini": "2 * auc - 1"

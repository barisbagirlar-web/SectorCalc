    },
    {
      "id": "correctionFactor",
      "label": "Correction Factor",
      "type": "number",
      "unit": "-",
      "default": 1,
      "businessContext": "Manual correction factor (e.g., for foam, ullage, etc.)",
      "label_i18n": {
        "en": "Correction Factor",
        "tr": "Düzeltme Faktörü",
        "de": "Correction Factor",
        "fr": "Correction Factor",
        "es": "Correction Factor",
        "ar": "Correction Factor"
      },
      "businessContext_i18n": {

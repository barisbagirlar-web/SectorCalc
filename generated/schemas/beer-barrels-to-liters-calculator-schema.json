        "tr": "Manuel düzeltme faktörü (örneğin köpük, boşluk vb. için)"
      }
    }
  ],
  "formulas": {
    "volumeAtReference": "barrels * litersPerBarrel",
    "temperatureCorrectionFactor": "1 + thermalExpansionCoefficient * (temperatureC - referenceTemperatureC)",
    "volumeAfterTemperatureCorrection": "volumeAtReference * temperatureCorrectionFactor",
    "volumeLiters": "volumeAfterTemperatureCorrection * correctionFactor"
  },
  "outputs": {
    "primary": "volumeLiters",
    "breakdown": [
      "volumeAtReference",
      "temperatureCorrectionFactor",
      "volumeAfterTemperatureCorrection"
    ],

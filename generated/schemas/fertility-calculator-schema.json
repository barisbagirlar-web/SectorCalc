{
  "toolName": "fertility-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Yaş",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Yaş, gebe kalma olasılığını etkileyen temel faktörlerden biridir.",
      "label_i18n": {
        "en": "Yaş",
        "tr": "Yaş",
        "de": "Yaş",
        "fr": "Yaş",
        "es": "Yaş",
        "ar": "Yaş"
      }
    },
    {
      "id": "cycleLength",
      "label": "Adet Döngüsü Uzunluğu",
      "type": "number",
      "unit": "days",
      "default": 28,
      "businessContext": "Ortalama adet döngüsü uzunluğu, ovulasyon gününü belirlemede kullanılır.",
      "label_i18n": {
        "en": "Adet Döngüsü Uzunluğu",
        "tr": "Adet Döngüsü Uzunluğu",
        "de": "Adet Döngüsü Uzunluğu",
        "fr": "Adet Döngüsü Uzunluğu",
        "es": "Adet Döngüsü Uzunluğu",
        "ar": "Adet Döngüsü Uzunluğu"
      }
    },
    {
      "id": "lutealPhase",
      "label": "Luteal Faz Süresi",
      "type": "number",
      "unit": "days",
      "default": 14,
      "businessContext": "Ovulasyon sonrası luteal fazın uzunluğu, doğurganlık penceresini hesaplamak için gereklidir.",
      "label_i18n": {
        "en": "Luteal Faz Süresi",
        "tr": "Luteal Faz Süresi",
        "de": "Luteal Faz Süresi",
        "fr": "Luteal Faz Süresi",
        "es": "Luteal Faz Süresi",
        "ar": "Luteal Faz Süresi"
      }
    },
    {
      "id": "monthsTrying",
      "label": "Deneme Süresi",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Aktif olarak gebe kalmaya çalışılan ay sayısı, kümülatif olasılığı hesaplamak için kullanılır.",
      "label_i18n": {
        "en": "Deneme Süresi",
        "tr": "Deneme Süresi",
        "de": "Deneme Süresi",
        "fr": "Deneme Süresi",
        "es": "Deneme Süresi",
        "ar": "Deneme Süresi"
      }
    }
  ],
  "formulas": {
    "ovulationDay": "cycleLength - lutealPhase",
    "fertileStartDay": "ovulationDay - 5",
    "fertileEndDay": "ovulationDay + 1",
    "ageFactor": "age <= 30 ? 1 : Math.max(0.1, 1 - (age - 30) * 0.02)",
    "cycleFactor": "(cycleLength >= 26 && cycleLength <= 32) ? 1 : 0.8",
    "baseProb": "0.2",
    "probabilityPerCycle": "baseProb * ageFactor * cycleFactor",
    "cumulativeProbability": "1 - Math.pow(1 - probabilityPerCycle, monthsTrying)",
    "cumulativeProbability___100": "cumulativeProbability * 100",
    "result": "probabilityPerCycle * 100"
  },
  "outputs": {
    "primary": "result",
    "breakdown": [
      "ovulationDay",
      "fertileStartDay",
      "fertileEndDay",
      "cumulativeProbability * 100"
    ]
  },
  "category": "Üretim & İmalat",
  "sector": "Üretim & İmalat",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "plastik",
  "profession": "Proses Mühendisi",
  "categoryId": "diger"
}

{
  "toolName": "fertility-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Yaş",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Yaş, gebe kalma olasılığını etkileyen temel faktörlerden biridir."
    },
    {
      "id": "cycleLength",
      "label": "Adet Döngüsü Uzunluğu",
      "type": "number",
      "unit": "days",
      "default": 28,
      "businessContext": "Ortalama adet döngüsü uzunluğu, ovulasyon gününü belirlemede kullanılır."
    },
    {
      "id": "lutealPhase",
      "label": "Luteal Faz Süresi",
      "type": "number",
      "unit": "days",
      "default": 14,
      "businessContext": "Ovulasyon sonrası luteal fazın uzunluğu, doğurganlık penceresini hesaplamak için gereklidir."
    },
    {
      "id": "monthsTrying",
      "label": "Deneme Süresi",
      "type": "number",
      "unit": "months",
      "default": 12,
      "businessContext": "Aktif olarak gebe kalmaya çalışılan ay sayısı, kümülatif olasılığı hesaplamak için kullanılır."
    }
  ],
  "formulas": {
    "ovulationDay": "cycleLength - lutealPhase",
    "fertileStartDay": "ovulationDay - 5",
    "fertileEndDay": "ovulationDay + 1",
    "ageFactor": "age <= 30 ? 1 : Math.max(0.1, 1 - (age - 30) * 0.02)",
    "cycleFactor": "(cycleLength >= 26 && cycleLength <= 32) ? 1 : 0.8",
    "baseProb": 0.2,
    "probabilityPerCycle": "baseProb * ageFactor * cycleFactor",
    "cumulativeProbability": "1 - Math.pow(1 - probabilityPerCycle, monthsTrying)"
  },
  "outputs": {
    "primary": "probabilityPerCycle * 100",
    "breakdown": [
      "ovulationDay",
      "fertileStartDay",
      "fertileEndDay",
      "cumulativeProbability * 100"
    ]
  },
  "category": "Ölçüm & Dönüşüm",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "hse-ergonomics"
}

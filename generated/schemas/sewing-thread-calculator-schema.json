{
  "toolName": "sewing-thread-calculator",
  "inputs": [
    {
      "id": "seamLength",
      "label": "Seam Length",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Total length of seams in the garment (meters)",
      "label_i18n": {
        "en": "Seam Length",
        "tr": "Dikiş Yeri Uzunluğu",
        "de": "Seam Length",
        "fr": "Seam Length",
        "es": "Seam Length",
        "ar": "Seam Length"
      },
      "businessContext_i18n": {
        "en": "Total length of seams in the garment (meters)",
        "tr": "Giysideki toplam dikiş uzunluğu (metre)"
      }
    },
    {
      "id": "stitchesPerCm",
      "label": "Stitches per cm",
      "type": "number",
      "unit": "stitches/cm",
      "default": 4,
      "businessContext": "Stitch density (stitches per centimeter)",
      "label_i18n": {
        "en": "Stitches per cm",
        "tr": "cm başına dikiş sayısı",
        "de": "Stitches per cm",
        "fr": "Stitches per cm",
        "es": "Stitches per cm",
        "ar": "Stitches per cm"
      },
      "businessContext_i18n": {
        "en": "Stitch density (stitches per centimeter)",
        "tr": "Dikiş yoğunluğu (santimetre başına dikiş sayısı)"
      }
    },
    {
      "id": "threadConsumptionPerStitch",
      "label": "Thread Consumption per Stitch",
      "type": "number",
      "unit": "cm",
      "default": 0.75,
      "businessContext": "Average thread consumed per stitch (cm)",
      "label_i18n": {
        "en": "Thread Consumption per Stitch",
        "tr": "Dikiş Başına İplik Tüketimi",
        "de": "Thread Consumption per Stitch",
        "fr": "Thread Consumption per Stitch",
        "es": "Thread Consumption per Stitch",
        "ar": "Thread Consumption per Stitch"
      },
      "businessContext_i18n": {
        "en": "Average thread consumed per stitch (cm)",
        "tr": "Dikiş başına ortalama iplik tüketimi (cm)"
      }
    },
    {
      "id": "numberOfGarments",
      "label": "Number of Garments",
      "type": "number",
      "unit": "pieces",
      "default": 1,
      "businessContext": "Total number of garments to be produced",
      "label_i18n": {
        "en": "Number of Garments",
        "tr": "Giysi Sayısı",
        "de": "Number of Garments",
        "fr": "Number of Garments",
        "es": "Number of Garments",
        "ar": "Number of Garments"
      },
      "businessContext_i18n": {
        "en": "Total number of garments to be produced",
        "tr": "Üretilecek toplam giysi sayısı"
      }
    },
    {
      "id": "wastePercentage",
      "label": "Waste Percentage",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Waste factor for thread breakage, bobbin changes, etc.",
      "label_i18n": {
        "en": "Waste Percentage",
        "tr": "Fire Yüzdesi",
        "de": "Waste Percentage",
        "fr": "Waste Percentage",
        "es": "Waste Percentage",
        "ar": "Waste Percentage"
      },
      "businessContext_i18n": {
        "en": "Waste factor for thread breakage, bobbin changes, etc.",
        "tr": "İplik kopması, masura değişimi vb. için fire faktörü"
      }
    }
  ],
  "formulas": {
    "totalThreadPerGarment": "seamLength * stitchesPerCm * threadConsumptionPerStitch",
    "totalWithoutWaste": "totalThreadPerGarment * numberOfGarments",
    "wasteAddition": "totalWithoutWaste * wastePercentage / 100",
    "totalThreadWithWaste": "totalWithoutWaste + wasteAddition"
  },
  "outputs": {
    "primary": "totalThreadWithWaste",
    "breakdown": [
      "totalThreadPerGarment",
      "totalWithoutWaste",
      "wasteAddition"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalThreadWithWaste",
    "unit": "m"
  },
  "category": "Sürdürülebilirlik",

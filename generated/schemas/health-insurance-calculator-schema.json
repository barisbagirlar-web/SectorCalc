{
  "toolName": "health-insurance-calculator",
  "inputs": [
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "unit": "years",
      "default": 30,
      "businessContext": "Age of the primary insured",
      "label_i18n": {
        "en": "Age",
        "tr": "Yaş",
        "de": "Alter",
        "fr": "Age",
        "es": "Age",
        "ar": "Age"
      },
      "businessContext_i18n": {
        "en": "Age of the primary insured",
        "tr": "Ana sigortalının yaşı"
      }
    },
    {
      "id": "sumInsured",
      "label": "Sum Insured",
      "type": "number",
      "unit": "currency",
      "default": 500000,
      "businessContext": "Total coverage amount",
      "label_i18n": {
        "en": "Sum Insured",
        "tr": "Sigorta Tutarı",
        "de": "Sum Insured",
        "fr": "Sum Insured",
        "es": "Sum Insured",
        "ar": "Sum Insured"
      },
      "businessContext_i18n": {
        "en": "Total coverage amount",
        "tr": "Toplam teminat miktarı"
      }
    },
    {
      "id": "familyMembers",
      "label": "Number of Family Members",
      "type": "number",
      "unit": "persons",
      "default": 1,
      "businessContext": "Total insured family members including primary",
      "label_i18n": {
        "en": "Number of Family Members",
        "tr": "Aile Üyesi Sayısı",
        "de": "Number of Family Members",
        "fr": "Number of Family Members",
        "es": "Number of Family Members",
        "ar": "Number of Family Members"
      },
      "businessContext_i18n": {
        "en": "Total insured family members including primary",
        "tr": "Birincil dahil toplam sigortalı aile üyeleri"
      }
    },
    {
      "id": "smokerStatus",
      "label": "Smoker Status",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "0 for non-smoker, 1 for smoker",
      "label_i18n": {
        "en": "Smoker Status",
        "tr": "Sigara İçme Durumu",
        "de": "Smoker Status",
        "fr": "Smoker Status",
        "es": "Smoker Status",
        "ar": "Smoker Status"
      },
      "businessContext_i18n": {
        "en": "0 for non-smoker, 1 for smoker",
        "tr": "0 içmiyor, 1 içiyor"
      }
    },
    {
      "id": "preExisting",
      "label": "Pre-existing Conditions",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "0 for none, 1 for pre-existing conditions",
      "label_i18n": {
        "en": "Pre-existing Conditions",
        "tr": "Önceden Var Olan Hastalıklar",
        "de": "Pre-existing Conditions",
        "fr": "Pre-existing Conditions",
        "es": "Pre-existing Conditions",
        "ar": "Pre-existing Conditions"
      },
      "businessContext_i18n": {
        "en": "0 for none, 1 for pre-existing conditions",
        "tr": "0 yok, 1 var"
      }
    },
    {
      "id": "occupationRisk",
      "label": "Occupation Risk Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Risk factor based on occupation (1.0 = low risk, up to 2.0 high risk)",
      "label_i18n": {
        "en": "Occupation Risk Factor",
        "tr": "Meslek Risk Faktörü",
        "de": "Occupation Risk Factor",
        "fr": "Occupation Risk Factor",
        "es": "Occupation Risk Factor",
        "ar": "Occupation Risk Factor"
      },
      "businessContext_i18n": {
        "en": "Risk factor based on occupation (1.0 = low risk, up to 2.0 high risk)",
        "tr": "Mesleğe göre risk faktörü (1.0 = düşük risk, 2.0'a kadar yüksek risk)"
      }
    }
  ],
  "formulas": {
    "basePremium": "sumInsured * 0.02 * (1 + (age - 30) * 0.01)",
    "familyMultiplier": "1 + (familyMembers - 1) * 0.2",
    "riskMultiplier": "1 + smokerStatus * 0.5 + preExisting * 0.3",
    "totalPremium": "basePremium * familyMultiplier * riskMultiplier * occupationRisk"
  },
  "outputs": {
    "primary": "totalPremium",
    "breakdown": [
      "basePremium",
      "familyMultiplier",
      "riskMultiplier",
      "totalPremium"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPremium",
    "unit": "years"
  },
  "category": "İSG & Risk",
  "sector": "Kimya & Proses",
  "premiumRequired": false,

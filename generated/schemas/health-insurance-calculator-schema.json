    },
    {
      "id": "preExisting",
      "label": "Pre-existing Conditions",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "0 for none, 1 for pre-existing conditions",
      "label_i18n": {
        "en": "Pre-existing Conditions",
        "tr": "Önceden Var Olan Hastalıklar",
        "de": "Vorerkrankungen",
        "fr": "Affections préexistantes",
        "es": "Condiciones preexistentes",
        "ar": "Pre-existing Conditions"
      },
      "businessContext_i18n": {
        "en": "0 for none, 1 for pre-existing conditions",
        "tr": "0 yok, 1 var",
        "de": "0 für keine, 1 für Vorerkrankungen",
        "fr": "0 pour aucune, 1 pour affections préexistantes",
        "es": "0 para ninguna, 1 para condiciones preexistentes"
      }
    },
    {
      "id": "occupationRisk",
      "label": "Occupation Risk Factor",
      "type": "number",
      "unit": "multiplier",
      "default": 1,
      "businessContext": "Risk factor based on occupation (1.0 = low risk, up to 2.0 high risk)",
      "label_i18n": {
        "en": "Occupation Risk Factor",
        "tr": "Meslek Risk Faktörü",
        "de": "Berufsrisikofaktor",
        "fr": "Facteur de risque professionnel",
        "es": "Factor de riesgo ocupacional",
        "ar": "Occupation Risk Factor"
      },
      "businessContext_i18n": {
        "en": "Risk factor based on occupation (1.0 = low risk, up to 2.0 high risk)",
        "tr": "Mesleğe göre risk faktörü (1.0 = düşük risk, 2.0'a kadar yüksek risk)",
        "de": "Risikofaktor basierend auf dem Beruf (1,0 = niedriges Risiko, bis zu 2,0 hohes Risiko)",
        "fr": "Facteur de risque basé sur la profession (1,0 = faible risque, jusqu'à 2,0 risque élevé)",
        "es": "Factor de riesgo basado en la ocupación (1.0 = bajo riesgo, hasta 2.0 alto riesgo)"
      }
    }
  ],
  "formulas": {
    "basePremium": "sumInsured * 0.02 * (1 + (age - 30) * 0.01)",
    "familyMultiplier": "1 + (familyMembers - 1) * 0.2",
    "riskMultiplier": "1 + smokerStatus * 0.5 + preExisting * 0.3",
    "totalPremium": "basePremium * familyMultiplier * riskMultiplier * occupationRisk"
  },
  "outputs": {
    "primary": "totalPremium",
    "breakdown": [
      "basePremium",
      "familyMultiplier",
      "riskMultiplier",
      "totalPremium"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalPremium",
    "unit": "years"
  },
  "category": "İSG & Risk",

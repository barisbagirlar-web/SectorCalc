    {
      "id": "smokerStatus",
      "label": "Smoker Status",
      "type": "number",
      "unit": "binary",
      "default": 0,
      "businessContext": "0 for non-smoker, 1 for smoker",
      "label_i18n": {
        "en": "Smoker Status",
        "tr": "Sigara İçme Durumu",
        "de": "Raucherstatus",
        "fr": "Statut tabagique",
        "es": "Estado de fumador",
        "ar": "Smoker Status"
      },
      "businessContext_i18n": {

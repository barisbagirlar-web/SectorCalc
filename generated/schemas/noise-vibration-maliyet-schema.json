  "formulas": {
    "NoiseExposure_dBA": "10 * LOG10((1/T) * SUM(t_i * 10^(L_i/10)))",
    "Vibration_RMS": "SQRT((1/T) * SUM(a_i^2 * t_i))",
    "HealthCost": "IF(Noise > 85 OR Vibration > Limit, MedicalScreening + PPE_Cost + InsurancePremiumHike, 0)",
    "ProductivityLoss": "(ActualOutput - BaselineOutput) * UnitMargin",
    "ReworkCost": "VibrationDefectRate * TotalUnits * ReworkCostPerUnit",
    "MitigationROI": "(HealthCost + ProdLoss + ReworkCost) / MitigationInvestment"
  },

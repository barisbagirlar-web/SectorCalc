  "formulas": {
    "Expected Value (EV)": "((streets === 2 ? Math.min(outs * 4, 99) : Math.min(outs * 2, 99)) / 100) * (potSize + betToCall) - (1 - (streets === 2 ? Math.min(outs * 4, 99) : Math.min(outs * 2, 99)) / 100) * betToCall",
    "Equity (%)": "streets === 2 ? Math.min(outs * 4, 99) : Math.min(outs * 2, 99)",
    "Pot Odds (%)": "(betToCall / (potSize + betToCall)) * 100",
    "Break-even Equity (%)": "(betToCall / (potSize + 2 * betToCall)) * 100"
  },
  "outputs": {
    "primary": "Expected Value (EV)",
    "breakdown": [
      "Equity (%)",
      "Pot Odds (%)",
      "Break-even Equity (%)"

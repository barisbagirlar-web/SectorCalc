{
  "toolName": "golf-club-distance-calculator",
  "inputs": [
    {
      "id": "swingSpeed",
      "label": "Swing Speed",
      "type": "number",
      "unit": "mph",
      "default": 100,
      "businessContext": "Club head speed at impact, typical driver 90-110 mph.",
      "label_i18n": {
        "en": "Swing Speed",
        "tr": "Swing Speed",
        "de": "Swing Speed",
        "fr": "Swing Speed",
        "es": "Swing Speed",
        "ar": "Swing Speed"
      }
    },
    {
      "id": "loft",
      "label": "Loft Angle",
      "type": "number",
      "unit": "deg",
      "default": 10.5,
      "businessContext": "Effective loft angle of the club. Driver ~9-12°, irons higher.",
      "label_i18n": {
        "en": "Loft Angle",
        "tr": "Loft Angle",
        "de": "Loft Angle",
        "fr": "Loft Angle",
        "es": "Loft Angle",
        "ar": "Loft Angle"
      }
    },
    {
      "id": "elevation",
      "label": "Elevation",
      "type": "number",
      "unit": "ft",
      "default": 0,
      "businessContext": "Elevation above sea level affecting air density. Higher elevation = longer carry.",
      "label_i18n": {
        "en": "Elevation",
        "tr": "Elevation",
        "de": "Elevation",
        "fr": "Elevation",
        "es": "Elevation",
        "ar": "Elevation"
      }
    },
    {
      "id": "wind",
      "label": "Wind Speed",
      "type": "number",
      "unit": "mph",
      "default": 0,
      "businessContext": "Wind speed in mph. Positive = tailwind, negative = headwind.",
      "label_i18n": {
        "en": "Wind Speed",
        "tr": "Wind Speed",
        "de": "Wind Speed",
        "fr": "Wind Speed",
        "es": "Wind Speed",
        "ar": "Wind Speed"
      }
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "°F",
      "default": 70,
      "businessContext": "Ambient temperature in Fahrenheit. Warmer air less dense = longer carry.",
      "label_i18n": {
        "en": "Temperature",
        "tr": "Temperature",
        "de": "Temperature",
        "fr": "Temperature",
        "es": "Temperature",
        "ar": "Temperature"
      }
    }
  ],
  "formulas": {
    "baseDistance": "swingSpeed * 2.3 - (loft - 10.5) * 2",
    "elevationFactor": "1 + elevation * 0.00002",
    "windFactor": "1 + wind * 0.01",
    "tempFactor": "1 + (temperature - 70) * 0.001",
    "distance": "baseDistance * elevationFactor * windFactor * tempFactor"
  },
  "outputs": {
    "primary": "distance",
    "breakdown": [
      "baseDistance",
      "elevationFactor",
      "windFactor",
      "tempFactor"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "distance"
  },

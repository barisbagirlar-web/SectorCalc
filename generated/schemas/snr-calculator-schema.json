{
  "toolName": "snr-calculator",
  "inputs": [
    {
      "id": "signalVoltage",
      "label": "Signal Voltage",
      "type": "number",
      "unit": "V",
      "default": 1,
      "businessContext": "RMS voltage of the desired signal"
    },
    {
      "id": "loadResistance",
      "label": "Load Resistance",
      "type": "number",
      "unit": "Ω",
      "default": 50,
      "businessContext": "System impedance"
    },
    {
      "id": "bandwidth",
      "label": "Bandwidth",
      "type": "number",
      "unit": "Hz",
      "default": 1000000,
      "businessContext": "Noise bandwidth of the system"
    },
    {
      "id": "temperature",
      "label": "Temperature",
      "type": "number",
      "unit": "K",
      "default": 290,
      "businessContext": "Absolute temperature in Kelvin (290K ≈ 17°C)"
    },
    {
      "id": "noiseFigure",
      "label": "Noise Figure",
      "type": "number",
      "unit": "dB",
      "default": 0,
      "businessContext": "System noise figure, 0 dB for ideal noiseless"
    }
  ],
  "formulas": {
    "noiseVoltageThermal": "Math.sqrt(4 * 1.380649e-23 * temperature * bandwidth * loadResistance)",
    "noiseFactor": "10 ** (noiseFigure / 10)",
    "totalNoiseVoltage": "noiseVoltageThermal * Math.sqrt(noiseFactor)",
    "snrLinear": "signalVoltage / totalNoiseVoltage",
    "snr_dB": "20 * Math.log10(snrLinear)"
  },
  "outputs": {
    "primary": "snr_dB",
    "breakdown": [
      "noiseVoltageThermal",
      "totalNoiseVoltage",
      "snrLinear"
    ]
  },
  "category": "Elektrik & Otomasyon",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "electrical-power-systems",
  "sectorId": "diger",
  "profession": "Genel Uzman",
  "categoryId": "safety"
}

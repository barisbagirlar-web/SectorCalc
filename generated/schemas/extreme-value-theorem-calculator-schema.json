{
  "toolName": "extreme-value-theorem-calculator",
  "inputs": [
    {
      "id": "location",
      "label": "Location (μ)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Location parameter of the GEV distribution (center).",
      "label_i18n": {
        "en": "Location (μ)",
        "tr": "Location (μ)",
        "de": "Location (μ)",
        "fr": "Location (μ)",
        "es": "Location (μ)",
        "ar": "Location (μ)"
      }
    },
    {
      "id": "scale",
      "label": "Scale (σ)",
      "type": "number",
      "unit": "unit",
      "default": 1,
      "businessContext": "Scale parameter, must be > 0. Controls spread.",
      "label_i18n": {
        "en": "Scale (σ)",
        "tr": "Scale (σ)",
        "de": "Scale (σ)",
        "fr": "Scale (σ)",
        "es": "Scale (σ)",
        "ar": "Scale (σ)"
      }
    },
    {
      "id": "shape",
      "label": "Shape (ξ)",
      "type": "number",
      "unit": "unit",
      "default": 0,
      "businessContext": "Shape parameter. ξ>0 heavy-tailed, ξ=0 Gumbel, ξ<0 bounded.",
      "label_i18n": {
        "en": "Shape (ξ)",
        "tr": "Shape (ξ)",
        "de": "Shape (ξ)",
        "fr": "Shape (ξ)",
        "es": "Shape (ξ)",
        "ar": "Shape (ξ)"
      }
    },
    {
      "id": "returnPeriod",
      "label": "Return Period",
      "type": "number",
      "unit": "years",
      "default": 100,
      "businessContext": "Average recurrence interval in years (e.g., 100 for 100-year event).",
      "label_i18n": {
        "en": "Return Period",
        "tr": "Return Period",
        "de": "Return Period",
        "fr": "Return Period",
        "es": "Return Period",
        "ar": "Return Period"
      }
    }
  ],
  "formulas": {
    "exceedanceProbability": "1 / returnPeriod",
    "returnLevel": "Math.abs(shape) < 1e-10 ? location - scale * Math.log(-Math.log(1 - 1/returnPeriod)) : location + (scale/shape) * (Math.pow(-Math.log(1 - 1/returnPeriod), -shape) - 1)"
  },
  "outputs": {
    "primary": "returnLevel",
    "breakdown": [
      "exceedanceProbability",
      "returnLevel"
    ]
  },

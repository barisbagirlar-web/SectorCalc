{
  "toolName": "runs-test-calculator",
  "inputs": [
    {
      "id": "countA",
      "label": "Count of Type A",
      "type": "number",
      "unit": "unit",
      "default": null,
      "businessContext": "Number of items in first category",
      "label_i18n": {

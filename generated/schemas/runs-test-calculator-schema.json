        "es": "Count of Type A",
        "ar": "Count of Type A"
      }
    },
    {
      "id": "countB",
      "label": "Count of Type B",
      "type": "number",
      "unit": "unit",
      "default": null,
      "businessContext": "Number of items in second category",
      "label_i18n": {
        "en": "Count of Type B",
        "tr": "Count of Type B",
        "de": "Count of Type B",
        "fr": "Count of Type B",
        "es": "Count of Type B",
        "ar": "Count of Type B"
      }
    },
    {
      "id": "runs",
      "label": "Observed Number of Runs",
      "type": "number",
      "unit": "unit",
      "default": null,
      "businessContext": "Total number of runs in the sequence",
      "label_i18n": {
        "en": "Observed Number of Runs",
        "tr": "Observed Number of Runs",
        "de": "Observed Number of Runs",
        "fr": "Observed Number of Runs",
        "es": "Observed Number of Runs",
        "ar": "Observed Number of Runs"
      }
    },
    {
      "id": "alpha",
      "label": "Significance Level (α)",
      "type": "number",
      "unit": "unit",
      "default": 0.05,
      "businessContext": "Type I error threshold for hypothesis test conclusion",
      "label_i18n": {
        "en": "Significance Level (α)",
        "tr": "Significance Level (α)",
        "de": "Significance Level (α)",
        "fr": "Significance Level (α)",
        "es": "Significance Level (α)",
        "ar": "Significance Level (α)"
      }
    }
  ],
  "formulas": {
    "expectedRuns": "(2 * countA * countB) / (countA + countB) + 1",
    "varianceRuns": "2 * countA * countB * (2 * countA * countB - countA - countB) / (Math.pow(countA + countB, 2) * (countA + countB - 1))",
    "stdDevRuns": "Math.sqrt(varianceRuns)",
    "zScore": "(runs - expectedRuns) / stdDevRuns",
    "zAbs": "Math.abs(zScore)",
    "phi": "0.3989423 * Math.exp(-zAbs * zAbs / 2)",
    "t": "1 / (1 + 0.2316419 * zAbs)",
    "poly": "t * (0.319381530 + t * (-0.356563782 + t * (1.781477937 + t * (-1.821255978 + t * 1.330274429))))",
    "cdf": "1 - phi * poly",
    "pValue": "2 * (zScore > 0 ? (1 - cdf) : cdf)",
    "conclusion": "pValue < alpha ? 'Reject H0: Data is not random' : 'Do not reject H0: Data may be random'"
  },
  "outputs": {
    "primary": "pValue",
    "breakdown": [
      "expectedRuns",
      "varianceRuns",
      "stdDevRuns",
      "zScore",
      "pValue",
      "conclusion"
    ]
  },

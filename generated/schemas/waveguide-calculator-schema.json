{
  "toolName": "waveguide-calculator",
  "inputs": [
    {
      "id": "width",
      "label": "Genişlik (a)",
      "type": "number",
      "unit": "mm",
      "default": 22.86,
      "businessContext": "Dalga kılavuzu geniş iç boyutu"
    },
    {
      "id": "height",
      "label": "Yükseklik (b)",
      "type": "number",
      "unit": "mm",
      "default": 10.16,
      "businessContext": "Dalga kılavuzu dar iç boyutu"
    },
    {
      "id": "frequency",
      "label": "Çalışma Frekansı",
      "type": "number",
      "unit": "GHz",
      "default": 10,
      "businessContext": "İşletim frekansı"
    },
    {
      "id": "permittivity",
      "label": "Bağıl Dielektrik Sabiti",
      "type": "number",
      "unit": "boyutsuz",
      "default": 1,
      "businessContext": "İç dielektrik malzeme (hava için 1)"
    }
  ],
  "formulas": {
    "cutoffFrequency": "150 / (width * Math.sqrt(permittivity))",
    "guideWavelength": "(300 / (frequency * Math.sqrt(permittivity))) / Math.sqrt(1 - Math.pow(150 / (width * Math.sqrt(permittivity)) / frequency, 2))",
    "characteristicImpedance": "(377 / Math.sqrt(permittivity)) / Math.sqrt(1 - Math.pow(150 / (width * Math.sqrt(permittivity)) / frequency, 2))"
  },
  "outputs": {
    "primary": "cutoffFrequency",
    "breakdown": [
      "guideWavelength",
      "characteristicImpedance"
    ],
    "outputFields": [
      {
        "id": "cutoffFrequency",
        "label": "Kesim Frekansı",
        "unit": "GHz",
        "description": "TE10 modu için rehber dalga kesim frekansı"
      },
      {
        "id": "guideWavelength",
        "label": "Kılavuz Dalga Boyu",
        "unit": "mm",
        "description": "Dalga kılavuzu içindeki ilerleme dalga boyu"
      },
      {
        "id": "characteristicImpedance",
        "label": "Dalga Empedansı",
        "unit": "Ohm",
        "description": "TE modu için karakteristik empedans"
      }
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "engineering-science",
  "sectorSlug": "cnc-manufacturing",
  "categorySlug": "cnc-additive-manufacturing"
}

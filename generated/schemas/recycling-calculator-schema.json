        "es": "Geri Dönüştürülen Miktar (kg)",
        "ar": "Geri Dönüştürülen Miktar (kg)"
      }
    },
    {
      "id": "contaminationRate",
      "label": "Kirlilik Oranı (%)",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Geri dönüştürülen malzemedeki kirlilik oranı",
      "label_i18n": {
        "en": "Kirlilik Oranı (%)",
        "tr": "Kirlilik Oranı (%)",
        "de": "Kirlilik Oranı (%)",
        "fr": "Kirlilik Oranı (%)",
        "es": "Kirlilik Oranı (%)",
        "ar": "Kirlilik Oranı (%)"
      }
    },
    {
      "id": "disposalCostPerKg",
      "label": "Bertaraf Maliyeti (TL/kg)",
      "type": "number",
      "unit": "TL/kg",
      "default": 0.5,
      "businessContext": "Atığın kg başına bertaraf maliyeti",
      "label_i18n": {
        "en": "Bertaraf Maliyeti (TL/kg)",
        "tr": "Bertaraf Maliyeti (TL/kg)",
        "de": "Bertaraf Maliyeti (TL/kg)",
        "fr": "Bertaraf Maliyeti (TL/kg)",
        "es": "Bertaraf Maliyeti (TL/kg)",
        "ar": "Bertaraf Maliyeti (TL/kg)"
      }
    },
    {
      "id": "revenuePerKg",
      "label": "Geri Dönüşüm Geliri (TL/kg)",
      "type": "number",
      "unit": "TL/kg",
      "default": 1.2,
      "businessContext": "Geri dönüştürülen malzemenin kg başına satış geliri",
      "label_i18n": {
        "en": "Geri Dönüşüm Geliri (TL/kg)",
        "tr": "Geri Dönüşüm Geliri (TL/kg)",
        "de": "Geri Dönüşüm Geliri (TL/kg)",
        "fr": "Geri Dönüşüm Geliri (TL/kg)",
        "es": "Geri Dönüşüm Geliri (TL/kg)",
        "ar": "Geri Dönüşüm Geliri (TL/kg)"
      }
    }
  ],
  "formulas": {
    "effectiveRecycledWeight": "recycledAmount * (1 - contaminationRate / 100)",
    "recyclingRate": "((recycledAmount * (1 - contaminationRate / 100)) / totalWaste) * 100",
    "disposalWeight": "totalWaste - (recycledAmount * (1 - contaminationRate / 100))",
    "costSavings": "(recycledAmount * (1 - contaminationRate / 100)) * disposalCostPerKg",
    "revenueGenerated": "(recycledAmount * (1 - contaminationRate / 100)) * revenuePerKg",
    "netSavings": "(recycledAmount * (1 - contaminationRate / 100)) * (disposalCostPerKg + revenuePerKg)"
  },
  "outputs": {
    "primary": "recyclingRate",
    "breakdown": [
      "effectiveRecycledWeight",
      "disposalWeight",
      "costSavings",
      "revenueGenerated",
      "netSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netSavings"
  },

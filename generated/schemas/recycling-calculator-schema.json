      }
    },
    {
      "id": "recycledAmount",
      "label": "Geri Dönüştürülen Miktar (kg)",
      "type": "number",
      "unit": "kg",
      "default": 300,
      "businessContext": "Geri dönüşüme gönderilen atık miktarı",
      "label_i18n": {
        "en": "Geri Dönüştürülen Miktar (kg)",
        "tr": "Geri Dönüştürülen Miktar (kg)",
        "de": "Geri Dönüştürülen Miktar (kg)",

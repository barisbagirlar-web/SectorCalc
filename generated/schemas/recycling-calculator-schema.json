        "es": "Tasa de contaminación en el material reciclado",
        "ar": "نسبة التلوث في المواد المعاد تدويرها"
      }
    },
    {
      "id": "disposalCostPerKg",
      "label": "Bertaraf Maliyeti (TL/kg)",
      "type": "number",
      "unit": "TL/kg",
      "default": 0.5,
      "businessContext": "Atığın kg başına bertaraf maliyeti",
      "label_i18n": {
        "en": "Bertaraf Maliyeti (TL/kg)",
        "tr": "Disposal cost (TL/kg)",
        "de": "Entsorgungskosten (TL/kg)",
        "fr": "Coût d'élimination (TL/kg)",
        "es": "Costo de eliminación (TL/kg)",
        "ar": "تكلفة التخلص (TL/kg)"
      },
      "businessContext_i18n": {
        "en": "Disposal cost per kg of waste",
        "tr": "Atığın kg başına bertaraf maliyeti",
        "de": "Entsorgungskosten pro kg Abfall",
        "fr": "Coût d'élimination par kg de déchet",
        "es": "Costo de eliminación por kg de residuo",
        "ar": "تكلفة التخلص لكل كجم من النفايات"
      }
    },
    {
      "id": "revenuePerKg",
      "label": "Geri Dönüşüm Geliri (TL/kg)",
      "type": "number",
      "unit": "TL/kg",
      "default": 1.2,
      "businessContext": "Geri dönüştürülen malzemenin kg başına satış geliri",
      "label_i18n": {
        "en": "Recycling Revenue (TL/kg)",
        "tr": "Geri Dönüşüm Geliri (TL/kg)",
        "de": "Recyclingerlös (TL/kg)",
        "fr": "Revenu du recyclage (TL/kg)",
        "es": "Ingreso por reciclaje (TL/kg)",
        "ar": "إيرادات إعادة التدوير (TL/kg)"
      },
      "businessContext_i18n": {
        "en": "Sales revenue per kg of recycled material",
        "tr": "Geri dönüştürülen malzemenin kg başına satış geliri",
        "de": "Verkaufserlös pro kg recyceltem Material",
        "fr": "Revenu de vente par kg de matière recyclée",
        "es": "Ingresos por venta por kg de material reciclado",
        "ar": "إيرادات بيع المواد المعاد تدويرها لكل كجم"
      }
    }
  ],
  "formulas": {
    "effectiveRecycledWeight": "recycledAmount * (1 - contaminationRate / 100)",
    "recyclingRate": "((recycledAmount * (1 - contaminationRate / 100)) / totalWaste) * 100",
    "disposalWeight": "totalWaste - (recycledAmount * (1 - contaminationRate / 100))",
    "costSavings": "(recycledAmount * (1 - contaminationRate / 100)) * disposalCostPerKg",
    "revenueGenerated": "(recycledAmount * (1 - contaminationRate / 100)) * revenuePerKg",
    "netSavings": "(recycledAmount * (1 - contaminationRate / 100)) * (disposalCostPerKg + revenuePerKg)"
  },
  "outputs": {
    "primary": "recyclingRate",
    "breakdown": [
      "effectiveRecycledWeight",
      "disposalWeight",
      "costSavings",
      "revenueGenerated",
      "netSavings"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "netSavings",
    "unit": "kg"
  },

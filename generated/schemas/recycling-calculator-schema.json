        "en": "Pollution Rate (%)",
        "tr": "Kirlilik Oranı (%)",
        "de": "Verunreinigungsrate (%)",
        "fr": "Taux d'impuretés (%)",
        "es": "Tasa de contaminación (%)",
        "ar": "نسبة التلوث (%)"
      },
      "businessContext_i18n": {

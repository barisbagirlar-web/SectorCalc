      "businessContext": "Geri dönüşüme gönderilen atık miktarı",
      "label_i18n": {
        "en": "Recycled Amount (kg)",
        "tr": "Geri Dönüştürülen Miktar (kg)",
        "de": "Recycelte Menge (kg)",
        "fr": "Quantité recyclée (kg)",
        "es": "Cantidad reciclada (kg)",
        "ar": "الكمية المعاد تدويرها (كجم)"
      },
      "businessContext_i18n": {
        "en": "Amount of waste sent for recycling",
        "tr": "Geri dönüşüme gönderilen atık miktarı",
        "de": "Menge des zum Recycling gegebenen Abfalls",

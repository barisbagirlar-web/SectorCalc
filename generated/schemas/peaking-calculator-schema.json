{
  "toolName": "peaking-calculator",
  "inputs": [
    {
      "id": "peakDemand",
      "label": "Peak Demand",
      "type": "number",
      "unit": "kW",
      "default": 100,
      "businessContext": "Highest power demand during peak hours"
    },
    {
      "id": "offPeakDemand",
      "label": "Off-Peak Demand",
      "type": "number",
      "unit": "kW",
      "default": 50,
      "businessContext": "Power demand during off-peak hours"
    },
    {
      "id": "peakHours",
      "label": "Peak Hours",
      "type": "number",
      "unit": "hours",
      "default": 8,
      "businessContext": "Number of peak hours per day"
    },
    {
      "id": "offPeakHours",
      "label": "Off-Peak Hours",
      "type": "number",
      "unit": "hours",
      "default": 16,
      "businessContext": "Number of off-peak hours per day"
    },
    {
      "id": "peakRate",
      "label": "Peak Rate",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.15,
      "businessContext": "Electricity rate during peak hours"
    },
    {
      "id": "offPeakRate",
      "label": "Off-Peak Rate",
      "type": "number",
      "unit": "currency/kWh",
      "default": 0.05,
      "businessContext": "Electricity rate during off-peak hours"
    }
  ],
  "formulas": {
    "peakEnergyCost": "peakDemand * peakHours * peakRate",
    "offPeakEnergyCost": "offPeakDemand * offPeakHours * offPeakRate",
    "totalCost": "peakEnergyCost + offPeakEnergyCost"
  },
  "outputs": {
    "primary": "totalCost",
    "breakdown": [
      "peakEnergyCost",
      "offPeakEnergyCost"
    ]
  },
  "category": "Enerji & Karbon",
  "sector": "Enerji & Elektrik",
  "premiumRequired": false,
  "catalogCategory": "health-body",
  "sectorSlug": "cleaning",
  "categorySlug": "technology-ai-cloud-cyber",
  "sectorId": "enerji",
  "profession": "Enerji Mühendisi",
  "categoryId": "energy"
}

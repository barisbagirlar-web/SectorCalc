{
  "toolName": "irr-calculator",
  "catalogCategory": "everyday-life",
  "categorySlug": "finance-sales-working-capital",
  "sector": "Finans",
  "sectorId": "finance-sales-working-capital",
  "inputs": [
    {
      "id": "investment",
      "label": "Initial Investment (USD)",
      "type": "number",
      "unit": "USD",
      "default": 100000,
      "min": 0,
      "businessContext": "Initial project cost."
    },
    {
      "id": "ortalamaNakit",
      "label": "Avg Annual Cash Flow (USD)",
      "type": "number",
      "unit": "USD",
      "default": 35000,
      "min": 0,
      "businessContext": "Average annual cash inflow."
    },
    {
      "id": "year",
      "label": "Project Life (Years)",
      "type": "number",
      "unit": "years",
      "default": 5,
      "min": 1,
      "businessContext": "Project's economic life."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "(Math.pow(1 + ortalamaNakit / Math.max(1, investment), 1 / Math.max(1, year)) - 1) * 100"
  },
  "outputs": {
    "primary": "result",
    "unit": "%",
    "breakdown": {
      "result": "IRR (Internal Rate of Return - Yaklasik)"
    },
    "breakdownUnits": {
      "result": "%"
    },
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Verify inputs before making financial decisions.",
      "Consult a licensed financial advisor for personalized advice."
    ],
    "dataConfidenceAdjusted": "result"
  },
  "premiumRequired": false,
  "premiumFeatures": [],
  "about": {
    "description": {
      "short": "Estimate the internal rate of return (IRR) that zeroes NPV.",
      "long": "Estimate the internal rate of return (IRR) that zeroes NPV."
    }
  },
  "sectorSlug": "daily-renovation"
}

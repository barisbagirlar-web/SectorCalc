    },
    {
      "id": "enflasyon",
      "label": "Annual Inflation (%)",
      "type": "number",
      "unit": "%",
      "default": 15,
      "min": 0,
      "businessContext": "Average annual inflation rate."
    },
    {
      "id": "year",
      "label": "Number of Years",
      "type": "number",
      "unit": "years",
      "default": 5,
      "min": 0,
      "businessContext": "Future period in years."
    }
  ],
  "validation": {
    "rules": [
      "All numeric inputs must be positive numbers."
    ],
    "thresholds": {}
  },
  "formulas": {
    "result": "nominalDeger / Math.pow(1 + enflasyon / 100, year)"
  },

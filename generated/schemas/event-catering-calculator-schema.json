{
  "toolName": "event-catering-calculator",
  "inputs": [
    {
      "id": "numberOfGuests",
      "label": "Number of Guests",
      "type": "number",
      "unit": "guests",
      "default": 100,
      "businessContext": "Expected total number of attendees for the event.",
      "label_i18n": {
        "en": "Number of Guests",
        "tr": "Number of Guests",
        "de": "Number of Guests",
        "fr": "Number of Guests",
        "es": "Number of Guests",
        "ar": "Number of Guests"
      }
    },
    {
      "id": "costPerPlate",
      "label": "Cost per Plate",
      "type": "number",
      "unit": "USD",
      "default": 15,
      "businessContext": "Direct food and beverage cost per guest, including ingredients and preparation.",
      "label_i18n": {
        "en": "Cost per Plate",
        "tr": "Cost per Plate",
        "de": "Cost per Plate",
        "fr": "Cost per Plate",
        "es": "Cost per Plate",
        "ar": "Cost per Plate"
      }
    },
    {
      "id": "serviceStaff",
      "label": "Service Staff",
      "type": "number",
      "unit": "persons",
      "default": 5,
      "businessContext": "Number of waitstaff and service personnel required.",
      "label_i18n": {
        "en": "Service Staff",
        "tr": "Service Staff",
        "de": "Service Staff",
        "fr": "Service Staff",
        "es": "Service Staff",
        "ar": "Service Staff"
      }
    },
    {
      "id": "staffHourlyRate",
      "label": "Staff Hourly Rate",
      "type": "number",
      "unit": "USD/hr",
      "default": 20,
      "businessContext": "Hourly wage per service staff, including benefits and taxes.",
      "label_i18n": {
        "en": "Staff Hourly Rate",
        "tr": "Staff Hourly Rate",
        "de": "Staff Hourly Rate",
        "fr": "Staff Hourly Rate",
        "es": "Staff Hourly Rate",
        "ar": "Staff Hourly Rate"
      }
    },
    {
      "id": "eventDurationHours",
      "label": "Event Duration",
      "type": "number",
      "unit": "hours",
      "default": 4,
      "businessContext": "Total duration of the event from setup to teardown.",
      "label_i18n": {
        "en": "Event Duration",
        "tr": "Event Duration",
        "de": "Event Duration",
        "fr": "Event Duration",
        "es": "Event Duration",
        "ar": "Event Duration"
      }
    },
    {
      "id": "overheadFixed",
      "label": "Fixed Overhead",
      "type": "number",
      "unit": "USD",
      "default": 500,
      "businessContext": "Fixed costs such as equipment rental, insurance, permits, and transportation.",
      "label_i18n": {
        "en": "Fixed Overhead",
        "tr": "Fixed Overhead",
        "de": "Fixed Overhead",
        "fr": "Fixed Overhead",
        "es": "Fixed Overhead",
        "ar": "Fixed Overhead"
      }
    },
    {
      "id": "profitMarginPercent",
      "label": "Profit Margin",
      "type": "number",
      "unit": "%",
      "default": 20,
      "businessContext": "Desired markup percentage on total cost to ensure profitability.",
      "label_i18n": {
        "en": "Profit Margin",
        "tr": "Profit Margin",
        "de": "Profit Margin",
        "fr": "Profit Margin",
        "es": "Profit Margin",
        "ar": "Profit Margin"
      }
    },
    {
      "id": "taxRatePercent",
      "label": "Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 8,
      "businessContext": "Applicable sales tax or VAT percentage on the subtotal.",
      "label_i18n": {
        "en": "Tax Rate",
        "tr": "Tax Rate",
        "de": "Tax Rate",
        "fr": "Tax Rate",
        "es": "Tax Rate",
        "ar": "Tax Rate"
      }
    }
  ],
  "formulas": {
    "totalFoodCost": "numberOfGuests * costPerPlate",
    "totalStaffCost": "serviceStaff * staffHourlyRate * eventDurationHours",
    "totalVariableCost": "totalFoodCost + totalStaffCost",
    "totalFixedCost": "overheadFixed",
    "subtotal": "totalVariableCost + totalFixedCost",
    "taxAmount": "subtotal * (taxRatePercent / 100)",
    "totalCost": "subtotal + taxAmount",
    "revenueRequired": "totalCost * (1 + profitMarginPercent / 100)",
    "pricePerPlate": "revenueRequired / numberOfGuests"
  },
  "outputs": {
    "primary": "pricePerPlate",
    "breakdown": [
      "totalFoodCost",
      "totalStaffCost",
      "totalCost",
      "revenueRequired"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "pricePerPlate",
    "unit": "guests"
  },
  "category": "Maliyet & Bütçeleme",
  "sector": "Perakende & Ticaret",
  "premiumRequired": false,
  "catalogCategory": "everyday-life",
  "sectorSlug": "daily-renovation",
  "categorySlug": "finance-sales-working-capital",
  "sectorId": "perakende",
  "profession": "Satış Müdürü",
  "categoryId": "cost",
  "validation": {
    "rules": [],
    "thresholds": {}
  },
  "premiumFeatures": []
}

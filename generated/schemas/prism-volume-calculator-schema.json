{
  "toolName": "prism-volume-calculator",
  "inputs": [
    {
      "id": "baseArea",
      "label": "Base Area",
      "type": "number",
      "unit": "m²",
      "default": 0,
      "businessContext": "If known, enter the prism's base area directly (set >0). If 0, base area is computed from sides and side length."
    },
    {
      "id": "sides",
      "label": "Number of Sides",
      "type": "number",
      "unit": "",
      "default": 3,
      "businessContext": "Number of sides of the regular polygonal base (e.g., 3 for triangle, 4 for square). Only used if base area is 0."
    },
    {
      "id": "sideLength",
      "label": "Side Length",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Length of one side of the regular polygonal base. Only used if base area is 0."
    },
    {
      "id": "height",
      "label": "Height",
      "type": "number",
      "unit": "m",
      "default": 1,
      "businessContext": "Perpendicular height of the prism."
    }
  ],
  "formulas": {
    "computedBaseArea": "(sides >= 3) ? (sides * sideLength * sideLength) / (4 * Math.tan(Math.PI / sides)) : (sideLength * sideLength)",
    "finalBaseArea": "baseArea > 0 ? baseArea : computedBaseArea",
    "volume": "finalBaseArea * height"
  },
  "outputs": {
    "primary": "volume",
    "breakdown": [
      "finalBaseArea",
      "height"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "math-statistics",
  "sectorSlug": "ecommerce",
  "categorySlug": "technology-ai-cloud-cyber"
}

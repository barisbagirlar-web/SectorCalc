{
  "toolName": "state-tax-calculator",
  "inputs": [
    {
      "id": "grossIncome",
      "label": "Gross Income",
      "type": "number",
      "unit": "USD",
      "default": 50000,
      "businessContext": "Annual gross income before taxes",
      "label_i18n": {
        "en": "Gross Income",
        "tr": "Brüt Gelir",
        "de": "Gross Income",
        "fr": "Gross Income",
        "es": "Gross Income",
        "ar": "Gross Income"
      },
      "businessContext_i18n": {
        "en": "Annual gross income before taxes",
        "tr": "Vergi öncesi yıllık brüt gelir"
      }
    },
    {
      "id": "stateTaxRate",
      "label": "State Tax Rate",
      "type": "number",
      "unit": "%",
      "default": 5,
      "businessContext": "Applicable state income tax rate",
      "label_i18n": {
        "en": "State Tax Rate",
        "tr": "Eyalet Vergi Oranı",
        "de": "Steuersatz des Bundesstaats",
        "fr": "State Tax Rate",
        "es": "State Tax Rate",
        "ar": "State Tax Rate"
      },
      "businessContext_i18n": {
        "en": "Applicable state income tax rate",
        "tr": "Geçerli eyalet gelir vergisi oranı"
      }
    },
    {
      "id": "standardDeduction",
      "label": "Standard Deduction",
      "type": "number",
      "unit": "USD",
      "default": 12000,
      "businessContext": "Standard deduction amount for the tax year",
      "label_i18n": {
        "en": "Standard Deduction",
        "tr": "Standart Kesinti",
        "de": "Standard Deduction",
        "fr": "Standard Deduction",
        "es": "Standard Deduction",
        "ar": "Standard Deduction"
      },
      "businessContext_i18n": {
        "en": "Standard deduction amount for the tax year",
        "tr": "Vergi yılı için standart kesinti tutarı"
      }
    },
    {
      "id": "additionalDeductions",
      "label": "Additional Deductions",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Other deductions (e.g., mortgage interest, charitable contributions)",
      "label_i18n": {
        "en": "Additional Deductions",
        "tr": "Ek Kesintiler",
        "de": "Additional Deductions",
        "fr": "Additional Deductions",
        "es": "Additional Deductions",
        "ar": "Additional Deductions"
      },
      "businessContext_i18n": {
        "en": "Other deductions (e.g., mortgage interest, charitable contributions)",
        "tr": "Diğer kesintiler (ör. ipotek faizi, bağışlar)"
      }
    },
    {
      "id": "taxCredits",
      "label": "Tax Credits",
      "type": "number",
      "unit": "USD",
      "default": 0,
      "businessContext": "Non-refundable tax credits to reduce tax liability",
      "label_i18n": {
        "en": "Tax Credits",
        "tr": "Vergi Kredileri",
        "de": "Tax Credits",
        "fr": "Tax Credits",
        "es": "Tax Credits",
        "ar": "Tax Credits"
      },
      "businessContext_i18n": {
        "en": "Non-refundable tax credits to reduce tax liability",
        "tr": "Vergi borcunu azaltmak için iade edilmeyen vergi kredileri"
      }
    }
  ],
  "formulas": {
    "taxableIncome": "grossIncome - standardDeduction - additionalDeductions",
    "taxBeforeCredits": "taxableIncome > 0 ? taxableIncome * stateTaxRate / 100 : 0"
  },
  "outputs": {
    "primary": "taxBeforeCredits",
    "breakdown": [
      "taxableIncome",
      "taxBeforeCredits",
      "totalTaxOwed"
    ],
    "hiddenLossDrivers": [],
    "suggestedActions": [
      "Review inputs and verify results against site standards."
    ],
    "dataConfidenceAdjusted": "totalTaxOwed",
    "unit": "USD"
  },

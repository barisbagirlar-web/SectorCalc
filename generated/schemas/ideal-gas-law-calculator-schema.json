{
  "toolName": "ideal-gas-law-calculator",
  "inputs": [
    {
      "id": "volume",
      "label": "Volume (V)",
      "type": "number",
      "unit": "L",
      "default": 22.4,
      "businessContext": "The volume of the gas in liters."
    },
    {
      "id": "moles",
      "label": "Moles (n)",
      "type": "number",
      "unit": "mol",
      "default": 1,
      "businessContext": "Amount of substance in moles."
    },
    {
      "id": "temperature",
      "label": "Temperature (T)",
      "type": "number",
      "unit": "K",
      "default": 273.15,
      "businessContext": "Absolute temperature in Kelvin."
    },
    {
      "id": "gasConstant",
      "label": "Gas Constant (R)",
      "type": "number",
      "unit": "L·atm/(mol·K)",
      "default": 0.082057,
      "businessContext": "Ideal gas constant. Adjust based on pressure/volume units."
    }
  ],
  "formulas": {
    "pressure": "(moles * gasConstant * temperature) / volume"
  },
  "outputs": {
    "primary": "pressure",
    "breakdown": [
      "P = nRT/V",
      "PV = nRT"
    ]
  },
  "category": "Teknik & Mühendislik",
  "sector": "Teknik & Mühendislik",
  "premiumRequired": false,
  "catalogCategory": "physics-science",
  "sectorSlug": "energy-consumption",
  "categorySlug": "technology-ai-cloud-cyber"
}

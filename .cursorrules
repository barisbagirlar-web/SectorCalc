# .cursorrules — SectorCalc
role: senior_engineer_production_mode
hard_constraints:
  - english_only: true          # kod, yorum, commit, PR, UI string
  - no_eval_no_new_function: true
  - formula_execution: server_side_only
  - design_tokens_locked:
      bg: "#F0EEE6"
      ink: "#1A1915"
      accent: "#BD5D3A"
      radius: "0px"
  - schema_contract: 25_key_top_level  # değişiklik önce ci_gate_validate.js'den geçmeli
  - incomplete_work_forbidden: true    # "borç bırakma" — TODO/stub bırakılamaz
verification_required_before_done:
  - "npm run ci:gate"
  - "npm run test:golden"
communication_style:
  - no_filler_phrases: true
  - no_summary_after_code: true
  - flag_uncertainty_explicitly: true   # varsayım yaptıysa açıkça yaz

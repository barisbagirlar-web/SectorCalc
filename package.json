    "guard:sitemap-root": "node scripts/guard-sitemap-root-contract.mjs",
    "smoke:sitemap-root": "node scripts/smoke-sitemap-root.mjs",
    "guard:working-tree-clean": "node scripts/guard-working-tree-clean.mjs",
    "resolve:pro-schema-loader-dirty": "node scripts/resolve-pro-schema-loader-dirty-file.mjs"

{
  "name": "fresh_app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/next-build-with-500-fallback.mjs && npm run generate:sitemap-static",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=6144 tsc --noEmit",
    "guard:repo": "node scripts/sectorcalc-repo-guard.mjs",
    "lint:errors": "eslint --quiet",
    "verify:gate": "npm run guard:repo && npm run guard:root-only && npm run typecheck && npm run lint:errors && npm run build",
    "verify:gate:test": "npm run test --if-present && npm run verify:gate",
    "guard:root-only": "node scripts/sectorcalc-root-only-route-guard.mjs",
    "smoke:root-only": "node scripts/sectorcalc-root-only-runtime-smoke.mjs",
    "verify:global-root-only": "npm run verify:gate && git restore -- next-env.d.ts firebase-debug.log 2>/dev/null || true && npm run smoke:root-only",
    "verify:root-only-hard": "npm run guard:root-only && npm run verify:gate && npm run smoke:root-only",
    "guard:universal-renderer": "node scripts/sectorcalc-universal-renderer-guard.mjs",
    "guard:balanced-input-fields": "node scripts/sectorcalc-balanced-input-fields-guard.mjs",
    "guard:header-clickability": "node scripts/sectorcalc-header-controls-clickability-guard.mjs",
    "generate:sitemap-static": "tsx scripts/generate-sitemap-static.ts",
    "prebuild": "tsx scripts/prebuild-reference-registry.ts && tsx scripts/prebuild-reference-engine-guard.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.62.0",
    "@serwist/next": "^9.5.11",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "autoprefixer": "^10.5.2",
    "big.js": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.0.0",
    "jsep": "^1.4.0",
    "lucide-react": "^1.22.0",
    "next": "^15.5.19",
    "next-intl": "^4.13.0",
    "nodemailer": "^9.0.1",
    "openai": "^6.45.0",
    "postcss": "^8.5.16",
    "postcss-import": "^16.1.1",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "serwist": "^9.5.11",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "fast-check": "^4.8.0",
    "firebase-tools": "^15.22.4",
    "tailwindcss": "^3.4.19",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}

{
  "name": "sectorcalc",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:schemas": "vitest run src/lib/premium-schema/__tests__/schema-linter.test.ts",
    "validate:premium-schemas": "vitest run src/lib/premium-schema/__tests__/schema-linter.test.ts src/lib/premium-schema/__tests__/premium-schema-engine.test.ts src/lib/premium-schema/__tests__/premium-migration-map.test.ts src/lib/premium-schema/__tests__/premium-report-ux.test.ts src/lib/premium-schema/__tests__/schema-draft.test.ts",
    "seo:llms": "npx tsx scripts/generate-seo-authority-txt.ts",
    "seo:authority-txt": "npx tsx scripts/generate-seo-authority-txt.ts",
    "seo:export-manifest": "npx tsx scripts/export-indexable-manifest.ts",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "prebuild": "npm run lint:schemas && npm run seo:authority-txt && npm run seo:export-manifest",
    "audit:revenue-tools": "node scripts/audit-revenue-tools.mjs",
    "audit:formulas": "npx tsx scripts/audit-formulas.ts",
    "audit:alignment": "npx tsx scripts/audit-alignment.ts",
    "audit:input-design": "npx tsx scripts/audit-input-design.ts",
    "audit:migration-plan": "npx tsx scripts/audit-migration-plan.ts",
    "audit:smart-form": "npx tsx scripts/audit-smart-form.ts",
    "audit:smart-form-architecture": "npm run audit:smart-form",
    "inventory:formulas": "npx tsx scripts/inventory-formulas.ts",
    "test:formulas": "vitest run src/lib/formula-governance",
    "check:secrets": "node scripts/check-commit-secrets.mjs",
    "admin:set-claim": "node scripts/set-admin-claim.mjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@react-pdf/renderer": "^4.5.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^1.17.0",
    "next": "^15.1.0",
    "next-intl": "^4.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "fast-check": "^4.8.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.8"

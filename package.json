    "purge:legacy-forms:apply": "node scripts/purge-legacy-form-files.mjs --apply",
    "guard:v531-form-architecture": "node scripts/guard-v531-form-architecture-lock.mjs",
    "guard:forbidden-form-surfaces": "node scripts/guard-forbidden-form-surfaces.mjs",

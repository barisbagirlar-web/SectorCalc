scripts/.cache/
archive/
cleanup-root.sh
scratch.js
scratch-map.js
.cursorignore

# Generated Sitemaps
public/sitemap*.xml

.npm-cache/
fable_dedektif/
public/routes.json

# Generated audit output
audit-output/


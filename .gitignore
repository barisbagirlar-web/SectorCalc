# AI repair local history (never commit)
.sectorcalc/
ai-repair-history.jsonl

# env / secrets
.env
.env.local
.env.batch.keys.local
.env.*.local
*.pem
*.key
*service-account*.json
*firebase-adminsdk*.json
*.private.json
credentials.json

# Build artifacts — regenerated every build (timestamp noise)
steelcore-validation-report.json

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
debug.log
*.log
deploy-debug.log
functions-debug.log

# os/editor
.DS_Store
.vscode/
.idea/

# DeepSeek scan output — committed for Vercel (schemas + generated/*.ts)
# generated/

# TypeScript cache
*.tsbuildinfo
tsconfig.tsbuildinfo
.vercel
.env*.local

# DeepSeek batch runner progress (local only)
.batch-progress*.json
scripts/data/omni-batch.pid

# AI index files (regenerated every prebuild — timestamp noise)
public/ai-categories.json
public/ai-tool-index.json
public/ai-tool-index.txt
public/ai-tool-routes.json

# Build-time sitemap shards (prebuild: generate:sitemap-static)
public/sitemap/*.xml
# Dynamic sitemap index (SSR/ISR, not checked in)
public/sitemap.xml

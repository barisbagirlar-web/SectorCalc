{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/sectorcalc/result-perspectives/universal-result-adapter": [
        "./src/sectorcalc/result-perspectives/universal-result-adapter-runtime.ts"
      ],
      "@/*": [
        "./src/*"
      ],
      "@generated/*": [
        "./generated/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "backup",
    "node_modules",
    "scripts",
    "functions",
    "apps",
    "_safe_vault",
    "archive",
    ".next",
    ".firebase",
    "backups",
    "test-results",
    "tmp",
    "coverage",
    "out",
    "dist",
    "build",
    "public/sw.js",
    "public/wasm",
    "sectorcalc_free_v531_formula_blueprints",
    "sectorcalc_pro_new_v531_package",
    "**/registry.generated.ts",
    "**/bank-grade-financial-projection-covenant-model.formula.ts",
    "**/machining-cycle-time-part-cost-sheet.formula.ts",
    "**/sealed-job-quote-certificate-fire-setup-vade.formula.ts",
    "**/steel-structure-weight-cost-takeoff.formula.ts",
    "**/compressed-air-pipe-sizing-pressure-drop.formula.ts",
    "**/hydraulic-cylinder-pump-sizing.formula.ts",
    "**/pump-system-curve-npsh-verifier.formula.ts",
    "**/shaft-deflection-critical-speed-check.formula.ts",
    "**/scope-1-2-3-splitter-for-smes.formula.ts",
    "**/ppap-gauge-rr-cpk-ppk-quality-submission-bundle.formula.ts",
    "src/app/api/__debug"
  ]
}

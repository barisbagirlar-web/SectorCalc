{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sectorcalc.com/tools/SC-010/v1.0.0/schema.json",
  "title": "True Labor Cost Calculator",
  "description": "Real monthly cost of an employee beyond net salary: employer taxes, benefits, severance, overtime, recruitment.",
  "version": "1.0.0",
  "toolCode": "SC-010",
  "category": "cost",
  "type": "object",
  "required": ["country", "netSalary", "payFrequency"],
  "properties": {
    "country": { "type": "string", "enum": ["US", "TR", "DE", "GB", "IN", "FR"], "description": "Country used for default tax and benefit rates." },
    "netSalary": { "type": "number", "minimum": 0, "default": 3500, "x-unit": "currency", "description": "Monthly net (take-home) salary." },
    "payFrequency": { "type": "string", "enum": ["hourly", "weekly", "biweekly", "monthly"], "description": "How the net salary figure is paid." },
    "hoursPerWeek": { "type": "number", "exclusiveMinimum": 0, "maximum": 80, "default": 40, "x-unit": "h/week", "description": "Average worked hours per week." },
    "employeeRate": { "type": "number", "minimum": 0, "exclusiveMaximum": 1, "x-unit": "ratio", "description": "Employee social contribution rate (0-1). Leave blank for country default." },
    "employerSSRate": { "type": "number", "minimum": 0, "maximum": 1, "x-unit": "ratio", "description": "Employer social security rate (0-1). Leave blank for country default." },
    "employerUnempRate": { "type": "number", "minimum": 0, "maximum": 1, "x-unit": "ratio", "description": "Employer unemployment insurance rate (0-1)." },
    "healthMonthly": { "type": "number", "minimum": 0, "default": 0, "x-unit": "currency", "description": "Monthly employer health insurance cost." },
    "mealMonthly": { "type": "number", "minimum": 0, "default": 0, "x-unit": "currency", "description": "Monthly meal or food allowance." },
    "transportMonthly": { "type": "number", "minimum": 0, "default": 0, "x-unit": "currency", "description": "Monthly transport allowance." },
    "annualBonus": { "type": "number", "minimum": 0, "default": 0, "x-unit": "currency", "description": "Annual bonus amount (spread into monthly cost)." },
    "severanceRate": { "type": "number", "minimum": 0, "maximum": 0.5, "x-unit": "ratio", "description": "Severance accrual rate as a fraction of annual gross." },
    "overtimeHoursMonthly": { "type": "number", "minimum": 0, "maximum": 200, "default": 0, "x-unit": "h/month", "description": "Average overtime hours per month." },
    "overtimeMultiplier": { "type": "number", "minimum": 1, "maximum": 3, "default": 1.5, "x-unit": "x", "description": "Overtime pay multiplier (e.g. 1.5 = time-and-a-half)." },
    "recruitmentCost": { "type": "number", "minimum": 0, "default": 0, "x-unit": "currency", "description": "One-time recruitment cost amortized over tenure." },
    "tenureYears": { "type": "number", "exclusiveMinimum": 0, "maximum": 40, "default": 3, "x-unit": "years", "description": "Expected tenure used to amortize recruitment cost." },
    "currency": { "type": "string", "description": "Currency code for display (optional override)." }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.sectorcalc.com/schemas/SC-020-feeds-speeds-v1.0.0.json",
  "title": "SC-020 CNC Feeds Speeds Tool Life Inputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "materialId",
    "diameterMm",
    "teeth",
    "vcMPerMin",
    "fzMm",
    "apMm",
    "aeMm",
    "spindleKw",
    "spindleTorqueNm",
    "stickOutMm",
    "noseRadiusMm",
    "efficiency",
    "coolant",
    "interruption",
    "toolCost",
    "machineCostPerMin",
    "currency"
  ],
  "properties": {
    "materialId": { "type": "string", "minLength": 1 },
    "diameterMm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "teeth": { "type": "string", "pattern": "^[0-9]+$" },
    "vcMPerMin": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "fzMm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "apMm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "aeMm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "spindleKw": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "spindleTorqueNm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "stickOutMm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "noseRadiusMm": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "efficiency": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "coolant": { "type": "string", "enum": ["dry", "flood", "mist", "mql", "high_pressure"] },
    "interruption": { "type": "string", "enum": ["continuous", "light", "medium", "heavy"] },
    "toolCost": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "machineCostPerMin": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" },
    "currency": { "type": "string", "minLength": 1, "maxLength": 4 },
    "youngModulusMPa": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?$" }
  }
}

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "scripts",
    "functions",
    "apps",
    "backup",
    "backups",
    "archive",
    "_safe_vault",
    ".next",
    ".firebase",
    "test-results",
    "tmp",
    "coverage",
    "out",
    "dist",
    "build",
    "src/app/api/__debug"
  ]
}
